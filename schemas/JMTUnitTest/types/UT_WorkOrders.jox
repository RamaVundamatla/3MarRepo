    <JadeMethod name="iRelTransChangeRoadToShip2" id="a4e05584-dacb-4df4-9307-68f5a0ab2f82">
        <source>iRelTransChangeRoadToShip2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2024	navpw1	Initial creation TFS: 59411 (62272)

*/

constants
	REF					: String = "62272";
	WOID				: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1			: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2			: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3			: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4			: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5			: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6			: String = "UT" &amp; REF &amp; "-6";
	UT_BookingNumber	: String = "UT_" &amp; REF &amp; "BOOK";
	UT_VoyageCode		: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName		: String = "UT_" &amp; REF &amp; "VES";
	UT_BlockStack		: String = REF &amp; "1";
	UT_ReleaseRequest	: String = "UT_" &amp; REF &amp; "REL";
	UT_CargoTypeAbbr	: String = "STEEL COIL";
	UT_ProductCode		: String = "ROLLS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	booking				: CM_BookingRef;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	jobTi,
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReleaseRequest	: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::iRelTransChangeRoadToShip2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	//self.deleteBooking(UT_BookingNumber);
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteTerminalArea(UT_BlockStack);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT)).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus())));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT)).replace(Param3, app.imexStatusEnumToString(tI2.getImExStatus())));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT)).replace(Param3, app.imexStatusEnumToString(tI3.getImExStatus())));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT)).replace(Param3, app.imexStatusEnumToString(tI4.getImExStatus())));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT)).replace(Param3, app.imexStatusEnumToString(tI5.getImExStatus())));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT)).replace(Param3, app.imexStatusEnumToString(tI6.getImExStatus())));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, 6, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
							 "UT MA Resource",
							 "MAN",
							 1,
							 false,
							 true,
							 toDoTaskDescSet
							 );
	
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);								//28.06.2023 navma1 #58920
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,6,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,6,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Delete Booking
	self.deleteBooking(UT_BookingNumber);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_SHIP_STR, UT_BookingNumber, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release request
	
	
	//Verify Booking
	booking := terminal.allBookingRefsByRef[UT_BookingNumber];
	self.assertNotNullMsg(booking, "booking");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	foreach ti in wod.CM_WodRelease.allActionedTIs do :actionedTiLoop
		foreach jobTi in wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems do
			if ti.id = jobTi.id then
				continue actionedTiLoop;
			endif;
			
		endforeach;
		
		self.assertTrueMsg(false, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job missing actioned ti with id: '" &amp; ti.id &amp; "'");
		
	endforeach;
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.opts.purge;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertNullMsg(tI1.myBookingRef, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRef");
	self.assertNullMsg(tI1.myBookingRefItem, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRefItem");
	
	self.assertNullMsg(tI2.myBookingRef, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRef");
	self.assertNullMsg(tI2.myBookingRefItem, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRefItem");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertNotNullMsg(ti.myBookingRef, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRef");
		self.assertTrueMsg(ti.myBookingRef = booking, "Verify Tracked item: '" &amp; ti.id &amp; "' Booking Ref Expected: '" &amp; UT_BookingNumber &amp; "' | Actual: '" &amp; ti.myBookingRef.bookingReference &amp; "'");
		self.assertNotNullMsg(ti.myBookingRefItem, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRefItem");
		self.assertTrueMsg(ti.myBookingRefItem.doesTIMatchMe(ti, false), "Verify Tracked item: '" &amp; ti.id &amp; "' TI Does not match booking ref item");
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
		
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="iRelTransChangeRoadToShip3" id="c526aa69-a3cf-412d-9f45-cce01fc006e6">
        <source>iRelTransChangeRoadToShip3();
/*

Purpose:			Release by type with no cargo items assigned

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2024	navpw1	Initial creation TFS: 59411 (62272)

*/

constants
	REF					: String = "62272";
	WOID				: String = "UT" &amp; REF &amp; "-3";
	UT_ReleaseNumber1	: String = "UT_" &amp; REF &amp; "-3REL1";
	UT_ReleaseNumber2	: String = "UT_" &amp; REF &amp; "-3REL2";
	UT_VoyageCode		: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName		: String = "UT_" &amp; REF &amp; "VES";
	UT_BlockStack		: String = REF &amp; "1";
	UT_CargoTypeAbbr	: String = "STEEL COIL";
	UT_ProductCode		: String = "ROLLS";
	UT_TotalRequested	: Integer = 10;
	UT_QuantityToSplit	: Integer = 5;
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	booking				: CM_BookingRef;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	blockStack			: CM_BlockStack;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReleaseRequest	: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::iRelTransChangeRoadToShip3;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(UT_ReleaseNumber2, null);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	self.deleteTerminalArea(UT_BlockStack);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_SHIP_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Release request
	
	
	//Verify New Releasse Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="iRelTransChangeRoadToShip4" id="e83ba4ee-4620-4dd8-b914-c4fac15e0485">
        <source>iRelTransChangeRoadToShip4();
/*

Purpose:			Release by type with no cargo items assigned (Non-Approved Work Order Split)

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2024	navpw1	Initial creation TFS: 59411 (62272)

*/

constants
	REF					: String = "62272";
	WOID				: String = "UT" &amp; REF &amp; "-4";
	UT_ReleaseNumber1	: String = "UT_" &amp; REF &amp; "-4REL1";
	UT_ReleaseNumber2	: String = "UT_" &amp; REF &amp; "-4REL2";
	UT_VoyageCode		: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName		: String = "UT_" &amp; REF &amp; "VES";
	UT_CargoTypeAbbr	: String = "STEEL COIL";
	UT_ProductCode		: String = "ROLLS";
	UT_TotalRequested	: Integer = 10;
	UT_QuantityToSplit	: Integer = 5;
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	booking				: CM_BookingRef;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	blockStack			: CM_BlockStack;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReleaseRequest	: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::iRelTransChangeRoadToShip4;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(UT_ReleaseNumber2, null);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);								//28.06.2023 navma1 #58920
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	//self.xApproveWorkOrder(workOrder);
	//self.opts.purge;
	//self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	//objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_SHIP_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	//self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release request
	
	
	//Verify New Releasse Request
	releaseRequest2 := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(UT_ReleaseNumber2, null);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoDiscrepWithWO" id="4e71e8ab-7806-4ab7-aedb-50bec0210d35">
        <source>tCargoDiscrepWithWO();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Mar 2025	navhl20 Bug MTN-34322: EUP FR | 54014 - Unable to zero out weight and quantity for cargo attached to a job (Error 88606)

*/

constants
	VoyageID 	= "UT34322_VOY";
	VesselID 	= "34322_VSL";
	CargoID 	= "34322CARGO";
	CargoTypeID = "UT34322_BB";
	WOID		= "WO34322";
vars
	operator		: CM_Operator;
	voyage			: CM_Voyage;
	vessel			: CM_Vessel;
	cargoType 		: CM_CargoType;
	shippingLine	: String;
	lc				: CM_LocationsController;
	height			: Integer;
	cargoOnShip 	: CM_TrackedItem;
	term			: CM_Terminal;
	tiSet 			:  CM_TISet;
	pxyWod			: CM_WorkOrderDtl;
	wodArr			: CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder		: CM_WorkOrder;
	realJobSheet	: CM_WorkPointJobSheet;
	extRef1,
	extRef2,
	remarks			: String;
	pxyVoyJob		: CM_VoyageWorkPointJob;
	voyJob			: CM_VoyageJob;
	firstJob,
	secondJob		: CM_Job;
	useYardJobsSet,
	canAutoActTiWo,
	zeroOut,
	keepAsIs		: 	Any;
begin
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSet := term.getConfig(UseYardJobsCargoWO);
	canAutoActTiWo := term.getConfig(AllowAutoActionCargoWo);
	keepAsIs 	   := term.getConfig(StateShortlandZeroQtyWgt);
	zeroOut 	   := term.getConfig(DisallowDiscrepZero);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(StateShortlandZeroQtyWgt, CMIF_ConfigTerminal.State_KeepAsIs);
	term.setConfig(DisallowDiscrepZero, false);
	commitTransaction;
	
	operator 		:= self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	shippingLine 	:= self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString();
	cargoType 		:= self.addCargoType(CargoTypeID, false);
	
	// Create Vesse; and Voyage
	vessel := self.addVesselWithHolds(VesselID, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageID, vessel.name, vessel.myOperator.code, shippingLine, 0);
	
	self.getTerminal.findLocationFromString(VoyageID, true, lc, height); 
	
	// Create Cargo and put it on ship
	cargoOnShip := self.addCargoBreakBulkAtLocation(CargoID, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", 500);
	self.updateTI(cargoOnShip);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(cargoOnShip);
	
	self.deleteWorkOrderNoValidation(WOID);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_34322");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF134322";
	extRef2 		:= "UT_REF1234322";
	remarks 		:= "UT_REMARKS34322";
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	
	// Do the discrepancy
	// Expecting the discrepancy transaction created to be "CM_ShipDescrepancy" because the TI is onShip;
	app.myTrxUA.trxBreakBulkOverage(cargoOnShip, null, 0, 0, 0, 0, "UT56436_ONSHPDISC", true, false, false, app.myPassport);
	if app.myPassport.hasErrorsOrWarnings() then
		app.myPassport.warningsAcknowledged	:= true;
		app.myTrxUA.trxBreakBulkOverage(cargoOnShip, null, 0, 0, 0, 0, "UT56436_ONSHPDISC", true, false, false, app.myPassport);
	endif;
	
	self.assertTrue(cargoOnShip.hasTransactionOfType(TRANS_TYPE_DISCREPANCY_SHIP));
	
	// Clean up
	app.myTrxUA.trxWOUnApprove(workOrder,app.myPassport);
	self.deleteTrackedItem(cargoOnShip, false);
	self.deleteCargoType(CargoTypeID);
	self.deleteVoyage(VoyageID);
	self.deleteVessel(VesselID);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSet);
	term.setConfig(AllowAutoActionCargoWo, canAutoActTiWo);
	term.setConfig(StateShortlandZeroQtyWgt, keepAsIs);
	term.setConfig(DisallowDiscrepZero, zeroOut);
	commitTransaction;
	delete tiSet;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyVoyJob;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobChangeVoyage" id="89e7c127-fa93-41e0-9447-6312fd29f9b9">
        <source>tCargoJobChangeVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
*/

constants
	REF  : String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JCV1';
vars
	tI1, 
	tI2					:	CM_TrackedItem;
	workOrder,
	pxyWorkOrder		:	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	tiSet				: 	CM_TISet;
	wod,
	pxyWod				: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	voyage				: CM_Voyage;
	term				: CM_Terminal;
begin
	
	/*
	** Setup Section, create the work order with a change voyage task with multiple tracked items
	*/
	term 	 := self.getMyTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	

	// Setup the work order options
	tI1 := self.xAddCargo("UTCNT1" &amp; REF,null,TI_STATE_NORMAL,null);
	tI2 := self.xAddCargo("UTCNT2" &amp; REF,null,TI_STATE_NORMAL,null);
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141:[56147]
	tiSet.add(tI2);					//12.01.2023 navma1 #56141:[56147]
	
	voyage := self.xAddVoyage("HLVES"&amp;REF,"HLVOY"&amp;REF);
	
	self.opts.purge();
	self.opts.addAssoc('WOId', 	   		WOID);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',     WO_TASK_CHANGEVOYAGE );
	self.opts.addAssoc('Voyage',       voyage.code);
	self.opts.addAssoc('dtArrived',    voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodNullVoyage transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_CHANGEVOYAGE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TICHGVOY_CREATED,false,false);
	
	// Approve the work order
	self.xApproveWorkOrder(workOrder);
	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TICHGVOY_UPDATED,false,false);	
	
	// Action the work order
	self.xActionWorkOrder(workOrder);
	
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TICHGVOY_UPDATED,true,false);	
	

epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobExportReturn" id="5faf55be-b605-4115-88eb-4787713fa074">
        <source>tCargoJobExportReturn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
*/

constants
	REF	 : String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JER1';
vars
	tI1, tI2			: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	job 				: CM_Job;
	wle					: CM_WOWLE;
	tiSet				: CM_TISet;
	wod					: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod				: CM_WorkOrderDtl;
	pxyWorkOrder,
	realWorkOrder		: CM_WorkOrder;
	term				: CM_Terminal;
begin
	/*
	** Setup Section, create the work order with a export returned task with multiple tracked items
	*/
	
	term := self.getMyTerminal;
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);

	// Setup the work order options
	// Setup the work order options
	tI1 := self.xAddCargo("UTCNT1" &amp; REF,null,TI_STATE_NORMAL,null);
	tI2 := self.xAddCargo("UTCNT2" &amp; REF,null,TI_STATE_NORMAL,null);	
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_EXPORTRETURN );
	
	// Create the work order
	create pxyWod as CM_WodExportReturn transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_EXPORTRETURN,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,realWorkOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := realWorkOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIEXPRET_CREATED,false,false);
	
	
	// Approve the work order
	self.xApproveWorkOrder(realWorkOrder);	
	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIEXPRET_UPDATED,false,false);	
	
	// Action the work order
	self.xActionWorkOrder(realWorkOrder);	
	
	// Export Return From Approved to Complete
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIEXPRET_UPDATED,true,false);
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobMove" id="c0b471b3-3fbc-44ff-9442-15de97f1f7fe">
        <source>tCargoJobMove();
/*

Purpose:			
A test to ensure we can move cargo for work orders when the option to use yard jobs for work orders has been selected

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2022	navcs2	
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/
constants
	REF = UT_DSL.TFS53038;
	WOID : String  = 'UT'&amp;REF&amp;'JMV1';
vars
	blockstack1, blockstack2	: CM_BlockStack;
	tI1, tI2					: CM_TrackedItem;
	useYardJobsSetting			: Any;
	tiSet						: CM_TISet;
	wod							: CM_WorkOrderDtl;
	wodArr						: CM_WorkOrderDtlArray;
	pxyWod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	realWorkOrder				: CM_WorkOrder;
	canAutoActionTiWo			: Boolean;
begin
	
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := self.getTerminal.getConfig(AllowAutoActionCargoWo).Boolean;
	
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	deleteWorkOrderNoValidation(WOID);

	deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	deleteTerminalArea("UTBS2" &amp; REF);
	blockstack2 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	create tiSet transient;
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(tI1, blockstack1);
	tiSet.add(tI1);
	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	move(tI2, blockstack1);
	tiSet.add(tI2);
	
	self.opts.purge();
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_MOVE );
	self.opts.addAssoc('autoRTQ',true );
	
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,realWorkOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := realWorkOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIMOVE_CREATED,false,false);


	self.assertEqual(tI1.locationId, blockstack1.id);
	self.assertEqual(tI2.locationId, blockstack1.id);

	
	self.xApproveWorkOrder(realWorkOrder);
	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIMOVE_UPDATED,false,false);
	
	
	self.xActionWorkOrder(realWorkOrder);

	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIMOVE_UPDATED,true,false);
	
	
	self.assertEqual(tI1.myPrimaryQueuedLocation, blockstack2.myLocationsController);
	self.assertEqual(tI2.myPrimaryQueuedLocation, blockstack2.myLocationsController);
	
	self.move(tI1, tI1.myPrimaryQueuedLocation);
	
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,2,TRANS_TYPE_WO_TIMOVE_UPDATED,false,false);
	
	self.assertEqual(wod.CM_WorkOrderTIDtl.allCompleteTIs.size,1);
	
	self.move(tI2, tI2.myPrimaryQueuedLocation);
	
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIMOVE_COMPLET,false,false);
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobPack" id="528dd03b-4b01-441c-abfd-ea66f9ffb374">
        <source>tCargoJobPack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF: String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JPK1';
vars
	tI1, tI2			:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	subTermWo			: 	Any;
	tiSet,
	childTiSet			: 	CM_TISet;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	cargoType			: 	CM_CargoType;
	packingCargo1,
	packingCargo2		: 	CMIF_InOutAttachment;
	attachments			: 	CMIF_InOutAttachmentArray;
	terminal			: 	CM_Terminal;
	vessel 				: 	CM_Vessel;
	voyage				: 	CM_Voyage;
	subTerm1			: 	CM_SubTerminal;
begin
	/*
	** Setup Section, create the work order with a pack task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting 	:= self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	:= self.getTerminal.getConfig(AllowAutoActionCargoWo);
	subTermWo 			:= self.getTerminal.getConfig(IsSubTerminalsOn);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	self.getTerminal.setConfig(IsSubTerminalsOn,false);
	commitTransaction;
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	self.deleteWorkOrderNoValidation(WOID);

	// Setup the work order options
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	cargoType := self.getCargoType("LCL Cargo");
	assertNotNull(cargoType);
	
	self.deleteCargo(REF &amp; "PACK1", cargoType);
	self.deleteCargo(REF &amp; "PACK2", cargoType);
	
	create packingCargo1 transient;
	packingCargo1.set(terminal, cargoType.id, REF &amp; "PACK1", "", 100); 
	packingCargo1.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create packingCargo2 transient;
	packingCargo2.set(terminal, cargoType.id, REF &amp; "PACK2", "", 190); 
	packingCargo2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(packingCargo1);
	
	self.addContainerChildren(tI1.CM_Container, attachments);
	self.assertEqualMsg(tI1.allChildren.size(), 1, "Doesn't have one children");
	
	attachments.clear();
	attachments.add(packingCargo2);
	
	self.addContainerChildren(tI2.CM_Container, attachments);
	self.assertEqualMsg(tI2.allChildren.size(), 1, "Doesn't have one children");
	
	create childTiSet transient;
	childTiSet.add(tI1.allChildren.first);
	childTiSet.add(tI2.allChildren.first);
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147
	
	vessel := self.addVesselWithHolds("UT_HLVES1", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_HLVOY1", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.deleteSubTerminal("SubTerm1");
	subTerm1 := self.addSubTerminal("SubTerm1", SubTermType_Depot_Int);

	self.opts.purge();
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('SubTerminal', subTerm1.code);
	
	create pxyWod as CM_WodPack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,null,tiSet,childTiSet);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIPACK_CREATED,false,false);
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIPACK_UPDATED,false,false);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIPACK_UPDATED,true,false);
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	self.getTerminal.setConfig(IsSubTerminalsOn,subTermWo);
	commitTransaction;
	delete tiSet;
	delete packingCargo1;
	delete packingCargo2;
	delete attachments;
	delete childTiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobPackByType" id="96a63715-ef68-4be5-accc-346cc463b5ef">
        <source>tCargoJobPackByType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2023 navhl20 ChangeRequest 59819:[60443] EUP | Delivery Dispatch Screen - Unit Tests - [3]
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

constants
	REF	 : String  =  "60443";
	WOID : String  = 'UT'&amp;REF&amp;'JPT';
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVOY" &amp; REF;
	WPJS : String = "UT58336JS";
	TruckId : String = 'UTTRK1'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	hideMoveConfirmation 	: Boolean;
	packingCargo1,
	packingCargo2			: CM_TrackedItem;
	attachments				: CMIF_InOutAttachmentArray;
	packTIs					: CM_TIArray;
	wh						: CM_IrregularBlockArea;
	before,
	after					: Integer;
	pxy						: CM_ProxyLink;
	cargoType				: CM_CargoType;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL1");
	self.deleteVoyage(Voyage);
	
	// vessel and voyage	
	vessel := self.addVesselWithHolds("UTHLVESS1", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteContainer("UTHL01" &amp; REF);
	self.deleteContainer("UTHL02" &amp; REF);
	self.deleteContainer(REF &amp; "PACK1");
	self.deleteContainer(REF &amp; "PACK2");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	tI1 := self.addContainerOpts("UTHM01" &amp; REF, "2200", "MT", operator);	
	tI2 := self.addContainerOpts("UTHM02" &amp; REF, "2200", "MT", operator);
	
	self.move(tI1, blockStack);	
	self.move(tI2, blockStack);
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("GVS"));
	
	wh := terminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK1", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	packingCargo2 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK2", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc('Number', 2);
	self.opts.addAssoc('NumberSec', 200);
	self.opts.addAssoc('ISOType', "2200");
	self.opts.addAssoc('CargoType', cargoType);
	self.opts.addAssoc('PackType', CM_ReserveDetail.PackType_Parent);
	self.opts.addAssoc('PackType1', CM_ReserveDetail.PackType_Child);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UHLREL1", BR_TYPE_PACKING, 1);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	create pxyWod as CM_WodPack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	
	app.myTrxUA.trxUpdatePackCargo(tI1, packingCargo1, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);	//19.03.2024 navhl20 #62863
	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease,releaseRequest);
	self.packCompleteContainer(tI1.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_PART_COMPLETE, "The job has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_PART_COMPLETE, "The job has not been part completed");
	
	app.myTrxUA.trxUpdatePackCargo(tI2, packingCargo2, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);	//19.03.2024 navhl20 #62863
	self.packCompleteContainer(tI2.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_COMPLETED, "The job has not been completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_COMPLETED, "The job has not been completed");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete packTIs;
	delete attachments;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobPackMulti" id="6a2686bd-228a-4d40-a110-76e0837aa989">
        <source>tCargoJobPackMulti();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2023	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF	 : String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JPK2';
vars
	tI1, tI2,tI7,
	tI3,tI4,tI5,tI6		:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	subTermWo			: 	Any;
	toDoTaskDesc,
	toDoTaskDesc1,
	toDoTaskDesc2		: 	CM_ToDoTaskDesc;
	tiSet,
	tiSet1,
	tiSet2,
	tiSet3				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet,
	todoSet1			: 	CM_ToDoTaskDescSet;
	blockstack1			: 	CM_BlockStack;
	cargoType			: 	CM_CargoType;
	packingCargo1,
	packingCargo2,
	packingCargo3,
	packingCargo4,
	packingCargo5,
	packingCargo6,
	packingCargo7		:	CM_TrackedItem;
	attachments			: 	CMIF_InOutAttachmentArray;
	terminal			: 	CM_Terminal;
	packTIs				: 	CM_TIArray;
	wh					: 	CM_IrregularBlockArea;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	pxyWod1,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	vessel 				: 	CM_Vessel;
	voyage				: 	CM_Voyage;
	subTerm1			: 	CM_SubTerminal;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	subTermWo 			:= self.getTerminal.getConfig(IsSubTerminalsOn);
	
	beginTransaction;
		self.getTerminal.setConfig(UseYardJobsCargoWO, true);
		self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
		self.getTerminal.setConfig(IsSubTerminalsOn,false);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);

	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	self.deleteContainer("UTCNT3" &amp; REF);
	self.deleteContainer("UTCNT4" &amp; REF);
	
	//Creating cargos for detail -1
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI3 := self.addContainerOpts("UTCNT3" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI4 := self.addContainerOpts("UTCNT4" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	self.deleteContainer("MATCHILD003");
	self.deleteContainer("MATCHILD004");
	self.deleteContainer("MATCHILD005");
	self.deleteContainer("MATCHILD006");
	self.deleteContainer("MATCHILD007");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addContainerAtLocation("MATCHILD001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	packingCargo2 := self.addContainerAtLocation("MATCHILD002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	packingCargo3 := self.addContainerAtLocation("MATCHILD003", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	packingCargo4 := self.addContainerAtLocation("MATCHILD004", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	packingCargo5 := self.addContainerAtLocation("MATCHILD005", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	packingCargo6 := self.addContainerAtLocation("MATCHILD006", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	packingCargo7 := self.addContainerAtLocation("MATCHILD007", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	
	self.deleteTerminalArea("HUT01" &amp; REF);
	blockstack1 := addBlockStack("HUT01" &amp; REF, 10, null);
	
	self.deleteTerminalArea("HUT02" &amp; REF);
	blockstack1 := addBlockStack("HUT02" &amp; REF, 10, null);
	
	self.move(tI1, blockstack1);	
	self.move(tI2, blockstack1);
	self.move(tI3, blockstack1);
	self.move(tI4, blockstack1);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);		
	
	self.deleteContainer("UTCNT5" &amp; REF);
	self.deleteContainer("UTCNT6" &amp; REF);
	self.deleteContainer("UTCNT7" &amp; REF);
	
	//Creating cargos for detail -2
	tI5 := self.addContainerOpts("UTCNT5" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI6 := self.addContainerOpts("UTCNT6" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI7 := self.addContainerOpts("UTCNT7" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	self.move(tI5, blockstack1);	
	self.move(tI6, blockstack1);
	self.move(tI7, blockstack1);
	
	create tiSet1 transient;
	tiSet1.add(tI5);
	tiSet1.add(tI6);
	tiSet1.add(tI7);


	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("UTDO13423",TODO_TYPE_GROUP_TI); 								//1
	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc["Todo11"];
	if toDoTaskDesc1 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc1);
	endif;
	toDoTaskDesc1 := self.createToDoTaskDesc("Todo11");					//2
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc["Todo12"];
	if toDoTaskDesc2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc2);
	endif;
	toDoTaskDesc2 := self.createToDoTaskDesc("Todo12");					//3
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	toDoTaskDescSet.add(toDoTaskDesc1);
	toDoTaskDescSet.add(toDoTaskDesc2);
	
	self.addToDoTaskResource("UTHLRES1",
											 "UT HL Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	todoSet.add(toDoTaskDesc1);
	todoSet.add(toDoTaskDesc2);
	
	create todoSet1 transient;
	todoSet1.add(toDoTaskDesc);
	todoSet1.add(toDoTaskDesc1);
	
	create tiSet2 transient;
	tiSet2.add(packingCargo1);
	tiSet2.add(packingCargo2);
	tiSet2.add(packingCargo3);
	tiSet2.add(packingCargo4);	
	
	create tiSet3 transient;
	tiSet3.add(packingCargo5);
	tiSet3.add(packingCargo6);
	tiSet3.add(packingCargo7);
	
	vessel := self.addVesselWithHolds("UT_HLVES1", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_HLVOY1", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.deleteSubTerminal("SubTerm1");
	subTerm1 := self.addSubTerminal("SubTerm1", SubTermType_Depot_Int);

	self.opts.purge();
	self.opts.addAssoc('TargetTA', "HUT02" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);	
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('SubTerminal', subTerm1.code);
	
	// Create the work order
	create pxyWod as CM_WodPack transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,todoSet,tiSet,tiSet2);
	
	create pxyWod1 as CM_WodPack transient;
	self.xCreateWorkOrderDetail(pxyWod1,WO_TASK_PACK,todoSet1,tiSet1,tiSet3);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIPACK_CREATED,false,false);
	
	//  Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIPACK_UPDATED,false,false);	
	
	//  Approve the work order
	self.xActionWorkOrder(workOrder);	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIPACK_UPDATED,true,false);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	//Completing half task in detail- 1
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.assertEqualMsg(wod.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	//Completing half task in detail -2
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.assertEqualMsg(workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	//Completing remaining tasks in detail -1
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc2,tiSet,null);
	self.assertEqualMsg(wod.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	//Completing remaining tasks in detail -2
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	self.assertEqualMsg(workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	create packTIs transient;
	packTIs.add(packingCargo1);
	self.packContainer(tI1.CM_Container, packTIs);
	self.packCompleteContainer(tI1.CM_Container);
	
	packTIs.clear();
	packTIs.add(packingCargo2);
	self.packContainer(tI2.CM_Container, packTIs);
	self.packCompleteContainer(tI2.CM_Container);
	
	packTIs.clear();
	packTIs.add(packingCargo3);
	self.packContainer(tI3.CM_Container, packTIs);
	self.packCompleteContainer(tI3.CM_Container);
	
	packTIs.clear();
	packTIs.add(packingCargo4);
	self.packContainer(tI4.CM_Container, packTIs);
	self.packCompleteContainer(tI4.CM_Container);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,4,TRANS_TYPE_WO_TIPACK_UPDATED,true,false);
	
	packTIs.clear();
	packTIs.add(packingCargo5);
	self.packContainer(tI5.CM_Container, packTIs);
	self.packCompleteContainer(tI5.CM_Container);
	
	packTIs.clear();
	packTIs.add(packingCargo6);
	self.packContainer(tI6.CM_Container, packTIs);
	self.packCompleteContainer(tI6.CM_Container);
	
	packTIs.clear();
	packTIs.add(packingCargo7);
	self.packContainer(tI7.CM_Container, packTIs);
	self.packCompleteContainer(tI7.CM_Container);
	
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,4,TRANS_TYPE_WO_TIPACK_COMPLET,true,false);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_COMPLETE,3,TRANS_TYPE_WO_TIPACK_COMPLET,true,false);
epilog
	beginTransaction;
		self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
		self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
		self.getTerminal.setConfig(IsSubTerminalsOn,subTermWo);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	delete todoSet1;
	delete tiSet1;
	delete tiSet2;
	delete tiSet3;
	delete attachments;
	delete packTIs;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobReceiveRail" id="21810389-d195-40ba-9522-365f8ab5c1eb">
        <updating/>
        <source>tCargoJobReceiveRail()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jul 2023	navma1	ChangeRequest 58342: EUP | Delivery Dispatch Screen - Rail Operation
25 Jul 2023	navlw1	ChangeRequest 58336: [59189] EUP | Delivery Dispatch Screen - Unit Tests [Receive Rail]

*/
constants
	REF: String    =  UT_DSL.TFS58342.String;
	WOID : String  = 'UT'&amp;REF&amp;'JRC1';
	MyTrain : String = 'TR-UT'&amp;REF;
	MyWagon : String = "UK-"&amp;REF&amp;"_1";
	RailAreaId : String	= "UT" &amp; REF;
	BlockStack : String = "UT1" &amp; REF;
	WagonClass : String = "US";
	YA : String = 'UT_YA';
vars
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	term			    : CM_Terminal;
	voyage				: CM_Voyage;
	vessel				: CM_Vessel;
	booking				: CM_BookingRef;
	tI1, 
	tI2					: CM_TrackedItem;
	tiSet				: CM_TISet;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	job 				: CM_Job;
	train,
	pxyTrain 			: CM_Train;
	wagon1 				: CM_Wagon;
	railArea 			: CM_Rail;
	railLine			: CM_RailLine;
	bs1					: CM_BlockStack;
	wagonClass 			: CM_WagonClass;
	wagonMaster			: CM_WagonMaster;
	tiSetDup 			: CM_TIByIdDups;
	wle					: CM_WorkListEntry;
	cmifRakeRegion		: CMIF_RakeRegion;
	trainSet			: CM_TrainSet;
	pxyMaster			: CM_WagonMaster;
begin
	/*
	** Setup Section, create the work order with a receive cargo task with multiple tracked items
	*/
	
	term := self.getMyTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, true);
		term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(MyTrain,null);
	self.deleteRailArea(RailAreaId);
		
	voyage  := self.xAddVoyage("UTVSL"&amp;REF, 'UTVOY'&amp;REF);
	self.assertNotNullMsg(voyage,"Voyage has not been created");
	
	booking := self.xAddBooking('UTBK'&amp;REF,voyage);
	self.assertNotNullMsg(booking,"Booking has not been created");
	
	// create train
	train := self.addTrain(MyTrain, null);
	self.assertNotNullMsg(train, "train not created");
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[WagonClass];
	self.assertNotNullMsg(train, "Cannot find wagon class");
	
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	// create the block stack where the containers will be stored after discharged
	self.deleteTerminalArea(BlockStack);
	bs1 := self.addBlockStack(BlockStack, 10, null);
	
	self.disableAllYA (true);
	self.deleteYA (YA);
	self.addYACatchAll (YA, bs1);
	
	// create the wagon master
	create pxyMaster transient;
	pxyMaster.setProxy(MyWagon, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	self.assertNoTrxErrorsOrWarnings();
	
	// create prenoted cargo
	self.opts.addAssoc("TransMode", TI_TRANSMODE_RAIL_STR);
	tI1 := self.xAddCargo("UTCNT1" &amp; REF,voyage,TI_STATE_NOTIFIED,'UTBK'&amp;REF);
	tI2 := self.xAddCargo("UTCNT2" &amp; REF,voyage,TI_STATE_NOTIFIED,'UTBK'&amp;REF);
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);
	
	create tiSetDup transient;
	tiSetDup.add(tI1);					
	tiSetDup.add(tI2);
	
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	self.assertNotNullMsg(wagonMaster, "Couldn't find wagon master");
	
	// create the wagon and add the trackedItems to it
	wagon1 := self.addWagonToTrainOption2(train, wagonMaster, tiSetDup, false);
	self.assertNotNullMsg(wagon1, "Wagon not created");
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon1, 1, app.myPassport);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_RAIL);
	self.opts.addAssoc('booking','UTBK'&amp;REF);
	// these two settings are used to get the train and set it on the work order
	self.opts.addAssoc('transObj', MyTrain);
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;
	
	// Make the train arrive
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	// confirm the train IN 
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Switch to the wagon
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// discharge the tracked item from the wagon
	wle := tI1.allWorklistEntries.first;
	self.assertNotNull (wle);
	
	self.moveQueuedCargo (wle);
	// check the work order is part complete
	//self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	// discharge the second tracked item from the wagon
	wle := tI2.allWorklistEntries.first;
	self.assertNotNull (wle);
	
	self.moveQueuedCargo (wle);
	// check the work order is complete
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	// depart the train 
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);  //iout
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon1);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
epilog
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
		term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete tiSetDup;
	delete pxyTrain;
	delete cmifRakeRegion;
	delete trainSet;
	delete pxyMaster; 
	
	self.disableAllYA (false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobReceiveRoadMulti" id="dbad604f-a2a8-4bb1-a4be-54a73037f1ff">
        <updating/>
        <source>tCargoJobReceiveRoadMulti()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Apr 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
*/

constants
	REF: String  =  "55443";
	WOID : String  = 'UT'&amp;REF&amp;'JRC2';
vars
	tI1, tI2,tI7,
	tI3,tI4,tI5,tI6		:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	gateAutoComplete,
	hhUnloadEdit		: 	Any;
	toDoTaskDesc,
	toDoTaskDesc1,
	toDoTaskDesc2		: 	CM_ToDoTaskDesc;
	tiSet,
	tiSet1				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet,
	todoSet1			: 	CM_ToDoTaskDescSet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	booking				: 	CM_BookingRef;
	vvr,
	vvr1				: 	CM_VehicleVisitRecord;
	truckName, 
	driverName			: 	String;
	dualGate			: 	CM_Gate;
	yic					:	CM_YardInterchangeArea;
	pin					:	CM_GateArea;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	pxyWod1,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	job					:	CM_RoadJob;
	wle					:	CM_WorkListEntry;
	term				:   CM_Terminal;
	createPin          	: Boolean;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	term			   := self.getTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	gateAutoComplete   := term.getConfig(GateInAutoCompleteBkgrnd);
	hhUnloadEdit   	   := term.getConfig(HhTUnloadEdit);
	createPin          := self.getTerminal.getConfig(NoPINs).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(GateInAutoCompleteBkgrnd, true);
	term.setConfig(HhTUnloadEdit, true);
	term.setConfig(NoPINs, false);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT2"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT3"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT4"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT5"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT6"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT7"), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT2");
	tI3 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT3");
	tI4 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT4");		
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);		
	
	//Creating cargos for detail -2
	tI5 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT5");	
	tI6 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT6");
	tI7 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT7");		
	
	create tiSet1 transient;
	tiSet1.add(tI5);
	tiSet1.add(tI6);
	tiSet1.add(tI7);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc["Todo1"];
	if toDoTaskDesc1 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc1);
	endif;
	toDoTaskDesc1 := self.createToDoTaskDesc("Todo1");					//2
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc["Todo2"];
	if toDoTaskDesc2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc2);
	endif;
	toDoTaskDesc2 := self.createToDoTaskDesc("Todo2");					//3
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	toDoTaskDescSet.add(toDoTaskDesc1);
	toDoTaskDescSet.add(toDoTaskDesc2);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	todoSet.add(toDoTaskDesc1);
	todoSet.add(toDoTaskDesc2);
	
	create todoSet1 transient;
	todoSet1.add(toDoTaskDesc);
	todoSet1.add(toDoTaskDesc1);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCONT1" &amp; "," &amp; "UTCONT2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create pxyWod1 as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod1,WO_TASK_RECEIVE,todoSet1,tiSet1,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	//Completing half task in detail- 1
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.assertEqualMsg(wod.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	//Completing half task in detail -2
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.assertEqualMsg(workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	//Completing remaining tasks in detail -1
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc2,tiSet,null);
	self.assertEqualMsg(wod.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	//Completing remaining tasks in detail -2
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	self.assertEqualMsg(workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	self.gateInPinReceival(workOrder.getPINNumber,'UTTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Allocate job to jobSheet
	job := term.myWOJobSheet.allJobsByRequiredDTPriority[workOrder.requiredByDT,3].CM_RoadJob;
	
	//Complete workOrder
	foreach wle in job.workListEntries do
		self.queueWLE(wle);
	endforeach;
	self.moveVehicleToYard(job.myVehicle);
	foreach wle in job.workListEntries do
		self.moveWLE(wle);
	endforeach;
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,4,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_COMPLETE,3,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
	self.roadExit(job.myVehicleVisit);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(GateInAutoCompleteBkgrnd, gateAutoComplete);
	term.setConfig(HhTUnloadEdit, hhUnloadEdit);
	term.setConfig(NoPINs, createPin);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	delete todoSet1;
	delete tiSet1;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobRecieveRoad" id="446db9e2-e02b-431b-8dde-f9a51e8443eb">
        <source>tCargoJobRecieveRoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
28 Jun 2023 navma1  Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
*/

constants
	REF: String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JRC1';
vars
	tI1, tI2			:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	job 				: 	CM_Job;
	tiSet				: 	CM_TISet;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a receive cargo task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);

	// Setup the work order options
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147

	beginTransaction;
	tI1.changeState(TI_STATE_NOTIFIED, app.myPassport);
	tI2.changeState(TI_STATE_NOTIFIED, app.myPassport);
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);	
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );								//28.06.2023 navma1 #58920
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;

epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobRecieveShip" id="d8398125-c1b0-4342-b852-dc74dc50c57e">
        <source>tCargoJobRecieveShip();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 June 2023	navlw1	Initial creation

*/
constants
	REF		: String  = '58730';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = 'UTWORECIEVESHIP';
vars
	voyage 			: 	CM_Voyage;
	bol, realBol 	:	CM_BOL;
	bolDetail		:	CM_BOLDtl;
	tI1, tI2,
	pxyTi			:	CM_TrackedItem;
	vessel 			:	CM_Vessel;
	term			:	CM_Terminal;
	tiSet 			: 	CM_TISet;
	operator		: 	CM_Operator;
	dischargePort 	:	CM_Port;
	pxyWod,
	wod				: 	CM_WorkOrderDtl;
	wodArr			: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder		: 	CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);
	
	// terminal
	term := self.getTerminal();	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTLWVOY"&amp;REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	// tracked items
	tI1 := self.xAddCargo("UTCON1" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI1);
	
	tI2 := self.xAddCargo("UTCON2" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI2);
	
	pxyTi := app.createUpdateProxy(tI1).CM_TrackedItem;
	
	create tiSet transient;
	tiSet.add(pxyTi);					
	// tiSet.add(tI2);				
	
	bolDetail := bol.allBOLDtls.first;
	app.myTrxUA.trxUpdateTIBOL(tiSet,bol,bolDetail,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(bolDetail.allTrackedItems.first,tI1);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	
	//re get the tracked item
	tI1 := self.getTrackedItem("UTCON1" &amp; REF);
	self.assertNotNull(tI1);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
epilog
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobReleaseRail" id="eb748813-6fe2-4d0a-8b03-10aa8e8c6df2">
        <source>tCargoJobReleaseRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jul 2023	navlw1	ChangeRequest 58336: [59296]EUP | Delivery Dispatch Screen - Unit Tests [Release Rail]

*/
constants
	REF 			: String = UT_DSL.TFS58342.String;
	MyTrain 		: String = 'UTTR2'&amp;REF;
	MyWagon 		: String = "UK-"&amp;REF&amp;"_2";
	RailAreaId 		: String = "UTRA1";
	BlockStack 		: String = "UTBS2" &amp; REF;
	WagonClass		: String = "US";
	YA 				: String = 'UT_YA_'&amp;REF;
	CargoId1		: String = "UTCNT5"&amp;REF;
	CargoId2		: String = "UTCNT6"&amp;REF;
	WOID 			: String = 'UT'&amp;REF&amp;'JRC2';
	ReleaseRequest 	: String = "UTBULKREQ"&amp; REF;
vars
	releaseRequest 		: CM_BulkRelease;
	train,
	pxyTrain			: CM_Train;
	wagonMaster			: CM_WagonMaster;
	term 				: CM_Terminal;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	railArea 			: CM_Rail;
	pxyMaster			: CM_WagonMaster;
	wagonClass			: CM_WagonClass;
	tI1,
	tI2					: CM_TrackedItem;
	bs1 				: CM_BlockStack;
	operator 			: CM_Operator;
	tiSet				: CM_TISet;
	wod,
	pxyWod				: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	job 				: CM_Job;
	wle					: CM_WorkListEntry;
	code 				: String;
	relTime				: TimeStamp;
	wagon 				: CM_Wagon;
	railLine			: CM_RailLine;
	lc					: CM_LocationsController;
	cmifObjects 		: ObjectArray;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	railIORake 			: CM_RailJSInOutRake;
	obj 				: Object;
	cmifMoveController	: CMIF_MoveController;
	wleArray,
	wlesWithWarnings,
	allWleArray			: CM_WLEArray;
	allRailJobsArray	: CM_RailJobArray;
	agent				: CM_RailProcessingAgent;
	wagonArray			: CM_WagonArray;
	railJob 			: CM_RailJob;
	cmifRakeRegion		: CMIF_RakeRegion;
	trainSet 			: CM_TrainSet;
begin
	term := self.getMyTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, true);
		term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// setup delete stuff
	self.deleteWorkOrderNoValidation(WOID);
	
	self.deleteContainer(CargoId1);
	self.deleteContainer(CargoId2);
	self.deleteReleaseRequest(ReleaseRequest);
		
	// wagon master stuff
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	self.deleteTrain(MyTrain,null);
	self.deleteRailArea(RailAreaId);
	
	// create the train and wagons
	train := self.addTrain(MyTrain,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[WagonClass];
	self.assertNotNullMsg(train, "Cannot find wagon class");
	
	create pxyMaster transient;
	pxyMaster.setProxy(MyWagon, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	self.assertNoTrxErrorsOrWarnings();
	
	wagon := self.addWagon(MyWagon,wagonClass.code,train);
	self.assertNotNullMsg(wagon, "Wagon not created");
	
	// create the blockstack
	self.deleteTerminalArea(BlockStack);
	bs1 := self.addBlockStack(BlockStack, 10, null);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	self.disableAllYA (true);
	self.deleteYA (YA);
	self.addYACatchAll (YA, bs1);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	// create the tracked items
	tI1 := self.addContainerOpts(CargoId1, "2200", "MT", operator);
	self.assertNotNullMsg(tI1, "TrackedItem");
	tI2 := self.addContainerOpts(CargoId2, "2200", "MT", operator);
	self.assertNotNullMsg(tI2, "TrackedItem");
	
	// move the containers to the blockstack
	self.move(tI1, bs1.myLocationsController);
	self.move(tI2, bs1.myLocationsController);
	
	self.deleteStops(tI1);
	self.deleteStops(tI2);
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);
	 
	// create the release request
	self.opts.purge();
	self.opts.addAssoc("ISOType", '2200');
	self.opts.addAssoc("ISOGroup", 'GEN2');
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	// self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc('Number', 2);
	releaseRequest := self.addReleaseById(ReleaseRequest,BR_TYPE_RAIL,tiSet);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_RAIL);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	// these two settings are used to get the train and set it on the work order
	self.opts.addAssoc('transObj', MyTrain);
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;
	
	self.opts.addAssoc("release", releaseRequest);
	// assign release to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	
	//cmifRequest.quantityTxt := releaseRequest.allReserveDetails.first.totalRequested;
	
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// arrive the train
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	railLine.switchPositions(wagon, 01);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	// confirm the train IN 
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	create allRailJobsArray transient;
	foreach railJob in railIORake.railJobs do 
		allRailJobsArray.add(railJob);
	endforeach;
	
	// get the rail jobs
	create wleArray transient;
	create agent transient;
	create wagonArray transient; 
	
    wagonArray.clear();
    wleArray.clear();
	
    wagonArray.add( train.allWagonsByOrderInward[1]);
	railJob := allRailJobsArray.first;
    wleArray.add(railJob.workListEntries.first);
	allRailJobsArray.remove(railJob);
    agent.initialise( self.getTerminal );
    agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
    delete agent;
	
	// Queue the WLE 
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport);

	self.assertTrueMsg(tI1.myPrimaryQueuedLocation &lt;&gt; null, "container did not queue");
    // Move the WLE to the Wagon
    self.moveWLEWithNoAssert(wleArray[1]);
    self.assertNoTrxErrorsOrWarnings();
	
	// check work order is part complete
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	create agent transient;
	wagonArray.clear();
    wleArray.clear();
	
	wagonArray.add( train.allWagonsByOrderInward[1]);
	railJob := allRailJobsArray.first;
    wleArray.add(railJob.workListEntries.first);
	allRailJobsArray.remove(railJob);
    agent.initialise( self.getTerminal );
    agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
    delete agent;
	
	// Queue the WLE 
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport);
	
	self.assertTrueMsg(tI2.myPrimaryQueuedLocation &lt;&gt; null, "container did not queue");
    // Move the WLE to the Wagon
    self.moveWLEWithNoAssert(wleArray[1]);
    self.assertNoTrxErrorsOrWarnings();
	
	// check work order is part complete
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	// depart the train 
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);  //iout
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
epilog
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
		term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete pxyMaster;
	delete tiSet;
	delete pxyWod;
	delete wodArr;
	delete pxyWorkOrder;
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete pxyTrain;
	delete cmifObjects;
	delete wleArray;
	delete wagonArray;
	delete allRailJobsArray;
	delete trainSet;
	delete cmifRakeRegion;
	self.disableAllYA (false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobReleaseRoad" id="181c012c-e79d-443f-b9fc-ce52ef0134bd">
        <source>tCargoJobReleaseRoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
*/

constants
	REF: String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JRE1';
vars
	tI1, tI2			:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	job 				: 	CM_Job;
	tiSet				:	CM_TISet;
	releaseRequest		:	CM_BulkRelease;
	taSource			:	CM_TerminalArea;
	code				: 	String;
	relTime				:	TimeStamp;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);

	// Setup the work order options
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", "1001");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	releaseRequest := self.addReleaseById("UTBULKREL", BR_TYPE_SHIP, tiSet);
	self.assertNotNull(releaseRequest);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );								//28.06.2023 navma1 #58920
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREL_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREL_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;

	
	/*
	** Complete the Work order
	*/
	
	
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobReleaseRoadByType" id="b0f22efe-69b4-4dbb-9776-ab7b49b92032">
        <source>tCargoJobReleaseRoadByType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
05 Jul 2023	navlw1	ChangeRequest 58336:[58723] EUP - Unit Test for Release by Type Splitable cargo items
07 Aug 2023	navhl20	ChangeRequest 58336:[58723] EUP - Unit Test for Release by Type Splitable cargo items
18 Apr 2024	navpw1	Fixed unit test now uses "Steel Coil" instead of "Cannon Balls" - Causes issues leading to 1018 exception with yard allocations

*/

constants
	REF: String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JREBST1';
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVoy" &amp; REF;
	WPJS : String = "UT58336JS";
	TruckId : String = 'UTTRK1'&amp;REF;
vars
	tI1,
	tI2,
	tI3,
	tI4,
	tI5					: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	tiSet				: CM_TISet;
	releaseRequest		: CM_BulkRelease;
	taSource			: CM_TerminalArea;
	code				: String;
	relTime				: TimeStamp;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	vehicleName, 
	driverName			: String;
	terminalUTHelper	: UT_HelperAdmTerm;
	gate				: CM_Gate;
	terminal 			: CM_Terminal;
	vvr					: CM_VehicleVisitRecord;
	driver				: CM_DriverDetails;
	vehicle				: CM_Vehicle;
	operator 			: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	wle						: CM_WorkListEntry;
	myPxyWorkPointJobSheet	: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	hideMoveConfirmation 	: Boolean;
	tmpFoundLC				: CM_LocationsController;
	moveController			: CMIF_MoveController;
	cnt						: Integer;
	product					: CM_Product;
	
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, false);
	self.setTerminalConfig(HhMoveConfirmation,true);			//05.01.2023 navma1
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tCargoJobReleaseRoadByType;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL1");
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBul01", cargoType);
	self.deleteCargo("UTBul02", cargoType);
	self.deleteCargo("UTBul03", cargoType);
	self.deleteCargo("UTBul04", cargoType);
	self.deleteCargo("UTBul05", cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul01", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBul02", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI3 := self.addCargoBreakBulkAtLocation("UTBul03", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI4 := self.addCargoBreakBulkAtLocation("UTBul04", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI5 := self.addCargoBreakBulkAtLocation("UTBul05", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 2500);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTBULKREL1", BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2500);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );						//28.06.2023 navma1 #58920
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,2500,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.first;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();

	// create the move controller
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI1);
	moveController.setQuantity(500);
	
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();
	
	// create the move controller
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI2);
	moveController.setQuantity(500);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI3);
	moveController.setQuantity(500);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI4);
	moveController.setQuantity(500);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();
	
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI5);
	moveController.setQuantity(500);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	wod := workOrder.allWoDtls.first;
	if wod.status = WO_STATUS_COMPLETE then
		self.assertEqualMsg(wod.status , WO_STATUS_COMPLETE, "The work order task status should :" &amp; app.workOrderStatusEnumToString(WO_STATUS_COMPLETE));	
		cnt := wod.CM_WorkOrderTIDtl.allCompleteTIs.size;
		
		self.assertTrueMsg(cnt = 5, "The work order detail has no Completed TIs populated , AllCompleted Must have :5 " &amp;" TI and Currently only : "&amp; cnt.String );
		self.xCheckWorkOrderTransaction(wod,TRANS_TYPE_WO_TIREL_COMPLET);
		
		cnt := workOrder.CM_WorkOrderTI.allTIs.size;
		if workOrder.allWoDtls.size = 1 then
			self.assertTrueMsg(cnt = 5, "The work order Should have Empty , AllTIs : 5" &amp;" and Currently only : "&amp; cnt.String );
		endif;
	endif;
	self.roadExit(vvr);
	
epilog
 
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete terminalUTHelper;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete truckUnLoaderController;
	delete moveController;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobToDo" id="f25035ae-b94f-4181-a4d3-c9d5d6c018bb">
        <source>tCargoJobToDo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2022	navcs2	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF: String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JTD1';
vars
	tI1, tI2			:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	taskID				:	Integer;
	tiSet, 
	completeTiSet1,
	completeTiSet2		: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;

begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);

	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147


	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskTI(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );

	self.opts.addAssoc('TaskType',WO_TASK_TODO );
	self.opts.addAssoc('toDoTaskID', taskID);
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	
	// Create the work order
	create pxyWod as CM_WodToDo transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_TODO,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TITODO_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TITODO_UPDATED,false,false);	
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	/*
	** Part complete then complete the work order
	*/
	
	create completeTiSet1 transient;
	create completeTiSet2 transient;
	
	completeTiSet1.add(tI1);
	completeTiSet2.add(tI2);

	// Complete the to do task on the first TI
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, completeTiSet1, null, app.myPassport);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,2,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	// Complete the to do task on the second TI
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, completeTiSet2, null, app.myPassport);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete completeTiSet1;
	delete completeTiSet2;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobToDoMulti" id="33516e02-aaf4-4062-aca4-bc74fe4accef">
        <source>tCargoJobToDoMulti();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF: String  =  "56614";
	WOID : String  = 'UT'&amp;REF&amp;'JTD2';
vars
	tI1, tI2,tI7,
	tI3,tI4,tI5,tI6		:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc,
	toDoTaskDesc1,
	toDoTaskDesc2		: 	CM_ToDoTaskDesc;
	tiSet,
	tiSet1				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet,
	todoSet1			: 	CM_ToDoTaskDescSet;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	pxyWod1,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);

	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	self.deleteContainer("UTCNT3" &amp; REF);
	self.deleteContainer("UTCNT4" &amp; REF);
	
	//Creating cargos for detail -1
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI3 := self.addContainerOpts("UTCNT3" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI4 := self.addContainerOpts("UTCNT4" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));			
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);		
	
	self.deleteContainer("UTCNT5" &amp; REF);
	self.deleteContainer("UTCNT6" &amp; REF);
	self.deleteContainer("UTCNT7" &amp; REF);
	
	//Creating cargos for detail -2
	tI5 := self.addContainerOpts("UTCNT5" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI6 := self.addContainerOpts("UTCNT6" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI7 := self.addContainerOpts("UTCNT7" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));			
	
	create tiSet1 transient;
	tiSet1.add(tI5);
	tiSet1.add(tI6);
	tiSet1.add(tI7);


	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc["Todo1"];
	if toDoTaskDesc1 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc1);
	endif;
	toDoTaskDesc1 := self.createToDoTaskDesc("Todo1");					//2
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc["Todo2"];
	if toDoTaskDesc2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc2);
	endif;
	toDoTaskDesc2 := self.createToDoTaskDesc("Todo2");					//3
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	toDoTaskDescSet.add(toDoTaskDesc1);
	toDoTaskDescSet.add(toDoTaskDesc2);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	todoSet.add(toDoTaskDesc1);
	todoSet.add(toDoTaskDesc2);
	
	create todoSet1 transient;
	todoSet1.add(toDoTaskDesc);
	todoSet1.add(toDoTaskDesc1);

	self.opts.addAssoc('TaskType',WO_TASK_TODO );
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	
	// Create the work order
	create pxyWod as CM_WodToDo transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_TODO,todoSet,tiSet,null);
	
	create pxyWod1 as CM_WodToDo transient;
	self.xCreateWorkOrderDetail(pxyWod1,WO_TASK_TODO,todoSet1,tiSet1,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TITODO_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	//Completing half task in detail- 1
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,4,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	//Completing half task in detail -2
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_PARTCOMPLETE,3,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	
	//Completing remaining tasks in detail -1
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc2,tiSet,null);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,4,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
	
	//Completing remaining tasks in detail -2
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,4,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_COMPLETE,3,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	delete todoSet1;
	delete tiSet1;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobToDoMultiUnApprove" id="adcd5357-0d53-42fe-9a6a-0320ceda09ca">
        <source>tCargoJobToDoMultiUnApprove();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2024	navah1	Initial creation
11 Sep 2024 navah1  Bug 65907: EUP - Error 1310 when actioning work order that has been un - approved before
*/


constants
	REF: String  =  "56614";
	WOID : String  = 'UT'&amp;REF&amp;'JTD2';
vars
	tI1, tI2,tI7,
	tI3,tI4,tI5,tI6		:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc,
	toDoTaskDesc1,
	toDoTaskDesc2		: 	CM_ToDoTaskDesc;
	tiSet,
	tiSet1				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet,
	todoSet1			: 	CM_ToDoTaskDescSet;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	pxyWod1,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);

	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	self.deleteContainer("UTCNT3" &amp; REF);
	self.deleteContainer("UTCNT4" &amp; REF);
	
	//Creating cargos for detail -1
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI3 := self.addContainerOpts("UTCNT3" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI4 := self.addContainerOpts("UTCNT4" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));			
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);		
	
	self.deleteContainer("UTCNT5" &amp; REF);
	self.deleteContainer("UTCNT6" &amp; REF);
	self.deleteContainer("UTCNT7" &amp; REF);
	
	//Creating cargos for detail -2
	tI5 := self.addContainerOpts("UTCNT5" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI6 := self.addContainerOpts("UTCNT6" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI7 := self.addContainerOpts("UTCNT7" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));			
	
	create tiSet1 transient;
	tiSet1.add(tI5);
	tiSet1.add(tI6);
	tiSet1.add(tI7);


	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc["Todo1"];
	if toDoTaskDesc1 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc1);
	endif;
	toDoTaskDesc1 := self.createToDoTaskDesc("Todo1");					//2
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc["Todo2"];
	if toDoTaskDesc2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc2);
	endif;
	toDoTaskDesc2 := self.createToDoTaskDesc("Todo2");					//3
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	toDoTaskDescSet.add(toDoTaskDesc1);
	toDoTaskDescSet.add(toDoTaskDesc2);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	todoSet.add(toDoTaskDesc1);
	todoSet.add(toDoTaskDesc2);
	
	create todoSet1 transient;
	todoSet1.add(toDoTaskDesc);
	todoSet1.add(toDoTaskDesc1);

	self.opts.addAssoc('TaskType',WO_TASK_TODO );
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	
	// Create the work order
	create pxyWod as CM_WodToDo transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_TODO,todoSet,tiSet,null);
	
	create pxyWod1 as CM_WodToDo transient;
	self.xCreateWorkOrderDetail(pxyWod1,WO_TASK_TODO,todoSet1,tiSet1,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TITODO_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	self.assertEqualMsg(wod.CM_WodToDo.allToDoTasks.size , 12,"Work order has incorrect number of to-do tasks"); 
	
	// Un-approve the work order
	self.xUnApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TITODO_UPDATED,false,false);
	self.assertEqualMsg(wod.CM_WodToDo.allToDoTasks.size , 0,"Work order contains to-do tasks"); 
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	self.assertEqualMsg(wod.CM_WodToDo.allToDoTasks.size ,12,"Work order has incorrect number of to-do tasks"); 
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	//Completing half task in detail- 1
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,4,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	//Completing half task in detail -2
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_PARTCOMPLETE,3,TRANS_TYPE_WO_TITODO_UPDATED,true,false);
	
	
	//Completing remaining tasks in detail -1
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc2,tiSet,null);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,4,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
	
	//Completing remaining tasks in detail -2
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,4,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_COMPLETE,3,TRANS_TYPE_WO_TITODO_COMPLET,true,false);
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	delete todoSet1;
	delete tiSet1;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobUnpack" id="c7c3cad8-eccf-409a-b901-2b66054e1209">
        <source>tCargoJobUnpack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF: String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'JUPK1';
vars
	container			: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	job 				: CM_Job;
	blockstack1			: CM_BlockStack;
	cargoType			: CM_CargoType;
	packingCargo1,
	packingCargo2		: CMIF_InOutAttachment;
	attachments			: CMIF_InOutAttachmentArray;
	terminal			: CM_Terminal;
	unpackTIs			: CM_TIArray;
	tiSet				: CM_TISet;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a TI unpack task with a tracked item
	*/
	
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	// Setup the work order options
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	container := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	cargoType := self.getCargoType("LCL Cargo");
	assertNotNull(cargoType);

	self.deleteCargo(REF &amp; "PACK1", cargoType);
	self.deleteCargo(REF &amp; "PACK2", cargoType);
	
	create packingCargo1 transient;
	packingCargo1.set(terminal, cargoType.id, REF &amp; "PACK1", "", 100); 
	packingCargo1.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create packingCargo2 transient;
	packingCargo2.set(terminal, cargoType.id, REF &amp; "PACK2", "", 190); 
	packingCargo2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(packingCargo1);
	attachments.add(packingCargo2);
	
	addContainerChildren(container.CM_Container, attachments);
	assertEqualMsg(container.allChildren.size(), 2, "Doesn't have two children");
	
	create unpackTIs transient;
	unpackTIs.add(container.allChildren.first);
	
	self.deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	
	self.deleteTerminalArea("UTBS2" &amp; REF);
	blockstack1 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.move(container, blockstack1);	
		
	self.opts.purge();
	self.opts.addAssoc('unpackTA', "UTBS1" &amp; REF);
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	self.opts.addAssoc('TaskType',WO_TASK_UNPACK );
	
	create tiSet transient;
	tiSet.add(container);														//12.01.2023 navma1 #56141 Task#56147

	// Create the work order
	create pxyWod as CM_WodUnpack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIUNPACK_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIUNPACK_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(container));
	endforeach;
	
	
	/*
	** Part complete then complete the work order
	*/
	
	// Move then unpack the container
	self.move(container, container.myPrimaryQueuedLocation);
	self.unpackContainer(container, unpackTIs);
	self.unpackCompleteContainer(container);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,1,TRANS_TYPE_WO_TIUNPACK_COMPLET,true,false);
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	delete packingCargo1;
	delete packingCargo2;
	delete attachments;
	delete unpackTIs;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoJobUnpackMulti" id="3321be09-efa5-40d7-b060-75f3c8171d62">
        <source>tCargoJobUnpackMulti();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2023	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
18 Apr 2023	navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF: String  =  "UT015";
	WOID : String  = 'UT'&amp;REF&amp;'JUPK2';
vars
	tI1, tI2,tI7,
	tI3,tI4,tI5,tI6		:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc,
	toDoTaskDesc1,
	toDoTaskDesc2		: 	CM_ToDoTaskDesc;
	tiSet,
	tiSet1				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet,
	todoSet1			: 	CM_ToDoTaskDescSet;
	blockstack1			: 	CM_BlockStack;
	cargoType			: 	CM_CargoType;
	packingCargo1,
	packingCargo2,
	packingCargo3,
	packingCargo4,
	packingCargo5,
	packingCargo6,
	packingCargo7		:	CMIF_InOutAttachment;
	attachments			: 	CMIF_InOutAttachmentArray;
	terminal			: 	CM_Terminal;
	unpackTIs			: 	CM_TIArray;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	pxyWod1,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);

	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	self.deleteContainer("UTCNT3" &amp; REF);
	self.deleteContainer("UTCNT4" &amp; REF);
	
	//Creating cargos for detail -1
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI3 := self.addContainerOpts("UTCNT3" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI4 := self.addContainerOpts("UTCNT4" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	cargoType := self.getCargoType("LCL Cargo");
	assertNotNull(cargoType);

	self.deleteCargo(REF &amp; "PACK01", cargoType);
	self.deleteCargo(REF &amp; "PACK02", cargoType);
	self.deleteCargo(REF &amp; "PACK03", cargoType);
	self.deleteCargo(REF &amp; "PACK04", cargoType);
	
	create packingCargo1 transient;
	packingCargo1.set(terminal, cargoType.id, REF &amp; "PACK01", "", 100); 
	packingCargo1.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	create packingCargo2 transient;
	packingCargo2.set(terminal, cargoType.id, REF &amp; "PACK02", "", 100); 
	packingCargo2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	create packingCargo3 transient;
	packingCargo3.set(terminal, cargoType.id, REF &amp; "PACK03", "", 100); 
	packingCargo3.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	create packingCargo4 transient;
	packingCargo4.set(terminal, cargoType.id, REF &amp; "PACK04", "", 100); 
	packingCargo4.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(packingCargo1);
	
	self.addContainerChildren(tI1.CM_Container, attachments);
	self.assertEqualMsg(tI1.allChildren.size(), 1, "Doesn't have one children");
	
	attachments.clear();
	attachments.add(packingCargo2);
	
	self.addContainerChildren(tI2.CM_Container, attachments);
	self.assertEqualMsg(tI2.allChildren.size(), 1, "Doesn't have one children");
	
	attachments.clear();
	attachments.add(packingCargo3);
	
	self.addContainerChildren(tI3.CM_Container, attachments);
	self.assertEqualMsg(tI3.allChildren.size(), 1, "Doesn't have one children");
	
	attachments.clear();
	attachments.add(packingCargo4);
	
	self.addContainerChildren(tI4.CM_Container, attachments);
	self.assertEqualMsg(tI4.allChildren.size(), 1, "Doesn't have one children");
	
	self.deleteTerminalArea("UT01" &amp; REF);
	blockstack1 := addBlockStack("UT01" &amp; REF, 10, null);
	
	self.deleteTerminalArea("UT02" &amp; REF);
	blockstack1 := addBlockStack("UT02" &amp; REF, 10, null);
	
	self.move(tI1, blockstack1);	
	self.move(tI2, blockstack1);
	self.move(tI3, blockstack1);
	self.move(tI4, blockstack1);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);		
	
	self.deleteContainer("UTCNT5" &amp; REF);
	self.deleteContainer("UTCNT6" &amp; REF);
	self.deleteContainer("UTCNT7" &amp; REF);
	
	//Creating cargos for detail -2
	tI5 := self.addContainerOpts("UTCNT5" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI6 := self.addContainerOpts("UTCNT6" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI7 := self.addContainerOpts("UTCNT7" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	self.deleteCargo(REF &amp; "PACK05", cargoType);
	self.deleteCargo(REF &amp; "PACK06", cargoType);
	self.deleteCargo(REF &amp; "PACK07", cargoType);
	
	create packingCargo5 transient;
	packingCargo5.set(terminal, cargoType.id, REF &amp; "PACK05", "", 100); 
	packingCargo5.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	create packingCargo6 transient;
	packingCargo6.set(terminal, cargoType.id, REF &amp; "PACK06", "", 100); 
	packingCargo6.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	create packingCargo7 transient;
	packingCargo7.set(terminal, cargoType.id, REF &amp; "PACK07", "", 100); 
	packingCargo7.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	attachments.clear();
	attachments.add(packingCargo5);
	
	self.addContainerChildren(tI5.CM_Container, attachments);
	self.assertEqualMsg(tI5.allChildren.size(), 1, "Doesn't have one children");
	
	attachments.clear();
	attachments.add(packingCargo6);
	
	self.addContainerChildren(tI6.CM_Container, attachments);
	self.assertEqualMsg(tI6.allChildren.size(), 1, "Doesn't have one children");
	
	attachments.clear();
	attachments.add(packingCargo7);
	
	self.addContainerChildren(tI7.CM_Container, attachments);
	self.assertEqualMsg(tI7.allChildren.size(), 1, "Doesn't have one children");
	
	//create unpackTIs transient;
	//unpackTIs.add(tI1.allChildren.first);
	
	self.move(tI5, blockstack1);	
	self.move(tI6, blockstack1);
	self.move(tI7, blockstack1);
	
	create tiSet1 transient;
	tiSet1.add(tI5);
	tiSet1.add(tI6);
	tiSet1.add(tI7);


	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc["Todo11"];
	if toDoTaskDesc1 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc1);
	endif;
	toDoTaskDesc1 := self.createToDoTaskDesc("Todo11");					//2
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc["Todo12"];
	if toDoTaskDesc2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc2);
	endif;
	toDoTaskDesc2 := self.createToDoTaskDesc("Todo12");					//3
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	toDoTaskDescSet.add(toDoTaskDesc1);
	toDoTaskDescSet.add(toDoTaskDesc2);
	
	self.addToDoTaskResource("UTHLRES1",
											 "UT HL Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	todoSet.add(toDoTaskDesc1);
	todoSet.add(toDoTaskDesc2);
	
	create todoSet1 transient;
	todoSet1.add(toDoTaskDesc);
	todoSet1.add(toDoTaskDesc1);

	self.opts.purge();
	self.opts.addAssoc('unpackTA', "UT01" &amp; REF);
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UT02" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_UNPACK );
	
	// Create the work order
	create pxyWod as CM_WodUnpack transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,todoSet,tiSet,null);
	
	create pxyWod1 as CM_WodUnpack transient;
	self.xCreateWorkOrderDetail(pxyWod1,WO_TASK_UNPACK,todoSet1,tiSet1,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIUNPACK_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIUNPACK_UPDATED,true,false);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	//Completing half task in detail- 1
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.assertEqualMsg(wod.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	//Completing half task in detail -2
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	self.assertEqualMsg(workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	//Completing remaining tasks in detail -1
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	self.completeToDoTask(toDoTaskDesc2,tiSet,null);
	self.assertEqualMsg(wod.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	//Completing remaining tasks in detail -2
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI5);
	tiSet.add(tI6);
	tiSet.add(tI7);
	self.completeToDoTask(toDoTaskDesc1,tiSet,null);
	self.assertEqualMsg(workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allToDoRequests.first.status, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	create unpackTIs transient;
	unpackTIs.add(tI1.allChildren.first);
	self.unpackContainer(tI1, unpackTIs);
	self.unpackCompleteContainer(tI1);
	
	unpackTIs.clear();
	unpackTIs.add(tI2.allChildren.first);
	self.unpackContainer(tI2, unpackTIs);
	self.unpackCompleteContainer(tI2);
	
	unpackTIs.clear();
	unpackTIs.add(tI3.allChildren.first);
	self.unpackContainer(tI3, unpackTIs);
	self.unpackCompleteContainer(tI3);
	
	unpackTIs.clear();
	unpackTIs.add(tI4.allChildren.first);
	self.unpackContainer(tI4, unpackTIs);
	self.unpackCompleteContainer(tI4);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,4,TRANS_TYPE_WO_TIUNPACK_UPDATED,true,false);
	
	unpackTIs.clear();
	unpackTIs.add(tI5.allChildren.first);
	self.unpackContainer(tI5, unpackTIs);
	self.unpackCompleteContainer(tI5);
	
	unpackTIs.clear();
	unpackTIs.add(tI6.allChildren.first);
	self.unpackContainer(tI6, unpackTIs);
	self.unpackCompleteContainer(tI6);
	
	unpackTIs.clear();
	unpackTIs.add(tI7.allChildren.first);
	self.unpackContainer(tI7, unpackTIs);
	self.unpackCompleteContainer(tI7);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,4,TRANS_TYPE_WO_TIUNPACK_COMPLET,true,false);
	self.xCheckWorkOrder(workOrder.allWoDtls.last,WO_STATUS_COMPLETE,3,TRANS_TYPE_WO_TIUNPACK_COMPLET,true,false);
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	delete todoSet1;
	delete tiSet1;
	delete attachments;
	delete packingCargo1;
	delete packingCargo2;
	delete packingCargo3;
	delete packingCargo4;
	delete packingCargo5;
	delete packingCargo6;
	delete packingCargo7;
	delete unpackTIs;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoNoJobChangeVoyage" id="e12a7f5a-455a-42de-8922-888c975a54bb">
        <source>tCargoNoJobChangeVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF  : String  =  UT_DSL.TFS54344.String;
	WOID : String  = 'UT'&amp;REF&amp;'NJCV1';
vars
	tI1, 
	tI2					:	CM_TrackedItem;
	workOrder,
	pxyWorkOrder		:	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	job 				: 	CM_Job;
	wle					: 	CM_WOWLE;
	tiSet				: 	CM_TISet;
	wod,
	pxyWod				: 	CM_WorkOrderDtl;
	wodArr				: 	CM_WorkOrderDtlArray;
	voyage				:	CM_Voyage;
	vessel				: 	CM_Vessel;
begin
	/*
	** Setup Section, create the work order with a change voyage task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, false);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	// Setup the work order options
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);

	self.opts.purge();
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	self.opts.addAssoc('TaskType',WO_TASK_CHANGEVOYAGE );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodNullVoyage transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_CHANGEVOYAGE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.assertNotNull(workOrder);
	self.assertEqual(workOrder.id , WOID);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TICHGVOY_CREATED,false,false);	
	
	// Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TICHGVOY_UPDATED,false,false);	
	
	// Action the work order
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TICHGVOY_COMPLET,true,false);

epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoNoJobMove" id="d65792da-5810-4c19-96c0-da5c660320bd">
        <source>tCargoNoJobMove();
/*

Purpose:	

Test moving cargo using a work order while the option for using yard jobs for work orders is not selected		

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2022	navcs2 	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants
	REF = UT_DSL.TFS53038;
	WOID : String  = 'UT'&amp;REF&amp;'NJMV1';
vars
	blockstack1, 
	blockstack2		:	CM_BlockStack;
	tI1, 
	tI2				:	CM_TrackedItem;
	tiSet			: 	CM_TISet;
	useYardJob		: 	Boolean;
	wodArr			: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod				: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder		: 	CM_WorkOrder;
begin
	
	useYardJob := self.getMyTerminal.isUseYardJobsForCargoWo;				//06.03.2023 navma1 #56457:[56458]
	self.setTerminalConfig(UseYardJobsCargoWO,false);						//06.03.2023 navma1 #56457:[56458]
	
	deleteWorkOrderNoValidation(WOID);

	deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	deleteTerminalArea("UTBS2" &amp; REF);
	blockstack2 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	create tiSet transient;
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(tI1, blockstack1);
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	move(tI2, blockstack1);
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	
	self.opts.addAssoc('TaskType',WO_TASK_MOVE );
	
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;	
	
	workOrder.actionTI(tI1, "Move", app.myPassport);
	workOrder.actionTI(tI2, "Move", app.myPassport);
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIMOVE_CREATED,false,false);
	
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIMOVE_UPDATED,false,false);
	
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIMOVE_COMPLET,true,false);


epilog
	self.setTerminalConfig(UseYardJobsCargoWO,useYardJob);											//06.03.2023 navma1 #56457:[56458]
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoNoJobMove2" id="d370227c-108c-4be3-89b2-e7fe8eba45de">
        <source>tCargoNoJobMove2();
/*
navma1
cnwndl1
cnwrd1
Purpose:	

Test moving cargo using a work order while the option for using yard jobs for work orders is not selected		

Parameters:			

Return Value:	

Date		Who		Reason
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/
vars
	blockStack,
	washStack 			: CM_BlockStack;
	ti1,
	ti2					: CM_TrackedItem;
	tiSet				: CM_TISet;
	term				: CM_Terminal;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	woTrans				: CM_WOTransaction;
	woTranstype			: Integer;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
begin
	
	term				:= self.getMyTerminal();
	useYardJobsSetting  := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	:= term.getConfig(AllowAutoActionCargoWo);
	
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, false);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation('RJDUTWO1');

	deleteTerminalArea("UTBS1");
	blockStack := addBlockStack("UTBS1", 10, null);
	
	deleteTerminalArea("RJDWSH");
	washStack := addBlockStack("RJDWSH", 10, null);
	
	self.deleteContainer("RJDTEST0001");
	self.deleteContainer("RJDTEST0002");
	
	create tiSet transient;
	
	ti1 := self.addContainerOpts("RJDTEST0001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	tiSet.add(ti1);
	move(ti1, blockStack);
	
	ti2 := self.addContainerOpts("RJDTEST0002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	tiSet.add(ti2);
	move(ti2, blockStack);
	
	self.opts.purge();
	self.opts.addAssoc('TargetTA'  , "RJDWSH");
	self.opts.addAssoc('TaskType'  , WO_TASK_MOVE );  // for task type to add.
	
	
	// lets add a basic user entry work order
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,'RJDUTWO1',WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first();
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIMOVE_CREATED,false,false);
	
	// Approve Work Order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIMOVE_UPDATED,false,false);
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIMOVE_COMPLET,true,false);
	
	// check complete transaction 
	woTranstype := wod.getTransTypeByMode();							
	woTrans 	:= wod.getLastTransOfType(woTranstype);				
	self.assertNotNull(woTrans);
	
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoNoJobReceiveRoad" id="9adbaa56-6d4e-4673-9cb5-434e0ebe7fc8">
        <updating/>
        <source>tCargoNoJobReceiveRoad()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings

*/
constants
	REF  : String    =  UT_DSL.TFS58339.String;
	WOID : String  = 'UT'&amp;REF&amp;'JRC1';
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Boolean;
	term			    : CM_Terminal;
	tiSet				: CM_TISet;
	tI1, 
	tI2					:CM_TrackedItem;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	voyage				: CM_Voyage;
	booking				: CM_BookingRef;
	createPin           : Boolean;
begin
	
	term := self.getMyTerminal();
	
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo).Boolean;
	createPin          :=term.getConfig(NoPINs).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, false);
	term.setConfig(AllowAutoActionCargoWo, false);
	term.setConfig(NoPINs, false);
	commitTransaction;
	
	
	self.deleteWorkOrderNoValidation(WOID);
	
	voyage := self.xAddVoyage('UTVSL'&amp;REF,'UTVOY'&amp;REF);

	booking:= self.xAddBooking('UTBook'&amp;REF,voyage);
	
	tI1 := self.xAddCargo("UTCNT1" &amp; REF,null,TI_STATE_NOTIFIED,'UTBook'&amp;REF);
	tI2 := self.xAddCargo("UTCNT2" &amp; REF,null,TI_STATE_NOTIFIED,'UTBook'&amp;REF);
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);		
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);	
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('Booking',booking.bookingReference );
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );								//28.06.2023 navma1 #58920
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,false,false);
	
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	self.gateInPinReceival(workOrder.getPINNumber,'UTTRK'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
epilog

	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(NoPINs, createPin);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoVoyJobRecieveShip" id="728721ae-a1be-4d89-b43a-b44526071ce8">
        <source>tCargoVoyJobRecieveShip();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants
	REF		: String  = '58400';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = "UTHMVOY"&amp;REF;
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, tI2,tI3,tI4,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	startDate				: 	TimeStamp;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	groMethod				: 	CM_WorkOrderJobGroupMethod;
	firstJob,
	secondJob				: 	CM_Job;
	mobileAgent 			: 	CMIF_MobileGenericAgent;
	blockStack				:	CM_BlockStack;
	hideMoveConfirmation	: 	Any;
begin

	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := term.getConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(HhMoveConfirmation,true);           //08.1.2024 navma1 
	commitTransaction;
	
	self.deleteTerminalArea("BS1711");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS1711", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	// tracked items
	tI1 := self.xAddCargo("UTCON1" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI1);
	
	tI2 := self.xAddCargo("UTCON2" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI2);
	
	tI3 := self.xAddCargo("UTCON3" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI3);
	
	tI4 := self.xAddCargo("UTCON4" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI4);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI1.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI3.setSpecialStow("STOW1");
		tI3.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI2.setSpecialStow("STOW2");
		tI2.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI4.setSpecialStow("STOW2");
		tI4.changeState(TI_STATE_ONSHIP,app.myPassport);
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	groMethod := term.allWOJobGroupMethods["UTHM60063",term];
	
	self.xApproveWorkOrder(workOrder);
	
	self.opts.purge();
	self.opts.addAssoc('GrpMethod', groMethod);
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_61617");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	
	delete pxyVoyJob;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,secondJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(secondJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(term);
	mobileAgent.setMyVoyage(voyage); 
	mobileAgent.setDoNotShowMsgBox(true);		// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
	
	mobileAgent.setMyJob(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderDischargeWOJob(tI1,blockStack.myLocationsController,tI1.totalQuantity,tI1.totalWeight);
	
	self.assertEqual(firstJob.status,JOB_PART_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_PARTCOMPLETE);
	
	mobileAgent.setMyJob(secondJob.CM_WOReceiveCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderDischargeWOJob(tI2,blockStack.myLocationsController,tI2.totalQuantity,tI2.totalWeight);
	
	self.assertEqual(secondJob.status,JOB_PART_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_PARTCOMPLETE);
	
	mobileAgent.setMyJob(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderDischargeWOJob(tI3,blockStack.myLocationsController,tI3.totalQuantity,tI3.totalWeight);
	
	self.assertEqual(firstJob.status,JOB_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_PARTCOMPLETE);
	
	mobileAgent.setMyJob(secondJob.CM_WOReceiveCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderDischargeWOJob(tI4,blockStack.myLocationsController,tI4.totalQuantity,tI4.totalWeight);
	
	self.assertEqual(secondJob.status,JOB_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(HhMoveConfirmation,hideMoveConfirmation);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete myPxyWorkPointJobSheet;
	delete pxyVoyJob;
	delete mobileAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRetroPackJob" id="cdc85c3a-6516-4166-b3a9-8fc1e8b755cd">
        <source>tCheckRetroPackJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

constants
	REF	 : String  =  "628633";
	WOID : String  = 'UT'&amp;REF&amp;'RPJ';
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVOY" &amp; REF;
	WPJS : String = "UT62863JS";
	TruckId : String = 'UTTRK1'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	packingCargo1,
	packingCargo2			: CM_TrackedItem;
	attachments				: CMIF_InOutAttachmentArray;
	packTIs					: CM_TIArray;
	wh						: CM_IrregularBlockArea;
	cargoType				: CM_CargoType;
	job						: CM_Job;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("BS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTRel"&amp;REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage	
	vessel := self.addVesselWithHolds("UTVES" &amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteContainer("UT" &amp; REF);
	self.deleteContainer("UT1" &amp; REF);
	self.deleteContainer(REF &amp; "PACK1");
	self.deleteContainer(REF &amp; "PACK2");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	tI1 := self.addContainerOpts("UT" &amp; REF, "2200", "MT", operator);	
	tI2 := self.addContainerOpts("UT1" &amp; REF, "2200", "MT", operator);
	
	self.move(tI1, blockStack);	
	self.move(tI2, blockStack);
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("GVS"));
	
	wh := terminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK1", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	packingCargo2 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK2", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc('Number', 2);
	self.opts.addAssoc('NumberSec', 200);
	self.opts.addAssoc('ISOType', "2200");
	self.opts.addAssoc('CargoType', cargoType);
	self.opts.addAssoc('PackType', CM_ReserveDetail.PackType_Parent);
	self.opts.addAssoc('PackType1', CM_ReserveDetail.PackType_Child);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTRel"&amp;REF, BR_TYPE_PACKING, 1);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	create pxyWod as CM_WodPack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	
	job := wod.CM_WorkOrderTIDtl.allJobs.last;
	
	app.myTrxUA.trxUpdateJobRetroDT(job,app.actualTimeServer().addDays(-10),app.myPassport);
	self.assertEqualMsg(job.isRetrospective,true,"Job is should retrospective job");
	
	app.myTrxUA.trxUpdatePackCargo(tI1, packingCargo1, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,app.actualTimeServer().addDays(-10), app.myPassport);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease,releaseRequest);
	self.opts.addAssoc("RetroDT",app.actualTimeServer().addDays(-10));
	self.packCompleteContainer(tI1.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_PART_COMPLETE, "The job has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_PART_COMPLETE, "The job has not been part completed");
	self.assertEqualMsg(packingCargo1.getLastTransOfClass(CM_Pack).dateTime.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	self.assertEqualMsg(tI1.getLastTransOfClass(CM_PackComplete).dateTime.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	
	app.myTrxUA.trxUpdatePackCargo(tI2, packingCargo2, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,app.actualTimeServer().addDays(-10), app.myPassport);
	self.packCompleteContainer(tI2.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_COMPLETED, "The job has not been completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_COMPLETED, "The job has not been completed");
	self.assertEqualMsg(packingCargo2.getLastTransOfClass(CM_Pack).dateTime.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	self.assertEqualMsg(tI2.getLastTransOfClass(CM_PackComplete).dateTime.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete packTIs;
	delete attachments;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRetroRecRoadJob" id="be6ef647-a7d3-4e47-b274-c8f338fc6539">
        <updating/>
        <source>tCheckRetroRecRoadJob()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

constants
	REF: String  =  "62525";
	WOID : String  = 'UT'&amp;REF&amp;'JRC2';
vars
	tI1					:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	gateAutoComplete,
	hhUnloadEdit,
	isRetro				: 	Any;
	tiSet				: 	CM_TISet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	booking				: 	CM_BookingRef;
	vvr					: 	CM_VehicleVisitRecord;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	job					:	CM_RoadJob;
	term				: 	CM_Terminal;
	controller			: 	CMIF_MobileTruckLoaderUnloader;	
	blockStack			: 	CM_TerminalArea;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	term			   := self.getTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	gateAutoComplete   := term.getConfig(GateInAutoCompleteBkgrnd);
	hhUnloadEdit   	   := term.getConfig(HhTUnloadEdit);
	isRetro   	   	   := term.getConfig(IsRetrospectiveMode);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(GateInAutoCompleteBkgrnd, true);
	term.setConfig(HhTUnloadEdit, true);
	term.setConfig(IsRetrospectiveMode, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UT" &amp; REF), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	self.deleteVehicle('UTHM-'&amp;REF);
	self.deleteTerminalArea("HM" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack("HM" &amp; REF, 10, null);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UT" &amp; REF);			
	
	create tiSet transient;
	tiSet.add(tI1);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-10));
	vvr := self.gateInMultiContainer('UTHM-'&amp;REF,"2200",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code,"MT",self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()),tiSet);
	//self.gateInPinReceival(workOrder.getPINNumber,'UTTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Allocate job to jobSheet
	job := term.myWOJobSheet.allJobsByRequiredDTPriority[workOrder.requiredByDT,3].CM_RoadJob;
	
	self.assertEqualMsg(vvr.retrospectiveDT.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	self.assertEqualMsg(job.isRetrospective,true,"Job is should retrospective job");
	
	//Complete workOrder
	self.moveVehicleToYard(job.myVehicle);
	create controller transient;
	controller.setMyTerminal(term);
	controller.setTruck(job.myVehicle);
	controller.saveChangesUnload(tI1,blockStack.allLocationsControllers.first,tI1.totalQuantity,null,app.actualTimeServer().addDays(-9));
	self.assertEqualMsg(tI1.getLastTransOfClass(CM_Move).dateTime.Date,app.actualTimeServer().addDays(-9).Date,"Retrospective Date not updated correctly");
	
	
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-8));
	self.roadExit(vvr);
	self.assertEqualMsg(vvr.timeOut.Date,app.actualTimeServer().addDays(-8).Date,"Retrospective Date not updated correctly");
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(GateInAutoCompleteBkgrnd, gateAutoComplete);
	term.setConfig(HhTUnloadEdit, hhUnloadEdit);
	term.setConfig(IsRetrospectiveMode, isRetro);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRetroRecShipJob" id="3b179a2e-1637-4396-9429-990507ed860e">
        <source>tCheckRetroRecShipJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

constants
	REF		: String  = '628631';
	WOID 	: String  = 'UT'&amp;REF&amp;'RSHP';
	Voyage	: String  = "UTHMVOY"&amp;REF;
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo,
	isRetro					: 	Any;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	firstJob				: 	CM_Job;
	mobileAgent 			: 	CMIF_MobileGenericAgent;
	blockStack				:	CM_BlockStack;
	hideMoveConfirmation	: 	Any;
begin

	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := term.getConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	isRetro   	   	   	:= term.getConfig(IsRetrospectiveMode);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(HhMoveConfirmation,true);
	term.setConfig(IsRetrospectiveMode, true);
	commitTransaction;
	
	self.deleteTerminalArea("BS" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack("BS" &amp; REF, 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	// tracked items
	tI1 := self.xAddCargo("UT" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI1);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI1.changeState(TI_STATE_ONSHIP,app.myPassport);
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	
	self.xActionWorkOrder(workOrder);
	
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	
	app.myTrxUA.trxUpdateJobRetroDT(firstJob,app.actualTimeServer().addDays(-10),app.myPassport);
	
	if realJobSheet = null then
		self.opts.purge();
		self.opts.addAssoc('Shift', app.actualTimeServer().addDays(-10));
		realJobSheet := self.xCreateJobSheetShip("UT" &amp; REF);
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(-10),app.actualTimeServer().addDays(-10),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	self.assertEqualMsg(firstJob.isRetrospective,true,"Job is should retrospective job");
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(term);
	mobileAgent.setMyVoyage(voyage); 
	mobileAgent.setDoNotShowMsgBox(true);
	
	mobileAgent.setMyJob(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderDischargeWOJob(tI1,blockStack.myLocationsController,tI1.totalQuantity,tI1.totalWeight);
	self.assertEqualMsg(tI1.allTransactions.first.dateTime.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	
	self.assertEqual(firstJob.status,JOB_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(HhMoveConfirmation,hideMoveConfirmation);
	term.setConfig(IsRetrospectiveMode, isRetro);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete myPxyWorkPointJobSheet;
	delete pxyVoyJob;
	delete mobileAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRetroRelRoadJob" id="7f5af6b6-7033-4637-9739-8d3942c2e77e">
        <source>tCheckRetroRelRoadJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
18 Apr 2024	navpw1	Fixed unit test changed currentMethodBeingRun to the correctly named method

*/

constants
	REF: String  =  "62863";
	WOID : String  = 'UT'&amp;REF&amp;'JRR';
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVoy" &amp; REF;
	WPJS : String = "UT62863-1JS";
	TruckId : String = 'UTTRK1'&amp;REF;
vars
	tI1					: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	isRetro				: Any;
	tiSet				: CM_TISet;
	releaseRequest		: CM_BulkRelease;
	taSource			: CM_TerminalArea;
	code				: String;
	relTime				: TimeStamp;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	vehicleName, 
	driverName			: String;
	terminalUTHelper	: UT_HelperAdmTerm;
	gate				: CM_Gate;
	terminal 			: CM_Terminal;
	vvr					: CM_VehicleVisitRecord;
	driver				: CM_DriverDetails;
	vehicle				: CM_Vehicle;
	operator 			: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	wle						: CM_WorkListEntry;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	hideMoveConfirmation 	: Boolean;
	tmpFoundLC				: CM_LocationsController;
	moveController			: CMIF_MoveController;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	isRetro   	   	   := self.getTerminalConfig(IsRetrospectiveMode);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, false);
	self.setTerminalConfig(HhMoveConfirmation,true);
	self.setTerminalConfig(IsRetrospectiveMode, true);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tCheckRetroRelRoadJob;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTREL1" &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	
	self.deleteCargo("UT01" &amp; REF, cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UT01" &amp; REF, cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	terminalUTHelper.opts.purge();
	terminalUTHelper.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-10));
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 500);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTREL1" &amp; REF, BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, cargoType.getProductFromCode("TIEWIRE10G"));
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,500,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.first;
	
	self.assertEqualMsg(wle.job.isRetrospective,true,"Job is should retrospective job");
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();

	// create the move controller
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI1);
	moveController.setQuantity(500);
	moveController.retrospectiveDT := app.actualTimeServer().addDays(-9);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	self.assertEqualMsg(vvr.timeIn.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	self.assertEqualMsg(tI1.allTransactions.first.dateTime.Date,app.actualTimeServer().addDays(-9).Date,"Retrospective Date not updated correctly");
	
	
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-8));
	self.roadExit(vvr);
	self.assertEqualMsg(vvr.timeOut.Date,app.actualTimeServer().addDays(-8).Date,"Retrospective Date not updated correctly");
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	self.setTerminalConfig(HhMoveConfirmation,hideMoveConfirmation);
	self.setTerminalConfig(IsRetrospectiveMode, isRetro);
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete terminalUTHelper;
	delete truckUnLoaderController;
	delete moveController;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRetroRelShipJob" id="18261b26-931a-460b-a556-2622cf99bd02">
        <source>tCheckRetroRelShipJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack

*/

constants
	REF		: String  = '628632';
	WOID 	: String  = 'UT'&amp;REF&amp;'RSHP';
	WOID1	: String  = 'UT'&amp;REF&amp;'RSHP1';
	Voyage	: String  = 'UTSHIP' &amp; REF;
vars
	voyage 					: 	CM_Voyage;
	tI1, tI2,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	blockStack				:	CM_BlockStack;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	firstJob				: 	CM_Job;
	realJobSheet,
	realJobSheet1			:	CM_WorkPointJobSheet;
	releaseRequest			: 	CM_BulkRelease;
	taSource				: 	CM_TerminalArea;
	code					: 	String;
	relTime					:	TimeStamp;
	cargoType				: 	CM_CargoType;
	mobileAgent 			: 	CMIF_MobileGenericAgent;
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteTerminalArea("BS"&amp;REF);
	
	// setup stuff 
	blockStack := self.addBlockStack("BS"&amp;REF, 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteWorkOrderNoValidation(WOID1);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTHMVOY"&amp;REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	//Work Order with tracked items
	// tracked items
	tI1 := self.xAddCargo("UT" &amp; REF, voyage, TI_STATE_NORMAL, null);
	self.assertNotNull(tI1);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	
	// Create the work order detail
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	
	self.xActionWorkOrder(workOrder);
	
	self.assertEqual(workOrder.allWoDtls.size,1);
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	
	app.myTrxUA.trxUpdateJobRetroDT(firstJob,app.actualTimeServer().addDays(-10),app.myPassport);
	
	if realJobSheet = null then
		self.opts.purge();
		self.opts.addAssoc('Shift', app.actualTimeServer().addDays(-10));
		realJobSheet := self.xCreateJobSheetShip("UT" &amp;REF);
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(-10),app.actualTimeServer().addDays(-10),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.size,1);
	self.assertEqualMsg(firstJob.isRetrospective,true,"Job is should retrospective job");
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(term);
	mobileAgent.setMyVoyage(voyage); 
	mobileAgent.setDoNotShowMsgBox(true);
	
	mobileAgent.setMyJob(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderLoadWOJob(tI1,voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first,null,tI1.totalQuantity,tI1.totalWeight);
	self.assertEqualMsg(tI1.allTransactions.first.dateTime.Date,app.actualTimeServer().addDays(-10).Date,"Retrospective Date not updated correctly");
	
	self.assertEqual(firstJob.status,JOB_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
	
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyVoyJob;
	
	//Work Order with release by type
	cargoType := term.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	
	self.deleteCargo("UT01" &amp; REF, cargoType);
	
	tI2 := self.addCargoBreakBulkAtLocation("UT01" &amp; REF, cargoType, 100, blockStack.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 100);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTBULKREL1", BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	// Create the work order detail
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID1,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	self.assertEqual(workOrder.allWoDtls.size,1);
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	app.myTrxUA.trxUpdateJobRetroDT(firstJob,app.actualTimeServer().addDays(-9),app.myPassport);
	
	if realJobSheet1 = null then
		self.opts.purge();
		self.opts.addAssoc('Shift', app.actualTimeServer().addDays(-9));
		realJobSheet1 := self.xCreateJobSheetShip("UT1" &amp;REF);
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(-9),app.actualTimeServer().addDays(-9),remarks,0,realJobSheet1,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet1,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.size,1);
	self.assertEqualMsg(firstJob.isRetrospective,true,"Job is should retrospective job");
	
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(term);
	mobileAgent.setMyVoyage(voyage); 
	mobileAgent.setDoNotShowMsgBox(true);
	
	mobileAgent.setMyJob(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.first);
	self.deleteStops(tI2);
	mobileAgent.doLanderLoadWOJob(tI2,voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first,null,tI2.totalQuantity,tI2.totalWeight);
	self.assertEqualMsg(tI2.allTransactions.first.dateTime.Date,app.actualTimeServer().addDays(-9).Date,"Retrospective Date not updated correctly");
	
	self.assertEqual(firstJob.status,JOB_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyVoyJob;
	delete mobileAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRetroUnpackJob" id="9f72e876-e5fb-4f19-a2a0-bed9d127d92a">
        <source>tCheckRetroUnpackJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

constants
	REF: String  =  "62863";
	WOID : String  = 'UT'&amp;REF&amp;'RUJ';
vars
	container,
	child				: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	job 				: CM_Job;
	blockstack1			: CM_BlockStack;
	cargoType			: CM_CargoType;
	packingCargo1,
	packingCargo2		: CMIF_InOutAttachment;
	attachments			: CMIF_InOutAttachmentArray;
	terminal			: CM_Terminal;
	unpackTIs			: CM_TIArray;
	tiSet				: CM_TISet;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
begin
	/*
	** Setup Section, create the work order with a TI unpack task with a tracked item
	*/
	
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	// Setup the work order options
	self.deleteContainer("UT" &amp; REF);
	
	container := self.addContainerOpts("UT" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	cargoType := self.getCargoType("LCL Cargo");
	self.assertNotNull(cargoType);

	self.deleteCargo(REF &amp; "PACK1", cargoType);
	self.deleteCargo(REF &amp; "PACK2", cargoType);
	
	create packingCargo1 transient;
	packingCargo1.set(terminal, cargoType.id, REF &amp; "PACK1", "", 100); 
	packingCargo1.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create packingCargo2 transient;
	packingCargo2.set(terminal, cargoType.id, REF &amp; "PACK2", "", 190); 
	packingCargo2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(packingCargo1);
	attachments.add(packingCargo2);
	
	self.addContainerChildren(container.CM_Container, attachments);
	self.assertEqualMsg(container.allChildren.size(), 2, "Doesn't have two children");
	
	create unpackTIs transient;
	unpackTIs.add(container.allChildren.first);
	
	self.deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	
	self.deleteTerminalArea("UTBS2" &amp; REF);
	blockstack1 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.move(container, blockstack1);	
		
	self.opts.purge();
	self.opts.addAssoc('unpackTA', "UTBS1" &amp; REF);
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_UNPACK );
	
	create tiSet transient;
	tiSet.add(container);

	// Create the work order
	create pxyWod as CM_WodUnpack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIUNPACK_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIUNPACK_UPDATED,true,false);
	
	job := wod.CM_WorkOrderTIDtl.allJobs.first;
	app.myTrxUA.trxUpdateJobRetroDT(job,app.actualTimeServer().addDays(-9),app.myPassport); 
	
	/*
	** Part complete then complete the work order
	*/
	
	// Move then unpack the container
	self.move(container, container.myPrimaryQueuedLocation);
	child := container.allChildren.first.CM_TrackedItem;
	app.myTrxUA.trxUpdateUnpackCargo(child, blockstack1.allLocationsControllers.first,null,null,true,app.actualTimeServer().addDays(-9), app.myPassport);
	self.assertEqualMsg(child.getLastTransOfClass(CM_Unpack).dateTime.Date,app.actualTimeServer().addDays(-9).Date,"Retrospective Date not updated correctly");
	child := container.allChildren.first.CM_TrackedItem;
	app.myTrxUA.trxUpdateUnpackCargo(child, blockstack1.allLocationsControllers.first,null,null,true,app.actualTimeServer().addDays(-9), app.myPassport);
	self.assertEqualMsg(child.getLastTransOfClass(CM_Unpack).dateTime.Date,app.actualTimeServer().addDays(-9).Date,"Retrospective Date not updated correctly");
	self.assertEqualMsg(container.getLastTransOfClass(CM_UnpackComplete).dateTime.Date,app.actualTimeServer().addDays(-9).Date,"Retrospective Date not updated correctly");
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,1,TRANS_TYPE_WO_TIUNPACK_COMPLET,true,false);
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	delete packingCargo1;
	delete packingCargo2;
	delete attachments;
	delete unpackTIs;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRoadWithTrailer" id="4d4d12c4-39b1-4591-8562-f377d2dfe657">
        <updating/>
        <source>tCheckRoadWithTrailer()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2024 navhl20 ChangeRequest 63148: EUP* | 53729 - Delivery Dispatch Screen - Should not update job status when trailers got completed.
*/

constants
	REF: String  	=  "63148";
	WOID : String 	= 'UT'&amp;REF&amp;'JRC2';
	Cargo_Type 		= "CT" &amp; REF;
	TrailerType 	="TRT" &amp; REF;
	TrailerID 		= "TR" &amp; REF;
vars
	tI1					:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	gateAutoComplete,
	hhUnloadEdit		: 	Any;
	tiSet				: 	CM_TISet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	booking				: 	CM_BookingRef;
	vvr					: 	CM_VehicleVisitRecord;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	job					:	CM_RoadJob;
	term				: 	CM_Terminal;
	controller			: 	CMIF_MobileTruckLoaderUnloader;	
	blockStack			: 	CM_TerminalArea;
	tt					: 	CM_TILCType;
	trailer 			: 	CM_TILC;
	ct 					: 	CM_CargoType;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	term			   := self.getTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	gateAutoComplete   := term.getConfig(GateInAutoCompleteBkgrnd);
	hhUnloadEdit   	   := term.getConfig(HhTUnloadEdit);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(GateInAutoCompleteBkgrnd, true);
	term.setConfig(HhTUnloadEdit, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UT" &amp; REF), false);
	self.deleteBooking("UT_HLBOOKING" &amp; REF);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	self.deleteVehicle('UTHM-'&amp;REF);
	self.deleteTerminalArea("HM" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack("HM" &amp; REF, 10, null);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING" &amp; REF , self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING" &amp; REF);
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UT" &amp; REF);	
	
	self.deleteAllCargo(TrailerID,ct);
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);	
	self.assertNotNull(tt);
	
	create tiSet transient;
	tiSet.add(tI1);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.opts.purge();
	self.opts.addAssoc('TrailerImexStatus', TI_IMEX_STATUS_REMAINONBOARD);
	vvr := self.gateInTrailerAndContainer('UTHM-'&amp;REF,TrailerID,tI1.id,tt.code,"2200",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code,"MT",self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Allocate job to jobSheet
	job := vvr.myRoadJob;
	
	//Move vehicle to yard
	self.moveVehicleToYard(job.myVehicle);
	self.assertEqualMsg(job.status,JOB_UNACTIONED,"Job should not be part completed");
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(GateInAutoCompleteBkgrnd, gateAutoComplete);
	term.setConfig(HhTUnloadEdit, hhUnloadEdit);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckShipJobSheet" id="75424e0b-5741-4b24-b0d1-b54ba4226977">
        <source>tCheckShipJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants
	REF		: String  = '60090';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = 'UTWORECIEVESHIP';
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, tI2,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	startDate				: 	TimeStamp;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	firstJob,
	secondJob				: 	CM_Job;
	blockStack				:	CM_BlockStack;
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteTerminalArea("BS1711");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS1711", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTLWVOY"&amp;REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	// tracked items
	tI1 := self.xAddCargo("UTCON1" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI1);
	
	tI2 := self.xAddCargo("UTCON2" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI2);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_60090");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete myPxyWorkPointJobSheet;
	delete pxyVoyJob;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckWOApprovalInv01" id="ed4e2731-bea1-4c45-ba48-b891029425ff">
        <source>tCheckWOApprovalInv01();
/*
Purpose: TFS 51904  Work Orders. If there is an estimate for a cargo work order, when it is approved if the debtor is not prepay then no cash invoice should be created

Date		Who		Reason
01NOV2021	NAVAB1	TFS 51904
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants

	WO_NUM 		= "WO-AB004";
	BS_ID1 		= "UTBS1";
	BS_ID2 		= "UTBS2";
	CONT_ID1	= "WONU2111011";
	CONT_ID2 	= "WONU2111012";
	INV_TYPE 	= "UT_InvWOMove";
	INVLINETYPE = "UT_LineTypeWOMove";
	TRANMAP 	= 'UT_WOMove';
	SERVICE 	= "UT_ServiceWOMove";
	CALCTYPE 	= 'CCT00';
	DEBTOR 		= "UT_DEBTOR_AB";
vars
	blockStack,
	washStack 				: CM_BlockStack;
	ti 						: CM_TrackedItem;
	operator 				: CM_Operator;
	debtor1					: CM_Debtor;
	services				: CM_ServiceByNameDict;
	service1,
	service2				: CM_Service;
	calcType				: CM_CalculationType;
	invType					: CM_InvoiceDesc;
	invLineType1			: CM_InvoiceLineDesc;
	bank 					: CM_Bank;
	cashonly				: Boolean;
	currentRequiresApproval : Boolean;
	tiSet					: CM_TISet;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
begin

	cashonly := app.isCashOnlyEnabled;
	
	app.setPropertyValue("isCashOnlyEnabled",false);

	deleteTerminalArea(BS_ID1);
	blockStack := addBlockStack(BS_ID1, 10, null);
	deleteTerminalArea(BS_ID2);
	washStack := addBlockStack(BS_ID2, 10, null);
	
	self.deleteContainer(CONT_ID1);
	self.deleteContainer(CONT_ID2);
	

	self.deleteInvoiceTransactionMap(1, TRANMAP);
	self.deleteInvoiceType(INV_TYPE);
	self.deleteInvoiceService(SERVICE, FORCED_ERASE);
	self.deleteInvoiceLineType(INVLINETYPE, FORCED_ERASE);

	bank := self.getTerminal().getDefaultCompanyBank();
	
	create services transient;
	invType := self.createInvoiceType(INV_TYPE, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; INV_TYPE &amp; " not created");

	calcType := app.myRoot.allCalculationTypesByCode[CALCTYPE];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CALCTYPE &amp; " not found");
	
	service1 := self.createInvoiceService(SERVICE,"Value of 1", calcType, null);
	self.assertNotNullMsg(service1, SERVICE &amp; " not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType(INVLINETYPE, calcType, invType, services, "SDT1");
	self.assertNotNullMsg(invLineType1, INVLINETYPE &amp; " not created");
	
	// agent and debtor, set rates
	self.deleteDebtor(DEBTOR);

	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	
	operator := self.addOperator("UTAB", "Empty Pool Party Test Operator 1", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(operator,"Operator Create Failed");
	

	self.setServiceRate(service1, debtor1, "01/01/2021".Date, 0.10);
	service2 := bank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2021".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.xLoadTranMapWorkOrder();	
	
	create tiSet transient;
	
	ti := self.addContainerOpts(CONT_ID1, "2200", "APPL", operator);	
	move(ti, blockStack);
	tiSet.add(ti);
	
	ti := self.addContainerOpts(CONT_ID2, "2200", "APPL", operator);		
	move(ti, blockStack);
	tiSet.add(ti);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', BS_ID2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_MOVE );  // for task type to add.

	
	// lets add a basic user entry work order
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WO_NUM,WO_STATUS_USERENTRY,wodArr);
	
	self.assertNotNull(workOrder);
	wod := workOrder.allWoDtls.first;
	
	//test the work order main stuff
	self.assertEqual(workOrder.taskStatus ,  WO_STATUS_USERENTRY);
	//self.assertEqual(workOrder.totalRequired ,  2);							//06.03.2023 navma1 #56457:[56458]
	self.assertEqual(workOrder.id , WO_NUM );
	self.assertNotNull(workOrder.startAtDT);
	self.assertNotNull(workOrder.requiredByDT);
	self.assertNotNull(workOrder.enteredByDT);
	self.assertNotNull(workOrder.myOrganisation);

	//now test the source
	self.assertEqual(wod.CM_WorkOrderTIDtl.allSelectedTIs.listString(Comma,CM_TrackedItem::id.name) ,
					CONT_ID1 &amp; "," &amp; CONT_ID2);	//08.02.2023 navma1 #56457:[56458]
	
	// and the tasks
	self.assertEqual(workOrder.allWoDtls.size , 1);
	self.assertEqual(wod.autoQueueTask , false);
	
	self.assertNotNullMsg(workOrder.myCashReceipt,"Work Order Estimate Not Created, cash receipt");
	
	currentRequiresApproval := self.setApprovalForWODetail(WorkOrderMode_Cargo, WO_TASK_MOVE, false);
	
	self.approveWorkOrder(workOrder);
	self.assertEqual(workOrder.CM_WorkOrderTI.allTIs.listString(Comma,CM_TrackedItem::id.name) ,  CONT_ID1 &amp; "," &amp; CONT_ID2);	//12.01.2023 navma1 #56141 Task#56147
	self.assertTrueMsg( workOrder.taskStatus = WO_STATUS_APPROVED, "Work Order " &amp; WO_NUM &amp; " status has not changed to 'Approved'.");
	
	self.assertNullMsg(workOrder.myCashReceipt.myCashInvoice,"Work Order estimate wrongly created a cash invoice");
	
	
epilog
	self.deleteWorkOrderNoValidation(WO_NUM);			//12.04.2023 navma1 #57569:[57570]
	app.setPropertyValue("isCashOnlyEnabled",cashonly);
	self.setApprovalForWODetail(WorkOrderMode_Cargo, WO_TASK_MOVE, currentRequiresApproval);
	delete services;
	delete tiSet;
	self.resetDefaultTranMap();
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckWOApprovalInv02" id="c1ff9eb8-722a-4f8d-a1d6-7a70c1431873">
        <source>tCheckWOApprovalInv02();
/*
Purpose: TFS 51904  Work Orders. If there is an estimate for a cargo work order, when it is approved if the debtor is prepay then a cash invoice should be created

Date		Who		Reason
01 Nov 2021	NAVAB1	TFS 51904
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants

	WO_NUM = "WO-AB002";
	BS_ID1 = "UTBS1";
	BS_ID2 = "UTBS2";
	CONT_ID1 = "WONU2111011";
	CONT_ID2 = "WONU2111012";
	INV_TYPE = "UT_InvWOMove";
	INVLINETYPE = "UT_LineTypeWOMove";
	TRANMAP = 'UT_WOMove';
	SERVICE = "UT_ServiceWOMove";
	CALCTYPE = 'CCT00';
	DEBTOR = "UT_DEBTOR_AB";
vars
	blockStack,
	washStack 				: CM_BlockStack;
	ti						: CM_TrackedItem;
	operator 				: CM_Operator;
	debtor1					: CM_Debtor;
	services				: CM_ServiceByNameDict;
	service1,
	service2				: CM_Service;
	calcType				: CM_CalculationType;
	invType					: CM_InvoiceDesc;
	invLineType1			: CM_InvoiceLineDesc;
	bank 					: CM_Bank;
	cashonly 				: Boolean;
	currentRequiresApproval : Boolean;
	currentInvoiceProcess   : CM_InvoiceProcess;
	tiSet				    : CM_TISet;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
begin

	cashonly := app.isCashOnlyEnabled;
	
	app.setPropertyValue("isCashOnlyEnabled",false);
	deleteWorkOrderNoValidation(WO_NUM);						//12.04.2023 navma1 #57569:[57570]

	deleteTerminalArea(BS_ID1);
	blockStack := addBlockStack(BS_ID1, 10, null);
	deleteTerminalArea(BS_ID2);
	washStack := addBlockStack(BS_ID2, 10, null);
	
	self.deleteContainer(CONT_ID1);
	self.deleteContainer(CONT_ID2);
	

	self.deleteInvoiceTransactionMap(1, TRANMAP);
	self.deleteInvoiceType(INV_TYPE);
	self.deleteInvoiceService(SERVICE, FORCED_ERASE);
	self.deleteInvoiceLineType(INVLINETYPE, FORCED_ERASE);

	bank := self.getTerminal().getDefaultCompanyBank();
	
	create services transient;
	invType := self.createInvoiceType(INV_TYPE, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; INV_TYPE &amp; " not created");

	calcType := app.myRoot.allCalculationTypesByCode[CALCTYPE];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CALCTYPE &amp; " not found");
	
	service1 := self.createInvoiceService(SERVICE,"Value of 1", calcType, null);
	self.assertNotNullMsg(service1, SERVICE &amp; " not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType(INVLINETYPE, calcType, invType, services, "SDT1");
	self.assertNotNullMsg(invLineType1, INVLINETYPE &amp; " not created");
	
	// agent and debtor, set rates
	self.deleteDebtor(DEBTOR);

	debtor1 := self.addDebtor(DEBTOR, PaymentType_PrePay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	
	operator := self.addOperator("UTAB", "Empty Pool Party Test Operator 1", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(operator,"Operator Create Failed");
	

	self.setServiceRate(service1, debtor1, "01/01/2021".Date, 0.10);
	service2 := bank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2021".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.xLoadTranMapWorkOrder();	
	
	create tiSet transient;
	
	ti := self.addContainerOpts(CONT_ID1, "2200", "APPL", operator);	
	move(ti, blockStack);
	tiSet.add(ti);
	
	ti := self.addContainerOpts(CONT_ID2, "2200", "APPL", operator);		
	move(ti, blockStack);
	tiSet.add(ti);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq'  , 2);
	self.opts.addAssoc('TargetTA'  , BS_ID2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType'  , WO_TASK_MOVE );  // for task type to add.

	
	// lets add a basic user entry work order
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WO_NUM,WO_STATUS_USERENTRY,wodArr);
	
	self.assertNotNull(workOrder);
	wod := workOrder.allWoDtls.first;
	
	//test the work order main stuff
	self.assertEqual(workOrder.taskStatus ,  WO_STATUS_USERENTRY);
	//self.assertEqual(workOrder.totalRequired ,  2);						//06.03.2023 navma1 #56457:[56458]
	self.assertEqual(workOrder.id , WO_NUM );
	self.assertNotNull(workOrder.startAtDT);
	self.assertNotNull(workOrder.requiredByDT);
	self.assertNotNull(workOrder.enteredByDT);
	self.assertNotNull(workOrder.myOrganisation);

	//now test the source
	self.assertEqual(wod.CM_WorkOrderTIDtl.allSelectedTIs.listString(Comma,CM_TrackedItem::id.name)  ,  
					CONT_ID1 &amp; "," &amp; CONT_ID2);	//08.02.2023  #56457:[56458]
	
	// and the tasks
	self.assertEqual(workOrder.allWoDtls.size , 1);
	self.assertEqual(wod.autoQueueTask , false);
	
	self.assertNotNullMsg(workOrder.myCashReceipt,"Work Order Estimate Not Created, cash receipt");
	
	currentRequiresApproval := self.setApprovalForWODetail(WorkOrderMode_Cargo, WO_TASK_MOVE, false);
	
	// SET THE BANK INVOICE PROCESS TO PELINDO
	// WHEN A PRE PAY IS APPROVED THE INVOICE STATUS IS SET TO PREPEND, WHICH IS ON THE PELINDO INVOICE PROCESS NOT THE DEFAULT.
	currentInvoiceProcess := bank.myInvoiceProcess;
	beginTransaction;
	bank.setInvoiceProcess( CM_InvoiceProcessPel1.firstInstance );
	commitTransaction;

	
	self.approveWorkOrder(workOrder);
	self.assertEqual(workOrder.CM_WorkOrderTI.allTIs.listString(Comma,CM_TrackedItem::id.name)  ,  CONT_ID1 &amp; "," &amp; CONT_ID2);	//12.01.2023 navma1 #56141 Task#56147
	self.assertTrueMsg( workOrder.taskStatus = WO_STATUS_APPROVED, "Work Order " &amp; WO_NUM &amp; " status has not changed to 'Approved'.");
	
	self.assertNotNullMsg(workOrder.myCashReceipt.myCashInvoice,"Work Order estimate wrongly did not create a cash invoice");
	
	
epilog
	beginTransaction;
	bank.setInvoiceProcess( currentInvoiceProcess );
	commitTransaction;

	app.setPropertyValue("isCashOnlyEnabled",cashonly);
	self.setApprovalForWODetail(WorkOrderMode_Cargo, WO_TASK_MOVE, currentRequiresApproval);
	delete services;
	delete tiSet;
	self.resetDefaultTranMap();
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckWOJobGroup" id="0d7095a6-8e21-440b-a9ee-1af99c4c6f15">
        <source>tCheckWOJobGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/
constants
	Ref				: String = "60063-1";
	Code			: String = "UTHM" &amp; Ref;
	Description		: String = "Unit Test";
	UCode			: String = "UTHM" &amp; Ref;
	UDescription	: String = "Unit Test";
vars
	pxyWoJobGroup,
	woJobGroup 	: CM_WorkOrderJobGroupMethod;
	terminal	: CM_Terminal;
	detailType	: CM_WorkOrderDetailType;
	detailArr	: CM_WorkOrderDetailTypeArray;
	allVessel	: CM_VesselSet;
	allGC		: IntegerArray;
begin
	terminal := self.getMyTerminal();
	
	create detailArr transient;
	create allGC transient;
	create allVessel transient;
	foreach detailType in app.myRoot.allWorkOrderTaskTypes do
		if detailType.description.cnContains("Receive Cargo") then
			detailArr.add(detailType);
		endif;
	endforeach;
	
	//Delete Work Order Job Group Method
	woJobGroup := terminal.allWOJobGroupMethods[UCode,terminal];
	if woJobGroup &lt;&gt; null then
		app.myTrxDA.trxDeleteWOJobGrouping(woJobGroup , app.myPassport);
	endif;
	
	//Create Work Order Job Group Method
	create pxyWoJobGroup transient;
	allGC.add(1);
	pxyWoJobGroup.setProxy(Code,Description,false,terminal,allGC,allVessel,detailArr);
	
	app.myTrxCA.trxCreateWOJobGrouping(pxyWoJobGroup, woJobGroup, app.myPassport);
	self.assertNotNull(woJobGroup);
	delete pxyWoJobGroup;
	
	//Update Work Order Job Group Method
	beginTransaction;
	pxyWoJobGroup := woJobGroup.pxyCreateUpdateProxy();
	commitTransaction;
	pxyWoJobGroup.setProxy(UCode,UDescription,false,terminal,allGC,allVessel,detailArr);
	
	app.myTrxUA.trxUpdateWOJobGrouping(pxyWoJobGroup, app.myPassport);
	self.assertEqual(woJobGroup.code,UCode);
	self.assertEqual(woJobGroup.description,UDescription);
epilog
	delete detailArr;
	delete allVessel;
	delete allGC;
	delete pxyWoJobGroup;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckingStaging" id="626e0630-298c-4f97-ae8f-e774785512c1">
        <source>tCheckingStaging();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
18 Apr 2024	navpw1	Fixed unit test now uses "Steel Coil" instead of "Cannon Balls" - Causes issues leading to 1018 exception with yard allocations

*/

constants
	REF		: String  = '61583';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = "UTHMVOY"&amp;REF;
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, tI2				:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod,
	wod						: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting		: 	Any;
	blockStack,
	targetBlockStack		:	CM_BlockStack;
	cargoType				: 	CM_CargoType;
	location				: 	CM_LocationsController;
	stop					: 	CM_StopsTable;
	releaseRequest			: 	CM_BulkRelease;
	taSource				: 	CM_TerminalArea;
	code					:	String;
	relTime					: 	TimeStamp;
	reserveDetail			: 	CM_ReserveSelection;
	toDoTaskDescSet     	: 	CM_ToDoTaskDescBySortKey;
	todoSet					: 	CM_ToDoTaskDescSet;
	toDoTaskDesc			: 	CM_ToDoTaskDesc;
	product					: CM_Product;
	
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting  := term.getConfig(UseYardJobsCargoWO);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	commitTransaction;
	
	self.deleteTerminalArea("BS1711");
	self.deleteTerminalArea("BS1901");
	
	// setup stuff 
	blockStack 		 := self.addBlockStack("BS1711", 10, null);
	targetBlockStack := self.addBlockStack("BS1901", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	self.deleteReleaseRequest("UTBULKREL1");
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := term.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UT1" &amp; REF, cargoType);
	self.deleteCargo("UT2" &amp; REF, cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UT1" &amp; REF, cargoType, 100, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UT2" &amp; REF, cargoType, 100, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	beginTransaction;
		tI1.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI2.changeState(TI_STATE_ONSHIP,app.myPassport);
	commitTransaction;
	
	stop := app.myRoot.allStopsTable[2];
	self.clearStopWithExpiry(tI1,stop,"test",app.actualTimeServer().addDays(2).date);
	self.clearStopWithExpiry(tI2,stop,"test",app.actualTimeServer().addDays(2).date);
	
	// Add to do task to the work order detail
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("TodoHM" &amp; REF);
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	toDoTaskDesc := self.createToDoTaskDesc("TodoHM" &amp; REF); 
	self.assertNotNull(toDoTaskDesc);
	
	create todoSet transient;
	todoSet.tryAddIfNotNull(toDoTaskDesc);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 200);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTRel" &amp; REF, BR_TYPE_SHIP, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	// Create the work order detail
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	reserveDetail := releaseRequest.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertEqualMsg(wod.CM_WodRelease.allSelectedTIs.size, 0, "The Selected tracked items size should be 0");
	self.assertEqualMsg(wod.CM_WodRelease.allActionedTIs.size, 0, "The Actioned tracked items size should be 0");
	self.assertEqualMsg(wod.CM_WodRelease.allToDoRequests.first.allSelectedTIs.size, 0, "The Selected tracked items size should be 0");
	self.assertEqualMsg(wod.CM_WodRelease.allToDoRequests.first.allActionedTIs.size, 0, "The Actioned tracked items size should be 0");
	self.assertEqualMsg(reserveDetail.CM_ReserveSelection.allTrackedItems.size, 0, "The tracked items size in reserve detail should be 0");
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	location := targetBlockStack.myLocationsController;
	
	app.myTrxUA.trxUpdateStagedTis(reserveDetail,location,tiSet,term,app.myPassport);
	
	self.assertEqualMsg(tI1.locationId, location.getFullId(), "The Selected tracked item not moved properly");
	self.assertEqualMsg(tI2.locationId, location.getFullId(), "The Selected tracked item not moved properly");
	
	self.assertEqualMsg(wod.CM_WodRelease.allSelectedTIs.size, 2, "The Selected tracked items size should be 2");
	self.assertEqualMsg(wod.CM_WodRelease.allActionedTIs.size, 2, "The Actioned tracked items size should be 2");
	self.assertEqualMsg(wod.CM_WodRelease.allToDoRequests.first.allSelectedTIs.size, 2, "The Selected tracked items size should be 2");
	self.assertEqualMsg(wod.CM_WodRelease.allToDoRequests.first.allActionedTIs.size, 2, "The Actioned tracked items size should be 2");
	self.assertEqualMsg(reserveDetail.CM_ReserveSelection.allTrackedItems.size, 2, "The tracked items size in reserve detail should be 2");
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete toDoTaskDescSet;
	delete todoSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDDReceiveRoad" id="bab782ec-6299-45da-9768-ec7ef15b34ef">
        <updating/>
        <source>tDDReceiveRoad()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
28 Jun 2023 navma1  Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
28 Jun 2023 navma1  Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
*/

constants
	REF: String  =  "58543";
	WOID : String  = 'UT'&amp;REF&amp;'DDR';
vars
	tI1, tI2,tI3,tI4,tI5	:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	gateAutoComplete,
	hhUnloadEdit			: 	Any;
	toDoTaskDesc			: 	CM_ToDoTaskDesc;
	tiSet					: 	CM_TISet;
	todoSet					: 	CM_ToDoTaskDescSet;
	voyage					: 	CM_Voyage;
	vessel 					:	CM_Vessel;
	booking					: 	CM_BookingRef;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod						: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	roadJob					: 	CM_RoadJob;
	wle						:	CM_WorkListEntry;
	term					:   CM_Terminal;
	job						:	CM_Job;
	createPin          	    : Boolean;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	term := self.getTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	gateAutoComplete   := term.getConfig(GateInAutoCompleteBkgrnd);
	hhUnloadEdit   	   := term.getConfig(HhTUnloadEdit);
	createPin          := term.getConfig(NoPINs).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(GateInAutoCompleteBkgrnd, true);
	term.setConfig(HhTUnloadEdit, true);
	term.setConfig(NoPINs, false);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTTI1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTTI2"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTTI3"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTTI4"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTTI5"), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTTI1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTTI2");
	tI3 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTTI3");
	tI4 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTTI4");	
	tI5 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTTI5");		
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI);
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTTI1" &amp; "," &amp; "UTTI2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('mode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );								//28.06.2023 navma1 #58920
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,5,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Approve and Action the work order
	self.xApproveWorkOrder(workOrder);	
	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,5,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//realJobSheet := self.getMyTerminal().allJobSheetsForWorkPoints.first;
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheet();
	endif;
	
	//Allocate job to jobSheet
	create allJobArr transient;
	allJobArr.addNoDuplicates(workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first,false);
	if realJobSheet &lt;&gt; null then
		myPxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	endif;
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//Road Gate
	self.gateInPinReceival(workOrder.getPINNumber,'UTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,5,TRANS_TYPE_WO_TIREC_UPDATED,true,true);
	
	//Allocate job to jobSheet
	foreach job in self.getMyTerminal().myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	allJobArr.clear();
	allJobArr.addNoDuplicates(roadJob,false);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,5,TRANS_TYPE_WO_TIREC_UPDATED,true,true);
	
	//Complete workOrder
	foreach wle in roadJob.workListEntries do
		self.queueWLE(wle);
	endforeach;
	self.moveVehicleToYard(roadJob.myVehicle);
	foreach wle in roadJob.workListEntries do
		self.moveWLE(wle);
	endforeach;
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,5,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
	self.roadExit(roadJob.myVehicleVisit);														//28.06.2023 navma1 #58920
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(GateInAutoCompleteBkgrnd, gateAutoComplete);
	term.setConfig(HhTUnloadEdit, hhUnloadEdit);
	term.setConfig(NoPINs, createPin);
	commitTransaction;
	delete tiSet;
	delete todoSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDDWODGroupingRel" id="f0667e51-8544-4f87-9259-61e3fb5b686b">
        <source>tDDWODGroupingRel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Nov 2023 navhl20 ChangeRequest 61506: EUP | Ship Operations in DD - [54176.010] - [Release] Work Order Detail Grouping

*/

constants
	REF		: String  = '61506';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = 'UTWORELEASESHIP';
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, tI2,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	blockStack				:	CM_BlockStack;
	groMethod				: 	CM_WorkOrderJobGroupMethod;
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteTerminalArea("BS2911");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS2911", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTHMVOY"&amp;REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// tracked items
	tI1 := self.xAddCargo("UTHM1" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI1);
	
	tI2 := self.xAddCargo("UTHM2" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI2);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI2.setSpecialStow("STOW2");
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	
	groMethod := term.allWOJobGroupMethods["UTHMTEST",term];
	self.opts.purge();
	self.opts.addAssoc('GrpMethod', groMethod);
	self.xActionWorkOrder(workOrder);
	
	self.assertEqual(workOrder.allWoDtls.size,2);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobActionTxnCheckPack" id="98b3200e-3d26-49ad-af02-4da7af3633df">
        <source>tJobActionTxnCheckPack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62898: Jade - Unit Test
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
29 Oct 2024 navbs1 Bug MTN-12389: EUP - FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
*/

constants
	REF				= "UT62898";
	WOID 			= "UTWO62898";
	CARGOTYPEDESC 	= "UT_62898";
	BLOCKSTACK		= "BS" &amp;REF;
	Voyage			= "VOY" &amp; REF;
	WPJS			= "UT62898JS";
	TruckId			= 'TRK1'&amp;REF;
vars
	tI1						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	packingCargo1			: CM_TrackedItem;
	attachments				: CMIF_InOutAttachmentArray;
	packTIs					: CM_TIArray;
	wh						: CM_IrregularBlockArea;
	cargoType				: CM_CargoType;
	tiTransaction			: CM_TITransaction;
	tiJobTransaction		: CM_TIJobDetail;
	woTransaction			: CM_WOTransaction;
	woJobTransaction		: CM_WOJobDetail;
	parentPackJob			: CM_WOPackJob;
	jobStartTS,
	jobCompleteTS,
	jobStopTS,
	jobResumeTS				: TimeStamp;
	time					: Time;
	actualString,
	expectedString			: String;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UHLREL1");
	self.deleteVoyage(Voyage);
	
	// vessel and voyage	
	vessel := self.addVesselWithHolds("UTHLVESS1", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteContainer("UT1" &amp; REF);
	self.deleteContainer(REF &amp; "PACK1");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	tI1 := self.addContainerOpts("UT1" &amp; REF, "2200", "MT", operator);	
	
	self.move(tI1, blockStack);	
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("GVS"));
	
	wh := terminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK1", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc('Number', 2);
	self.opts.addAssoc('NumberSec', 200);
	self.opts.addAssoc('ISOType', "2200");
	self.opts.addAssoc('CargoType', cargoType);
	self.opts.addAssoc('PackType', CM_ReserveDetail.PackType_Parent);
	self.opts.addAssoc('PackType1', CM_ReserveDetail.PackType_Child);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UHLREL1", BR_TYPE_PACKING, 1);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	create pxyWod as CM_WodPack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	parentPackJob := wod.CM_WodPack.allJobs.first().CM_WOPackJob;
	
	app.myTrxUA.trxUpdatePackCargo(tI1, packingCargo1, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);	//22.03.2024 navhl20 #62863
	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease,releaseRequest);
	self.packCompleteContainer(tI1.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_PART_COMPLETE, "The job has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_PART_COMPLETE, "The job has not been part completed");
	
	// Job Start
	time := time.addMinutes(5);
	jobStartTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(parentPackJob, Job_Action_Start, jobStartTS, tI1, app.myPassport);				//23.09.2024  navbs1  #12445
	
	// Job Stop
	time := time.addMinutes(5);
	jobStopTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(parentPackJob, Job_Action_Stop, jobStopTS, tI1, app.myPassport);				//23.09.2024  navbs1  #12445
	
	// Job Resume
	time := time.addMinutes(5);
	jobResumeTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(parentPackJob, Job_Action_Resume, jobResumeTS, tI1, app.myPassport);			//23.09.2024  navbs1  #12445
	
	
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(parentPackJob, Job_Action_Complete, jobCompleteTS, tI1, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// Check transaction in WO
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTART);
	self.assertNotNullMsg(woTransaction, "WO Job Start transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "WO Job Start Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "WO Job Start Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, parentPackJob.id, "WO Job Start Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobStart, jobStartTS, "WO Job Start Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTOP);
	self.assertNotNullMsg(woTransaction, "WO Job Stop transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "WO Job Stop Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "WO Job Stop Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, parentPackJob.id, "WO Job Stop Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobEnd, jobStopTS, "WO Job Stop Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBRESUME);
	self.assertNotNullMsg(woTransaction, "WO Job Resume transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "WO Job Resume Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "WO Job Resume Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, parentPackJob.id, "WO Job Resume Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobStart, jobResumeTS, "WO Job Resume Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "WO Job Resume Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNotNullMsg(woTransaction, "WO Job Complete transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "WO Job Complete Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "WO Job Complete Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, parentPackJob.id, "WO Job Complete Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobEnd, jobCompleteTS, "WO Job Complete Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "WO Job Complete Sheet Code incorrect");
	endif;
	
	// Check transaction in Parent container
	tiTransaction := tI1.getLastTransOfType(TRANS_TYPE_TIJOBSTART);
	self.assertNotNullMsg(tiTransaction, "TI Job Start transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, parentPackJob.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobStart, jobStartTS, "TI Job Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	
	//commenting this code as we no longer record JOB STOP AND JOB RESUME transactions against TI
	/*START 29.10.2024  navbs1  #12389
	tiTransaction := tI1.getLastTransOfType(TRANS_TYPE_TIJOBSTOP);
	self.assertNotNullMsg(tiTransaction, "TI Job Stop transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, parentPackJob.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobEnd, jobStopTS, "TI Job Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	
	tiTransaction := tI1.getLastTransOfType(TRANS_TYPE_TIJOBRESUME);
	self.assertNotNullMsg(tiTransaction, "TI Job Resume transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, parentPackJob.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobStart, jobResumeTS, "TI Job Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	END 29.10.2024  navbs1  #12389*/
	
	tiTransaction := tI1.getLastTransOfType(TRANS_TYPE_TIJOBCOMPLETE);
	self.assertNotNullMsg(tiTransaction, "TI Job Complete transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, parentPackJob.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, parentPackJob.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, parentPackJob.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobEnd, jobCompleteTS, "TI Job Start incorrect");
	if parentPackJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, parentPackJob.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	
	expectedString := jobStartTS.asStringJMT() &amp; " to " &amp; jobStopTS.asStringJMT() &amp; CrLf &amp; jobResumeTS.asStringJMT() &amp; " to " &amp; jobCompleteTS.asStringJMT();
	actualString := parentPackJob.getJobActivity();
	//20/03/2024	navkc1 CR 62694 Task 62901
	self.assertEqualMsg(actualString, expectedString, "Job activity string is not correct!");	
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete packTIs;
	delete attachments;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobActionTxnCheckRail" id="33e9931c-36f3-4716-90e2-86130861bb20">
        <source>tJobActionTxnCheckRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62898: Jade - Unit Test
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
16 Oct 2024 navbs1 Bug MTN-23124: EUP - FR | 54883 - Start and End Times for Operations in Mobile App - part 3


*/
constants
	REF 			: String = UT_DSL.TFS58342.String;
	MyTrain 		: String = 'UTTR2'&amp;REF;
	MyWagon 		: String = "UK-"&amp;REF&amp;"_2";
	RailAreaId 		: String = "UTRA1";
	BlockStack 		: String = "UTBS2" &amp; REF;
	WagonClass		: String = "US";
	YA 				: String = 'UT_YA_'&amp;REF;
	CargoId1		: String = "UTCNT5"&amp;REF;
	CargoId2		: String = "UTCNT6"&amp;REF;
	WOID 			: String = 'UT'&amp;REF&amp;'JRC2';
	ReleaseRequest 	: String = "UTBULKREQ"&amp; REF;
vars
	releaseRequest 		: CM_BulkRelease;
	train,
	pxyTrain			: CM_Train;
	wagonMaster			: CM_WagonMaster;
	term 				: CM_Terminal;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	railArea 			: CM_Rail;
	pxyMaster			: CM_WagonMaster;
	wagonClass			: CM_WagonClass;
	tI1,
	tI2					: CM_TrackedItem;
	bs1 				: CM_BlockStack;
	operator 			: CM_Operator;
	tiSet				: CM_TISet;
	wod,
	pxyWod				: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	job 				: CM_Job;
	code 				: String;
	relTime				: TimeStamp;
	wagon 				: CM_Wagon;
	railLine			: CM_RailLine;
	cmifObjects 		: ObjectArray;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	railIORake 			: CM_RailJSInOutRake;
	obj 				: Object;
	wleArray,
	wlesWithWarnings			: CM_WLEArray;
	allRailJobsArray	: CM_RailJobArray;
	agent				: CM_RailProcessingAgent;
	wagonArray			: CM_WagonArray;
	railJob 			: CM_RailJob;
	cmifRakeRegion		: CMIF_RakeRegion;
	trainSet 			: CM_TrainSet;
	woTransaction			: CM_WOTransaction;
	woJobTransaction		: CM_WOJobDetail;
	jobStartTS,
	jobCompleteTS,
	jobStopTS,
	jobResumeTS				: TimeStamp;
	event					: CM_EventTransaction;
	wagonEvent				: CMEVT_WagonTransaction;
	time					: Time;
	actualString,
	expectedString			: String;
begin
	term := self.getMyTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, true);
		term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// setup delete stuff
	self.deleteWorkOrderNoValidation(WOID);
	
	self.deleteContainer(CargoId1);
	self.deleteContainer(CargoId2);
	self.deleteReleaseRequest(ReleaseRequest);
		
	// wagon master stuff
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	self.deleteTrain(MyTrain,null);
	self.deleteRailArea(RailAreaId);
	
	// create the train and wagons
	train := self.addTrain(MyTrain,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[WagonClass];
	self.assertNotNullMsg(train, "Cannot find wagon class");
	
	create pxyMaster transient;
	pxyMaster.setProxy(MyWagon, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	self.assertNoTrxErrorsOrWarnings();
	
	wagon := self.addWagon(MyWagon,wagonClass.code,train);
	self.assertNotNullMsg(wagon, "Wagon not created");
	
	// create the blockstack
	self.deleteTerminalArea(BlockStack);
	bs1 := self.addBlockStack(BlockStack, 10, null);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	self.disableAllYA (true);
	self.deleteYA (YA);
	self.addYACatchAll (YA, bs1);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	// create the tracked items
	tI1 := self.addContainerOpts(CargoId1, "2200", "MT", operator);
	self.assertNotNullMsg(tI1, "TrackedItem");
	tI2 := self.addContainerOpts(CargoId2, "2200", "MT", operator);
	self.assertNotNullMsg(tI2, "TrackedItem");
	
	// move the containers to the blockstack
	self.move(tI1, bs1.myLocationsController);
	self.move(tI2, bs1.myLocationsController);
	
	self.deleteStops(tI1);
	self.deleteStops(tI2);
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);
	 
	// create the release request
	self.opts.purge();
	self.opts.addAssoc("ISOType", '2200');
	self.opts.addAssoc("ISOGroup", 'GEN2');
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc('Number', 2);
	releaseRequest := self.addReleaseById(ReleaseRequest,BR_TYPE_RAIL,tiSet);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_RAIL);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	// these two settings are used to get the train and set it on the work order
	self.opts.addAssoc('transObj', MyTrain);
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;
	
	self.opts.addAssoc("release", releaseRequest);
	// assign release to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// arrive the train
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	railLine.switchPositions(wagon, 01);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	// confirm the train IN 
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	create allRailJobsArray transient;
	foreach railJob in railIORake.railJobs do 
		allRailJobsArray.add(railJob);
	endforeach;
	
	// get the rail jobs
	create wleArray transient;
	create agent transient;
	create wagonArray transient; 
	
    wagonArray.clear();
    wleArray.clear();
	
    wagonArray.add( train.allWagonsByOrderInward[1]);
	railJob := allRailJobsArray.first;
    wleArray.add(railJob.workListEntries.first);
	allRailJobsArray.remove(railJob);
    agent.initialise( self.getTerminal );
    agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
    delete agent;
	
	// Queue the WLE 
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport);

	self.assertTrueMsg(tI1.myPrimaryQueuedLocation &lt;&gt; null, "container did not queue");
    // Move the WLE to the Wagon
    self.moveWLEWithNoAssert(wleArray[1]);
    self.assertNoTrxErrorsOrWarnings();
	
	// check work order is part complete
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	create agent transient;
	wagonArray.clear();
    wleArray.clear();
	
	wagonArray.add( train.allWagonsByOrderInward[1]);
	railJob := allRailJobsArray.first;
    wleArray.add(railJob.workListEntries.first);
	allRailJobsArray.remove(railJob);
    agent.initialise( self.getTerminal );
    agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
    delete agent;
	
	// Queue the WLE 
	app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport);
	
	self.assertTrueMsg(tI2.myPrimaryQueuedLocation &lt;&gt; null, "container did not queue");
	
	// Job Start
	time := time.addMinutes(5);
	jobStartTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(railJob, Job_Action_Start, jobStartTS, null, app.myPassport);			//23.09.2024  navbs1  #12445	
	
	// Job Stop
	time := time.addMinutes(5);
	jobStopTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(railJob, Job_Action_Stop, jobStopTS, null, app.myPassport);				//23.09.2024  navbs1  #12445
	
	// Job Resume
	time := time.addMinutes(5);
	jobResumeTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(railJob, Job_Action_Resume, jobResumeTS, null, app.myPassport);			//23.09.2024  navbs1  #12445
	
	
    // Move the WLE to the Wagon
    self.moveWLEWithNoAssert(wleArray[1]);
    self.assertNoTrxErrorsOrWarnings();
	
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(railJob, Job_Action_Complete, jobCompleteTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// check work order is part complete
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	// depart the train 
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);
	
	// Check transaction in WO
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTART);
	self.assertNotNullMsg(woTransaction, "WO Job Start transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, railJob.getJobTypeDescription(), "WO Job Start Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, railJob.getJobClassNiceString(), "WO Job Start Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, railJob.getJobId(), "WO Job Start Id incorrect");				//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobStart, jobStartTS, "WO Job Start Start incorrect");
	if railJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, railJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_WagonJobStart, jobStartTS];
				self.assertNotNullMsg(event, "Event Job Start should not be null");
				wagonEvent := event.CMEVT_WagonTransaction;
				self.assertEqualMsg(wagonEvent.jobDesc, railJob.getJobTypeDescription(), "Event Start Job Description incorrect");
				self.assertEqualMsg(wagonEvent.jobType, railJob.getJobClassNiceString(), "Event Start Job Type incorrect");
				self.assertEqualMsg(wagonEvent.jobId, railJob.getJobId(), "Event Start Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(wagonEvent.jobStart, jobStartTS, "Event Start Job Start incorrect");
				if railJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(wagonEvent.jobSheetCode, railJob.myJobSheet.externalName, "Event Start Job Sheet incorrect");
				endif;
				self.assertEqualMsg(wagonEvent.myWagon, wagon, "Event Start Job Wagon incorrect");
				self.assertEqualMsg(wagonEvent.myTrain, train, "Event Start Job Train incorrect");
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTOP);
	self.assertNotNullMsg(woTransaction, "WO Job Stop transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, railJob.getJobTypeDescription(), "WO Job Stop Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, railJob.getJobClassNiceString(), "WO Job Stop Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, railJob.getJobId(), "WO Job Stop Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobEnd, jobStopTS, "WO Job Stop Start incorrect");
	if railJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, railJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_WagonJobStop, jobStopTS];
				self.assertNotNullMsg(event, "Event Job Stop should not be null");
				wagonEvent := event.CMEVT_WagonTransaction;
				self.assertEqualMsg(wagonEvent.jobDesc, railJob.getJobTypeDescription(), "Event Stop Job Description incorrect");
				self.assertEqualMsg(wagonEvent.jobType, railJob.getJobClassNiceString(), "Event Stop Job Type incorrect");
				self.assertEqualMsg(wagonEvent.jobId, railJob.getJobId(), "Event Stop Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(wagonEvent.jobEnd, jobStopTS, "Event Stop Job End incorrect");
				if railJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(wagonEvent.jobSheetCode, railJob.myJobSheet.externalName, "Event Stop Job Sheet incorrect");
				endif;
				self.assertEqualMsg(wagonEvent.myWagon, wagon, "Event Stop Job Wagon incorrect");
				self.assertEqualMsg(wagonEvent.myTrain, train, "Event Stop Job Train incorrect");
		
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBRESUME);
	self.assertNotNullMsg(woTransaction, "WO Job Resume transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, railJob.getJobTypeDescription(), "WO Job Resume Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, railJob.getJobClassNiceString(), "WO Job Resume Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, railJob.getJobId(), "WO Job Resume Id incorrect");				//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobStart, jobResumeTS, "WO Job Resume Start incorrect");
	if railJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, railJob.myJobSheet.externalName, "WO Job Resume Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_WagonJobResume, jobResumeTS];
				self.assertNotNullMsg(event, "Event Job Resume should not be null");
				wagonEvent := event.CMEVT_WagonTransaction;
				self.assertEqualMsg(wagonEvent.jobDesc, railJob.getJobTypeDescription(), "Event Resume Job Description incorrect");
				self.assertEqualMsg(wagonEvent.jobType, railJob.getJobClassNiceString(), "Event Resume Job Type incorrect");
				self.assertEqualMsg(wagonEvent.jobId, railJob.getJobId(), "Event Resume Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(wagonEvent.jobStart, jobResumeTS, "Event Resume Job Start incorrect");
				if railJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(wagonEvent.jobSheetCode, railJob.myJobSheet.externalName, "Event Resume Job Sheet incorrect");
				endif;
				self.assertEqualMsg(wagonEvent.myWagon, wagon, "Event Resume Job Wagon incorrect");
				self.assertEqualMsg(wagonEvent.myTrain, train, "Event Resume Job Train incorrect");
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNotNullMsg(woTransaction, "WO Job Complete transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, railJob.getJobTypeDescription(), "WO Job Complete Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, railJob.getJobClassNiceString(), "WO Job Complete Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, railJob.getJobId(), "WO Job Complete Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobEnd, jobCompleteTS, "WO Job Complete Start incorrect");
	if railJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, railJob.myJobSheet.externalName, "WO Job Complete Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_WagonJobComplete, jobCompleteTS];
				self.assertNotNullMsg(event, "Event Job Complete should not be null");
				wagonEvent := event.CMEVT_WagonTransaction;
				self.assertEqualMsg(wagonEvent.jobDesc, railJob.getJobTypeDescription(), "Event Complete Job Description incorrect");
				self.assertEqualMsg(wagonEvent.jobType, railJob.getJobClassNiceString(), "Event Complete Job Type incorrect");
				self.assertEqualMsg(wagonEvent.jobId, railJob.getJobId(), "Event Complete Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(wagonEvent.jobEnd, jobCompleteTS, "Event Complete Job End incorrect");
				if railJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(wagonEvent.jobSheetCode, railJob.myJobSheet.externalName, "Event Complete Job Sheet incorrect");
				endif;
				self.assertEqualMsg(wagonEvent.myWagon, wagon, "Event Complete Job Wagon incorrect");
				self.assertEqualMsg(wagonEvent.myTrain, train, "Event Complete Job Train incorrect");
	
	expectedString := jobStartTS.asStringJMT() &amp; " to " &amp; jobStopTS.asStringJMT() &amp; CrLf &amp; jobResumeTS.asStringJMT() &amp; " to " &amp; jobCompleteTS.asStringJMT();
	actualString := railJob.getJobActivity();
	//20/03/2024	navkc1 CR 62694 Task 62901
	self.assertEqualMsg(actualString, expectedString, "Job activity string is not correct!");	
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
epilog
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
		term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete pxyMaster;
	delete tiSet;
	delete pxyWod;
	delete wodArr;
	delete pxyWorkOrder;
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete pxyTrain;
	delete cmifObjects;
	delete wleArray;
	delete wagonArray;
	delete allRailJobsArray;
	delete trainSet;
	delete cmifRakeRegion;
	self.disableAllYA (false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobActionTxnCheckRoad" id="dcf404ce-4cbb-45ea-9af1-b1c2ad9baa6b">
        <updating/>
        <source>tJobActionTxnCheckRoad() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62898: Jade - Unit Test
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
16 Oct 2024 navbs1 Bug MTN-23124: EUP - FR | 54883 - Start and End Times for Operations in Mobile App - part 3

*/
constants
	REF: String  =  "58543";
	WOID : String  = 'UT'&amp;REF&amp;'DDR';
vars
	tI1						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	gateAutoComplete,
	hhUnloadEdit			: Any;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	tiSet					: CM_TISet;
	todoSet					: CM_ToDoTaskDescSet;
	voyage					: CM_Voyage;
	vessel 					: CM_Vessel;
	booking					: CM_BookingRef;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	myPxyWorkPointJobSheet,
	realJobSheet			: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	roadJob					: CM_RoadJob;
	wle						: CM_WorkListEntry;
	term					: CM_Terminal;
	job						: CM_Job;
	woTransaction			: CM_WOTransaction;
	woJobTransaction		: CM_WOJobDetail;
	jobStartTS,
	jobCompleteTS,
	jobStopTS,
	jobResumeTS				: TimeStamp;
	vvr						: CM_VehicleVisitRecord;
	vvrDetail				: CM_VehicleVisitRecordDetail;
	event					: CM_EventTransaction;
	truckEvent				: CMEVT_TruckEvent;
	time					: Time;
	actualString,
	expectedString			: String;
	createPin          	    : Boolean;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	
	term := self.getTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	gateAutoComplete   := term.getConfig(GateInAutoCompleteBkgrnd);
	hhUnloadEdit   	   := term.getConfig(HhTUnloadEdit);
	createPin          := term.getConfig(NoPINs).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(GateInAutoCompleteBkgrnd, true);
	term.setConfig(HhTUnloadEdit, true);
	term.setConfig(NoPINs, false);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTTI1"), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	self.deleteVehicle('UTHL'&amp;REF);							//16.10.2024  navbs1  #23124
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 1);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTTI1");	
	
	create tiSet transient;
	tiSet.add(tI1);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI);
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 1);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTTI1" &amp; "," &amp; "UTTI2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('mode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Approve and Action the work order
	self.xApproveWorkOrder(workOrder);	
	
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheet();
	endif;
	
	//Allocate job to jobSheet
	create allJobArr transient;
	allJobArr.addNoDuplicates(workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first,false);
	if realJobSheet &lt;&gt; null then
		myPxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	endif;
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//Road Gate
	self.gateInPinReceival(workOrder.getPINNumber,'UTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,true);
	
	//Allocate job to jobSheet
	foreach job in self.getMyTerminal().myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	allJobArr.clear();
	allJobArr.addNoDuplicates(roadJob,false);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,true);
	
	// Job Start
	time := time.addMinutes(5);
	jobStartTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(roadJob, Job_Action_Start, jobStartTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// Job Stop
	time := time.addMinutes(5);
	jobStopTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(roadJob, Job_Action_Stop, jobStopTS, null, app.myPassport);			//23.09.2024  navbs1  #12445
	
	// Job Resume
	time := time.addMinutes(5);
	jobResumeTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(roadJob, Job_Action_Resume, jobResumeTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	//Complete workOrder
	foreach wle in roadJob.workListEntries do
		self.queueWLE(wle);
	endforeach;
	self.moveVehicleToYard(roadJob.myVehicle);
	foreach wle in roadJob.workListEntries do
		self.moveWLE(wle);
	endforeach;
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,1,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
	
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(roadJob, Job_Action_Complete, jobCompleteTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	vvr := roadJob.myVehicleVisit;
	// Check transaction in WO
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTART);
	self.assertNotNullMsg(woTransaction, "WO Job Start transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, roadJob.getJobTypeDescription(), "WO Job Start Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, roadJob.getJobClassNiceString(), "WO Job Start Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, roadJob.getJobId(), "WO Job Start Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobStart, jobStartTS, "WO Job Start Start incorrect");
	if roadJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, roadJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_TruckJobStart, jobStartTS];
				self.assertNotNullMsg(event, "Event Job Start should not be null");
				truckEvent := event.CMEVT_TruckEvent;
				self.assertEqualMsg(truckEvent.jobDesc, roadJob.getJobTypeDescription(), "Event Start Job Description incorrect");
				self.assertEqualMsg(truckEvent.jobType, roadJob.getJobClassNiceString(), "Event Start Job Type incorrect");
				self.assertEqualMsg(truckEvent.jobId, roadJob.getJobId(), "Event Start Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(truckEvent.jobStart, jobStartTS, "Event Start Job Start incorrect");
				if roadJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(truckEvent.jobSheetCode, roadJob.myJobSheet.externalName, "Event Start Job Sheet incorrect");
				endif;
				self.assertEqualMsg(truckEvent.getVehicleVisit(), vvr, "Event Start Job VVR incorrect");
				self.assertEqualMsg(truckEvent.myWOTransaction, woJobTransaction, "Event Start Job WO Transaction incorrect");
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTOP);
	self.assertNotNullMsg(woTransaction, "WO Job Stop transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, roadJob.getJobTypeDescription(), "WO Job Stop Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, roadJob.getJobClassNiceString(), "WO Job Stop Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, roadJob.getJobId(), "WO Job Stop Id incorrect");				//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobEnd, jobStopTS, "WO Job Stop Start incorrect");
	if roadJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, roadJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_TruckJobStop, jobStopTS];
				self.assertNotNullMsg(event, "Event Job Stop should not be null");
				truckEvent := event.CMEVT_TruckEvent;
				self.assertEqualMsg(truckEvent.jobDesc, roadJob.getJobTypeDescription(), "Event Stop Job Description incorrect");
				self.assertEqualMsg(truckEvent.jobType, roadJob.getJobClassNiceString(), "Event Stop Job Type incorrect");
				self.assertEqualMsg(truckEvent.jobId, roadJob.getJobId(), "Event Stop Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(truckEvent.jobEnd, jobStopTS, "Event Stop Job End incorrect");
				if roadJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(truckEvent.jobSheetCode, roadJob.myJobSheet.externalName, "Event Stop Job Sheet incorrect");
				endif;
				self.assertEqualMsg(truckEvent.getVehicleVisit(), vvr, "Event Stop Job VVR incorrect");
				self.assertEqualMsg(truckEvent.myWOTransaction, woJobTransaction, "Event Stop Job WO Transaction incorrect");
		
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBRESUME);
	self.assertNotNullMsg(woTransaction, "WO Job Resume transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, roadJob.getJobTypeDescription(), "WO Job Resume Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, roadJob.getJobClassNiceString(), "WO Job Resume Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, roadJob.getJobId(), "WO Job Resume Id incorrect");				//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobStart, jobResumeTS, "WO Job Resume Start incorrect");
	if roadJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, roadJob.myJobSheet.externalName, "WO Job Resume Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_TruckJobResume, jobResumeTS];
				self.assertNotNullMsg(event, "Event Job Resume should not be null");
				truckEvent := event.CMEVT_TruckEvent;
				self.assertEqualMsg(truckEvent.jobDesc, roadJob.getJobTypeDescription(), "Event Resume Job Description incorrect");
				self.assertEqualMsg(truckEvent.jobType, roadJob.getJobClassNiceString(), "Event Resume Job Type incorrect");
				self.assertEqualMsg(truckEvent.jobId, roadJob.getJobId(), "Event Resume Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(truckEvent.jobStart, jobResumeTS, "Event Resume Job Start incorrect");
				if roadJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(truckEvent.jobSheetCode, roadJob.myJobSheet.externalName, "Event Resume Job Sheet incorrect");
				endif;
				self.assertEqualMsg(truckEvent.getVehicleVisit(), vvr, "Event Resume Job VVR incorrect");
				self.assertEqualMsg(truckEvent.myWOTransaction, woJobTransaction, "Event Resume Job WO Transaction incorrect");
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNotNullMsg(woTransaction, "WO Job Complete transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, roadJob.getJobTypeDescription(), "WO Job Complete Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, roadJob.getJobClassNiceString(), "WO Job Complete Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, roadJob.getJobId(), "WO Job Complete Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobEnd, jobCompleteTS, "WO Job Complete Start incorrect");
	if roadJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, roadJob.myJobSheet.externalName, "WO Job Complete Sheet Code incorrect");
	endif;
	
				// Check Event created for Job Actions
				event := term.allEventsByTypeDateTime[EVT_TruckJobComplete, jobCompleteTS];
				self.assertNotNullMsg(event, "Event Job Complete should not be null");
				truckEvent := event.CMEVT_TruckEvent;
				self.assertEqualMsg(truckEvent.jobDesc, roadJob.getJobTypeDescription(), "Event Complete Job Description incorrect");
				self.assertEqualMsg(truckEvent.jobType, roadJob.getJobClassNiceString(), "Event Complete Job Type incorrect");
				self.assertEqualMsg(truckEvent.jobId, roadJob.getJobId(), "Event Complete Job Id incorrect");		//16.10.2024  navbs1  #23124
				self.assertEqualMsg(truckEvent.jobEnd, jobCompleteTS, "Event Complete Job End incorrect");
				if roadJob.myJobSheet &lt;&gt; null then
					self.assertEqualMsg(truckEvent.jobSheetCode, roadJob.myJobSheet.externalName, "Event Complete Job Sheet incorrect");
				endif;
				self.assertEqualMsg(truckEvent.getVehicleVisit(), vvr, "Event Complete Job VVR incorrect");
				self.assertEqualMsg(truckEvent.myWOTransaction, woJobTransaction, "Event Complete Job WO Transaction incorrect");
	
	expectedString := jobStartTS.asStringJMT() &amp; " to " &amp; jobStopTS.asStringJMT() &amp; CrLf &amp; jobResumeTS.asStringJMT() &amp; " to " &amp; jobCompleteTS.asStringJMT();
	actualString := roadJob.getJobActivity();
	
	self.roadExit(vvr);
	
	//20/03/2024	navkc1 CR 62694 Task 62901
	self.assertEqualMsg(actualString, expectedString, "Job activity string is not correct!");	
	
	// Check VVR Details created for Job Actions
	vvrDetail := vvr.allVehicleVisitRecordDetails[jobStartTS, VisitRecord_JobStart];
	self.assertNotNullMsg(vvrDetail, "VVR Detail Job Start should not be null");
	
	vvrDetail := vvr.allVehicleVisitRecordDetails[jobStopTS, VisitRecord_JobStop];
	self.assertNotNullMsg(vvrDetail, "VVR Detail Job Stop should not be null");
	
	vvrDetail := vvr.allVehicleVisitRecordDetails[jobResumeTS, VisitRecord_JobResume];
	self.assertNotNullMsg(vvrDetail, "VVR Detail Job Resume should not be null");
	
	vvrDetail := vvr.allVehicleVisitRecordDetails[jobCompleteTS, VisitRecord_JobComplete];
	self.assertNotNullMsg(vvrDetail, "VVR Detail Job Complete should not be null");
	
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(GateInAutoCompleteBkgrnd, gateAutoComplete);
	term.setConfig(HhTUnloadEdit, hhUnloadEdit);
	term.setConfig(NoPINs, createPin);
	commitTransaction;
	delete tiSet;
	delete todoSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobActionTxnCheckUnpack" id="be85ebe4-daeb-4d15-82b3-cba5c8a19db0">
        <source>tJobActionTxnCheckUnpack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62898: Jade - Unit Test
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues

*/
constants
	REF		= "UT62898";
	WOID 	= "UTWO62898";
	CARGOTYPEDESC = "UT_62898";
vars
	container			: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	job 				: CM_Job;
	blockstack1			: CM_BlockStack;
	cargoType			: CM_CargoType;
	packingCargo1,
	packingCargo2		: CMIF_InOutAttachment;
	attachments			: CMIF_InOutAttachmentArray;
	terminal			: CM_Terminal;
	unpackTIs			: CM_TIArray;
	tiSet				: CM_TISet;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	tiTransaction		: CM_TITransaction;
	tiJobTransaction	: CM_TIJobDetail;
	woTransaction		: CM_WOTransaction;
	woJobTransaction	: CM_WOJobDetail;
	jobStartTS,
	jobCompleteTS,
	jobStopTS,
	jobResumeTS			: TimeStamp;
	time					: Time;
	actualString,
	expectedString			: String;
begin
	/*
	** Setup Section, create the work order with a TI unpack task with a tracked item
	*/
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	// Setup the work order options
	self.deleteContainer("UT1" &amp; REF);
	self.deleteContainer("UT2" &amp; REF);
	
	container := self.addContainerOpts("UT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	// Cargo Type
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", false);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");

	self.deleteCargo(REF &amp; "PACK1", cargoType);
	self.deleteCargo(REF &amp; "PACK2", cargoType);
	
	create packingCargo1 transient;
	packingCargo1.set(terminal, cargoType.id, REF &amp; "PACK1", "", 100); 
	packingCargo1.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create packingCargo2 transient;
	packingCargo2.set(terminal, cargoType.id, REF &amp; "PACK2", "", 190); 
	packingCargo2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(packingCargo1);
	attachments.add(packingCargo2);
	
	addContainerChildren(container.CM_Container, attachments);
	assertEqualMsg(container.allChildren.size(), 2, "Doesn't have two children");
	
	create unpackTIs transient;
	unpackTIs.add(container.allChildren.first);
	
	self.deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	
	self.deleteTerminalArea("UTBS2" &amp; REF);
	blockstack1 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.move(container, blockstack1);	
	
	self.opts.purge();
	self.opts.addAssoc('unpackTA', "UTBS1" &amp; REF);
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	self.opts.addAssoc('TaskType',WO_TASK_UNPACK );
	
	create tiSet transient;
	tiSet.add(container);														//12.01.2023 navma1 #56141 Task#56147

	// Create the work order
	create pxyWod as CM_WodUnpack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIUNPACK_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIUNPACK_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(container));
	endforeach;
	
	// Job Start
	time := time.addMinutes(5);
	jobStartTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Start, jobStartTS, container, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// Job Stop
	time := time.addMinutes(5);
	jobStopTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Stop, jobStopTS, container, app.myPassport);			//23.09.2024  navbs1  #12445
	
	// Job Resume
	time := time.addMinutes(5);
	jobResumeTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Resume, jobResumeTS, container, app.myPassport);		//23.09.2024  navbs1  #12445
	
	/*
	** Part complete then complete the work order
	*/
	
	// Move then unpack the container
	self.move(container, container.myPrimaryQueuedLocation);
	self.unpackContainer(container, unpackTIs);
	self.unpackCompleteContainer(container);
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,1,TRANS_TYPE_WO_TIUNPACK_COMPLET,true,false);
	
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Complete, jobCompleteTS, container, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// Check transaction in WO
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTART);
	self.assertNotNullMsg(woTransaction, "WO Job Start transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, job.getJobTypeDescription(), "WO Job Start Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, job.getJobClassNiceString(), "WO Job Start Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, job.id, "WO Job Start Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobStart, jobStartTS, "WO Job Start Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, job.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTOP);
	self.assertNotNullMsg(woTransaction, "WO Job Stop transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, job.getJobTypeDescription(), "WO Job Stop Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, job.getJobClassNiceString(), "WO Job Stop Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, job.id, "WO Job Stop Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobEnd, jobStopTS, "WO Job Stop Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, job.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBRESUME);
	self.assertNotNullMsg(woTransaction, "WO Job Resume transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, job.getJobTypeDescription(), "WO Job Resume Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, job.getJobClassNiceString(), "WO Job Resume Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, job.id, "WO Job Resume Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobStart, jobResumeTS, "WO Job Resume Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, job.myJobSheet.externalName, "WO Job Resume Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNotNullMsg(woTransaction, "WO Job Complete transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, job.getJobTypeDescription(), "WO Job Complete Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, job.getJobClassNiceString(), "WO Job Complete Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, job.id, "WO Job Complete Id incorrect");
	self.assertEqualMsg(woJobTransaction.jobEnd, jobCompleteTS, "WO Job Complete Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, job.myJobSheet.externalName, "WO Job Complete Sheet Code incorrect");
	endif;
	
	// Check transaction in Parent container
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBSTART);
	self.assertNotNullMsg(tiTransaction, "TI Job Start transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, job.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, job.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, job.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobStart, jobStartTS, "TI Job Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, job.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	
	//commenting this code as we no longer record JOB STOP AND JOB RESUME transactions against TI
	/*START 23.09.2024  navbs1  #12445
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBSTOP);
	self.assertNotNullMsg(tiTransaction, "TI Job Stop transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, job.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, job.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, job.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobEnd, jobStopTS, "TI Job Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, job.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBRESUME);
	self.assertNotNullMsg(tiTransaction, "TI Job Resume transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, job.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, job.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, job.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobStart, jobResumeTS, "TI Job Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, job.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	END 23.09.2024  navbs1  #12445*/
	
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBCOMPLETE);
	self.assertNotNullMsg(tiTransaction, "TI Job Complete transaction should not be null");
	tiJobTransaction := tiTransaction.CM_TIJobDetail;
	self.assertEqualMsg(tiJobTransaction.jobDesc, job.getJobTypeDescription(), "TI Job Description incorrect");
	self.assertEqualMsg(tiJobTransaction.jobType, job.getJobClassNiceString(), "TI Job Type incorrect");
	self.assertEqualMsg(tiJobTransaction.jobId, job.id, "TI Job Id incorrect");
	self.assertEqualMsg(tiJobTransaction.jobEnd, jobCompleteTS, "TI Job Start incorrect");
	if job.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(tiJobTransaction.jobSheetCode, job.myJobSheet.externalName, "TI Job Sheet Code incorrect");
	endif;
	
	expectedString := jobStartTS.asStringJMT() &amp; " to " &amp; jobStopTS.asStringJMT() &amp; CrLf &amp; jobResumeTS.asStringJMT() &amp; " to " &amp; jobCompleteTS.asStringJMT();
	actualString := job.getJobActivity();
	//20/03/2024	navkc1 CR 62694 Task 62901
	self.assertEqualMsg(actualString, expectedString, "Job activity string is not correct!");	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	delete packingCargo1;
	delete packingCargo2;
	delete attachments;
	delete unpackTIs;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobActionTxnCheckUnpackScan" id="c3909a45-f398-47a2-a658-594dcf996168">
        <source>tJobActionTxnCheckUnpackScan();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2024 navbs1  Initial Creation Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue

*/
constants
	REF		= "UT14791";
	WOID 	= "UTWO14791";
	CARGOTYPEDESC = "UT_14791";
vars
	container			: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	job 				: CM_Job;
	blockstack1			: CM_BlockStack;
	cargoType			: CM_CargoType;
	packingCargo1,
	packingCargo2		: CMIF_InOutAttachment;
	attachments			: CMIF_InOutAttachmentArray;
	terminal			: CM_Terminal;
	unpackTIs			: CM_TIArray;
	tiSet				: CM_TISet;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	tiTransaction		: CM_TITransaction;
	woTransaction		: CM_WOTransaction;
	jobStartTS,
	jobCompleteTS,
	jobStopTS,
	jobResumeTS			: TimeStamp;
	time					: Time;
	actualString,
	expectedString			: String;
begin
	/*
	** Setup Section, create the work order with a TI unpack task with a tracked item
	*/
	
	// Set the config to use yard jobs for the terminal
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	// Setup the work order options
	self.deleteContainer("UT1" &amp; REF);
	
	container := self.addContainerOpts("UT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	// Cargo Type
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", false);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");

	self.deleteCargo(REF &amp; "PACK1", cargoType);
	self.deleteCargo(REF &amp; "PACK2", cargoType);
	
	create packingCargo1 transient;
	packingCargo1.set(terminal, cargoType.id, REF &amp; "PACK1", "", 100); 
	packingCargo1.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create packingCargo2 transient;
	packingCargo2.set(terminal, cargoType.id, REF &amp; "PACK2", "", 190); 
	packingCargo2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(packingCargo1);
	attachments.add(packingCargo2);
	
	addContainerChildren(container.CM_Container, attachments);
	assertEqualMsg(container.allChildren.size(), 2, "Doesn't have two children");
	
	
	self.deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	
	self.deleteTerminalArea("UTBS2" &amp; REF);
	blockstack1 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.move(container, blockstack1);	
	
	self.opts.purge();
	self.opts.addAssoc('unpackTA', "UTBS1" &amp; REF);
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	self.opts.addAssoc('TaskType',WO_TASK_UNPACK );
	
	create tiSet transient;
	tiSet.add(container);														

	// Create the work order
	create pxyWod as CM_WodUnpack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,1,TRANS_TYPE_WO_TIUNPACK_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIUNPACK_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(container));
	endforeach;
	
	app.setIsWebApp(true);
	app.myPassport.setContext(Context_Pass_MOB_Scan);
	
	// Job Start
	time := time.addMinutes(5);
	jobStartTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Start, jobStartTS, null, app.myPassport);	
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTART);
	self.assertNotNullMsg(woTransaction, "WO Job Start transaction should not be null");
	
	//Since no child cargo is unpacked ,job start should not be recorded on TI
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBSTART);
	self.assertNullMsg(tiTransaction, "TI Job Start transaction should be null");
	
	// Move then unpack the container
	self.move(container, container.myPrimaryQueuedLocation);
	
	create unpackTIs transient;
	unpackTIs.add(container.allChildren.first);
	
	self.unpackContainer(container, unpackTIs);
	
	app.myPassport.setContext(Context_Pass_MOB_Scan);
	
	//every time a cargo is unpack , a job action complete call is triggered
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Complete, jobCompleteTS, container, app.myPassport);
	
	//Since first child cargo is unpacked ,job start should be recorded on TI
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBSTART);
	self.assertNotNullMsg(tiTransaction, "TI Job Start transaction should not be null");
	
	//Job Complete transaction should not be recorded as the job status still not complete
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNullMsg(woTransaction, "WO Job Complete transaction should be null");
	
	//Job Complete transaction should not be recorded  as TI has still child cargo to be unpacked 
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBCOMPLETE);
	self.assertNullMsg(tiTransaction, "TI Job Complete transaction should  be null");
	
	app.myPassport.setContext(Context_Pass_MOB_Scan);
	
	// Job Stop
	time := time.addMinutes(5);
	jobStopTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Stop, jobStopTS, null, app.myPassport);	
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTOP);
	self.assertNotNullMsg(woTransaction, "WO Job Stop transaction should not be null");
	
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBSTOP);
	self.assertNullMsg(tiTransaction, "TI Job Stop transaction should be null");
	
	app.myPassport.setContext(Context_Pass_MOB_Scan);
	
	// Job Resume
	time := time.addMinutes(5);
	jobResumeTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Resume, jobResumeTS, null, app.myPassport);	
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBRESUME);
	self.assertNotNullMsg(woTransaction, "WO Job Resume transaction should not be null");
	
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBRESUME);
	self.assertNullMsg(tiTransaction, "TI Job Resume transaction should be null");
	
	//unpack second child cargo cargo
	unpackTIs.clear();
	unpackTIs.add(container.allChildren.first);
	
	self.unpackContainer(container, unpackTIs);
	self.unpackCompleteContainer(container);
	
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,1,TRANS_TYPE_WO_TIUNPACK_COMPLET,true,false);
	
	app.myPassport.setContext(Context_Pass_MOB_Scan);
	
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(job, Job_Action_Complete, jobCompleteTS, container, app.myPassport);
	
	//Job Complete transaction should be recorded as job is complete
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNotNullMsg(woTransaction, "WO Job Complete transaction should not be null");
	
	//Job Complete transaction should be recorded as all child cargoes are unpacked 
	tiTransaction := container.getLastTransOfType(TRANS_TYPE_TIJOBCOMPLETE);
	self.assertNotNullMsg(tiTransaction, "TI Job Complete transaction should not be null");	
	
	
	expectedString := jobStartTS.asStringJMT() &amp; " to " &amp; jobStopTS.asStringJMT() &amp; CrLf &amp; jobResumeTS.asStringJMT() &amp; " to " &amp; jobCompleteTS.asStringJMT();
	actualString := job.getJobActivity();
	
	self.assertEqualMsg(actualString, expectedString, "Job activity string is not correct!");	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	delete packingCargo1;
	delete packingCargo2;
	delete attachments;
	delete unpackTIs;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	app.setIsWebApp(false);
	app.myPassport.setContext(Context_Pass_Null);
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobActionTxnCheckVoyage" id="88cbdaec-bd59-4018-a1af-b2e2074862cb">
        <source>tJobActionTxnCheckVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62898: Jade - Unit Test
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
16 Oct 2024 navbs1 Bug MTN-23124: EUP - FR | 54883 - Start and End Times for Operations in Mobile App - part 3


*/
constants
	REF		: String  = '58400';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = "UTHMVOY"&amp;REF;
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	wod,
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	groMethod				: 	CM_WorkOrderJobGroupMethod;
	firstJob				: 	CM_Job;
	mobileAgent 			: 	CMIF_MobileGenericAgent;
	blockStack				:	CM_BlockStack;
	hideMoveConfirmation	: 	Any;
	woTransaction			: CM_WOTransaction;
	woJobTransaction		: CM_WOJobDetail;
	jobStartTS,
	jobCompleteTS,
	jobStopTS,
	jobResumeTS				: TimeStamp;
	time					: Time;
	actualString,
	expectedString			: String;
begin

	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := term.getConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(HhMoveConfirmation,true);
	commitTransaction;
	
	self.deleteTerminalArea("BS1711");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS1711", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	// tracked items
	tI1 := self.xAddCargo("UTCON1" &amp; REF, voyage, TI_STATE_ONSHIP, null);
	self.assertNotNull(tI1);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI1.changeState(TI_STATE_ONSHIP,app.myPassport);
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	groMethod := term.allWOJobGroupMethods["UTHM60063",term];
	
	self.xApproveWorkOrder(workOrder);
	
	self.opts.purge();
	self.opts.addAssoc('GrpMethod', groMethod);
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_61617");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	wod 			:= workOrder.allWoDtls.first();
	firstJob 		:= wod.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	
	// Job Start
	time := time.addMinutes(5);
	jobStartTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(voyJob, Job_Action_Start, jobStartTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// Job Stop
	time := time.addMinutes(5);
	jobStopTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(voyJob, Job_Action_Stop, jobStopTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	// Job Resume
	time := time.addMinutes(5);
	jobResumeTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(voyJob, Job_Action_Resume, jobResumeTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(term);
	mobileAgent.setMyVoyage(voyage); 
	mobileAgent.setDoNotShowMsgBox(true);
	
	mobileAgent.setMyJob(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.first);
	mobileAgent.doLanderDischargeWOJob(tI1,blockStack.myLocationsController,tI1.totalQuantity,tI1.totalWeight);
	
	// Job Complete
	time := time.addMinutes(5);
	jobCompleteTS.setTime(time);
	app.myTrxUA.trxUpdateJobAction(voyJob, Job_Action_Complete, jobCompleteTS, null, app.myPassport);		//23.09.2024  navbs1  #12445
	
	self.assertEqual(firstJob.status,JOB_COMPLETE);
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
	
	// Check transaction in WO
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTART);
	self.assertNotNullMsg(woTransaction, "WO Job Start transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, voyJob.getJobTypeDescription(), "WO Job Start Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, voyJob.getJobClassNiceString(), "WO Job Start Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, voyJob.getJobId(), "WO Job Start Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobStart, jobStartTS, "WO Job Start Start incorrect");
	if voyJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, voyJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBSTOP);
	self.assertNotNullMsg(woTransaction, "WO Job Stop transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, voyJob.getJobTypeDescription(), "WO Job Stop Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, voyJob.getJobClassNiceString(), "WO Job Stop Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, voyJob.getJobId(), "WO Job Stop Id incorrect");				//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobEnd, jobStopTS, "WO Job Stop Start incorrect");
	if voyJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, voyJob.myJobSheet.externalName, "WO Job Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBRESUME);
	self.assertNotNullMsg(woTransaction, "WO Job Resume transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, voyJob.getJobTypeDescription(), "WO Job Resume Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, voyJob.getJobClassNiceString(), "WO Job Resume Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, voyJob.getJobId(), "WO Job Resume Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobStart, jobResumeTS, "WO Job Resume Start incorrect");
	if voyJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, voyJob.myJobSheet.externalName, "WO Job Resume Sheet Code incorrect");
	endif;
	
	woTransaction := wod.getLastTransOfType(TRANS_TYPE_WOJOBCOMPLETE);
	self.assertNotNullMsg(woTransaction, "WO Job Complete transaction should not be null");
	woJobTransaction := woTransaction.CM_WOJobDetail;
	self.assertEqualMsg(woJobTransaction.jobDesc, voyJob.getJobTypeDescription(), "WO Job Complete Description incorrect");
	self.assertEqualMsg(woJobTransaction.jobType, voyJob.getJobClassNiceString(), "WO Job Complete Type incorrect");
	self.assertEqualMsg(woJobTransaction.jobId, voyJob.getJobId(), "WO Job Complete Id incorrect");			//16.10.2024  navbs1  #23124
	self.assertEqualMsg(woJobTransaction.jobEnd, jobCompleteTS, "WO Job Complete Start incorrect");
	if voyJob.myJobSheet &lt;&gt; null then
		self.assertEqualMsg(woJobTransaction.jobSheetCode, voyJob.myJobSheet.externalName, "WO Job Complete Sheet Code incorrect");
	endif;
	
	expectedString := jobStartTS.asStringJMT() &amp; " to " &amp; jobStopTS.asStringJMT() &amp; CrLf &amp; jobResumeTS.asStringJMT() &amp; " to " &amp; jobCompleteTS.asStringJMT();
	actualString := voyJob.getJobActivity();
	//20/03/2024	navkc1 CR 62694 Task 62901
	self.assertEqualMsg(actualString, expectedString, "Job activity string is not correct!");	
	
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(HhMoveConfirmation,hideMoveConfirmation);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete myPxyWorkPointJobSheet;
	delete pxyVoyJob;
	delete mobileAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tJobSplitPackWO" id="51d5271b-3fb7-47c8-8fe3-da83dd0a9d7a">
        <source>tJobSplitPackWO();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2024	navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues

*/

constants
	REF	 		: String  	=  "65424";
	WOID		: String  	= 'UT'&amp;REF&amp;'JPT';
	BLOCKSTACK 	: String	= "BS" &amp;REF;
	Voyage		: String 	= "UTVOY" &amp; REF;
	WPJS 		: String 	= 'UT'&amp;REF&amp;'JS';
	TruckId 	: String 	= 'UTTRK1'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	packingCargo1,
	packingCargo2,
	packingCargo3,
	packingCargo4			: CM_TrackedItem;
	attachments				: CMIF_InOutAttachmentArray;
	packTIs					: CM_TIArray;
	wh						: CM_IrregularBlockArea;
	cargoType				: CM_CargoType;
	jobP,
	jobC,
	job						: CM_Job;
	jobId					: String;
	wleSet					: CM_WLESet;
	wle						: CM_WorkListEntry;
	realJobSheet,
	myPxyWorkPointJobSheet	: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest('UTRel' &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage	
	vessel := self.addVesselWithHolds("UTVES" &amp; REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteContainer("UT01" &amp; REF);
	self.deleteContainer("UT02" &amp; REF);
	self.deleteContainer(REF &amp; "PACK1");
	self.deleteContainer(REF &amp; "PACK2");
	self.deleteContainer(REF &amp; "PACK3");
	self.deleteContainer(REF &amp; "PACK4");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	tI1 := self.addContainerOpts("UT01" &amp; REF, "2200", "MT", operator);	
	tI2 := self.addContainerOpts("UT02" &amp; REF, "2200", "MT", operator);
	
	self.move(tI1, blockStack);	
	self.move(tI2, blockStack);
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("GVS"));
	
	wh := terminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK1", cargoType, 1, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	packingCargo2 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK2", cargoType, 1, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	packingCargo3 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK3", cargoType, 1, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	packingCargo4 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK4", cargoType, 1, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc('Number', 2);
	self.opts.addAssoc('NumberSec', 4);
	self.opts.addAssoc('ISOType', "2200");
	self.opts.addAssoc('CargoType', cargoType);
	self.opts.addAssoc('PackType', CM_ReserveDetail.PackType_Parent);
	self.opts.addAssoc('PackType1', CM_ReserveDetail.PackType_Child);
	releaseRequest:=self.addReleaseByTypeRequestOpts('UTRel' &amp; REF, BR_TYPE_PACKING, 1);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	create pxyWod as CM_WodPack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		self.opts.purge();
		self.opts.addAssoc('WPJobSheet','JS'&amp;REF);
		realJobSheet := self.xCreateJobSheet();
	endif;
	
	//Allocate job to jobSheet
	create allJobArr transient;
	allJobArr.addNoDuplicates(workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first,false);
	if realJobSheet &lt;&gt; null then
		myPxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	endif;
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdatePackCargo(tI1, packingCargo1, 1, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease,releaseRequest);
	self.packCompleteContainer(tI1.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_PART_COMPLETE, "The job has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_PART_COMPLETE, "The job has not been part completed");
	
	jobC := wod.CM_WorkOrderTIDtl.allJobs.last;
	jobP := wod.CM_WorkOrderTIDtl.allJobs.first;
	jobId := "Split" &amp; REF;
	
	create wleSet transient;
	foreach wle in jobP.workListEntries do
		if wle.status &lt;&gt; WLE_COMPLETED then
			wleSet.add(wle);
		endif;
	endforeach;
	
	foreach wle in jobC.workListEntries do
		if wle.status &lt;&gt; WLE_COMPLETED then
			wleSet.add(wle);
		endif;
	endforeach;
	
	app.myTrxUA.trxUpdateJobSplitWithWle(jobC,jobId,realJobSheet,wleSet,terminal,null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(jobC.getRemainingQuantity(), 0.asStringJMT, "Remaining quantity should be 0");
	self.assertEqualMsg(jobC.status, JOB_COMPLETE, "Job should be completed");
	self.assertEqualMsg(jobP.getRemainingQuantity(), 0.asStringJMT, "Remaining quantity should be 0");
	self.assertEqualMsg(jobP.status, JOB_COMPLETE, "Job should be completed");
	jobC := wod.CM_WorkOrderTIDtl.allJobs.last;
	self.assertEqualMsg(jobC.getRemainingQuantity(), 3.asStringJMT, "Remaining quantity should be 3");
	self.assertEqualMsg(jobC.status, JOB_UNACTIONED, "job should be unactioned");
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		if job.id = jobC.id then
			jobP := job;
			break;
		endif;
	endforeach;
	self.assertEqualMsg(jobP.getRemainingQuantity(), 1.asStringJMT, "Remaining quantity should be 1");
	self.assertEqualMsg(jobP.status, JOB_UNACTIONED, "job should be unactioned");
	
	app.myTrxUA.trxUpdatePackCargo(tI2, packingCargo2, 1, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	app.myTrxUA.trxUpdatePackCargo(tI2, packingCargo3, 1, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	app.myTrxUA.trxUpdatePackCargo(tI2, packingCargo4, 1, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease,releaseRequest);
	self.packCompleteContainer(tI2.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	self.assertEqualMsg(jobP.status,JOB_COMPLETE, "The job has not been completed");
	self.assertEqualMsg(jobC.status,JOB_COMPLETE, "The job has not been completed");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete packTIs;
	delete attachments;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete wleSet;
	delete myPxyWorkPointJobSheet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackCargoWithMultiWle" id="89114f53-2228-43c1-99e3-721fdf4a718a">
        <source>tPackCargoWithMultiWle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2024 navhl20	ChangeRequest 65650: FR | 54177 - Retrospective Operations - Packing

*/

constants
	REF	 		: String	= "65650";
	WOID 		: String 	= 'UT'&amp;REF&amp;'JPT';
	BLOCKSTACK 	: String	= "BS" &amp;REF;
	Voyage		: String 	= "UTVOY" &amp; REF;
	WPJS 		: String 	= 'UT'&amp;REF&amp;'JS';
	TruckId 	: String 	= 'UTTRK1'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	packingCargo1,
	packingCargo2			: CM_TrackedItem;
	attachments				: CMIF_InOutAttachmentArray;
	packTIs					: CM_TIArray;
	wh						: CM_IrregularBlockArea;
	cargoType				: CM_CargoType;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteWorkOrderNoValidation(WOID &amp;'-1');
	self.deleteReleaseRequest("UTREL"&amp;REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage	
	vessel := self.addVesselWithHolds("UTVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteContainer("UTHL01" &amp; REF);
	self.deleteContainer("UTHL02" &amp; REF);
	self.deleteContainer(REF &amp; "PACK1");
	self.deleteContainer(REF &amp; "PACK2");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	tI1 := self.addContainerOpts("UTHM01" &amp; REF, "2200", "MT", operator);	
	tI2 := self.addContainerOpts("UTHM02" &amp; REF, "2200", "MT", operator);
	
	self.move(tI1, blockStack);	
	self.move(tI2, blockStack);
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("GVS"));
	
	wh := terminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK1", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	packingCargo2 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK2", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	create tiSet transient;
	tiSet.add(packingCargo1);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	create pxyWod as CM_WodReceive transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID &amp;'-1',WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc('Number', 2);
	self.opts.addAssoc('NumberSec', 200);
	self.opts.addAssoc('ISOType', "2200");
	self.opts.addAssoc('CargoType', cargoType);
	self.opts.addAssoc('PackType', CM_ReserveDetail.PackType_Parent);
	self.opts.addAssoc('PackType1', CM_ReserveDetail.PackType_Child);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTREL"&amp;REF, BR_TYPE_PACKING, 1);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('Voyage', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	
	delete pxyWod;
	create pxyWod as CM_WodPack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_PACK,null,null,null);
	
	delete wodArr;
	create wodArr transient;
	wodArr.add(pxyWod);
	
	delete pxyWorkOrder;
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order	
	self.xApproveWorkOrder(workOrder);
	
	// Action  work order
	self.xActionWorkOrder(workOrder);
	
	app.myTrxUA.trxUpdatePackCargo(tI1, packingCargo1, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	/*self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease,releaseRequest);
	self.packCompleteContainer(tI1.CM_Container);
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.first.status,WLE_PART_COMPLETE, "The job has not been part completed");
	self.assertEqualMsg(wod.CM_WodPack.allJobs.last.status,WLE_PART_COMPLETE, "The job has not been part completed");*/
	self.assertEqualMsg(packingCargo1.myParent, tI1, "The cargo has not been packed");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete packTIs;
	delete attachments;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPopulateBOLFromBooking" id="fd293132-1fcf-4f2a-ace7-0245c1cad847">
        <source>tPopulateBOLFromBooking();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 November 2022	navhl20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
30 January  2023    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars
	voyage 				: CM_Voyage;
	booking				: CM_BookingRef;
	cannon				: CM_CargoType;
	bol 				: CM_BOLIn;
	realBOL 			: CM_BOL; 
	strictBOLorDocket	: Any;
begin
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	self.deleteBooking("UT_DocCon");
	self.deleteBOL("UT_DocCon",null);
	self.deleteVoyage("UT_Doc");
	
	self.opts.purge();
	self.opts.addAssoc("UseVesselAllocations", true);
	voyage := self.addVoyageWithConRORO("UT_Doc", "MESDIAM", "UTOP", self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 4, false, false);
	self.assertNotNull(voyage);
	
	cannon := self.getCargoType("CANNON");
	self.assertNotNull(cannon);
	
	booking := self.addBookingForGeneralCargo("UT_DocCon", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", cannon.id, 5);
	self.assertNotNull(booking);
	
	create bol transient;
	bol.populatePxyFromBooking(booking);
	app.myTrxCA.trxCreateBOL(bol,realBOL,null, app.myPassport); 			//30.01.2023 navdp20 TFS #56969[56288]
	self.assertNoTrxErrorsOrWarnings(); 									//30.01.2023 navdp20 TFS #56969[56288]
	//Checking Bol
	self.assertEqualMsg(booking.dischargePort,realBOL.dischargePort,"Discharge is not Equal");
	self.assertEqualMsg(booking.consignorReference,realBOL.clientRef1,"Consignor Reference is not Equal");
	self.assertEqualMsg(booking.customerReference,realBOL.clientRef2,"Customer Reference is not Equal");
	self.assertEqualMsg(booking.destinationPort,realBOL.destinationPort,"Destination Port is not Equal");
	self.assertEqualMsg(booking.directDelivery,realBOL.directDelivery,"Direct Delivery is not Equal");
	self.assertEqualMsg(booking.myOperator,realBOL.myOperator,"Operator is not Equal");
	self.assertEqualMsg(booking.bookingReference,realBOL.number,"Booking Rference is not Equal");
	self.assertEqualMsg(booking.remarks,realBOL.remarks,"Remarks are not Equal");
	//Checking BolDtls collection
	self.assertNotNullMsg(bol.allBOLDtls,"BOLDtls are Null");
	//Checking BolDtls 
	self.assertEqualMsg(booking.allBookingRefItems.first.cargoType,realBOL.allBOLDtls.first.cargoType,"Cargo Type is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.colour,realBOL.allBOLDtls.first.colour,"Colour is not Same");
	self.assertEqualMsg(booking.allBookingRefItems.first.commodity,realBOL.allBOLDtls.first.commodity,"Commodity is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.consigneeCode,realBOL.allBOLDtls.first.consigneeCode,"Consignee Code is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.consignorCode,realBOL.allBOLDtls.first.consignorCode,"Consignor Code is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.description,realBOL.allBOLDtls.first.description,"Description is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.height,realBOL.allBOLDtls.first.height,"Height is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.length,realBOL.allBOLDtls.first.length,"Length is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.markNumber,realBOL.allBOLDtls.first.markNumber,"Mark Number is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.quantity,realBOL.allBOLDtls.first.quantity,"Quantity is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.remarks,realBOL.allBOLDtls.first.remarks,"Remarks are not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.volume.Integer,realBOL.allBOLDtls.first.volume.Integer,"Volume is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.weight,realBOL.allBOLDtls.first.weight,"Weight is not Equal");
	self.assertEqualMsg(booking.allBookingRefItems.first.width,realBOL.allBOLDtls.first.width,"Width is not Equal");
    self.deleteBOL(realBOL.number,realBOL);  								//02.02.2023 navdp20 TFS #56969[56288]
epilog
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	delete bol;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPopulateBOLFromTrackedItem" id="143fe9da-1a03-427c-a555-d6a36975f776">
        <source>tPopulateBOLFromTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 February 2023    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars
	voyage 	: CM_Voyage;
	ti1		: CM_TrackedItem;
	tiSet	: CM_TISet;
	cannon	: CM_CargoType;
	bol 	: CM_BOLIn; 
	realBOL : CM_BOL; 												
begin
	self.deleteContainer("TEST");
	self.opts.purge();
	create tiSet transient;
	ti1 := self.addContainerOpts("TEST", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	//Start 02.02.2023 navdp20 TFS #56969[56288]
	beginTransaction;
	ti1.setBookingReference("UTREF");
	commitTransaction;
	//End 02.02.2023 navdp20 TFS #56969[56288]
	self.assertNotNull(ti1);
	tiSet.add(ti1);
	
	create bol transient;
	bol.populatePxyFromTrackedItem(tiSet);
	app.myTrxCA.trxCreateBOL(bol, realBOL, null, app.myPassport);	//30.01.2023 navdp20 TFS #56969[56288]
	self.assertNoTrxErrorsOrWarnings();								//30.01.2023 navdp20 TFS #56969[56288]
	//Checking Bol
	self.assertEqualMsg(ti1.consignee,realBOL.consignee,"Consignee is not Equal");
	self.assertEqualMsg(ti1.clientRef,realBOL.clientRef1,"Client Reference1 is not Equal");
	self.assertEqualMsg(ti1.clientRef,realBOL.clientRef2,"Client Reference2 is not Equal");
	self.assertEqualMsg(ti1.consignor,realBOL.consignor,"Consignor is not Equal");
	self.assertEqualMsg(ti1.destinationPort,realBOL.destinationPort,"Destination Port is  not Equal");
	self.assertEqualMsg(ti1.dischargePort,realBOL.dischargePort,"Discharge Port is not Equal");
	self.assertEqualMsg(ti1.directDelivery,realBOL.directDelivery,"Direct Delivery is not Equal");
	self.assertEqualMsg(ti1.generalLandingDate,realBOL.generalLandingDate,"General Landing Date is not Equal");
	self.assertEqualMsg(ti1.loadPort,realBOL.loadPortCode,"Load Port is not Equal");
	self.assertEqualMsg(ti1.myOperator,realBOL.myOperator,"Operator is not Equal");
	self.assertEqualMsg(ti1.myProduct,realBOL.myProduct,"Product is not Equal");
	self.assertEqualMsg(ti1.mySubTerminal,realBOL.mySubTerminal,"SubTerminal is not Equal");
	self.assertEqualMsg(ti1.productCode,realBOL.productCode,"Product Code is not Equal");
	self.assertEqualMsg(ti1.remarks,realBOL.remarks,"Reamarks are not Equal");
	self.assertEqualMsg(ti1.vehicle,realBOL.vehicle,"Vehicle is not Same");
	self.assertEqualMsg(ti1.weightTare,realBOL.weightTare,"WeightTare is not Equal");
	
	//Checking BolDtls collection
	self.assertNotNullMsg(realBOL.allBOLDtls,"BOLDtls are NULL");
	
	//checking BolDtls
	self.assertEqualMsg(ti1.cargoType,realBOL.allBOLDtls.first.cargoType,"CargoType is not Equal");
	self.assertEqualMsg(ti1.commodity,realBOL.allBOLDtls.first.commodity,"Commodity is not Equal");
	self.assertEqualMsg(ti1.consignor,realBOL.allBOLDtls.first.consignorCode,"ConsignorCode is not Equal");
	self.assertEqualMsg(ti1.description,realBOL.allBOLDtls.first.description,"Description is not Equal");
	self.assertEqualMsg(ti1.height,realBOL.allBOLDtls.first.height,"Height is not Equal");
	self.assertEqualMsg(ti1.length,realBOL.allBOLDtls.first.length,"Length is not Equal");
	self.assertEqualMsg(ti1.markNumber,realBOL.allBOLDtls.first.markNumber,"Mark Number is not Equal");
	self.assertEqualMsg(ti1.quantity,realBOL.allBOLDtls.first.quantity,"Quantity is not Equal");
	self.assertEqualMsg(ti1.remarks,realBOL.allBOLDtls.first.remarks,"Remarks are not Equal");
	self.assertEqualMsg(ti1.volume,realBOL.allBOLDtls.first.volume,"Volume is not Equal");
	self.assertEqualMsg(ti1.weight,realBOL.allBOLDtls.first.weight,"Weight is not Equal");
	self.deleteBOL(realBOL.number,realBOL);						//02.02.2023 navdp20 TFS #56969[56288]
	
epilog
	delete bol;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPopulateBookingFromBoL" id="60d3e949-9b1b-4d76-a0b8-30ab46802167">
        <source>tPopulateBookingFromBoL();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
31 January  2023    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars
	voyage 		: CM_Voyage;
	booking,
	realBooking	: CM_BookingRef;
	cannon		: CM_CargoType;
	bol 		: CM_BOL; 
	release 	: CM_BulkRelease; 
	voyage1		: CM_Voyage; 
	strictBOLorDocket	: Any;
begin
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	self.deleteBooking("UT_DocCon");
	self.deleteVoyage("UT_Doc");
	self.deleteVoyage("UTVBOOK1");
	
	self.opts.purge();
	self.opts.addAssoc("UseVesselAllocations", true);
	voyage := self.addVoyageWithConRORO("UT_Doc", "UTBOAT", "UTOP", self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 4, false, false);
	self.assertNotNull(voyage);
	
	cannon := self.getCargoType("CANNON");
	self.assertNotNull(cannon);
	
	voyage1 := addVoyageWithContainerStructur("UTVBOOK1", "UTBOAT2", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	bol := self.addBOL("UT_DocCon", voyage1,self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString), null, self.getTerminal );
	
	create booking transient;
	booking.populatePxyFromBoL(bol);
	app.myTrxCA.trxCreateBookingBulkRel(booking, realBooking, release, app.myPassport);	//31.01.2023 navdp20 TFS #56969[56288]
	self.assertNoTrxErrorsOrWarnings(); 												//31.01.2023 navdp20 TFS #56969[56288]
	//Checking BookingRef
	self.assertEqualMsg(realBooking.dischargePort,bol.dischargePort,"Dischargeport is not Equal");
	self.assertEqualMsg(realBooking.consignorReference,bol.clientRef1,"Consignor Reference is not Equal");
	self.assertEqualMsg(realBooking.customerReference,bol.clientRef2,"Customer Reference is not Equal");
	self.assertEqualMsg(realBooking.destinationPort,bol.destinationPort,"DestinationPort is not Equal");
	self.assertEqualMsg(realBooking.directDelivery,bol.directDelivery,"DirectDelivery is not Equal");
	self.assertEqualMsg(realBooking.myConsignee,bol.myConsignee,"Consignee is not Equal");
	self.assertEqualMsg(realBooking.myConsignor,bol.myConsignor,"Consignor is not Equal");
	self.assertEqualMsg(realBooking.myOperator,bol.myOperator,"Operator is not Equal");
	self.assertEqualMsg(realBooking.bookingReference,bol.number,"BookingReference is not Equal");
	self.assertEqualMsg(realBooking.myProduct,bol.myProduct,"Product is not Equal");
	self.assertEqualMsg(realBooking.remarks,bol.remarks,"Remarks are not Equal");
	//Checking BookingRefItem collection
	self.assertNotNullMsg(realBooking.allBookingRefItems,"BookingRefItems are Null");
	//Checking BookingRefItem
	self.assertEqualMsg(realBooking.allBookingRefItems.first.cargoType,bol.allBOLDtls.first.cargoType,"CargoType is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.colour,bol.allBOLDtls.first.colour,"Colour is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.commodity,bol.allBOLDtls.first.commodity,"Commodity is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.description,bol.allBOLDtls.first.description,"Description is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.height,bol.allBOLDtls.first.height,"Height is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.length,bol.allBOLDtls.first.length,"Length is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.markNumber,bol.allBOLDtls.first.markNumber,"MarkNumber is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.quantity,bol.allBOLDtls.first.quantity,"Quantity is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.remarks,bol.allBOLDtls.first.remarks,"Remarks is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.volume.Integer,bol.allBOLDtls.first.volume.Integer,"Volume is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.weight,bol.allBOLDtls.first.weight,"Weight is not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.width,bol.allBOLDtls.first.width,"Width is not Equal");
	
	self.deleteBooking(realBooking.bookingReference); 									//02.02.2023 navdp20 TFS #56969[56288]
epilog
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	delete booking;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPopulateBookingFromRelRe" id="48f727b7-475a-4f8c-a558-179e95bdb9d7">
        <source>tPopulateBookingFromRelRe();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 February 2023    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/
constants
	RELEASE = "UTRRBYTYPE"; 
vars
	voyage 		: CM_Voyage;
	booking,
	realBooking	: CM_BookingRef;
	cannon		: CM_CargoType;
	bulkRel,
	release		: CM_BulkRelease;
	
begin
	self.deleteReleaseRequest(RELEASE);
	self.deleteBooking(RELEASE); 																		//02.02.2023 navdp20 TFS #56969[56288]
	self.opts.purge;	
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	bulkRel := addReleaseByTypeRequestOpts(RELEASE, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertNotNull(bulkRel);
	
	create booking transient;
	booking.populatePxyFromBulkRelease(bulkRel, null);													// ### TFS 59411 (61855) 30Jan2024 NAVPW1
	app.myTrxCA.trxCreateBookingBulkRel(booking,realBooking,release,app.myPassport);					//31.01.2023 navdp20 TFS #56969[56288]
	self.assertNoTrxErrorsOrWarnings(); 																//31.01.2023 navdp20 TFS #56969[56288]
	//Checking BookingRef
	self.assertEqualMsg(realBooking.consigneeCode,bulkRel.consigneeCode,"Consignee Code is not Equal");
	self.assertEqualMsg(realBooking.consignorCode,bulkRel.consignorCode,"Consignor Code is not Equal");
	self.assertEqualMsg(realBooking.consigneeDesc,bulkRel.consigneeDesc,"Consignee Description is not Same");
	self.assertEqualMsg(realBooking.consignorDesc,bulkRel.consignorDesc,"Consignor Description is  not Same");
	self.assertEqualMsg(realBooking.customsAgent,bulkRel.customsAgent,"Customs Agent is not Equal");
	self.assertEqualMsg(realBooking.myOperator,bulkRel.myOperator,"Operator is not Equal");
	self.assertEqualMsg(realBooking.myFreightForwarder,bulkRel.myFreightForwarder,"Freight Forwarder is not Equal");
	self.assertEqualMsg(realBooking.myTerminal,bulkRel.myTerminal,"Terminal is not Equal");
	self.assertEqualMsg(realBooking.myVoyage,bulkRel.myVoyage,"Voyage is not Equal");
	self.assertEqualMsg(realBooking.remarks,bulkRel.remarksAdditional1,"Remarks Additional1 is not Equal");
	self.assertEqualMsg(realBooking.remarks,bulkRel.remarksAdditional2,"Remarks Additional2 is not Equal");
	//Checking BookingRefItem collection
	self.assertNotNullMsg(realBooking.allBookingRefItems,"Booking Reference Items are Null");
	//Checking BookingRefItem
	self.assertEqualMsg(realBooking.allBookingRefItems.first.remarks,bulkRel.allReserveDetails.first.remarks,"Remarks are not Equal");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.sequence,bulkRel.allReserveDetails.first.sequence,"Sequence is not Same");
	self.assertEqualMsg(realBooking.allBookingRefItems.first.weight,bulkRel.allReserveDetails.first.weightRequested,"Weight Requested is not Same");
epilog
	delete booking;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPopulateRelReqFromBooking" id="a1e5c996-8e5e-42d1-b6be-4c96fab911fc">
        <source>tPopulateRelReqFromBooking();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 February 2022    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars
	voyage 		: CM_Voyage;
	booking		: CM_BookingRef;
	cont		: CM_CargoType;
	bulkRel,
	realBulkRel : CM_BulkRelease; 
	ti1 		:CM_TrackedItem; 
begin
	self.deleteBooking("UT_DocCon");
	self.deleteReleaseRequest("UT_DocCon");
	//Start 02.02.2023 navdp20 TFS #56969[56288]
	self.deleteVoyage("MESDI000002"); 
	
	voyage := 	self.addVoyageWithContainerStructur("MESDI000002","MESDIAM","HLL","APL");			
	self.assertNotNull(voyage); 
	
	cont := self.getCargoType("CONT"); 
	self.assertNotNull(cont);
	//End 02.02.2023 navdp20 TFS #56969[56288]
	self.opts.purge();
	//Start 02.02.2023 navdp20 TFS #56969[56288]
	self.opts.addAssoc("ISOType", "2200"); 
	self.opts.addAssoc("ISOGroupType", "GEN2"); 
	booking := self.addBookingForGeneralCargo("UT_DocCon", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", cont.id, 5);
	self.assertNotNull(booking);
	self.deleteContainer("UTHLTT00001");
	ti1	:=	self.addContainer("UTHLTT00001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container; 
	beginTransaction;
	ti1.setMyBooking(booking,booking.allBookingRefItems.first);
	commitTransaction;
	//End 02.02.2023 navdp20 TFS #56969[56288]
	
	create bulkRel transient;
	bulkRel.populatePxyFromBooking(booking);
	app.myTrxCA.trxCreateBulkRelease(bulkRel,realBulkRel,null, app.myPassport);					//02.02.2023 navdp20 TFS #56969[56288]
	self.assertNoTrxErrorsOrWarnings();									 						//02.02.2023 navdp20 TFS #56969[56288]
	
	//Checking BulkRelRes
	self.assertEqualMsg(booking.consigneeCode,realBulkRel.consigneeCode,"Consignee Code is not Equal");
	self.assertEqualMsg(booking.consignorCode,realBulkRel.consignorCode,"Consignor Code is not Equal");
	self.assertEqualMsg(booking.consigneeDesc,realBulkRel.consigneeDesc,"Consignee Description is not Same");
	self.assertEqualMsg(booking.consignorDesc,realBulkRel.consignorDesc,"Consignor Description is not Same");
	self.assertEqualMsg(booking.customsAgent,realBulkRel.customsAgent,"Customs Agent is not Equal");
	self.assertEqualMsg(booking.myOperator,realBulkRel.myOperator,"Operator is not Equal");
	self.assertEqualMsg(booking.myTerminal,realBulkRel.myTerminal,"Terminal is not Equal");
	self.assertEqualMsg(booking.myVoyage,realBulkRel.myVoyage,"Voyage is not Equal");
	self.assertEqualMsg(booking.remarks,realBulkRel.remarksAdditional1,"Remarks Additional1 are not Equal");
	self.assertEqualMsg(booking.remarks,realBulkRel.remarksAdditional2,"Remarks Additional2 are not Equal");

	//Checking ReserveDetails collection
	self.assertNotNullMsg(bulkRel.allReserveDetails,"Reserve Details are nulll"); 				//02.02.2023 navdp20 TFS #56969[56288]
epilog
	delete bulkRel;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecRoadWithToDoWS" id="35acbf18-3b00-4ef7-96d0-2edf5e32dfb2">
        <updating/>
        <source>tRecRoadWithToDoWS()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2024 navhl20 Bug 32981 EUP - Todo Tasks Job complete for Partial Receive and Release Work orders

*/

constants
	REF			: String = "329811";
	WOID 		: String = 'UT'&amp;REF&amp;'JREBTR';
	BLOCKSTACK 	: String = "BS" &amp;REF;
	Voyage		: String = "UTVoy" &amp; REF;
	TruckId 	: String = 'UTTRKHM'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	retroMode				: Any;
	tiSet					: CM_TISet;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	allJobArr				: CM_JobSet;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	hideMoveConfirmation 	: Boolean;
	job						: CM_RoadJob;
	defaultProcess			: String;
	vvr						: CM_VehicleVisitRecord;
	autoPlanEnabled			: Any;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	toDoTaskDescSet     	: CM_ToDoTaskDescBySortKey;
	todoSet					: CM_ToDoTaskDescSet;
	optionalParam			: String;
	todoJob					: CM_Job;
	wodTodo					: CM_WodToDo;
	jobOid,
	response				: String;
	matches					: JadeRegexResult;
	booking					: CM_BookingRef;
	controller				: CMIF_MobileTruckLoaderUnloader;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("BS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("BS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := terminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := terminal.getConfig(AllowAutoActionCargoWo);
	defaultProcess 		 := terminal.getConfig(DefaultVoyageProcess).String;
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	retroMode 			 := terminal.getConfig(IsRetrospectiveMode).String;
	
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, true);
	terminal.setConfig(AllowAutoActionCargoWo, true);
	terminal.setConfig(DefaultVoyageProcess,"EUP");
	terminal.setConfig(HhMoveConfirmation,true);
	terminal.setConfig(IsRetrospectiveMode,false);
	commitTransaction;
	
	autoPlanEnabled := self.setTerminalConfig(AutoPlanEnabled, false);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL" &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	self.deleteTrackedItem(self.getTrackedItem("UTHMCONT1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTHMCONT2"), false);
	self.deleteBooking("UT_BK" &amp; REF);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_BK" &amp; REF, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTHMCONT1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTHMCONT2");
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo" &amp; REF,TODO_TYPE_GROUP_TI);
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTHM" &amp; REF,
							 "UT HM Resource",
							 "MAN",
							 1,
							 false,
							 true,
							 toDoTaskDescSet
							 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	tiSet.clear;
	tiSet.add(tI1);
	
	self.deleteVehicle('UTHM-'&amp;REF);
	vvr := self.gateInMultiContainer('UTHM-'&amp;REF,"2200",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code,"MT",self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()),tiSet);
	//self.gateInPinReceival(workOrder.getPINNumber,'UTTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	job := terminal.myWOJobSheet.allJobsByRequiredDTPriority[workOrder.requiredByDT,3].CM_RoadJob;
	
	//Complete workOrder
	self.moveVehicleToYard(job.myVehicle);
	create controller transient;
	controller.setMyTerminal(terminal);
	controller.setTruck(job.myVehicle);
	controller.saveChangesUnload(tI1,blockStack.allLocationsControllers.first,tI1.totalQuantity,null,null);
	
	wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first;
	if wodTodo &lt;&gt; null then
		todoJob := wodTodo.allJobs.first;
	endif;
	if todoJob &lt;&gt; null then
		optionalParam := "?MTNInternalAPIService&amp;operationalJobOid=" &amp; job.getOidAsString;
		jobOid := todoJob.getOidAsString();
		self.webServiceCallWithParams( CM_UnitTestAgent::wsGetJobDetails.name, jobOid,optionalParam,response);
		self.assertNotNullMsg(response, "No response from POST /Find/Cargo");
		self.assertEqualMsg(JadeRegex@findAll(response, '"cargoId":', false, false, matches), 1, "cargoId found in response message when not expected" &amp; CrLf &amp; response);
	endif;
epilog
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	terminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	terminal.setConfig(DefaultVoyageProcess,defaultProcess);
	terminal.setConfig(IsRetrospectiveMode,retroMode);
	commitTransaction;
	self.setTerminalConfig(AutoPlanEnabled, autoPlanEnabled);
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete matches;
	delete toDoTaskDescSet;
	delete todoSet;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecRoadWithToDoWS2TRK" id="1a688502-7ecb-4cd7-99b2-062cb05a2a35">
        <updating/>
        <source>tRecRoadWithToDoWS2TRK()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2025 navhl20 Bug MTN-34107 EUP - ToDo Tasks getting completed for Partial Receive Work Orders

*/

constants
	REF			: String = "34107";
	WOID 		: String = 'UT'&amp;REF&amp;'JREBTR';
	BLOCKSTACK 	: String = "BS" &amp;REF;
	Voyage		: String = "UTVoy" &amp; REF;
	TruckId1 	: String = 'UTTRK1'&amp;REF;
	TruckId2 	: String = 'UTTRK2'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	retroMode				: Any;
	tiSet					: CM_TISet;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	allJobArr				: CM_JobSet;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	hideMoveConfirmation 	: Boolean;
	job						: CM_RoadJob;
	defaultProcess			: String;
	vvr						: CM_VehicleVisitRecord;
	autoPlanEnabled			: Any;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	toDoTaskDescSet     	: CM_ToDoTaskDescBySortKey;
	todoSet					: CM_ToDoTaskDescSet;
	optionalParam			: String;
	todoJob					: CM_Job;
	wodTodo					: CM_WodToDo;
	jobOid,
	response				: String;
	matches					: JadeRegexResult;
	booking					: CM_BookingRef;
	controller				: CMIF_MobileTruckLoaderUnloader;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("BS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("BS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := terminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := terminal.getConfig(AllowAutoActionCargoWo);
	defaultProcess 		 := terminal.getConfig(DefaultVoyageProcess).String;
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	retroMode 			 := terminal.getConfig(IsRetrospectiveMode).String;
	
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, true);
	terminal.setConfig(AllowAutoActionCargoWo, true);
	terminal.setConfig(DefaultVoyageProcess,"EUP");
	terminal.setConfig(HhMoveConfirmation,true);
	terminal.setConfig(IsRetrospectiveMode,false);
	commitTransaction;
	
	autoPlanEnabled := self.setTerminalConfig(AutoPlanEnabled, false);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL" &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	self.deleteTrackedItem(self.getTrackedItem("UTHMCONT1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTHMCONT2"), false);
	self.deleteBooking("UT_BK" &amp; REF);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_BK" &amp; REF, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTHMCONT1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTHMCONT2");
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo" &amp; REF,TODO_TYPE_GROUP_TI);
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTHM" &amp; REF,
							 "UT HM Resource",
							 "MAN",
							 1,
							 false,
							 true,
							 toDoTaskDescSet
							 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//First Truck
	tiSet.clear;
	tiSet.add(tI1);
	
	self.deleteVehicle(TruckId1);
	vvr := self.gateInMultiContainer(TruckId1,"2200",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code,"MT",self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()),tiSet);
	//self.gateInPinReceival(workOrder.getPINNumber,'UTTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	job := terminal.myWOJobSheet.allJobsByRequiredDTPriority[workOrder.requiredByDT,3].CM_RoadJob;
	
	//Complete workOrder
	self.moveVehicleToYard(job.myVehicle);
	create controller transient;
	controller.setMyTerminal(terminal);
	controller.setTruck(job.myVehicle);
	controller.saveChangesUnload(tI1,blockStack.allLocationsControllers.first,tI1.totalQuantity,null,null);
	
	wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first;
	if wodTodo &lt;&gt; null then
		todoJob := wodTodo.allJobs.first;
	endif;
	if todoJob &lt;&gt; null then
		optionalParam := "?MTNInternalAPIService&amp;operationalJobOid=" &amp; job.getOidAsString;
		jobOid := todoJob.getOidAsString();
		self.webServiceCallWithParams( CM_UnitTestAgent::wsGetJobDetails.name, jobOid,optionalParam,response);
		self.assertNotNullMsg(response, "No response from POST /Find/Cargo");
		self.assertEqualMsg(JadeRegex@findAll(response, '"cargoId":', false, false, matches), 1, "cargoId found in response message when not expected" &amp; CrLf &amp; response);
	endif;
	
	delete controller;
	
	//Second truck
	tiSet.clear;
	tiSet.add(tI2);
	
	self.deleteVehicle(TruckId2);
	vvr := self.gateInMultiContainer(TruckId2,"2200",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code,"MT",self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()),tiSet);
	//self.gateInPinReceival(workOrder.getPINNumber,'UTTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_PARTCOMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	job := terminal.myWOJobSheet.allJobsByRequiredDTPriority[workOrder.requiredByDT,3].CM_RoadJob;
	
	//Complete workOrder
	self.moveVehicleToYard(job.myVehicle);
	create controller transient;
	controller.setMyTerminal(terminal);
	controller.setTruck(job.myVehicle);
	controller.saveChangesUnload(tI2,blockStack.allLocationsControllers.first,tI2.totalQuantity,null,null);
	
	wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first;
	if wodTodo &lt;&gt; null then
		todoJob := wodTodo.allJobs.first;
	endif;
	if todoJob &lt;&gt; null then
		optionalParam := "?MTNInternalAPIService&amp;operationalJobOid=" &amp; job.getOidAsString;
		jobOid := todoJob.getOidAsString();
		self.webServiceCallWithParams( CM_UnitTestAgent::wsGetJobDetails.name, jobOid,optionalParam,response);
		self.assertNotNullMsg(response, "No response from POST /Find/Cargo");
		self.assertEqualMsg(JadeRegex@findAll(response, '"cargoId":', false, false, matches), 1, "cargoId found in response message when not expected" &amp; CrLf &amp; response);
	endif;
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
epilog
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	terminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	terminal.setConfig(DefaultVoyageProcess,defaultProcess);
	terminal.setConfig(IsRetrospectiveMode,retroMode);
	commitTransaction;
	self.setTerminalConfig(AutoPlanEnabled, autoPlanEnabled);
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete matches;
	delete toDoTaskDescSet;
	delete todoSet;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecShipUsingWS" id="a9f27112-33c4-4189-8f15-c59a8d21972b">
        <source>tRecShipUsingWS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
18 Apr 2024	navpw1	Fixed unit test now uses "Steel Coil" instead of "Cannon Balls" - Causes issues leading to 1018 exception with yard allocations

*/

constants
	REF		: String  = '61617';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = "UTHMVOY"&amp;REF;
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, tI2,tI3,tI4,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	groMethod				: 	CM_WorkOrderJobGroupMethod;
	firstJob,
	secondJob,
	voyJob1,
	voyJob2					: 	CM_Job;
	blockStack				:	CM_BlockStack;
	targetLoc				: 	CM_BlockController;
	cargoType				: 	CM_CargoType;
	location				: 	CM_LocationsController;
	mode					: 	Integer;
	defaultProcess			: 	String;
	hideMoveConfirmation	: 	Any;
	product					: CM_Product;
	
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := term.getConfig(AllowAutoActionCargoWo);
	defaultProcess 		 := term.getConfig(DefaultVoyageProcess).String;
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(DefaultVoyageProcess,"EUP");
	term.setConfig(HhMoveConfirmation,true);           //05.1.2024 navma1 
	commitTransaction;
	
	self.deleteTerminalArea("BS1711");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS1711", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := term.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBul01", cargoType);
	self.deleteCargo("UTBul02", cargoType);
	self.deleteCargo("UTBul03", cargoType);
	self.deleteCargo("UTBul04", cargoType);
	self.deleteCargo("UTBul05", cargoType);
	
	if voyage.myGeneralCargoVoyage &lt;&gt; null then
		location := voyage.myGeneralCargoVoyage.allLocationsByOrdinal.first;
	endif;
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul01", cargoType, 100, location, dischargePort.code, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBul02", cargoType, 100, location, dischargePort.code, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI3 := self.addCargoBreakBulkAtLocation("UTBul03", cargoType, 100, location, dischargePort.code, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI4 := self.addCargoBreakBulkAtLocation("UTBul04", cargoType, 100, location, dischargePort.code, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI1.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI3.setSpecialStow("STOW1");
		tI3.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI2.setSpecialStow("STOW2");
		tI2.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI4.setSpecialStow("STOW2");
		tI4.changeState(TI_STATE_ONSHIP,app.myPassport);
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	
	// Create the work order detail
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	groMethod := term.allWOJobGroupMethods["UTHM60063",term];
	
	self.xApproveWorkOrder(workOrder);
	
	self.opts.purge();
	self.opts.addAssoc('GrpMethod', groMethod);
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_58400");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addMonths(1),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	
	delete pxyVoyJob;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addMonths(1),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,secondJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(secondJob.CM_WOReceiveCargoJob.allVoyageJobs.size,1);
	
	//Complete tracked items discharge
	voyJob1 := firstJob.CM_WOReceiveCargoJob.allVoyageJobs.first;
	voyJob2	:= secondJob.CM_WOReceiveCargoJob.allVoyageJobs.first;
	targetLoc := blockStack.myLocationsController;
	mode := JOB_TYPE_DISCHARGE;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob1, tI1, targetLoc);
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob2, tI2, targetLoc);
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob1, tI3, targetLoc);
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob2, tI4, targetLoc);
	
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(DefaultVoyageProcess,defaultProcess);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete myPxyWorkPointJobSheet;
	delete pxyVoyJob;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransChangeRailToRoad" id="7595626d-8c12-4676-8e56-747a8718775e">
        <updating/>
        <source>tRecTransChangeRailToRoad() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive

*/

constants
	REF : String = 59997.String;
	WOID : String  = 'UT'&amp;REF&amp;'JRC1';
	MyTrain : String = 'TRUT5'&amp;REF;
	MyWagon : String = "UK-"&amp;REF&amp;"_1";
	RailAreaId : String	= "UT" &amp; REF;
	BlockStack : String = "UT1" &amp; REF;
	WagonClass : String = "US";
	YA : String = 'UT_YA';
vars
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any; 
	term			    : CM_Terminal;
	voyage				: CM_Voyage;
	booking				: CM_BookingRef;
	tI1, 
	tI2					: CM_TrackedItem;
	tiSet				: CM_TISet;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	job 				: CM_Job;
	train,
	pxyTrain 			: CM_Train;
	wagon1 				: CM_Wagon;
	railArea 			: CM_Rail;
	railLine			: CM_RailLine;
	bs1					: CM_BlockStack;
	wagonClass 			: CM_WagonClass;
	wagonMaster			: CM_WagonMaster;
	tiSetDup 			: CM_TIByIdDups;
	cmifRakeRegion		: CMIF_RakeRegion;
	trainSet			: CM_TrainSet;
	pxyMaster			: CM_WagonMaster;
	
	pxyWO				: 	CM_WorkOrderTI;
	objArr				: 	ObjectArray;
	newWO				: 	CM_WorkOrder;	
	
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet				: 	CM_ToDoTaskDescSet;
begin
	/*
	** Setup Section, create the work order with a receive cargo task with multiple tracked items
	*/
	
	term := self.getMyTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, true);
		term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(MyTrain,null);
	self.deleteRailArea(RailAreaId);
		
	voyage  := self.xAddVoyage("UTVSL"&amp;REF, 'UTVOY'&amp;REF);
	self.assertNotNullMsg(voyage,"Voyage has not been created");
	
	booking := self.xAddBooking('UTBK'&amp;REF,voyage);
	self.assertNotNullMsg(booking,"Booking has not been created");
	
	// create train
	train := self.addTrain(MyTrain, null);
	self.assertNotNullMsg(train, "train not created");
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[WagonClass];
	self.assertNotNullMsg(train, "Cannot find wagon class");
	
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	// create the block stack where the containers will be stored after discharged
	self.deleteTerminalArea(BlockStack);
	bs1 := self.addBlockStack(BlockStack, 10, null);
	
	self.disableAllYA (true);
	self.deleteYA (YA);
	self.addYACatchAll (YA, bs1);
	
	// create the wagon master
	create pxyMaster transient;
	pxyMaster.setProxy(MyWagon, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	self.assertNoTrxErrorsOrWarnings();
	
	// create prenoted cargo
	self.opts.addAssoc("TransMode", TI_TRANSMODE_RAIL_STR);
	tI1 := self.xAddCargo("UTCNT1" &amp; REF,voyage,TI_STATE_NOTIFIED,'UTBK'&amp;REF);
	tI2 := self.xAddCargo("UTCNT2" &amp; REF,voyage,TI_STATE_NOTIFIED,'UTBK'&amp;REF);
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);
	
	create tiSetDup transient;
	tiSetDup.add(tI1);					
	tiSetDup.add(tI2);
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	self.assertNotNullMsg(wagonMaster, "Couldn't find wagon master");
	
	// create the wagon and add the trackedItems to it
	wagon1 := self.addWagonToTrainOption2(train, wagonMaster, tiSetDup, false);
	self.assertNotNullMsg(wagon1, "Wagon not created");
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon1, 1, app.myPassport);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_RAIL);
	self.opts.addAssoc('booking','UTBK'&amp;REF);
	// these two settings are used to get the train and set it on the work order
	self.opts.addAssoc('transObj', MyTrain);
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,	todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;

	create objArr transient;
	objArr.add(tI2);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,voyage,TI_TRANSMODE_ROAD_STR,"test_Book_05",objArr,self.getMyTerminal(), app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();																						
	
	newWO := tI2.allWorkOrders.first;
	if newWO.allWoDtls.isNotEmpty then																						
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_CREATED,true,false);
	endif;
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	self.xCheckWorkOrder(newWO.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	self.xCheckWorkOrder(newWO.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.assertEqualMsg(workOrder.allWoDtls.last.status ,  WO_STATUS_ACTIONED, "The work order task status should be actioned");
epilog
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
		term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	
	if toDoTaskDescSet &lt;&gt; null then
		delete toDoTaskDescSet;
	endif;
	if todoSet &lt;&gt; null then
		delete todoSet;
	endif;	
	
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete tiSetDup;
	delete pxyTrain;
	delete cmifRakeRegion;
	delete trainSet;
	delete pxyMaster; 

	delete pxyWO;
	delete objArr;	
	self.disableAllYA (false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransChangeRailToShip" id="ca810be3-daca-48af-a3a5-bcd2179b2937">
        <updating/>
        <source>tRecTransChangeRailToShip() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive

*/

constants
	REF : String = 59997.String;	
	WOID : String  = 'UT'&amp;REF&amp;'JRC1';
	MyTrain : String = 'TRUT6'&amp;REF;
	MyWagon : String = "UK-"&amp;REF&amp;"_1";
	RailAreaId : String	= "UT" &amp; REF;
	BlockStack : String = "UT1" &amp; REF;
	WagonClass : String = "US";
	YA : String = 'UT_YA';
vars
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	term			    : CM_Terminal;
	voyage				: CM_Voyage;
	booking				: CM_BookingRef;
	tI1, 
	tI2					: CM_TrackedItem;
	tiSet				: CM_TISet;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	job 				: CM_Job;
	train,
	pxyTrain 			: CM_Train;
	wagon1 				: CM_Wagon;
	railArea 			: CM_Rail;
	railLine			: CM_RailLine;
	bs1					: CM_BlockStack;
	wagonClass 			: CM_WagonClass;
	wagonMaster			: CM_WagonMaster;
	tiSetDup 			: CM_TIByIdDups;
	cmifRakeRegion		: CMIF_RakeRegion;
	trainSet			: CM_TrainSet;
	pxyMaster			: CM_WagonMaster;
	
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	newWO				: CM_WorkOrder;	
	
	toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	noExportStops		: Boolean;
	strictBOLorDocket	: Any;
begin
	/*
	** Setup Section, create the work order with a receive cargo task with multiple tracked items
	*/
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	term := self.getMyTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting	:= self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo	:= self.getTerminalConfig(AllowAutoActionCargoWo);
	noExportStops		:= self.getTerminalConfig(NoExportStops).Boolean;
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	self.setTerminalConfig(NoExportStops, true);	//Euroports will manually clear the stops if one of these is encountered
	
	self.deleteWorkOrderNoValidation(WOID);
	
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(MyTrain,null);
	self.deleteRailArea(RailAreaId);
		
	voyage  := self.xAddVoyage("UTVSL"&amp;REF, 'UTVOY'&amp;REF);
	self.assertNotNullMsg(voyage,"Voyage has not been created");
	
	booking := self.xAddBooking('UTBK'&amp;REF,voyage);
	self.assertNotNullMsg(booking,"Booking has not been created");
	
	// create train
	train := self.addTrain(MyTrain, null);
	self.assertNotNullMsg(train, "train not created");
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[WagonClass];
	self.assertNotNullMsg(train, "Cannot find wagon class");
	
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	// create the block stack where the containers will be stored after discharged
	self.deleteTerminalArea(BlockStack);
	bs1 := self.addBlockStack(BlockStack, 10, null);
	
	self.disableAllYA (true);
	self.deleteYA (YA);
	self.addYACatchAll (YA, bs1);
	
	// create the wagon master
	create pxyMaster transient;
	pxyMaster.setProxy(MyWagon, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	self.assertNoTrxErrorsOrWarnings();
	
	// create prenoted cargo
	self.opts.addAssoc("TransMode", TI_TRANSMODE_RAIL_STR);
	tI1 := self.xAddCargo("UTCNT1" &amp; REF,voyage,TI_STATE_NOTIFIED,'UTBK'&amp;REF);
	tI2 := self.xAddCargo("UTCNT2" &amp; REF,voyage,TI_STATE_NOTIFIED,'UTBK'&amp;REF);
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);
	
	create tiSetDup transient;
	tiSetDup.add(tI1);					
	tiSetDup.add(tI2);
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	
	wagonMaster := self.getRoot.allWagonMasters[MyWagon];
	self.assertNotNullMsg(wagonMaster, "Couldn't find wagon master");
	
	// create the wagon and add the trackedItems to it
	wagon1 := self.addWagonToTrainOption2(train, wagonMaster, tiSetDup, false);
	self.assertNotNullMsg(wagon1, "Wagon not created");
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon1, 1, app.myPassport);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_RAIL);
	self.opts.addAssoc('booking','UTBK'&amp;REF);
	// these two settings are used to get the train and set it on the work order
	self.opts.addAssoc('transObj', MyTrain);
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,	todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREC_UPDATED,true,false);

	// Check each job has a WLE
	foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;

	create objArr transient;
	objArr.add(tI2);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;

	self.deleteBOL("test_Bol_06",null);	
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,voyage,TI_TRANSMODE_SHIP_STR,"test_Bol_06",objArr,self.getMyTerminal(), app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();	
	
	newWO := tI2.allWorkOrders.first;
	if newWO.allWoDtls.isNotEmpty then
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_CREATED,true,false);
	endif;
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	self.xCheckWorkOrder(newWO.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	self.xCheckWorkOrder(newWO.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.assertEqualMsg(workOrder.allWoDtls.last.status ,  WO_STATUS_ACTIONED, "The work order task status should be actioned");
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	self.setTerminalConfig(NoExportStops, noExportStops);
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	
	if toDoTaskDescSet &lt;&gt; null then
		delete toDoTaskDescSet;
	endif;
	if todoSet &lt;&gt; null then
		delete todoSet;
	endif;	
	
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete tiSetDup;
	delete pxyTrain;
	delete cmifRakeRegion;
	delete trainSet;
	delete pxyMaster; 

	delete pxyWO;
	delete objArr;	
	self.disableAllYA (false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransChangeRoadToRail" id="b3658e94-a68c-438b-84e4-ef0faa8c170f">
        <updating/>
        <source>tRecTransChangeRoadToRail() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive

*/

constants
	REF: String  =  "59997";
	WOID : String  = 'UT' &amp; REF &amp; 'JTC3';
	MyTrain : String = 'TRUT3' &amp; REF;
	
vars
	tI1, tI2,tI3,tI4	:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	tiSet				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet				: 	CM_ToDoTaskDescSet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	booking				: 	CM_BookingRef;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	pxyWO				: 	CM_WorkOrderTI;
	objArr				:	 ObjectArray;
	newWO				: 	CM_WorkOrder;
	train				: 	CM_Train;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT2"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT3"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT4"), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteVoyage("HLVOY" &amp; REF);
	self.deleteVessel("HLVES" &amp; REF);
	
	vessel := self.addVesselWithHolds("HLVES" &amp; REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY" &amp; REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first, "UTCONT1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first, "UTCONT2");
	tI3 := self.addPrenotedContainer(booking.allBookingRefItems.first, "UTCONT3");
	tI4 := self.addPrenotedContainer(booking.allBookingRefItems.first, "UTCONT4");		
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo", TODO_TYPE_GROUP_TI); 
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
							 "UT MA Resource",
							 "MAN",
							 1,
							 false,
							 true,
							 toDoTaskDescSet
							 );
	
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	self.deleteTrain(MyTrain, null);		
	// create train
	train := self.addTrain(MyTrain, null);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_TotalReq, 2);
	self.opts.addAssoc(UT_OPTS_TargetTA, "UTBS2" &amp; REF);
	self.opts.addAssoc(UT_OPTS_CargoList, "UTCONT1" &amp; "," &amp; "UTCONT2");
	self.opts.addAssoc(UT_OPTS_RequiredByDT, app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc(UT_OPTS_TaskType, WO_TASK_RECEIVE );
	self.opts.addAssoc(UT_OPTS_Booking, booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);	
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RECEIVE, todoSet, tiSet, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 4, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	create objArr transient;
	objArr.add(tI4);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,train,TI_TRANSMODE_RAIL_STR,"test_Book_03",objArr,self.getMyTerminal(), app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();																						
	
	self.assertEqual(wod.CM_WodReceive.allJobs.first.workListEntries.size, 3);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 3, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.xCheckWorkOrderDetail(wod.CM_WodReceive.allToDoRequests.first, WO_STATUS_ACTIONED, 3, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.xCheckWorkOrderDetail(workOrder.allWoDtls.last, WO_STATUS_ACTIONED, 3, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	
	newWO := tI4.allWorkOrders.first; 
	if newWO.allWoDtls.isNotEmpty then
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 1, TRANS_TYPE_WO_TIREC_CREATED, true, false);
		self.xCheckWorkOrderDetail(wod.CM_WodReceive, WO_STATUS_ACTIONED, 1, TRANS_TYPE_WO_TIREC_CREATED, true, false);
		self.xCheckWorkOrderDetail(newWO.allWoDtls.last.CM_WodReceive.allToDoRequests.first, WO_STATUS_ACTIONED, 1, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	endif;
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransChangeRoadToShip" id="0f4bd0cf-089a-4d4a-ac79-bf0767eb42bc">
        <updating/>
        <source>tRecTransChangeRoadToShip()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
28 Jun 2023 navma1  Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
21 Dec 2023 navhl20 Bug 61861: EUP | Work Order Transport Mode change - issues
10 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
*/

constants
	REF: String  =  "56631";
	WOID : String  = 'UT'&amp;REF&amp;'JTC2';
vars
	tI1, tI2,tI3,tI4	:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	tiSet				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet				: 	CM_ToDoTaskDescSet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	booking				: 	CM_BookingRef;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	pxyWO				: 	CM_WorkOrderTI;
	objArr				:	ObjectArray;
	newWO				: 	CM_WorkOrder;
	strictBOLorDocket	: 	Any;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT2"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT3"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT4"), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT2");
	tI3 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT3");
	tI4 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT4");		
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCONT1" &amp; "," &amp; "UTCONT2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);								//28.06.2023 navma1 #58920
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	create objArr transient;
	objArr.add(tI4);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	self.deleteBOL("test_Bol_01",null);																						//10.01.2024 navlc30 #59997
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,voyage,TI_TRANSMODE_SHIP_STR,"test_Bol_01",objArr,self.getMyTerminal(), app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();																						//13.12.2023 naviv1 #61543
	
	newWO := tI4.allWorkOrders.first; 
	if newWO.allWoDtls.isNotEmpty then																						//13.12.2023 naviv1 #61543
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_CREATED,true,false);
	endif;
	self.assertEqualMsg(tI4.locationId, voyage.code, "The cargo should be in ship");
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);												//21.11.2023 navhl20 #61861
	self.xCheckWorkOrder(newWO.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);													//21.11.2023 navhl20 #61861
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);			//21.11.2023 navhl20 #61861
	self.xCheckWorkOrder(newWO.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);				//21.11.2023 navhl20 #61861
	
	self.assertEqualMsg(workOrder.allWoDtls.last.status ,  WO_STATUS_ACTIONED, "The work order task status should be actioned");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyWO;
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransChangeShipToRail" id="a1c4732a-f08c-4788-b75a-6d4f600c7596">
        <updating/>
        <source>tRecTransChangeShipToRail()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
*/

constants
	REF: String  =  "59997";
	WOID : String  = 'UT'&amp;REF&amp;'JTC4';
	MyTrain : String = 'TRUT4'&amp;REF;	
vars
	tI1, tI2,tI3,tI4	:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	tiSet				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet				: 	CM_ToDoTaskDescSet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	pxyWO				: 	CM_WorkOrderTI;
	objArr				: 	ObjectArray;
	bol					:	CM_BOL;
	aPort 				: 	CM_Port;
	oper 				: 	CM_Operator;
	newWO				: 	CM_WorkOrder;
	train				: 	CM_Train;
	strictBOLorDocket	: 	Any;		
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT01"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT02"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT03"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT04"), false);
	self.deleteBOL("UT_HLBOL",bol);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	bol := self.addBOL("UT_HLBOL",voyage,vessel.myOperator,null,self.getTerminal());
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	//Creating cargos for detail
	tI1 := self.addContainerOnShip( "UTCONT01", null, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	tI2 := self.addContainerOnShip( "UTCONT02", null, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	tI3 := self.addContainerOnShip( "UTCONT03", null, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	tI4 := self.addContainerOnShip( "UTCONT04", null, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	
	beginTransaction;
		tI1.attachToBOL(bol);
		tI2.attachToBOL(bol);
		tI3.attachToBOL(bol);
		tI4.attachToBOL(bol);
	commitTransaction;
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	
	self.deleteTrain(MyTrain,null);		
	// create train
	train := self.addTrain(MyTrain, null);	
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCONT1" &amp; "," &amp; "UTCONT2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('bol', bol);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIREC_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	create objArr transient;
	objArr.add(tI3);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Changing Transport to Rail
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,train,TI_TRANSMODE_RAIL_STR,"test_Book_04",objArr,self.getMyTerminal(), app.myPassport, null);	
	self.assertNoTrxErrorsOrWarnings();																						
	
	newWO := tI3.allWorkOrders.first;
	if newWO.allWoDtls.isNotEmpty then																						
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_CREATED,true,false);
	endif;
	self.assertEqualMsg(tI3.locationId, voyage.code, "The cargo should be in ship");
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);												
	self.xCheckWorkOrder(newWO.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);													
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	self.xCheckWorkOrder(newWO.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.assertEqualMsg(workOrder.allWoDtls.last.status ,  WO_STATUS_ACTIONED, "The work order task status should be actioned");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	delete tiSet;
	if toDoTaskDescSet &lt;&gt; null then
		delete toDoTaskDescSet;
	endif;
	if todoSet &lt;&gt; null then
		delete todoSet;
	endif;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyWO;
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransChangeShipToRoad" id="fbc0e8b7-9cf5-4c74-a185-0fd1ad814287">
        <updating/>
        <source>tRecTransChangeShipToRoad()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
21 Dec 2023 navhl20 Bug 61861: EUP | Work Order Transport Mode change - issues
10 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
*/

constants
	REF: String  =  "56631";
	WOID : String  = 'UT'&amp;REF&amp;'JTC1';
vars
	tI1, tI2,tI3,tI4	:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	tiSet				: 	CM_TISet;
	toDoTaskDescSet     : 	CM_ToDoTaskDescBySortKey;
	todoSet				: 	CM_ToDoTaskDescSet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	pxyWO				: 	CM_WorkOrderTI;
	objArr				: 	ObjectArray;
	bol					:	CM_BOL;
	aPort 				: 	CM_Port;
	oper 				: 	CM_Operator;
	newWO				: 	CM_WorkOrder; 
	strictBOLorDocket	: 	Any;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT01"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT02"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT03"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT04"), false);
	self.deleteBOL("UT_HLBOL",bol);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	bol := self.addBOL("UT_HLBOL",voyage,vessel.myOperator,null,self.getTerminal());
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	//Creating cargos for detail -1

	tI1 := self.addContainerOnShip( "UTCONT01", oper, "2200", "APPL", null, voyage, aPort.code, voyage.code);												//10.01.2024 navlc30 #59997
	tI2 := self.addContainerOnShip( "UTCONT02", oper, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	tI3 := self.addContainerOnShip( "UTCONT03", oper, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	tI4 := self.addContainerOnShip( "UTCONT04", oper, "2200", "APPL", null, voyage, aPort.code, voyage.code);
	
	beginTransaction;
		tI1.attachToBOL(bol);
		tI2.attachToBOL(bol);
		tI3.attachToBOL(bol);
		tI4.attachToBOL(bol);
	commitTransaction;
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCONT1" &amp; "," &amp; "UTCONT2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	self.opts.addAssoc('bol', bol);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIREC_CREATED,false,false);	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	create objArr transient;
	objArr.add(tI4);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,voyage,TI_TRANSMODE_ROAD_STR,"test_Booking_01",objArr,self.getMyTerminal(), app.myPassport, null);		//10.01.2024 navlc30 #59997
	self.assertNoTrxErrorsOrWarnings();																						//13.12.2023 naviv1 #61543
	
	newWO := tI4.allWorkOrders.first;
	if newWO.allWoDtls.isNotEmpty then																						//13.12.2023 naviv1 #61543
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_CREATED,true,false);
	endif;
	
	self.assertEqualMsg(tI4.locationId, voyage.code, "The cargo should be in ship");
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);												//21.11.2023 navhl20 #61861
	self.xCheckWorkOrder(newWO.allWoDtls.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);													//21.11.2023 navhl20 #61861
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);			//21.11.2023 navhl20 #61861
	self.xCheckWorkOrder(newWO.allWoDtls.first.CM_WodReceive.allToDoRequests.first,WO_STATUS_APPROVED,1,TRANS_TYPE_WO_TIREC_UPDATED,true,false);				//21.11.2023 navhl20 #61861
	
	self.assertEqualMsg(workOrder.allWoDtls.last.status ,  WO_STATUS_ACTIONED, "The work order task status should be actioned");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	delete tiSet;
	if toDoTaskDescSet &lt;&gt; null then
		delete toDoTaskDescSet;
	endif;
	if todoSet &lt;&gt; null then
		delete todoSet;
	endif;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyWO;
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRecTransRoadToShipWithStatus" id="9d2af324-5367-45b8-93b7-12f0d36004e0">
        <updating/>
        <source>tRecTransRoadToShipWithStatus()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2023 navhl20 Defect 61920: EUP - The Work Order Status for the "Receive Road WO" remains "Part Complete" despite changing the transport mode for all remaining items to "Ship."
16 Jan 2023 navhl20 Defect 62032: EUP - Error when confirming the cargo using the Cargo Scanning app
*/

constants
	REF: String  =  "61920";
	WOID : String  = 'UT'&amp;REF&amp;'JTC2';
vars
	tI1, tI2,tI3,tI4	:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	toDoTaskDesc		: 	CM_ToDoTaskDesc;
	tiSet				: 	CM_TISet;
	voyage				: 	CM_Voyage;
	vessel 				:	CM_Vessel;
	booking				: 	CM_BookingRef;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	pxyWO				: 	CM_WorkOrderTI;
	objArr				: 	ObjectArray;
	newWO				: 	CM_WorkOrder;
	job					:	CM_RoadJob;
	wle					:	CM_WorkListEntry;
	term				: 	CM_Terminal;
	wleArr				: 	CM_WLEArray;
	strictBOLorDocket	: 	Any;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	strictBOLorDocket := app.myRoot.getConfig(StrictBOLNumberCheck);
	
	beginTransaction;
	app.myRoot.setConfig(StrictBOLNumberCheck, false,false);
	commitTransaction;
	
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteTrackedItem(self.getTrackedItem("UTCONTH1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONTH2"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONTH3"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONTH4"), false);
	self.deleteBooking("UT_HLBOOKING");
	self.deleteBOL("test_Bol_01",null);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer("UT_HLBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, "UT_HLBOOKING");
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONTH1");	
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONTH2");
	tI3 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONTH3");
	tI4 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONTH4");		
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);

	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,4,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.gateInPinReceival(workOrder.getPINNumber,'UTTHL'&amp;REF);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,4,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Allocate job to jobSheet
	job := term.myWOJobSheet.allJobsByRequiredDTPriority[workOrder.requiredByDT,3].CM_RoadJob;
	
	//Complete workOrder
	self.queueWLE(job.workListEntries.first);
	self.moveVehicleToYard(job.myVehicle);
	self.moveWLE(job.workListEntries.first);
	self.deleteJobEntry(job.workListEntries.last);
	self.deleteJobEntry(job.workListEntries.last);
	self.deleteJobEntry(job.workListEntries.last);
	self.roadExit(job.myVehicleVisit);
	
	create objArr transient;
	objArr.add(tI2);
	objArr.add(tI3);
	objArr.add(tI4);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO,pxyWO.allWoDtls.first.CM_WodReceive,voyage,TI_TRANSMODE_SHIP_STR,"test_Bol_01",objArr,self.getMyTerminal(), app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	
	newWO := tI4.allWorkOrders.first; 
	if newWO.allWoDtls.isNotEmpty then
		wod := newWO.allWoDtls.first;
		self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_CREATED,true,false);
	endif;
	
	self.assertEqualMsg(tI2.locationId, voyage.code, "The cargo should be in ship");			//16.01.2023 navhl20 #62032
	
	self.xCheckWorkOrder(workOrder.allWoDtls.first,WO_STATUS_COMPLETE,1,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
	self.xCheckWorkOrder(newWO.allWoDtls.first,WO_STATUS_APPROVED,3,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	self.assertEqualMsg(workOrder.taskStatus ,  WO_STATUS_COMPLETE, "The work order status should be completed");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	app.myRoot.setConfig(StrictBOLNumberCheck, strictBOLorDocket, false);
	commitTransaction;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyWO;
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRailAnyAmtWS1" id="75620618-2e07-447f-b619-305c0e13ab03">
        <source>tRelRailAnyAmtWS1();
/*

Purpose:			Tests Work Order Cargo Release Any Amount by Quantity with Cargo Type that does allow duplicates and cargo that has a quantity of 1 assigning to the release properly 
					and work order Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
29 October 2024	navpw1	Initial creation JIRA: MTN-33528

*/

constants
	REF								: String = "33361";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL1";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "3";
	AmountTrackedItems				: Integer = 5;
	StartCargoId					: Integer = 1;
	MaxCargoId						: Integer = 6;
	LoadedTrackedItems				: Integer = 5;
	UT_WorkPoint					: String = "UT_WORAIL";
	UT_WorkPointJobSheet			: String = "UT_WOR";
	
	UT_Train 		: String = "UT" &amp; REF &amp; "_1";
	UT_Wagon1 		: String = "BOX-" &amp; REF &amp; "_1";
	UT_Wagon2 		: String = "BOX-" &amp; REF &amp; "_2";
	UT_Wagon3 		: String = "BOX-" &amp; REF &amp; "_3";
	
	UT_RailAreaId 		: String = "UT" &amp; REF;
	UT_WagonClass		: String = "BOX";
	
vars
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	ti								: CM_TrackedItem;
	vehicleBookingTerminal			: CM_VehicleBookingTerminal;
	reserveDetail					: CM_ReserveDetail;
	configArr						: StringArray;
	myRoot							: CM_Root;
	allTis							: CM_TISet;
	train,
	pxyTrain			: CM_Train;
	railArea 			: CM_Rail;
	pxyMaster			: CM_WagonMaster;
	wagonClass			: CM_WagonClass;
	wagon1,
	wagon2,
	wagon3,
	wagon				: CM_Wagon;
	railLine			: CM_RailLine;
	wagonMaster			: CM_WagonMaster;
	railIORake : CM_RailJSInOutRake;
	obj : Object;
	cmifObjects 		: ObjectArray;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	wagMoveControl : CMIF_WagonMoveController;
	allWagons			: CM_WagonArray;
	wleArray			: CM_WLEArray;
	tmpReq 		   	 : CMIF_Request;
	agent 		   	 : CM_RailProcessingAgent;
	job				: CM_Job;
	railJob			: CM_RailJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	wsPutCargoToWagon,
	wsPutCompleteWagon,
	trackedItemId					: String;
	cargoOid,
	wagonOid,
	operatorStr						: String;
	expectFailure					: Boolean;
	wle								: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	cmifRakeRegion					: CMIF_RakeRegion;
	trainSet						: CM_TrainSet;
	
begin
	/*
	*	Setup Section
	*/
	terminal	:= self.getMyTerminal();
	myRoot		:= app.myRoot;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmtMaxWgtWS3;
	
	//Terminal Configs
	/*create configArr transient;
	configArr.add(UseYardJobsCargoWO);
	configArr.add(AllowAutoActionCargoWo);
	configArr.add(NoImportStops);
	configArr.add(AllowVBSInPast);
	terminalUTHelper.xSetupTerminalConfigs(configArr, true, terminal);
	*/
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(AllowVBSInPast, true);
	
	//configArr.clear();
	
	//configArr.add(AutoPlanAllowLogging);
	//configArr.add(AutoPlanEnabled);
	//terminalUTHelper.xSetupTerminalConfigs(configArr, false, terminal);
	
	self.setTerminalConfig(AutoPlanAllowLogging, false);
	self.setTerminalConfig(AutoPlanEnabled, false);
	
	//configArr.clear;
	
	self.setTerminalConfig(ShowRelReqOnRailLoadList, true);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	// wagon master stuff
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon2];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon3];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	self.deleteTrain(UT_Train, null);
	self.deleteRailArea(UT_RailAreaId);
	
	// create the train and wagons
	train := self.addTrain(UT_Train, null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(UT_RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[UT_WagonClass];
	self.assertNotNullMsg(wagonClass, "Cannot find wagon class");
	
	create pxyMaster transient;
	pxyMaster.setProxy(UT_Wagon1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	self.assertNoTrxErrorsOrWarnings();
	
	wagon1 := self.addWagon(UT_Wagon1, wagonClass.code, train);
	self.assertNotNullMsg(wagon1, "wagon1 not created");
	
	wagon2 := self.addWagon(UT_Wagon2, wagonClass.code, train);
	self.assertNotNullMsg(wagon2, "wagon2 not created");
	
	wagon3 := self.addWagon(UT_Wagon3, wagonClass.code, train);
	self.assertNotNullMsg(wagon3, "wagon3 not created");
	
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Weight, 250.00.Decimal);
	
	create allTis transient;
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
		allTis.add(ti);
		beginTransaction;
		ti.setIntendedReleaseModeFromStr( TI_TRANSMODE_RAIL_STR );
		commitTransaction;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_RAIL, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	// arrive the train
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(self.localToSystemTime(app.actualTimeServer));
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create allWagons transient;
	allWagons.add(wagon1);
	allWagons.add(wagon2);
	allWagons.add(wagon3);
	
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine;
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo := true;
	wagMoveControl.autoSetEffectiveTimeStamp();
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete wagMoveControl;
	
	railIORake := wagon1.getRailJSInOutRake(false);
	
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	
	cmifRequest.isAnyAmount := true;
	cmifRequest.quantityTxt := 1;
	//terminalUTHelper.rail_SetupCMIFRequest(cmifRequest);
	
	self.assertNotNull(cmifRequest);
	
	//app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	app.myTrxUA.trxUpdateAssignBulkOutRail(intFaceBP, railIORake, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create wleArray transient;
	
	//jlier1 TFS 56733 27/4/23 
	foreach tmpReq in intFaceBP.allCMIFRequests do
			if tmpReq.myNewJob &lt;&gt; null then
				tmpReq.myNewJob.workListEntries.copyNoDups(wleArray);
			endif;
	endforeach;
	
	self.assertEqualMsg(wleArray.size, 1, "Expected the wle array to ony contain 1 wle");
	self.assertTrueMsg(wleArray.first.isAnyAmount, "Wle should be an 'Any Amount' wle");
	self.assertTrueMsg(wleArray.first.isRailBreakBulkRelease, "Wle should have the following set to true: 'isRailBreakBulkRelease'");
	
	foreach wagon in allWagons do
		self.assertTrueMsg(wagon.isBoxcar, "Wagon must be a box car");
		
	endforeach;
	
	if wleArray.size &gt; 0 then
	
		create agent transient;
		agent.initialise(terminal);
		agent.showWarnings := true;
		agent.doAssignReleasesToWagons( wleArray, allWagons, false, true );
	endif;
	
	//Assign Work Order to Work point job sheet
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isRail then
			railJob := job.CM_RailJob;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(railJob, "railJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(railJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(railJob, "railJob");
	
	//Assign tracked items to wagon using web endpoint
	loopVar := StartCargoId;
	while loopVar &lt;= StartCargoId + LoadedTrackedItems - 1 do
	//while loopVar &lt;= MaxCargoId do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Move last one should result in error --Check for error then continue completing and make sure it still completes
	ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
	wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
	cargoOid := ti.getOidAsString();
	operatorStr := null;
	expectFailure := true;
	
	self.opts.purge;
	self.opts.addAssoc("ExpectedResponse", "Code :85094. " &amp; app.getErrorString(Work_list_entry_found));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
	self.opts.purge;
	self.logMessage("Expected Exception has been Raised: '" &amp; app.getErrorString(Work_list_entry_found));
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Clear the Rake for the Rail Job");
	
	wsPutCompleteWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false
		}';
	wagonOid := wagon1.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteWagon.name, operatorStr, wsPutCompleteWagon, wagonOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Rail Job in one section
	
	//Verify Rail Job has right amount of wle's
	self.assertTrueMsg(railJob.workListEntries.size = AmountTrackedItems, "Rail Job WLE Count Expected: '" &amp; AmountTrackedItems.String &amp; "' | Actual: '" &amp; railJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Rail Job
	foreach wle in railJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "wle.myRequest should be a delivery request");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_DeliveryRequest.quantity = 0, "wle.myRequest.CM_DeliveryRequest.quantity should be set to 0");
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order
	//Verify that work order is completed
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	
	//Verify work order job only things not in xCheckWorkOrder
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify rail job is complete
	self.assertTrueMsg(railJob.status = JOB_COMPLETE, "Expected the rail job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(railJob.workListEntries.size, AmountTrackedItems, "Expected Rail Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in railJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Confirm Out Wagons
	create wagMoveControl transient;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo := true;
	wagMoveControl.autoSetEffectiveTimeStamp();
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirm(allWagons, false, wagMoveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Clear Rake
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add(wagon1);	//Change to allWagons copy
	cmifRakeRegion.allWagons.add(wagon2);
	cmifRakeRegion.allWagons.add(wagon3);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//Depart Train
	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
	
	
	//self.xWorkOrderRailAnyAmtLoad(workOrder, wod, vehicleName, driverName, gate.name, releaseRequest, reserveDetail, realVbsTimeSlot, 
	//								UT_WorkPoint, UT_WorkPointJobSheet, tisToLoad, true, tiToFail, cargoType, terminalUTHelper, terminal);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete terminalUTHelper;
	delete configArr;
	delete cmifObjects;
	delete agent;
	delete wagMoveControl;
	delete pxyMaster;
	delete pxyTrain;
	if intFaceBP &lt;&gt; null then
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP.myProxyRailJob;
	endif;
	delete intFaceBP;
	delete wleArray;
	delete allWagons;
	delete allJobArr;
	delete pxyWorkPointJobSheet;
	delete cmifRakeRegion;
	delete allTis;
	delete trainSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRailAnyAmtWS2" id="a3ee251f-1e72-499a-99e6-d24989b3dd3d">
        <source>tRelRailAnyAmtWS2();
/*

Purpose:			Tests Work Order Cargo Release Any Amount by Quantity with Cargo Type that does allow duplicates and cargo that has a quantity of 5 assigning to the release properly 
					and work order Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
06 December 2024	navpw1	Initial creation JIRA: MTN-33528

*/

constants
	REF								: String = "33361";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL2";
	UT_TotalRequested				: Integer = 25;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	AmountTrackedItems				: Integer = 5;
	StartCargoId					: Integer = 7;
	MaxCargoId						: Integer = 12;
	LoadedTrackedItems				: Integer = 5;
	UT_WorkPoint					: String = "UT_WORAIL";
	UT_WorkPointJobSheet			: String = "UT_WOR";
	
	UT_Train 		: String = "UT" &amp; REF &amp; "_2";
	UT_Wagon1 		: String = "BOX-" &amp; REF &amp; "_4";
	UT_Wagon2 		: String = "BOX-" &amp; REF &amp; "_5";
	UT_Wagon3 		: String = "BOX-" &amp; REF &amp; "_6";
	
	UT_RailAreaId 		: String = "UT" &amp; REF;
	UT_WagonClass		: String = "BOX";
	
vars
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	ti								: CM_TrackedItem;
	vehicleBookingTerminal			: CM_VehicleBookingTerminal;
	reserveDetail					: CM_ReserveDetail;
	configArr						: StringArray;
	myRoot							: CM_Root;
	allTis							: CM_TISet;
	train,
	pxyTrain			: CM_Train;
	railArea 			: CM_Rail;
	pxyMaster			: CM_WagonMaster;
	wagonClass			: CM_WagonClass;
	wagon1,
	wagon2,
	wagon3,
	wagon				: CM_Wagon;
	railLine			: CM_RailLine;
	wagonMaster			: CM_WagonMaster;
	railIORake : CM_RailJSInOutRake;
	obj : Object;
	cmifObjects 		: ObjectArray;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	wagMoveControl : CMIF_WagonMoveController;
	allWagons			: CM_WagonArray;
	wleArray			: CM_WLEArray;
	tmpReq 		   	 : CMIF_Request;
	agent 		   	 : CM_RailProcessingAgent;
	job				: CM_Job;
	railJob			: CM_RailJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	wsPutCargoToWagon,
	wsPutCompleteWagon,
	trackedItemId					: String;
	cargoOid,
	wagonOid,
	operatorStr						: String;
	expectFailure					: Boolean;
	wle								: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	cmifRakeRegion					: CMIF_RakeRegion;
	trainSet						: CM_TrainSet;
	
begin
	/*
	*	Setup Section
	*/
	terminal	:= self.getMyTerminal();
	myRoot		:= app.myRoot;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmtMaxWgtWS3;
	
	///Terminal Configs
	/*create configArr transient;
	configArr.add(UseYardJobsCargoWO);
	configArr.add(AllowAutoActionCargoWo);
	configArr.add(NoImportStops);
	configArr.add(AllowVBSInPast);
	terminalUTHelper.xSetupTerminalConfigs(configArr, true, terminal);
	*/
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(AllowVBSInPast, true);
	
	//configArr.clear();
	
	//configArr.add(AutoPlanAllowLogging);
	//configArr.add(AutoPlanEnabled);
	//terminalUTHelper.xSetupTerminalConfigs(configArr, false, terminal);
	
	self.setTerminalConfig(AutoPlanAllowLogging, false);
	self.setTerminalConfig(AutoPlanEnabled, false);
	
	//configArr.clear;
	
	self.setTerminalConfig(ShowRelReqOnRailLoadList, true);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	// wagon master stuff
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon2];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon3];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	self.deleteTrain(UT_Train, null);
	self.deleteRailArea(UT_RailAreaId);
	
	// create the train and wagons
	train := self.addTrain(UT_Train, null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(UT_RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[UT_WagonClass];
	self.assertNotNullMsg(wagonClass, "Cannot find wagon class");
	
	create pxyMaster transient;
	pxyMaster.setProxy(UT_Wagon1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	self.assertNoTrxErrorsOrWarnings();
	
	wagon1 := self.addWagon(UT_Wagon1, wagonClass.code, train);
	self.assertNotNullMsg(wagon1, "wagon1 not created");
	
	wagon2 := self.addWagon(UT_Wagon2, wagonClass.code, train);
	self.assertNotNullMsg(wagon2, "wagon2 not created");
	
	wagon3 := self.addWagon(UT_Wagon3, wagonClass.code, train);
	self.assertNotNullMsg(wagon3, "wagon3 not created");
	
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_Quantity, 5);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Weight, 250.00.Decimal);
	
	create allTis transient;
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
		allTis.add(ti);
		beginTransaction;
		ti.setIntendedReleaseModeFromStr( TI_TRANSMODE_RAIL_STR );
		commitTransaction;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_RAIL, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	// arrive the train
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(self.localToSystemTime(app.actualTimeServer));
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create allWagons transient;
	allWagons.add(wagon1);
	allWagons.add(wagon2);
	allWagons.add(wagon3);
	
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine;
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo := true;
	wagMoveControl.autoSetEffectiveTimeStamp();
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete wagMoveControl;
	
	railIORake := wagon1.getRailJSInOutRake(false);
	
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	
	cmifRequest.isAnyAmount := true;
	cmifRequest.quantityTxt := 1;
	//terminalUTHelper.rail_SetupCMIFRequest(cmifRequest);
	
	self.assertNotNull(cmifRequest);
	
	//app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	app.myTrxUA.trxUpdateAssignBulkOutRail(intFaceBP, railIORake, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create wleArray transient;
	
	//jlier1 TFS 56733 27/4/23 
	foreach tmpReq in intFaceBP.allCMIFRequests do
			if tmpReq.myNewJob &lt;&gt; null then
				tmpReq.myNewJob.workListEntries.copyNoDups(wleArray);
			endif;
	endforeach;
	
	self.assertEqualMsg(wleArray.size, 1, "Expected the wle array to ony contain 1 wle");
	self.assertTrueMsg(wleArray.first.isAnyAmount, "Wle should be an 'Any Amount' wle");
	self.assertTrueMsg(wleArray.first.isRailBreakBulkRelease, "Wle should have the following set to true: 'isRailBreakBulkRelease'");
	
	foreach wagon in allWagons do
		self.assertTrueMsg(wagon.isBoxcar, "Wagon must be a box car");
		
	endforeach;
	
	if wleArray.size &gt; 0 then
	
		create agent transient;
		agent.initialise(terminal);
		agent.showWarnings := true;
		agent.doAssignReleasesToWagons( wleArray, allWagons, false, true );
	endif;
	
	//Assign Work Order to Work point job sheet
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isRail then
			railJob := job.CM_RailJob;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(railJob, "railJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(railJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(railJob, "railJob");
	
	//Assign tracked items to wagon using web endpoint
	loopVar := StartCargoId;
	while loopVar &lt;= StartCargoId + LoadedTrackedItems - 1 do
	//while loopVar &lt;= MaxCargoId do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Move last one should result in error --Check for error then continue completing and make sure it still completes
	ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
	wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
	cargoOid := ti.getOidAsString();
	operatorStr := null;
	expectFailure := true;
	
	self.opts.purge;
	self.opts.addAssoc("ExpectedResponse", "Code :85094. " &amp; app.getErrorString(Work_list_entry_found));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
	self.opts.purge;
	self.logMessage("Expected Exception has been Raised: '" &amp; app.getErrorString(Work_list_entry_found));
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Clear the Rake for the Rail Job");
	
	wsPutCompleteWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false
		}';
	wagonOid := wagon1.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteWagon.name, operatorStr, wsPutCompleteWagon, wagonOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Rail Job in one section
	
	//Verify Rail Job has right amount of wle's
	self.assertTrueMsg(railJob.workListEntries.size = AmountTrackedItems, "Rail Job WLE Count Expected: '" &amp; AmountTrackedItems.String &amp; "' | Actual: '" &amp; railJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Rail Job
	foreach wle in railJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "wle.myRequest should be a delivery request");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 5, "wle.quantity should be set to 5");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_DeliveryRequest.quantity = 0, "wle.myRequest.CM_DeliveryRequest.quantity should be set to 0");
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order
	//Verify that work order is completed
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	
	//Verify work order job only things not in xCheckWorkOrder
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify rail job is complete
	self.assertTrueMsg(railJob.status = JOB_COMPLETE, "Expected the rail job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(railJob.workListEntries.size, AmountTrackedItems, "Expected Rail Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in railJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Confirm Out Wagons
	create wagMoveControl transient;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo := true;
	wagMoveControl.autoSetEffectiveTimeStamp();
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirm(allWagons, false, wagMoveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Clear Rake
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add(wagon1);	//Change to allWagons copy
	cmifRakeRegion.allWagons.add(wagon2);
	cmifRakeRegion.allWagons.add(wagon3);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//Depart Train
	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
	
	
	//self.xWorkOrderRailAnyAmtLoad(workOrder, wod, vehicleName, driverName, gate.name, releaseRequest, reserveDetail, realVbsTimeSlot, 
	//								UT_WorkPoint, UT_WorkPointJobSheet, tisToLoad, true, tiToFail, cargoType, terminalUTHelper, terminal);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete terminalUTHelper;
	delete configArr;
	delete cmifObjects;
	delete agent;
	delete wagMoveControl;
	delete pxyMaster;
	delete pxyTrain;
	if intFaceBP &lt;&gt; null then
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP.myProxyRailJob;
	endif;
	delete intFaceBP;
	delete wleArray;
	delete allWagons;
	delete allJobArr;
	delete pxyWorkPointJobSheet;
	delete cmifRakeRegion;
	delete allTis;
	delete trainSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRailAnyAmtWS3" id="56620ce0-8f1e-4d01-8ac5-bd1979b2748e">
        <source>tRelRailAnyAmtWS3();
/*

Purpose:			Tests Work Order Cargo Release Any Amount by Quantity with Cargo Type that does allow duplicates and cargo that has a quantity of 5 assigning to the release properly and 
					and work order Loads in one Load. Splitting/Merging cargo test.

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
06 December 2024	navpw1	Initial creation JIRA: MTN-33528

*/

constants
	REF								: String = "33361";
	WOID							: String = "UT" &amp; REF &amp; "-3";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL3";
	UT_TotalRequested				: Integer = 30;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	AmountTrackedItems				: Integer = 5;
	AmountWles						: Integer = 10;
	StartCargoId					: Integer = 13;
	MaxCargoId						: Integer = 18;
	LoadedTrackedItems				: Integer = 5;
	UT_WorkPoint					: String = "UT_WORAIL";
	UT_WorkPointJobSheet			: String = "UT_WOR";
	
	UT_Train 		: String = "UT" &amp; REF &amp; "_3";
	UT_Wagon1 		: String = "BOX-" &amp; REF &amp; "_7";
	UT_Wagon2 		: String = "BOX-" &amp; REF &amp; "_8";
	UT_Wagon3 		: String = "BOX-" &amp; REF &amp; "_9";
	
	UT_RailAreaId 		: String = "UT" &amp; REF;
	UT_WagonClass		: String = "BOX";
	
vars
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	ti								: CM_TrackedItem;
	vehicleBookingTerminal			: CM_VehicleBookingTerminal;
	reserveDetail					: CM_ReserveDetail;
	configArr						: StringArray;
	myRoot							: CM_Root;
	allTis							: CM_TISet;
	train,
	pxyTrain			: CM_Train;
	railArea 			: CM_Rail;
	pxyMaster			: CM_WagonMaster;
	wagonClass			: CM_WagonClass;
	wagon1,
	wagon2,
	wagon3,
	wagon				: CM_Wagon;
	railLine			: CM_RailLine;
	wagonMaster			: CM_WagonMaster;
	railIORake : CM_RailJSInOutRake;
	obj : Object;
	cmifObjects 		: ObjectArray;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	wagMoveControl : CMIF_WagonMoveController;
	allWagons			: CM_WagonArray;
	wleArray			: CM_WLEArray;
	tmpReq 		   	 : CMIF_Request;
	agent 		   	 : CM_RailProcessingAgent;
	job				: CM_Job;
	railJob			: CM_RailJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	wsPutCargoToWagon,
	wsPutCompleteWagon,
	trackedItemId					: String;
	cargoOid,
	wagonOid,
	operatorStr						: String;
	expectFailure					: Boolean;
	wle								: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	cmifRakeRegion					: CMIF_RakeRegion;
	trainSet						: CM_TrainSet;
	
begin
	/*
	*	Setup Section
	*/
	terminal	:= self.getMyTerminal();
	myRoot		:= app.myRoot;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRailAnyAmtWS3;
	
	//Terminal Configs
	create configArr transient;
	configArr.add(UseYardJobsCargoWO);
	configArr.add(AllowAutoActionCargoWo);
	configArr.add(NoImportStops);
	configArr.add(AllowVBSInPast);
	terminalUTHelper.xSetupTerminalConfigs(configArr, true, terminal);
	
	configArr.clear();
	
	configArr.add(AutoPlanAllowLogging);
	configArr.add(AutoPlanEnabled);
	terminalUTHelper.xSetupTerminalConfigs(configArr, false, terminal);
	
	configArr.clear;
	
	self.setTerminalConfig(ShowRelReqOnRailLoadList, true);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	// wagon master stuff
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon2];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	wagonMaster := self.getRoot.allWagonMasters[UT_Wagon3];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	self.deleteTrain(UT_Train, null);
	self.deleteRailArea(UT_RailAreaId);
	
	// create the train and wagons
	train := self.addTrain(UT_Train, null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(UT_RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	
	// get the wagon class
	wagonClass := self.getRoot.allWagonClasses[UT_WagonClass];
	self.assertNotNullMsg(wagonClass, "Cannot find wagon class");
	
	create pxyMaster transient;
	pxyMaster.setProxy(UT_Wagon1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	self.assertNoTrxErrorsOrWarnings();
	
	wagon1 := self.addWagon(UT_Wagon1, wagonClass.code, train);
	self.assertNotNullMsg(wagon1, "wagon1 not created");
	
	wagon2 := self.addWagon(UT_Wagon2, wagonClass.code, train);
	self.assertNotNullMsg(wagon2, "wagon2 not created");
	
	wagon3 := self.addWagon(UT_Wagon3, wagonClass.code, train);
	self.assertNotNullMsg(wagon3, "wagon3 not created");
	
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_Quantity, 6);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Weight, 250.00.Decimal);
	
	create allTis transient;
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
		allTis.add(ti);
		beginTransaction;
		ti.setIntendedReleaseModeFromStr( TI_TRANSMODE_RAIL_STR );
		commitTransaction;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_RAIL, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	// arrive the train
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(self.localToSystemTime(app.actualTimeServer));
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create allWagons transient;
	allWagons.add(wagon1);
	allWagons.add(wagon2);
	allWagons.add(wagon3);
	
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine;
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo := true;
	wagMoveControl.autoSetEffectiveTimeStamp();
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete wagMoveControl;
	
	railIORake := wagon1.getRailJSInOutRake(false);
	
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	
	cmifRequest.isAnyAmount := true;
	cmifRequest.quantityTxt := 1;
	//terminalUTHelper.rail_SetupCMIFRequest(cmifRequest);
	
	self.assertNotNull(cmifRequest);
	
	//app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	app.myTrxUA.trxUpdateAssignBulkOutRail(intFaceBP, railIORake, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create wleArray transient;
	
	//jlier1 TFS 56733 27/4/23 
	foreach tmpReq in intFaceBP.allCMIFRequests do
			if tmpReq.myNewJob &lt;&gt; null then
				tmpReq.myNewJob.workListEntries.copyNoDups(wleArray);
			endif;
	endforeach;
	
	self.assertEqualMsg(wleArray.size, 1, "Expected the wle array to ony contain 1 wle");
	self.assertTrueMsg(wleArray.first.isAnyAmount, "Wle should be an 'Any Amount' wle");
	self.assertTrueMsg(wleArray.first.isRailBreakBulkRelease, "Wle should have the following set to true: 'isRailBreakBulkRelease'");
	
	foreach wagon in allWagons do
		self.assertTrueMsg(wagon.isBoxcar, "Wagon must be a box car");
		
	endforeach;
	
	if wleArray.size &gt; 0 then
	
		create agent transient;
		agent.initialise(terminal);
		agent.showWarnings := true;
		agent.doAssignReleasesToWagons( wleArray, allWagons, false, true );
	endif;
	
	//Assign Work Order to Work point job sheet
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isRail then
			railJob := job.CM_RailJob;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(railJob, "railJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(railJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(railJob, "railJob");
	
	//Assign tracked items to wagon using web endpoint
	loopVar := StartCargoId;
	while loopVar &lt;= StartCargoId + LoadedTrackedItems - 1 do
	//while loopVar &lt;= MaxCargoId do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; 3.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; 3.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Move last one should result in error --Check for error then continue completing and make sure it still completes
	ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
	wsPutCargoToWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"wagonOid": "' &amp; wagon1.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
	cargoOid := ti.getOidAsString();
	operatorStr := null;
	expectFailure := true;
	
	self.opts.purge;
	self.opts.addAssoc("ExpectedResponse", "Code :85094. " &amp; app.getErrorString(Work_list_entry_found));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoToWagon.name, operatorStr, wsPutCargoToWagon, cargoOid, expectFailure);
	self.opts.purge;
	self.logMessage("Expected Exception has been Raised: '" &amp; app.getErrorString(Work_list_entry_found));
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Clear the Rake for the Rail Job");
	
	wsPutCompleteWagon := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false
		}';
	wagonOid := wagon1.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteWagon.name, operatorStr, wsPutCompleteWagon, wagonOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Rail Job in one section
	
	//Verify Rail Job has right amount of wle's
	self.assertTrueMsg(railJob.workListEntries.size = AmountWles, "Rail Job WLE Count Expected: '" &amp; AmountWles.String &amp; "' | Actual: '" &amp; railJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Rail Job
	foreach wle in railJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "wle.myRequest should be a delivery request");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 3, "wle.quantity should be set to 3");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_DeliveryRequest.quantity = 0, "wle.myRequest.CM_DeliveryRequest.quantity should be set to 0");
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order
	//Verify that work order is completed
	self.opts.purge;
	terminalUTHelper.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, AmountWles);
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	
	//Verify work order job only things not in xCheckWorkOrder
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountWles, "Expected Work Order Job to have '" &amp; AmountWles.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountWles, "Expected Work Order Job to have '" &amp; AmountWles.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify rail job is complete
	self.assertTrueMsg(railJob.status = JOB_COMPLETE, "Expected the rail job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(railJob.workListEntries.size, AmountWles, "Expected Rail Job to have '" &amp; AmountWles.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in railJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Confirm Out Wagons
	create wagMoveControl transient;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo := true;
	wagMoveControl.autoSetEffectiveTimeStamp();
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirm(allWagons, false, wagMoveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Clear Rake
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add(wagon1);	//Change to allWagons copy
	cmifRakeRegion.allWagons.add(wagon2);
	cmifRakeRegion.allWagons.add(wagon3);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//Depart Train
	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
	
	
	//self.xWorkOrderRailAnyAmtLoad(workOrder, wod, vehicleName, driverName, gate.name, releaseRequest, reserveDetail, realVbsTimeSlot, 
	//								UT_WorkPoint, UT_WorkPointJobSheet, tisToLoad, true, tiToFail, cargoType, terminalUTHelper, terminal);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete terminalUTHelper;
	delete configArr;
	delete cmifObjects;
	delete agent;
	delete wagMoveControl;
	delete pxyMaster;
	delete pxyTrain;
	if intFaceBP &lt;&gt; null then
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP.myProxyRailJob;
	endif;
	delete intFaceBP;
	delete wleArray;
	delete allWagons;
	delete allJobArr;
	delete pxyWorkPointJobSheet;
	delete cmifRakeRegion;
	delete allTis;
	delete trainSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS1" id="a8b5706a-911b-4974-88b5-56da30273431">
        <source>tRelRoadAnyIDAnyAmountUsingWS1();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount by Quantity with Cargo Type that allows duplicates and cargo that has a quantity of 1 assigning to the release properly and work order
					Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
28 August 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF;
	AmountTrackedItems				: Integer = 5;
	StartCargoId					: Integer = 1;
	MaxCargoId						: Integer = 5;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure					: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	trackedItemId,
	vehicleName, 
	driverName						: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	wle,
	operationalWle					: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS1;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	//voyage := self.getVoyage(UT_VoyageCode);
	voyage := self.myVoyage;
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseRequest, releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Verify Road Job has right amount of wle's
	self.assertTrueMsg(roadJob.workListEntries.size = AmountTrackedItems + 1, "Road Job WLE Count Expected: '" &amp; (AmountTrackedItems + 1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 1, "wle.myRequest.CM_TIRequest.quantity should be set to 1");
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true); 
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems + 1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems + 1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems + 1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems, "Expected Road Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS2" id="e21f93c1-7289-4755-a030-8cfe9b201546">
        <source>tRelRoadAnyIDAnyAmountUsingWS2();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount by Quantity with Cargo Type that does not allow duplicates and cargo that has a quantity of 1 assigning to the release properly and work order
					Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
06 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL2";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "CANNONBALL";
	UT_ProductCode					: String = "12POUNDER-12";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "2";
	AmountTrackedItems				: Integer = 5;
	StartCargoId					: Integer = 6;
	MaxCargoId						: Integer = 10;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	expectFailure,
	foundPlaceholderWoWle			: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	vehicleName, 
	driverName,
	trackedItemId					: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;

	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	wle,
	operationalWle					: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS2;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, AmountTrackedItems);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '"
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Verify Road Job has right amount of wle's
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems+1, "Road Job WLE Count Expected: '" &amp; (AmountTrackedItems+1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 0, "wle.myRequest.CM_TIRequest.quantity should be set to 0");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems+1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems+1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems+1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems, "Expected Road Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS3" id="931db740-733d-4951-8240-53257312f1db">
        <source>tRelRoadAnyIDAnyAmountUsingWS3();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount by Quantity with Cargo Type that allows duplicates and cargo that has a quantity more than 1 assigning to the release properly and work order
					Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
09 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

constants
	REF								: String = "65623";
	WOID							: String= "UT" &amp; REF &amp; "-3";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL3";
	UT_TotalRequested				: Integer = 15;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "3";
	AmountTrackedItems				: Integer = 3;
	StartCargoId					: Integer = 11;
	MaxCargoId						: Integer = 13;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure					: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	trackedItemId,
	vehicleName, 
	driverName						: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	wle,
	operationalWle					: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS3;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Quantity, 5);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.totalQuantity = 5, "Expected total quantity of tracked item '" &amp; ti.id &amp; "' to be: '5' actual is: '" &amp; ti.totalQuantity.String &amp; "'");
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": true,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": 5
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Verify Road Job has right amount of wle's
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems+1, "Road Job WLE Count Expected: '" &amp; (AmountTrackedItems+1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 5, "wle.quantity should be set to 5");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 5, "wle.myRequest.CM_TIRequest.quantity should be set to 5");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, 4, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems+1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems+1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, 3, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems, "Expected Road Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS4" id="5db25dc6-597c-42b4-84ff-de025aa23aab">
        <source>tRelRoadAnyIDAnyAmountUsingWS4();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount with Cargo Type that does not allow duplicates and trying to overfill the Work Order

Parameters:			(In Progress) - Constants need changing

Return Value:		

Date				Who		Reason
09 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

constants
	REF									: String = "65623";
	WOID								: String = "UT" &amp; REF &amp; "-4";
	UT_BlockStack						: String = "WOBLOCK";
	UT_Cargo							: String = "UT" &amp; REF;
	UT_VoyageCode						: String = "UT_WOVOY";
	UT_VesselName						: String = "UT_WOVES";
	UT_ReleaseRequest					: String = "UT_" &amp; REF &amp; "REL4";
	UT_TotalRequested					: Integer = 5;
	UT_CargoTypeAbbr					: String = "CANNONBALL";
	UT_ProductCode						: String = "12POUNDER-12";
	Param1								: String = "%1";
	Param2								: String = "%2";
	Param3								: String = "%3";
	TrackedItemImexStatusMessage		: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId								: String = "UTTrk" &amp; REF &amp; "4";
	AmountTrackedItems					: Integer = 5;
	StartCargoId						: Integer = 14;
	MaxCargoId							: Integer = 19;
	UT_WorkPoint						: String = "UT_WOROAD";
	UT_WorkPointJobSheet				: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure						: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	vehicleName, 
	driverName							: String;
	terminal							: CM_Terminal;
	operator							: CM_Operator;
	cargoType							: CM_CargoType;
	product								: CM_Product;
	loopVar								: Integer;
	blockStack							: CM_BlockStack;
	vessel								: CM_Vessel;
	voyage								: CM_Voyage;
	pxyReserveSelection					: CM_ReserveSelection;
	releaseRequest						: CM_BulkRelease;
	terminalUTHelper					: UT_HelperAdmTerm;
	wodArr								: CM_WorkOrderDtlArray;
	pxyWod,
	wod									: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder							: CM_WorkOrder;
	vvr									: CM_VehicleVisitRecord;
	gate								: CM_Gate;
	job									: CM_Job;
	roadJob								: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet						: CM_WorkPointJobSheet;
	allJobArr							: CM_JobSet;
	vehicle								: CM_Vehicle;
	ti									: CM_TrackedItem;
	carrier								: CM_Carrier;
	wle,
	operationalWle						: CM_WorkListEntry;
	trackedItemId						: String;
	woJob								: CM_WOReleaseCargoJob;
	wowle								: CM_WOWLE;
	jobSheet							: CM_WorkPointJobSheet;
	workPoint							: CM_WorkPoint;
	reserveDetail						: CM_ReserveDetail;
	
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS4;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, UT_TotalRequested);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId-1 do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '"
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Move last one should result in error --Check for error then continue completing and make sure it still completes
	ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
	wsPutCargoLoadToReleaseRequest := '{
	"isAcknowledged": "",
	"warningsAcknowledged": false,
	"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
	"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
	"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
	"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
	}';
	cargoOid := ti.getOidAsString();
	operatorStr := null;
	expectFailure := true;
	
	self.opts.purge;
	self.opts.addAssoc("ExpectedResponse", "Code :90006. " &amp; app.getErrorString1(Quant_weigh_relea_will_excee_r, reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr()));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
	self.opts.purge;
	self.logMessage("Expected Exception Raised: '" &amp; app.getErrorString1(Quant_weigh_relea_will_excee_r, reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr()));
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Road Exit the Road Job");
	
	//Verify Road Job has right amount of wle's
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems+1, "Road Job WLE Count Expected: '" &amp; (AmountTrackedItems+1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 0, "wle.myRequest.CM_TIRequest.quantity should be set to 0");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems+1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems+1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems+1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Detail to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems, "Expected Road Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "'");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS5" id="39155aaa-0a87-49aa-9846-129e40c8cc74">
        <source>tRelRoadAnyIDAnyAmountUsingWS5();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount with Cargo Type that allows duplicates and trying to overfill the Work Order individually

Parameters:			(In Progress) - Constants need changing

Return Value:		

Date				Who		Reason
09 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-5";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL5";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "5";
	AmountTrackedItems				: Integer = 6;
	StartCargoId					: Integer = 20;
	MaxCargoId						: Integer = 25;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure					: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	trackedItemId					: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;

	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	vehicleName, 
	driverName						: String;
	wle,
	operationalWle					: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	jobSheet						: CM_WorkPointJobSheet;
	workPoint						: CM_WorkPoint;
	reserveDetail					: CM_ReserveDetail;
	
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS5;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	//voyage := self.getVoyage(UT_VoyageCode);
	voyage := self.myVoyage;
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId-1 do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Move last one should result in error --Check for error then continue completing and make sure it still completes
	ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
	wsPutCargoLoadToReleaseRequest := '{
	"isAcknowledged": "",
	"warningsAcknowledged": false,
	"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
	"reserveDetailOid": "' &amp; reserveDetail.getOidAsString() &amp; '",
	"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
	"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
	}';
	cargoOid := ti.getOidAsString();
	operatorStr := null;
	expectFailure := true;
	
	self.opts.purge;
	self.opts.addAssoc("ExpectedResponse", "Code :90006. " &amp; app.getErrorString1(Quant_weigh_relea_will_excee_r, reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr()));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
	self.opts.purge;
	self.logMessage("Expected Exception Raised: '" &amp; app.getErrorString1(Quant_weigh_relea_will_excee_r, reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr()));
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Road Exit the Road Job");
	
	//Verify Road Job has right amount of wle's
	self.assertTrueMsg(roadJob.workListEntries.size = AmountTrackedItems, "Road Job WLE Count Expected: '" &amp; AmountTrackedItems.String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 1, "wle.myRequest.CM_TIRequest.quantity should be set to 1");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true); 
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, AmountTrackedItems-1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems-1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems-1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems-1, "Expected Road Job to have '" &amp; (AmountTrackedItems-1).String &amp; "' wle's assigned | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "'");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS6" id="e577a9f8-dcfe-4ee9-93ce-ad3d0c7d686c">
        <source>tRelRoadAnyIDAnyAmountUsingWS6();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount with Cargo Type that allows duplicates and trying to overfill the Work Order bulk quantity of 5

Parameters:			(In Progress) - Constants need changing

Return Value:		

Date				Who		Reason
11 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-6";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL5";
	UT_TotalRequested				: Integer = 15;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF;
	AmountTrackedItems				: Integer = 4;
	LoadedCargoAmount				: Integer = 3;
	StartCargoId					: Integer = 26;
	MaxCargoId						: Integer = 29;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure						: Boolean;
	terminal			: CM_Terminal;
	operator			: CM_Operator;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	loopVar				: Integer;
	blockStack			: CM_BlockStack;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	pxyReserveSelection	: CM_ReserveSelection;
	releaseRequest		: CM_BulkRelease;
	terminalUTHelper	: UT_HelperAdmTerm;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	vvr					: CM_VehicleVisitRecord;
	gate				: CM_Gate;
	job					: CM_Job;
	roadJob				: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet		: CM_WorkPointJobSheet;
	allJobArr			: CM_JobSet;
	vehicle				: CM_Vehicle;
	ti					: CM_TrackedItem;
	carrier				: CM_Carrier;
	vehicleName, 
	driverName			: String;
	wle,
	operationalWle		: CM_WorkListEntry;
	trackedItemId		: String;
	woJob				: CM_WOReleaseCargoJob;
	wowle				: CM_WOWLE;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr			: String;
	jobSheet			: CM_WorkPointJobSheet;
	workPoint			: CM_WorkPoint;
	reserveDetail		: CM_ReserveDetail;
	
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS6;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	//voyage := self.getVoyage(UT_VoyageCode);
	voyage := self.myVoyage;
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Quantity, 5);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId-1 do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": true,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
		
	endwhile;
	
	//Move last one should result in error --Check for error then continue completing and make sure it still completes
	ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
	wsPutCargoLoadToReleaseRequest := '{
	"isAcknowledged": "",
	"warningsAcknowledged": true,
	"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
	"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
	"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
	"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
	}';
	cargoOid := ti.getOidAsString();
	operatorStr := null;
	expectFailure := true;
	
	self.opts.purge;
	self.opts.addAssoc("ExpectedResponse", "Code :90006. " &amp; app.getErrorString1(Quant_weigh_relea_will_excee_r, reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr()));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
	self.opts.purge;
	self.logMessage("Expected Exception Raised: '" &amp; app.getErrorString1(Quant_weigh_relea_will_excee_r, reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.getProductISOTypeDescr()));
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Road Exit the Road Job");
	
	//Verify Road Job has right amount of wle's
	self.assertTrueMsg(roadJob.workListEntries.size = LoadedCargoAmount + 1, "Road Job WLE Count Expected: '" &amp; (LoadedCargoAmount + 1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 5, "wle.quantity should be set to 5");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 5, "wle.myRequest.CM_TIRequest.quantity should be set to 5");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true); 
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, 4, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = LoadedCargoAmount+1, "Expected Work Order Detail to have '" &amp; (LoadedCargoAmount+1).String &amp; "' wle's assigned");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.xCheckWorkOrder(wod, WO_STATUS_COMPLETE, 3, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = LoadedCargoAmount, "Expected Work Order Detail to have '" &amp; LoadedCargoAmount.String &amp; "' wle's assigned");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myTrackedItem &lt;&gt; null, "wowle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, LoadedCargoAmount, "Expected Road Job to have '" &amp; LoadedCargoAmount.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
	//Verify Release request
	//Verify Release request is complete
	self.assertTrueMsg(releaseRequest.isComplete, "The release request should be complete");
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS7" id="57c34ad6-07d8-4da1-ab66-49befd7cddeb">
        <source>tRelRoadAnyIDAnyAmountUsingWS7();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount with Cargo Type that does not allows duplicates and trying to underfill the Work Order

Parameters:			(In Progress) - Constants need changing

Return Value:		

Date				Who		Reason
09 September 2024	navpw1	Initial creation JIRA: MTN-33060 (MTN-33061)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-7";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL7";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "CANNONBALL";
	UT_ProductCode					: String = "12POUNDER-12";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "7";
	AmountTrackedItems				: Integer = 5;
	LoadedTrackedItems				: Integer = 3;
	StartCargoId					: Integer = 30;
	MaxCargoId						: Integer = 35;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure					: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	trackedItemId,
	vehicleName, 
	driverName						: String;
	loopVar,
	trackedItemsAssigned,
	operationalWlesAssigned,
	wowlesCompleted					: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	wle,
	operationalWle					: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS4;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 5);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= StartCargoId + LoadedTrackedItems - 1 do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '"
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Verify Road Job has right amount of wle's
	self.assertEqualMsg(roadJob.workListEntries.size, AmountTrackedItems-1, "Road Job WLE Count Expected: '" &amp; (AmountTrackedItems-1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 0, "wle.myRequest.CM_TIRequest.quantity should be set to 0");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, 3);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null and not foundPlaceholderWoWle then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		if trackedItemId = "No Tracked Item Assigned" then //These are allowed to be unassigned from a operationalWle
			continue;
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed 
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, 3);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems, "Expected Work Order Job to have '" &amp; AmountTrackedItems.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	trackedItemsAssigned := null;
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemsAssigned += 1;
		endif;
		
		if wowle.myOperationalWLE &lt;&gt; null then
			operationalWlesAssigned += 1;
		endif;	
		
		if wowle.status = JOB_COMPLETE then
			wowlesCompleted += 1;
		endif;
		
	endforeach;
	
	//Verify 3 wowle's have tracked items assigned
	self.assertEqualMsg(trackedItemsAssigned, LoadedTrackedItems, "Checking Work Order wles with Tracked Items Assigned Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; trackedItemsAssigned.String &amp; "'");
	
	//Verify 3 wowle's have a operational wle assigned
	self.assertEqualMsg(operationalWlesAssigned, LoadedTrackedItems, "Checking Work Order wles with Operational Wle Assigned Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; operationalWlesAssigned.String &amp; "'");
	
	//Verify Work Order wle is complete
	self.assertEqualMsg(wowlesCompleted, LoadedTrackedItems, "Checking Work Order wles that are complete Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; wowlesCompleted.String &amp; "'");
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, LoadedTrackedItems, "Expected Road Job to have '" &amp; LoadedTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS8" id="34e17a8e-2718-431d-8ca6-fc0799aa67d1">
        <source>tRelRoadAnyIDAnyAmountUsingWS8();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount with Cargo Type that allows duplicates and trying to underfill the Work Order individually

Parameters:			(In Progress) - Constants need changing

Return Value:		

Date				Who		Reason
09 September 2024	navpw1	Initial creation JIRA: MTN-33060 (MTN-33061)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-8";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL8";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "8";
	AmountTrackedItems				: Integer = 5;
	LoadedTrackedItems				: Integer = 3;
	StartCargoId					: Integer = 36;
	MaxCargoId						: Integer = 40;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure					: Boolean;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	loopVar,
	trackedItemsAssigned,
	operationalWlesAssigned,
	wowlesCompleted					: Integer;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	vehicleName, 
	driverName						: String;
	wle,
	operationalWle					: CM_WorkListEntry;
	trackedItemId					: String;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr						: String;
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS8;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= StartCargoId + LoadedTrackedItems - 1 do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": false,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '"
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Verify Road Job has right amount of wle's
	self.assertEqualMsg(roadJob.workListEntries.size, LoadedTrackedItems+1, "Road Job WLE Count Expected: '" &amp; (LoadedTrackedItems+1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = 1, "wle.quantity should be set to 1");
		
		//Verify that the wle request has the correct quantity
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 0, "wle.myRequest.CM_TIRequest.quantity should be set to 0");
		
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	//self.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, LoadedTrackedItems);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems-1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = LoadedTrackedItems+1, "Expected Work Order Job to have '" &amp; (LoadedTrackedItems+1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, LoadedTrackedItems);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems-1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems-1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems-1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemsAssigned += 1;
		endif;
		
		if wowle.myOperationalWLE &lt;&gt; null then
			operationalWlesAssigned += 1;
		endif;	
		
		if wowle.status = JOB_COMPLETE then
			wowlesCompleted += 1;
		endif;
		
	endforeach;
	
	//Verify 3 wowle's have tracked items assigned
	self.assertEqualMsg(trackedItemsAssigned, LoadedTrackedItems, "Checking Work Order wles with Tracked Items Assigned Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; trackedItemsAssigned.String &amp; "'");
	
	//Verify 3 wowle's have a operational wle assigned
	self.assertEqualMsg(operationalWlesAssigned, LoadedTrackedItems, "Checking Work Order wles with Operational Wle Assigned Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; operationalWlesAssigned.String &amp; "'");
	
	//Verify 3 wowle's are complete
	self.assertEqualMsg(wowlesCompleted, LoadedTrackedItems, "Checking Work Order wles that are complete Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; wowlesCompleted.String &amp; "'");
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, LoadedTrackedItems, "Expected Road Job to have '" &amp; LoadedTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmountUsingWS9" id="f1b5dd62-7eaa-417b-9870-80b3ec6de79b">
        <source>tRelRoadAnyIDAnyAmountUsingWS9();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount with Cargo Type that allows duplicates and trying to underfill the Work Order with quantity 5

Parameters:			(In Progress) - Constants need changing

Return Value:		

Date				Who		Reason
27 September 2024	navpw1	Initial creation JIRA: MTN-33060 (MTN-33061)

*/

constants
	REF								: String = "65623";
	WOID							: String = "UT" &amp; REF &amp; "-9";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL9";
	UT_TotalRequested				: Integer = 20;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "9";
	AmountTrackedItems				: Integer = 5;
	LoadedTrackedItems				: Integer = 3;
	StartCargoId					: Integer = 41;
	MaxCargoId						: Integer = 45;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo,
	autoPlanAllowLogging,
	autoPlanEnabled,
	importStops,
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure					: Boolean;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	loopVar,
	trackedItemsAssigned,
	operationalWlesAssigned,
	wowlesCompleted					: Integer;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	vvr								: CM_VehicleVisitRecord;
	gate							: CM_Gate;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	vehicleName, 
	driverName						: String;
	wle,
	operationalWle					: CM_WorkListEntry;
	trackedItemId					: String;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr						: String;
begin
	/*
	*	Setup Section
	*/
	terminal := self.getMyTerminal();
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmountUsingWS8;
	
	//Terminal Configs
	useYardJobsSetting		:= terminal.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo		:= terminal.getConfig(AllowAutoActionCargoWo).Boolean;
	autoPlanAllowLogging	:= terminal.getConfig(AutoPlanAllowLogging).Boolean;
	autoPlanEnabled			:= terminal.getConfig(AutoPlanEnabled).Boolean;
	importStops				:= terminal.getConfig(NoImportStops).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	if autoPlanAllowLogging then
		self.setTerminalConfig(AutoPlanAllowLogging, false);
	endif;
	
	if autoPlanEnabled then
		self.setTerminalConfig(AutoPlanEnabled, false);
	endif;
	
	if not importStops then
		self.setTerminalConfig(NoImportStops, true);
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Quantity, 5);
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(UT_WorkPoint, UT_WorkPointJobSheet, terminal);
	
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, UT_WorkPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; UT_WorkPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := StartCargoId;
	while loopVar &lt;= StartCargoId + LoadedTrackedItems - 1 do
		ti := self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String);
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": true,
		"releaseOid": "' &amp; releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; releaseRequest.allReserveDetails.first.CM_ReserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	//Verify Road Job has right amount of wle's
	self.assertEqualMsg(roadJob.workListEntries.size, LoadedTrackedItems+1, "Road Job WLE Count Expected: '" &amp; (LoadedTrackedItems+1).String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertEqualMsg(wle.quantity, 5, "wle.quantity should be set to 5");
		
		//Verify that the wle request has the correct quantity
		self.assertEqualMsg(wle.myRequest.CM_TIRequest.quantity, 5, "wle.myRequest.CM_TIRequest.quantity should be set to 5 | Actual: '" &amp; wle.myRequest.CM_TIRequest.quantity.String &amp; "'");
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	//self.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, LoadedTrackedItems);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems-1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	self.opts.purge;
	terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = LoadedTrackedItems+1, "Expected Work Order Job to have '" &amp; (LoadedTrackedItems+1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem = null then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is completed
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, LoadedTrackedItems);
	self.xCheckWorkOrder(wod, WO_STATUS_PARTCOMPLETE, AmountTrackedItems-1, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	self.assertTrueMsg(woJob.workListEntries.size = AmountTrackedItems-1, "Expected Work Order Job to have '" &amp; (AmountTrackedItems-1).String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemsAssigned += 1;
		endif;
		
		if wowle.myOperationalWLE &lt;&gt; null then
			operationalWlesAssigned += 1;
		endif;	
		
		if wowle.status = JOB_COMPLETE then
			wowlesCompleted += 1;
		endif;
		
	endforeach;
	
	//Verify 3 wowle's have tracked items assigned
	self.assertEqualMsg(trackedItemsAssigned, LoadedTrackedItems, "Checking Work Order wles with Tracked Items Assigned Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; trackedItemsAssigned.String &amp; "'");
	
	//Verify 3 wowle's have a operational wle assigned
	self.assertEqualMsg(operationalWlesAssigned, LoadedTrackedItems, "Checking Work Order wles with Operational Wle Assigned Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; operationalWlesAssigned.String &amp; "'");
	
	//Verify 3 wowle's are complete
	self.assertEqualMsg(wowlesCompleted, LoadedTrackedItems, "Checking Work Order wles that are complete Expected:'" &amp; LoadedTrackedItems.String &amp; "' | Actual: '" &amp; wowlesCompleted.String &amp; "'");
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, LoadedTrackedItems, "Expected Road Job to have '" &amp; LoadedTrackedItems.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete allJobArr;
	delete terminalUTHelper;
	delete pxyWorkPointJobSheet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmtMaxWgtWS1" id="2b9a0d6f-744a-49e8-9a36-874845aa56b3">
        <source>tRelRoadAnyIDAnyAmtMaxWgtWS1();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount by Quantity with Cargo Type that allows duplicates and cargo that has a quantity of 1 assigning to the release properly and 
					has a vbs slot with max weight and work order Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
29 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

constants
	REF								: String = "14770";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF;
	StartCargoId					: Integer = 1;
	MaxCargoId						: Integer = 5;
	LoadedTrackedItems				: Integer = 2;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	UT_TimeSlotTypeId				: String = REF;					//Move to class initialize
	UT_TimeSlotId1					: String = "IDUT" &amp; REF &amp; "1";
	UT_SourceTypeRelease			: Integer = 2;
	UT_VBSMaxWeight					: Decimal = 500.0000.Decimal;
	
vars
	vehicleName, 
	driverName						: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	vehicleBookingTerminal			: CM_VehicleBookingTerminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	gate							: CM_Gate;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	pxyVbsTimeSlotItem				: CM_VehicleBookingTimeSlotItem;
	pxyVbsTimeSlot,
	realVbsTimeSlot					: CM_VehicleBookingTimeSlot;
	vbsSlotType						: CM_VehicleBookingTimeSlotType;
	driver							: CM_DriverDetails;
	reserveDetail					: CM_ReserveDetail;
	configArr						: StringArray;
	myRoot							: CM_Root;
	allTis							: CM_TISet;
	tisToLoad						: CM_TIArray;
	tiToFail						: CM_TrackedItem;
	
begin
	/*
	*	Setup Section
	*/
	terminal	:= self.getMyTerminal();
	myRoot		:= app.myRoot;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmtMaxWgtWS1;
	
	//Terminal Configs
	/*create configArr transient;
	configArr.add(UseYardJobsCargoWO);
	configArr.add(AllowAutoActionCargoWo);
	configArr.add(NoImportStops);
	configArr.add(AllowVBSInPast);
	terminalUTHelper.xSetupTerminalConfigs(configArr, true, terminal);
	*/
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(AllowVBSInPast, true);
	
	/*configArr.clear();
	
	configArr.add(AutoPlanAllowLogging);
	configArr.add(AutoPlanEnabled);
	terminalUTHelper.xSetupTerminalConfigs(configArr, false, terminal);
	
	configArr.clear;
	*/
	
	self.setTerminalConfig(AutoPlanAllowLogging, false);
	self.setTerminalConfig(AutoPlanEnabled, false);
	
	terminalUTHelper.xSetupVbsProcess(myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE], terminal);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	vbsSlotType := terminal.allTerminalVBSSlotTypes[UT_TimeSlotTypeId];
	
	//Delete Vbs Time Slot
	if vbsSlotType &lt;&gt; null then
		foreach realVbsTimeSlot in vehicleBookingTerminal.allVBTimeslotsById do
			if realVbsTimeSlot.myVBTimeSlotType &lt;&gt; vbsSlotType then
				continue;
			endif;
			
			if realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
				self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
			endif;
			
			self.deleteVbsTimeSlotAdv(realVbsTimeSlot.id);
			
		endforeach;
	endif;
	
	realVbsTimeSlot := self.getVbsTimeSlot(UT_TimeSlotId1);
	if realVbsTimeSlot &lt;&gt; null and realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
		self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
	endif;
	self.deleteVbsTimeSlotAdv(UT_TimeSlotId1);
	
	//Delete VBS SlotType
	self.deleteVbsTimeslotType(UT_TimeSlotTypeId);
	
	//Create VBS Slot Type
	vbsSlotType := self.addVbsTimeslotType(UT_TimeSlotTypeId, "Slot Type Create" &amp; UT_TimeSlotTypeId); 
	self.assertNotNullMsg(vbsSlotType, "vbsSlotType");
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.myVoyage;
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	driver := self.getDriverDetails(driverName);
	self.assertNotNullMsg(driver, "driver");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	vehicle := self.getVehicle(TruckId);
	if vehicle = null then
		vehicle := self.addVehicle(TruckId, carrier, terminal);
	endif;
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Weight, 250.00.Decimal);
	
	create allTis transient;
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
		allTis.add(ti);
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	
	//Create a vbs slot
	//Create VBS Slot &amp; Item using Release Request By Weight
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequest,
							releaseRequest.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							1000,
							0,
							UT_VBSMaxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	realVbsTimeSlot := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, app.actualTimeAppServer(), app.actualTimeAppServer(), vehicleBookingTerminal, carrier, null, driver, vehicle, self.createdByUnitTest(null), true,
														false, null, null, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlot, "Create: realVbsTimeSlot");
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	create tisToLoad transient;
	
	foreach ti in allTis do
		if tisToLoad.size &lt; LoadedTrackedItems then
			tisToLoad.add(ti);
		endif;
	endforeach;
	
	tiToFail := allTis.last;
	
	self.xWorkOrderAnyIdAnyAmtLoad(workOrder, wod, vehicleName, driverName, gate.name, releaseRequest, reserveDetail, realVbsTimeSlot, 
									UT_WorkPoint, UT_WorkPointJobSheet, tisToLoad, true, tiToFail, cargoType, terminalUTHelper, terminal);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete terminalUTHelper;
	delete pxyVbsTimeSlot;
	delete configArr;
	delete allTis;
	delete tisToLoad;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmtMaxWgtWS2" id="4298d94e-d178-4c3c-bac9-f9604dd84f78">
        <source>tRelRoadAnyIDAnyAmtMaxWgtWS2();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount by Quantity with Cargo Type that allows duplicates and cargo that has a quantity more than 1 assigning to the release properly and 
					has a vbs slot with max weight and work order Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
29 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

constants
	REF								: String = "14770";
	WOID							: String= "UT" &amp; REF &amp; "-2";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL2";
	UT_TotalRequested				: Integer = 15;
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "2";
	StartCargoId					: Integer = 6;
	MaxCargoId						: Integer = 10;
	LoadedTrackedItems				: Integer = 2;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	UT_TimeSlotTypeId				: String = REF;					//Move to class initialize
	UT_TimeSlotId1					: String = "IDUT" &amp; REF &amp; "2";
	UT_SourceTypeRelease			: Integer = 2;
	UT_VBSMaxWeight					: Decimal = 500.0000.Decimal;
	
vars
	vehicleName, 
	driverName						: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	vehicleBookingTerminal			: CM_VehicleBookingTerminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	gate							: CM_Gate;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	pxyVbsTimeSlotItem				: CM_VehicleBookingTimeSlotItem;
	pxyVbsTimeSlot,
	realVbsTimeSlot					: CM_VehicleBookingTimeSlot;
	vbsSlotType						: CM_VehicleBookingTimeSlotType;
	driver							: CM_DriverDetails;
	reserveDetail					: CM_ReserveDetail;
	configArr						: StringArray;
	myRoot							: CM_Root;
	allTis							: CM_TISet;
	tisToLoad						: CM_TIArray;
	tiToFail						: CM_TrackedItem;
	
begin
	/*
	*	Setup Section
	*/
	terminal	:= self.getMyTerminal();
	myRoot		:= app.myRoot;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmtMaxWgtWS2;
	
	//Terminal Configs
	/*create configArr transient;
	configArr.add(UseYardJobsCargoWO);
	configArr.add(AllowAutoActionCargoWo);
	configArr.add(NoImportStops);
	configArr.add(AllowVBSInPast);
	terminalUTHelper.xSetupTerminalConfigs(configArr, true, terminal);
	*/
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(AllowVBSInPast, true);
	
	/*configArr.clear();
	
	configArr.add(AutoPlanAllowLogging);
	configArr.add(AutoPlanEnabled);
	terminalUTHelper.xSetupTerminalConfigs(configArr, false, terminal);
	
	configArr.clear;
	*/
	
	self.setTerminalConfig(AutoPlanAllowLogging, false);
	self.setTerminalConfig(AutoPlanEnabled, false);
	
	terminalUTHelper.xSetupVbsProcess(myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE], terminal);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	vbsSlotType := terminal.allTerminalVBSSlotTypes[UT_TimeSlotTypeId];
	
	//Delete Vbs Time Slot
	if vbsSlotType &lt;&gt; null then
		foreach realVbsTimeSlot in vehicleBookingTerminal.allVBTimeslotsById do
			if realVbsTimeSlot.myVBTimeSlotType &lt;&gt; vbsSlotType then
				continue;
			endif;
			
			if realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
				self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
			endif;
			
			self.deleteVbsTimeSlotAdv(realVbsTimeSlot.id);
			
		endforeach;
	endif;
	
	realVbsTimeSlot := self.getVbsTimeSlot(UT_TimeSlotId1);
	if realVbsTimeSlot &lt;&gt; null and realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
		self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
	endif;
	self.deleteVbsTimeSlotAdv(UT_TimeSlotId1);
	
	//Delete VBS SlotType
	self.deleteVbsTimeslotType(UT_TimeSlotTypeId);
	
	//Create VBS Slot Type
	vbsSlotType := self.addVbsTimeslotType(UT_TimeSlotTypeId, "Slot Type Create" &amp; UT_TimeSlotTypeId); 
	self.assertNotNullMsg(vbsSlotType, "vbsSlotType");
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	driver := self.getDriverDetails(driverName);
	self.assertNotNullMsg(driver, "driver");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	vehicle := self.getVehicle(TruckId);
	if vehicle = null then
		vehicle := self.addVehicle(TruckId, carrier, terminal);
	endif;
	self.assertNotNullMsg(vehicle, "vehicle");
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Quantity, 5);
	self.opts.addAssoc(UT_OPTS_Weight, 250.00.Decimal);
	
	create allTis transient;
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.totalQuantity = 5, "Expected total quantity of tracked item '" &amp; ti.id &amp; "' to be: '5' actual is: '" &amp; ti.totalQuantity.String &amp; "'");
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
		allTis.add(ti);
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	//Create a vbs slot
	//Create VBS Slot &amp; Item using Release Request By Weight
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequest,
							releaseRequest.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							1000,
							0,
							UT_VBSMaxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	realVbsTimeSlot := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, app.actualTimeAppServer(), app.actualTimeAppServer(), vehicleBookingTerminal, carrier, null, driver, vehicle, self.createdByUnitTest(null), true,
														false, null, null, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlot, "Create: realVbsTimeSlot");
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	create tisToLoad transient;
	
	foreach ti in allTis do
		if tisToLoad.size &lt; LoadedTrackedItems then
			tisToLoad.add(ti);
		endif;
	endforeach;
	
	tiToFail := allTis.last;
	
	self.xWorkOrderAnyIdAnyAmtLoad(workOrder, wod, vehicleName, driverName, gate.name, releaseRequest, reserveDetail, realVbsTimeSlot, 
									UT_WorkPoint, UT_WorkPointJobSheet, tisToLoad, true, tiToFail, cargoType, terminalUTHelper, terminal);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete terminalUTHelper;
	delete pxyVbsTimeSlot;
	delete configArr;
	delete allTis;
	delete tisToLoad;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadAnyIDAnyAmtMaxWgtWS3" id="1cb6668e-f74d-4ae9-8701-07144ff5f729">
        <source>tRelRoadAnyIDAnyAmtMaxWgtWS3();
/*

Purpose:			Tests Work Order Cargo Release Any Id Any Amount by Quantity with Cargo Type that does not allow duplicates and cargo that has a quantity of 1 assigning to the release properly and 
					has a vbs slot with max weight and work order Loads in one Load

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
29 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

constants
	REF								: String = "14770";
	WOID							: String = "UT" &amp; REF &amp; "-3";
	UT_BlockStack					: String = "WOBLOCK";
	UT_Cargo						: String = "UT" &amp; REF;
	UT_VoyageCode					: String = "UT_WOVOY";
	UT_VesselName					: String = "UT_WOVES";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL3";
	UT_TotalRequested				: Integer = 5;
	UT_CargoTypeAbbr				: String = "CANNONBALL";
	UT_ProductCode					: String = "12POUNDER-12";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	TruckId							: String = "UTTrk" &amp; REF &amp; "3";
	AmountTrackedItems				: Integer = 5;
	StartCargoId					: Integer = 11;
	MaxCargoId						: Integer = 13;
	LoadedTrackedItems				: Integer = 2;
	UT_WorkPoint					: String = "UT_WOROAD";
	UT_WorkPointJobSheet			: String = "UT_WO";
	UT_TimeSlotTypeId				: String = REF;					//Move to class initialize
	UT_TimeSlotId1					: String = "IDUT" &amp; REF &amp; "2";
	UT_SourceTypeRelease			: Integer = 2;
	UT_VBSMaxWeight					: Decimal = 500.0000.Decimal;
	
vars
	vehicleName, 
	driverName						: String;
	loopVar							: Integer;
	terminal						: CM_Terminal;
	operator						: CM_Operator;
	cargoType						: CM_CargoType;
	product							: CM_Product;
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	pxyReserveSelection				: CM_ReserveSelection;
	releaseRequest					: CM_BulkRelease;
	terminalUTHelper				: UT_HelperAdmTerm;
	wodArr							: CM_WorkOrderDtlArray;
	pxyWod,
	wod								: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder						: CM_WorkOrder;
	gate							: CM_Gate;
	vehicle							: CM_Vehicle;
	ti								: CM_TrackedItem;
	carrier							: CM_Carrier;
	pxyVbsTimeSlotItem				: CM_VehicleBookingTimeSlotItem;
	pxyVbsTimeSlot,
	realVbsTimeSlot					: CM_VehicleBookingTimeSlot;
	vbsSlotType						: CM_VehicleBookingTimeSlotType;
	vehicleBookingTerminal			: CM_VehicleBookingTerminal;
	driver							: CM_DriverDetails;
	reserveDetail					: CM_ReserveDetail;
	configArr						: StringArray;
	myRoot							: CM_Root;
	allTis							: CM_TISet;
	tisToLoad						: CM_TIArray;
	tiToFail						: CM_TrackedItem;
	
begin
	/*
	*	Setup Section
	*/
	terminal	:= self.getMyTerminal();
	myRoot		:= app.myRoot;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadAnyIDAnyAmtMaxWgtWS3;
	
	//Terminal Configs
	/*create configArr transient;
	configArr.add(UseYardJobsCargoWO);
	configArr.add(AllowAutoActionCargoWo);
	configArr.add(NoImportStops);
	configArr.add(AllowVBSInPast);
	terminalUTHelper.xSetupTerminalConfigs(configArr, true, terminal);
	*/
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(AllowVBSInPast, true);
	
	/*configArr.clear();
	
	configArr.add(AutoPlanAllowLogging);
	configArr.add(AutoPlanEnabled);
	terminalUTHelper.xSetupTerminalConfigs(configArr, false, terminal);
	
	configArr.clear;
	*/
	
	self.setTerminalConfig(AutoPlanAllowLogging, false);
	self.setTerminalConfig(AutoPlanEnabled, false);
	
	terminalUTHelper.xSetupVbsProcess(myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE], terminal);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	vbsSlotType := terminal.allTerminalVBSSlotTypes[UT_TimeSlotTypeId];
	
	//Delete Vbs Time Slot
	if vbsSlotType &lt;&gt; null then
		foreach realVbsTimeSlot in vehicleBookingTerminal.allVBTimeslotsById do
			if realVbsTimeSlot.myVBTimeSlotType &lt;&gt; vbsSlotType then
				continue;
			endif;
			
			if realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
				self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
			endif;
			
			self.deleteVbsTimeSlotAdv(realVbsTimeSlot.id);
			
		endforeach;
	endif;
	
	realVbsTimeSlot := self.getVbsTimeSlot(UT_TimeSlotId1);
	if realVbsTimeSlot &lt;&gt; null and realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
		self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
	endif;
	self.deleteVbsTimeSlotAdv(UT_TimeSlotId1);
	
	//Delete VBS SlotType
	self.deleteVbsTimeslotType(UT_TimeSlotTypeId);
	
	//Create VBS Slot Type
	vbsSlotType := self.addVbsTimeslotType(UT_TimeSlotTypeId, "Slot Type Create" &amp; UT_TimeSlotTypeId); 
	self.assertNotNullMsg(vbsSlotType, "vbsSlotType");
	
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	if product = null then
		product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	endif;
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.getTerminalArea(UT_BlockStack).CM_BlockStack;
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.getVessel(UT_VesselName);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.getVoyage(UT_VoyageCode);
	self.assertNotNullMsg(voyage, "voyage");
	
	carrier := myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	driver := self.getDriverDetails(driverName);
	self.assertNotNullMsg(driver, "driver");
	
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	vehicle := self.getVehicle(TruckId);
	if vehicle = null then
		vehicle := self.addVehicle(TruckId, carrier, terminal);
	endif;
	self.assertNotNullMsg(vehicle, "vehicle");
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Weight, 250.00.Decimal);
	
	create allTis transient;
	loopVar := StartCargoId;
	while loopVar &lt;= MaxCargoId do
		ti := self.addCargoAtLocation(UT_Cargo &amp; "-" &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti | " &amp; UT_Cargo &amp; "-" &amp; loopVar.String);
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus()))));
		loopVar += 1;
		allTis.add(ti);
	endwhile;
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//Verify Release request
	
	//Create a vbs slot
	//Create VBS Slot &amp; Item using Release Request By Weight
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequest,
							releaseRequest.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							1000,
							0,
							UT_VBSMaxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	realVbsTimeSlot := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, app.actualTimeAppServer(), app.actualTimeAppServer(), vehicleBookingTerminal, carrier, null, driver, vehicle, self.createdByUnitTest(null), true,
														false, null, null, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlot, "Create: realVbsTimeSlot");
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	create tisToLoad transient;
	
	foreach ti in allTis do
		if tisToLoad.size &lt; LoadedTrackedItems then
			tisToLoad.add(ti);
		endif;
	endforeach;
	
	tiToFail := allTis.last;
	
	self.xWorkOrderAnyIdAnyAmtLoad(workOrder, wod, vehicleName, driverName, gate.name, releaseRequest, reserveDetail, realVbsTimeSlot, 
									UT_WorkPoint, UT_WorkPointJobSheet, tisToLoad, true, tiToFail, cargoType, terminalUTHelper, terminal);
	
epilog
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete terminalUTHelper;
	delete pxyVbsTimeSlot;
	delete configArr;
	delete allTis;
	delete tisToLoad;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadByType2Trk" id="f2758d25-0c34-4757-9ccd-bcc55662f4b7">
        <source>tRelRoadByType2Trk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Mar 2024 navhl20 Bug 62758: EUP | FR | Work Order status - complete without loading all items

*/

constants
	REF: String  =  "62758";
	WOID : String  = 'UT'&amp;REF&amp;'RRBT';
	BLOCKSTACK : String = "UTBS1" &amp; REF;
	Voyage	: String = "UTVoy" &amp; REF;
	WPJS : String = "UT62758JS";
	TruckId : String = 'UTTRK1'&amp; REF;
vars
	tI1,
	tI2					: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	tiSet				: CM_TISet;
	releaseRequest		: CM_BulkRelease;
	taSource			: CM_TerminalArea;
	code				: String;
	relTime				: TimeStamp;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	vehicleName, 
	driverName			: String;
	terminalUTHelper	: UT_HelperAdmTerm;
	gate				: CM_Gate;
	terminal 			: CM_Terminal;
	vvr					: CM_VehicleVisitRecord;
	driver				: CM_DriverDetails;
	vehicle				: CM_Vehicle;
	operator 			: CM_Operator;
	blockStack				: CM_BlockStack;
	wle						: CM_WorkListEntry;
	myPxyWorkPointJobSheet	: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	hideMoveConfirmation 	: Any;
	tmpFoundLC				: CM_LocationsController;
	moveController			: CMIF_MoveController;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.setTerminalConfig(UseYardJobsCargoWO, true);
	canAutoActionTiWo := self.setTerminalConfig(AllowAutoActionCargoWo, false);
	hideMoveConfirmation := self.setTerminalConfig(HhMoveConfirmation, true);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadByType2Trk;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL1" &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	//cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	
	self.deleteCargo("UT_Stl_10G_01", cargoType);
	self.deleteCargo("UT_Stl_10G_02", cargoType);
	self.deleteCargo("UT_Stl_10G_03", cargoType);
	self.deleteCargo("UT_Stl_10G_04", cargoType);
	self.deleteCargo("UT_Stl_10G_05", cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UT_Stl_10G_01", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UT_Stl_10G_02", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 5);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTBULKREL1" &amp; REF, BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, cargoType.getProductFromCode("TIEWIRE10G"));
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,2,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();

	// create the move controller
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI1);
	moveController.setQuantity(1);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();
	
	// create the move controller
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI2);
	moveController.setQuantity(1);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	self.roadExit(vvr);
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	self.setTerminalConfig(HhMoveConfirmation, hideMoveConfirmation);
	
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete terminalUTHelper;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete truckUnLoaderController;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadUsingWS" id="be558c98-b6fc-4a3e-a06d-89095dad9dda">
        <source>tRelRoadUsingWS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jan 2024	navhl20	Bug 62026: MTN - Unit test case missing for release road
18 Apr 2024	navpw1	Fixed unit test changed currentMethodBeingRun to the correctly named method, now uses "Steel Coil" instead of "Cannon Balls" - Causes issues leading to 1018 exception with yard allocations
09 Sep 2024	navbs1	Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job

*/

constants
	REF: String  =  "62026";
	WOID : String  = 'UT'&amp;REF&amp;'JREBTR';
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVoy" &amp; REF;
	TruckId : String = 'UTTRKHM'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	retroMode				: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	myPxyWorkPointJobSheet,
	realJobSheet			: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	hideMoveConfirmation 	: Boolean;
	job						: CM_Job;
	defaultProcess			: String;
	carrier					: CM_Carrier;
	roadJob					: CM_RoadJob;
	vehicle					: CM_Vehicle;
	vehicleName, 
	driverName				: String;
	terminalUTHelper		: UT_HelperAdmTerm;
	gate					: CM_Gate;
	vvr						: CM_VehicleVisitRecord;
	driver					: CM_DriverDetails;
	wle						: CM_WorkListEntry;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	tmpFoundLC				: CM_LocationsController;
	moveController			: CMIF_MoveController;
	cnt						: Integer;
	product					: CM_Product;
	autoPlanEnabled			: Any;
	prof : JadeProfiler;
	ts : TimeStamp;
	releaseAmount 			: Integer;
	
begin
	prof := process.profiler;
    prof.fileName := app.getAppServerLogDir() &amp; '\tmpFiles\' &amp; method.name &amp; ts.formatAsYYYYMMDDHHmmSS &amp; ".log";
    prof.methodCount := 200;
    //prof.reportCacheStatistics := false;
	prof.clearMethodCache();
	prof.reportActualTime := true;
	prof.reportTotalTime := true;
	prof.reportLoadTime := true;
    prof.start;
	
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := terminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := terminal.getConfig(AllowAutoActionCargoWo);
	defaultProcess 		 := terminal.getConfig(DefaultVoyageProcess).String;
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	retroMode 			 := terminal.getConfig(IsRetrospectiveMode).String;
	
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, true);
	terminal.setConfig(AllowAutoActionCargoWo, true);
	terminal.setConfig(DefaultVoyageProcess,"EUP");
	terminal.setConfig(HhMoveConfirmation,true);
	terminal.setConfig(IsRetrospectiveMode,false);
	commitTransaction;
	
	autoPlanEnabled := self.setTerminalConfig(AutoPlanEnabled, false);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadUsingWS;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL1");
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	//cargoType := terminal.getCargoTypeFromDescription("Cannon Balls");
	//self.assertNotNullMsg(cargoType, "CargoType");
	
	//product := cargoType.getProductFromCode("10X6-POUND");
	//self.assertNotNullMsg(product, "product");
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBul01", cargoType);
	self.deleteCargo("UTBul02", cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul01", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBul02", cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 1000);
	self.opts.addAssoc('Carrier', carrier);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTBULKREL1", BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 1000);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1000,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in self.getMyTerminal().myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_62026");
	endif;
	
	//Allocate job to jobSheet
	create allJobArr transient;
	if realJobSheet &lt;&gt; null then
		myPxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	endif;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI1, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);	//09.09.2024 navbs1 #65777
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI2, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);	//09.09.2024 navbs1 #65777
epilog
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	terminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	terminal.setConfig(DefaultVoyageProcess,defaultProcess);
	terminal.setConfig(IsRetrospectiveMode,retroMode);
	commitTransaction;
	self.setTerminalConfig(AutoPlanEnabled, autoPlanEnabled);
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete terminalUTHelper;
	prof.stop;
	prof.report;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadWithToDoWS" id="c15d0797-a596-4a99-bf49-a8894e5bdfb9">
        <source>tRelRoadWithToDoWS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2024 navhl20 Bug 32981 EUP - Todo Tasks Job complete for Partial Receive and Release Work orders

*/

constants
	REF			: String = "32981";
	WOID 		: String = 'UT'&amp;REF&amp;'JREBTR';
	BLOCKSTACK 	: String = "BS" &amp;REF;
	Voyage		: String = "UTVoy" &amp; REF;
	TruckId 	: String = 'UTTRKHM'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	retroMode				: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	myPxyWorkPointJobSheet,
	realJobSheet			: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	hideMoveConfirmation 	: Boolean;
	job						: CM_Job;
	defaultProcess			: String;
	carrier					: CM_Carrier;
	roadJob					: CM_RoadJob;
	vehicle					: CM_Vehicle;
	vehicleName, 
	driverName				: String;
	terminalUTHelper		: UT_HelperAdmTerm;
	gate					: CM_Gate;
	vvr						: CM_VehicleVisitRecord;
	product					: CM_Product;
	autoPlanEnabled			: Any;
	releaseAmount 			: Integer;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	toDoTaskDescSet     	: CM_ToDoTaskDescBySortKey;
	todoSet					: CM_ToDoTaskDescSet;
	optionalParam			: String;
	todoJob					: CM_Job;
	wodTodo					: CM_WodToDo;
	jobOid,
	response				: String;
	matches					: JadeRegexResult;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting   := terminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := terminal.getConfig(AllowAutoActionCargoWo);
	defaultProcess 		 := terminal.getConfig(DefaultVoyageProcess).String;
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	retroMode 			 := terminal.getConfig(IsRetrospectiveMode).String;
	
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, true);
	terminal.setConfig(AllowAutoActionCargoWo, true);
	terminal.setConfig(DefaultVoyageProcess,"EUP");
	terminal.setConfig(HhMoveConfirmation,true);
	terminal.setConfig(IsRetrospectiveMode,false);
	commitTransaction;
	
	autoPlanEnabled := self.setTerminalConfig(AutoPlanEnabled, false);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelRoadUsingWS;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBULKREL" &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBul01" &amp; REF, cargoType);
	self.deleteCargo("UTBul02" &amp; REF, cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul01" &amp; REF, cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBul02" &amp; REF, cargoType, 500, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo" &amp; REF,TODO_TYPE_GROUP_TI);
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTHM" &amp; REF,
							 "UT HM Resource",
							 "MAN",
							 1,
							 false,
							 true,
							 toDoTaskDescSet
							 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	carrier := app.myRoot.allCarriers["DOUG"];
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 1000);
	self.opts.addAssoc('Carrier', carrier);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTBULKREL" &amp; REF, BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 1000);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,500,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in self.getMyTerminal().myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_" &amp; REF);
	endif;
	
	//Allocate job to jobSheet
	create allJobArr transient;
	if realJobSheet &lt;&gt; null then
		myPxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	endif;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI1, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);
	
	wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first;
	if wodTodo &lt;&gt; null then
		todoJob := wodTodo.allJobs.first;
	endif;
	if todoJob &lt;&gt; null then
		optionalParam := "?MTNInternalAPIService&amp;operationalJobOid=" &amp; roadJob.getOidAsString;
		jobOid := todoJob.getOidAsString();
		self.webServiceCallWithParams( CM_UnitTestAgent::wsGetJobDetails.name, jobOid,optionalParam,response);
		self.assertNotNullMsg(response, "No response from POST /Find/Cargo");
		self.assertEqualMsg(JadeRegex@findAll(response, '"cargoId":', false, false, matches), 1, "cargoId found in response message when not expected" &amp; CrLf &amp; response);
	endif;
epilog
	beginTransaction;
	terminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	terminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	terminal.setConfig(DefaultVoyageProcess,defaultProcess);
	terminal.setConfig(IsRetrospectiveMode,retroMode);
	commitTransaction;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete terminalUTHelper;
	delete matches;
	delete toDoTaskDescSet;
	delete todoSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelRoadWithTodo" id="4e3bdbc6-abe4-45ce-8a9d-48f82e037991">
        <source>tRelRoadWithTodo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2

*/

constants
	REF			: String  	=  "66078";
	WOID 		: String  	= 'UT'&amp;REF&amp;'JREBST1';
	BLOCKSTACK 	: String 	= "BS" &amp;REF;
	Voyage		: String 	= "UTVoy" &amp; REF;
	WPJS 		: String	= "UT" &amp; REF;
	TruckId 	: String 	= 'UTTRK1'&amp;REF;
vars
	tI1,
	tI2						: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo,
	isRetro					: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	vehicleName, 
	driverName				: String;
	terminalUTHelper		: UT_HelperAdmTerm;
	gate					: CM_Gate;
	terminal 				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	wle						: CM_WorkListEntry;
	myPxyWorkPointJobSheet	: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	hideMoveConfirmation 	: Boolean;
	tmpFoundLC				: CM_LocationsController;
	moveController			: CMIF_MoveController;
	cnt						: Integer;
	product					: CM_Product;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	toDoTaskDescSet     	: CM_ToDoTaskDescBySortKey;
	todoSet					: CM_ToDoTaskDescSet;
	wodTodo					: CM_WodToDo;
	woTodoJob				: CM_WOToDoTaskJob;
	found					: Boolean;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	isRetro   	   	   := self.getTerminalConfig(IsRetrospectiveMode);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, false);
	self.setTerminalConfig(HhMoveConfirmation,true);
	self.setTerminalConfig(IsRetrospectiveMode, true);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tCargoJobReleaseRoadByType;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTREL"&amp;REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBulk01" &amp; REF, cargoType);
	self.deleteCargo("UTBulk02" &amp; REF, cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBulk01" &amp; REF, cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBulk02" &amp; REF, cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	self.purgeStops(tI1);
	self.purgeStops(tI2);
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo" &amp; REF,TODO_TYPE_GROUP_TI);
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTHM" &amp; REF,
							 "UT HM Resource",
							 "MAN",
							 1,
							 false,
							 true,
							 toDoTaskDescSet
							 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	terminalUTHelper.opts.purge();
	terminalUTHelper.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-10));
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Create the Release
	self.opts.purge();
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 2);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTREL" &amp; REF, BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,2,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.first;
	
	self.assertEqualMsg(wle.job.isRetrospective,true,"Job is should retrospective job");
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();

	// create the move controller
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI1);
	moveController.setQuantity(1);
	moveController.retrospectiveDT := app.actualTimeServer().addDays(-9);
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first;
	
	if wodTodo &lt;&gt; null then
		woTodoJob := wodTodo.allJobs.first.CM_WOToDoTaskJob;
	endif;
	
	found := false;
	if woTodoJob &lt;&gt; null then
		foreach wle in woTodoJob.workListEntries do
			if wle.myTrackedItem = tI1 then
				found := true;
			endif;
		endforeach;
	endif;
	
	self.assertEqualMsg(found, true, "The tracked item " &amp; tI1.id &amp; " not assigned to todo job work list entry");
	
	create tiSet transient;
	tiSet.add(tI1);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	self.assertEqualMsg(wodTodo.status, WO_STATUS_PARTCOMPLETE, "The to do work order detail has not been part completed");
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.last;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();
	
	// create the move controller
	delete moveController;
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI2);
	moveController.setQuantity(1);
	moveController.retrospectiveDT := app.actualTimeServer().addDays(-9);
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	found := false;
	if woTodoJob &lt;&gt; null then
		foreach wle in woTodoJob.workListEntries do
			if wle.myTrackedItem = tI2 then
				found := true;
			endif;
		endforeach;
	endif;
	
	self.assertEqualMsg(found, true, "The tracked item " &amp; tI2.id &amp; " not assigned to todo job work list entry");
	
	delete tiSet;
	create tiSet transient;
	tiSet.add(tI2);
	self.completeToDoTask(toDoTaskDesc,tiSet,null);
	
	self.assertEqualMsg(wodTodo.status, WO_STATUS_PARTCOMPLETE, "The to do work order detail has not been part completed");
	
	self.xCheckWorkOrder(wod,WO_STATUS_COMPLETE,2,TRANS_TYPE_WO_TIREC_COMPLET,true,false);
	
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-8));
	self.roadExit(vvr);
	self.assertEqualMsg(vvr.timeOut.Date,app.actualTimeServer().addDays(-8).Date,"Retrospective Date not updated correctly");
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	self.setTerminalConfig(HhMoveConfirmation,hideMoveConfirmation);
	self.setTerminalConfig(IsRetrospectiveMode, isRetro);
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete terminalUTHelper;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete truckUnLoaderController;
	delete moveController;
	delete todoSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelShipUsingWS" id="0434c089-97b8-4c0d-9c85-cfc165628fa6">
        <source>tRelShipUsingWS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
18 Apr 2024	navpw1	Fixed unit test now uses "Steel Coil" instead of "Cannon Balls" - Causes issues leading to 1018 exception with yard allocations

*/

constants
	REF		: String  = '58401';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	Voyage	: String  = "UTHMVOY"&amp;REF;
vars
	voyage 					: 	CM_Voyage;
	bol, realBol 			:	CM_BOL;
	tI1, tI2,tI3,tI4,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	myPxyWorkPointJobSheet,
	realJobSheet			:	CM_WorkPointJobSheet;
	allJobArr				: 	CM_JobSet;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	groMethod				: 	CM_WorkOrderJobGroupMethod;
	firstJob,
	secondJob,
	voyJob1,
	voyJob2					: 	CM_Job;
	blockStack				:	CM_BlockStack;
	cargoType				: 	CM_CargoType;
	location				: 	CM_LocationsController;
	mode					: 	Integer;
	defaultProcess			: 	String;
	hideMoveConfirmation	: 	Any;
	stop					:	CM_StopsTable;
	product					: CM_Product;
	
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting  := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo 	 := term.getConfig(AllowAutoActionCargoWo);
	defaultProcess 		 := term.getConfig(DefaultVoyageProcess).String;
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	term.setConfig(DefaultVoyageProcess,"EUP");
	term.setConfig(HhMoveConfirmation,true);           //05.1.2024 navma1 
	commitTransaction;
	
	self.deleteTerminalArea("BS1711");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS1711", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realBol := voyage.getBOL("UTBOLLWVOY");
	bol := self.xAddBOL("UTBOLLWVOY",realBol,voyage,operator,term);
	self.assertNotNull(bol);
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := term.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBul001", cargoType);
	self.deleteCargo("UTBul002", cargoType);
	self.deleteCargo("UTBul003", cargoType);
	self.deleteCargo("UTBul004", cargoType);
	
	if voyage.myGeneralCargoVoyage &lt;&gt; null then
		location := voyage.myGeneralCargoVoyage.allLocationsByOrdinal.first;
	endif;
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul001", cargoType, 100, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBul002", cargoType, 100, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
	tI3 := self.addCargoBreakBulkAtLocation("UTBul003", cargoType, 100, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
	tI4 := self.addCargoBreakBulkAtLocation("UTBul004", cargoType, 100, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI1.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI3.setSpecialStow("STOW1");
		tI3.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI2.setSpecialStow("STOW2");
		tI2.changeState(TI_STATE_ONSHIP,app.myPassport);
		tI4.setSpecialStow("STOW2");
		tI4.changeState(TI_STATE_ONSHIP,app.myPassport);
	commitTransaction;
	
	stop := app.myRoot.allStopsTable[2];
	self.clearStopWithExpiry(tI1,stop,"test",app.actualTimeServer().addDays(2).date);
	self.clearStopWithExpiry(tI2,stop,"test",app.actualTimeServer().addDays(2).date);
	self.clearStopWithExpiry(tI3,stop,"test",app.actualTimeServer().addDays(2).date);
	self.clearStopWithExpiry(tI4,stop,"test",app.actualTimeServer().addDays(2).date);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType', WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	
	// Create the work order detail
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	groMethod := term.allWOJobGroupMethods["UTHM60063",term];
	
	self.xApproveWorkOrder(workOrder);
	
	self.opts.purge();
	self.opts.addAssoc('GrpMethod', groMethod);
	self.xActionWorkOrder(workOrder);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_58401");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addMonths(1),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.size,1);
	
	delete pxyVoyJob;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addMonths(1),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,secondJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(secondJob.CM_WOReleaseCargoJob.allVoyageJobs.size,1);
	
	//Complete tracked items discharge
	voyJob1 := firstJob.CM_WOReleaseCargoJob.allVoyageJobs.first;
	voyJob2	:= secondJob.CM_WOReleaseCargoJob.allVoyageJobs.first;
	mode := JOB_TYPE_LOAD;
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob1, tI1, location);
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob2, tI2, location);
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob1, tI3, location);
	self.webServiceCallWithParams( CM_UnitTestAgent::wsLanderComplete.name, mode, voyage, voyJob2, tI4, location);
	
	self.assertEqual(workOrder.taskStatus,WO_STATUS_COMPLETE);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	term.setConfig(DefaultVoyageProcess,defaultProcess);
	term.setConfig(HhMoveConfirmation,hideMoveConfirmation);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete allJobArr;
	delete myPxyWorkPointJobSheet;
	delete pxyVoyJob;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRailToRoad" id="d1ad3af2-b56e-40f1-b3cb-50a795f129ea">
        <source>tRelTransChangeRailToRoad();
/*

Purpose:			Release from Rail &gt; Road By Id

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2024	navpw1	Initial creation TFS: 59411 (61868)

*/

constants
	REF								: String = "61868";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1						: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2						: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3						: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4						: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5						: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6						: String = "UT" &amp; REF &amp; "-6";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "TR";
	UT_BlockStack					: String = REF &amp; "1";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_ReleaseRequest2				: String = "UT_" &amp; REF &amp; "REL2";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	//toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	train				: CM_Train;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	isExact				: Boolean;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	self.deleteTerminalArea(UT_BlockStack);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Train, train);
	
	//Turn the below code into a loop for less code and easier understanding
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalRequested, 1);
	
	releaseRequest := self.addReleaseById(UT_ReleaseRequest, BR_TYPE_RAIL, tiSet); // Create a release request/bulk release. Release by Id
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', train.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 6, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 6, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_ROAD_STR, UT_ReleaseRequest2, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release request
	
	
	//Verify Booking
	releaseRequest := terminal.getBulkReleaseFromCode(UT_ReleaseRequest2);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertTrueMsg(releaseRequest.code = UT_ReleaseRequest2, "Release Request not found for code: '" &amp; UT_ReleaseRequest2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.first.code = UT_ReleaseRequest, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest &amp; "' | Actual '" &amp; tI1.allBulkReleasesAssigned.first.code &amp; "'");
	self.assertTrueMsg(tI1.allReserveDetails.first.doesTIMatchForRelease(tI1, isExact), "Verify Tracked item: '" &amp; tI1.id &amp; "' TI Does not match reserve ti");
	
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.first.code = UT_ReleaseRequest, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest &amp; "' | Actual '" &amp; tI2.allBulkReleasesAssigned.first.code &amp; "'");
	self.assertTrueMsg(tI2.allReserveDetails.first.doesTIMatchForRelease(tI2, isExact), "Verify Tracked item: '" &amp; tI2.id &amp; "' TI Does not match reserve ti");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertTrueMsg(ti.allBulkReleasesAssigned.first.code = UT_ReleaseRequest2, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest2 &amp; "' | Actual '" &amp; ti.allBulkReleasesAssigned.first.code &amp; "'");
		self.assertTrueMsg(ti.allReserveDetails.first.doesTIMatchForRelease(ti, isExact), "Verify Tracked item: '" &amp; ti.id &amp; "' TI Does not match reserve ti");
		
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete tiSet;
	//delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRailToRoad2" id="5f47095c-60fd-4c6f-b287-44753dace47e">
        <source>tRelTransChangeRailToRoad2();
/*

Purpose:			Release from Rail &gt; Road By Type

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2024	navpw1	Initial creation TFS: 59411 (61868)

*/

constants
	REF								: String = "61868";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_ReleaseNumber1				: String = "UT_" &amp; REF &amp; "-2REL1";
	UT_ReleaseNumber2				: String = "UT_" &amp; REF &amp; "-2REL2";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "ROLLS";
	UT_TotalRequested				: Integer = 10;
	UT_QuantityToSplit				: Integer = 5;
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "2T";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	train				: CM_Train;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeRailToRoad2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(UT_ReleaseNumber2, null);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_RAIL, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', train.code);	
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_ROAD_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Release request
	
	
	//Verify New Releasse Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRailToShip" id="24515aef-17ba-4400-adb7-4f3a47076872">
        <source>tRelTransChangeRailToShip();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2024	navpw1	Initial creation TFS: 59411 (61865)

*/

constants
	REF								: String = "61865";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1						: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2						: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3						: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4						: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5						: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6						: String = "UT" &amp; REF &amp; "-6";
	UT_BookingNumber				: String = "UT_" &amp; REF &amp; "BOOK";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "TR";
	UT_BlockStack					: String = REF &amp; "1";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	//toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	booking				: CM_BookingRef;
	train				: CM_Train;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	isExact				: Boolean;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteTerminalArea(UT_BlockStack);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Train, train);
	
	//Turn the below code into a loop for less code and easier understanding
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalRequested, 1);
	
	releaseRequest := self.addReleaseById(UT_ReleaseRequest, BR_TYPE_RAIL, tiSet); // Create a release request/bulk release. Release by Id
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', train.code);
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 6, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 6, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Delete Booking
	self.deleteBooking(UT_BookingNumber);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_SHIP_STR, UT_BookingNumber, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release request
	
	
	//Verify Booking
	booking := terminal.allBookingRefsByRef[UT_BookingNumber];
	self.assertNotNullMsg(booking, "booking");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.first.code = UT_ReleaseRequest, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest &amp; "' | Actual '" &amp; tI1.allBulkReleasesAssigned.first.code &amp; "'");
	self.assertTrueMsg(tI1.allReserveDetails.first.doesTIMatchForRelease(tI1, isExact), "Verify Tracked item: '" &amp; tI1.id &amp; "' TI Does not match reserve ti");
	self.assertNullMsg(tI1.myBookingRef, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRef");
	self.assertNullMsg(tI1.myBookingRefItem, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRefItem");
	
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.first.code = UT_ReleaseRequest, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest &amp; "' | Actual '" &amp; tI2.allBulkReleasesAssigned.first.code &amp; "'");
	self.assertTrueMsg(tI2.allReserveDetails.first.doesTIMatchForRelease(tI2, isExact), "Verify Tracked item: '" &amp; tI2.id &amp; "' TI Does not match reserve ti");
	self.assertNullMsg(tI2.myBookingRef, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRef");
	self.assertNullMsg(tI2.myBookingRefItem, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRefItem");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertNotNullMsg(ti.myBookingRef, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRef");
		self.assertTrueMsg(ti.myBookingRef = booking, "Verify Tracked item: '" &amp; ti.id &amp; "' Booking Ref Expected: '" &amp; UT_BookingNumber &amp; "' | Actual: '" &amp; ti.myBookingRef.bookingReference &amp; "'");
		self.assertNotNullMsg(ti.myBookingRefItem, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRefItem");
		self.assertTrueMsg(ti.myBookingRefItem.doesTIMatchMe(ti, false), "Verify Tracked item: '" &amp; ti.id &amp; "' TI Does not match booking ref item");
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
		
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete tiSet;
	//delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRailToShip2" id="87ada90a-bb45-4cc3-b711-f42dae92a60c">
        <source>tRelTransChangeRailToShip2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2024	navpw1	Initial creation TFS: 59411 (61865)

*/

constants
	REF								: String = "61865";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_ReleaseNumber1				: String = "UT_" &amp; REF &amp; "-2REL1";
	UT_ReleaseNumber2				: String = "UT_" &amp; REF &amp; "-2REL2";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "ROLLS";
	UT_TotalRequested				: Integer = 10;
	UT_QuantityToSplit				: Integer = 5;
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "2T";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	train				: CM_Train;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeRailToShip2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_RAIL, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_RAIL);
	self.opts.addAssoc('transObj', train.code);	
	self.opts.addAssoc('dtArrived', train.scheduledArrivalDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_SHIP_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Release request
	
	
	//Verify New Releasse Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRoadToRail" id="154f14f5-ad8a-488f-932b-a5687f1e5110">
        <source>tRelTransChangeRoadToRail();
/*

Purpose:			Release from Road &gt; Rail By Id

Parameters:			

Return Value:		

Date				Who		Reason
13 February 2024	navpw1	Initial creation TFS: 59411 (61867)

*/

constants
	REF								: String = "61867";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1						: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2						: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3						: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4						: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5						: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6						: String = "UT" &amp; REF &amp; "-6";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "TR";
	UT_BlockStack					: String = REF &amp; "1";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_ReleaseRequest2				: String = "UT_" &amp; REF &amp; "REL2";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	//toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	train				: CM_Train;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	isExact				: Boolean;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	self.deleteTerminalArea(UT_BlockStack);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_Train, train);
	
	//Turn the below code into a loop for less code and easier understanding
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalRequested, 1);
	
	releaseRequest := self.addReleaseById(UT_ReleaseRequest, BR_TYPE_ROAD, tiSet); // Create a release request/bulk release. Release by Id
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,6,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,6,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, train, TI_TRANSMODE_RAIL_STR, UT_ReleaseRequest2, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release request
	
	
	//Verify Booking
	releaseRequest := terminal.getBulkReleaseFromCode(UT_ReleaseRequest2);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertTrueMsg(releaseRequest.code = UT_ReleaseRequest2, "Release Request not found for code: '" &amp; UT_ReleaseRequest2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.first.code = UT_ReleaseRequest, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest &amp; "' | Actual '" &amp; tI1.allBulkReleasesAssigned.first.code &amp; "'");
	self.assertTrueMsg(tI1.allReserveDetails.first.doesTIMatchForRelease(tI1, isExact), "Verify Tracked item: '" &amp; tI1.id &amp; "' TI Does not match reserve ti");
	
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.first.code = UT_ReleaseRequest, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest &amp; "' | Actual '" &amp; tI2.allBulkReleasesAssigned.first.code &amp; "'");
	self.assertTrueMsg(tI2.allReserveDetails.first.doesTIMatchForRelease(tI2, isExact), "Verify Tracked item: '" &amp; tI2.id &amp; "' TI Does not match reserve ti");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertTrueMsg(ti.allBulkReleasesAssigned.first.code = UT_ReleaseRequest2, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: '" &amp; UT_ReleaseRequest2 &amp; "' | Actual '" &amp; ti.allBulkReleasesAssigned.first.code &amp; "'");
		self.assertTrueMsg(ti.allReserveDetails.first.doesTIMatchForRelease(ti, isExact), "Verify Tracked item: '" &amp; ti.id &amp; "' TI Does not match reserve ti");
		
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete tiSet;
	//delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRoadToRail2" id="9eecb3e1-dd98-4a42-b33d-e515876bbb59">
        <source>tRelTransChangeRoadToRail2();
/*

Purpose:			Release from Road &gt; Rail By Type

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2024	navpw1	Initial creation TFS: 59411 (61867)

*/

constants
	REF								: String = "61867";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_ReleaseNumber1				: String = "UT_" &amp; REF &amp; "-2REL1";
	UT_ReleaseNumber2				: String = "UT_" &amp; REF &amp; "-2REL2";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "ROLLS";
	UT_TotalRequested				: Integer = 10;
	UT_QuantityToSplit				: Integer = 5;
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "1T";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	train				: CM_Train;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeRoadToRail2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(UT_ReleaseNumber2, null);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, train, TI_TRANSMODE_RAIL_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Release request
	
	
	//Verify New Releasse Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeRoadToShip" id="ae5c87e3-4831-452f-aa1b-7afd5f466296">
        <updating/>
        <source>tRelTransChangeRoadToShip() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 January 2024	navpw1	Initial creation TFS: 59411 (61855)

*/

constants
	REF								: String = "59411";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1						: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2						: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3						: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4						: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5						: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6						: String = "UT" &amp; REF &amp; "-6";
	UT_BookingNumber				: String = "UT_" &amp; REF &amp; "BOOK";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_BlockStack					: String = REF &amp; "1";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	booking				: CM_BookingRef;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	//self.deleteBooking(UT_BookingNumber);
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteTerminalArea(UT_BlockStack);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	//Turn the below code into a loop for less code and easier understanding
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_IMPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalRequested, 1);
	
	releaseRequest := self.addReleaseById(UT_ReleaseRequest, BR_TYPE_ROAD, tiSet); // Create a release request/bulk release. Release by Id
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	create todoSet transient;
	todoSet.add(toDoTaskDesc);

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);								//28.06.2023 navma1 #58920
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,todoSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,6,TRANS_TYPE_WO_TIREC_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,6,TRANS_TYPE_WO_TIREC_UPDATED,true,false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Delete Booking
	self.deleteBooking(UT_BookingNumber);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_SHIP_STR, UT_BookingNumber, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release request
	
	
	//Verify Booking
	booking := terminal.allBookingRefsByRef[UT_BookingNumber];
	self.assertNotNullMsg(booking, "booking");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI1.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertNullMsg(tI1.myBookingRef, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRef");
	self.assertNullMsg(tI1.myBookingRefItem, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRefItem");
	
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertTrueMsg(tI2.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
	self.assertNullMsg(tI2.myBookingRef, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRef");
	self.assertNullMsg(tI2.myBookingRefItem, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRefItem");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertNotNullMsg(ti.myBookingRef, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRef");
		self.assertTrueMsg(ti.myBookingRef = booking, "Verify Tracked item: '" &amp; ti.id &amp; "' Booking Ref Expected: '" &amp; UT_BookingNumber &amp; "' | Actual: '" &amp; ti.myBookingRef.bookingReference &amp; "'");
		self.assertNotNullMsg(ti.myBookingRefItem, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRefItem");
		self.assertTrueMsg(ti.myBookingRefItem.doesTIMatchMe(ti, false), "Verify Tracked item: '" &amp; ti.id &amp; "' TI Does not match booking ref item");
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
		
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete tiSet;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeShipToRail" id="061bfe85-fd73-46df-8492-3bab04731dcd">
        <source>tRelTransChangeShipToRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2024	navpw1	Initial creation TFS: 59411 (61866)

*/

constants
	REF								: String = "61866";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1						: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2						: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3						: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4						: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5						: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6						: String = "UT" &amp; REF &amp; "-6";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY1";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "V1";
	UT_BlockStack					: String = REF &amp; "1";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_ReleaseRequest2				: String = "UT_" &amp; REF &amp; "REL2";
	UT_ExportBooking				: String = "UT_" &amp; REF &amp; "BOOK";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "T1";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	//toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	exportBooking,
	pxyBooking			: CM_BookingRef;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	isExact				: Boolean;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyTiHazardsArr		: CM_TIHazardByCodeDict;
	pxyHazardsArr		: CM_HazardByCodeDict;
	train				: CM_Train;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeShipToRail;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	self.deleteTerminalArea(UT_BlockStack);
	self.deleteBooking(UT_ExportBooking);
	self.deleteTrain(UT_TrainCode, null);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_EXPORT);
	
	//Turn the below code into a loop for less code and easier understanding
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalRequested, 1);
	
	//Setup Booking
	create pxyTiHazardsArr transient;
	pxyBooking := terminalUTHelper.xSetupBooking(UT_ExportBooking, null, operator, voyage, null, null, null, null,
													null, null, null, null, null, null, 
													"FCL", null, null, null, null, null, null, null, pxyTiHazardsArr);
	
	//Setup Booking Items
	//create pxyBookingItems transient;
	//ISO Container
	create pxyHazardsArr transient;
	foreach ti in tiSet do
		terminalUTHelper.xSetupBookingItem(pxyBooking, ti.id, ti.myCargoType.abbreviation, ti.myProduct.code, null, null, ti.myOperator.code, pxyHazardsArr, null, ti.commodity, null,
											null, null, null, null, null, null,  null, null, null, null, null, null, null, null, null, NULL_TEMPERATURE,
											null, null, null, null, null, ti.weight, null, null, 1, CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
	endforeach;
	
	//Create Booking
	exportBooking := terminalUTHelper.xCreateBooking(pxyBooking);
	self.assertNotNullMsg(exportBooking, "exportBooking");
	
	beginTransaction;
	foreach ti in tiSet do
		ti.setPropertyValue(CM_TrackedItem::myBookingRef.name, exportBooking);
		ti.setPropertyValue(CM_TrackedItem::myBookingRefItem.name, exportBooking.allBookingRefItems.first);
		ti.setPropertyValue(CM_TrackedItem::bookingReference.name, exportBooking.bookingReference);
		ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyage);
		//ti.setPropertyValue(CM_TrackedItem::vesselCode.name, vessel.code);
		//ti.setPropertyValue(CM_TrackedItem::vesselName.name, vessel.name);
		ti.setPropertyValue(CM_TrackedItem::voyageCode.name, voyage.code);
	endforeach;
	commitTransaction;
	
	//Verify Release request
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc(UT_OPTS_Booking, UT_ExportBooking);
	//self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, tiSet, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 6, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 6, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, train, TI_TRANSMODE_RAIL_STR, UT_ReleaseRequest2, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release Request
	releaseRequest := terminal.getBulkReleaseFromCode(UT_ReleaseRequest2);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertTrueMsg(releaseRequest.code = UT_ReleaseRequest2, "Release Request not found for code: '" &amp; UT_ReleaseRequest2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertNotNullMsg(tI1.myBookingRef, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRef");
	self.assertTrueMsg(tI1.myBookingRef = exportBooking, "Verify Tracked item: '" &amp; tI1.id &amp; "' Booking Ref Expected: '" &amp; UT_ExportBooking &amp; "' | Actual: '" &amp; tI1.myBookingRef.bookingReference &amp; "'");
	self.assertNotNullMsg(tI1.myBookingRefItem, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRefItem");
	self.assertTrueMsg(tI1.myBookingRefItem.doesTIMatchMe(tI1, false), "Verify Tracked item: '" &amp; tI1.id &amp; "' TI Does not match booking ref item");
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI1.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI1.getImExStatus = TI_IMEX_STATUS_EXPORT, "Verify Tracked item: '" &amp; tI1.id &amp; "' IMEX Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(tI1.getImExStatus) &amp; "'");
	
	self.assertNotNullMsg(tI2.myBookingRef, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRef");
	self.assertTrueMsg(tI2.myBookingRef = exportBooking, "Verify Tracked item: '" &amp; tI2.id &amp; "' Booking Ref Expected: '" &amp; UT_ExportBooking &amp; "' | Actual: '" &amp; tI2.myBookingRef.bookingReference &amp; "'");
	self.assertNotNullMsg(tI2.myBookingRefItem, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRefItem");
	self.assertTrueMsg(tI2.myBookingRefItem.doesTIMatchMe(tI2, false), "Verify Tracked item: '" &amp; tI2.id &amp; "' TI Does not match booking ref item");
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI2.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI2.getImExStatus = TI_IMEX_STATUS_EXPORT, "Verify Tracked item: '" &amp; tI2.id &amp; "' IMEX Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(tI2.getImExStatus) &amp; "'");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertNullMsg(ti.myBookingRef, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRef");
		self.assertNullMsg(ti.myBookingRefItem, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRefItem");
		self.assertTrueMsg(ti.getImExStatus = TI_IMEX_STATUS_IMPORT, "Verify Tracked item: '" &amp; ti.id &amp; "' IMEX Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(ti.getImExStatus) &amp; "'");
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete tiSet;
	//delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	delete pxyTiHazardsArr;
	delete pxyHazardsArr;
	delete pxyBooking;
	delete terminalUTHelper;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeShipToRail2" id="8da964ac-74e3-4fcd-9888-ad9c91c38d5f">
        <source>tRelTransChangeShipToRail2();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2024	navpw1	Initial creation TFS: 59411 (61866)

*/

constants
	REF								: String = "61866";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo						: String = "UT" &amp; REF &amp; "-";
	UT_ReleaseNumber1				: String = "UT_" &amp; REF &amp; "-2REL1";
	UT_ReleaseNumber2				: String = "UT_" &amp; REF &amp; "-2REL2";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY2";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "V2";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "ROLLS";
	UT_TotalRequested				: Integer = 10;
	UT_QuantityToSplit				: Integer = 5;
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "T2";
	UT_BlockStack					: String = REF &amp; "1";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	ti					: CM_TrackedItem;
	tiSet				: CM_TISet;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	train				: CM_Train;
	blockStack			: CM_BlockStack;
	loopVar				: Integer;
	cg					: CM_CargoGroup;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeShipToRail2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	foreach loopVar in 1 to 10 do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; loopVar.String), false);
	endforeach;
	
	self.deleteCargoGroup(WOID);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	self.deleteTrain(UT_TrainCode, null);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_EXPORT);
	
	//Add cargo on site
	create tiSet transient;
	foreach loopVar in 1 to 10 do
		ti := self.addCargoAtLocation(UT_Cargo &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti");
		beginTransaction;
		ti.setVoyageCode(UT_VoyageCode, app.myPassport);
		commitTransaction;
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT)).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus())));
		self.assertEqualMsg(ti.voyageCode, UT_VoyageCode, "Voyage codes do not match");
		tiSet.add(ti);
	endforeach;
	
	cg := self.addCargoGroup(WOID, tiSet);
	
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc("CargoType", cargoType);
	terminalUTHelper.opts.addAssoc(UT_OPTS_Voyage, voyage);
	terminalUTHelper.opts.addAssoc("Product", product);
	terminalUTHelper.opts.addAssoc(UT_OPTS_CargoGroup, cg);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_SHIP, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");	
	
	//Verify Release request
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID,WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, train, TI_TRANSMODE_RAIL_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Release request
	releaseRequest := terminal.getBulkReleaseFromCode(UT_ReleaseNumber1);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertTrueMsg(releaseRequest.code = UT_ReleaseNumber1, "Release Request not found for code: '" &amp; UT_ReleaseNumber1 &amp; "'");
	self.assertNotNullMsg(releaseRequest.myVoyage, "releaseRequest.myVoyage");
	self.assertTrueMsg(releaseRequest.myVoyage.code = UT_VoyageCode, "Release Request voyage code Expected: '" &amp; UT_VoyageCode &amp; "' | Actual: '" &amp; releaseRequest.myVoyage.code &amp; "'");
	
	//Verify New Release Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeShipToRoad" id="5238c13a-fbb1-4a5d-9872-f446d376a370">
        <source>tRelTransChangeShipToRoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2024	navpw1	Initial creation TFS: 59411 (61864)

*/

constants
	REF								: String = "61864";
	WOID							: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo1						: String = "UT" &amp; REF &amp; "-1";
	UT_Cargo2						: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo3						: String = "UT" &amp; REF &amp; "-3";
	UT_Cargo4						: String = "UT" &amp; REF &amp; "-4";
	UT_Cargo5						: String = "UT" &amp; REF &amp; "-5";
	UT_Cargo6						: String = "UT" &amp; REF &amp; "-6";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY1";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "V1";
	UT_BlockStack					: String = REF &amp; "1";
	UT_ReleaseRequest				: String = "UT_" &amp; REF &amp; "REL";
	UT_ReleaseRequest2				: String = "UT_" &amp; REF &amp; "REL2";
	UT_ExportBooking				: String = "UT_" &amp; REF &amp; "BOOK";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "GVS";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	tI1, tI2, tI3,
	tI4, tI5, tI6		: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	//toDoTaskDesc		: CM_ToDoTaskDesc;
	tiSet				: CM_TISet;
	//toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	objArr				: ObjectArray;
	blockStack			: CM_BlockStack;
	releaseRequest		: CM_BulkRelease;
	exportBooking,
	pxyBooking			: CM_BookingRef;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	isExact				: Boolean;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyTiHazardsArr		: CM_TIHazardByCodeDict;
	pxyHazardsArr		: CM_HazardByCodeDict;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeShipToRoad;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	tI6 := self.getTrackedItem(UT_Cargo6);
	
	if tI6 &lt;&gt; null and tI6.allWorkOrders.first &lt;&gt; null then
		self.deleteWorkOrderNoValidation(tI6.allWorkOrders.first.id);
	endif;
	
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo1), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo2), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo3), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo4), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo5), false);
	self.deleteTrackedItem(self.getTrackedItem(UT_Cargo6), false);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	self.deleteTerminalArea(UT_BlockStack);
	self.deleteBooking(UT_ExportBooking);
	
	terminal := self.getMyTerminal();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(operator.code, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_EXPORT);
	
	//Turn the below code into a loop for less code and easier understanding
	tI1 := self.addCargoAtLocation(UT_Cargo1, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI1, "tI1");
	self.assertTrueMsg(tI1.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI1.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI2 := self.addCargoAtLocation(UT_Cargo2, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI2, "tI2");
	self.assertTrueMsg(tI2.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI2.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI3 := self.addCargoAtLocation(UT_Cargo3, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI3, "tI3");
	self.assertTrueMsg(tI3.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI3.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI4 := self.addCargoAtLocation(UT_Cargo4, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI4, "tI4");
	self.assertTrueMsg(tI4.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI4.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI5 := self.addCargoAtLocation(UT_Cargo5, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI5, "tI5");
	self.assertTrueMsg(tI5.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI5.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	tI6 := self.addCargoAtLocation(UT_Cargo6, cargoType, operator, blockStack.myLocationsController);
	self.assertNotNullMsg(tI6, "tI6");
	self.assertTrueMsg(tI6.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, tI6.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT).replace(Param3, app.imexStatusEnumToString(tI1.getImExStatus()))));
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	tiSet.add(tI3);
	tiSet.add(tI4);
	tiSet.add(tI5);
	tiSet.add(tI6);
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalRequested, 1);
	
	//Setup Booking
	create pxyTiHazardsArr transient;
	pxyBooking := terminalUTHelper.xSetupBooking(UT_ExportBooking, null, operator, voyage, null, null, null, null,
													null, null, null, null, null, null, 
													"FCL", null, null, null, null, null, null, null, pxyTiHazardsArr);
	
	//Setup Booking Items
	//create pxyBookingItems transient;
	//ISO Container
	create pxyHazardsArr transient;
	foreach ti in tiSet do
		terminalUTHelper.xSetupBookingItem(pxyBooking, ti.id, ti.myCargoType.abbreviation, ti.myProduct.code, null, null, ti.myOperator.code, pxyHazardsArr, null, ti.commodity, null,
											null, null, null, null, null, null,  null, null, null, null, null, null, null, null, null, NULL_TEMPERATURE,
											null, null, null, null, null, ti.weight, null, null, 1, CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
	endforeach;
	
	//Create Booking
	exportBooking := terminalUTHelper.xCreateBooking(pxyBooking);
	self.assertNotNullMsg(exportBooking, "exportBooking");
	
	beginTransaction;
	foreach ti in tiSet do
		ti.setPropertyValue(CM_TrackedItem::myBookingRef.name, exportBooking);
		ti.setPropertyValue(CM_TrackedItem::myBookingRefItem.name, exportBooking.allBookingRefItems.first);
		ti.setPropertyValue(CM_TrackedItem::bookingReference.name, exportBooking.bookingReference);
		ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyage);
		//ti.setPropertyValue(CM_TrackedItem::vesselCode.name, vessel.code);
		//ti.setPropertyValue(CM_TrackedItem::vesselName.name, vessel.name);
		ti.setPropertyValue(CM_TrackedItem::voyageCode.name, voyage.code);
	endforeach;
	commitTransaction;
	
	//Verify Release request
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', UT_Cargo1 &amp; "," &amp; UT_Cargo2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc(UT_OPTS_Booking, UT_ExportBooking);
	//self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, tiSet, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID, WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 6, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 6, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Create a object array to hold our ti4 so we can change transport mode on it
	create objArr transient;
	objArr.add(tI3);
	objArr.add(tI4);
	objArr.add(tI5);
	objArr.add(tI6);
	
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_ROAD_STR, UT_ReleaseRequest2, objArr, terminal, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(tI6.allWorkOrders.first, "tI6.allWorkOrders.first");
	
	//Verify Release Request
	releaseRequest := terminal.getBulkReleaseFromCode(UT_ReleaseRequest2);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertTrueMsg(releaseRequest.code = UT_ReleaseRequest2, "Release Request not found for code: '" &amp; UT_ReleaseRequest2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 2, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(tI6.allWorkOrders.first.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := tI6.allWorkOrders.first.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Tracked items
	self.assertNotNullMsg(tI1.myBookingRef, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRef");
	self.assertTrueMsg(tI1.myBookingRef = exportBooking, "Verify Tracked item: '" &amp; tI1.id &amp; "' Booking Ref Expected: '" &amp; UT_ExportBooking &amp; "' | Actual: '" &amp; tI1.myBookingRef.bookingReference &amp; "'");
	self.assertNotNullMsg(tI1.myBookingRefItem, "Verify Tracked item: '" &amp; tI1.id &amp; "' myBookingRefItem");
	self.assertTrueMsg(tI1.myBookingRefItem.doesTIMatchMe(tI1, false), "Verify Tracked item: '" &amp; tI1.id &amp; "' TI Does not match booking ref item");
	self.assertTrueMsg(tI1.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI1.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; tI1.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI1.getImExStatus = TI_IMEX_STATUS_EXPORT, "Verify Tracked item: '" &amp; tI1.id &amp; "' IMEX Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(tI1.getImExStatus) &amp; "'");
	
	self.assertNotNullMsg(tI2.myBookingRef, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRef");
	self.assertTrueMsg(tI2.myBookingRef = exportBooking, "Verify Tracked item: '" &amp; tI2.id &amp; "' Booking Ref Expected: '" &amp; UT_ExportBooking &amp; "' | Actual: '" &amp; tI2.myBookingRef.bookingReference &amp; "'");
	self.assertNotNullMsg(tI2.myBookingRefItem, "Verify Tracked item: '" &amp; tI2.id &amp; "' myBookingRefItem");
	self.assertTrueMsg(tI2.myBookingRefItem.doesTIMatchMe(tI2, false), "Verify Tracked item: '" &amp; tI2.id &amp; "' TI Does not match booking ref item");
	self.assertTrueMsg(tI2.allBulkReleasesAssigned.isEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Bulk Releases Assigned Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI2.allReserveDetails.isEmpty, "Verify Tracked item: '" &amp; tI2.id &amp; "' Reserve Details Expected: 'Empty' | Actual: 'Not Empty'");
	self.assertTrueMsg(tI2.getImExStatus = TI_IMEX_STATUS_EXPORT, "Verify Tracked item: '" &amp; tI2.id &amp; "' IMEX Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(tI2.getImExStatus) &amp; "'");
	
	foreach ti in objArr as CM_TrackedItem do
		self.assertTrueMsg(ti.allBulkReleasesAssigned.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Bulk Releases Assigned Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertTrueMsg(ti.allReserveDetails.isNotEmpty, "Verify Tracked item: '" &amp; ti.id &amp; "' Reserve Details Expected: 'Not Empty' | Actual: 'Empty'");
		self.assertNullMsg(ti.myBookingRef, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRef");
		self.assertNullMsg(ti.myBookingRefItem, "Verify Tracked item: '" &amp; ti.id &amp; "' myBookingRefItem");
		self.assertTrueMsg(ti.getImExStatus = TI_IMEX_STATUS_IMPORT, "Verify Tracked item: '" &amp; ti.id &amp; "' IMEX Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_IMPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(ti.getImExStatus) &amp; "'");
	endforeach;
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete tiSet;
	//delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	delete pxyTiHazardsArr;
	delete pxyHazardsArr;
	delete pxyBooking;
	delete terminalUTHelper;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransChangeShipToRoad2" id="1461de4e-a1c7-4ac0-acd8-7872b3f5db90">
        <source>tRelTransChangeShipToRoad2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2024	navpw1	Initial creation TFS: 59411 (61864)

*/

constants
	REF								: String = "61864";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_Cargo						: String = "UT" &amp; REF &amp; "-";
	UT_ReleaseNumber1				: String = "UT_" &amp; REF &amp; "-2REL1";
	UT_ReleaseNumber2				: String = "UT_" &amp; REF &amp; "-2REL2";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY2";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "V2";
	UT_CargoTypeAbbr				: String = "STEEL COIL";
	UT_ProductCode					: String = "ROLLS";
	UT_TotalRequested				: Integer = 10;
	UT_QuantityToSplit				: Integer = 5;
	UT_BlockStack					: String = REF &amp; "1";
	Param1							: String = "%1";
	Param2							: String = "%2";
	Param3							: String = "%3";
	TrackedItemImexStatusMessage	: String = "Tracked Item: '%1' Imex Status: Expected: '%2' | Actual '%3'";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	ti					: CM_TrackedItem;
	tiSet				: CM_TISet;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	todoSet				: CM_ToDoTaskDescSet;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	releaseRequest,
	releaseRequest2		: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReserveSelection	: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	blockStack			: CM_BlockStack;
	loopVar				: Integer;
	cg					: CM_CargoGroup;
	
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeShipToRoad2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	foreach loopVar in 1 to 10 do
		self.deleteTrackedItem(self.getTrackedItem(UT_Cargo &amp; loopVar.String), false);
	endforeach;
	
	self.deleteCargoGroup(WOID);
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	blockStack := self.addBlockStack(UT_BlockStack, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_EXPORT);
	
	//Add cargo on site
	create tiSet transient;
	foreach loopVar in 1 to 10 do
		ti := self.addCargoAtLocation(UT_Cargo &amp; loopVar.String, cargoType, operator, blockStack.myLocationsController);
		self.assertNotNullMsg(ti, "ti");
		beginTransaction;
		ti.setVoyageCode(UT_VoyageCode, app.myPassport);
		commitTransaction;
		self.assertTrueMsg(ti.getImExStatus() = TI_IMEX_STATUS_EXPORT, TrackedItemImexStatusMessage.replace(Param1, ti.id).replace(Param2, app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT)).replace(Param3, app.imexStatusEnumToString(ti.getImExStatus())));
		self.assertEqualMsg(ti.voyageCode, UT_VoyageCode, "Voyage codes do not match");
		tiSet.add(ti);
	endforeach;
	
	cg := self.addCargoGroup(WOID, tiSet);
	
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc("CargoType", cargoType);
	terminalUTHelper.opts.addAssoc(UT_OPTS_Voyage, voyage);
	terminalUTHelper.opts.addAssoc("Product", product);
	terminalUTHelper.opts.addAssoc(UT_OPTS_CargoGroup, cg);
	
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_SHIP, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	//Verify Release request
	
	
	// Add to do task to the work order detail
	//toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI); 								//1
	
	//create toDoTaskDescSet transient;
	//toDoTaskDescSet.add(toDoTaskDesc);
	
	//self.addToDoTaskResource("UTMARESTRA",
	//						 "UT MA Resource",
	//						 "MAN",
	//						 1,
	//						 false,
	//						 true,
	//						 toDoTaskDescSet
	//						 );
	
	//create todoSet transient;
	//todoSet.add(toDoTaskDesc);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, todoSet, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder, workOrder, WOID,WO_STATUS_USERENTRY, wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, voyage, TI_TRANSMODE_ROAD_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify Release request
	releaseRequest := terminal.getBulkReleaseFromCode(UT_ReleaseNumber1);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertTrueMsg(releaseRequest.code = UT_ReleaseNumber1, "Release Request not found for code: '" &amp; UT_ReleaseNumber1 &amp; "'");
	self.assertNotNullMsg(releaseRequest.myVoyage, "releaseRequest.myVoyage");
	self.assertTrueMsg(releaseRequest.myVoyage.code = UT_VoyageCode, "Release Request voyage code Expected: '" &amp; UT_VoyageCode &amp; "' | Actual: '" &amp; releaseRequest.myVoyage.code &amp; "'");
	
	//Verify New Release Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	workOrder := terminal.allWorkOrders[WOID];
	self.assertNotNullMsg(workOrder.allWoDtls.first, "Work Order with Id: '" &amp; WOID &amp; "' Should have a detail assinged to it");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_SHIP_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_TotalRequested - UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := releaseRequest2.allWOReleases.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	delete toDoTaskDescSet;
	delete todoSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	delete wodArr;
	delete pxyWO;
	delete objArr;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRelTransRoadToRailMultiLine" id="7ffb1e09-234a-4df4-893a-5226c07ba9d6">
        <source>tRelTransRoadToRailMultiLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2024	navhl20 Bug MTN-33557: EUP | Change of Transport Mode for Release by Type not working for multiple Release Lines

*/

constants
	REF								: String = "33557";
	WOID							: String = "UT" &amp; REF &amp; "-2";
	UT_ReleaseNumber1				: String = "UT_" &amp; REF &amp; "-2REL1";
	UT_ReleaseNumber2				: String = "UT_" &amp; REF &amp; "-2REL2";
	UT_VoyageCode					: String = "UT_" &amp; REF &amp; "VOY";
	UT_VesselName					: String = "UT_" &amp; REF &amp; "VES";
	UT_CargoTypeAbbr				: String = "PAPER";
	UT_ProductCode					: String = "REELS";
	UT_ProductCode1					: String = "ROLLS";
	UT_TotalRequested				: Integer = 10;
	UT_QuantityToSplit				: Integer = 10;
	UT_TrainCode					: String = "UT_" &amp; REF &amp; "1T";
	
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	wodArr				: CM_WorkOrderDtlArray;
	objArr				: CM_ObjectArray;
	pxyWod,
	pxyWod1,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	pxyWO				: CM_WorkOrderTI;
	releaseRequest,
	releaseRequest2,
	pxyRelease			: CM_BulkRelease;
	operator			: CM_Operator;
	terminal			: CM_Terminal;
	cargoType			: CM_CargoType;
	product1,
	product2			: CM_Product;
	terminalUTHelper	: UT_HelperAdmTerm;
	pxyReserveSelection,
	pxyReserveSelection1: CM_ReserveSelection;
	wle					: CM_WorkListEntry;
	train				: CM_Train;
begin
	/*
	** Setup Section, create the work order with a to do cargo task with multiple tracked items
	*/
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, true);
	
	terminal := self.getMyTerminal();
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRelTransChangeRoadToRail2;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation(WOID);
	
	releaseRequest2 := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(UT_ReleaseNumber2, null);
	if releaseRequest2 &lt;&gt; null and 
		releaseRequest2.code = UT_ReleaseNumber2 and 
		releaseRequest2.allWOReleases.isNotEmpty and 
		releaseRequest2.allWOReleases.first.myParent &lt;&gt; null
	then
		self.deleteWorkOrderNoValidation(releaseRequest2.allWOReleases.first.myParent.id);
	endif;
	
	self.deleteVoyage(UT_VoyageCode);
	self.deleteVessel(UT_VesselName);
	self.deleteTrain(UT_TrainCode, null);
	self.deleteReleaseRequest(UT_ReleaseNumber1);
	self.deleteReleaseRequest(UT_ReleaseNumber2);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product1 := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product1, "product");
	
	product2 := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode1);
	self.assertNotNullMsg(product2, "product");
	
	vessel := self.addVesselWithHolds(UT_VesselName, 2, 2);
	self.assertNotNullMsg(vessel, "vessel");
	
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "voyage");
	
	train := self.addTrain(UT_TrainCode, null);
	self.assertNotNullMsg(train, "train");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalVolume, NULL_VOLUME);
	self.opts.addAssoc(UT_OPTS_Product, product1);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product1);
	pxyReserveSelection := terminalUTHelper.xCreateReserveSelection(cargoType, product1, null, UT_TotalRequested, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseNumber1, BR_TYPE_ROAD, true, terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	pxyReserveSelection1 := terminalUTHelper.xCreateReserveSelection(cargoType, product2, null, UT_TotalRequested, null, null);
	pxyRelease := app.createUpdateProxy(releaseRequest).CM_BulkRelease;
	pxyReserveSelection1.setMyHeader(pxyRelease);
	app.myTrxUA.trxUpdateBulkRelease(pxyRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertEqual(releaseRequest.allReserveDetails.size,2);
	delete pxyReserveSelection1;
	delete pxyRelease;
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', null);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', releaseRequest.code);
	self.opts.addAssoc('bulkReleaseDT', releaseRequest.dateRequested);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);	
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod, WO_TASK_RELEASE, null, null, null);
	
	create pxyWod1 as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod1, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(workOrder, "workOrder");
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod, WO_STATUS_USERENTRY, 0, TRANS_TYPE_WO_TIREC_CREATED, false, false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	pxyWO := app.createUpdateProxy(workOrder).CM_WorkOrderTI;
	
	wle := pxyWO.allWoDtls.first.CM_WodRelease.allJobs.first.workListEntries.first;
	
	create objArr transient;
	objArr.add(wle);
	
	//Change Transport mode of ti4 to Ship from Road
	app.myTrxUA.trxUpdateWorkOrderTransport(pxyWO, pxyWO.allWoDtls.first.CM_WodRelease, train, TI_TRANSMODE_RAIL_STR, UT_ReleaseNumber2, objArr, terminal, app.myPassport, UT_QuantityToSplit);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify New Releasse Request
	releaseRequest2 := terminal.getBulkReleaseFromCode(UT_ReleaseNumber2);
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	
	//Verify Original Work Order
	wod := workOrder.allWoDtls.last;
	self.opts.purge;
	self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_ROAD, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_ROAD_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	self.assertTrueMsg(wod.isWodRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WodRelease");
	self.assertTrueMsg(wod.CM_WodRelease.totalActioned = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail totalActioned Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.totalActioned.String &amp; "'");
	
	//Verify Original Work Order Jobs and work list entries
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isWorkOrderJob, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a work order job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.isRelease, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job should be a release job");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size = wod.CM_WodRelease.allActionedTIs.size, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job allTrackedItems size Expected '" &amp;  wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob.allTrackedItems.size.String &amp; "'");
	
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.size = 1, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntries Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.size.String &amp; "'");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job workListEntry quantity Expected: '" &amp; UT_QuantityToSplit.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.workListEntries.first.quantity.String &amp; "'");
	
	//Verify Original Work Order Request
	self.assertNotNullMsg(wod.CM_WodRelease.allJobs.first.allRequests.first, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.isWorkOrderRequest, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request should be a work order request");
	self.assertTrueMsg(wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested = UT_QuantityToSplit, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Job Request totalRequested Expected: '" &amp; wod.CM_WodRelease.allActionedTIs.size.String &amp; "' | Actual: '" &amp; wod.CM_WodRelease.allJobs.first.allRequests.first.CM_WORequest.totalRequested.String &amp; "'");
	
	//Verify New Mode of Transport/Ship Work Order
	self.assertNotNullMsg(releaseRequest2, "releaseRequest2");
	self.assertTrueMsg(releaseRequest2.code = UT_ReleaseNumber2, "Release Request not found for code: '" &amp; UT_ReleaseNumber2 &amp; "'");
	self.assertTrueMsg(releaseRequest2.allWOReleases.isNotEmpty, "Release Request for code: '" &amp; UT_ReleaseNumber2 &amp; "' is not associated to any WOD Releases");
	wod := workOrder.allWoDtls.first;
	self.opts.purge;
	//self.xCheckWorkOrder(wod, WO_STATUS_APPROVED, 4, TRANS_TYPE_WO_TIREC_CREATED, true, false);
	self.assertTrueMsg(wod.isWodTI, "Work Order with Id: '" &amp; WOID &amp; "' First Detail should be of type CM_WorkOrderTIDtl");
	self.assertTrueMsg(wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_RAIL, "Work Order with Id: '" &amp; WOID &amp; "' First Detail Mode of Transport Expected: '" &amp; TI_TRANSMODE_RAIL_STR &amp; "' | Actual '" &amp; app.transportModeENumToString(wod.CM_WorkOrderTIDtl.getTransport()) &amp; "'");
	
	//Verify Wles/Jobs
	
epilog
	self.setTerminalConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.setTerminalConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	delete terminalUTHelper;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
		delete pxyWorkOrder;
	endif;
	if pxyWO &lt;&gt; null then
		pxyWO.allWoDtls.purge;
		delete pxyWO;
	endif;
	delete wodArr;
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseShipJobSheet" id="52b799f4-8f61-4ba0-a299-b7ef1f15ca13">
        <source>tReleaseShipJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
18 Apr 2024	navpw1	Fixed unit test now uses "Steel Coil" instead of "Cannon Balls" - Causes issues leading to 1018 exception with yard allocations

*/

constants
	REF		: String  = '61510';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	WOID1	: String  = 'UT'&amp;REF&amp;'SHP1'; 
	Voyage	: String  = 'UTWORELEASESHIP';
vars
	voyage 					: 	CM_Voyage;
	tI1, tI2,
	pxyTi					:	CM_TrackedItem;
	vessel 					:	CM_Vessel;
	term					:	CM_Terminal;
	tiSet 					: 	CM_TISet;
	operator				: 	CM_Operator;
	dischargePort 			:	CM_Port;
	pxyWod					: 	CM_WorkOrderDtl;
	wodArr					: 	CM_WorkOrderDtlArray;
	pxyWorkOrder,
	workOrder				: 	CM_WorkOrder;
	useYardJobsSetting,
	canAutoActionTiWo		: 	Any;
	blockStack				:	CM_BlockStack;
	groMethod				: 	CM_WorkOrderJobGroupMethod;
	startDate				: 	TimeStamp;
	extRef1,
	extRef2,
	remarks					: 	String;
	pxyVoyJob				: 	CM_VoyageWorkPointJob;
	voyJob					: 	CM_VoyageJob;
	firstJob,
	secondJob				: 	CM_Job;
	realJobSheet			:	CM_WorkPointJobSheet;
	releaseRequest			: 	CM_BulkRelease;
	taSource				: 	CM_TerminalArea;
	code					: 	String;
	relTime					:	TimeStamp;
	cargoType				: 	CM_CargoType;
	product					: CM_Product;
	
begin
	// terminal
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteTerminalArea("BS2911");
	
	// setup stuff 
	blockStack := self.addBlockStack("BS2911", 10, null);
	
	/*
	** Setup Section, create the work order with a recieve ship task with multiple tracked items
	*/
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteWorkOrderNoValidation(WOID1);
	self.deleteVoyage(Voyage);	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHMVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTHMVOY"&amp;REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	//Work Order with tracked items
	// tracked items
	tI1 := self.xAddCargo("UTHM1" &amp; REF, voyage, TI_STATE_NORMAL, null);
	self.assertNotNull(tI1);
	
	tI2 := self.xAddCargo("UTHM2" &amp; REF, voyage, TI_STATE_NORMAL, null);
	self.assertNotNull(tI2);
	
	beginTransaction;
		tI1.setSpecialStow("STOW1");
		tI2.setSpecialStow("STOW2");
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	// Create the work order detail
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	
	groMethod := term.allWOJobGroupMethods["UTHMTEST",term];
	self.opts.purge();
	self.opts.addAssoc('GrpMethod', groMethod);
	self.xActionWorkOrder(workOrder);
	
	self.assertEqual(workOrder.allWoDtls.size,2);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_61510_01");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.size,1);
	
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyVoyJob;
	
	//Work Order with release by type
	cargoType := term.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 2500);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UTBULKREL1", BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('transportMode', TI_TRANSMODE_SHIP);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	// Create the work order detail
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	// create the work order
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID1,WO_STATUS_USERENTRY,wodArr);
	
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	self.assertEqual(workOrder.allWoDtls.size,1);
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheetShip("UT_61510");
	endif;
	
	//Allocate job to jobSheet
	extRef1 		:= "UT_REF1" &amp; REF;
	extRef2 		:= "UT_REF12" &amp; REF;
	remarks 		:= "UT_REMARKS" &amp; REF;
	firstJob 		:= workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allJobs.first;
	secondJob		:= workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allJobs.first;
	create pxyVoyJob transient;
	pxyVoyJob.setProxyForUpdate(app.actualTimeServer().addDays(2),app.actualTimeServer().addDays(2),remarks,0,realJobSheet,extRef1,extRef2);
	app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,realJobSheet,firstJob,null,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(firstJob.CM_WOReleaseCargoJob.allVoyageJobs.size,1);
epilog
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	delete pxyTi;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	delete pxyVoyJob;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadRelWithTwoRelLine" id="1061fdf7-6dc7-45e4-a4e1-412c3c417100">
        <source>tRoadRelWithTwoRelLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Dec 2024	navhl20 Bug MTN-33681: MTN - Unexpected Program error on the Road Gate form

*/

constants
	REF			: String  = "33681";
	WOID 		: String  = 'UT'&amp;REF&amp;'JREBST1';
	BLOCKSTACK 	: String  = "BS" &amp;REF;
	Voyage		: String  = "UTVoy" &amp; REF;
	TruckId 	: String  = 'UTTRK1'&amp;REF;
vars
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
	tiSet					: CM_TISet;
	releaseRequest			: CM_BulkRelease;
	code					: String;
	relTime					: TimeStamp;
	wodArr					: CM_WorkOrderDtlArray;
	pxyWod,
	pxyWod1,
	wod						: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder				: CM_WorkOrder;
	vehicleName, 
	driverName				: String;
	terminalUTHelper		: UT_HelperAdmTerm;
	gate					: CM_Gate;
	terminal 				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	myPxyWorkPointJobSheet	: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType1,
	cargoType2				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	hideMoveConfirmation 	: Boolean;
	moveController			: CMIF_MoveController;
	product1,
	product2				: CM_Product;
	pxyReserveSelection1,
	pxyReserveSelection2	: CM_ReserveSelection;
	pxyRelease				: CM_BulkRelease;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, false);
	self.setTerminalConfig(HhMoveConfirmation,true);			//05.01.2023 navma1
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tRoadRelWithTwoRelLine;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest("UTBLK" &amp; REF);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType1 := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType1, "cargoType");
	
	cargoType2 := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("ALUM").CM_CargoType;
	self.assertNotNullMsg(cargoType2, "cargoType");
	
	product1 := cargoType1.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product1, "product");
	
	product2:= cargoType2.getProductFromCode("INGOTS_BUNDLED");
	self.assertNotNullMsg(product2, "product");
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("CargoType", cargoType1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Product", product1);
	pxyReserveSelection1 := terminalUTHelper.xCreateReserveSelection(cargoType1, product1, null, 5, null, null);
	releaseRequest := terminalUTHelper.xCreateReleaseRequest("UTBLK" &amp; REF, BR_TYPE_ROAD, true, terminal, pxyReserveSelection1);	// Create a release request/bulk release. Release by Type
	pxyReserveSelection2 := terminalUTHelper.xCreateReserveSelection(cargoType2, product2, null, 5, null, null);
	pxyRelease := app.createUpdateProxy(releaseRequest).CM_BulkRelease;
	pxyReserveSelection2.setMyHeader(pxyRelease);
	app.myTrxUA.trxUpdateBulkRelease(pxyRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertEqual(releaseRequest.allReserveDetails.size,2);
	delete pxyReserveSelection2;
	delete pxyRelease;
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	self.opts.addAssoc('reserve',releaseRequest.allReserveDetails.first);
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );
	self.opts.addAssoc('reserve',releaseRequest.allReserveDetails.last);
	
	create pxyWod1 as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod1, WO_TASK_RELEASE, null, null, null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	wodArr.add(pxyWod1);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.addAssoc("both", true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,5,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	self.deleteVVR(vvr);
epilog
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete terminalUTHelper;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete truckUnLoaderController;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadReleaseBreakBulk" id="3c67eaf6-aa8b-46c6-9a02-2549c190a011">
        <source>tRoadReleaseBreakBulk();
/*

Purpose:	Validates the count of WO WLEs and Yard WLEs when the break bulk cargo is being partially loaded to the truck

Parameters:			

Return Value:		

Date		Who		Reason
09 Sep 2024	navbs1	Initial creation Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job

*/


constants
	REF: String  =  "65777";
	WOID : String  = 'UTWO'&amp;REF;
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVoy" &amp; REF;
	TruckId : String = 'UTTRK1'&amp;REF;
	ReleaseRequestId :String = 'UTBULKREL1'&amp;REF;
vars
	tI1,
	tI2,
	tI3,
	tI4,
	tI5					: CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	releaseRequest		: CM_BulkRelease;
	taSource			: CM_TerminalArea;
	code				: String;
	relTime				: TimeStamp;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	vehicleName, 
	driverName			: String;
	terminalUTHelper	: UT_HelperAdmTerm;
	gate				: CM_Gate;
	terminal 			: CM_Terminal;
	vvr					: CM_VehicleVisitRecord;
	driver				: CM_DriverDetails;
	vehicle				: CM_Vehicle;
	operator 			: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	myPxyWorkPointJobSheet	: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	cargoType				: CM_CargoType;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	truckUnLoaderController	: CMIF_MobileTruckLoaderUnloader;
	hideMoveConfirmation 	: Boolean;
	moveController			: CMIF_MoveController;
	product					: CM_Product;
	releaseAmount 			: Integer;
	yardJob,woJob 			: CM_Job;
	woWLE					: CM_WorkListEntry;
	
begin
	/*
	** Setup Section, create the work order with a release cargo task 
	*/
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminalConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminalConfig(AllowAutoActionCargoWo);
	hideMoveConfirmation := self.getTerminalConfig(HhMoveConfirmation).Boolean;
	
	self.setTerminalConfig(UseYardJobsCargoWO, true);
	self.setTerminalConfig(AllowAutoActionCargoWo, false);
	self.setTerminalConfig(HhMoveConfirmation,true);			
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::tCargoJobReleaseRoadByType;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteReleaseRequest(ReleaseRequestId);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	self.deleteCargo("UTBul01", cargoType);
	self.deleteCargo("UTBul02", cargoType);
	self.deleteCargo("UTBul03", cargoType);
	self.deleteCargo("UTBul04", cargoType);
	self.deleteCargo("UTBul05", cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul01", cargoType, 50, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI2 := self.addCargoBreakBulkAtLocation("UTBul02", cargoType, 50, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI3 := self.addCargoBreakBulkAtLocation("UTBul03", cargoType, 50, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI4 := self.addCargoBreakBulkAtLocation("UTBul04", cargoType, 4, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	tI5 := self.addCargoBreakBulkAtLocation("UTBul05", cargoType, 50, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 21);
	releaseRequest:=self.addReleaseByTypeRequestOpts(ReleaseRequestId, BR_TYPE_ROAD, cargoType.id);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_ROAD );						
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,null,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	
	
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseRequest);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,21,releaseRequest);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	yardJob := vvr.vehicle.allRoadJobs.last;
	woWLE :=yardJob.workListEntries.last.myWorkOrderWLE;
	assertNotNull(woWLE);
	woJob := woWLE.job;
	
	
	terminalUTHelper.opts.purge();
	
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	releaseAmount := 5;
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI1, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);
	
	assertEqualMsg(yardJob.workListEntries.size, woJob.workListEntries.size, "Yard WLES and WO WLES count should be equal");
	
	releaseAmount := 3;
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI1, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);
	
	assertEqualMsg(yardJob.workListEntries.size, woJob.workListEntries.size, "Yard WLES and WO WLES count should be equal");
	
	releaseAmount := 2;
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI2, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);
	
	assertEqualMsg(yardJob.workListEntries.size, woJob.workListEntries.size, "Yard WLES and WO WLES count should be equal");
	
	releaseAmount := 4;
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI4, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);
	
	assertEqualMsg(yardJob.workListEntries.size, woJob.workListEntries.size, "Yard WLES and WO WLES count should be equal");
	
	releaseAmount := 7;
	
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRestLoadByReqRoad.name, tI3, releaseRequest, releaseRequest.allReserveDetails.first.CM_ReserveDetail, vehicle, releaseAmount);
	
	assertEqualMsg(yardJob.workListEntries.size, woJob.workListEntries.size, "Yard WLES and WO WLES count should be equal");
	
	self.assertEqualMsg(workOrder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been  completed");
	
	
	self.roadExit(vvr);
	
epilog
 
	if pxyWorkOrder &lt;&gt; null and pxyWorkOrder.allWoDtls &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete terminalUTHelper;
	delete myPxyWorkPointJobSheet;
	delete allJobArr;
	delete truckUnLoaderController;
	delete moveController;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS52249" id="d61e25f9-3f40-4796-b921-05d16f2a6b73">
        <source>tTFS52249();
/*

Purpose:			
		The following Test will be used to create 2 unpack work orders , The first one checking the validation of adding a todo task not matching
		Thr Second Test will check if we managed to create an unpack work order with the correct todo task description
Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2021 navma1 ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
06 Mar 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
28 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/
constants
	REF = UT_DSL.TFS52249;
	TERMINAL 		= "UT";
vars
	bs1,
	bs2			 : CM_BlockStack;
	child1,
	child2,
	cont1,	
	cont2		 : CM_TrackedItem;
	operator	 : CM_Operator;
	cargoType	 : CM_CargoType;
	packTIs		 : CM_TIArray;
	toDoTaskDesc : CM_ToDoTaskDesc;
	helperSys	 : UT_HelperAdmSys;
	terminal	 : CM_Terminal;
	tiSet		 : CM_TISet;
	wodArr		 : CM_WorkOrderDtlArray;
	pxyWod,
	wod			 : CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder	 : CM_WorkOrder;
	todoTaskSet	 : CM_ToDoTaskDescSet;
begin
	/*
	1-
	*/
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators['APL'];
	
	create helperSys transient;
	self.opts.addAssoc("Terminal", TERMINAL);
	helperSys.opts.addAssoc("Terminal", TERMINAL);
	helperSys.setActiveProfile();
	
	helperSys.code:= 'UTCT'&amp;REF;
	helperSys.xDeleteCargoType(false,false,true,false,false,true);

	
	cargoType := self.addCargoType('UTCT'&amp;REF,false);
	self.assertTrueMsg( cargoType &lt;&gt; null, 'UTCT'&amp;REF &amp; " not created in setup." );	
	
	toDoTaskDesc := helperSys.xCreateToDoTaskDesc(method.getNiceName,
												'UT'&amp;REF.String,
												cargoType.abbreviation);
	

	
	deleteTerminalArea('UTBS'&amp;REF);
	bs1 := addBlockStack('UTBS'&amp;REF, 10, null);
	
	deleteTerminalArea('UTBSS'&amp;REF);												//24.3.2023 navhl20	#56614[56615]
	bs2 := addBlockStack('UTBSS'&amp;REF, 10, null);									//24.3.2023 navhl20	#56614[56615]
	
	self.deleteContainer('UTCNT1'&amp;REF);
	self.deleteContainer('UTCNT2'&amp;REF);
	self.deleteCargo('UTCHILD1'&amp;REF,cargoType);
	self.deleteCargo('UTCHILD1'&amp;REF,cargoType);
	
	create tiSet transient;
	
	cont1 := self.addContainerOpts('UTCNT1'&amp;REF, "2200", "GENL", operator);	
	move(cont1, bs1);
	tiSet.add(cont1);
	
	cont2 := self.addContainerOpts('UTCNT2'&amp;REF, "2200", "GENL", operator);		
	move(cont2, bs1);
	tiSet.add(cont2);

	child1 := self.addCargoAtLocation( 'UTCHILD1'&amp;REF, cargoType, operator, bs1.myLocationsController ).CM_Cargo;
	self.assertTrueMsg( child1 &lt;&gt; null,'UTCHILD1'&amp;REF &amp; " not created in setup." );	
	
	child2 := self.addCargoAtLocation( 'UTCHILD2'&amp;REF, cargoType, operator, bs1.myLocationsController ).CM_Cargo;
	self.assertTrueMsg( child2 &lt;&gt; null,'UTCHILD2'&amp;REF &amp; " not created in setup." );	
	
	create packTIs transient;
	packTIs.add(child1);
	packContainer(cont1.CM_Container, packTIs);
	self.packCompleteContainer( cont1.CM_Container );
	self.assertEqualMsg(cont1.numChildren, 1, "Container children incorrect");
	
	
	delete packTIs;
	create packTIs transient;
	packTIs.add(child2);
	self.packContainer(cont2.CM_Container,packTIs);
	self.packCompleteContainer( cont2.CM_Container );
	self.assertEqualMsg(cont2.numChildren, 1, "Container children incorrect");
	
	
	/*
	2- Create UnPack Work order
	*/
	deleteWorkOrderNoValidation('UTWO'&amp;REF);			//12.04.2023 navma1 #57569:[57570]
	
	self.opts.purge();
	self.opts.addAssoc('unpackTA'	, bs2.id);											//28.3.2023 navhl20	#56614[56615]
	self.opts.addAssoc('RequiredByDT' , app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('toDoTaskID' , toDoTaskDesc.code );
	self.opts.addAssoc('TaskType'   , WO_TASK_UNPACK );

	
	//Check Error
	create todoTaskSet transient;
	todoTaskSet.add(toDoTaskDesc);
	create pxyWod as CM_WodUnpack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,todoTaskSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,'UTWO'&amp;REF,WO_STATUS_USERENTRY,wodArr);
	assertFalseMsg(workOrder &lt;&gt; null ,"Work Order Must be null");
	
	delete todoTaskSet;
	delete pxyWod;
	delete pxyWorkOrder;
	delete wodArr;
	
	toDoTaskDesc := helperSys.xCreateToDoTaskDesc(method.getNiceName,
										'UT'&amp;REF.String,
										'CONT');
	create todoTaskSet transient;
	todoTaskSet.add(toDoTaskDesc);
	create pxyWod as CM_WodUnpack transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_UNPACK,todoTaskSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,'UTWO'&amp;REF,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.assertEqual(workOrder.taskStatus ,  WO_STATUS_USERENTRY);
	//self.assertEqual(workOrder.totalRequired ,  2);									//06.03.2023 navma1 #56457:[56458]
	self.assertEqual(workOrder.id , 'UTWO'&amp;REF );
	self.assertNotNull(workOrder.startAtDT);
	self.assertNotNull(workOrder.requiredByDT);
	self.assertNotNull(workOrder.enteredByDT);
	self.assertNotNull(workOrder.myOrganisation);


	self.assertEqual(wod.CM_WorkOrderTIDtl.allSelectedTIs.listString(Comma,CM_TrackedItem::id.name) ,  cont1.id &amp; "," &amp; cont2.id);  //12.01.2023 navma1 #56141 Task#56147
	

	self.assertEqual(workOrder.allWoDtls.size , 1);
	self.assertEqualMsg(wod.CM_WodUnpack.allToDoRequests.size ,1 ,'ToDo Task'&amp; toDoTaskDesc.description&amp;' has not been added correctly ');
	
epilog
	delete helperSys;
	delete packTIs;
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	delete todoTaskSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS52425" id="f0d8f82c-4f3c-4623-bdbd-c3348047be71">
        <source>tTFS52425();
/*
Purpose:			

Date		Who		Reason
23 November 2021	navab1	TFS 52425
*/
constants	
	VesselCode 		: String = 'TFS52425';
	Voyagecode 		: String = 'TFS52425';
	VesselRemarks = "TFS52425 Vessel remarks";
	ShippingAgent 	 			: String = "ISTCO";	

vars
	pxyVoyage, realVoyage : CM_Voyage;
	vessel : CM_Vessel;
	arrivalDate, now				 : TimeStamp;
	departureDate 			 : TimeStamp;
	cargoLoadOperator,
	cargoDischargeOperator,
	operator : CM_Operator;
	departureTS,
	arrivalTS : TimeStamp;
	terminal : CM_Terminal;
	externalRef : String;
	lastPort,
	lastPortOfCall,
	nextPortOfCall,
	originPort: CM_Port;
	visitType : HMS_VisitType;
	vesselCategory : HMS_VesselCategory;
	voyageProcess : CM_VoyageProcess;
	voyCode : String;
	shippingAgent	: CM_ShippingAgent;
begin

	terminal := self.getTerminal();
	
	self.deleteVessel(VesselCode);
	shippingAgent := self.getRoot.allShippingAgentsByCode[ShippingAgent];
	self.assertNotNull(shippingAgent);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);

	self.opts.purge();
	self.opts.addAssoc('VesselRemarks',VesselRemarks );
	self.opts.addAssoc("ShippingAgent", shippingAgent);
	
	vessel := addVesselCellular(VesselCode,operator );

	self.assertTrueMsg(vessel &lt;&gt; null, "Vessel is NULL");
	self.assertTrueMsg(vessel.remarks = VesselRemarks, "Vessel remarks should be '" &amp; VesselRemarks &amp; "'");
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	voyageProcess := terminal.getDefaultVoyageProcess(); 

	pxyVoyage:= vessel.createProxyVoyageRequest(terminal,
												Voyagecode,
												self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),
												arrivalDate,
												departureDate,
												false,
												null, 
												externalRef, 
												originPort,
												lastPortOfCall,
												nextPortOfCall,
												lastPort,
												vesselCategory,
												visitType,
												cargoLoadOperator,
												cargoDischargeOperator,
												voyageProcess,
												app.myPassport);
												
	self.assertTrueTrxOKShowPassport("ERROR - PxyVoyage");
	self.assertTrueMsg(pxyVoyage &lt;&gt; null, "PxyVoyage is NULL");
	self.assertTrueMsg(pxyVoyage.remarks = VesselRemarks, "pxyVoyage remarks should be '" &amp; VesselRemarks &amp; "'");
	
	pxyVoyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_VoyReqSubmitted]);
	
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxCA.trxCreateVoyageRequest(pxyVoyage,
										vessel,
										operator, operator, operator,
										null,null,null,null,
										false,
										"TFS52425 GENERALLY GOOD",
										null,
										app.myPassport);
										
	realVoyage := self.getVoyage(Voyagecode);
	
	
	self.assertTrueTrxOKShowPassport("ERROR - realVoyage");
	self.assertTrueMsg(realVoyage &lt;&gt; null, "realVoyage is NULL");
	self.assertTrueMsg(realVoyage.remarks = VesselRemarks, "realVoyage remarks should be '" &amp; VesselRemarks &amp; "'");

epilog
	delete pxyVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS52489" id="a5d52786-d654-4cae-b25c-81f8549b034d">
        <source>tTFS52489();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jun 2022	navcs2	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/
constants
	REF = UT_DSL.TFS52489;
vars
	tI1, tI2					:	CM_TrackedItem;
	toDoTaskDesc				: 	CM_ToDoTaskDesc;
	taskID						:	Integer;
	tiSet						: 	CM_TISet;
	wodArr						: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod							: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder					: 	CM_WorkOrder;
begin
	deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Dimension"];  
	
	taskID := toDoTaskDesc.code;

	create tiSet transient;
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	tiSet.add(tI1);
	tiSet.add(tI2);
	
	self.opts.purge();
	self.opts.addAssoc('TaskType',WO_TASK_TODO );
	self.opts.addAssoc('toDoTaskID', taskID);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create pxyWod as CM_WodToDo transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_TODO,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,'UTWO'&amp;REF,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.assertEqual(wod.CM_WorkOrderTIDtl.allSelectedTIs.listString(Comma,CM_TrackedItem::id.name) ,
					tI1.id &amp; "," &amp; tI2.id);  											//08.02.2023 navma1 #56457:[56458]
	assertEqual(app.myPassport.noErrors, true);
epilog
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS52580" id="4490db55-c389-4b4c-92a3-77b1d5190e7c">
        <source>tTFS52580();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Feb 2022 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	voyage		 : CM_Voyage;
	wo			 : CM_WorkOrder;
	terminal	 : CM_Terminal;
	occurOnDT    : TimeStamp;
	helperSys    : UT_HelperAdmSys;
	helperTerm   : UT_HelperAdmTerm;
	resourceType : HMS_ResourceType;
	debtor		 : CM_DebtorNode;
	invoice		 : CM_Invoice;
	
begin
	
	self.opts.purge();
	self.opts.addAssoc(UT_Profile.P_TERMINAL,'UT');
	terminal := self.getTerminal();
	
	
	self.xAddWOVoyageRequest(UT_DSL.TFS52580,false);
	
	/*
		1- Create Voyage Work Order
	*/
	voyage :=  self.getVoyage('UT'&amp; UT_DSL.TFS52580);
	self.xValidateVoyageStatus(voyage,Voyage_Status_VoyReqSubmitted); // 102
	beginTransaction;
	voyage.setMyDischargeCompany(terminal.getDefaultCompanyBank);
	commitTransaction;
	
	wo := voyage.getWorkOrderForVoyageRequest().myParent;
	self.xApproveWorkOrder(wo);
	self.xValidateVoyageStatus(voyage,Voyage_Status_ServicesPending); // 107
	/*
		2- Create IMSR
	*/
	occurOnDT := voyage.arrivedDT.addHours(3);
	self.xAddWOIMSR(voyage,null,occurOnDT,3.3,5.5,6.6,false,false);
	
	
	wo := voyage.getWorkOrderForIMSR().myParent;
	self.xApproveWorkOrder(wo);
	self.xValidateVoyageStatus(voyage,Voyage_Status_ApprovalPending); // 109
	
	self.xActionWorkOrder(wo);
	
	
	/*
		3 - Add Resource Type
			Add Harbour Resource
			Add Hms Movement For Arrival
	*/
	
	create helperSys  transient ;
	resourceType := helperSys.xCreateHMSResourceType(UT_DSL.TFS52580,true,'DAYS');
	helperSys.xCreateHarbourResource(terminal.myHarbour,resourceType,terminal.myHarbour.allWharves.first);
	
	create helperTerm  transient ;
	helperTerm.xAddHmsMovementResource(voyage,HMSMovementTypeArrival,UT_DSL.TFS52580,UT_DSL.TFS52580,15,null,null);
	
	/*
		4- Prepare Invoice Confiuration
		   Load Transction Map
		   CalculationTpe : VT001 - HMS Ressource Qty
	*/
	
	helperTerm.xCreateInvoiceType(CM_InvoiceDesc.Key_Voyage,UT_DSL.TFS52580);
	
	
	helperTerm.xCreateInvoiceServiceLineRate(UT_DSL.TFS52580,UT_DSL.TFS52580,UT_DSL.TFS52580,FORCED_ERASE,debtor,55.0,INV_CALC_TYPE_RESOURCE_QTY);
	
	helperTerm.helperHmsTransactionMaps('HMS',UT_DSL.TFS52580,null);
	
	helperTerm.xGenerateInvoiceForMovement(voyage,HMSMovementTypeArrival);

	
	
	/*
		Final - Validate Results 
		Check Invoice been added to the IMSR Wo 
		Check Work Order has been Added to the Invoice 
		Check Invoice Total Amout  Qty : 15 , Rate : 55 = 825
	*/
	
	wo := voyage.getWorkOrderForIMSR().myParent;
	
	assertTrueMsg(wo.allInvoices.size = 1 , 
					'IMSR Work Order : ' 			&amp; wo.id &amp; CrLf   &amp;
					'Invoice Count :'			    &amp; wo.allInvoices.size.String);
		
	invoice := voyage.allInvoices.first;
	
	assertTrueMsg(invoice.allWorkOrders.size = 1 , 
					'Invoice  : ' 				    &amp; invoice.sequenceNum.String &amp; CrLf   &amp;
					'Work Orders Count :'		    &amp; invoice.allWorkOrders.size.String);
					
	assertTrueMsg(invoice.getTotalAmount = 825 ,
				 'Expected Invoice Total Amout : 825'  &amp; CrLf   &amp;
				  'Current Invoice Total Amout :'		&amp; invoice.getTotalAmount.String);
	
	
epilog
	delete helperSys;
	delete helperTerm;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobMulti" id="a11698c0-c774-444f-baa7-3e1ee57e32b4">
        <source>tToDoJobMulti();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
	MyTrain: String = UT_DSL.TFS54344.String &amp; "T";
vars
	proxyWorkOrder,
	workorder			: CM_WorkOrder;
	useYardJobsSetting 	: Any;
	debtor1, debtor2,
	debtor3			  	: CM_Debtor;
	debtorSet			: CM_DebtorSet;
	train1,
	train2				: CM_Train;
	trainSet 			: CM_TrainSet;
	toDoTaskDescNonOps,
	toDoTaskDescTrain	: CM_ToDoTaskDesc;
	taskID	:	Integer;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** 1st Setup Section, create the work order with a ToDo NonOps task with multiple debtors
	*/	
	
	// Set the config to use yard jobs for the terminal	
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;
	
	// Delete the old work order and create containers to add

	// Setup the work order options
	self.opts.purge();

	
	// Add to do task to the work order detail
	toDoTaskDescNonOps := self.xAddToDoTaskNonOps(); 
	taskID := toDoTaskDescNonOps.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDescNonOps);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );	
	
	
	self.deleteDebtor("UT_WODebtor1");
	self.deleteDebtor("UT_WODebtor2");
	
	// Setup the debotrs
	create debtorSet transient;
	
	debtor1 := self.addDebtor("UT_WODebtor1", PaymentType_None).CM_Debtor;
	debtor2 := self.addDebtor("UT_WODebtor2", PaymentType_None).CM_Debtor;
	
	// Verify the debtors have been created correctly
	self.assertNotNullMsg(debtor1, "Debtor1 is null");
	self.assertNotNullMsg(debtor2, "Debtor2 is null");
	
	debtorSet.add(debtor1);
	debtorSet.add(debtor2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	self.opts.addAssoc('toDoTaskID', taskID);
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_NONOPS);
	
	// Add the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, debtorSet);
	
	/*
	**	1st Assert Section
	*/
	
	// Check the work order has been created
	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check that a transaction of the correct type has been created
	self.assertTrueMsg(workorder.allWoDtls.size &gt; 0, "No work order details have been added to the work order");
	
	// Check the first transatction is the correct type for the NonOps task
	self.assertTrueMsg(workorder.allWoDtls.first.allWODtlTransactions.first.isKindOf(CM_WOToDo_NonOps), "The first transaction is not the correct type");
	
	// Check the first transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_NOP_CREATED, "The create transaction is not the correct type");
	
	// Check the debtors have been correctly populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allDebtors.size &gt; 0, "The work order detail contains no tracked items");

	/*
	** 2nd Setup Section, update the work order with a ToDo Train task with multiple trains
	*/	
	self.opts.purge();	
	
	// Add to do task to the work order detail
	toDoTaskDescTrain := self.xAddToDoTaskTrain(); 
	taskID := toDoTaskDescTrain.code;
	
	delete toDoTaskDescSet;  
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDescTrain);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	self.opts.addAssoc('toDoTaskID', taskID);
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_TRAIN);
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);
	
	// Setup the trains to be added for the train task
	self.deleteTrainAndWagons(MyTrain &amp; "1");
	self.deleteTrainAndWagons(MyTrain &amp; "2");
	train1 := self.addTrain(MyTrain &amp; "1" , null);
	train2 := self.addTrain(MyTrain &amp; "2", null);
	
	// Check the trains have been created correctly
	self.assertNotNullMsg(train1, "Train 1");
	self.assertNotNullMsg(train2, "Train 2");
	
	// Add the trainsand create the work order
	create trainSet transient;
	
	trainSet.add(train1);
	trainSet.add(train2);
	
	// Create the update proxy and add the new work order detail
	proxyWorkOrder := app.createUpdateProxy(workorder).CM_WorkOrderToDo;
	
	// Add the new work order detail to the work order
	self.addWorkOrderVasTask(proxyWorkOrder.CM_WorkOrderToDo, trainSet);
	
	// Update the work order details
	app.myTrxUA.trxUpdateWorkOrderTasks(proxyWorkOrder, app.myPassport);
	
	
	/*
	**	2nd Assert Section
	*/
	
	// Assert that work order has 2 different work order details
	self.assertTrue(workorder.allWoDtls.size = 2);
	
	// Check the first transatction is the correct type for the Train task
	self.assertTrueMsg(workorder.allWoDtls.last.allWODtlTransactions.last.isKindOf(CM_WOToDo_Train), "The last transaction is not the correct type");

	// Check the debtors have been correctly populated
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WodToDoTrain.allTrains.size &gt; 0, "The work order detail contains no debtors");
	

	/*
	** 3rd Setup Section, update the work order with another NonOps task with a debtors
	*/	
	delete proxyWorkOrder;
	
	taskID := toDoTaskDescNonOps.code;
	
	delete toDoTaskDescSet;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDescNonOps);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	self.opts.addAssoc('toDoTaskID', taskID);
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_NONOPS);
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);
	
	self.deleteDebtor("UT_WODebtor3");
	
	
	// Setup the debotrs
	delete debtorSet;
	
	create debtorSet transient;
	
	debtor3 := self.addDebtor("UT_WODebtor3", PaymentType_None).CM_Debtor;
	
	// Verify the debtors have been created correctly
	self.assertNotNullMsg(debtor3, "Debtor3 is null");
	
	debtorSet.add(debtor3);
	
	// Create the update proxy and add the new work order detail
	proxyWorkOrder := app.createUpdateProxy(workorder).CM_WorkOrderToDo;
	
	// Add the new work order detail to the work order
	self.addWorkOrderVasTask(proxyWorkOrder.CM_WorkOrderToDo, debtorSet);
	
	// Update the work order details
	app.myTrxUA.trxUpdateWorkOrderTasks(proxyWorkOrder, app.myPassport);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder);
	
	
	/*
	**	3rd Assert Section
	*/
	
	/*
	** Check the first non operational task
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.allRequests.first.isKindOf(CM_WONonOperationalToDoRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 4, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_NonOps), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has trains populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allDebtors.size &gt; 0, "The work order detail has no trains populated");
	
	// Check that the work order detail has populated the jobs trains
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.CM_WOToDoNonOperationalJob.allDebtors.size &gt; 0, "The jobs trains set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	
	/*
	** Check the the Train task
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls[2].status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WodToDoTrain.allJobs.first.allRequests.first.isKindOf(CM_WOTrainToDoRequest), "The request is null or of the wrong type");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Train), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has trains populated
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WodToDoTrain.allTrains.size &gt; 0, "The work order detail has no trains populated");
	
	// Check that the work order detail has populated the jobs trains
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WodToDoTrain.allJobs.first.CM_WOToDoTrainJob.allTrains.size &gt; 0, "The jobs trains set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls[2].CM_WodToDoTrain.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
		
	
	/*
	** Check the second non operational task
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.last.status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WodToDoNonOperational.allJobs.first.allRequests.first.isKindOf(CM_WONonOperationalToDoRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_NonOps), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has trains populated
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WodToDoNonOperational.allDebtors.size &gt; 0, "The work order detail has no trains populated");
	
	// Check that the work order detail has populated the jobs trains
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WodToDoNonOperational.allJobs.first.CM_WOToDoNonOperationalJob.allDebtors.size &gt; 0, "The jobs trains set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.last.CM_WodToDoNonOperational.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the work orders transaction count
	self.assertEqualMsg(workorder.allTransactions.size, 9, "Incorrect number of transactions created for the work order");
epilog
	delete proxyWorkOrder;
	delete debtorSet;
	delete trainSet;
	delete toDoTaskDescSet;
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobNonOps" id="483f621e-b187-4d4d-9177-df9028dd0815">
        <source>tToDoJobNonOps();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	debtor1, debtor2	  : CM_Debtor;
	debtorSet : CM_DebtorSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction	: CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** Setup Section, create the work order with a NonOps task with multiple debtors
	*/
	
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskNonOps(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_NONOPS);
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create voyages and add them to a set	
	self.deleteDebtor("UT_WODebtor1");
	self.deleteDebtor("UT_WODebtor2");
	
	create debtorSet transient;
	
	debtor1 := self.addDebtor("UT_WODebtor1", PaymentType_None).CM_Debtor;
	debtor2 := self.addDebtor("UT_WODebtor2", PaymentType_None).CM_Debtor;
	
	debtorSet.add(debtor1);
	debtorSet.add(debtor2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, debtorSet);
	
	// Check the work order is not null
	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");
	
	// Check the first transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_NOP_CREATED, "The create transaction is not the correct type");
	
	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");
	
	// Check the work order task has the correct status
	self.assertEqualMsg(workorder.taskStatus ,  WO_STATUS_PENDING, "The work order task status should be user entry");
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder);
	
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_NOP_UPDATED, "The create transaction is not the correct type");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.allRequests.first.isKindOf(CM_WONonOperationalToDoRequest), "The request is null or of the wrong type");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_NonOps), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has debtors populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allDebtors.size &gt; 0, "The work order detail has no debtors populated");
	
	// Check that the work order detail has populated the jobs debtors
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.CM_WOToDoNonOperationalJob.allDebtors.size &gt; 0, "The jobs debtors set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");

	/*
	 * Check the first debtor have the correct work order entities
	*/
	
	// Check the debtor has a job
	self.assertTrueMsg(debtor1.allWorkOrderJobs.size &gt; 0, "debtor1 has no work order jobs");
	
	// Check the debtor has a request
	self.assertTrueMsg(debtor1.allWorkOrderRequests.size &gt; 0, "debtor1 has no work order requests");
	
	// Check the debtor has a WLE
	self.assertTrueMsg(debtor1.allWorkOrderWLEs.size &gt; 0, "debtor1 has no work order WLEs");
	
	// Check the debtor has a toDoTask
	self.assertTrueMsg(debtor1.allToDoTasksToDo.size &gt; 0, "debtor1 has no work order toDoTasks");
	
	/*
	 * Check the second debtor have the correct work order entities
	*/
	
	// Check the debtor has a job
	self.assertTrueMsg(debtor2.allWorkOrderJobs.size &gt; 0, "debtor2 has no work order jobs");
	
	// Check the debtor has a request
	self.assertTrueMsg(debtor2.allWorkOrderRequests.size &gt; 0, "debtor2 has no work order requests");
	
	// Check the debtor has a WLE
	self.assertTrueMsg(debtor2.allWorkOrderWLEs.size &gt; 0, "debtor2 has no work order WLEs");
	
	// Check the debtor has a toDoTask
	self.assertTrueMsg(debtor2.allToDoTasksToDo.size &gt; 0, "debtor2 has no work order toDoTasks");
	
	
	/*
	 * Complete the to do tasks
	*/
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(debtor1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.status, 1, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(debtor2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoNonOperational.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check the complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_NOP_COMPLET, "The create transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete debtorSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobTrain" id="d68020ca-931c-4656-a6c7-466df6cb414e">
        <source>tToDoJobTrain();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
	MyTrain: String = UT_DSL.TFS54344.String &amp; "T";
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	train1, train2 : CM_Train;
	trainSet : CM_TrainSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction : CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
	toDoTask	: CM_ToDoTask;
	proxyResourceTypeUsage, resourcetypeUsage : CM_ResourceTypeUsage;
	newTrans : CM_Transaction;
begin
	/*
	** Setup Section, create the work order with a ToDo train task with multiple trains
	*/
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;
	
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskTrain(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_TRAIN);	
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create Trains and add to proxy
	self.deleteTrainAndWagons(MyTrain &amp; "1");
	self.deleteTrainAndWagons(MyTrain &amp; "2");
	train1 := self.addTrain(MyTrain &amp; "1" , null);
	train2 := self.addTrain(MyTrain &amp; "2", null);

	create trainSet transient;
	
	trainSet.add(train1);
	trainSet.add(train2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order and check it is not null	
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, trainSet);

	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");

	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");
	
	// Check the create transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_TRN_CREATED, "The create transaction is not the correct type");
	
	// Check the work order task has the correct status
	self.assertEqualMsg(workorder.taskStatus ,  WO_STATUS_PENDING, "The work order task status should be user entry");
	
	// Approve and action, will create a transaction each
	self.xApproveWorkOrder(workorder);
	
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.allRequests.first.isKindOf(CM_WOTrainToDoRequest), "The request is null or of the wrong type");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Train), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has trains populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allTrains.size &gt; 0, "The work order detail has no trains populated");
	
	// Check that the work order detail has populated the jobs trains
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.CM_WOToDoTrainJob.allTrains.size &gt; 0, "The jobs trains set has not been populated");

	// Check that WLEs have been created
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.workListEntries.size, 2, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_TRN_UPDATED, "The create transaction is not the correct type");
	
	
	/*
	 * Check the first train have the correct work order entities
	*/
	
	// Check the train has a job
	self.assertTrueMsg(train1.allWorkOrderJobs.size &gt; 0, "train1 has no work order jobs");
	
	// Check the train has a request
	self.assertTrueMsg(train1.allWorkOrderRequests.size &gt; 0, "train1 has no work order requests");
	
	// Check the train has a WLE
	self.assertTrueMsg(train1.allWorkOrderWLEs.size &gt; 0, "train1 has no work order WLEs");
	
	// Check the train has a toDoTask
	self.assertTrueMsg(train1.allToDoTasksToDo.size &gt; 0, "train1 has no work order toDoTasks");
	
	/*
	 * Check the second train have the correct work order entities
	*/
	
	// Check the train has a job
	self.assertTrueMsg(train2.allWorkOrderJobs.size &gt; 0, "train2 has no work order jobs");
	
	// Check the train has a request
	self.assertTrueMsg(train2.allWorkOrderRequests.size &gt; 0, "train2 has no work order requests");
	
	// Check the train has a WLE
	self.assertTrueMsg(train2.allWorkOrderWLEs.size &gt; 0, "train2 has no work order WLEs");
	
	// Check the train has a toDoTask
	self.assertTrueMsg(train2.allToDoTasksToDo.size &gt; 0, "train2 has no work order toDoTasks");
	
	
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(train1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(train1.allToDoTasksCompleted.size &gt; 0, "train1 has no completed to do tasks");
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.status, 1, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(train2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(train2.allToDoTasksCompleted.size &gt; 0, "train2 has no completed to do tasks");
	
	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoTrain.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check the final complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_TRN_COMPLET, "The create transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete trainSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobTruck" id="5c18159c-9a37-4182-879a-e8b4192c77b3">
        <source>tToDoJobTruck();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
	TruckId = "WOTRUCK";
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	vehicleVisit1, vehicleVisit2 : CM_VehicleVisitRecord;
	vehicleVisitSet : CM_VehicleVisitRecordSet;
	truck1,
	truck2,
 	gateName,
	driverName	: String;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction	: CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** Setup Section, create the work order with a ToDo train task with multiple trains
	*/
	
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;
		
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskTruck(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_TRUCK);
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create the vehicle visits and check that they are not null
	gateName := self.getTerminal.getDefaultGate_IN().name;

	self.deleteVehicle(truck1);
	self.deleteVehicle(truck2);

	truck1 := TruckId &amp; "1";
	truck2 := TruckId &amp; "2";
	
	vehicleVisit1 := self.addVehicleVisitRecord(truck1, "", driverName, gateName);
	self.assertNotNullMsg(vehicleVisit1, "Vehicle Visit 1 is null");
	
	vehicleVisit2 := self.addVehicleVisitRecord(truck2, "", driverName, gateName);
	self.assertNotNullMsg(vehicleVisit2, "Vehicle Visit 2 is null");

	create vehicleVisitSet transient;
	
	vehicleVisitSet.add(vehicleVisit1);
	vehicleVisitSet.add(vehicleVisit2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, vehicleVisitSet);
	
	// Check the work order is not null
	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_TRK_CREATED, "The created transaction is not the correct type");
	
	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");
	
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder);	
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");	
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.allRequests.first.isKindOf(CM_WOVehicleVisitToDoRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrue(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Truck));

	// Check that the work order detail has trucks populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allVehicleVisits.size &gt; 0, "The work order detail has no trucks populated");
	
	// Check that the work order detail has populated the jobs trucks
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.CM_WOToDoVehicleVisitJob.allVehicleVisits.size &gt; 0, "The jobs trucks set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_TRK_UPDATED, "The update transaction is not the correct type");
	
	
	/*
	** Check the first truck have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(vehicleVisit1.allWorkOrderJobs.size &gt; 0, "vehicle visit 1 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(vehicleVisit1.allWorkOrderRequests.size &gt; 0, "vehicle visit 1 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(vehicleVisit1.allWorkOrderWLEs.size &gt; 0, "vehicle visit 1 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(vehicleVisit1.allToDoTasksToDo.size &gt; 0, "vehicle visit 1 has no work order toDoTasks");
	
	/*
	** Check the second voyage have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(vehicleVisit2.allWorkOrderJobs.size &gt; 0, "vehicle visit 2 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(vehicleVisit2.allWorkOrderRequests.size &gt; 0, "vehicle visit 2 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(vehicleVisit2.allWorkOrderWLEs.size &gt; 0, "vehicle visit 2 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(vehicleVisit2.allToDoTasksToDo.size &gt; 0, "vehicle visit 2 has no work order toDoTasks");
	
	
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(vehicleVisit1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(vehicleVisit1.allToDoTasksCompleted.size &gt; 0, "vehicleVisit1 has no completed to do tasks");
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.status, 1, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(vehicleVisit2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(vehicleVisit2.allToDoTasksCompleted.size &gt; 0, "vehicleVisit2 has no completed to do tasks");
	
	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVehicleVisit.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check the complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_TRK_COMPLET, "The complete transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete vehicleVisitSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobVbs" id="5720dd97-ca94-4cfd-bd29-f5e4f7545bfd">
        <source>tToDoJobVbs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	vbsTimeSlot1, vbsTimeSlot2 : CM_VehicleBookingTimeSlot;
	vbsSet 	: CM_VehicleBookingTimeSlotById;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction : CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** Setup Section, create the work order with a ToDo vbs task with multiple vehicle booking time slots
	*/
	
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskVBS(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	// Setup the work order options	
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_VBS);
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create vehicle booking time slots and add them to the work order
	vbsTimeSlot1 := addVehicleBookingAdv(REF &amp; "1");
	vbsTimeSlot2 := addVehicleBookingAdv(REF &amp; "2");
	
	create vbsSet transient;
	
	vbsSet.add(vbsTimeSlot1);
	vbsSet.add(vbsTimeSlot2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, vbsSet);
	
	// Check the work order is not null
	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");
	
	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");

	// Check the create transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_VBS_CREATED, "The created transaction is not the correct type");
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder);
	
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");

	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order state is not action");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.allRequests.first.isKindOf(CM_WOVBSToDoSlotRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_VBS), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has vbs slots populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allVBSSlots.size &gt; 0, "The work order detail has no vbs slots populated");

	// Check that the work order detail has populated the jobs vbs slots
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.CM_WOToDoVBSSlotJob.allVBSSlots.size &gt; 0, "The jobs vbs slots set has not been populated");
	
	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VBS_UPDATED, "The update transaction is not the correct type");
	
	/*
	** Check the first VBSlot have the correct work order entities
	*/
	
	// Check the VBSlot has a job
	self.assertTrueMsg(vbsTimeSlot1.allWorkOrderJobs.size &gt; 0, "vbsTimeSlot1 has no work order jobs");
	
	// Check the VBSlot has a request
	self.assertTrueMsg(vbsTimeSlot1.allWorkOrderRequests.size &gt; 0, "vbsTimeSlot1 has no work order requests");
	
	// Check the VBSlot has a WLE
	self.assertTrueMsg(vbsTimeSlot1.allWorkOrderWLEs.size &gt; 0, "vbsTimeSlot1 has no work order WLEs");
	
	// Check the VBSlot has a toDoTask
	self.assertTrueMsg(vbsTimeSlot1.allToDoTasksToDo.size &gt; 0, "vbsTimeSlot1 has no work order toDoTasks");
	
	/*
	** Check the second VBSlot have the correct work order entities
	*/
	
	// Check the VBSlot has a job
	self.assertTrueMsg(vbsTimeSlot2.allWorkOrderJobs.size &gt; 0, "vbsTimeSlot2 has no work order jobs");
	
	// Check the VBSlot has a request
	self.assertTrueMsg(vbsTimeSlot2.allWorkOrderRequests.size &gt; 0, "vbsTimeSlot2 has no work order requests");
	
	// Check the VBSlot has a WLE
	self.assertTrueMsg(vbsTimeSlot2.allWorkOrderWLEs.size &gt; 0, "vbsTimeSlot2 has no work order WLEs");
	
	// Check the VBSlot has a toDoTask
	self.assertTrueMsg(vbsTimeSlot2.allToDoTasksToDo.size &gt; 0, "vbsTimeSlot2 has no work order toDoTasks");
	
	
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(vbsTimeSlot1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(vbsTimeSlot1.allToDoTasksCompleted.size &gt; 0, "vbsTimeSlot1 has no completed to do tasks");	
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.status, 1, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(vbsTimeSlot2, taskID, app.myPassport, null,workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(vbsTimeSlot2.allToDoTasksCompleted.size &gt; 0, "vbsTimeSlot2 has no completed to do tasks");
	
	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVBS.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check the complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VBS_COMPLET, "The complete transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete vbsSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobVoyage" id="50c4e032-f328-4978-a2c0-894ac7d11e0c">
        <source>tToDoJobVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
	VoyageName1: String = UT_DSL.TFS54344.String &amp; "VOY1";
	VoyageName2: String = UT_DSL.TFS54344.String &amp; "VOY2";
	BoatCode: String = UT_DSL.TFS54344.String &amp; "B";
	TestOperator	= 'UTOP';
	InVoyName1		= UT_DSL.TFS54344.String &amp; "1";				
	InVoyName2		= UT_DSL.TFS54344.String &amp; "2";
	BoatName        = 'My Vessel';
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	voyage1, voyage2 : CM_Voyage;
	voyageSet : CM_VoyageSet;
	vessel : CM_Vessel;
	operator : CM_Operator;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction	: CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** Setup Section, create the work order with a ToDo voyage task with multiple voyages
	*/
	
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskVoyage(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_VOYAGE);
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create voyages and add them to a set
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);	
	self.assertIsDeleted(vessel);
	operator := self.getOperator(TestOperator);
	assertNotNullMsg(operator, "The operator is null");
	
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	self.deleteVoyage(VoyageName1);
	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	self.deleteVoyage(VoyageName2);
	voyage2 := self.addVoyageWithInwardCode(        VoyageName2,
                                                    InVoyName2,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	create voyageSet transient;
	
	voyageSet.add(voyage1);
	voyageSet.add(voyage2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, voyageSet);
	
	// Check the work order is not null
	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");
	
	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");
	
	// Check the create transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_VOY_CREATED, "The create transaction is not the correct type");
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder);
	
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order state is not action");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.allRequests.first.isKindOf(CM_WOVoyageToDoRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Voyage), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has voyages populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allVoyages.size &gt; 0, "The work order detail has no voyages populated");

	// Check that the work order detail has populated the jobs voyages
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.CM_WOToDoVoyageJob.allVoyages.size &gt; 0, "The jobs voyages set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VOY_UPDATED, "The update transaction is not the correct type");
	
	
	/*
	** Check the first voyages have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage1.allWorkOrderJobs.size &gt; 0, "voyage1 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage1.allWorkOrderRequests.size &gt; 0, "voyage1 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage1.allWorkOrderWLEs.size &gt; 0, "voyage1 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage1.allToDoTasksToDo.size &gt; 0, "voyage1 has no work order toDoTasks");
	
	/*
	** Check the second voyage have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage2.allWorkOrderJobs.size &gt; 0, "voyage2 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage2.allWorkOrderRequests.size &gt; 0, "voyage2 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage2.allWorkOrderWLEs.size &gt; 0, "voyage2 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage2.allToDoTasksToDo.size &gt; 0, "voyage2 has no work order toDoTasks");
	
	
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(voyage1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(voyage1.allToDoTasksCompleted.size &gt; 0, "voyage1 has no completed to do tasks");
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.status, 1, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(voyage2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(voyage2.allToDoTasksCompleted.size &gt; 0, "voyage2 has no completed to do tasks");
	
	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check the complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VOY_COMPLET, "The complete transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete voyageSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobVoyageUnApprove" id="15d8b0e3-9dd2-4cd5-bc11-2175490a75a9">
        <source>tToDoJobVoyageUnApprove();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Sep 2024	navah1	Initial creation
11 Sep 2024 navah1  Bug 65907: EUP - Error 1310 when actioning work order that has been un - approved before
*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
	VoyageName1: String = UT_DSL.TFS54344.String &amp; "VOY1";
	VoyageName2: String = UT_DSL.TFS54344.String &amp; "VOY2";
	BoatCode: String = UT_DSL.TFS54344.String &amp; "B";
	TestOperator	= 'UTOP';
	InVoyName1		= UT_DSL.TFS54344.String &amp; "1";				
	InVoyName2		= UT_DSL.TFS54344.String &amp; "2";
	BoatName        = 'My Vessel';
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	voyage1, voyage2 : CM_Voyage;
	voyageSet : CM_VoyageSet;
	vessel : CM_Vessel;
	operator : CM_Operator;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction	: CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** Setup Section, create the work order with a ToDo voyage task with multiple voyages
	*/
	
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;

	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskVoyage(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_VOYAGE);
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create voyages and add them to a set
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);	
	self.assertIsDeleted(vessel);
	operator := self.getOperator(TestOperator);
	assertNotNullMsg(operator, "The operator is null");
	
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	self.deleteVoyage(VoyageName1);
	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	self.deleteVoyage(VoyageName2);
	voyage2 := self.addVoyageWithInwardCode(        VoyageName2,
                                                    InVoyName2,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	create voyageSet transient;
	
	voyageSet.add(voyage1);
	voyageSet.add(voyage2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, voyageSet);
	
	// Check the work order is not null
	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");
	
	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");
	
	// Check the create transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_VOY_CREATED, "The create transaction is not the correct type");
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder); 
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order state is not action");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.allRequests.first.isKindOf(CM_WOVoyageToDoRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Voyage), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has voyages populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allVoyages.size &gt; 0, "The work order detail has no voyages populated");

	// Check that the work order detail has populated the jobs voyages
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.CM_WOToDoVoyageJob.allVoyages.size &gt; 0, "The jobs voyages set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VOY_UPDATED, "The update transaction is not the correct type");
	
	
	/*
	** Check the first voyages have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage1.allWorkOrderJobs.size &gt; 0, "voyage1 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage1.allWorkOrderRequests.size &gt; 0, "voyage1 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage1.allWorkOrderWLEs.size &gt; 0, "voyage1 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage1.allToDoTasksToDo.size &gt; 0, "voyage1 has no work order toDoTasks");
	
	/*
	** Check the second voyage have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage2.allWorkOrderJobs.size &gt; 0, "voyage2 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage2.allWorkOrderRequests.size &gt; 0, "voyage2 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage2.allWorkOrderWLEs.size &gt; 0, "voyage2 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage2.allToDoTasksToDo.size &gt; 0, "voyage2 has no work order toDoTasks");
	
	// Un-Approve the work order 
	self.xUnApproveWorkOrder(workorder);
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs are present after unapproving work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size = 0, "Work order jobs are present for unapproved work order");
	
	// Check the status of the work order detail is "user entry"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_USERENTRY, "The work order state is actioned");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Voyage), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has voyages populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allVoyages.size &gt; 0, "The work order detail has no voyages populated");

	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VOY_UPDATED, "The update transaction is not the correct type");
	
	
	/*
	** Check the first voyages have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage1.allWorkOrderJobs.size = 0, "voyage1 has work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage1.allWorkOrderRequests.size = 0, "voyage1 has work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage1.allWorkOrderWLEs.size = 0, "voyage1 has work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage1.allToDoTasksToDo.size = 0, "voyage1 has work order toDoTasks");
	
	/*
	** Check the second voyage have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage2.allWorkOrderJobs.size = 0, "voyage2 has work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage2.allWorkOrderRequests.size = 0, "voyage2 has work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage2.allWorkOrderWLEs.size = 0, "voyage2 has work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage2.allToDoTasksToDo.size = 0, "voyage2 has work order toDoTasks");
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workorder); 
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No Work order jobs have been created for this work order detail");
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order state is not action");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.allRequests.first.isKindOf(CM_WOVoyageToDoRequest), "The request is null or of the wrong type");
	
	// Check that transactions have been created when actioning and creating
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	// Check that the transactions are the right type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Voyage), "The Transactions are not the correct type or are null");
	
	// Check that the work order detail has voyages populated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allVoyages.size &gt; 0, "The work order detail has no voyages populated");

	// Check that the work order detail has populated the jobs voyages
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.CM_WOToDoVoyageJob.allVoyages.size &gt; 0, "The jobs voyages set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the update transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VOY_UPDATED, "The update transaction is not the correct type");
	
	
	/*
	** Check the first voyages have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage1.allWorkOrderJobs.size &gt; 0, "voyage1 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage1.allWorkOrderRequests.size &gt; 0, "voyage1 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage1.allWorkOrderWLEs.size &gt; 0, "voyage1 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage1.allToDoTasksToDo.size &gt; 0, "voyage1 has no work order toDoTasks");
	
	/*
	** Check the second voyage have the correct work order entities
	*/
	
	// Check the voyage has a job
	self.assertTrueMsg(voyage2.allWorkOrderJobs.size &gt; 0, "voyage2 has no work order jobs");
	
	// Check the voyage has a request
	self.assertTrueMsg(voyage2.allWorkOrderRequests.size &gt; 0, "voyage2 has no work order requests");
	
	// Check the voyage has a WLE
	self.assertTrueMsg(voyage2.allWorkOrderWLEs.size &gt; 0, "voyage2 has no work order WLEs");
	
	// Check the voyage has a toDoTask
	self.assertTrueMsg(voyage2.allToDoTasksToDo.size &gt; 0, "voyage2 has no work order toDoTasks");
	
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(voyage1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(voyage1.allToDoTasksCompleted.size &gt; 0, "voyage1 has no completed to do tasks");
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.status, JOB_PART_COMPLETE, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(voyage2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(voyage2.allToDoTasksCompleted.size &gt; 0, "voyage2 has no completed to do tasks");
	
	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoVoyage.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 4, "Incorrect amount of transactions have been created");
	
	// Check the complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_VOY_COMPLET, "The complete transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete voyageSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoJobWagon" id="9cc3884a-c7df-4fea-8944-ca53ebc7ddf3">
        <source>tToDoJobWagon();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/
constants
	REF: String  =  UT_DSL.TFS54344.String;
	MyWagon: String = REF &amp; "W";
	MyTrain: String = UT_DSL.TFS54344.String &amp; "T";
vars
	workorder : CM_WorkOrder;
	useYardJobsSetting : Any;
	train1, train2 : CM_Train;
	wagon1, wagon2 : CM_Wagon;
	wagonSet : CM_WagonSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	taskID	:	Integer;
	transaction	: CM_Transaction;
	toDoTaskDescSet     : CM_ToDoTaskDescBySortKey;
begin
	/*
	** Setup Section, create the work order with a ToDo wagon task with multiple wagons
	*/
	
	
	// Set the config to use yard jobs for the terminal	
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskWagon(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
											 
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_WAGON);

	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create Trains
	self.deleteTrainAndWagons(MyTrain &amp; "1");
	self.deleteTrainAndWagons(MyTrain &amp; "2");
	train1 := self.addTrain(MyTrain &amp; "1" , null);
	train2 := self.addTrain(MyTrain &amp; "2", null);
	
	// Assert the trains were create correctly
	self.assertNotNullMsg(train1, "Train1 was not creted correctly");
	self.assertNotNullMsg(train2, "Train2 was not creted correctly");
	
	// Create Wagons
	wagon1 := self.addWagon(MyWagon &amp; "1", "UK", train1);
	wagon2 := self.addWagon(MyWagon &amp; "2", "UK", train2);
	
	// Assert the wagons were created correctly
	self.assertNotNullMsg(wagon1, "Wagon 1 not created");
	self.assertNotNullMsg(wagon2, "Wagon 2 not created");

	// Add wagons to proxy
	create wagonSet transient;
	
	wagonSet.add(wagon1);
	wagonSet.add(wagon2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, wagonSet);
	
	// Check the work order is not null
	self.assertNotNullMsg(workorder, "The Work order was not created");
	
	// Check a create transaction has been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 1, "A transaction has not been created for creating the work order detail");
	
	// Check the work order has a task
	self.assertNotNullMsg(workorder.allWoDtls.first, "The work order has no tasks");
	
	// Check the create transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.first.type, TRANS_TYPE_WO_TODO_WGN_CREATED, "The create transaction is not the correct type");
	
	// Approve and Action the work order
	self.xApproveWorkOrder(workorder);
	
	
	/*
	**	Assert Section
	*/
	
	// Check that jobs have been created while actioning the work order
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.size &gt; 0, "No jobs have been create for this work order");
	
	// Check that the status of the work order detail has changed to action
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order has not been actioned or the status did not update correctly");
	
	// Check the request has been created and is the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.allRequests.first.isKindOf(CM_WOWagonToDoRequest), "The request is null or of the wrong type");

	// Check that the workorder detail has had transactions generated
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 2, "The incorrect number of transactions have been created");
	
	// Check that the transactions created are the correct type
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.first.isKindOf(CM_WOToDo_Wagon), "The incorrect transaction type has been created");
	
	// Check that work order details has wagons
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allWagons.size &gt; 0, "The work order detail doesnt not contian any wagons like it should");
	
	// Check that the work order detail has populated the jobs wagons
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.first.CM_WOToDoWagonJob.allWagons.size &gt; 0, "The jobs wagons set has not been populated");

	// Check that WLEs have been created
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.workListEntries.size &gt; 0, "The work order detail has no work list entries");
	
	// Check the To Do Task descriptions has been added to the work order details
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allToDoTasksDescs.size &gt; 0, "The work order detail has no to do tasks");
	
	// Check the To Do Task descriptions has been added to the job
	self.assertNotNullMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.CM_WOToDoWagonJob.myToDoTaskDesc, "The Job has not to do task");
	
	// Check the updated transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_WGN_UPDATED, "The update transaction is not the correct type");
	
	
	/*
	** Check the first wagon have the correct work order entities
	*/
	
	// Check the wagon has a job
	self.assertTrueMsg(wagon1.allWorkOrderJobs.size &gt; 0, "wagon1 has no work order jobs");
	
	// Check the wagon has a request
	self.assertTrueMsg(wagon1.allWorkOrderRequests.size &gt; 0, "wagon1 has no work order requests");
	
	// Check the wagon has a WLE
	self.assertTrueMsg(wagon1.allWorkOrderWLEs.size &gt; 0, "wagon1 has no work order WLEs");
	
	// Check the wagon has a toDoTask
	self.assertTrueMsg(wagon1.allToDoTasksToDo.size &gt; 0, "wagon1 has no work order toDoTasks");
	
	
	/*
	** Check the second wagon have the correct work order entities
	*/
	
	// Check the wagon has a job
	self.assertTrueMsg(wagon2.allWorkOrderJobs.size &gt; 0, "wagon2 has no work order jobs");
	
	// Check the wagon has a request
	self.assertTrueMsg(wagon2.allWorkOrderRequests.size &gt; 0, "wagon2 has no work order requests");
	
	// Check the wagon has a WLE
	self.assertTrueMsg(wagon2.allWorkOrderWLEs.size &gt; 0, "wagon2 has no work order WLEs");
	
	// Check the wagon has a toDoTask
	self.assertTrueMsg(wagon2.allToDoTasksToDo.size &gt; 0, "wagon2 has no work order toDoTasks");
	
	
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(wagon1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(wagon1.allToDoTasksCompleted.size &gt; 0, "wagon1 has no completed to do tasks");
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Check the job is part complete
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.status, 1, "The work order job has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(wagon2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);

	// Check the todo task has moved from to do to complete
	self.assertTrueMsg(wagon2.allToDoTasksCompleted.size &gt; 0, "wagon2 has no completed to do tasks");
	
	// Check the WLEs have been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.workListEntries.first.statusString, "Completed", "The first WLE has not been completed");
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.workListEntries.last.statusString, "Completed", "The second WLE has not been completed");

	// Check the job has been completed
	self.assertEqualMsg(workorder.allWoDtls.first.CM_WodToDoWagon.allJobs.first.status, 4, "The work order job has not been completed");
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	// Check that transactions have been created when completing
	self.assertTrueMsg(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allWODtlTransactions.size = 3, "Incorrect amount of transactions have been created");
	
	
	// Check the complete transaction we create
	self.assertEqualMsg(workorder.allWoDtls.first.allWODtlTransactions.last.type, TRANS_TYPE_WO_TODO_WGN_COMPLET, "The complete transaction is not the correct type");
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	
	delete wagonSet;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoTaskDescCargo" id="ee4ccc54-67ca-46d0-8a25-a06b534b6b36">
        <source>tToDoTaskDescCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2022	navds20	ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance

*/

constants
	ToDoTaskCode			             : String = "UT_10101";
	Type								 : Integer = TODO_TYPE_GROUP_TI;
	ShortDesc                            : String = "Paint Damaged";
	TaskRemarks                          : String = "UT Remarks";
vars
	ti                                   : CM_TrackedItem;
	operator	                         : CM_Operator;
	tiSet                                : CM_TISet;
	toDoTask                             : CM_ToDoTaskDesc;
	proxyToDoTask                        : CM_ToDoTaskDesc;
	tiUpdateCntrlr						 : CMIF_TIUpdateController;
begin
     
    toDoTask := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
    
	
	self.opts.purge();
	self.opts.addAssoc("RequiresExtraInfo", "Weight");
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_WEIGH);
	self.opts.addAssoc("Type", Type);
	
	toDoTask := self.createToDoTaskDesc(ToDoTaskCode);
	self.assertEqual(toDoTask.type, Type);
    
epilog
    delete proxyToDoTask;
	delete tiSet;
	delete tiUpdateCntrlr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoTaskDescNonOps" id="0941ca93-92e3-4f41-a562-ca9e9a17c3f4">
        <source>tToDoTaskDescNonOps();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Nov 2022	navcs2	ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance

*/

constants
	ToDoTaskCode			             : String = "UT_10101";
	Type								 : Integer = TODO_TYPE_GROUP_NONOPS;
	ShortDesc                            : String = "NonOps ToDo";
	TaskRemarks                          : String = "UT Remarks";
vars
	ti                                   : CM_TrackedItem;
	operator	                         : CM_Operator;
	tiSet                                : CM_TISet;
	toDoTask                             : CM_ToDoTaskDesc;
	proxyToDoTask                        : CM_ToDoTaskDesc;
	tiUpdateCntrlr						 : CMIF_TIUpdateController;
begin
    
    toDoTask := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
    
	
	self.opts.purge();
	self.opts.addAssoc("RequiresExtraInfo", "Weight");
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_WEIGH);
	self.opts.addAssoc("Type", Type);
	
	toDoTask := self.createToDoTaskDesc(ToDoTaskCode);
	self.assertEqual(toDoTask.type, Type);
    
	 
epilog
    delete proxyToDoTask;
	delete tiSet;
	delete tiUpdateCntrlr;
end;</source>
    </JadeMethod>
