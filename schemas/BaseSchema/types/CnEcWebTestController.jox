____________________________________________________________________________
An instance of this class is used to control the whole Web Test
process.  The following steps show how:

	1. Create an instance of this class;
	2. Add a list of Web Tests using the "addWebTests" method;
	3. Initiate the Test by invoking the "doRunTest" method.</text>
    <DbClassMap file="WebTest"/>
    <ImplicitInverseRef name="allMessageFields" id="0a61bf73-791a-4f00-8947-1b92519dde12">
        <memberTypeInverse/>
        <type name="CnEcWebTestMessageFieldArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allWebTests" id="9e3ec8ce-7e24-4318-a5ff-247013a15f86">
        <memberTypeInverse/>
        <type name="CnEcWebTestArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="isStopRequested" id="7094e9ff-eee1-4dd2-9d93-3a99db616869">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myTA" id="9c6f6bc6-de63-4eb7-bd99-cf819a41add6">
        <embedded/>
        <type name="CnEcWebTestAgent"/>
        <access>readonly</access>
