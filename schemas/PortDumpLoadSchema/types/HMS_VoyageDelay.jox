<Class name="HMS_VoyageDelay">
    <JadeMethod name="importPLXMLReference" id="fbc65019-2b56-452b-92fa-e156347ccf55">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_CheckPoint::myHarbour.name then
		return app.getMyHarbour();
	else
		return app.getMyHarbour().allRegions[_theCode];
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="theKey" id="2a4667af-50b3-4960-a64f-0ced157d6fdb">
        <source>theKey(): String;

vars

begin
	return self.startTime.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
