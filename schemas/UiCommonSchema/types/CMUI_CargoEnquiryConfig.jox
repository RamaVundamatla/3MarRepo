    <JadeMethod name="setGeneralCargoInfoRows" id="b4e58c36-aa55-4d9d-9cdd-c5771b9228a1">
        <source>setGeneralCargoInfoRows( _cargoType	: CM_CargoBOLType; _rowName : String ) : Boolean protected;
/*
*/
vars
	product	: CM_Product;
begin
	
	
	// 35199 handle cargo attributes of items with cargo type but no sub-type (product)
	if _cargoType.isKindOf(CM_CargoType) then
		product := _cargoType.CM_CargoType.mySystemProductType;
	endif;
	if product = null then
		return false;
	endif;
				
	// 35846 always show Total Weight - is not dependent on cargo type visibility
	///if (_rowName = ETRow_TotalWeight) and not product.isAttributeValidForCargoType(ETRow_MyWeight) then
	///		return true;	
	if (_rowName = ETRow_Volume) and not product.isAttributeValidForCargoType(ETRow_MyVolume) then
			return true;	
	elseif (_rowName = ETRow_Quantity) and not product.isAttributeValidForCargoType(ETRow_MyQuantity) then
			return true;	
	elseif (_rowName = ETRow_Density) and not product.isAttributeValidForCargoType(ETRow_Density) then
			return true;	
	elseif (_rowName = ETRow_Length) and not product.isAttributeValidForCargoType(ETRow_MyLength) then
			return true;	
	elseif (_rowName = ETRow_Height) and not product.isAttributeValidForCargoType(ETRow_MyHeight) then
			return true;	
	elseif (_rowName = ETRow_Width) and not product.isAttributeValidForCargoType(ETRow_MyWidth) then
			return true;	
	elseif (_rowName = ETRow_Pieces) and not product.isAttributeValidForCargoType(ETRow_Pieces) then
			return true;	
	elseif (_rowName = ETRow_WidthString) and not product.isAttributeValidForCargoType(ETRow_WidthString) then
			return true;	
	elseif (_rowName = ETRow_HeightString) and not product.isAttributeValidForCargoType(ETRow_HeightString) then
			return true;	
	elseif (_rowName = ETRow_LengthString) and not product.isAttributeValidForCargoType(ETRow_LengthString) then
			return true;	
	endif;
	return false;
end;
</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f6c05992-d340-4568-bd59-c670588f8174">
        <updating/>
        <source>setupForm() updating;

vars
	hadException	: Boolean;
	cargoBOLType	: CM_CargoBOLType;
begin

	on Exception do duplicateProxyException(exception, hadException);

	self.createMyAssistant(CMUI_Assistant);
	self.myUser := app.myPassport.myUser;
	self.caption := self.caption &amp; " " &amp; self.myUser.userName;

	inheritMethod();
	self.handleMenusForModalDisplay();
	// populate the cargo types and default to the current one from the cargo enquiry form, just cargo types not BOL types as well
	self.myAssistant.comboBoxCargoBolType(self.cmbCargoType, self.cargoTypeId, true, false, true, true);
	// Nov 2011 from 28374, not Logs as these have different enquiry and edit tables which is not handled here
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Log];
	self.cmbCargoType.removeObject(cargoBOLType);
	if self.cmbCargoType.listIndex = - 1 then		// no current cargo/BOL type or not one that has config, use the default
		cargoBOLType := app.myPassport.getDefaultCargoBOLType();
		self.cmbCargoType.listIndex := self.cmbCargoType.findObject(cargoBOLType);
	endif;
	self.doCargoTypeClick();
	if hadException then	// second form for same user/cargo type - just close this one
		unloadForm();
	endif;

	self.btnTabUp.enabled := false;
	self.btnTabDown.enabled := false;
	self.btnAttrAdd.enabled := false;
	self.btnAttrDown.enabled := false;
	self.btnAttrRemove.enabled := false;
	self.btnAttrUp.enabled := false;
	self.btnAttrUp.caption := 225.Character;
	self.btnAttrUp.fontName := "Wingdings";
	self.btnAttrUp.fontSize := 8;
	self.btnTabUp.caption := 225.Character;
	self.btnTabUp.fontName := "Wingdings";
	self.btnTabUp.fontSize := 8;
	self.btnAttrDown.caption := 226.Character;
	self.btnAttrDown.fontName := "Wingdings";
	self.btnAttrDown.fontSize := 8;
	self.btnTabDown.caption := 226.Character;
	self.btnTabDown.fontName := "Wingdings";
	self.btnTabDown.fontSize := 8;
	self.btnClose.width := self.btnAddTab.width;
	self.btnClose.height := self.btnCancel.height;
	
	self.tblTabs.selectionType := self.tblTabs.SelectionType_Row;	// single row selection
	self.tblAllAttributes.selectMode := self.tblTabs.SelectMode_WholeRows;	
	self.tblAllAttributes.selectionType := self.tblTabs.SelectionType_Row;	// single row selection
	self.tblAllAttributes.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	self.btnCopyTo.enabled := app.getMyUser().canDo(self.myTerminal, PmAdmCargoEnquiryConfigCopy);
end;
</source>
    </JadeMethod>
    <JadeMethod name="showTabsForCargoType" id="b258e216-4508-43df-ac36-df2526f39516">
        <updating/>
        <source>showTabsForCargoType(_getDefault : Boolean) updating, protected;

vars
	isDefault	: Boolean;
	idx,
	rows		: Integer;
	uctab		: CM_UserConfigTab;
begin
	delete self.myProxyUserCargoType;
	self.myProxyUserCargoType := self.myUser.getUserCargoTypeForEdit(self.myCargoType, _getDefault);
	
	self.tblTabs.rows := self.tblTabs.fixedRows;
	self.tblTabs.columns := 2;
	self.tblTabs.clearAllSelected();
	self.tblTabs.accessRow(1).fontBold := true;
	self.tblTabs.setCellText(1, 1, app.getErrorString(Sheets));
	self.tblTabs.setCellText(1, 2, app.getErrorString(Reefer));
	self.myUserConfigTab := null;
	self.btnDeleteTab.enabled := false;
	self.btnRenameTab.enabled := false;
	self.btnTabDown.enabled := false;
	self.btnTabUp.enabled := true;
	self.btnSave.enabled := false;
	
	self.tblTabs.columnWidth[2] := (self.tblTabs.width * .25).Integer;
	foreach uctab in self.myProxyUserCargoType.allUserConfigTabs do
		idx := self.tblTabs.addItemObject(uctab, uctab.description &amp; Tab &amp; uctab.tabType.String);
		self.tblTabs.accessCell(idx, 2).inputType := Table.InputType_CheckBox;
	endforeach;
	self.recolourTable(self.tblTabs);

	// select the first one
	if self.tblTabs.rows &gt; self.tblTabs.fixedRows then
		self.tblTabs.row := self.tblTabs.fixedRows + 1;
		self.tblTabs.selectRow(1, true);
		self.doTblTabsSelect();
	endif;
	self.chkUseDefault.value := self.myProxyUserCargoType.isDefault;
	
	self.populateAllAttributes();
end;
</source>
        <access>protected</access>
        <Parameter name="_getDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortAllAttributes" id="15453ffa-e139-4534-819e-d2ef9378d3f5">
        <updating/>
        <source>sortAllAttributes() updating, protected;

vars
	table		: CM_DataTable;

begin
	table := self.tblAllAttributes;
	table.sortAscending := not table.sortAscending;
	
	table.sortColumn[1]	:= 1;    
	table.sortAsc[1]	:= table.sortAscending;
	table.sortCased[1]	:= false;
	
	table.resort;

	if table.sortAscending then
		table.accessCell(1,1).text := "Attribute  ^";
	else
		table.accessCell(1,1).text := "Attribute  v";
	endif;
	
	self.recolourTable(table);
end;</source>
        <access>protected</access>
    </JadeMethod>
