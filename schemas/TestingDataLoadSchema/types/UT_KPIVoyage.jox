    <JadeMethod name="planDischargeItem" id="066ce3ad-0a1e-4801-aa18-9414bfcb4594">
        <source>planDischargeItem(_job : CM_VoyageJob);
// ---------------------------------------------------------------------------
// Created:     02 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyages : ObjectSet;
	voy : CM_Voyage;
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
begin
	//voy := self.getVoyage("OPSVIEW001");

	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("OPBS1");

	location := bs.allLocationsControllers.first;

	jobSheet:=voyage.allJobSheets["COV1"];

	job := _job;
	// Discharge ONLY
	if not job.CM_VoyageJob.isDischarge then
		return;
	endif;
		
	//### for each ti 
	foreach req in job.allRequests discreteLock do
		foreach wle in req.allWorkListEntries discreteLock do
			self.movePlannedWLE(wle.myTrackedItem, location, wle);
		endforeach;
	endforeach;

epilog
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="planDischargeItems" id="4e7f22a3-8cf7-477d-90c4-2be63b588ece">
        <source>planDischargeItems();
// ---------------------------------------------------------------------------
// Created:     02 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyages : ObjectSet;
	//voy : CM_Voyage;
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	trackedItem : CM_TrackedItem;
begin
	
	write "Plan discharge items";
	app.writeLog("Plan discharge items", LogINFO);
	
	//voy := self.getVoyage("OPSVIEW001");
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("OVBS1");
	
	/*
	self.updateYADisableAll(true);
	self.deleteYA("BISHYA");
	create voyages transient;
	voyages.add(voy);
	ya := self.addYA1("BISHYA", YACriteriaType_Voyage, voyages, bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	*/
	location := bs.allLocationsControllers.first;

	foreach job in voyage.allVoyageJobs  discreteLock do
	
		// Discharge ONLY
		if not job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		
		//### for each ti 
		foreach req in job.allRequests discreteLock do
	
			// PAR 30637
			if req.isSOB then
				continue;
			endif;
		
			foreach wle in req.allWorkListEntries discreteLock do
				self.movePlannedWLE(wle.myTrackedItem, location, wle);
			endforeach;
		endforeach;
	endforeach;
	
	// CHECK DISCHARGE
	foreach job in voyage.allVoyageJobs  discreteLock do
	
		// Discharge ONLY
		if not job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
	
			if req.isSOB then
				foreach wle in req.allWorkListEntries do
			if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isDischarge then
				self.deleteStops(wle.myTrackedItem);
				self.movePlanned(wle.myTrackedItem, wle.CM_VoyageWLE.myRequest.CM_SlotRequest.myRequestLinkedLoad.CM_SlotRequest.mySlotController);
			endif;
		endforeach;
			endif;
		endforeach;
		
		foreach wle in job.workListEntries do
			trackedItem := wle.myTrackedItem;
			if trackedItem &lt;&gt; null then
				self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null), trackedItem.id &amp; " Did not plan discharge");
			endif;
			
		endforeach;
	endforeach;
	
	
//	self.updateYADisableAll(false);

epilog
	//delete voyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="planLoadItemDLR_RORO" id="3c7fa3f4-fd2d-4a98-8242-777bf1ba5488">
        <updating/>
        <source>planLoadItemDLR_RORO(dlrID : String; dlrLocn : String; _dlrType : String) updating;
/*
Purpose:	PAR 28968 DLR between LOLO and RORO		
Date				Who			Reason
APRIL 2012		CNWAB1		Initial creation
*/


vars
//	jobSheet		: CM_VoyageJobSheet;
	//voyage 			: CM_Voyage;
	trackedItem 	: CM_TrackedItem;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	realAlloc : CM_YardAllocation;
	moves : CM_FutureMoveArray;
	firstReq : CM_RORORequest;
begin
	// PAR 28968
	
	//voyage := self.getVoyage("OPSVIEW001");
	
	create theTIs transient;
	create lcs transient;
	create moves transient;
	
	trackedItem := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container,dlrID];
	theTIs.add(trackedItem);
	
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	self.getJobROROControllerByID(voyage.code,DECK1, null, dlrLocn, lcs, true, 1);

	
	firstReq := lcs.first.getRequest(true).CM_RORORequest;
	realAlloc := firstReq.getVoyageAllocations().first;
	
	foreach trackedItem in theTIs discreteLock do
		if _dlrType = "DLR" then
			trackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMoveDLRLoad,moves );
		else
			trackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMoveSOB,moves );
		endif;
		
		self.assertTrueMsg(moves.isEmpty(),trackedItem.id &amp; " " &amp; _dlrType &amp; " is already planned for load.");
	endforeach;	

	self.planTIsRORO(theTIs,lcs, firstReq);
	
	self.logMessageNow(_dlrType &amp; " Plan " &amp; trackedItem.id);
	self.assertNoTrxErrorsPassport(" Load Plan of " &amp; _dlrType &amp; " " &amp; dlrID &amp; " Issues &gt;&gt; ");
	
	foreach trackedItem in theTIs discreteLock do
		self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null),trackedItem.id &amp; " " &amp; _dlrType &amp; " did not plan load.");
	endforeach;	

epilog
	delete theTIs;
	delete lcs;
	delete moveController;
	delete moves;
end;</source>
        <Parameter name="dlrID" type="String"/>
        <Parameter name="dlrLocn" type="String"/>
        <Parameter name="_dlrType" type="String"/>
    </JadeMethod>
    <JadeMethod name="planLoadItems" id="3ae85d1c-a9c0-4fad-884e-442941447257">
        <updating/>
        <source>planLoadItems() updating;
// cnwer1
/* 

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation

*/

vars
	tmpOptionsUsed 	: IntegerArray;
	slots : CM_SlotControllerArray;
	allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_Job;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode 			: Integer;
	//voyage 			: CM_Voyage;
	planIfStops,
	planFromRowEnds,
	useWeights,
	planAccrossTermArea,
	planAccrossTermAreaCol,
	ignoreWarnings,
	planTwinLift	: Boolean;
	
	height,
	numRowSep,
	weightAve,
	weightPC	: Integer;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	wles,wlesWithWarnings : CM_WLEArray;
begin
	
	write "Plan load items";
	app.writeLog("Plan load items", LogINFO);
	
	//need to delete all containers and recreate
	
	self.removeAllStops();
	self.removeAllRTS();
	
	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	mode:=3; //this is job mode voyage is 1 crane is 2
	//voyage := self.getVoyage("OPSVIEW001");
	jobSheet:=voyage.allJobSheets["COV1"];
	
	/*
		//result of trying to rerun this test
		//really should create the voyage and jobs before hand
		won't work if that one job has been completed need to create the job and delete it everytime
		job was marked up as 20 tl for discharge port BNE
	
	*/
	//there's only one job
	foreach job in voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		// 28522 Manually Plan the Prenotes
		if job.jobId = self.pnJobNum then
			continue;
		endif;
		allJobs.add(job);
	endforeach;

	/* the options that could be included
		VoyageFullPlanThirdHeight
		VoyageFullPlanGroundHeight
		VoyageFullPlanOSVoyage
		VoyageFullPlanOSDischPort
	*/
	
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,false, app.myPassport );
	planAccrossTermArea:=true;
	ignoreWarnings := true;
	
	//self.setYardAreaFlipped();
	controller.init(self.getTerminal,
					mode, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					planAccrossTermArea,
					planAccrossTermAreaCol,
					ignoreWarnings,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null); // DO THE LOAD PLAN


	
	// ### PAR 28522 PLAN THE PRENOTES
	//self.planLoadItemsPN();
	//self.planLoadItemsDLR();
	
epilog
	delete wles;
	delete wlesWithWarnings;
	delete lcs;
	delete theTIs;
	delete slots;
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete allJobSet;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="planLoadItemsDLR" id="dee50937-ccba-4072-971b-5b2a9ad7a222">
        <updating/>
        <source>planLoadItemsDLR() updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2011		CNWAB1		Initial creation
*/

vars
	tmpOptionsUsed 	: IntegerArray;
	slots : CM_SlotControllerArray;
	allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_Job;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode, idx 			: Integer;
	//voyage 			: CM_Voyage;

	
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
	wle : CM_WorkListEntry;
	slot : CM_SlotController;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	wles,wlesWithWarnings : CM_WLEArray;
	dlrID : String;

begin
	// THIS IS A TEST TO PLAN LOAD SOME PRENOTES, THEN UNPLAN THEM AND CHECK THAT THE WLE IS NOT COMPLETE, 
	
	// WE THEN DELETE THE JOB

	//voyage := self.getVoyage("OPSVIEW001");
	jobSheet:=voyage.allJobSheets["COV1"];
	
	// ### PAR 28522 PLAN THE PRENOTES
	create theTIs transient;
	dlrID := IdPrefix &amp; "D202233";
	
	foreach idx in 1 to 8 do
		trackedItem := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container,dlrID &amp; idx.String];
		theTIs.add(trackedItem);
	endforeach;
	
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	create slots transient;
	self.getJobSlotControllers(voyage.code,"05",DeckOnDeck,3,1,4,slots);
	self.getJobSlotControllers(voyage.code,"07",DeckOnDeck,3,1,4,slots);

	create lcs transient;
	slots.copy(lcs);
	create moveController transient;

	moveController.isRehandleMove := true;
	moveController.mySlotRequest := slots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	app.myPassport.setWarningsIgnored(true);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(theTIs, lcs, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach trackedItem in theTIs discreteLock do
		self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null),trackedItem.id &amp; " DLR did not plan load.");
	endforeach;	
	

epilog
	delete wles;
	delete wlesWithWarnings;
	delete lcs;
	delete theTIs;
	delete slots;
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete allJobSet;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="planLoadItemsDLR2" id="fda9900b-8724-46f3-9013-e5d6dbf811f9">
        <updating/>
        <source>planLoadItemsDLR2() updating;
/*
Purpose:	PAR 28968 DLR between LOLO and RORO		
Date				Who			Reason
APRIL 2012		CNWAB1		Initial creation
*/


vars
	jobSheet		: CM_VoyageJobSheet;
	//voyage 			: CM_Voyage;
	trackedItem 	: CM_TrackedItem;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	realAlloc : CM_YardAllocation;
begin
	// PAR 28968
	
	//voyage := self.getVoyage("OPSVIEW001");
	jobSheet:=voyage.allJobSheets["UT_KPI"];
	
	create theTIs transient;
	create lcs transient;
	
	trackedItem := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container,"DLRR2022452"];
	theTIs.add(trackedItem);
	
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN351", lcs, true, 1);

	realAlloc := lcs.first.getRequest(true).getVoyageAllocations().first;
	self.planTIsRORO(theTIs,lcs, realAlloc.CM_VoyageAllocation.allRequests.first.CM_RORORequest);
	
	self.assertNoTrxErrorsOrWarnings();
	
	foreach trackedItem in theTIs discreteLock do
		self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null),trackedItem.id &amp; " DLR did not plan load.");
	endforeach;	
	
	// ### SOB
	theTIs.clear();
	trackedItem := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container,"SOBB2022452"];
	theTIs.add(trackedItem);
	
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN302", lcs, true, 1);

	realAlloc := lcs.first.getRequest(true).getVoyageAllocations().first;
	self.planTIsRORO(theTIs,lcs, realAlloc.CM_VoyageAllocation.allRequests.first.CM_RORORequest);
	
	self.assertNoTrxErrorsOrWarnings();
	
	foreach trackedItem in theTIs discreteLock do
		self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null),trackedItem.id &amp; " SOB did not plan load.");
	endforeach;	
epilog
	delete theTIs;
	delete lcs;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="planLoadItemsPN" id="2fe2306c-fe34-4fc2-86f5-4eada99185c8">
        <updating/>
        <source>planLoadItemsPN() updating;
// cnwer1
/* 

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation

*/
vars
	tmpOptionsUsed 	: IntegerArray;
	slots : CM_SlotControllerArray;
	allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_Job;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode, idx 			: Integer;
	//voyage 			: CM_Voyage;

	
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
	wle : CM_WorkListEntry;
	slot : CM_SlotController;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	wles,wlesWithWarnings : CM_WLEArray;
begin
	// THIS IS A TEST TO PLAN LOAD SOME PRENOTES, THEN UNPLAN THEM AND CHECK THAT THE WLE IS NOT COMPLETE, 
	
	// WE THEN DELETE THE JOB

	//voyage := self.getVoyage("OPSVIEW001");
	jobSheet:=voyage.allJobSheets["COV1"];
	
	// ### PAR 28522 PLAN THE PRENOTES
	create theTIs transient;
	trackedItem := self.getTerminal().allNotifiedTIsByCargoTypeId[TI_CargoType_Container, IdPrefix &amp; "P8899001"];
	theTIs.add(trackedItem);
	trackedItem := self.getTerminal().allNotifiedTIsByCargoTypeId[TI_CargoType_Container, IdPrefix &amp; "P8899002"];
	theTIs.add(trackedItem);
	trackedItem := self.getTerminal().allNotifiedTIsByCargoTypeId[TI_CargoType_Container, IdPrefix &amp; "P8899003"];
	theTIs.add(trackedItem);
	trackedItem := self.getTerminal().allNotifiedTIsByCargoTypeId[TI_CargoType_Container, IdPrefix &amp; "P8899004"];
	theTIs.add(trackedItem);

	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	create slots transient;
	self.getJobSlotControllers(voyage.code,"05",DeckOnDeck,1,1,4,slots);

	create lcs transient;
	slots.copy(lcs);
	create moveController transient;

	moveController.isRehandleMove := false;
	moveController.mySlotRequest := slots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	app.myPassport.setWarningsIgnored(true);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(theTIs, lcs, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach trackedItem in theTIs discreteLock do
		self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null),trackedItem.id &amp; " Prenote did not plan load.");
	endforeach;	
	
	create wles transient;
	create wlesWithWarnings transient;
	foreach trackedItem in theTIs discreteLock do
		wles.add(trackedItem.getVoyageWLEUnactioned(true));
	endforeach;
	
	app.myTrxUA.trxUpdateWLEsUnplan(wles, wlesWithWarnings, NO_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	foreach trackedItem in theTIs discreteLock do
		self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation = null),trackedItem.id &amp; " Prenote did not unplan load.");
	endforeach;	

	foreach wle in wles discreteLock do
		self.assertTrueMsg((wle.status = WLE_UNACTIONED),"ERROR: " &amp; wle.id &amp; " Prenote WLE  unplan set WLE status to complete.");
	endforeach;
	self.deleteVoyageJob(voyage,"COV1",self.pnJobNum);

	
epilog
	delete wles;
	delete wlesWithWarnings;
	delete lcs;
	delete theTIs;
	delete slots;
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete allJobSet;
	delete moveController;
end;</source>
    </JadeMethod>
