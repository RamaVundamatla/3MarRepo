        <source>setFrom(_leg: CM_KPIMovementLegDtl) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2012	cnwdw1	Initial creation
*/
vars

begin
	self.duration := _leg.duration;
	self.travelDuration := _leg.travelDuration;
	self.finishTime := _leg.finishTime.asStringForWebInterface;
	self.machineId := _leg.machineId;
	self.machineType := _leg.machineType;
	self.source := _leg.source;
	self.sourceType := _leg.sourceType;
	self.startTime := _leg.startTime.asStringForWebInterface;
	self.target := _leg.target;
	self.targetType := _leg.targetType;
epilog

end;</source>
