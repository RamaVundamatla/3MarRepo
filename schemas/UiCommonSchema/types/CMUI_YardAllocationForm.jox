    <JadeMethod name="doResize" id="45035b7a-a5f1-4dd3-989e-6d818ab1276c">
        <updating/>
        <source>doResize() updating;
// --------------------------------------------------------------------------------
// Created:		29 March 2006 by cnwdad1
//
// Purpose:		Standard method that is invoked when the receiver is reseized.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	topPosition	: Real;
	
begin
	inheritMethod();
	
	topPosition	:=	frmToolbar.top + frmToolbar.height + 5;
	
	lblYardAlloc.top	:=	topPosition;
	cmbYardAlloc.top	:=	topPosition;
	ctrlYardAlloc.top	:=	lblYardAlloc.top + lblYardAlloc.height + 5;
	self.height			:=	ctrlYardAlloc.top + ctrlYardAlloc.height + 38;
	
end;</source>
    </JadeMethod>
