    <JadeMethod name="sdlGetWorkOrderWRecpt" id="136d174b-8158-4db7-a811-249887fa8611">
        <source>sdlGetWorkOrderWRecpt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2019	jlgsl4	TFS 45163 - PEL1 - Receival card is not being populated

*/

vars
	workOrder : CM_WorkOrderVoyage;
	count : Integer;
	voyage : CM_Voyage;
	tiSet : CM_TISet;
	id : String;
begin
	app.initialize();
	create tiSet transient;
	foreach workOrder in CM_WorkOrderVoyage.instances where workOrder.allCashReceipts.isNotEmpty and not workOrder.myVoyage.archived do
		voyage := workOrder.myVoyage;
		workOrder.getAllTIs(tiSet);
		if tiSet.isNotEmpty() then
			id := tiSet.first.id;
		else
			id := 'n.a.';
		endif;
		write workOrder.id &amp; ' has ' &amp; workOrder.allInvoices.size.asStringJMT &amp; ' invoices, is in terminal ' &amp; voyage.myTerminal.code &amp;
			' on voyage ' &amp; voyage.code &amp; ' which departed on ' &amp; voyage.departedDT.asStringJMT &amp; ' and its first item is ' &amp; id;
		count := count + 1;
		if count &gt; 100 then
			break;
		endif;
	endforeach;
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlGetWorkOrdersforVyg" id="232563f8-59d6-4737-b927-26d5441c0788">
        <source>sdlGetWorkOrdersforVyg();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jun 2019	jlgsl4	TFS 45163 - PEL1 - Receival card is not being populated

*/

vars
	workOrder : CM_WorkOrderVoyage;
	tiSet : CM_TISet;
	trackedItem : CM_TrackedItem;
	id, vvrReg, fwdrDesc : String;
begin
	app.initialize(); // comment out/remove when running in UI
	create tiSet transient;
	foreach workOrder in CM_WorkOrderVoyage.instances where workOrder.id = '20190500023-A001' do // Pelindo w/o that receipt doesn't print for...
		workOrder.getAllTIs(tiSet);
		vvrReg := 'n.a.';
		fwdrDesc := vvrReg;
		id := vvrReg;
		if tiSet.isNotEmpty() then
			trackedItem := tiSet.first;
			id := trackedItem.id;
			if trackedItem.getVehicleVisit &lt;&gt; null then
				vvrReg := trackedItem.getVehicleVisit.regNumber;
			endif;
			if trackedItem.myFreightForwarder &lt;&gt; null then
				fwdrDesc := trackedItem.myFreightForwarder.description;
			endif;		
		endif;
		app.writeLog('**********' &amp; class.name &amp; '::' &amp; method.name &amp; ' - Work order ' &amp; workOrder.id &amp; ' has ' &amp; workOrder.allInvoices.size.asStringJMT &amp; ' invoices and ' &amp;
			workOrder.allCashReceipts.size.asStringJMT &amp; ' cash receipts; its tracked item has ID ' &amp; id &amp; ', its vehicle reg is ' &amp; vvrReg &amp; ' and its forwarder is ' &amp; fwdrDesc, LogINFO);
	endforeach;
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlGlobalVoyagesIPNPEL1" id="160c1545-9c7e-49c4-b9e8-b24aeda99889">
        <source>sdlGlobalVoyagesIPNPEL1();
/*

Purpose:	List all IPN or PEL1 CM_VoyageGlobal		

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	voyageGlobal : CM_VoyageGlobal;
	voyage : CM_Voyage;
	countIPNorPEL1 : Integer;
	countDefault : Integer;
begin
	app.initialize();
	foreach voyageGlobal in CM_VoyageGlobal.instances where voyageGlobal.allVoyages.size &gt; 0 do
		countIPNorPEL1 := 0;
		countDefault := 0;
		foreach voyage in voyageGlobal.allVoyages do
			if voyage.myVoyageProcess &lt;&gt; CM_VoyageProcessDefault.firstInstance then
				countIPNorPEL1 := countIPNorPEL1 + 1;
			else
				countDefault := countDefault + 1;
			endif;
		endforeach;
		if (countIPNorPEL1 = voyageGlobal.allVoyages.size) or (countIPNorPEL1 &gt; 0 and countDefault = 0) then
			//write voyageGlobal.code &amp; " has all IPN or PEL1 voyages";
		elseif countDefault = voyageGlobal.allVoyages.size  or (countDefault &gt; 0 and countIPNorPEL1 = 0) then 
			//write voyageGlobal.code &amp; " has all Default voyages";
		elseif countDefault + countIPNorPEL1 = voyageGlobal.allVoyages.size then
			write voyageGlobal.code &amp; " has " &amp; countDefault.String &amp; " default and " &amp; countIPNorPEL1.String &amp; " IPN or PEL1 processes";			
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
