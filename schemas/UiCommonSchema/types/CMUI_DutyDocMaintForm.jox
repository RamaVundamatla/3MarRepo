    <JadeMethod name="loadDutyDoc" id="be45cd95-bc22-4206-be5b-474f86870a84">
        <source>loadDutyDoc(_loadDataEntry: Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	forwarder, consignee : CM_ConsigneeConsignor;
	voyage : CM_Voyage;
	bol: CM_BOL;
	startIdx : Integer;
	deliveryOrderExpiryTS : TimeStamp;
	effectiveTS 		  : TimeStamp;
	licenseExpiryTS 	  : TimeStamp;
begin
	
	if self.myDutyDoc = null then
		self.lblBillNoVal.caption:=null;
		//self.chkDataEntry.value:=true;  // cnwma1 31/07/2014 PAR 34408
		self.setEffectiveDate();
		return;
	endif;
	self.lblBillNoVal.caption:=self.myDutyDoc.id;
	self.txtTicket.text := self.myDutyDoc.ticket;
	self.txtDelivery.text:=self.myDutyDoc.deliveryOrder;
	self.txtDriver.text:=self.myDutyDoc.driver;
	self.txtManifest.text:=self.myDutyDoc.manifest;
	self.txtReexport.text:=self.myDutyDoc.reExportNumber;
	self.txtShipTruck.text:=self.myDutyDoc.transportation;
	deliveryOrderExpiryTS.cnEcSetDateAndTime(self.myDutyDoc.deliveryOrderExpiryDate,TimeEndOfDay);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtDelExpiry.setDate(self.systemToLocalTime(deliveryOrderExpiryTS).date());				// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtExitPort.text:= self.myDutyDoc.exitPort;
	self.chkDocDeposit.value:=self.myDutyDoc.docDeposit;
	self.txtDeposit.text:=self.myDutyDoc.dutyDeposit.asStringJMT();
	self.cmbCustomsInsp.text:=self.myDutyDoc.customsInspectorUser;
	self.txtReason.text:=self.myDutyDoc.reason;
	self.txtCustRemarks.text:=self.myDutyDoc.customRemarks;
	self.txtRemarks.text:=self.myDutyDoc.remarks;
	effectiveTS.cnEcSetDateAndTime(self.myDutyDoc.effectiveDate,TimeStartOfDay);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtEffectiveDate.setDate(self.systemToLocalTime(effectiveTS).date());						// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtGoodsDesc.text := self.myDutyDoc.goodsDescription; //08 Aug 2013	NDL	Par 32305
	self.txtDestination.text:=self.myDutyDoc.destination;  // PAR 32924
	
	voyage := self.myDutyDoc.getMyVoyage();
	if voyage &lt;&gt; null then
		self.cmbVoyage.setIndexFromObject(voyage);
	endif;
	
	forwarder := self.myDutyDoc.getMyForwarder();
	if forwarder &lt;&gt; null then
		self.cmbForwarder.setIndexFromObject(forwarder);
		licenseExpiryTS.cnEcSetDateAndTime(forwarder.licenseExpiryDate,TimeEndOfDay);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.lblForExpiryVal.caption := self.systemToLocalTime(licenseExpiryTS).date().asStringJMT();	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		// PAR 32897
		if forwarder.hasExpired then
			self.lblForExpiryVal.foreColor := Red;
		else
			self.lblForExpiryVal.foreColor := Black;
		endif;
	endif;

	consignee:= self.myDutyDoc.getMyConsignee();
	if consignee &lt;&gt; null then
		self.cmbConsignee.setIndexFromObject(consignee);
		licenseExpiryTS.cnEcSetDateAndTime(consignee.licenseExpiryDate,TimeEndOfDay);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.lblConExpiryVal.caption := self.systemToLocalTime(licenseExpiryTS).date().asStringJMT();	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		// PAR 32897
		if consignee.hasExpired then
			self.lblConExpiryVal.foreColor := Red;
		else
			self.lblConExpiryVal.foreColor := Black;
		endif;
	endif; 
	
	if self.myDutyDoc.border &lt;&gt; null then
		startIdx:=1;
		self.cmbBorder.listIndex := self.cmbBorder.findStringExact(startIdx,self.myDutyDoc.border);
	endif;
		
	if self.myDutyDoc.gcCountry &lt;&gt; null then
		startIdx:=1;
		self.cmbGCCountry.listIndex := self.cmbGCCountry.findStringExact(startIdx,self.myDutyDoc.gcCountry);
	endif;

	self.cmbStatus.setIndexForItemData(self.myDutyDoc.status);
		
	if self.myDutyDoc.invTerms &lt;&gt; null then
		startIdx:=1;
		self.cmbInvTerms.listIndex:=self.cmbInvTerms.findStringExact(startIdx,self.myDutyDoc.invTerms);	
	endif;
	
	if self.myDutyDoc.type &lt;&gt; null then
		startIdx:=1;
		self.cmbBillType.listIndex:=self.cmbBillType.findStringExact(startIdx,self.myDutyDoc.type);
	endif;
	
	self.lblBOLValue.caption := self.myDutyDoc.bol;
	self.lblPOLValue.caption := self.myDutyDoc.loadPort;
	self.lblPODValue.caption := self.myDutyDoc.dischargePort;  // PAR 32924

	
	if _loadDataEntry then
		self.chkDataEntry.value:=false;
		if self.myDutyDoc.dutyDocUserId &lt;&gt; null then
			self.chkDataEntry.value:=true;
			self.lblDataEntryUser.caption:=self.myDutyDoc.dutyDocUserId;
		endif;
	endif;
	
	self.chkDocInCharge.value:=false;
	if self.myDutyDoc.docInChargeUserId &lt;&gt; null then
		self.chkDocInCharge.value:=true;
		self.lblDocInCharge.caption:=self.myDutyDoc.docInChargeUserId;
	endif;
	
	self.chkSupervisor.value:=false;
	if self.myDutyDoc.supervisorUserId &lt;&gt; null then
		self.chkSupervisor.value:=true;
		self.lblSupervisor.caption:=self.myDutyDoc.supervisorUserId;
	endif;
	
	self.chkGroupSuper.value:=false;
	if self.myDutyDoc.groupSuperUserId &lt;&gt; null then
		self.chkGroupSuper.value:=true;
		self.lblGroupSuper.caption:=self.myDutyDoc.groupSuperUserId;
	endif;
	
	self.loadDutyDocItems();
epilog
	self.setControlsForPermissions();
	

end;</source>
        <access>protected</access>
        <Parameter name="_loadDataEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDutyDocItems" id="86071515-5062-4bda-87b3-6dc0234deaad">
        <source>loadDutyDocItems() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	dutyDocItem: CM_DutyDocItem;
	forwarder: CM_ConsigneeConsignor;
	voyage: CM_Voyage;
	licenseExpiryTS 	  : TimeStamp;
	deliveryOrderExpiryTS : TimeStamp;
begin
	self.tblDutyDocItems.rows:= self.tblDutyDocItems.fixedRows;
	self.tblDutyDocItems.displayRowsForCollection(self.myDutyDoc.allDutyDocItems, self.tblDutyDocItems.backColor, self.tblDutyDocItems.backColor, app.myPassport);

	self.btnPrintCar.visible := false;
	
	// Populate duty doc values from the duty doc item
	if self.myDutyDoc.allDutyDocItems.size &gt; 0 then
		dutyDocItem := self.myDutyDoc.allDutyDocItems.first;
		
		if self.cmbForwarder.listObject = null then
			forwarder :=  dutyDocItem.getMyFreightForwarder;
			if forwarder &lt;&gt; null then
				self.cmbForwarder.setIndexFromObject(forwarder);
				licenseExpiryTS.cnEcSetDateAndTime(forwarder.licenseExpiryDate,TimeEndOfDay);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.lblForExpiryVal.caption := self.systemToLocalTime(licenseExpiryTS).date().asStringJMT();	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				// PAR 32897
				if forwarder.hasExpired then
					self.lblForExpiryVal.foreColor := Red;
				else
					self.lblForExpiryVal.foreColor := Black;
				endif;
			endif;
		endif;
		
		if self.cmbVoyage.listObject = null then
			voyage := dutyDocItem.getMyVoyage;
			if voyage &lt;&gt; null then
				self.cmbVoyage.setIndexFromObject(voyage);
			endif;
		endif;
		
		if self.txtDelivery.text = null then
			self.txtDelivery.text := dutyDocItem.deliveryOrder;
			deliveryOrderExpiryTS.cnEcSetDateAndTime(dutyDocItem.deliveryOrderExpiryDate,TimeEndOfDay);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.txtDelExpiry.setDate(self.systemToLocalTime(deliveryOrderExpiryTS).date());			// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		if self.lblBOLValue.caption = null then
			self.lblBOLValue.caption := dutyDocItem.bol;
		endif;
		
		if self.lblPOLValue.caption = null then
			self.lblPOLValue.caption := dutyDocItem.pol;
		endif;
		
		if self.lblPODValue.caption = null then
			if dutyDocItem.getMyTrackedItem &lt;&gt; null then	//30 Jan 2014	NDL	Par 33181
				self.lblPODValue.caption := dutyDocItem.getMyTrackedItem.dischargePort;  // PAR 32924
			endif;
		endif;
	endif;
	self.summarizeItems;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
