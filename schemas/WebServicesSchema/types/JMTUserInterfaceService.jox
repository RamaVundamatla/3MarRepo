        <source>getUserPreferences(queryRequest : WS_UserPrefQueryRequest) : WS_UserPrefQueryResponse webService;

//KO - This method will not work with the new user preference behaviour, as such it should not be invoked and it can be deleted.

vars
	queryResp		: WS_UserPrefQueryResponse;
