    <JadeMethod name="doBtnTermSubAreaRemove" id="e0442730-7ce5-4375-be9b-2ac3b845bcc0">
        <updating/>
        <source>doBtnTermSubAreaRemove()updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	rtnValue : Boolean;
	theReturn,theIndex : Integer;
	theLCS : CM_LCArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	self.frmGridArea.enabled := false;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Sub Area","Removing...");
	self.tblOther.clearValues();
	
	// ## save these for updating the GUI
	create theLCS transient;
	self.myCurrentTermSubArea.allYardControllers.copy(theLCS);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteTerminalSubArea(self.myCurrentTermSubArea, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Sub Area', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.myCurrentTermSubArea := null;

epilog
	self.frmModalDialog.visible := false;
	delete theLCS;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTermSubAreaSave" id="a83f292d-a228-471a-a6ad-6cd90d85b808">
        <updating/>
        <source>doBtnTermSubAreaSave()updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	result : Integer;
	aPoint : CMUI_GridPoint;
	loadStateSet : Boolean;
	aController, tmpLC : CM_LocationsController;
	newTermSubArea : CM_TerminalSubArea;
	theLocations : CM_YardControllerSet ;
	theIndex : Integer;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Sub Area","Saving...");
	// ################################
	// ### SET UP PROXY
	if self.myCurrentTermSubArea &lt;&gt; null then
		theIndex := self.lstRestrictions.findObject(self.myCurrentTermSubArea);
	else
		theIndex := self.getListIndexForAdd();
	endif;
	if self.mode = self.Mode_Add then
		// Create a proxy
		create self.myProxyTermSubArea as CM_TerminalSubArea transient;
	endif;
	
//	create theLCS transient;
	if self.mode = self.Mode_Update then
		// keep these for updating GUI
		app.cmsBeginLoad(loadStateSet);
		self.myProxyTermSubArea := app.createUpdateProxy(self.myCurrentTermSubArea).CM_TerminalSubArea; 
	
		app.cmsEndLoad(loadStateSet);
	endif;	

	create theLocations transient;

	if self.myCurrentTerminalArea.isRestrictionBlockStack() then
		if self.myCurrentTerminalArea.isKindOf(CM_Depot) then 
			theLocations.add(self.myCurrentTerminalArea.CM_Depot.myLocationsController);	 
		else
			theLocations.add(self.myCurrentTerminalArea.CM_BlockStack.myLocationsController);	
		endif;
	else
		foreach aPoint in self.frmGridArea.myGridArea.allSelectedPoints do
			aController := aPoint.myLocationsController;
			if aController &lt;&gt; null then
				if aController .isKindOf(CM_YardController) then 
					if not theLocations.includes(aController.CM_YardController)then
						theLocations.add(aController.CM_YardController);
					endif;
					
					if aController.isKindOf(CM_GridController) then
						tmpLC := aController.CM_GridController.getMyNextController(CM_GapController);
						if tmpLC &lt;&gt; null and not theLocations.includes(tmpLC.CM_YardController)then
							theLocations.add(tmpLC.CM_YardController);
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	self.myProxyTermSubArea.setProxy(self.tblOther.getValueByName(ETRow_Id).String,
										self.tblOther.getValueByName(ETRow_Colour).Integer,
										self.myCurrentTerminalArea,
										theLocations);
	
												
	self.modalDialogShow(null, 'Cancel', null, null, "Sub Area " &amp;  self.myProxyTermSubArea.id,"Saving...");
	// ################################
	// ### TRX IT
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateTerminalSubArea(self.myProxyTermSubArea, newTermSubArea, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.myCurrentTermSubArea := newTermSubArea;
			endif;
		else
			app.myTrxUA.trxUpdateTerminalSubArea(self.myProxyTermSubArea, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Sub Area', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	// ################################
	// ### CLEAN UP GUI
	self.frmGridArea.enabled := false;
	self.doEnableControls(false);

epilog
	
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	self.frmModalDialog.visible := false;

	delete self.myProxyTermSubArea;
	delete theLocations;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMenuHeights" id="2af7fb92-8581-4c75-8ac4-5c96e3da5d4e">
        <source>doBuildMenuHeights();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	maxHeight : Integer;
begin

	self.mnuHeights.visible := false;
	self.btnPenPower.enabled := false;
	self.btnPenPowerDam.enabled := false;
	self.btnPenUnavail.enabled := false;
	self.btnPenAvail.enabled := false;
	
	self.mnuHPadAvail.visible := false;
	self.mnuHPadUnavail.visible := false;
	self.mnuHPowerDamaged.visible := false;
	self.mnuHPowerGood.visible := false;
	self.mnuLegend.visible := false;
			
	self.mnuHNothing1.visible := false;
	self.mnuHNothing2.visible := false;
	self.mnuHNothing3.visible := false;
	self.mnuHNothing4.visible := false;
	self.mnuHNothing5.visible := false;
	self.mnuHNothing6.visible := false;
	self.mnuHNothing7.visible := false;
	self.mnuHNothing8.visible := false;
	
	self.btnPenHeight1.visible := false;
	self.btnPenHeight2.visible := false;
	self.btnPenHeight3.visible := false;
	self.btnPenHeight4.visible := false;
	self.btnPenHeight5.visible := false;
	self.btnPenHeight6.visible := false;
	self.btnPenHeight7.visible := false;
	self.btnPenHeight8.visible := false;
	
	self.btnPenHeight1.enabled := false;
	self.btnPenHeight2.enabled := false;
	self.btnPenHeight3.enabled := false;
	self.btnPenHeight4.enabled := false;
	self.btnPenHeight5.enabled := false;
	self.btnPenHeight6.enabled := false;
	self.btnPenHeight7.enabled := false;
	self.btnPenHeight8.enabled := false;
	
	if self.myCurrentTerminalArea = null then
		return;
	endif;
	if self.myCurrentTerminalArea.isRestrictionBlockStack() then
		return;
	endif;
	
//	if self.frmGridArea.myGridArea.YRD_PadArea.areaMode &lt;&gt; YRD_PadArea.AreaMode_Height then
//		self.mnuHeights.visible := false;
//		return;
//	endif;
	//cnwjo3
	if self.myCurrentTerminalArea.isKindOf(CM_GridArea) then
		maxHeight := self.myCurrentTerminalArea.CM_GridArea.heightOfStack;
	else
		maxHeight := 1;
	endif;

//	if self.mode = self.Mode_View then
//		return;
//	endif;
	
	self.mnuHeights.visible := true;
	if self.frmGridArea.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_Height
	and self.mode &lt;&gt; self.Mode_View then
app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " "  );		
		self.mnuHPadAvail.visible := true;
		self.mnuHPadUnavail.visible := true;
		self.mnuHPowerDamaged.visible := true;
		self.mnuHPowerGood.visible := true;
		self.mnuLegend.visible := true;
		
		self.btnPenPower.enabled := true;
		self.btnPenUnavail.enabled := true;
		self.btnPenPowerDam.enabled := true;
		self.btnPenAvail.enabled := true;

		self.btnPenHeight1.enabled := true;
		self.btnPenHeight2.enabled := true;
		self.btnPenHeight3.enabled := true;
		self.btnPenHeight4.enabled := true;
		self.btnPenHeight5.enabled := true;
		self.btnPenHeight6.enabled := true;
		self.btnPenHeight7.enabled := true;
		self.btnPenHeight8.enabled := true;
				
	//	self.mnuHNothing1.visible := false;
	//	self.mnuHNothing2.visible := false;
	//	self.mnuHNothing3.visible := false;
	//	self.mnuHNothing4.visible := false;
	//	self.mnuHNothing5.visible := false;
	//	self.mnuHNothing6.visible := false;
	//	self.mnuHNothing7.visible := false;
	//	self.mnuHNothing8.visible := false;
//
//		self.btnPenHeight1.visible := false;
//		self.btnPenHeight2.visible := false;
//		self.btnPenHeight3.visible := false;
//		self.btnPenHeight4.visible := false;
//		self.btnPenHeight5.visible := false;
//		self.btnPenHeight6.visible := false;
//		self.btnPenHeight7.visible := false;
//		self.btnPenHeight8.visible := false;
	endif;

	if maxHeight &gt;= 1 then 
		self.mnuHNothing1.visible := true;
		self.btnPenHeight1.visible := true;
	endif;
	if maxHeight &gt;= 2 then 
		self.mnuHNothing2.visible := true;
		self.btnPenHeight2.visible := true;
	endif;
	if maxHeight &gt;= 3 then 
		self.mnuHNothing3.visible := true;
		self.btnPenHeight3.visible := true;
	endif;
	if maxHeight &gt;= 4 then 
		self.mnuHNothing4.visible := true;
		self.btnPenHeight4.visible := true;
	endif;
	if maxHeight &gt;= 5 then 
		self.mnuHNothing5.visible := true;
		self.btnPenHeight5.visible := true;
	endif;
	if maxHeight &gt;= 6 then 
		self.mnuHNothing6.visible := true;
		self.btnPenHeight6.visible := true;
	endif;
	if maxHeight &gt;= 7 then 
		self.mnuHNothing7.visible := true;
		self.mnuHNothing8.visible := true;
		self.btnPenHeight7.visible := true;
		self.btnPenHeight8.visible := true;
	endif;

epilog
	self.frmToolbar.positionToolbarControls();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="53bf0179-1366-4be8-82b3-e9b2aca493e1">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions
// 23/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars
	areaMode : Integer;
begin
	areaMode :=  self.theAreaMode;
	
	if areaMode = YRD_PadArea.AreaMode_SubBlock then
		self.doBtnSubCancel();

	elseif areaMode = YRD_PadArea.AreaMode_Height then
		self.doBtnHeightCancel();
	
	elseif areaMode = YRD_PadArea.AreaMode_Labour then
		self.doBtnLabourCancel();
	
	elseif areaMode = YRD_PadArea.AreaMode_TermSubArea then 
		self.doBtnTermSubAreaCancel();
	
	elseif areaMode = YRD_PadArea.AreaMode_DoorDirection then 
		self.doBtnDoorDirectionRuleCancel();
		
	elseif areaMode = YRD_PadArea.AreaMode_Hazardous then				// TFS 2844
		self.doBtnHazardsCancel();										// TFS 2844
		
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doComboTermAreaClick" id="b78bca70-0509-4c4f-82a6-32da765137bd">
        <updating/>
        <source>doComboTermAreaClick(_combo: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - removing location restrictions
// 07/02/2017 cnwrh7         TFS3212       Tidy up other YardLocation bugs found duirng test
vars

begin
	if _combo.listObject = null then
		return;
	endif;
	
	self.myCurrentTerminalArea := _combo.listObject.CM_TerminalArea;
	
	self.doShowTerminalArea(self.myCurrentTerminalArea);
	
	self.btnNewTV.enabled 		:= false;
	self.btnEditTV.enabled 		:= false;
	self.btnDeleteTV.enabled 	:= false;
	
	self.sptThumbEdit.hideLeftControl(true);
	
	// TFS 2198 CNWAB1			//+TFS3212
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.lstRestrictions.listIndex := 2;
		self.doLstRestrictionsClick(self.lstRestrictions);
	endif;
	
	// we are now showing something so suspend the blank sheet
	self.setNotifications();
	self.doMenuHeightsHide(true, true);
	self.doBuildMenuHeights();
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="dc06afbb-fc19-4cbc-b062-a5730310cbd5">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - removed references to location restrictions
// 23/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars
	areaMode : Integer;
begin
	areaMode :=  self.theAreaMode;
	
	if areaMode = YRD_PadArea.AreaMode_SubBlock then
		self.doBtnSubRemove();
	
	elseif areaMode = YRD_PadArea.AreaMode_Height then
	
	elseif areaMode = YRD_PadArea.AreaMode_Labour then
		self.doBtnLabourRemove();
	
	elseif areaMode = YRD_PadArea.AreaMode_TermSubArea then 
		self.doBtnTermSubAreaRemove();
	
	elseif areaMode = YRD_PadArea.AreaMode_DoorDirection then 
		self.doBtnDoorDirectionRuleRemove();
		
	elseif areaMode = YRD_PadArea.AreaMode_Hazardous then			// TFS 2844
		self.doBtnHazardsRemove();									// TFS 2844
		
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawGridArea" id="82641346-c9bf-4c05-b7a1-0e34fb0432f1">
        <updating/>
        <source>doDrawGridArea() updating;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	cmuiGridArea : CMUI_GridArea;
	areaName : String;
	areaMode : Integer;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	if self.frmGridArea.myGridArea &lt;&gt; null then
		areaMode := self.frmGridArea.myGridArea.YRD_PadArea.areaMode;
		self.sptThumbEdit.showRightControl(65, true);
	else
		if self.amInitialisingWithObject then
			areaMode := self.theAreaMode;
		else
			areaMode := YRD_PadArea.AreaMode_Height;
			self.sptThumbEdit.hideLeftControl(true);
		endif;
		self.sptThumbEdit.showRightControl(65, true);
	endif;
	cmuiGridArea := self.frmGridArea.myGridArea;
	delete cmuiGridArea;
	areaName := self.myCurrentTerminalArea.id.trimBlanks();
	
	self.setCaption(areaName &amp; " " &amp; app.getErrorString(Locations));

	if self.myCurrentTerminalArea.isRestrictionBlockStack() then
		self.sptThumbEdit.showLeftControl(35, true);
		self.sptThumbEdit.hideRightControl(true);
		self.mySDF.visible := false;
		return;
	endif;

	self.mySDF.visible := true;

	//areaName := self.myCurrentTerminalArea.CM_GridArea.id.trimBlanks();
	//cnwjo3
	self.mySDF.transparent := true; 
	
	create cmuiGridArea as YRD_PadArea transient;
	//cmuiGridArea.YRD_PadArea.setForCreate(self.myCurrentTerminalArea.CM_GridArea, self.myAssistant, false, self, areaMode);
	//cnwjo3
	cmuiGridArea.YRD_PadArea.setForCreate(self.myCurrentTerminalArea, self.myAssistant, false, self, areaMode);

	self.mySDF.addGridAreaAndFrame(cmuiGridArea, self.frmGridArea);
	// Update the navigator
	self.setNavigatorHeading(self.caption); 

	if self.xmlFlipH then
		self.doFlipH();
	endif;
	if self.xmlFlipV then
		self.doFlipV();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLegend" id="ef31d061-c23c-4e99-a15d-c27842b494ae">
        <source>doDrawLegend();
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theDrawingAttribute	: CM_DrawingAttribute;
	theX,theY,theColour, idx	:Integer;
	theFontName, aString : String;
	theCharacter : Character;
	theAttributes, theMeanings : StringArray;

begin
	create theMeanings transient;
	create theAttributes transient;
	
	theAttributes.add(PicTIBuilding);
	theMeanings.add("Building");
	theAttributes.add(PicTILight);
	theMeanings.add("Light");
	theAttributes.add(PicTIUnavail);
	theMeanings.add("Unavailable");
	theAttributes.add(PicTIPower);
	theMeanings.add("Power");
	theAttributes.add(PicTIGap);
	theMeanings.add("Gap");
	theAttributes.add("picTI1");
	theMeanings.add("Nothing From 1");
	theAttributes.add("picTI2");
	theMeanings.add("Nothing From 2");
	theAttributes.add("picTI3");
	theMeanings.add("Nothing From 3");
	theAttributes.add("picTI4");
	theMeanings.add("Nothing From 4");
	theAttributes.add("picTI5");
	theMeanings.add("Nothing From 5");
	theAttributes.add("picTI6");
	theMeanings.add("Nothing From 6");
	theAttributes.add("picTI7");
	theMeanings.add("Nothing From 7");
	theAttributes.add("picTI8");
	theMeanings.add("Nothing From 8");
	
	theY := 5;
	self.frmLegend.autoRedraw := true;
	self.frmLegend.drawFontSize := 12;
	foreach aString in theAttributes do
		idx := idx + 1;
		theDrawingAttribute := app.myRoot.allDrawingAttributes[aString];
	
		if theDrawingAttribute &lt;&gt; null then
			theX := 5;
			theCharacter := theDrawingAttribute.fontCharacter.Character;
			self.frmLegend.drawFontSize := 12;
			self.frmLegend.drawFontName := theDrawingAttribute.fontName;
			self.frmLegend.drawTextAt(theCharacter,theX,theY,theDrawingAttribute.colour);
			
			theX := 35;
			self.frmLegend.drawFontSize := 10;
			self.frmLegend.drawFontName := "Ariel";
			self.frmLegend.drawTextAt(theMeanings[idx],theX,theY,Black);
			
			theY := theY + 20;
		endif;
	endforeach;
epilog

	delete theAttributes;
	delete theMeanings;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="4244ee51-5b05-48ae-aba4-b32d5b258d91">
        <source>doEnableControls(_enable : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/11/2012	cnwcs5		par 30475 - removing location restrictions
// ---------------------------------------------------------------------------
	
begin

	self.tblOther.userInputEnabled	:= _enable;
	//08 July 2015	NDL	Par 36588	
	self.mulNotifyEmails.readOnly := not _enable;
	
end;</source>
