    <JadeMethod name="saveTimeSlot" id="45b3dad4-2079-4772-a862-29a1db331080">
        <updating/>
        <source>saveTimeSlot(pDay : Integer; pDate : Date; pTimeStart : Time; pNumOfSlot : Integer; pRow : Integer; pCol : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	errObj		: CM_Error;
	result		: Integer;
	isStandard  : Boolean;
begin
	if self.formType = FORM_TYPE_STD then
		isStandard := true;
	else
		isStandard := false;
	endif;

	
	if self.myProxyTimeSlot = null then
		if self.mode = self.MODE_CREATE or self.mode = self.MODE_ADD then
			if isStandard then
				create self.myProxyTimeSlot as CM_TimeSlotStd transient;
			else
				create self.myProxyTimeSlot as CM_TimeSlot transient;
			endif;
		elseif self.mode = self.MODE_EDIT or self.mode = self.MODE_COPY then
			self.myProxyTimeSlot := self.createProxiesForEdit(pRow, pCol);
		endif;
	endif;
	
	if isStandard then
		self.myProxyTimeSlot.CM_TimeSlotStd.setProxy(pDay, pTimeStart, pNumOfSlot, self.myTerminal);
	else
		self.myProxyTimeSlot.CM_TimeSlot.setProxy(pDate, pTimeStart, pNumOfSlot, self.myTerminal);
	endif;
	
	while true do
		if self.mode = MODE_CREATE or self.mode = MODE_ADD then
			app.myTrxCA.trxCreateTimeSlot(self.myProxyTimeSlot, app.myPassport, self.myNewTimeSlot,isStandard);
		else
			app.myTrxUA.trxUpdateTimeSlot(self.myProxyTimeSlot, app.myPassport, isStandard);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Booking Time Slot', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			errObj := app.myPassport.allErrorWarnings.first;
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;	
	endwhile;
	return false;
epilog
	if self.mode = MODE_EDIT then
		self.clearProxyDetails(self.myProxyTimeSlot);
	endif;
end;
</source>
        <Parameter name="pDay" type="Integer"/>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pTimeStart" type="Time"/>
        <Parameter name="pNumOfSlot" type="Integer"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObj" id="6ec54374-aa0e-4cfe-90fd-0ea3e5b43d64">
        <updating/>
        <source>selectObj(_row : Integer; _column : Integer; _refresh : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	obj			: Object;
	cell		: JadeTableCell;
	row			: JadeTableRow;
	column		: Integer;
	timeSlot 	: CM_TimeSlotStd;
	idxCol		: Integer;

begin
	//if not self.allSelectedObj.isEmpty then
	//	self.allSelectedObj.purge();
	//endif;
	if self.formType = FORM_TYPE_STD then
		column := _column;
	else
		column := 2;
	endif;
	
	cell := self.tblTimeSlot.accessCell(_row, column);
	row := self.tblTimeSlot.accessRow(_row);
	if cell = null then
		return;
	endif;
	obj := cell.itemObject;
	self.tblTimeSlot.row := _row;
	if self.mode &lt;&gt; MODE_EDIT then
		if row.selected = false then
			row.selected := true;
		endif;
	endif;

	self.myCurrentTimeSlot := obj.CM_TimeSlotEntity;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCreateDlg" id="e3f2ebb6-03e8-467d-9157-202319e1ca68">
        <updating/>
        <source>setCreateDlg() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mode = MODE_CREATE then
		self.lblStartTime.visible := true;
		self.txtTimeStart.visible := true;
		self.txtTimeStart.setTime(null);
		self.txtTimeStart.setFocus();
		
		self.txtTimeEnd.setTime(null);
		self.lblEndTime.visible := true;
		self.txtTimeEnd.visible := true;
		
		self.txtTimeInSlots.text := null;
		self.txtTimeInSlots.visible := true;
		self.lblTimeInSlots.visible := true;
		self.lblMin.visible := true;
		
		self.txtNumOfSlots.visible := true;
		self.lblNumPerSlot.visible := true;
		self.txtNumOfSlots.text := null;
		
		self.lblCopyDate.visible := false;
		self.dateMask.visible := false;
				
		self.lblTask.caption := "Bulk Create Time Slot";
		
		self.frmCreateDlg.height := STD_DLG_HIGHT;
		self.btnSave.top := STD_BTN_TOP;
		self.btnCancel.top := STD_BTN_TOP;
	elseif self.mode = MODE_ADD then
		self.lblStartTime.visible := true;
		self.txtTimeStart.visible := true;
		self.txtTimeStart.setTime(null);
		self.txtTimeStart.setFocus();
		
		self.txtTimeEnd.visible := false;
		self.lblEndTime.visible := false;
		
		self.txtTimeInSlots.visible := false;
		self.lblTimeInSlots.visible := false;
		self.lblMin.visible := false;
		
		self.txtNumOfSlots.visible := true;
		self.lblNumPerSlot.visible := true;
		self.txtNumOfSlots.text := null;
		
		self.lblCopyDate.visible := false;
		self.dateMask.visible := false;

		self.lblTask.caption := "Insert A Time Slot";		
		
		self.frmCreateDlg.height := STD_DLG_HIGHT - 20;
		self.btnSave.top := STD_BTN_TOP - 20;
		self.btnCancel.top := STD_BTN_TOP - 20;
	elseif self.mode = MODE_COPY then
		self.lblStartTime.visible := false;
		self.txtTimeStart.visible := false;
		
		self.txtTimeEnd.visible := false;
		self.lblEndTime.visible := false;
		
		self.txtTimeInSlots.visible := false;
		self.lblTimeInSlots.visible := false;
		self.lblMin.visible := false;
		
		self.txtNumOfSlots.visible := false;
		self.lblNumPerSlot.visible := false;
		
		self.lblCopyDate.visible := true;
		self.dateMask.visible := true;

		self.lblTask.caption := "Copy A Time Slot";		
		
		self.frmCreateDlg.height := STD_DLG_HIGHT - 40;
		self.btnSave.top := STD_BTN_TOP - 40;
		self.btnCancel.top := STD_BTN_TOP - 40;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setFormMode" id="5b175c7f-93f8-477b-94a8-d93d882c22a5">
        <updating/>
        <source>setFormMode(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpCol : Integer;
begin
	self.mode := _mode;
	
	if _mode = self.MODE_VIEW then
		self.btnCancelBase.caption := '&amp;Close';
		self.tblTimeSlot.readOnly 		:= true;
		self.btnDelete.enabled 			:= true;
		self.btnAdd.enabled 			:= true;
		self.btnEdit.enabled 			:= true;
		self.btnSaveBase.enabled		:= true;
		self.btnRefresh.enabled			:= true;
		self.tblTimeSlot.enabled		:= true;
		self.btnSaveBase.enabled		:= false;
		self.frmCreateDlg.visible := false;
	elseif _mode = self.MODE_CREATE then
	   	self.btnCancelBase.caption := '&amp;Cancel';
		self.tblTimeSlot.readOnly 		:= true;
		self.tblTimeSlot.enabled		:= false;
		self.btnSaveBase.enabled		:= false;
		self.btnDelete.enabled 			:= false;
		self.btnAdd.enabled 			:= false;
		self.btnEdit.enabled 			:= false;
		self.btnRefresh.enabled			:= false;
		//self.setTblForEdit();
		self.frmCreateDlg.visible := true;
	elseif _mode = self.MODE_ADD then
		self.btnCancelBase.caption := '&amp;Cancel';
		self.tblTimeSlot.readOnly 		:= true;
		self.tblTimeSlot.enabled		:= false;
		self.btnSaveBase.enabled		:= false;
		self.btnDelete.enabled 			:= false;
		self.btnAdd.enabled 			:= false;
		self.btnEdit.enabled 			:= false;
		self.btnRefresh.enabled			:= false;
		//self.setTblForEdit();
		self.frmCreateDlg.visible := true;		
	elseif _mode = self.MODE_COPY then
		self.btnCancelBase.caption := '&amp;Cancel';
		self.tblTimeSlot.readOnly 		:= true;
		self.tblTimeSlot.enabled		:= false;
		self.btnSaveBase.enabled		:= false;
		self.btnDelete.enabled 			:= false;
		self.btnAdd.enabled 			:= false;
		self.btnEdit.enabled 			:= false;
		self.btnRefresh.enabled			:= false;
		//self.setTblForEdit();
		self.frmCreateDlg.visible := true;		
	elseif _mode = self.MODE_EDIT then
		self.btnCancelBase.caption := '&amp;Cancel';
		self.tblTimeSlot.readOnly 		:= false;
		self.tblTimeSlot.enabled		:= true;
		self.btnSaveBase.enabled		:= true;
		self.btnDelete.enabled 			:= false;
		self.btnAdd.enabled 			:= false;
		self.btnEdit.enabled 			:= false;
		self.btnRefresh.enabled			:= false;
		//self.setTblForEdit();
		self.frmCreateDlg.visible := false;
	endif;
	self.setTblForEdit();
end;
</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTblForEdit" id="a3ac852e-af86-4cf3-ad53-0f82e420537b">
        <updating/>
        <source>setTblForEdit() updating;

vars
	row, col,
	inputType : Integer;
	tmpCol		: JadeTableColumn;
begin
	if self.mode = self.MODE_EDIT then
		self.tblTimeSlot.selectMode := Table.SelectMode_CurrentRow;
		tmpCol := self.tblTimeSlot.accessColumn(1);
		self.tblTimeSlot.initColumnForTime(tmpCol);
		inputType := Table.InputType_TextNumeric;
	elseif self.mode = self.MODE_VIEW then
		self.tblTimeSlot.selectMode := Table.SelectMode_CurrentRow;
		self.tblTimeSlot.accessColumn(1).inputType := Table.InputType_None;
		inputType := Table.InputType_None;
/*	elseif self.mode = self.MODE_ADD then
		self.tblTimeSlot.selectMode := Table.SelectMode_CurrentRow;
		tmpCol := self.tblTimeSlot.accessColumn(1);
		self.tblTimeSlot.initColumnForTime(tmpCol);
		inputType := Table.InputType_TextNumeric;*/
		
	endif;
	
	foreach col in 2 to self.tblTimeSlot.columns do
		self.tblTimeSlot.accessColumn(col).inputType := inputType;
	endforeach;
end;
</source>
    </JadeMethod>
