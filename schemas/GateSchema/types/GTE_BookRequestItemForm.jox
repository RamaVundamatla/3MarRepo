    <JadeMethod name="btnDocStopAction_click" id="1551dd76-2bef-461e-b03a-1f5a7970a830">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocStopAction_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	form : CMUI_DocumentActionsSelectForm;
	bookingItem : CM_BookingRefItem;
	pxyDocActions : CM_BookingItemActions;
	dispStr :String;
	
begin

	if CM_BookingRefItem.hasInstance(self.myProxyBookingRefItem) then
		bookingItem := self.myProxyBookingRefItem.CM_BookingRefItem;
		pxyDocActions := bookingItem.myBookingRefItemActions;
		if pxyDocActions = null then
			create pxyDocActions transient;
			pxyDocActions.setMyBookingRefItem( bookingItem );
		endif;
	else
		return;
	endif;
	
	create form transient;
	
	form.setMyTerminal(self.myTerminal);
	form.setBaseData( 	pxyDocActions,	//_documentActionsObj : CM_DocumentActions;
						false,	//_isTasks : Boolean;
						true	//_isStops : Boolean
						);
	
	form.showModal();
	
	if pxyDocActions &lt;&gt; null then
		dispStr := pxyDocActions.getStopsList(", ",false).trimBlanks;
	elseif bookingItem &lt;&gt; null and bookingItem.myBookingRefItemActions &lt;&gt; null then
		dispStr := bookingItem.myBookingRefItemActions.getStopsList(", ",false).trimBlanks;
	endif;

	
	txtDocStopAction.text := dispStr;
	
	return;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
