    <JadeMethod name="btnOverrideTaxCode_click" id="a9833202-2193-40f0-bc5d-21f6f3ac5821">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOverrideTaxCode_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	taxCodeObj      : CM_TaxCode;
	taxCode         : String;
	theTable        : CM_DataTable;
	colNewTaxCode, 
	colIsOverridden,
	row,
	index,
	rowSt,
	rowEnd     		: Integer;
begin
	taxCodeObj:= self.cmbNewTaxCode.listObject.CM_TaxCode;
	
	if taxCodeObj &lt;&gt; null then
		taxCode:= taxCodeObj.code;
	endif;
	theTable := self.tblInvTable;

	if theTable.row &lt;= theTable.fixedRows then
		app.msgBox(app.getErrorString(Select_charge_update),app.getErrorString(Tax_Override_Error),MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	colNewTaxCode := theTable.getColumnByRowName(ETRow_NewTaxCode);
	colIsOverridden := theTable.getColumnByRowName(ETRow_TaxOverridden);
	
	rowSt := theTable.fixedRows + 1;
	rowEnd := theTable.rows;
	
	foreach index in rowSt to rowEnd do
		if theTable.accessRow(index).selected then
			theTable.setCellText(index,colNewTaxCode,taxCode);
			theTable.setCellText(index,colIsOverridden,"Yes");
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
