    <JadeMethod name="pwDuplicateSubCargoTypes" id="52a0e431-8ee0-4385-8f35-2d2ae9f1ab45">
        <source>pwDuplicateSubCargoTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2024	navpw1	Initial creation

*/

vars
	cargoBolType	: CM_CargoBOLType;
	cargoType		: CM_CargoType;
	product,
	oldProduct : CM_Product;
	stringArr : ObjectLongNameDict;
	
begin
	create stringArr transient;
	//product := "4069.2451".asOid.CM_Product;
	//write product.getYAIdentifier();
	//write product.myCargoType.abbreviation;
	
	foreach cargoBolType in app.myRoot.allCargoTypesById do
		if not cargoBolType.isCargoType then
			continue;
		endif;
		
		cargoType := cargoBolType.CM_CargoType;
		if cargoType.allProducts.isEmpty then
			continue;
		endif;
		
		foreach product in cargoType.allProducts do
			if stringArr[product.getYAIdentifier()] = null then
				stringArr[product.getYAIdentifier()] := product;
				continue;
			endif;
			
			write product.getYAIdentifier();
			write product.code;
			
		endforeach;
	endforeach;
	
epilog
	delete stringArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwError4VVRTrackedItems" id="b359ea99-93b9-4b53-adfa-3a0a82ecdb4c">
        <source>pwError4VVRTrackedItems();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2024	navpw1	Initial creation TFS: 62570 - Script to fix invalid references

*/

constants
	RunTransaction : Boolean = false;
	
vars
	vvr	: CM_VehicleVisitRecord;
	gteEntity	: CMGTE_Entity;
	gteRelease	: CMGTE_Release;
	gteReceival	: CMGTE_Receival;
	count		: Integer;
	completedOk	: Boolean;
	
begin
	vvr := "2319.591874".asOid.CM_VehicleVisitRecord;
	if RunTransaction then
		beginTransaction;
	endif;
	foreach gteEntity in vvr.allGateEntities do
		if gteEntity.isRelease then
			gteRelease := gteEntity.CMGTE_Release;
			
			if gteRelease.myTrackedItem = null or global.isValidObject(gteRelease.myTrackedItem) then
				continue;
			endif;
			
			if RunTransaction then
				gteRelease.setPropertyValue(CMGTE_Release::myTrackedItem.name, null);
			endif;
			
			count := count + 1;
			
		elseif gteEntity.isKindOf(CMGTE_Receival) then
			gteReceival := gteEntity.CMGTE_Receival;
			
			if gteRelease.myTrackedItem = null or global.isValidObject(gteReceival.myTrackedItem) then
				continue;
			endif;
			
			if RunTransaction then
				gteReceival.setPropertyValue(CMGTE_Receival::myTrackedItem.name, null);
			endif;
			count := count + 1;
			
		endif;
		
	endforeach;
	
	if RunTransaction then
		commitTransaction;
	endif;
	
	completedOk := true;
	
	app.msgBox("Fixed Gate Entities: " &amp; count.String &amp; CrLf &amp; "What Was Done: Set invalid myTrackedItem to null", "Result", MsgBox_OK_Only);
	
epilog
	if not completedOk then
		if RunTransaction then
			abortTransaction;
		endif;
		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwExtractTransManifestObjs" id="64cab891-f123-471c-aa49-647e09c36e21">
        <source>pwExtractTransManifestObjs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2025	navpw1	Initial creation

*/

vars
	jdo : JadeDynamicObject;
	objectArr : ObjectArray;
	allTransManifest : ObjectArray;
	ediTransManifest : CM_EDIDataTransManifest;
	count : Integer;
	invalidTransManifest : Boolean;
	jsonData : String;
	myCargoOnSiteOid,
	myGateDocumentOid,
	myShipManifestOid,
	myTrainConsistOid : String;
	
begin
	on Exception do self.handle3039Exception(exception, ediTransManifest, invalidTransManifest);
	create objectArr transient;
	create allTransManifest transient;
	
	CM_EDIDataTransManifest.allInstances(allTransManifest, null, true);
	
	foreach ediTransManifest in allTransManifest as CM_EDIDataTransManifest do
		ediTransManifest.edition;
		if invalidTransManifest then
			continue;
		endif;
		
		create jdo transient;
		jdo.addProperty(CM_EDIDataTransManifest::estimatedDateTimeOfArrival.name, TimeStamp);
		jdo.addProperty(CM_EDIDataTransManifest::estimatedDateTimeOfDeparture.name, TimeStamp);
		jdo.addProperty(CM_EDIDataTransManifest::guid.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::headerDate.name, TimeStamp);
		jdo.addProperty(CM_EDIDataTransManifest::manifestNumber.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::myCargoOnSite.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::myGateDocument.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::myShipManifest.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::myTrainConsist.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::receiver.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::sender.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::statusString.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::transportReferenceCustomer.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::transportReferenceInternal.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::type.name &amp; "Name", String);
		jdo.addProperty(CM_EDIDataTransManifest::vehicleBookingSlotRemarks.name, String);
		jdo.addProperty(CM_EDIDataTransManifest::vehicleBookingSlotType.name, String);
		
		if ediTransManifest.myCargoOnSite &lt;&gt; null then
			myCargoOnSiteOid := ediTransManifest.myCargoOnSite.getOidString();
		endif;
		
		if ediTransManifest.myGateDocument &lt;&gt; null then
			myGateDocumentOid := ediTransManifest.myGateDocument.getOidString();
		endif;
		
		if ediTransManifest.myShipManifest &lt;&gt; null then
			myShipManifestOid := ediTransManifest.myShipManifest.getOidString();
		endif;
		
		if ediTransManifest.myTrainConsist &lt;&gt; null then
			myTrainConsistOid := ediTransManifest.myTrainConsist.getOidString();
		endif;
		
		jdo.setPropertyValue(CM_EDIDataTransManifest::estimatedDateTimeOfArrival.name, ediTransManifest.estimatedDateTimeOfArrival);
		jdo.setPropertyValue(CM_EDIDataTransManifest::estimatedDateTimeOfDeparture.name, ediTransManifest.estimatedDateTimeOfDeparture);
		jdo.setPropertyValue(CM_EDIDataTransManifest::guid.name, ediTransManifest.guid);
		jdo.setPropertyValue(CM_EDIDataTransManifest::headerDate.name, ediTransManifest.headerDate);
		jdo.setPropertyValue(CM_EDIDataTransManifest::manifestNumber.name, ediTransManifest.manifestNumber);
		jdo.setPropertyValue(CM_EDIDataTransManifest::myCargoOnSite.name, myCargoOnSiteOid);
		jdo.setPropertyValue(CM_EDIDataTransManifest::myGateDocument.name, myGateDocumentOid);
		jdo.setPropertyValue(CM_EDIDataTransManifest::myShipManifest.name, myShipManifestOid);
		jdo.setPropertyValue(CM_EDIDataTransManifest::myTrainConsist.name, myTrainConsistOid);
		jdo.setPropertyValue(CM_EDIDataTransManifest::receiver.name, ediTransManifest.receiver);
		jdo.setPropertyValue(CM_EDIDataTransManifest::sender.name, ediTransManifest.sender);
		jdo.setPropertyValue(CM_EDIDataTransManifest::statusString.name, ediTransManifest.statusString);
		jdo.setPropertyValue(CM_EDIDataTransManifest::transportReferenceCustomer.name, ediTransManifest.transportReferenceCustomer);
		jdo.setPropertyValue(CM_EDIDataTransManifest::transportReferenceInternal.name, ediTransManifest.transportReferenceInternal);
		jdo.setPropertyValue(CM_EDIDataTransManifest::type.name &amp; "Name", ediTransManifest.type);
		jdo.setPropertyValue(CM_EDIDataTransManifest::vehicleBookingSlotRemarks.name, ediTransManifest.vehicleBookingSlotRemarks);
		jdo.setPropertyValue(CM_EDIDataTransManifest::vehicleBookingSlotType.name, ediTransManifest.vehicleBookingSlotType);
		
		objectArr.add(jdo);
		
		count += 1;
	endforeach;
	
	jsonData := "[";
	
	foreach jdo in objectArr as JadeDynamicObject do
		jdo.deserializeJSON(jsonData); //Deserialize converts to json (Isn't that serialization?)
		jsonData &amp;= ",";
	endforeach;
	
	jsonData := jsonData.stripTrailingChar(",");
	
	jsonData &amp;= "]";
	
	write jsonData;
	
	on Exception do null;
	
epilog
	delete objectArr;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwFixEntData" id="2344587c-fe01-41f5-8221-7c3b828cd333">
        <source>pwFixEntData();
/*

