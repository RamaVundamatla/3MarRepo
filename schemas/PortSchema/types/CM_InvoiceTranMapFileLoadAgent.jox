				break;
		endif;
	endwhile;
	
	
	
	
	if not found then
		create updateController transient;
		app.cmsBeginLoad(ls);
		pxyQR := app.createUpdateProxy(_quantityRangeMapObj).CM_QuantityRangeMap;
		pxyQR.clear();
		app.cmsEndLoad(ls);

		if pxyQR.allRegisteredMethods = null then	//14 Jan 2011	NDL	Leaking transient in unit test
			create pxyQR.allRegisteredMethods transient;
		endif;
		_quantityRangeMapObj.allRegisteredMethods.copy(pxyQR.allRegisteredMethods);
		updateController.pxyQRMap := pxyQR;
		// copy the existing invoice line descriptions to the proxy, but not a VOID entry if there is no VOID in the load for this quantity range map
		// 32674 do this based on the voidList value only
		if self.voidList[self.rowCount] = false then
			lookForVoid := true;
		endif;

		lineMapDict := _quantityRangeMapObj.allTMInvoiceLineMappings;
		foreach lineMapping in lineMapDict do
			ild := lineMapping.myTMInvoiceLineDesc;
			key := lineMapping.mapValue;
			transferType := lineMapping.myTransferType;
			vesselCategory := lineMapping.myVesselCategory;
			groupType := lineMapping.myTMInvoiceLineGroupType;
			if lookForVoid then
				if ild.narration = self.voidInvoiceLineDesc then
					if searchKey = 0 then
						continue;
					elseif searchKey = key then
						continue;
					endif;
				endif;
			endif;
			create pxyMapping transient;
			pxyMapping.update(key, ild, pxyQR, groupType, transferType, vesselCategory, null, null, null);
		endforeach;
		
		key := 0;
		create pxyMapping transient;
		pxyMapping.update(key, invoiceLineDescObj, pxyQR, groupTypeObj, _transferType, _vesselCategory, null, null, null);

		app.myTrxUA.trxUpdateInvoiceTMTransaction(updateController, self.passport);
