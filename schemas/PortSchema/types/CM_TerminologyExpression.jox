    <JadeMethod name="set" id="f0e5b86b-256c-4348-81b5-62debf87b0f7">
        <updating/>
        <source>set(_termTypeExp 	: CM_TerminologyTypeExpression; 
		_termHdr 		: CM_TerminologyDef;
		_userExpression : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myTermTypeExpression := _termTypeExp;
	self.myTerminologyDef := _termHdr;
	self.userExpression := _userExpression;

end;</source>
