<Class name="CM_RemoteTransferDtl">
    <JadeMethod name="loadRemoteArray" id="3ee31367-033b-423c-98d9-96b341b7baa7">
        <updating/>
        <source>loadRemoteArray(_table: CM_EntryTable io) updating;

constants

	AllTiArrayRow = 4;
	ColumnHeading = 'New Id';
	
vars

	ti 					: String;

begin

	if _table.row = AllTiArrayRow then
		inheritMethod(_table);
		_table.setColumnHeadings(TransferItemArray, ColumnHeading);
		foreach ti in self.allIds do
			self.addRemoteRow(_table, ti, ti, null);
		endforeach;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="a99d67d4-1899-4c85-bead-d61de9d82bff">
        <updating/>
        <source>loadRemoteTable(_table : CM_EntryTable io) updating;


vars

	tmpRow	: Integer;
	extra	: CM_RemoteDataExtra;
	count	: Integer;

begin

	inheritMethod(_table);
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'Transfer Terminal Area', self.terminalAreaTo, null);
	self.addRemoteRow(_table, 'Transfer Log Row', self.transferTo, null);
	self.addRemoteRow(_table, 'All Transfer Items', Click, self);
	foreach extra in self.allRemoteDataExtra do
		count := count + 1;
		self.addRemoteRow(_table, 'NN Items Detail '  &amp; count.String, Click, extra);
	endforeach;
	
	
	
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
