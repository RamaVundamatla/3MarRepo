    <JadeMethod name="getDisplayStringForAttribute" id="18ecc2ab-f56f-4f06-8072-6bddcb096355">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin
	if _attrName = ETRow_HarboursDefined then
		if self.allProcessHarbours.isEmpty then
			return false.cnEcGetYesNo();
		else
			return true.cnEcGetYesNo() &amp; " (x" &amp; self.allProcessHarbours.size.String &amp; ")";
		endif;		
				
	elseif _attrName = ETRow_TerminalsDefined then	//11 June 2018	NDL	TFS 39140
		if self.allProcessTerminals.isEmpty then
			return false.cnEcGetYesNo();
		else
			return true.cnEcGetYesNo() &amp; " (x" &amp; self.allProcessTerminals.size.String &amp; ")";
		endif;		
				
	elseif _attrName = ETRow_AddReportsCount then	//08 Feb 2019	NDL	TFS 43240
		if self.allAdditionalReports.isEmpty then
			return false.cnEcGetYesNo();
		else
			return true.cnEcGetYesNo() &amp; " (x" &amp; self.allAdditionalReports.size.String &amp; ")";
		endif;	
					
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHMSResourceTypeForWater" id="071999e4-525a-4a0d-97a7-9a7fe689f0b8">
        <source>getHMSResourceTypeForWater( _term : CM_Terminal ) : HMS_ResourceType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	processHarbour : CM_ProcessHarbour;

begin

	if self.isDefaultProcessJMT then
		return null;
	endif;

	if _term = null or _term.myHarbour = null or self.allProcessHarbours.isEmpty then
		return null;
	endif;
	
	processHarbour := self.allProcessHarbours.getAtKey( self, _term.myHarbour );
	if processHarbour = null then
		return null;
	endif;
	
	return processHarbour.myHMSResourceForWater;

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="getHMSResourcesForStatus" id="85fdc1d8-5998-4108-a5a4-16769b35a599">
        <source>getHMSResourcesForStatus(_status : Integer) : HMS_ResourceByTypeDict;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/03/2018	jlgdap1		Initial creation TFS 37544
//
vars
	status : CM_VoyageStatus;

begin
	status := self.allStatuses[_status];
	if status &lt;&gt; null then
		return status.allHMSResourcesAllowed;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="HMS_ResourceByTypeDict"/>
    </JadeMethod>
