    <JadeMethod name="setForCreate" id="aaa82f81-638d-4cb1-8eca-b6c99e936353">
        <updating/>
        <source>setForCreate(pProxy : CM_CodeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.groupType	:= pProxy.groupType;
	self.setForUpdate(pProxy);
		
	self.myRoot		:= pProxy.myRoot;
	self.myCodeGroupType := pProxy.myCodeGroupType;

end;</source>
        <Parameter name="pProxy" type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1df76600-05a9-4720-9645-4b1054d69faa">
        <updating/>
        <source>setForUpdate(pProxy : CM_CodeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name	:= pProxy.name;

end;</source>
        <Parameter name="pProxy" type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="27a50205-079d-48f7-a980-a0551cf33092">
        <updating/>
        <source>setProxy(pType : Integer; pName : String; pRoot : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.groupType	:= pType;
	self.name		:= pName;
	self.myRoot		:= pRoot;
	
	self.myCodeGroupType := self.myRoot.allCodeGroupTypes[self.groupType];
	
end;</source>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pRoot" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="03b2acca-ed21-4236-962c-a42e50e504ae">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.groupType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'group type', 'groupType', null);
		app.raiseCMException(Input_required_field_grpType, 'groupType', null); // cnwdb2	PAR 35364
	endif;
	
	if self.groupType &lt;= 0 or self.groupType &gt; CodeGroup_MaxNumber then
		app.raiseCMException1(ERR_INVALID_VALUE, 'group type', 'groupType', null);
	endif;

	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'root', 'myRoot', null);
		app.raiseCMException(Input_required_field_root, 'myRoot', null); // cnwdb2	PAR 35364


	endif;
	
	if self.myRoot.allCodeGroups[self.groupType, self.name] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);	
	endif;
	
	self.validateForUpdate();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b6d9296f-b210-4403-ab04-e4b6d1ad4629">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not  self.allOperators.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Code Group ' &amp; self.name, 
							  self.allOperators.size.String &amp; ' Operator', null, null);
	endif;
	
	if not  self.allCodes.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, 'Code Group ' &amp; self.name, 
							  self.allCodes.size.String &amp; ' Code', null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="67258835-71f5-40fc-98be-5aa82aa318d8">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'name', 'name', null);
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
	endif;
	if self.myCodeGroupType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'codeGroupType', 'codeGroupType', null);		
		app.raiseCMException(Input_required_field_cdeGrpTyp, 'codeGroupType', null); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
