    <JadeMethod name="doTblDataRowColChange" id="c3de32bf-5ae3-4782-887b-d9a3a8cea111">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2012	cnwndl1	Initial creation	Par 29145

*/

vars
	
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
	ct			: TimeStamp;
	invalid		: Boolean;
	theTableInfo : CM_DataTable;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	theTableInfo := self.tblInfo;
	theTableInfo.rows := 0;

	if table.row &lt;= table.fixedRows then
		return;
	endif;

	theObject := table.accessRow(table.row).itemObject;

	//if (not global.isValidObject(theObject)) then
	//	return;
	//endif;
	//cnwjo3 par 23520
	if theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,theObject,invalid);
		ct := theObject.creationTime;
	endif;
	
	if invalid then
		return;
	endif;
	
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
	elseif CM_WorkListEntry.hasInstance(theObject) then
		if theObject.CM_WorkListEntry.myTrackedItem &lt;&gt; null or not theObject.isKindOf(CM_VoyageWLE) then  // 09/06/2010 cnwmh5 #20661
			theObject := theObject.CM_WorkListEntry.myTrackedItem;
			self.myCurrentTrackedItem := theObject.CM_TrackedItem;
		endif;
	endif;
			
	if self.useTableInfo then
		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else
			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				
				self.getExtraExtraInfo(dataContainer, theObject.CM_Object);
				theObject.CM_Object.getExtraInfo(dataContainer);
				theTableInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, theTableInfo, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
	
epilog

	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblQueryRowColChange" id="934eaf1f-8b69-4f05-80ee-4158163113af">
        <source>doTblQueryRowColChange(table : CM_EntryTable input);
// ---------------------------------------------------------------------------
// Created:     07 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	jRow			: JadeTableRow;
begin
	jRow := table.accessRow(table.row);

	if table.getRowByName(ETRow_CargoType) = jRow.row or
		table.getRowByName(ETRow_Operator) = jRow.row or
		table.getRowByName(ETRow_TermArea) = jRow.row or
		table.getRowByName(ETRow_ToDoTask) = jRow.row or
		table.getRowByName(ETRow_Voyage) = jRow.row then
		jRow.height := self.ROW_EXPANDED_HEIGHT;
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllUpdates" id="bffc7cfb-69f4-4256-a88f-3a29bf245107">
        <updating/>
        <source>getAllUpdates( _theRow : Integer; _theTI : CM_TrackedItem output ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 June 2012	cnwndl1	Initial creation	Par 29145 - Populate ther alltasks collections ready for updates.
		Simple means all actions that require no furher User interaction, so Add, and Remove for all tasks and the
		tasks that do not use a form for user entry during a complete.
		
		Items requiring resources or dimensions etc. are complex completes....

*/

vars

	tableCell : JadeTableCell;
	tableColumn : JadeTableColumn;
	theCol : Integer;
	theTask : CM_ToDoTask;
	invalidTask : Boolean;
	theTaskDesc : CM_ToDoTaskDesc;
	theTaskCode : Integer;
	tbl : CM_DataTable;
	complexTi : CM_TrackedItem;
	numCols : Integer;

begin

	on Exception do app.handleDeletedObject(exception,theTask,invalidTask);
	
	self.allTasksToAdd.clear();
	self.allTasksToCompleteSimple.clear();
	self.allTasksToRemove.clear();
	if self.allTasksToCompleteComplex = null then
		create self.allTasksToCompleteComplex transient;
	endif;
	self.allTasksToCompleteComplex.clear();
	
	tbl := self.tblData;
	
	// if bold then the line has changed

	if tbl.accessCell(_theRow, 1).fontBold = true then
		
		_theTI := tbl.accessRow(_theRow).itemObject.CM_TrackedItem;
		
		if _theTI &lt;&gt; null then
				
			numCols := tbl.columns;
			// go through each task (column) for this TI (row)
			// work out if a task has been added or removed
			foreach theCol in self.TaskStartColumn to numCols do
				tableCell := tbl.accessCell(_theRow,theCol);
				tableColumn := tbl.accessColumn(theCol);
	
				//### NOTE. ToDoTask TYPES can be deleted even though there are todotasks existing. There is no link.
				// ###			If A ToDoTask type has been deleted, but some of the TIs displayed have todo tasks set
				//				from it then this will be null and only the TIs using that todo task will have a check box..
	
				theTask := tableCell.itemObject.CM_ToDoTask;
				if theTask = null then // ADDING
					theTaskDesc := tableColumn.itemObject.CM_ToDoTaskDesc;
					if theTaskDesc &lt;&gt; null then
						theTaskCode := tableColumn.itemObject.CM_ToDoTaskDesc.code;
					endif;
				else
					theTaskCode := theTask.toDoTaskDescCode;
					theTaskDesc := theTask.toDoTaskDesc;
					if invalidTask then
						invalidTask:=false;
						continue;
					endif;
				endif;
				
				if theTaskCode = null then
					continue;
				endif;
				
				if not self.isRemovingTasks then // WE ARE IN ADD and COMPLETE MODE
					// if the task has been completed
					if tableCell.backColor = self.COLOUR_COMPLETED_EDITED then
						if theTaskDesc.isSimpleToDoTask then
							allTasksToCompleteSimple.add(theTaskCode);
						else
							allTasksToCompleteComplex.add(theTaskCode);
						endif;
					elseif tableCell.backColor = self.COLOUR_TO_DO_EDITED then //we've added a task
						allTasksToAdd.add(theTaskCode);
					endif;				
				else// WE ARE IN REMOVE TASK MODE
					if tableCell.itemObject &lt;&gt; null and tableCell.text = false.cnEcGetTableCheckBoxValue then
						allTasksToRemove.add(theTaskCode);
					endif;
				endif;	
			
			endforeach;
			
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="output"/>
    </JadeMethod>
