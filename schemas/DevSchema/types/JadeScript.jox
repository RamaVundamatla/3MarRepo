    <JadeMethod name="jreAddMoreTransTableRows" id="6f32c81d-6400-4ca2-9bc9-6638ad489c51">
        <source>jreAddMoreTransTableRows();
// for CCMS SFW 1262, transaction enquiry, add new transaction rows from file to group TransactionDetails and
//   then to table ETDef_CargoEnquiry
vars
	fileLine,
	token1,
	token2,
	work	: String;
	pos		: Integer;
	tlTable	: EntTableDef;
	tlGroup	: EntTableGroup;
	tlRow	: EntTableRow;
	proxy	: EntTableRowProxy;
	oa : ObjectArray;	// transient proxies
	tableRoot	: CM_EntTableDataRoot;
	entRow		: EntTableRow;
	file		: File;
	scm			: Schema;
	constCat	: ConstantCategory;
begin
	tableRoot := CM_Root.firstInstance.myEntTableDataRoot;
	tlGroup := tableRoot.allEntTableGroups[ETGrp_TransactionDetails];
	tlTable := 	tableRoot.allEntTableDefs[ETDef_TransactionCargoEnquiry];
	scm := rootSchema.getSchema("PortSchema");
	constCat := scm.getCategory('EntTableRows');
	create oa transient;
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.openInput('d:\temp\CargoTransactionOnlyRows.txt');
	beginTransaction;

	// all transaction enquiry rows
	while not file.endOfFile() do
		fileLine := file.readLine();
		pos := fileLine.pos(Tab, 1);
		if pos &lt; 2 then
			write "no TAB in " &amp; fileLine;
			continue;
		endif;
		token1 := fileLine[1:pos-1];
		if pos = fileLine.length then
			write "no heading in " &amp; fileLine;
			continue;
		endif;
		token2 := fileLine[pos+1:end];
		if tlGroup.allEntTableRowsByName[token1] &lt;&gt; null then
			write token1 &amp; " already in the group";
			continue;
		endif;
		work := token1;
		work.firstCharToUpper();
		work := 'ETRow_' &amp; work;
		if constCat.getConstants[work] = null then
			write "No " &amp; work;
			return;
		endif;
		create proxy transient;
		// all rows are read-only
		proxy.setBasicDetails(token1, token2, 0, true); 
		proxy.setPropertyValue("errorReturnString", token1);

		create tlRow persistent;
		tlRow.setForCreate(proxy, tlGroup);
		oa.add(proxy);
	endwhile;

	write ""; write "Table";

	foreach entRow in tlGroup.allEntTableRowsByName do
		if tlTable.allEntTableRows.includes(entRow) then
			//write entRow.name &amp; " already in table CargoEnquiry";
			continue;
		endif;
		write entRow.name &amp;  ":" &amp; entRow.getHeadingUnaltered() &amp; " add to table";
		if not tlTable.addRow(0, entRow) then
			write "table add fail on " &amp; entRow.name;
		endif;
	endforeach;
	//abortTransaction;
	commitTransaction;
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
	oa.purge;		// purge transient proxies
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreAddTableRows" id="9ad00f94-298f-44d0-9490-2da7210b9d23">
        <source>jreAddTableRows();
// for 23277, add all missing rows from ETDef_ContainerData to group InvListInvoices and
//   then to table ETDef_InvListDataTableLines
constants
	Default = 'Default';
vars
	codeString  : String;
	errorString : String;
	createView : Boolean;
	cdTable,
	ilTable	: EntTableDef;
	cdGroup,
	ilGroup	: EntTableGroup;
	ilView	: EntTableView;
	dataRoot : CM_EntTableDataRoot;
	cdRow,
	ilRow	: EntTableRow;
	proxy	: EntTableRowProxy;
	sa : StringArray;
	oa : ObjectArray;	// transient proxies
begin
	dataRoot := CM_EntTableDataRoot.firstInstance;
	cdTable := dataRoot.allEntTableDefs['ContainerData'];
	cdGroup := cdTable.myEntTableGroup;
	ilTable := dataRoot.allEntTableDefs['InvListDataTableLines'];
	ilGroup := ilTable.myEntTableGroup;

	beginTransaction;
	create sa transient;
	create oa transient;
//	write "Group";

	foreach ilRow in ilGroup.allEntTableRowsByName do
		sa.add(ilRow.name);
	endforeach;
	foreach cdRow in cdTable.allEntTableRows do
		if sa.includes(cdRow.name) then
//			write cdRow.name &amp;  " already in InvList group";
		else
//			write cdRow.name &amp;  " new";
			create proxy transient;
			proxy.setFromRealObject(cdRow);
			proxy.allEntTableDefs.clear;
			proxy.allEntTableViews.clear;
			// get duplicate errorReturnStrings
			errorString := proxy.errorReturnString;
			while true do
				if ilGroup.allEntTableRowsByErrorRtn[errorString] &lt;&gt; null then
					errorString := errorString &amp; 'A';
				else
					break;
				endif;
			endwhile;
			if proxy.errorReturnString &lt;&gt; errorString then
				write proxy.errorReturnString &amp; " to " &amp; errorString;
				proxy.setPropertyValue("errorReturnString", errorString);
			endif;

			create ilRow persistent;
			ilRow.setForCreate(proxy, ilGroup);
			oa.add(proxy);
		endif;
	endforeach;
	sa.clear;
//	write ""; write "Table";
	ilView := ilTable.allEntTableViews[Default];
	if ilView = null then
		createView := true;
		ilView := ilTable.addView(Default, "");
	endif;
	foreach ilRow in ilTable.allEntTableRows do
		sa.add(ilRow.name);
		if createView then
			ilView.addRow(ilRow);
			write ilRow.name&amp;" added to default view";
		endif;
	endforeach;
	foreach cdRow in cdTable.allEntTableRows do
		if sa.includes(cdRow.name) then
//			write cdRow.name &amp;  " already in InvList table";
		else
			write cdRow.name &amp;  " new";
			ilRow := ilGroup.allEntTableRowsByName[cdRow.name];
			if not ilTable.addRow(0, ilRow) then
				write "table add fail on " &amp; cdRow.name;
			endif;
			codeString := codeString &amp; Tab &amp; Tab &amp; "   _attrName = " &amp; cdRow.myEntTableRowHeader.constantName &amp; " or" &amp; CrLf;
		endif;
	endforeach;
	//abortTransaction;
	commitTransaction;
	write codeString;
epilog
	delete sa;
	oa.purge;
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreAddTransTableRows" id="045e0962-de4c-4f7c-9bda-44ae14f57b26">
        <source>jreAddTransTableRows();
// for CCMS SFW 1262, transaction enquiry, add all all ent table rows used for cargo enquiry to group TransactionDetails and
//   then to table ETDef_CargoEnquiry
vars
	errorString : String;
	tlTable	: EntTableDef;
	tlGroup	: EntTableGroup;
	cdRow,
	tlRow	: EntTableRow;
	proxy	: EntTableRowProxy;
	sa : StringArray;
	oa : ObjectArray;	// transient proxies
	tableName	: String;
	tableRoot	: CM_EntTableDataRoot;
	dict		: DynaDictionary;
	entTable	: EntTableDef;
	entRow		: EntTableRow;
	iter		: Iterator;
begin
	tableRoot := CM_Root.firstInstance.myEntTableDataRoot;
	create dict transient;
	dict.setMembership(EntTableRow);
	dict.addExternalKey(String, 35, false, true);
	dict.endKeys(false);
	tlGroup := tableRoot.allEntTableGroups['TransactionDetails'];
	tlTable := 	tableRoot.allEntTableDefs[ETDef_TransactionCargoEnquiry];
	
	// all cargo enquiry table defs
	create sa transient;
	sa.add('DefaultDataTable');
	sa.add('CargoEnqDefaultData');
	sa.add('ContainerData');
	sa.add('GeneratorData');
	foreach tableName in sa do
		entTable := tableRoot.allEntTableDefs[tableName];
		foreach entRow in entTable.allEntTableRows do
			if dict[entRow.name] = null then
				dict.putAtKey(entRow.name, entRow);
			endif;
		endforeach;
	endforeach;

	//*** rerun, clear out prior entries
	beginTransaction;
	tlGroup.allEntTableRowsByName.purge();
	write "group rows purged";
	if tlTable &lt;&gt; null then
		tlTable.allEntTableRows.clear();
		write "table rows purged";
	endif;
	commitTransaction;
	
	create oa transient;
	beginTransaction;

	iter := dict.createIterator();
	// all cargo enquiry rows
	while iter.next(cdRow) do
//		write cdRow.name &amp;  " new";
		if tlGroup.allEntTableRowsByName[cdRow.name] &lt;&gt; null then
			write cdRow.name &amp; " already in the group";
			continue;
		endif;
		create proxy transient;
		proxy.setFromRealObject(cdRow);
		// all rows are read-only
		proxy.setPropertyValue("inputType", 0);
		proxy.setPropertyValue("inputTypeForWeb", 0);
		proxy.setPropertyValue("controlName", "");
		proxy.allEntTableDefs.clear;
		proxy.allEntTableViews.clear;
		// get duplicate errorReturnStrings?
		errorString := proxy.errorReturnString;
		while true do
			if tlGroup.allEntTableRowsByErrorRtn[errorString] &lt;&gt; null then
				errorString := errorString &amp; 'A';
			else
				break;
			endif;
		endwhile;
		if proxy.errorReturnString &lt;&gt; errorString then
			write proxy.errorReturnString &amp; " to " &amp; errorString;
			proxy.setPropertyValue("errorReturnString", errorString);
		endif;

		create tlRow persistent;
		tlRow.setForCreate(proxy, tlGroup);
		oa.add(proxy);
	endwhile;

	write ""; write "Table";
	iter.reset();

	foreach entRow in tlGroup.allEntTableRowsByName do
		if tlTable.allEntTableRows.includes(entRow) then
			write entRow.name &amp; " already in table CargoEnquiry";
			continue;
		endif;
		write entRow.name &amp;  " add to table";
		if not tlTable.addRow(0, entRow) then
			write "table add fail on " &amp; entRow.name;
		endif;
	endforeach;
	//abortTransaction;
	commitTransaction;
epilog
	delete sa;
	oa.purge;		// purge transient proxies
	delete oa;
	delete iter;
	delete dict;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreAddYATypeIsEmpty" id="71d6757c-fdc9-4c42-948e-56a485633a0e">
        <source>jreAddYATypeIsEmpty();

vars
	proxyObj			: CM_YACriteriaType;
	isEmptyObj			: CM_YATypeIsEmpty;

begin
	app.initialize();
	
	beginTransaction;
	if CM_YATypeIsEmpty.instances.isEmpty() then
		create proxyObj as CM_YATypeIsEmpty transient;
		proxyObj.setProxy("Is Empty", true, YACriteriaType_IsEmpty);
		create isEmptyObj;
		isEmptyObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	commitTransaction;
	isEmptyObj.inspectModal;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreAnalyseCargoEnqTables" id="728ffc65-a4b8-466c-aec4-0fa44d773994">
        <source>jreAnalyseCargoEnqTables();
// for transaction enquiry, get a list of all ent table rows used for cargo enquiry
vars
	tableName	: String;
	tableRoot	: CM_EntTableDataRoot;
	dict		: DynaDictionary;
	entTable	: EntTableDef;
	entRow		: EntTableRow;
	iter		: Iterator;
	sa			: StringArray;
begin
	tableRoot := CM_Root.firstInstance.myEntTableDataRoot;
	create dict transient;
	dict.setMembership(EntTableRow);
	dict.addExternalKey(String, 35, false, true);
	dict.endKeys(false);
	
	create sa transient;
	sa.add('DefaultDataTable');
	sa.add('CargoEnqDefaultData');
	sa.add('ContainerData');
	sa.add('GeneratorData');
	foreach tableName in sa do
		entTable := tableRoot.allEntTableDefs[tableName];
		foreach entRow in entTable.allEntTableRows do
			if dict[entRow.name] = null then
				dict.putAtKey(entRow.name, entRow);
			endif;
		endforeach;
	endforeach;

	iter := dict.createIterator();
	while iter.next(entRow) do
		write entRow.name &amp; Tab &amp; entRow.getHeadingUnaltered() &amp; Tab &amp; entRow.shortHeading;
	endwhile;
	
epilog
	delete iter;
	delete dict;
	delete sa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreBigMethods" id="4cb5d111-9848-486f-b554-99fdb2c37af8">
        <source>jreBigMethods();

constants
	SizeLimit = 10000;
vars
	schemas	: StringArray;
	schemaName,
	className,
	methodName	: String;
	scm		: Schema;
	cls		: Class;
	mth		: Method;
	jm		: JadeMethod;
	code	: Binary;
	classes	: ClassNDict;
	methods		: MethodNDict;
	count		: Integer;
	file	: File;
	record	: String;
	agent	: DEV_ReleaseExtractAgent;
	
begin
	create file transient;
	file.openOutput("C:\temp\BigMethods.csv");
	file.writeLine("Schema,Class,Method,Size");

	create schemas transient;
	create agent transient;
	agent.getReleaseSchemas(schemas);
	foreach schemaName in schemas do
		scm := rootSchema.getSchema(schemaName);
		if scm = null then
			write "No schema " &amp; schemaName;
			continue;
		endif;
		classes := scm.getPropertyValue("classes").ClassNDict;
		foreach cls in classes do
			methods := cls.getPropertyValue("methods").MethodNDict;
			foreach mth in methods do
				if not mth.isKindOf(JadeMethod) then
					continue;
				endif;
				jm := mth.JadeMethod;
				code := jm.getPropertyValue("code").Binary;
				if code.length &gt; SizeLimit then
					count := count + 1;
					record := scm.name &amp; "," &amp; cls.name &amp; "," &amp; jm.name &amp; "," &amp; code.length.String;
					file.writeLine(record);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	write "methods &gt; " &amp; SizeLimit.String &amp; " = " &amp; count.String;
	file.close;
	
epilog
	delete file;
	delete schemas;
	delete agent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCashCredit" id="17e1acfc-de56-4061-9c14-90a1dc13deec">
        <source>jreCashCredit();

vars
	oa	: ObjectArray;
	cx : CM_ColourCount;
	cc : CM_CashCredit;
	cd : CM_CashCreditDetail;
	total : Decimal[16, 6];
	count	: Integer;
begin
	create oa transient;
	foreach cc in CM_CashCredit.instances do
		total := 0;
		count := count + 1;
		foreach cd in cc.allAppliedToCreditDetails do
			total := total + cd.cashValue;
		endforeach;
		if total &lt;&gt; cc.cashValue then
			create cx transient;
			cx.colour := cc.cashValue.Integer;
			cx.percent := total.Integer;
			cx.count := count;
			oa.add (cx);
		endif;
	endforeach;
	oa.inspectModal;
	oa.purge;
	delete oa;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCashCreditFix" id="675bfe16-a0b3-4d81-aa7a-47f39f2a35db">
        <source>jreCashCreditFix();

vars
	oa	: ObjectArray;
	cx : CM_ColourCount;
	cc : CM_CashCredit;
	cd : CM_CashCreditDetail;
	total,
	allocated	: Decimal[16, 6];
	count	: Integer;
begin
	beginTransaction;
	foreach cc in CM_CashCredit.instances do
		total := 0;
		allocated := 0;
		foreach cd in cc.allAppliedToCreditDetails do
			total := total + cd.cashValue;
			if total &gt; cc.cashValue then
				cd.setCashValue(cc.cashValue - allocated);
			endif;
			allocated := allocated + cd.cashValue;
		endforeach;
		cc.inspectModal;
	endforeach;
	abortTransaction;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCashPaymentTerminal" id="6f3feec9-4252-46f3-9cf3-36259b9d1bec">
        <source>jreCashPaymentTerminal();

vars
	payment	 : CM_CashPayment;
begin
	beginTransaction;
	foreach payment in CM_CashPayment.instances do
		if payment.myTerminal = null then
			if payment.myDebtorTerminal &lt;&gt; null then
				payment.setPropertyValue("myTerminal", payment.myDebtorTerminal.myTerminal);
			elseif payment.myInvoice &lt;&gt; null and
			   payment.myInvoice.myTerminal &lt;&gt; null then
				payment.setPropertyValue("myTerminal", payment.myInvoice.myTerminal);
			endif;
		endif;
	endforeach;
	commitTransaction;

end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCashReceiptBank" id="01ba3a55-6709-436b-bd5b-eeed6ef52af7">
        <source>jreCashReceiptBank();

vars
	receipt	: CM_CashReceipt;
	bank	: CM_Bank;
begin
	beginTransaction;
	foreach receipt in CM_CashReceipt.instances do
		if receipt.myBank = null then
			bank := receipt.myTerminal.getDefaultCompanyBank();
			receipt.setPropertyValue("myBank", bank);
		endif;
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCashReceiptRemoveDupCargo" id="f03f4a9b-89e9-4370-aeae-295bc856d750">
        <source>jreCashReceiptRemoveDupCargo();
// remove duplicate entries in CM_CashReceipt allTrackedItems after update development
vars
	cr		: CM_CashReceipt;
	tis		: CM_TIArray;
begin
	create tis transient;
	beginTransaction;
	foreach cr in CM_CashReceipt.instances do
		tis.clear();
		cr.allTrackedItems.copyNoDups(tis);
		if tis.size &lt;&gt; cr.allTrackedItems.size then
			write cr.String &amp; " allTIs " &amp; cr.allTrackedItems.size.String &amp; " now " &amp; tis.size.String;
			cr.allTrackedItems.clear();
			tis.copy(cr.allTrackedItems);
		endif;
	endforeach;
	//abortTransaction;
	commitTransaction;
epilog
	delete tis;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCashTerminalDict" id="db326036-f585-49f5-a7d9-ffd4c9532ea0">
        <source>jreCashTerminalDict();
// clear out the allCashReceipts extension dictionary
vars
	terminal	: CM_Terminal;
	dict : CM_CashReceiptDateDict;
begin
	beginTransaction;
	foreach terminal in CM_Terminal.instances do
		terminal.setExtensionObjectValue (Obj_Extn_allCashReceipts, null);
	endforeach;
	commitTransaction;

	beginTransaction;
	foreach dict in CM_CashReceiptDateDict.instances do
		delete dict;
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCheckCashPayments" id="cf57c874-07d1-4d9b-b62e-8fc174569744">
        <source>jreCheckCashPayments();
// see if we can get to the cash receipt from each cash payment
// it MOSTLY works except for part payments and duty docs where there is an invoice for the missing balance
vars
	allPayments : CM_CashDict;
	cashReceipt	: CM_CashReceipt;
	cashPayment	: CM_CashPayment;
	invoiceLine	: CM_InvoiceLine;
	invoiceTotal	: Decimal[16, 6];
	paymentTotal	: Decimal[16, 6];
	iterator	: Iterator;
	found		: Boolean;
	isEmpty		: Boolean;
begin
	create allPayments transient;
	foreach cashPayment in CM_CashPayment.instances do
		allPayments.add(cashPayment);
	endforeach;
	iterator := allPayments.createIterator();
	foreach cashReceipt in CM_CashReceipt.instances do
		isEmpty := false;
		if cashReceipt.allInvoiceLines.isEmpty and
		   cashReceipt.allTrackedItems.isEmpty and
		   cashReceipt.allProformaDetails.isEmpty then
			isEmpty := true;
		endif;
		found := false;
		paymentTotal := 0;
		invoiceTotal := 0;
		//foreach invoiceLine in cashReceipt.allInvoiceLines do
		//	invoiceTotal := invoiceTotal + invoiceLine.lineTotal;
		//endforeach;
		iterator.reset;
		allPayments.startKeyGeq(cashReceipt.dateTime, iterator);
		while iterator.next(cashPayment) do
			if cashPayment.dateTime &lt;&gt; cashReceipt.dateTime then
				break;
			endif;
			// recent in UT and JT1 and DP1
			//write " MATCHING dateTime CashReceipt " &amp; obj.String &amp; cashPayment.dateTime.String &amp; " " &amp; cashPayment.getDebtorTerminal().myTerminal.code;	// one or none, and when one there are several receipts that match
			found := true;
			paymentTotal := paymentTotal + cashPayment.cashValue;
		endwhile;
		// no-matches are mostly old (some current) in NDL, DP1, T01 or JBL terminal etc so are old or are duty docs
		if not found and not isEmpty then
			// Mixed, MOSTLY empty
			write "Receipt with no payments " &amp; cashReceipt.dateTime.String &amp; " " &amp; cashReceipt.myTerminal.code &amp; " cash total=" &amp; cashReceipt.cashValue.String
					 &amp; " invoice total=" &amp; invoiceTotal.String;
		elseif paymentTotal &lt;&gt; cashReceipt.cashValue then
			// DP1
			write "Receipt with mismatched payments " &amp; cashReceipt.dateTime.String &amp; " " &amp; cashReceipt.myTerminal.code &amp; " cash total=" &amp; cashReceipt.cashValue.String
					&amp; " payment total=" &amp; paymentTotal.String;
		else
			// recent JT1 and UT
			write "Receipt WITH matching payments " &amp; cashReceipt.dateTime.String &amp; " " &amp; cashReceipt.myTerminal.code &amp; " cash total=" &amp; cashReceipt.cashValue.String
					&amp; " payment total=" &amp; paymentTotal.String;
		endif;
	endforeach;
	
epilog
	delete allPayments;
	delete iterator;
end;


</source>
    </JadeMethod>
    <JadeMethod name="jreCheckDebtorInvoices" id="6681f10c-e79b-474e-b0b2-8c345c9c68c0">
        <source>jreCheckDebtorInvoices();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2013	cnwjre1	Initial creation

*/

vars
	file	: File;
	debtor	: CM_Debtor;
	invoice	: CM_Invoice;
	dict	: CM_InvoiceByTypeDict;
	coy		: CM_Bank;
	term	: CM_Terminal;
	lastType	: CM_InvoiceDesc;
	oa		: ObjectArray;
	obj		: Object;
	total	: Integer;
begin
	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput("c:\temp\OpenInvoicesDMAST.csv");
	file.writeLine("Debtor,Terminal,Company,Invoice type,Invoice per,Total");
	create oa transient;
	foreach debtor in CM_Debtor.instances do
		oa.add(debtor);
	endforeach;
	foreach debtor in CM_VoidDebtor.instances do
		oa.add(debtor);
	endforeach;
	
	foreach obj in oa do
		debtor := obj.CM_Debtor;
		dict := debtor.getPropertyValue("invoicesByType").CM_InvoiceByTypeDict;
		lastType := null;
		invoice := null;
		total := 0;
		foreach invoice in dict do
			if invoice.invoiceType &lt;&gt; lastType then
				if lastType &lt;&gt; null then
					coy := lastType.company;
					term := coy.terminal;
					file.writeLine(debtor.name &amp; "," &amp; term.code &amp; "," &amp; coy.code &amp; "," &amp; lastType.description &amp; "," &amp; lastType.getKeyDescription() &amp; "," &amp; total.String);
					total := 0;
				endif;
				lastType := invoice.invoiceType;
			endif;
			if invoice.status = CM_Invoice.INVOICE_OPEN then
				total := total + 1;
			endif;
		endforeach;
		if invoice &lt;&gt; null then
			if lastType &lt;&gt; null then
				coy := lastType.company;
				term := coy.terminal;
				file.writeLine(debtor.name &amp; "," &amp; term.code &amp; "," &amp; coy.code &amp; "," &amp; lastType.description &amp; "," &amp; lastType.getKeyDescription() &amp; "," &amp; total.String);
				total := 0;
			endif;
		endif;
	endforeach;
epilog
	if file &lt;&gt; null then
		if file.isOpen then
			file.close;
		endif;
		delete file;
	endif;
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreCheckEntTableRows" id="b4a4fb2a-4904-4911-9d13-31a8989e2964">
        <source>jreCheckEntTableRows();

vars
	file	: File;
	str, token,
	work	: String;
	pos		: Integer;
	scm		: Schema;
	cat		: ConstantCategory;
	gc		: Constant;
begin
	scm := rootSchema.getSchema('PortSchema');
	cat := scm.getCategory('EntTableRows');
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.openInput("D:\temp\TransactionRows.txt");
	while not file.endOfFile() do
		str := file.readLine();
		if str = null then
			continue;
		endif;
		pos := 1;
		token := str.cnEcGetNextWord(pos);
		gc := cat.getConstants['ETRow_' &amp; token];
		if gc = null then
			work := token;
			work.firstCharToUpper;
			gc := cat.getConstants['ETRow_' &amp; work];
		endif;
		if gc = null then
			write token &amp; " NOT found";
		else
			write token &amp; " " &amp; gc.name;
		endif;
		
	endwhile;
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCheckInterTermInvoicing" id="0800af08-2487-48ca-acc2-43510b7154b4">
        <source>jreCheckInterTermInvoicing();
//  CCMS GLT 2184 prototype
vars
	now		: TimeStamp;
	seqNum,
	seqNum2	: Integer;
	tmpTotal : Real;
	cont1,
	cont2	: CM_TrackedItem;
	tran1,
	tran2	: CM_TITransaction;
	debtor	: CM_Debtor;
	invType	: CM_InvoiceDesc;
	inv1, inv2	: CM_Invoice;
	line1,
	line2,
	newLine	: CM_InvoiceLine;
	charge	: CM_Charge;
	service	: CM_Service;
	bank	: CM_Bank;
	term2	: CM_Terminal;
	oa		: ObjectArray;
	obj		: Object;
	qrm : CM_QuantityRangeMap;
begin
	app.initialize();
	
	create oa transient;
	term2 := app.getTerminalByName("Terminal Two");
	app.myPassport.setMyTerminal(term2);
	
	cont2 := '2367.725653'.asOid.CM_TrackedItem;	// ANR60001821 in T02
	cont1 := cont2.myMoveCloneFromTI;				// the same in T01
	bank := cont2.companyOid;
	create qrm transient;
	
	// copy T01 invoices to T02 with references back to T01 
	beginTransaction;
	foreach tran1 in cont1.allTransactions do
		oa.clear();
		foreach line1 in tran1.allInvoiceLines do
			oa.add(line1);
		endforeach;
		foreach obj in oa do
			line1 := obj.CM_InvoiceLine;
			if line1.invoice = null then
				continue;
			endif;
			debtor := line1.invoice.debtor;
			invType := self.jreGetInvoiceType(bank, line1.invoice.invoiceType);
			create newLine persistent;
			// PAR 30751 seqNum := bank.getSeqNumInvoiceLine();
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); // PAR 30751

			if tran1.dateTime.isValid then
				now := tran1.dateTime;
			else
				now := app.serverTimestampAtTrxStart;
			endif;
			inv2 := bank.getAutoInvoice(invType, line1.invoiceLineDesc, tran1, debtor, null);
			write method.name&amp;" debtor "&amp;debtor.name&amp;" invoice "&amp;inv2.sequenceNum.String;

			newLine.setForCreate(seqNum, false, null, line1.invoiceLineDesc, inv2, debtor, bank, 0, now);
			newLine.setMyTransaction(tran1);
			newLine.setTrackedItem(tran1.myTrackedItem);
			foreach service in newLine.invoiceLineDesc.services do
				// PAR 30751 seqNum2 := bank.getSeqNumCharge();
				seqNum2 := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE); // PAR 30751
				create charge persistent;
				charge.setForCreate(bank, newLine, seqNum2, service);
			endforeach;
			tmpTotal := newLine.lineTotal;
// TFS 38113			newLine.setQuantityRange(line1.quantityRangeStart, line1.quantityRangeEnd, line1.quantityRangeZero);
			qrm.setPropertyValue("rangeStart", line1.quantityRangeStart);
			qrm.setPropertyValue("rangeEnd", line1.quantityRangeEnd);
			newLine.setQuantityRange(qrm);
			newLine.calculateQuantity();
			foreach charge in newLine.charges do
				charge.evaluateRate();
			endforeach;
		endforeach;
	endforeach;
	//cont2.inspectModal;
	commitTransaction;
	// ALL SEEMS OK - can view and post the invoice/lines
epilog
	delete oa;
	delete qrm;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCheckInvoiceFinancialPeriod" id="0cae54ff-4dfc-4cb3-bf7e-07ab9f27338f">
        <source>jreCheckInvoiceFinancialPeriod();

vars
	date	: Date;
	term	: CM_Terminal;
	bank	: CM_Bank;
	invoice	: CM_Invoice;
	line	: CM_InvoiceLine;
	iter	: Iterator;
	count	: Integer;
	max	: Integer;
begin
	app.initialize;
	max := 50;
	foreach term in app.myRoot.allTerminals do
		foreach bank in term.companies do
			count := 0;
			delete iter;
			iter := bank.invoicesByStatus.createIterator();
			// posted
			bank.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_POSTED, iter);
			while iter.next(invoice)  do
				if invoice.status &gt; CM_Invoice.INVOICE_POSTED then
					break;
				endif;
				date := invoice.getPostedFinancialPeriod();
				write term.code &amp; " " &amp; bank.code &amp; " " &amp; invoice.debtor.name &amp; " posted " &amp; invoice.postedDT.String &amp; " period " &amp; date.String;
				count := count + 1;
				if count &gt; max then
					break;
				endif;
			endwhile;
		endforeach;
	endforeach;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreCheckRateEntryConvert" id="b3352cfd-9732-4f81-91dc-fa84c090eef9">
        <source>jreCheckRateEntryConvert();
/*
Date		Who		Reason
28 Sep 2012	cnwjre1	Initial creation - par 29980 escalating storage charges
*/
vars
	entry	: CM_RateEntry;

begin
	beginTransaction;
	
	foreach entry in CM_RateEntry.instances do
		// 'cost is amount' and 'rate is percentage' have been stored in extension objects
		// now we want to put them in real properties
		entry.convertExtensionObjectValue (Obj_Extn_costIsAmount, CM_RateEntry::costIsAmount);
		entry.convertExtensionObjectValue (Obj_Extn_rateIsPercentage, CM_RateEntry::rateIsPercentage);
	endforeach;

	commitTransaction;
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCheckReceiveTransactions" id="4497c407-ebfd-460b-9149-04eb3d042605">
        <source>jreCheckReceiveTransactions();

vars
	cont	: CM_Container;
	trans	: CM_TITransaction;
	rec		: CM_Receive;
	recRoad	: CM_ReceiveRoad;
	recShip	: CM_ReceiveShip;
	hasRelease	: Boolean;
	count	: Integer;
begin
	foreach cont in CM_Container.instances do
		rec := null;
		recShip := null;
		recRoad := null;
		hasRelease := false;
		foreach trans in cont.allTransactions do
			if trans.class.name = CM_Receive.name then
				rec := trans.CM_Receive;
			elseif trans.class.name = CM_ReceiveShip.name then
				recShip := trans.CM_ReceiveShip;
			elseif trans.class.name = CM_ReceiveRoad.name then
				recRoad := trans.CM_ReceiveRoad;
			elseif trans.isKindOf(CM_Release) then
				hasRelease := true;
			endif;
		endforeach;
		if rec &lt;&gt; null and not hasRelease then
			if recShip &lt;&gt; null and
			   recShip.dateTime.date &lt;&gt; rec.dateTime.date then
				cont.inspectModal;
				count := count + 1;
				if count &gt; 3 then
					return;
				endif;
			elseif recRoad &lt;&gt; null and
			   recRoad.dateTime.date &lt;&gt; rec.dateTime.date then
				cont.inspectModal;
				count := count + 1;
				if count &gt; 3 then
					return;
				endif;
			endif;
		endif;
		
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCheckReleasedProformas" id="557bb118-58a3-40f4-b88b-3909bb909e85">
        <source>jreCheckReleasedProformas();
// payments which are still pro forma but the cargo has been released
vars
	payment	: CM_CashPayment;
	ti		: CM_TrackedItem;
	cc		: CM_ColourCount;
	count	: Integer;
	latest	: Date;
begin
write 2457085.Date.String;	// 3 March 2015, from run in Gulftainer Backup on 13/03/2015 so still happening ... count was 712.
return;
	latest := "01/01/2000".Date;
	foreach payment in CM_CashPayment.instances do
		if payment.isProformaPayment then
			ti := payment.myTrackedItem;
			if global.isValidObject(ti) then
				if ti.isOffSite then
					count := count + 1;
					if payment.dateTime.date &gt; latest then
						latest := payment.dateTime.date;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	create cc transient;
	cc.count := count;
	cc.colour := latest.Integer;
	write latest;
	cc.inspectModal;
	
	delete cc;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCleanupCashReceipts" id="919c56d6-ac6e-47d9-ba26-31ba17b89910">
        <source>jreCleanupCashReceipts();
// delete cash receipt instances with invalid invoice line or tracked item references (because no inversed collecitons back to do it automatically)
vars
	invInvalid,
	tiInvalid	: Boolean;
	ed			: Integer;
	receipt		: CM_CashReceipt;
	invLine		: CM_InvoiceLine;
	ti			: CM_TrackedItem;
	toDelete	: ObjectArray;
begin
	on Exception do app.handleDeletedObject(exception, invLine, invInvalid);
	on Exception do app.handleDeletedObject(exception, ti, tiInvalid);
	
	create toDelete transient;
	foreach receipt in CM_CashReceipt.instances do
		foreach invLine in receipt.allInvoiceLines do
			invInvalid := false;
			ed := invLine.edition;
			if invInvalid then
				toDelete.add(receipt);
				break;
			endif;
		endforeach;
		if invInvalid then
			continue;
		endif;
		foreach ti in receipt.allTrackedItems do
			tiInvalid := false;
			ed := ti.edition;
			if tiInvalid then
				toDelete.add(receipt);
				break;
			endif;
		endforeach;
	endforeach;
	beginTransaction;
	toDelete.purge;
	commitTransaction;
	
epilog
	delete toDelete;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCleanupCurrencyCode" id="b172f8dc-25e0-4162-aec9-fe75ef2c1362">
        <source>jreCleanupCurrencyCode();

vars
	cc : CM_CurrencyCode;
begin
	beginTransaction;
	foreach cc in CM_CurrencyCode.instances do
		if cc.myRoot = null then
			write cc;
			delete cc;
		endif;
	endforeach;
	commitTransaction;

end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCleanupReceiptStateData" id="0be4e3a4-7d9b-4bba-86e3-59119ff04447">
        <source>jreCleanupReceiptStateData();

vars
	cr	: CM_CashReceipt;
	sd	: CM_StateData;
	count	: Integer;
begin
	beginTransaction;
	foreach cr in CM_CashReceipt.instances do
		foreach sd in cr.getPropertyValue("allExtraData").CM_StateDataDict do
			delete sd;
			count := count + 1;
		endforeach;
		cr.getPropertyValue("allExtraData").CM_StateDataDict.clear();
	endforeach;
	commitTransaction;
	write count;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreClearTermOption" id="08c29069-e886-4e99-bc80-40fd9c9549d2">
        <source>jreClearTermOption();

vars
	term	: CM_Terminal;
	allStateObjects	: CM_StateObjectArray;
	stateObj	: CM_StateObject;
	data		: CM_StateData;
begin
	app.initialize();
	
	term := CM_Root.firstInstance.allTerminals["JT1"];

	beginTransaction;
	allStateObjects := term.getPropertyValue("allStateObjects").CM_StateObjectArray;
	stateObj := allStateObjects[ConfigGrp_System];
	data := stateObj.allStateData[CashAllCashTax];
	delete data;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreConvertCashInvoice" id="bc569864-1c4b-4880-ade2-4818061784fb">
        <source>jreConvertCashInvoice();

vars
	count			: Integer;
	cashReceipt		: CM_CashReceipt;
	invoice			: CM_Invoice;
begin
	beginTransaction;
	foreach cashReceipt in CM_CashReceipt.instances do
		invoice := cashReceipt.myCashInvoice;
		if invoice &lt;&gt; null then
			invoice.convertExtensionObjectValue (Obj_Extn_myCashReceipt, CM_Invoice::myCashReceipt);
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;
	write count.String &amp; " converted cash invoices";

end;
</source>
    </JadeMethod>
    <JadeMethod name="jreConvertCashPaymentReceipt" id="26a42370-6025-4b10-9334-0e2fa4727e5b">
        <source>jreConvertCashPaymentReceipt();
//	
vars
	cashReceipt	: CM_CashReceipt;
	cashPayment	: CM_CashPayment;
	paymentDict	: CM_CashPaymentDict;
	tiPayment	: CM_CashPayment;
	ti			: CM_TrackedItem;
	allPayments	: ObjectArray;
	obj			: Object;
	any	 : Any;
begin
	/*
	beginTransaction;
	foreach cashPayment in CM_CashPayment.instances do
		if cashPayment.debtorDerivedFrom &lt;&gt; null then
			cashPayment.setCashReceipt(cashPayment.debtorDerivedFrom.CM_CashReceipt);
			cashPayment.setPropertyValue("debtorDerivedFrom", null);
		endif;
	endforeach;
	commitTransaction;
	beginTransaction;
	foreach cashReceipt in CM_CashReceipt.instances do
		if not cashReceipt.isPrimaryDDCashReceiptForPrint then
			continue;
		endif;
		paymentDict := cashReceipt.getAllCashPayments();
		if paymentDict &lt;&gt; null then
			foreach cashPayment in paymentDict do
				if cashPayment.myCashReceipt = null then
					cashPayment.setPropertyValue("myCashReceipt", cashReceipt);	// adds to allCashPayments
				endif;
			endforeach;
		endif;
		foreach ti in cashReceipt.allTrackedItems do
			foreach tiPayment in ti.allCashPayments do
				if tiPayment.myCashReceipt = null then
					tiPayment.setPropertyValue("myCashReceipt", cashReceipt);	// adds to allCashPayments
				endif;
			endforeach;
		endforeach;
	endforeach;
	commitTransaction;
	*/
	
	/*
	create allPayments transient;
	foreach cashPayment in CM_CashPayment.instances do
		if cashPayment.myCashReceipt = null then
			allPayments.add(cashPayment);
		endif;
	endforeach;
	
	beginTransaction;
	foreach cashReceipt in CM_CashReceipt.instances do
		foreach obj in allPayments do
			cashPayment := obj.CM_CashPayment;
			if cashPayment.dateTime.date = cashReceipt.dateTime.date and
			   cashPayment.dateTime.time.hour = cashReceipt.dateTime.time.hour and
			   cashPayment.dateTime.time.minute = cashReceipt.dateTime.time.minute and
			   cashPayment.dateTime.time.second = cashReceipt.dateTime.time.second then	write cashPayment.String;
				cashPayment.setPropertyValue("myCashReceipt", cashReceipt);	// adds to allCashPayments
			endif;
		endforeach;
	endforeach;
	commitTransaction;
	*/
	
	create allPayments transient;
	beginTransaction;
	foreach cashReceipt in CM_CashReceipt.instances do
		paymentDict := cashReceipt.getAllCashPayments();
		if paymentDict &lt;&gt; null then
			cashReceipt.setAllCashPayments(null);
			allPayments.add(paymentDict);
		endif;
	endforeach;
	commitTransaction;
	
	beginTransaction;
	allPayments.purge;
	commitTransaction;
epilog
	delete allPayments;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreConvertCashPayments" id="7315ed7b-9d38-4d0f-a85a-51dbdb697a6c">
        <source>jreConvertCashPayments();
// set the myInvoiceLine for existing cash payments - prototype eventual 8.3.1 conversion
vars
	first,
	matched	: Boolean;
	count	: Integer;
	cashValue,
	lineValue	: Decimal[16, 6];
	totalToAllocate	: Decimal[16, 4];
	paidCharges	: Decimal[16, 4];
	thisPayment	: Decimal[16, 4];
	lineCount,
	payCount	: Integer;
	now			: TimeStamp;
	pxyCashPayment	: CM_CashPayment;
	newCP,
	cp		: CM_CashPayment;
	linePayment	: CM_CashPayment;
	ti		: CM_TrackedItem;
	lastLine	: CM_InvoiceLine;
	line	: CM_InvoiceLine;
	dt		: CM_DebtorTerminal;
	debtor	: CM_Debtor;
	terminal	: CM_Terminal;
	allInvoiceLines	: CM_InvoiceLineSet;
	allPayments		: CM_CashPaymentSet;
	paymentsToDelete	: CM_CashPaymentSet;
	allTIs			: CM_TISet;
begin
	app.initialize();
	first := true;
	
	create allInvoiceLines transient;
	create allPayments transient;
	create allTIs transient;
	foreach cp in CM_CashPayment.instances do
		ti := cp.myTrackedItem;
		if ti &lt;&gt; null and
		   global.isValidObject(ti) then
			if not allTIs.includes(ti) then
				allTIs.add(ti);
			endif;
		endif;
	endforeach;
	
	create paymentsToDelete transient;
	beginTransaction;
	foreach ti in allTIs do
		terminal := ti.myTerminal;
		write ti.id &amp; " " &amp; terminal.code &amp; " " &amp; ti.displaySite;
		allInvoiceLines.clear();
		allPayments.clear();
		// only want non-void cash-debtor lines with a value
		foreach line in ti.invoiceLines do
			if line.voided or
			   line.lineTotal = 0 then
				continue;
			endif;
			if not line.debtor.isCashOnlyDebtor(terminal) then
				continue;
			endif;
			allInvoiceLines.add(line);
		endforeach;
		// don't want pro forma payments, they don't have an invoice line assigned yet
		foreach cp in ti.allCashPayments do
			if not cp.isProformaPayment then
				allPayments.add(cp);
			endif;
		endforeach;
		count := 0;
		while true do
			matched := false;
			count := count + 1;
			if count &gt; 10 then		// paranoia
				write "EXIT on count&gt;10";
				break;
			endif;
			foreach cp in allPayments do
				debtor := null;
				dt := cp.getDebtorTerminal;
				if dt &lt;&gt; null then
					debtor := dt.myDebtor;
				endif;
				foreach line in allInvoiceLines do
					if cp.myInvoiceLine = line then
						write " payment/myLine match, " &amp; cp.String &amp; " " &amp; line.String &amp; " " &amp; cp.cashValue.String;
						allInvoiceLines.remove(line);
						allPayments.remove(cp);
						matched := true;
						break;
					endif;
					if cp.cashValue = line.lineTotal and
					   debtor = line.debtor then
						write " cp/line match, " &amp; cp.String &amp; " " &amp; line.String &amp; " " &amp; cp.cashValue.String;
					cp.setPropertyValue("myInvoiceLine", line);
						allInvoiceLines.remove(line);
						allPayments.remove(cp);
						matched := true;
						break;
					endif;
				endforeach;
				if matched then
					break;
				endif;
			endforeach;
			if not matched then
				break;
			endif;
		endwhile;
		cashValue := 0;
		lineValue := 0;
		lineCount := 0;
		payCount := 0;
		foreach cp in allPayments do
			cashValue := cashValue + cp.cashValue;
			payCount := payCount + 1;
		endforeach;
		foreach line in allInvoiceLines do
			lineValue := lineValue + line.lineTotal;
			lineCount := lineCount + 1;
		endforeach;
		write " " &amp; payCount.String &amp; " payments=" &amp; cashValue.String &amp; " " &amp; lineCount.String &amp; " lines=" &amp; lineValue.String;
		// delete payments which have no matching invoice lines - these are spurious ones from the old debtor balance code
		if lineCount = 0 and
		   payCount &lt;&gt; 0 then
			foreach cp in allPayments do
				paymentsToDelete.add(cp);
			endforeach;
		endif;
		
		if lineCount &gt; 0 and
		   payCount &gt; 0 then
			// get the last line
			foreach lastLine in allInvoiceLines do
			endforeach;
			foreach cp in allPayments do
				totalToAllocate := cp.cashValue;
				foreach line in allInvoiceLines do
					paidCharges := 0;
					foreach linePayment in line.allCashPayments do
						paidCharges := paidCharges + linePayment.cashValue;
					endforeach;
					if line.lineTotal &gt; paidCharges then
						thisPayment := line.lineTotal - paidCharges;
					else
						thisPayment := 0;
					endif;
					if thisPayment &gt; 0 then
						if thisPayment &gt; totalToAllocate then
							thisPayment := totalToAllocate;
						endif;
						// over-payment is allocated to the last line
						if line = lastLine and
						   totalToAllocate &gt; thisPayment then
						   thisPayment := totalToAllocate;
						endif;
						totalToAllocate := totalToAllocate - thisPayment;
						create pxyCashPayment transient;
						write " new payment " &amp; thisPayment.String &amp; " for line " &amp; line.String &amp; " " &amp; line.lineTotal.String;

						pxyCashPayment.setProxy(thisPayment,			//_cashValue : Decimal;
												0,						//_taxAmount : Decimal;
												cp.dateTime,			//_dateTime : TimeStamp;
												null,					//_proformaDesc : String;
												false,					//_manual : Boolean;
												0,						//_status : Integer;
												false,					//_voided : Boolean;	
												cp.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
												cp.myTrackedItem,		//_myTrackedItem : CM_TrackedItem;
												line.invoice,			//_myInvoice : CM_Invoice;
												null,					//_vvr : CM_VehicleVisitRecord;
												cp.myUser				//_myUser : CM_User;
												);
						pxyCashPayment.setPropertyValue("myCarrier", cp.myCarrier);
						pxyCashPayment.setPropertyValue("myDriver", cp.myDriver);
						pxyCashPayment.setInvoiceLine(line);
						pxyCashPayment.setCashReceipt(cp.myCashReceipt);
						newCP := app.myUtilityCA.utlCreateCashPayment(pxyCashPayment, app.myPassport);
					endif;
					if totalToAllocate &lt;= 0 then
						break;
					endif;
				endforeach;
				paymentsToDelete.add(cp);
			endforeach;
		endif;
	endforeach;
	
	write paymentsToDelete.size.String &amp; " payments to delete";
	paymentsToDelete.purge();
	commitTransaction;
	
epilog
	delete allInvoiceLines;
	delete allPayments;
	delete allTIs;
	delete paymentsToDelete;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCreateActivityHistory" id="80de01b2-e0b4-4133-b5c8-d2c1d0d9bf41">
        <source>jreCreateActivityHistory();
// add new activity history to test par 28754
vars
	count,
	max		: Integer;
	term	: CM_Terminal;

begin
	app.initialize();
	
	max := 2;
	foreach term in CM_Terminal.instances do
		if term.code = "T01" then
			break;
		endif;
	endforeach;
	
	beginTransaction;
	foreach count in 1 to max do
		app.createActivityHistory(ActivityHistoryGeneral, null, null, "System Testing", true, false);
		process.sleep(100);
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreCreateConsigneeDebtors" id="8926092f-d1bc-4a4f-9f29-b7bd84d49a80">
        <source>jreCreateConsigneeDebtors();
// 34679 create a cash-only debtor for each consignee who does not already have a debtor
//	also make existing debtors who have at least one consignee cash-only if not already
vars
	root	: CM_Root;
	rootBank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;
	consignee	: CM_ConsigneeConsignor;
	parent		: CM_DebtorNode;
	debtorNode	: CM_DebtorNode;
	debtor		: CM_Debtor;
	debtorNodeController : CMIF_DebtorNode;
	terminal	: CM_Terminal;
	allTerminals	: CM_TerminalArray;
	count,
	count2		: Integer;
		debtorTermDetail : CMIF_DebtorTerminalDetail;
	term : CM_Terminal;


begin
	app.initialize();

	root := app.myRoot;
	rootBank := root.myRootCompany;
	rdg := rootBank.getRootDebtorGroup();
	parent := rdg;
	create allTerminals transient;
	// NOTE at the time of running this, GLT had not cash-enabled their two terminals
	foreach terminal in root.allTerminals discreteLock do
		allTerminals.add(terminal);
	endforeach;
	
	// there are some debtors for consignee who are not cash-only
	beginTransaction;
	foreach debtorNode in rootBank.debtorNodes do
		if debtorNode.isKindOf(CM_Debtor) then
			debtor := debtorNode.CM_Debtor;
			if not debtor.consignors.isEmpty then
				foreach terminal in allTerminals do
					if debtor.allDebtorTerminals[terminal] = null then
						//debtor.createDebtorTerminal(terminal, true, null);
						//debtor.createDebtorTerminal(terminal, true, null, null, null, null); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
						debtor.createDebtorTerminal(terminal, true, null, null, null, null, "", ""); //navra1 - TFS 57086 - 1st May 2023
						count2 := count2 + 1;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	commitTransaction;

	beginTransaction;
	foreach consignee in CM_ConsigneeConsignor.instances do
		if consignee.isNotAvailableForEntry then
			continue;
		endif;
		if not consignee.isConsignee then
			continue;
		endif;
		if consignee.debtor = null then
			if rootBank.debtorNodes.includesKey(consignee.description) then
				///write "debtor " &amp; consignee.description &amp; " already exists";
				continue;
			endif;
			create debtorNodeController transient;
			debtorNodeController.allConsignors.add(consignee);
			debtorNodeController.myBank := rootBank;
			debtorNodeController.myTermsOfTrade := null ;
			debtorNodeController.myParentDebtorNode := parent;
			debtorNodeController.name := consignee.description;
			debtorNodeController.decfinName := consignee.code;

			// ### TFS 52237 02NOV2021 NAVAB1 add debtor terminal for all terminals
			foreach term in root.allTerminals do
				create debtorTermDetail transient;
				
				debtorTermDetail.setMyTerminal(term);
				debtorTermDetail.setPaymentType(PaymentType_PostPay);
				debtorTermDetail.setCashOnly(allTerminals.includes(term));
				debtorNodeController.allDebtorTerminalDetails.add(debtorTermDetail);
			endforeach;

			create debtor persistent;
			debtor.setForCreate(debtorNodeController);
			consignee.setDebtor(debtor);
			delete debtorNodeController;
			///write "created debtor " &amp; consignee.description;
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;
	///write count.String &amp; " new debtors";
	///write count2.String &amp; " updated to cash-only";
epilog
	delete allTerminals;
	debtorNodeController.allDebtorTerminalDetails.purge();
	delete debtorNodeController;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreDeleteCalendar" id="309ce4d9-5e94-4229-a745-0ab1d51a0612">
        <source>jreDeleteCalendar();

vars
	calendar	: CM_Calendar;
	dayType		: CM_DayType;
begin
	app.initialize();

	foreach calendar in CM_Calendar.instances do
		if calendar.code = "UTS2" then
			dayType := calendar.myDayType;
			beginTransaction;
			calendar.allTerminals.clear();
			commitTransaction;
			app.myTrxDA.trxDeleteCalendar(calendar, app.myPassport);write "calendar deleted";
			if dayType &lt;&gt; null then
				app.myTrxDA.trxDeleteDayType(dayType, app.myPassport);write "day type deleted";
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreDeleteCashReceipts" id="69d34dc4-3409-4b08-98f9-c1cb734a8c89">
        <source>jreDeleteCashReceipts();
// Delete cash receipts, refunds and payment methods to clean up and avoid reorg.
vars
	cr	: CM_CashReceipt;
	pm	: CM_PaymentMethod;
	il	: CM_InvoiceLine;
	count,
	count1,
	count2: Integer;
begin

	beginTransaction;
	foreach cr in CM_CashReceipt.instances do
		delete cr;
		count1 := count1 + 1;
	endforeach;
	commitTransaction;
	write method.name &amp; " " &amp; count1.String &amp; " cash receipts deleted";
	
return;
	
	
	count := 0;
	beginTransaction;
	foreach pm in CM_PaymentMethod.instances do
		delete pm;
		count := count + 1;
	endforeach;
	commitTransaction;
	write method.name &amp; " " &amp; count.String &amp; " payment methods deleted";
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreDeleteEDIMoveTI" id="d5661714-50ed-46ac-9202-2b364b17c926">
