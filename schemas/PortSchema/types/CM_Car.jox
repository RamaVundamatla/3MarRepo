    <JadeMethod name="setPxyFromCMIF_Receival" id="47a70f39-feb4-4812-b054-b2e9f85fb94a">
        <updating/>
        <source>setPxyFromCMIF_Receival(isUpdateTI: Boolean; pReceival: CMIF_Receival; _passport: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/09/2009	cnwdap1	Initial creation
13/09/2013	cnwdap1	PAR #32215 New Car attributes
// 17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields
*/
vars

begin
	inheritMethod(isUpdateTI,pReceival, _passport);			//+TFS38055
	
	if pReceival.hasRadio then
		self.hasRadio	:= CM_Car.HasRadio;
	else
		self.hasRadio	:= CM_Car.NoRadio;
	endif;
	self.selfPropelled	:= pReceival.selfPropelled;
	
	self.colour				:= pReceival.colour;				// PAR #32215
	self.make				:= pReceival.make;					// PAR #32215
	self.model				:= pReceival.model;					// PAR #32215
	self.carType			:= pReceival.carType;				// PAR #32215
	self.year				:= pReceival.year;					// PAR #32215
	self.trackingNumber1	:= pReceival.trackingNumber1;		// PAR #32215
	self.trackingNumber2	:= pReceival.trackingNumber2;		// PAR #32215
	self.docsReceived		:= pReceival.docsReceived;			// PAR #32215
	self.docsSent			:= pReceival.docsSent;				// PAR #32215
	self.docsCleared		:= pReceival.docsCleared;			// PAR #32215
	self.docsReturned		:= pReceival.docsReturned;			// PAR #32215
	self.nbrDoors			:= pReceival.nbrDoors;				// PAR #32215
	self.isNew				:= pReceival.isNew;					// PAR #32215
epilog

end;</source>
        <Parameter name="isUpdateTI" type="Boolean"/>
        <Parameter name="pReceival" type="CMIF_Receival"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
