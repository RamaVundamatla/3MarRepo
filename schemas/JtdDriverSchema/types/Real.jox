<PrimType name="Real">
    <JadeMethod name="jtdRoundedSeconds" id="10d59968-f0bb-4b9c-b43f-da504356554a">
        <source>jtdRoundedSeconds() : Real;

begin
	if self &lt; 0 then
		return self.roundedTo(1);
	endif;
	
	if self &lt; 1000 then
		return self.roundedTo(2);
	endif;
	
	if self &lt; 10000 then
		return self.roundedTo(1);
	endif;
	
	return self.roundedTo(0);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
