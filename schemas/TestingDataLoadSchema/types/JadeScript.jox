    <JadeMethod name="reset41921" id="e717b320-ff6c-42f8-a087-a6b57d1dc43b">
        <source>reset41921();
/*

Purpose:	Reset 41921		

Date		Who		Reason
12/11/2018	jlgmh5	Initial creation

*/
constants

	VoyageID1					: String = "MESDIAMZ0001";
	VoyageID2					: String = "MESDIAMZ10001";

vars

	dsl							: UT_DSL;
	voyage						: CM_Voyage;
	allocation					: CM_VoyageAllocation;

begin

	app.initialize();
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	dsl.deleteVoyage(VoyageID1);
	dsl.deleteVoyage(VoyageID2);
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Trade", "Tasman Trade Route");
	dsl.opts.addAssoc("UseAllocations", true);
	dsl.opts.addAssoc("VoyageAllocations", "14;19;2;5;13");
	
	voyage := dsl.addVoyageWithContainerStructur(VoyageID1, VoyageID1[1:8], "MSL", "MSL");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageID1 &amp; ") was not created.", LogINFO);
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Trade", "Tasman Trade Route");
	dsl.opts.addAssoc("UseAllocations", true);
	dsl.opts.addAssoc("VoyageAllocations", "14;19;2;5;13");
	
	voyage := dsl.addVoyageWithContainerStructur(VoyageID2, VoyageID2[1:9], "MSL", "MSL");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageID2 &amp; ") was not created.", LogINFO);
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Cargo Type", 1);
	dsl.opts.addAssoc("Commodity", "GEN");
	dsl.opts.addAssoc("Operator (Item)", "MSL");
	dsl.opts.addAssoc("ISO Type", "2200");
	dsl.opts.addAssoc("IMEX", 7);
	allocation := dsl.addVoyageAllocation(voyage);
	if allocation = null then
		app.writeLog("Voyage Allocation (E 2200 MSL CONT GEN USJAX) was not created.", LogINFO);
	endif;
	
epilog

	delete dsl;

end;</source>
    </JadeMethod>
