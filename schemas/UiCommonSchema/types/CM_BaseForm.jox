    <JadeMethod name="picExtractMethod" id="e622ff65-6398-4432-8d24-255c1348f1c9">
        <source>picExtractMethod(pPic : Binary);
// ---------------------------------------------------------------------------
// Created:     18 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	file		: File;
	cmdFile		: CMDFileSave;
	thePic		: Binary;

begin

	create cmdFile;
	cmdFile.dialogTitle	:= 'Select a file';
	cmdFile.initDir	:= 'c:\temp';
	
	if cmdFile.open = 0 then
		create file;
		file.mode		:= file.Mode_Output;
		file.kind		:= file.Kind_Binary;
		file.fileName	:= cmdFile.fileName;
		file.writeBinary(pPic);
	endif;
	
epilog
	delete file;
	delete cmdFile;

end;</source>
        <Parameter name="pPic" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="picLoadMethod" id="3dbc0b2c-836f-414b-8860-f81c4f531cb3">
        <updating/>
        <source>picLoadMethod() : Binary updating;
// ---------------------------------------------------------------------------
// Created:     18 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	file		: File;
	cmdFile		: CMDFileOpen;
	thePic		: Binary;

begin

	create cmdFile;
	cmdFile.dialogTitle	:= 'Select a picture file';
	cmdFile.initDir	:= 'c:\temp';
	
//	PictureType_None		: Integer = 0;		// Not a valid picture
//	PictureType_Bitmap		: Integer = 1;		// Bitmap
//	PictureType_NotUsed		: Integer = 2;		// Not used
//	PictureType_Icon		: Integer = 3;		// Icon
//	PictureType_Metafile	: Integer = 4;		// Metafile
//	PictureType_Cursor		: Integer = 5;		// Cursor
//	PictureType_TIF			: Integer = 6;		// Tag Image File Format (.tif file)
//	PictureType_JPEG		: Integer = 7;		// Joint Photographic Experts Group (JPEG)
//	PictureType_PNG			: Integer = 8;		// Portable Network Graphics (PNG)
//	PictureType_Gif			: Integer = 9;		// Graphic Interchange Format (GIF)
	
	cmdFile.filter := "Pictures(*.bmp;*.ico;*.jpg;*.gif;*.png;*.tiff)|*.bmp;*.ico;*.jpg;*.gif;*.png;*.tif"; // cnwrd1 3.11.08 par #18282

	
	if cmdFile.open = 0 then
		create file;
		file.mode		:= file.Mode_Input;
		file.kind		:= file.Kind_Binary;
		file.fileName	:= cmdFile.fileName;
		
		if not file.tryOpen() then
			app.msgBox("Can't open picture file ' " &amp; file.fileName &amp; "'",
					   "Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return thePic;
		endif;
		
		thePic := file.readBinary(file.fileLength);
		if not thePic.isPictureValid then // cnwrd1 3.11.08 par #18282
			app.msgBox("Invalid Picture file ' " &amp; file.fileName &amp; "'",
					"Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return null;
		endif;
	endif;
	
	return thePic;

epilog
	delete file;
	delete cmdFile;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
