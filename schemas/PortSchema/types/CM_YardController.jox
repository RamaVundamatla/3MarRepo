        <source>setForCreate(pProxy : CM_YardController; pTerminalArea : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.power			:= pProxy.power;
	self.powerDamaged	:= pProxy.powerDamaged;
	self.remarks		:= pProxy.remarks.trimBlanks;
	
	self.setForCreateLocnCntrl(pProxy);
	
	self.myTerminalArea	:= pTerminalArea;

end;</source>
