<Class name="SchemaComparisonUtility" id="eacbde19-d194-4abb-a855-c550cfce3c79">
    <superclass name="RootSchemaApp"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="sortSCMByClassMethodWithParams" id="1d54a06f-717c-4014-83ad-dbdca3fe9b2b">
        <source>sortSCMByClassMethodWithParams(_inputFile, _outputFile : File io);

/*

To allow for a simple source file comparison between to scm files, this JadeScript will strip out all the 
method sources from a given scm file, and output them into a new file in a slightly different format, to 
allow easier identification of the class and method name.

Importantly, it will also output the methods within a class in alphabetical order, rather than in Method oid
order, so that source file comparison between two similar schemas will be possible.

*/

vars
	
	nextLineOfFile 			: String;
	previousLineOfFile		: String;
	
	inMethodSources			: Boolean;
	currentClassName,
	currentMethodName		: String;
	methodSources			: MethodSourceByClassMethodDict;
	currentMethod			: MethodSource;
	pos						: Integer;
	
begin
	
	create methodSources transient;
	
	inMethodSources := false;
	currentClassName := null;
	
	while not _inputFile.endOfFile do
		previousLineOfFile := nextLineOfFile;
		nextLineOfFile := _inputFile.readLine;
		
		// Skip file until after typeSources line
		if not inMethodSources then
			if nextLineOfFile.pos( "typeSources", 1 ) &gt; 0 then
				inMethodSources := true;
			endif;
			continue;
		endif;

		// Have we got a new class?
		if nextLineOfFile.pos("jadeMethodSources", 1) &gt; 0 then
			currentMethod := null;
			
			pos := 2;
			currentClassName := previousLineOfFile.scanUntil(" ", pos);
			write "Processing Class " &amp; currentClassName;
			
			// Skip to next line
			continue;
		endif;
		
		// If we have no current class, then skip this line
		if currentClassName = null then
			continue;
		endif;
		
		// Are we between methods
		if currentMethod = null then
			currentMethodName := nextLineOfFile.trimBlanks;
			
			// Skip any blank lines and "Start of Class"/"End of Class" markers between methods
			if currentMethodName = null or 
			   currentMethodName.pos(")", 1) &gt; 0 or 
			   currentMethodName.pos("(", 1) &gt; 0 then
				currentMethodName := null;
				continue;
			endif;
			
			// Otherwise create a method object and skip to the next line
			create currentMethod transient;
			currentMethod.methodName := currentMethodName;
			currentMethod.className := currentClassName;
			methodSources.add(currentMethod);
			continue;
		endif;
		
		// Skip the "Start of Method Source" marker line
		if nextLineOfFile.trimBlanks = "{" then
			continue;
		endif;
		
		// Close off the current method at the "End of Method Source" marker
		if nextLineOfFile.trimBlanks = "}" then
			currentMethod := null;
			continue;
		endif;
		
		// Got to here, must be inside the current method source, so just add the current line to the source
		if currentMethod.methodSource = null then
			currentMethod.methodSource := nextLineOfFile;
		else
			currentMethod.methodSource := currentMethod.methodSource &amp; CrLf &amp; nextLineOfFile;
		endif;
	endwhile;
	
	// Write all the methods from the final class (in alphabetical order)
	foreach currentMethod in methodSources do
		_outputFile.writeLine(currentMethod.className &amp; "::" &amp; currentMethod.methodName);
		_outputFile.writeLine("{");
		_outputFile.writeString(currentMethod.methodSource &amp; CrLf);
		_outputFile.writeLine("}");
	endforeach;		
		
	_outputFile.close ;

epilog
	
	if methodSources &lt;&gt; null then
		methodSources.purge;
	endif;
	
end;
</source>
        <Parameter name="_inputFile" type="File" usage="io"/>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
</Class>
