    <JadeMethod name="setColumn" id="6d8df653-bad0-450c-94d5-69fe2b54d12d">
        <updating/>
        <source>setColumn(_column : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.column := _column;
	if self.myPxyGridColumn &lt;&gt; null then
		self.myPxyGridColumn.setColumn(_column);
	endif;
	
end;</source>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="47ee573d-d87c-4631-bc2b-cbf49da778e5">
        <updating/>
        <source>setForCreate(_sopGridArea : SOP_GridArea; _gridCol : CM_GridColumn) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin


	self.setLabel(_gridCol.label, _sopGridArea);//validateLabel();
	//epr par 24463 14/7/10
	if _gridCol.isKindOf(CM_GridColumn) and _gridCol.CM_GridColumn.allControllersByRow.size &gt;  0 then
		self.label40ftold:=_gridCol.CM_GridColumn.allControllersByRow.first.get40ftColumnLabel;
	endif;
	self.column := _gridCol.column;
	self.myGridCol := _gridCol;
	self.myPxyGridColumn := _gridCol;
	self.myGridArea	:= _sopGridArea;

end;</source>
        <Parameter name="_sopGridArea" type="SOP_GridArea"/>
        <Parameter name="_gridCol" type="CM_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="setLabel" id="dc463638-469d-4ec4-868f-bb0ecd83f51d">
        <updating/>
        <source>setLabel(_label : String; _sop_GridArea : SOP_GridArea)updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

	count		: Integer;
	doBreak		: Boolean;
begin

	count := 0;
	// TFS 2232 want to keep "1" as is and not pad with zeros so it looks better
	self.label := _label;
	//if _label.length = 1 and _label.isInteger then
	//	self.label := _label.padLeadingZeros(4);
	//else
	//	if _label[1:1] = "_" and _label.length &gt; 1 then
	//		self.label :="_" &amp;  _label[2:end].Integer.String.padLeadingZeros(4);
	//	else
	//		self.label := _label;
	//	endif;
	//endif;
	if _sop_GridArea = null then
		return;
	endif;

	while _sop_GridArea.hasColLabel(self.label) do
		if count = 99 or doBreak then
			break;	//give up other validation will catch it - user can re-enter label
		else
			self.label := _sop_GridArea.getNextLabel(self.label,doBreak);
			count := count + 1;
		endif;
	endwhile;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_sop_GridArea" type="SOP_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setProxySOPGridColumn" id="78ae684e-96df-482e-9b82-f8ab429e7600">
        <source>setProxySOPGridColumn(_gridArea : CM_GridArea; _mode : Integer) : CM_GridColumn;

vars

	gridColumn : CM_GridColumn;
	colNumber : Integer;
begin

	
	
	if _mode = CM_TableViewForm.Mode_Add or self.myGridCol = null then
		colNumber := self.column;
		gridColumn := _gridArea.allGridColumns[colNumber];
		if gridColumn = null then
			create gridColumn transient;
		endif;
	else
		colNumber := self.myGridCol.column;
		gridColumn := _gridArea.allGridColumns[colNumber];
		if gridColumn = null then
			gridColumn := self.myGridCol;
		endif;
	endif;
	
	if gridColumn = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Grid Column is null");
	endif;
	gridColumn.setForProxy(colNumber, self.label, _gridArea);
	return gridColumn;
end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_GridColumn"/>
    </JadeMethod>
</Class>
