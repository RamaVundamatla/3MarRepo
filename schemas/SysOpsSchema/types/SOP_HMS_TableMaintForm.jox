    <JadeMethod name="mnuInsertRow_click" id="4b986d9e-f393-4a5a-879f-41e326554477">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInsertRow_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
begin
	theRow := self.tblRoute.row;
	if theRow &gt; 0 and theRow &lt;= self.tblRoute.rows then
		self.tblRoute.addItemAt(null, theRow);
		self.tblRoute.row := theRow;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAllTblItems" id="eb33d35e-2fd7-4324-b347-73332da02c16">
        <updating/>
        <source>setAllTblItems(_mode: String) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------------------
// 31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation - no more HMS Voyage Delays
vars
	subClasses		: ClassColl;
	subClass		: Class;
	maintItemObj	: SOP_TableMaintItem;
	tmpTerminal		: CM_Terminal;
	tmpUser			: CM_User;

begin
	if _mode &lt;&gt; Mode_Harbour then
		inheritMethod(_mode);
		return;
	endif;

	beginLoad;
	
	self.allTableItems.purge;
	//self.myCurrentTableItem := null;
	self.setCurrentTableItem(null);							
	tmpUser := app.getMyUser();
	tmpTerminal := self.myTerminal;

	create subClasses transient;
	SOP_TableMaintItem.allLocalSubclasses(subClasses);

	foreach subClass in subClasses do
		if subClass.abstract then
			continue;
		endif;
		
		if (not subClass.inheritsFrom(SOPTM_HMS)) then
			continue;
		endif;
		
		if self.myHarbour = null then
			if subClass &lt;&gt; SOPTM_HMS_Harbour then
				continue;
			endif;
		endif;
		
		if subClass = SOPTM_HMS_Delay then					// PAR #35397
			continue;										// PAR #35397
		endif;												// PAR #35397
		
		create maintItemObj as subClass transient;
		
		if (maintItemObj.permissionGroup &lt;&gt; 0 and (not tmpUser.canDo(tmpTerminal, maintItemObj.permissionGroup))) 
		or (not tmpUser.canDo(tmpTerminal, maintItemObj.permissionView))
		then
			delete maintItemObj;
			continue;
		endif;
		
		self.allTableItems.add(maintItemObj);	
	endforeach;
	
	if self.allTableItems.isEmpty() then
		self.permissionMaint	:= 0;
		self.permissionView		:= 0;
	else
		maintItemObj			:=	self.allTableItems.first();
		self.permissionMaint	:=	maintItemObj.permissionMaint;
		self.permissionView		:=	maintItemObj.permissionView;
	endif;
epilog
	endLoad;
	delete subClasses;
end;</source>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
