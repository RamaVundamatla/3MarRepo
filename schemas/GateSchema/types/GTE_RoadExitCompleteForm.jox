    <JadeMethod name="initCmbCopies" id="93aa8c65-15ad-4b69-90e6-17d1d3b159f4">
        <source>initCmbCopies();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 August 2007
//
//----------------------------------------------------------------------

vars
	listPointer : Integer;
begin
	listPointer	:=	10;
	
	while listPointer &gt; 1 do
		listPointer	:=	listPointer - 1;
		self.cmbCopies.addItem(listPointer.String);
	endwhile;
	
	self.cmbCopies.listIndex := 9;
	
epilog

end;</source>
