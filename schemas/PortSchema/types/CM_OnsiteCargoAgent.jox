begin
	_collection.clear();
	startDateTime.setTime("00:00:00".Time);
	startDateTime.setDate(_date);
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(_date);

	create col transient;
	// search for all releases
	self.myTerminal.getTITxnsForTypeAll(TRANS_TYPE_RELEASE, startDateTime, endDateTime, null, null, col);
	
	foreach tran in col do
