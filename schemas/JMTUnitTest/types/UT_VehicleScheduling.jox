    <JadeMethod name="uCreate5VbsSlotType" id="0dce0889-83d4-4fb6-8c6b-b530a0d50f29">
        <source>uCreate5VbsSlotType();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 Sep 2022	navak20	TFS ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
24 May 2023 navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

constants
	REF = UT_DSL.TFS53899;
	CARRIERCODE : String = REF &amp; "CAR";
	SUBCARRIERCODE : String = REF &amp; "SUBCAR";
	DRIVERID    : String = REF &amp; "DRIVER";
	VEHICLEID   : String = REF &amp; "VEHICLE";
	ID			: String = "UIDUT" &amp; REF;
vars
	realVbsTimeSlot,
	proxyVbsTimeSlot,
	proxyVbsTimeSlot2		: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	id,						
	externalReference, remarks		: String;
	date					: Date;
	startTime,
	endTime,
	startTS, endTS 			: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	vbsTimeSlotITemsArray	: CM_ObjectArray;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	preGateInCheck,
	postGateCheck,
	kioskCheck				: Boolean;
	loadState				: Boolean;
	pxyObjArray,
	realObjArray			: ObjectArray;
	i 						: Integer;
	itr 					: CM_VehicleBookingTimeSlot;
begin
	create pxyObjArray transient;
	self.deleteVbsTimeslotType(REF &amp; "U");
	self.deleteVbsTimeSlotAdv(ID);
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(REF &amp; "U", "Slot Type Update " &amp; REF); 
		
	foreach i in 1 to 5 do
		self.deleteCarrier(CARRIERCODE &amp; i.String);
		
		// Create the transient vehicle booking time slot 
		create proxyVbsTimeSlot transient;

		// create vehicle booking time slot item
		self.createVbsTimeSlotItem(proxyVbsTimeSlot, "UTC01" &amp; i.String);
		
		// get tracked item
		vbsTimeSlotItem := proxyVbsTimeSlot.allVehicleBookingItems.first;
		self.assertNotNullMsg(vbsTimeSlotItem, "Proxy VehicleBookingTimeSlotItem");
		trackedItem := vbsTimeSlotItem.myTrackedItem;
		assertNotNullMsg(trackedItem, "Tracked Item");
		
		carrier := self.addCarrier(CARRIERCODE &amp; i.String, CARRIERCODE &amp; i.String, null, false, true, true, null);
		
		startTime.setTime(vbsSlotType.startTime);
		startTime.setDate(date);
		
		endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
		endTime.setDate(date);
		
		proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, null, null, null, null, true, false, null, null, vbsSlotType, ID &amp; i.String, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);		// 08 Aug 2024 navcs2	ChangeRequest 63928
		pxyObjArray.add(proxyVbsTimeSlot);
		delete vbsTimeSlotItem;
	endforeach;
	
	create realObjArray transient;
	//trx to create VBS slot type
	foreach itr in pxyObjArray as CM_VehicleBookingTimeSlot do
		app.myTrxCA.trxCreateVehicleBookingAdv(itr, realVbsTimeSlot,false, app.myPassport);				//24.5.2023 navhl20 #58041
		self.assertNoTrxErrorsOrWarnings();
		self.assertNotNull(realVbsTimeSlot);
		realObjArray.add(realVbsTimeSlot);
		delete itr;
	endforeach;
	
	startTS := self.systemToLocalTime(app.actualTimeServer);
	endTS := self.systemToLocalTime(app.actualTimeServer);
	remarks := "Testing";
	
	//Update trx
	foreach itr in realObjArray as CM_VehicleBookingTimeSlot do
		beginTransaction;
			proxyVbsTimeSlot2 := app.createUpdateProxy(itr).CM_VehicleBookingTimeSlot;
		commitTransaction;
		app.myTrxUA.trxUpdateVbsTransferSlot(proxyVbsTimeSlot2, startTS, endTS, remarks, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertEqual(itr.bookingTSstart, startTS);
		self.assertEqual(itr.bookingTSend, endTS);
		self.assertEqual(itr.remarks, remarks);
		delete proxyVbsTimeSlot2;
	endforeach;
	
	//Trx to delete time slot
	app.myTrxDA.trxDeleteMultiVehicleBookSlots(realObjArray, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete proxyVbsTimeSlot2;
	delete pxyObjArray;
	delete realObjArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="uGenerateVBSTimeslots" id="0b2b0c20-5db7-45d0-9459-23412cd5fed5">
        <source>uGenerateVBSTimeslots();
/*

Purpose:			Unit Test that Tests the generation of vehicle booking time slots

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
24 October 2014	cnwndl1	Initial creation Par 35008
12 May 2016		cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	termCode,
	msg			: String;
	term		: CM_Terminal;
	vvsTerm		: CM_VehicleBookingTerminal;
	startDate,
	endDate		: Date;
	startSize,
	endSize		: Integer;

begin
	termCode := "&lt;enter terminal code&gt;";
	read termCode;
	term := app.myRoot.allTerminals.getAtKey( termCode.toUpper.trimBlanks );
	self.assertTrueMsg( term &lt;&gt; null, "No terminal found called '" &amp; termCode.toUpper.trimBlanks &amp; "'");

	vvsTerm := term.myVehicleBookingTerminal;
	self.assertTrueMsg( term &lt;&gt; null, "No vehicle booking terminal object found for '" &amp; term.code &amp; "', is vehicle booking enabled?");
	
	startDate := app.actualTimeServer.Date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endDate := startDate + term.getConfig( VsGenerateDaysInAdvance ).Integer;
	
	startSize := vvsTerm.allBookingsByTS.size;
	vvsTerm.generateSlotsFromTemplate(startDate,endDate);
	
	self.assertTrueMsg( app.myPassport.noErrors, "Failed to generate timeslots '" &amp; app.myPassport.getErrorsAndWarningsAsString &amp; "'");
	
	endSize := vvsTerm.allBookingsByTS.size;
	self.assertTrueMsg( startSize &lt;&gt; endSize , "Failed to generate any additional timeslots, possibly timeslots already exist for each of the days, or not configured, or no templates... ");

	msg := (endSize - startSize).Integer.String &amp; " additional timeslots added for '" &amp; term.code &amp; "' during " &amp; startDate.String &amp; " - " &amp; endDate.String;
	app.msgBox(msg,"Success",MsgBox_OK_Only);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uVbsSlotType" id="d00c6405-2e81-45d6-9207-1cf9505947ab">
        <source>uVbsSlotType();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 Sep 2022			navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
24 May 2023 		navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
*/

constants
	REF = UT_DSL.TFS53899;
	CARRIERCODE : String = REF &amp; "CAR";
	SUBCARRIERCODE : String = REF &amp; "SUB";
	DRIVERID    : String = REF &amp; "DRIVER";
	VEHICLEID   : String = REF &amp; "VEHICLE";
	ID			: String = "UIDUT" &amp; REF;
vars
	realVbsTimeSlot,
	proxyVbsTimeSlot,
	proxyVbsTimeSlot2		: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	id,						
	externalReference, remarks		: String;
	date					: Date;
	startTime,
	endTime,
	startTS, endTS 			: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	vbsTimeSlotITemsArray	: CM_ObjectArray;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	preGateInCheck,
	postGateCheck,
	kioskCheck				: Boolean;
	email					: CM_EmailEntityByTypeNameDict;
	loadState				: Boolean;
	objectArray				: ObjectArray;
begin
	
	self.deleteVbsTimeSlotAdv(ID);
	self.deleteVbsTimeslotType(REF &amp; "U");
	self.deleteVehicle(VEHICLEID);
	self.deleteDriverDetails(DRIVERID);
	self.deleteCarrier(CARRIERCODE);
	self.deleteCarrier(SUBCARRIERCODE);

	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(REF &amp; "U", "Slot Type Update " &amp; REF); 
	
	// Create the transient vehicle booking time slot 
	create proxyVbsTimeSlot transient;

	// create vehicle booking time slot item
	self.createVbsTimeSlotItem(proxyVbsTimeSlot, "UTC01");
	
	// get tracked item
	vbsTimeSlotItem := proxyVbsTimeSlot.allVehicleBookingItems.first;
	self.assertNotNullMsg(vbsTimeSlotItem, "Proxy VehicleBookingTimeSlotItem");
	trackedItem := vbsTimeSlotItem.myTrackedItem;
	
	create email transient;
	
	carrier := self.addCarrier(CARRIERCODE, CARRIERCODE, email, false, true, true, null);
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);
	
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date);
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date);
	
	proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, subCarrier, null, null, null, true, false, null, null, vbsSlotType, ID, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);		// 08 Aug 2024 navcs2	ChangeRequest 63928
	
	//trx to create VBS slot type
	app.myTrxCA.trxCreateVehicleBookingAdv(proxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);			//24.5.2023 navhl20 #58041
	self.assertNoTrxErrorsOrWarnings();
	
	startTS.setDateTime(2022,09,30,9,13,20,0);
	endTS.setDateTime(2022,09,30,9,13,20,0);
	remarks := "Testing";
	
	//Update trx
	proxyVbsTimeSlot2 := app.createUpdateProxy(realVbsTimeSlot).CM_VehicleBookingTimeSlot;
	app.myTrxUA.trxUpdateVbsTransferSlot(proxyVbsTimeSlot2, startTS, endTS, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realVbsTimeSlot.bookingTSstart, startTS);
	self.assertEqual(realVbsTimeSlot.bookingTSend, endTS);
	
	//Trx to delete time slot
	create objectArray transient;
	objectArray.add(realVbsTimeSlot);
	app.myTrxDA.trxDeleteMultiVehicleBookSlots(objectArray, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete tiStringArray;
	delete email;
	delete proxyVbsTimeSlot;
	delete proxyVbsTimeSlot2;
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="zAddVbsTemplates" id="0fc0112e-e958-4846-b3e3-9766f41f9cf9">
        <source>zAddVbsTemplates( 	name : String;
					priority : Integer;
					calendar : CM_Calendar;
					vvsTerm : CM_VehicleBookingTerminal;
					vbtst : CM_VehicleBookingTimeSlotType
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation

*/

vars

	proxy : CM_VehicleBookingDayTemplate;
	newDayTemp : CM_VehicleBookingDayTemplate;
	
	start : Time;
	duration : Integer;
	numSlots : Integer;
	remarks : String;
	endTime : Time;
	
begin

	create proxy transient;
	proxy.setProxy(	name,	//	_name : String;
					priority,	//	_priority : Integer;
					calendar,	//_myCalendar : CM_Calendar;
					vvsTerm	//_myVehicleBookingTerm : CM_VehicleBookingTerminal
					);
						
	app.myTrxCA.trxCreateVehicleDayTemp(proxy, newDayTemp, app.myPassport);
	self.assertTrueMsg(newDayTemp &lt;&gt; null, "VehicleBookingDayTemplate not created for '" &amp; name &amp; "'");
	
	if name = app.getErrorString(Default) then
		start := "00:00".Time;
		duration := 15;
		numSlots := 2;
		endTime := "23:59".Time;
	else
		start := "08:00".Time;
		duration := 30;
		numSlots := 2;
		endTime := "15:59".Time;
	endif;
	
	remarks := "Unit test data";
	
	while true do
		self.zAddVbsTimeslot(	start,	//start : Time;
								duration,	//duration : Integer;
								numSlots,	//numSlots : Integer;
								remarks,	//remarks : String;
								newDayTemp,	//dayTemp : CM_VehicleBookingDayTemplate;
								vbtst	//btst : CM_VehicleBookingTimeSlotType
								);
		if app.myPassport.hasErrors then
			break;
		endif;
		start := start.cnEcAddMinutes(duration);
		if start &gt; endTime or start = "00:00".Time then
			break;
		endif;
	endwhile;
	
	
epilog

	delete proxy;
	
end;
</source>
        <Parameter name="name" type="String"/>
        <Parameter name="priority" type="Integer"/>
        <Parameter name="calendar" type="CM_Calendar"/>
        <Parameter name="vvsTerm" type="CM_VehicleBookingTerminal"/>
        <Parameter name="vbtst" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="zAddVbsTimeslot" id="fb21c452-54e8-4ff2-9337-dad381d8633c">
        <source>zAddVbsTimeslot(	start : Time;
					duration : Integer;
					numSlots : Integer;
					remarks : String;
					dayTemp : CM_VehicleBookingDayTemplate;
					vbtst : CM_VehicleBookingTimeSlotType
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	proxy : CM_VehicleBookingTimeTemplate;
	newTimeTemp : CM_VehicleBookingTimeTemplate;

begin

	create proxy transient;
	proxy.setProxy(	duration,	//_duration : Integer;
					numSlots,	//_numberOfSlots : Integer;
					remarks,	//_remarks : String;
					start,	//_startTime : Time;
					dayTemp,	//_myDayTemplate : CM_VehicleBookingDayTemplate
					vbtst	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType	//01 Oct 2014	NDL	Par 35008
					);
					
	app.myTrxCA.trxCreateVehicleTimeTemp(proxy, newTimeTemp, app.myPassport);
	self.assertTrueMsg(newTimeTemp &lt;&gt; null, "VehicleBookingTimeTemplate not created for '" &amp; start.asStringJMT &amp; "'");
			
epilog

	delete proxy;

end;</source>
        <Parameter name="start" type="Time"/>
        <Parameter name="duration" type="Integer"/>
        <Parameter name="numSlots" type="Integer"/>
        <Parameter name="remarks" type="String"/>
        <Parameter name="dayTemp" type="CM_VehicleBookingDayTemplate"/>
        <Parameter name="vbtst" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="zAssociateVbsSlot" id="65cf54a4-f9f1-4553-a5bb-0d2e04777f4f">
        <source>zAssociateVbsSlot(	_vssSlot : CM_VehicleBookingTimeSlot	input;
				_vvr : CM_VehicleVisitRecord
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

vars

	proxy : CM_VehicleBookingTimeSlot;
	loadState : Boolean;
	strArray : StringArray;
	allDeliveryIds, allPickupIds : StringArray;		// TFS 51248
	ti : CM_TrackedItem;

begin
	
	app.cmsBeginLoad(loadState);
	proxy := _vssSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	create allDeliveryIds transient;											// TFS 51248
	create allPickupIds transient;												// TFS 51248
	if _vvr = null then
		//_vssSlot.getTiIdsFromBookedItemsOrVvr(strArray);						// TFS 51248
		_vssSlot.getTiIdsFromBookedItemsOrVvr(allDeliveryIds, allPickupIds);	// TFS 51248
		allDeliveryIds.copy(strArray);											// TFS 51248
		allPickupIds.copy(strArray);											// TFS 51248
	else
		foreach ti in _vvr.allReceivedTrackedItems do
			strArray.add( ti.id );
			allDeliveryIds.add( ti.id );										// TFS 51248
		endforeach;
		foreach ti in _vvr.allReleasedTrackedItems do
			strArray.add( ti.id );
			allPickupIds.add( ti.id );											// TFS 51248
		endforeach;
	endif;
		
	proxy.setProxy(	_vssSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
					_vssSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
					_vssSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
					_vssSlot.myCarrier,	//_myCarrier : CM_Carrier;
					null,				//_mySubCarrier : CM_Carrier;
					_vssSlot.myDriver,	//_myDriver : CM_DriverDetails;
					_vssSlot.myVehicle,	//_myVehicle : CM_Vehicle;
					_vssSlot.remarks,	//_remarks : String;
					_vssSlot.includesDelivery,	//_includesDelivery : Boolean;
					_vssSlot.includesPickUp,	//_includesPickUp : Boolean;
					strArray,	//_bookedTiIds : StringArray;	
					_vvr,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
					_vssSlot.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
					_vssSlot.id,	//_id : String;
					_vssSlot.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
					_vssSlot.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
					null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					null,	//_preGateInCheck : Boolean;
					null,	//_preGateOutChck : Boolean;
					null,	//_kioskCheck : Boolean;
					null,	//_externalReference : String
					null 	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);									// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(proxy, allDeliveryIds, allPickupIds, app.myPassport);		// TFS 51248
	
epilog

	delete proxy;
	delete strArray;
	delete allDeliveryIds;			// TFS 51248
	delete allPickupIds;			// TFS 51248
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="_vssSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="zBookVbsSlot" id="5aa1ebc5-e3cc-4811-b95a-e3504fc676a3">
        <source>zBookVbsSlot(	_vbSlot : CM_VehicleBookingTimeSlot	input;
			_carrier : CM_Carrier;
			_driver : CM_DriverDetails;
			_vehicle : CM_Vehicle
			);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

vars

	proxy : CM_VehicleBookingTimeSlot;
	loadState : Boolean;

begin
	
	app.cmsBeginLoad(loadState);
	proxy := _vbSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
		
	proxy.setProxy(	_vbSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
					_vbSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
					_vbSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
					_carrier,	//_myCarrier : CM_Carrier;
					null,		//_mySubCarrier : CM_Carrier;
					_driver,	//_myDriver : CM_DriverDetails;
					_vehicle,	//_myVehicle : CM_Vehicle;
					_vbSlot.remarks,	//_remarks : String;
					true,	//_includesDelivery : Boolean;
					false,	//_includesPickUp : Boolean;
					null,	//_bookedTiIds : StringArray;	
					null,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
					_vbSlot.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
					_vbSlot.id,	//_id : String;
					_vbSlot.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
					_vbSlot.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
					null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					null,	//_preGateInCheck : Boolean;
					null,	//_preGateOutChck : Boolean;
					null,	//_kioskCheck : Boolean;
					null,	//_externalReference : String
					null 	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);				// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(proxy, null, null, app.myPassport);		// TFS 51248
	
epilog

	delete proxy;
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="_vbSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="zGateIn" id="afb75fcb-e1ff-411a-a134-ce5819350e08">
        <source>zGateIn( _truck : CM_Vehicle; _carrierCode : String; _driver : CM_DriverDetails; _cargoId : String ):CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation

*/
	
vars

	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
   
	
begin
	
	self.deleteContainer(_cargoId);	

	vvr := gateInStorageContainer(_truck.regNumber, _cargoId, "2200", operator.code, "MT", dualGate);
	ti := self.getTrackedItem(_cargoId);
	self.assertNoTrxErrorsOrWarnings();
	
	beginTransaction;
	vvr.setPropertyValue("carrierCode", _carrierCode);
	vvr.setPropertyValue("myDriverDetails", _driver);
	vvr.setPropertyValue("driversName", _driver.name);
	vvr.setPropertyValue("driverCode", _driver.code);
	commitTransaction;
	
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		
	self.moveVehicleToYard(vvr.vehicle);
		
	return vvr;
			
		
end;</source>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
