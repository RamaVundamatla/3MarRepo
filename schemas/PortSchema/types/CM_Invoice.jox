    <JadeMethod name="getRateDateForCurrencyCode" id="ca8bf883-415c-4850-9d6f-babf2ed1aa88">
        <source>getRateDateForCurrencyCode():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2018	jlgndl1	Initial creation	TFS 40908

*/

vars

	effectiveDT : TimeStamp;

begin
	
	effectiveDT := self.getRateDateFromStatus();
	
	if not effectiveDT.isValid() then
		effectiveDT := self.toDT;
	endif;
	
	if not effectiveDT.isValid() then
		effectiveDT := self.postedDT;
	endif;
	
	if not effectiveDT.isValid() then
		effectiveDT := self.createdTime;
	endif;
	
	return effectiveDT;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getRateDateFromStatus" id="bff16901-f927-4c24-84e2-fa280ed69da1">
        <source>getRateDateFromStatus():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197

*/

vars

	effectiveDT : TimeStamp;

begin

	effectiveDT := null;

	if self.status = INVOICE_PENDING then
		effectiveDT := self.prependDT;		// 20/12/18 MAP TFS42678 &amp; 42679
	elseif self.status = INVOICE_PREPEND then 
		effectiveDT := self.prependDT;
	elseif self.status = INVOICE_POSTED then 
		effectiveDT := self.prependDT;		// 20/12/18 MAP TFS42678 &amp; 42679
	elseif self.status = INVOICE_POSTED_REVERSE then
		effectiveDT := self.prependDT;		// 20/12/18 MAP TFS42678 &amp; 42679
	elseif self.status = INVOICE_POSTED_CREDIT then 
		effectiveDT := self.prependDT;		// 20/12/18 MAP TFS42678 &amp; 42679
	endif;
	
	return effectiveDT;

epilog

end;</source>
