    <JadeMethod name="setForUpdate" id="0bb76e50-0ebd-4fc3-9d2f-93826549ff75">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// --------------------------------------------------------------------------------
vars
	
begin
	inheritMethod(_proxyEDITI);

	self.bolNumber		:= _proxyEDITI.bolNumber;
	self.fieldName		:= _proxyEDITI.fieldName;
	self.fieldValue		:= _proxyEDITI.fieldValue;
	self.setId(_proxyEDITI.id);
//	self.voyageCode		:= _proxyEDITI.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setValuesForTest" id="83523afb-0a8d-474d-aa0d-f02491d45498">
        <updating/>
        <source>setValuesForTest(_voyageCode, _bol : String; _cargoType : Integer; 
			_cargoId : String; _fieldName, _fieldValue : String;
			_ediData : CM_EDIData) updating;
/* ---------------------------------------------------------------------------
Created:     07 March 2010 by cnwrs2

Purpose:     Used in Unit tests to set up the values of a EDICargoFieldUpdateTI
        
Change Date	Who		Reason
------------------------------------------------------------------------------*/
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars

begin
//	self.voyageCode	:= _voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setVoyageCode( _voyageCode );
	self.bolNumber	:= _bol;
	self.setId(_cargoId);
	self.cargoType 	:= _cargoType;
	
	self.fieldName	:= _fieldName;
	self.fieldValue	:= _fieldValue;
	
	self.myEDIData 	:= _ediData;
	
epilog

end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="ede739cb-c7b5-44f0-9927-bb300132a1b9">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="ba610348-ad29-486b-904d-36fb04fa8df1">
        <source>verifySelf();
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwdad1
//
// Purpose:		Validates the receiver and its properties.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 09/03/2010	cnwrl1		PAR 23008 - handle the EDI "Jump to Line" function.
// 29/07/2010	cnwrl1		PAR 23526 - CCMS 1075 - EDI Cargo Field Update needs additional fields.
// 04/07/2011	cnwcs5		par 27275 - new field imex (includes validation)
// 22/02/2016	cnwrs1		Par 37568 TFS 1177 CCMS 2158 - EDI User defined  field expansion
// 05/05/2016	cnwdap1		TFS #1699 Verified Gross Mass changes
//01 Feb 2018   cnwma1      ChangeRequest 36751: POL - ‘is Externally Monitored’ for EDI User Defined File Types
// 07/02/2023	jlizm1		TFS 56416 PNL Update Reefer PTI date/time from edi
// --------------------------------------------------------------------------------
vars
	upperFieldName	: String;
	voyageCodeStr	: String;
	imex			: CM_IMEXStatus;
	upperFieldValue	: String; 		// 05/07/2011 cnwcs5 par 27275
	found			: Boolean;		// 05/07/2011 cnwcs5 par 27275
	consign : CM_ConsigneeConsignor;
	ts				: TimeStamp;		// TFS 56416
	fileType		: CM_EDIFileType;	// TFS 56416
	
begin
	// The EDI file should contain either, a Cargo Type and ID, or a Voyage Code and BOL number.
	voyageCodeStr	:= self.getVoyageCode();		// cnwrl1 09/06/2010 PAR 24299
	
	if (self.cargoType &lt;&gt; null or self.id &lt;&gt; null) and (voyageCodeStr &lt;&gt; null or self.bolNumber &lt;&gt; null) then
		app.raiseCMException(Cargo_Field_Upd_TooManyKeys, null, self);
		return;
	endif;
	
	if self.cargoType = null and self.id = null and voyageCodeStr = null and self.bolNumber = null then
		app.raiseCMException(Cargo_Field_Upd_NoKeys, null, self);
		return;
	endif;
	
	if self.cargoType = null and self.id = null then
		if voyageCodeStr = null or self.bolNumber = null then
			app.raiseCMException1(Cargo_Field_Upd_KeyMissing, app.getString(Voyage_Code_And_BOL_Number), null, self);
			return;
		endif;
	elseif voyageCodeStr = null and self.bolNumber = null then
		if self.cargoType = null or self.id = null then
			app.raiseCMException1(Cargo_Field_Upd_KeyMissing, app.getString(Cargo_Type_And_Id), null, self);
			return;
		endif;
	endif;
	
	if self.id &lt;&gt; null then
		if self.cargoType = 0 then
			app.raiseCMException(Unspecified_Cargo_Type, null, self);
		elseif app.myRoot.allCargoTypesById[self.cargoType] = null then
			app.raiseCMException(ERR_INVALID_TI_TYPE, null, self);
		endif;
	endif;
	
	// Validate the field name being updated.
		
	upperFieldName := self.fieldName.toUpper();
	
	if upperFieldName &lt;&gt; self.U_AvailabilityGrade and 
		upperFieldName &lt;&gt; self.U_BOL and 
		upperFieldName &lt;&gt; self.U_BookingRef and 
		upperFieldName &lt;&gt; self.U_BulkRelease and 
		upperFieldName &lt;&gt; self.U_CargoSubtype and 
		upperFieldName &lt;&gt; self.U_CargoType and 
		upperFieldName &lt;&gt; self.U_Commodity and 
		upperFieldName &lt;&gt; self.U_Consignee and 
		upperFieldName &lt;&gt; self.U_Consignor and 
		upperFieldName &lt;&gt; self.U_CustomsAgent and 
		upperFieldName &lt;&gt; self.U_CustomsReference and 
		upperFieldName &lt;&gt; self.U_DeliveryRelease and 
		upperFieldName &lt;&gt; self.U_DestinationPort and 
		upperFieldName &lt;&gt; self.U_DischargePort and 
		upperFieldName &lt;&gt; self.U_FreightForwarder and
		upperFieldName &lt;&gt; self.U_Imex.toUpper and		// 05/07/2011 cnwcs5 par 27275		
		upperFieldName &lt;&gt; self.U_IntendedReleaseMode and 
		upperFieldName &lt;&gt; self.U_OffsiteCleaned and 
		upperFieldName &lt;&gt; self.U_OffsitePTI and
		upperFieldName &lt;&gt; self.U_PreTripDT and	// TFS 56416 jlizm1 03/02/2023
		upperFieldName &lt;&gt; self.U_Remarks and 
		upperFieldName &lt;&gt; self.U_ShipperSeal and 
		upperFieldName &lt;&gt; self.U_TrailerType and 
		upperFieldName &lt;&gt; self.U_Voyage and
		upperFieldName &lt;&gt; self.U_CargoWeightChange and		// Oct 2015 36912 TFS 456
		upperFieldName &lt;&gt; self.U_CargoQuantityChange and		// Oct 2015 36912 TFS 456
		upperFieldName &lt;&gt; self.U_IsWeightCertified and				// TFS #1699
		upperFieldName &lt;&gt; self.U_WeightCertifiedName and				// TFS #1699
		upperFieldName &lt;&gt; self.U_WeightCertifiedReference and			// TFS #1699
		upperFieldName &lt;&gt; self.U_IsExternallyMonitored and           // 01.Feb.2018 cnwma1 TFS #36751
		upperFieldName &lt;&gt; self.U_StoreOnPallet and	//20 Jan 2020	NDL	TFS 48250
		upperFieldName &lt;&gt; self.U_HeatTreated and	//20 Jan 2020	NDL	TFS 48250
		upperFieldName &lt;&gt; self.U_PalletType	//20 Jan 2020	NDL	TFS 48250 
		then
		app.raiseCMException1(Invalid_Field_Name, self.fieldName, null, self);
	endif;
	
	
	// 05/07/2011 cnwcs5 par 27275	- validate the imex status entered here
	if 	upperFieldName = self.U_Imex.toUpper then			
		// validate imex status has been entered correctly
		if self.fieldValue.isInteger then
			imex := app.myRoot.allImexStatuses [self.fieldValue.Integer];
		else
			upperFieldValue := self.fieldValue.toUpper;
			
			foreach imex in app.myRoot.allImexStatuses do
				if imex.description.toUpper = upperFieldValue or
					imex.abbreviation.toUpper = upperFieldValue then
					found := true;
					break;
				endif;
			endforeach;
			
			if not found then
				imex := null;
			endif;
		endif;
		if imex = null then
			// unknown value for imex
			app.raiseCMException2(ERR_FIELD_IMEX, self.fieldValue, 'IMEX Status', ETRow_ImexStatus, self);
		endif;
	
	//07 Sep 2021	NDL	TFS 51928
	elseif upperFieldName = self.U_Consignee or upperFieldName = self.U_Consignor then
		upperFieldValue := self.fieldValue.toUpper.trimBlanks;
		if upperFieldValue &lt;&gt; null then
			consign := app.myRoot.allConsigneeConsignors.getAtKey( upperFieldValue );
			if consign &lt;&gt; null then
				self.verifyObjectAvailableForEntry( consign );
			endif;
		endif;
	
	// TFS 56416
	elseif upperFieldName = self.U_PreTripDT.toUpper then
		if self.myEDIData &lt;&gt; null then
			fileType := self.myEDIData.getEDIFileType();
			if fileType &lt;&gt; null and fileType.isKindOf(CM_EDIFileTypeUser) then
				ts := self.fieldValue.ediTimeStampFormat(fileType, null, null);
				if ts &lt;&gt; null and not ts.isValid() then
					app.raiseCMException1(AutoScheduleDateError, self.fieldValue, self.fieldName, self);
				endif;
			endif;
		endif;
		
	endif;
	
// The validation of the field values is done later in the standard TI validation

end;
</source>
    </JadeMethod>
</Class>
