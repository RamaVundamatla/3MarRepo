    <JadeMethod name="getMyCargoContentsStatus" id="f4d88519-3334-4159-aa36-1d24ed8a406f">
        <source>getMyCargoContentsStatus() : CM_ContentsStatus;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 October 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	trackedItem			: CM_TrackedItem;
	gotException		: Boolean;
	contentStatus		: CM_ContentsStatus;
	contentStatusCode 	: Integer;
begin
	on Exception do app.handleDeletedObject (exception, trackedItem, gotException);
	
	trackedItem := self.myTrackedItem;
	if trackedItem &lt;&gt; null then
		contentStatusCode := trackedItem.getContentsStatus();
		contentStatus := app.myRoot.allContentsStatuses[contentStatusCode];
	endif;
	
	return contentStatus;
end;</source>
        <ReturnType type="CM_ContentsStatus"/>
    </JadeMethod>
