    <JadeMethod name="doMnuReturnTruckEG" id="863a021c-cedd-4434-9b9a-c516a87fd654">
        <source>doMnuReturnTruckEG();
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 February 2010	cnwrd1	Initial creation

*/
vars
	interMove, 
	pProxyInterTermMove :  CM_InterTerminalMove;
	result : Integer;
begin
		interMove := self.myCurrentInterTerminalMove;

		pProxyInterTermMove := app.createUpdateProxy(interMove).CM_InterTerminalMove;	// create update proxy
		pProxyInterTermMove.setStatus( ITT_LOADED ); //set to unloading
	
		
		while true do
			app.myTrxUA.trxUpdateInterTerminalMove(  pProxyInterTermMove , app.myPassport );  // update the move
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings();
				return;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					return;
				endif;
			endif;
		endwhile;
epilog
	delete pProxyInterTermMove;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuReturnYardEG" id="6a52130c-0a39-4d36-a6b3-d2fa78bb5136">
        <updating/>
        <source>doMnuReturnYardEG() updating;
/*

Date				Who		Reason
02 February 2010	cnwrd1	Initial creation

*/
vars
	result : Boolean;
	ittm : CM_InterTerminalMove;
	unloadTruckForm : YRD_ITTUnload;
begin

	ittm := self.myCurrentInterTerminalMove;
	
	if ittm = null then 
		return;
	endif;
	
	if ittm.status = ITT_LOADING then
		// if loading we havnt processed the move at all , we can just delete the ITM
		result := self.deleteInterTermMove(self.myCurrentInterTerminalMove);
		if result = true then
			self.myCurrentInterTerminalMove := null;
		endif;
		return; //all done here
	elseif ittm.status = ITT_LOADED or ittm.status = ITT_UNLOADING  then //unloading??
		// at this point the cargo has left the source terminal, and has been prenoted in the target terminal.
		// we need to do an unload at the source terminal , this will create a new vvr, shift the prenote, gate in a new ti instance(prenote).
		// we cant use the original location of the container as its been moved onto the truck then out of the yard so we need to get a location for it to be placed back into.
		create unloadTruckForm transient;
		unloadTruckForm.vAction_mode := Return_Mode;
		unloadTruckForm.myCurrentInterTerminalMove := self.myCurrentInterTerminalMove;
		unloadTruckForm.myUnloadTerminal := self.myTerminal;  //for unloading 'here'
		unloadTruckForm.showModal;		
	else
		// can only 'return to yard' if its on a truck - not unloaded 
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuUnloadTruckEG" id="efc187e3-0296-4fc8-bf45-87d8afebeb80">
        <updating/>
        <source>doMnuUnloadTruckEG() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars
	result : Boolean;
	ittm : CM_InterTerminalMove;
	unloadTruckForm : YRD_ITTUnload;
begin

	ittm := self.myCurrentInterTerminalMove;
	
	if ittm = null then 
		return;
	endif;
	
	if ittm.status = ITT_LOADING then
		// if loading we havnt processed the move at all , we can just delete the ITM
		result := self.deleteInterTermMove(self.myCurrentInterTerminalMove);
		if result = true then
			self.myCurrentInterTerminalMove := null;
		endif;
		return; //all done here
	elseif ittm.status = ITT_LOADED or ittm.status = ITT_UNLOADING  then //unloading??
		// at this point the cargo has left the source terminal, and has been prenoted in the target terminal.
		// we need to do an unload at the source terminal , this will create a new vvr, shift the prenote, gate in a new ti instance(prenote).
		// we cant use the original location of the container as its been moved onto the truck then out of the yard so we need to get a location for it to be placed back into.
		create unloadTruckForm transient;
		unloadTruckForm.vAction_mode := Unload_Mode;
		unloadTruckForm.myCurrentInterTerminalMove := self.myCurrentInterTerminalMove;
		unloadTruckForm.myUnloadTerminal := self.myTerminal;  //for unloading 'here'
		unloadTruckForm.showModal;		
	else
		// can only 'return to yard' if its on a truck - not unloaded 
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="7447978d-8fa1-4b4b-bc58-721ad3c6f46c">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_InterTerminalMove) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
