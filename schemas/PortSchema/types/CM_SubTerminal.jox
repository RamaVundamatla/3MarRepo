        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5cdc4d26-08e9-4a72-a73d-ee475b600921">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		06 April 2009 by cnwdad1
//
// Purpose:		Standard method to create a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();

	proxyObj.myTerminal	:=	self.myTerminal;
	proxyObj.myRoot		:=	self.myRoot;
	
	//15 Oct 2010	NDL Par 23991
	if not self.allAllowedEditAvailGrades.isEmpty then
		self.allAllowedEditAvailGrades.copy( proxyObj.allAllowedEditAvailGrades );
	endif;
	if not self.allAllowedEditToDoTasks.isEmpty then
		self.allAllowedEditToDoTasks.copy( proxyObj.allAllowedEditToDoTasks );
	endif;
	
	proxyObj.myBank := self.getMyBank;	//12 May 2015	NDL	Par 36181
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="228d400f-b0ef-4059-aa8f-7867c0861c92">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		06 April 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setForUpdate(_proxyObj);
	self.myTerminal := _proxyObj.myTerminal;
	self.myRoot	:=	app.myRoot;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="45e6e467-fa02-46f2-a08a-5ff1baa5652b">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		06 April 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.code 				:= _proxyObj.code;
	self.description 		:= _proxyObj.description;
	self.type 				:= _proxyObj.type;
	
	//15 Oct 2010	NDL Par 23991
	self.allAllowedEditAvailGrades.clear();
	if not _proxyObj.allAllowedEditAvailGrades.isEmpty then
		_proxyObj.allAllowedEditAvailGrades.copy( self.allAllowedEditAvailGrades );
	endif;
	self.allAllowedEditToDoTasks.clear();
	if not _proxyObj.allAllowedEditToDoTasks.isEmpty then
		_proxyObj.allAllowedEditToDoTasks.copy( self.allAllowedEditToDoTasks );
	endif;
	
	//03 Dec 2014	NDL	Par 35295
	self.setMyBank(  _proxyObj.getMyBank );
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyBank" id="05a7dd1c-748c-4b38-913e-8b24d320194f">
        <updating/>
        <source>setMyBank( _bank : CM_Bank ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwndl1	Initial creation	Par 35337

*/

vars

begin

	self.myBank := _bank;

epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="96cbde16-bfea-4e04-be1e-2ce1beb4f890">
        <updating/>
        <source>setProxy(	_code:String;
			_description:String;
			_type:Integer;
			_terminalObj:CM_Terminal;
			_bank : CM_Bank;
			_selectedAvailGrades : CM_MTGradeByCodeDict;	//13 Oct 2010	NDL Par 23991
			_selectedToDoDescs : CM_ToDoTaskDescByCode	//13 Oct 2010	NDL Par 23991
			) updating;
// --------------------------------------------------------------------------------
// Created:		06 April 2009 by cnwdad1
//
// Purpose:		Sets the attribute values on the receiver, which Must be a proxy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);

	self.code 			:=	_code[1:30];
	self.description 	:=	_description[1:256];
	self.type			:=	_type;
	self.myTerminal		:=	_terminalObj;
	self.setMyBank( _bank );
	self.myRoot 		:=	app.myRoot;
	
	//13 Oct 2010	NDL Par 23991
	self.allAllowedEditAvailGrades.clear();
	if _selectedAvailGrades &lt;&gt; null and not _selectedAvailGrades.isEmpty then
		_selectedAvailGrades.copy( self.allAllowedEditAvailGrades );
	endif;
	self.allAllowedEditToDoTasks.clear();
	if _selectedToDoDescs &lt;&gt; null and not _selectedToDoDescs.isEmpty then
		_selectedToDoDescs.copy( self.allAllowedEditToDoTasks );
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_selectedAvailGrades" type="CM_MTGradeByCodeDict"/>
        <Parameter name="_selectedToDoDescs" type="CM_ToDoTaskDescByCode"/>
    </JadeMethod>
    <JadeMethod name="type" id="dbf936d5-16e9-42bb-be45-97ce3f41b163">
        <methodInvocation>mapping</methodInvocation>
        <source>type(set : Boolean; _value : Integer io) mapping;
// --------------------------------------------------------------------------------
// Created:		03 April 2009 by cnwdad1
//
// Purpose:		Mapping method to pretect the value which 'type" is set to.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		if _value &lt;&gt; SubTermType_Marine_Int
		and _value &lt;&gt; SubTermType_Depot_Int
		and _value &lt;&gt; SubTermType_Warehouse_Int
		then
			app.raiseUnexpectedProgramError(class.name, method.name, "Invalid Sub-Terminal Type.");
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="typeDesc" id="19d65e28-57b9-48db-868e-24a2182a0161">
        <methodInvocation>mapping</methodInvocation>
        <source>typeDesc(set: Boolean; _value: String io) mapping;
// --------------------------------------------------------------------------------
// Created:		25 May 2009 by cnwdad1
//
// Purpose:		Mapping method of virtual string attribute to return the equivalent
//				string value of the real "type" attribute.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		app.raiseUnexpectedProgramError(class.name, method.name, "Attempting to set a virtual attribute.");
	else
		_value	:=	app.subTerminalTypeEnumToString(self.type);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="2801873c-b8ac-4e77-9d3f-82e0a8304170">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	08 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
04/06/2009	concms1	par 19803 - duplicate key exception (was checking wrong coll)
*/
vars
	sub : CM_SubTerminal;
begin
	sub := app.myRoot.allSubTerminals[code];// ### TFS 55643 30NOV2022 NAVAB1
 // ### TFS 55643 30NOV2022 NAVAB1	if app.myRoot.allSubTerminals[code] &lt;&gt; null then	// par 19803 - changed to check root collection
	if sub &lt;&gt; null then// ### TFS 55643 30NOV2022 NAVAB1
// ### TFS 55643 30NOV2022 NAVAB1		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		app.raiseCMException2(Termi_codes_uniqu_syste_wide_c,self.code,sub.myTerminal.code,null,null);// ### TFS 55643 30NOV2022 NAVAB1
	endif;

	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="723798f9-6e26-4f9b-9bf7-837b7e276c87">
        <source>validateForDelete();
/*
----------   ----------  --------------------------------------------------
Created:	08 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	whereUsed : String;
	
begin
	if self.allBulkReleasesByCode.cnEcIsNotEmpty()
	or self.allDataAccessControllers.cnEcIsNotEmpty()
	or self.allOnsiteTIsByIdCargoType.cnEcIsNotEmpty()
	or self.allTITransactionsByDateType.cnEcIsNotEmpty()
	then
		app.raiseCMException(SubTerminal_Delete_Has_Data, null, null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if not app.isGarbageCollectionProcess and self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ed5010a4-b9cb-42e1-977f-21abb1908f2b">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	08 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
04/06/2009	concms1		par 19803 - duplicate key exception
*/
vars
	subTerminal	:CM_SubTerminal;
begin
	subTerminal := app.myRoot.allSubTerminals[self.code];	// par 19803 
	
	if subTerminal &lt;&gt; null and							// par 19803 
		subTerminal &lt;&gt; self.pxyGetRealObject then		// par 19803
		// ### TFS 55643 30NOV2022 NAVAB1app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);	// par 19803
		app.raiseCMException2(Termi_codes_uniqu_syste_wide_c,self.code,subTerminal.myTerminal.code,null,null);// ### TFS 55643 30NOV2022 NAVAB1
	endif;												// par 19803
	
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="272ae374-5915-42ea-be70-a85c699ddf7c">
        <source>validateMe() protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'SubTerminal Code', null, null);
		app.raiseCMException(Input_required_field_subTermCd, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
