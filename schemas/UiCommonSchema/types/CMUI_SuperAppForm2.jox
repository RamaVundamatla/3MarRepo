    <JadeMethod name="getData" id="36ee7b59-a7fc-452d-9f5b-d18d7a7a4961">
        <updating/>
        <source>getData(pAny: Any input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if pType = CMUI_SuperAppForm2.GetData_SUPasswordIsSpecial then
		if self.checkSuperUserPassword(pAny.String) then
			app.setSpecial('01/12/3000'.TimeStamp);
			self.lblUserName.foreColor := Red;
		else
			app.msgBox("Incorrect Password.","Superuser Password Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="pAny" type="Any" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="52e0a727-0135-40b5-86bf-af08df42a1cb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	22 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning	
----------   ----------  --------------------------------------------------
*/
vars
	str :  String;
	vcp : Boolean;
	//printerName	: String;
	errorNumber	: Integer;
	errorText	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, 'Initializing app.printer document type', errorNumber, errorText, false, false); //PAR15996 July 2009

	//We may not need to inherit here as this is called later I think.
	//str := inheritMethod()
	if app.printer.retainCMDValues then
		//printerName := app.printer.getPrinterName();
		str := global.formatAsXML(XML_DefaultDocumentType, app.printer.getDefaultDocumentType.String);
		str := str &amp; global.formatAsXML(XML_DefaultPrinterName, app.printer.getPrinterName.String);
	endif;

	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handlePostShow" id="e1d41e08-3ab4-4584-8795-c33235498cc5">
        <updating/>
        <source>handlePostShow() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	user	: CM_User;

begin
	user := app.getMyUser();

	app.toolbarHidden		:=	user.getStateData(ConfigGrp_Gate, UserToolbarHidden).Boolean;
	app.saveSettingsOnExit	:=	user.getStateData(ConfigGrp_Gate, UserSaveSettingsOnExit).Boolean;

	if user.getStateData(ConfigGrp_Gate, UserNavigatorWindow).Boolean then
		if not (user.hasWelcomeForm() and user.getShowWelcomeScreen()) then	//Par18021 - Navigator shouyld be hiden, when Welcome screen is active
			app.userSavedWindowSettings := true;
			self.showNavigatorForm();
			app.userSavedWindowSettings := false;
		endif;
	endif;
	
	app.initWithSavedSettings();
	self.setDocoMenu();
	self.doShowAlertAlarm();
epilog
	app.userSavedWindowSettings := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="handlePostShowLock" id="e616f44a-b408-4fa5-bfea-739e2af00280">
        <updating/>
        <source>handlePostShowLock() updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	user		 : CM_User;
	userLock : CM_User;
begin

	user := app.getMyUser();
	userLock := app.myRoot.allUsers.getAtKey(self.userLocking.toUpper);
	
//	app.myPassport.setMyUser(user);
	
//	if not self.checkAccessPermission(user, userLock) then
//		app.unloadAllForms();
//		app.msgBox(app.getErrorString(WARNING_LOCK_ACCESS), "Security Warning", MsgBox_Stop_Icon);
//	else

//	endif;

	if userLock.getStateData(ConfigGrp_Gate, UserNavigatorWindow).Boolean then
		app.userSavedWindowSettings := true;
		self.showNavigatorForm();
		app.userSavedWindowSettings := false;
	endif;
	
	app.initWithSavedSettingsLock(user, userLock);
	
	app.toolbarHidden 		:= user.getStateData(ConfigGrp_Gate, UserToolbarHidden).Boolean;
	app.saveSettingsOnExit 	:= user.getStateData(ConfigGrp_Gate, UserSaveSettingsOnExit).Boolean;
	
	self.setDocoMenu();
	self.doShowAlertAlarm();
epilog
	app.userSavedWindowSettings := false;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="handlePreShow" id="b483cc2c-66e5-4650-b5bd-d954df03ea2c">
        <updating/>
        <source>handlePreShow() updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	picBinary : Binary;
begin
	self.showToolbar := true;
	app.createMyController(CMUI_Controller);
//	self.picPortLogo.picture := app.getPicLogoPort();
	picBinary := app.myRoot.getConfig(PortLogoPic).Binary;
	// USE The Jade Logo
	if picBinary = null then
		picBinary := app.myRoot.getConfig(PicAppLogoJade150X30).Binary;
	endif;

	self.zSetupToolbar();
	
	self.setNotifications();

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="3b93577a-ec3e-46fe-a8ff-d38bd55136ae">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLeft,
	tmpTop,
	tmpWidth,
	tmpHeight	: Integer;
	
	theXML,
	printerName, vcpValue : String;
	docType 	: Integer;
	setDocType 	: Boolean;
	setResult 	: Integer;
	
begin
	inheritMethod(_userWindow);
	
	theXML := _userWindow.xmlInfo;
	setDocType := false;
	
	self.getMonitorWorkArea(tmpLeft, tmpTop, tmpWidth, tmpHeight);
	if self.width &gt; tmpWidth then
		self.width := tmpWidth;
	endif; 
	if self.height &gt; tmpHeight then
		self.height := tmpHeight;
	endif;

	on Exception do app.handleNoDefaultPrinter(exception, false);	//19 Nov 2013	NDL	Par 32138 / 33003
		
	printerName := theXML.cnEcGetTagValueOfName(self.XML_DefaultPrinterName);
	if printerName = app.printer.getPrinterName then
		setDocType := true;
	endif;
	
	if printerName &lt;&gt; null then
		setResult := app.printer.setPrinter(printerName);
		//write "Set Result for Printer = " &amp; setResult.String;
		if app.printer.setPrinter(printerName) = Print_Successful then
			setDocType := true;
		endif;
	endif;
		
	if setDocType then
		docType := theXML.cnEcGetTagValueOfName(self.XML_DefaultDocumentType).Integer;
		if docType &lt;&gt; null then
			if docType = Print_Custom_Paper then		// 18/01/2011 cnwmh5 #26743
				docType := Print_A4;
			endif;
			app.printer.documentType := docType;
		endif;
	endif;
	
	 // TFS 4049
//	vcpValue := theXML.cnEcGetTagValueOfName("VCP");
//	if vcpValue &lt;&gt; null then
//		app.setIsVoyageCommodityPlanning(vcpValue.Integer.Boolean);
//	endif;
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
