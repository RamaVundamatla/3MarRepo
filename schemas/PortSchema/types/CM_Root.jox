    <JadeMethod name="resetRootSecurityRoles" id="bf6ad9e8-bba1-48ff-b238-bd2ed9fb80b3">
        <updating/>
        <source>resetRootSecurityRoles(_cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	secRole		: CM_SecurityRole;
	permAgent	: CM_PermissionAgent;
begin

	create permAgent transient;
	permAgent.populatePermissionDict(true, true, 0);
	permAgent.setAllPermissionValues(true);

	if self.mySecurityRoleSystem = null then
		// create self.mySecurityRoleSystem persistent;
		create secRole as CM_SecurityRoleSystemRoot persistent;
		secRole.CM_SecurityRoleSystemRoot.init(self, permAgent);
	else
		self.mySecurityRoleSystem.resetRootRole(permAgent, _cmifMonitor);
	endif;
	
	if self.mySecurityRoleTerminal = null then
		// create self.mySecurityRoleTerminal persistent;
		create secRole as CM_SecurityRoleTerminalRoot persistent;
		secRole.CM_SecurityRoleTerminalRoot.init(self, permAgent);
	else
		self.mySecurityRoleTerminal.resetRootRole(permAgent, _cmifMonitor);
	endif;

	
epilog
	delete permAgent;
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetTIBehaviourType" id="b0ef14c8-1267-4968-a751-5e127733f583">
        <source>resetTIBehaviourType(pConstant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     04 Feb 2005 by cnwdvb1
//
// Purpose:     This is used as a "callBack" method 

vars

	realTIBehaviourType,
	pxyTIBehaviour	: CM_TIBehaviourType;
	str,
	classToCreate,
	className,
	desc			: String;
	class			: Class;
	isSystemType	: Boolean;
		
begin

	if pConstant.valueAsInteger &lt;=TIBehaviourType_Null or
	   pConstant.valueAsInteger &gt; TIBehaviourType_Max then
	   	return;
	endif;

	realTIBehaviourType := self.allTIBehaviourTypes[pConstant.valueAsInteger];
	
	str := pConstant.text;
	
	classToCreate	:= str.cnEcGetTagValueOfName('classNameToCreate');
	className		:= str.cnEcGetTagValueOfName('className');
	desc			:= str.cnEcGetTagValueOfName('description');
	isSystemType	:= str.cnEcGetTagValueOfName('systemType').isTrueFalse('Yes', 'No', false);
	
	if classToCreate = null or className = null then
		return;
	endif;
	
	if realTIBehaviourType = null then
		class := currentSchema.getClass(className);
		if class = null then
			return;
		endif;

		create pxyTIBehaviour as class transient;
		pxyTIBehaviour.setProxyFromXML(pConstant.valueAsInteger, classToCreate, desc, isSystemType, self);
		app.myUtilityCA.utlCreateTIBehaviourType(pxyTIBehaviour);
	else
		pxyTIBehaviour := app.createUpdateProxy(realTIBehaviourType).CM_TIBehaviourType;
		pxyTIBehaviour.setProxyFromXML(pConstant.valueAsInteger, classToCreate, desc, isSystemType, self);
		app.myUtilityUA.utlUpdateTIBehaviourType(pxyTIBehaviour, realTIBehaviourType);
	endif;
	
epilog
	delete pxyTIBehaviour;
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
