<Class name="CM_QDecimalTemperatureMethod" id="c055a6fa-fe2d-4395-bb1b-b5eb170c393a">
    <superclass name="CM_QDecimalMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="displayNull" id="90c5bc73-2fdf-4f54-920a-ce56a301f72b">
        <methodInvocation>mapping</methodInvocation>
        <source>displayNull(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars

begin
	//we want to display the zero (null) values
	_value := true;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="774a8daf-a3ee-44dd-b4b7-605893d6e94c">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2009	cnwdap1	Initial creation
*/
vars

begin
	//return _obj.sendMsg(self.propertyName).Integer; //- cnwmd1, sh'd be a decimal...
	return _obj.sendMsg(self.propertyName).Decimal;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="a5beec64-8032-4428-9aaf-19f51c947631">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars

begin
	if _value.Decimal = NULL_DEFROST_TEMPERATURE then //Aug 2007 cnwrs1 CCMS1551
		return "DEFROST";
	elseif _value.Decimal &lt;&gt; NULL_TEMPERATURE and 
	   _value.Decimal &lt;&gt; NULL_TEMPERATURE_FAHRENHEIT then
		return inheritMethod(_value);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
