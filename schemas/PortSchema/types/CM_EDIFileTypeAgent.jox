<Class name="CM_EDIFileTypeAgent" id="0a0a2c2b-23ad-4127-8ae1-ee2251650a26">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allCAMProtocolDescs" id="30c16b99-cc43-41e6-b628-88177acd0f75">
        <memberTypeInverse/>
        <type name="CM_CamProtocolDescByNameDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allEDIFileTypes" id="232c590b-0992-41e6-a614-eb4b42a623bf">
        <memberTypeInverse/>
        <type name="CM_EDIFileTypeByNameDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="useReal" id="390c7160-6f5c-403f-ad28-6db3f3177c56">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="ad25c1ee-6580-4630-a14c-833f000b54d3">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if not self.useReal then // ### TFS CR 64617 TASK 64638 09JUL2024 NAVAB1
		self.allEDIFileTypes.purge;
		self.allCAMProtocolDescs.purge;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="cc84b75e-73eb-498d-8008-fee30e5e2726">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 12 Sep 2017	cnwrs1	TFS 6936 get licence app working
// 22/08/2023	navmd1	TFS 59024 Skip the old TransportManifest and CallOff EDIFileTypes (renamed/moved under CM_EDIFileTypeJSON)
vars
	tmpClassColl	: ClassColl;
	tmpClass		: Class;
	tmpFileType		: CM_EDIFileType;
	tmpProtDesc		: CM_CamProtocolDesc;
begin
	// ### TFS CR 64617 TASK 64638 09JUL2024 NAVAB1
	self.useReal := false;
	
	
	create tmpClassColl transient;
	CM_EDIFileType.allLocalSubclasses(tmpClassColl);
	
	foreach tmpClass in tmpClassColl do
		if tmpClass.abstract then
			continue;
		endif;
		
		if tmpClass.name = "CM_EDIFileTypeCallOff" or
			tmpClass.name = "CM_EDIFileTypeTransManifest"
		then
			continue;
		endif;
	
		create tmpFileType as tmpClass transient;
		// the create method on CM_EDIFileType will set the name &amp; type attributes
		if tmpFileType.name = null or
		   tmpFileType.type &lt;= 0 then
			// this has not been set in the create so do not allow permissions for this
		   	delete tmpFileType;
		   	continue;
		endif;
		self.allEDIFileTypes.add(tmpFileType);
	endforeach;

	tmpClassColl.clear;
	CM_CamProtocolDesc.allLocalSubclasses(tmpClassColl);
	
	foreach tmpClass in tmpClassColl do
		if tmpClass.abstract then
			continue;
		endif;
		create tmpProtDesc as tmpClass transient;
		// the create method on CM_CamProtocolDesc will set 
		if tmpProtDesc.name = null or
		   tmpFileType.type &lt;= 0 or
		   tmpClass.name = "CM_CamSEABX12322Desc" then
			// this has not been set in the create so do not allow permissions for this
		   	delete tmpProtDesc;
		   	continue;
		endif;
		self.allCAMProtocolDescs.add(tmpProtDesc);
	endforeach;
epilog
	delete tmpClassColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForReal" id="766e9a85-be56-406d-8c3d-702d3e742ceb">
        <updating/>
        <source>initForReal(_term : CM_Terminal) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars
	objs : CM_ObjectArray;
	tmpFileType		: CM_EDIFileType;
	tmpProtDesc		: CM_CamProtocolDesc;
begin
	self.useReal := true;
	create objs transient;
	CM_EDIFileType.allInstances(objs, 0, true);
	
	foreach tmpFileType in objs as CM_EDIFileType do

		if tmpFileType.class.name = "CM_EDIFileTypeCallOff" 
		or tmpFileType.class.name = "CM_EDIFileTypeTransManifest" then
			continue;
		endif;
		/*
		if _term &lt;&gt; null 
		and tmpFileType.allEDIDataIssueMappings[_term] &lt;&gt; null then
			continue;
		endif;
		*/
		self.allEDIFileTypes.add(tmpFileType);
	endforeach;

	objs.clear;
	CM_CamProtocolDesc.allInstances(objs, 0, true);
	
	foreach tmpProtDesc in objs as CM_CamProtocolDesc do
		if tmpProtDesc.class.name = "CM_CamSEABX12322Desc" then
		   	continue;
		endif;
		self.allCAMProtocolDescs.add(tmpProtDesc);
	endforeach;
epilog
	delete objs;
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="outputAsCSV" id="c132a168-bf01-416b-9bca-94c7c30f73a8">
        <source>outputAsCSV(_file : File);
// ---------------------------------------------------------------------------
// Created:     18 April 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin

	_file.writeLine('EDI File');
	_file.writeLine(self.showLicenceDetailsEDI());

	
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="showLicenceDetailsEDI" id="29cf9857-1034-4ac4-9049-c4cb850cfed4">
        <source>showLicenceDetailsEDI() : String protected;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars
	canDo		: Boolean;
	ediFileType	: CM_EDIFileType;
	camProtDesc	: CM_CamProtocolDesc;
	tmpDict		: CM_EDIFileTypeByNameDict;
	tmpCAMDict	: CM_CamProtocolDescByNameDict;
	str : String;
	root : CM_Root;
begin
	root := app.myRoot;
//	self.tblDetails.rows := 0;

	if (not root.isLicensedForProductCode(ProductCode_JMT_EDI)) then
		str := app.getErrorString(LicenseDetailsNotYetEntered);
		return str;
	endif;

	//EDI

	tmpDict := self.allEDIFileTypes;

	foreach ediFileType in tmpDict do

		canDo := root.canDoEDIFileType(ediFileType.type);
		str := str &amp; ediFileType.name &amp; Tab &amp; canDo.getYesNo()&amp; CrLf;
		
	endforeach;


	//CAMS

	tmpCAMDict := self.allCAMProtocolDescs;

	foreach camProtDesc in tmpCAMDict do

		canDo := root.canDoEDIFileType(camProtDesc.type);
		str := str &amp; camProtDesc.name &amp; Tab &amp; canDo.getYesNo() &amp; CrLf;
		
	endforeach;
	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
