    <JadeMethod name="trxROROControlerUpdateRelease" id="1ff5bebc-a3c3-4fe2-96f4-0164439595ac">
        <updating/>
        <source>trxROROControlerUpdateRelease(_theSlots : CM_LCArray; _reserveDetail : CM_ReserveDetail ; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2012	cnwrd1	Initial creation

*/

vars

begin


	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.myValUA.valROROControlerUpdateRelease(_theSlots, _reserveDetail , _passport );

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	beginTransaction;
	
	app.myUtilityUA.utlROROControlerUpdateRelease(_theSlots, _reserveDetail , _passport);

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
