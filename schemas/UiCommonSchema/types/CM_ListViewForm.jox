    <JadeMethod name="zBeginTimerForRefresh" id="fd963084-265c-4435-87a8-0e00e83dd0f3">
        <updating/>
        <source>zBeginTimerForRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2001 by cnwrs2
//
// Purpose:     When we receive notification of an delete/add event of the object
//				class we start a timer to do a refresh.  This is so that if another
//				process creates/deletes a large number of objects we only reduce the
//				number of refreshes required.  The timer delay is designed to allow
//				the other create/delete notifications to be received.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.timerRefreshActive) then
		self.timerRefreshActive := true;
		self.needLstDataRefresh := true;
		self.beginTimer(2000, Timer_OneShot, Timer_Refresh);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearPlaceHolderObject" id="081390be-7c22-48ed-9ba3-68c2b6cfbc67">
        <updating/>
        <source>zClearPlaceHolderObject(pRedisplay : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
begin

	if self.myPlaceHolderObject &lt;&gt; null then
		idx := lstData.findObject(self.myPlaceHolderObject);
		if idx &gt; 0 then
			lstData.removeItem(idx);
			if pRedisplay then
				self.zLstDataShow();
			endif;
		endif;
		delete self.myPlaceHolderObject;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pRedisplay" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zClearProxyArray" id="aba1593d-534c-4c1c-9f68-21f0d195e725">
        <updating/>
        <source>zClearProxyArray() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpProxy	: Object;
	
begin

	foreach tmpProxy in self.allProxyObjects do
		self.allProxyObjects.remove(tmpProxy);
		tmpProxy.CM_Object.erase(NORMAL_ERASE);
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearProxyDetails" id="6ee3c19c-7c59-4571-86af-7a7988114fc3">
        <updating/>
        <source>zClearProxyDetails() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpProxy	: Object;
begin

	if self.myProxyObject &lt;&gt; null then
		if (not self.allProxyObjects.includes(self.myProxyObject)) then
			self.myProxyObject.erase(NORMAL_ERASE);
		endif;
		self.myProxyObject := null;
	endif;

	self.zClearProxyArray();
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearThumbnailData" id="19af093b-c166-4871-a13a-40a504949f0d">
