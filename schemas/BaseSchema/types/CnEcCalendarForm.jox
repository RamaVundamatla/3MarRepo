        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="btnCancel" id="4cc07271-145b-4308-b7ed-3f6a38f0f2ad">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="2eca7aac-9f7d-4bba-aeef-4f41ffb66813">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="calendar" id="0b632c9c-f419-45bb-8aee-1252f89d641f">
        <embedded/>
        <type name="CnEcCalendar"/>
    </ImplicitInverseRef>
    <PrimAttribute name="positionLeft" id="e34d3d9f-593c-4b36-a90e-45f1e74331ec">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="positionTop" id="67e130bd-b815-42c0-b852-713ff0e72093">
