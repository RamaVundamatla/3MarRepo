    <JadeMethod name="keyDown" id="0e37cb3e-bb8c-44c9-9d44-4b100af931fe">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		16 August 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//5 Apr 2024  navsaa30 Bug 51948: MTN - Pressing F12 is not shutting down the OLD KIOSK App
// --------------------------------------------------------------------------------
begin
	if shift.cnEcIsCtrlKey() then
		inheritMethod(keyCode, shift);
	elseif app.isInternalEnvironment(false) and keyCode = CNEC_KEY_F12 then			// 5/4/24 navsaa30 #51948
		self.unloadMe(true);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBackgroundImage" id="60789573-3a93-4a3a-b6df-a363b05823f4">
        <source>setBackgroundImage(_image:Binary) protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Sets the background image for the receiver.
//
// Parameters:	_image - A BLOB of the image.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	picBackground.picture	:=	_image;
end;</source>
        <access>protected</access>
        <Parameter name="_image" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e5c95cec-147e-4875-bfd2-6952e4f81c50">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 August 2006 by cnwdad1
//
// Purpose:		Standard method to set up the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.aIsKioskWeightUsed	:=	app.getMyTerminalDO_NOT_USE().getConfig(IsKioskWeightUsed).Boolean;
	self.backColor		:=	Black;
	self.windowState	:=	Form.WindowState_Maximized;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showProxies" id="6c4650d5-6564-41c2-891e-a6e11637da7d">
        <source>showProxies();
// ---------------------------------------------------------------------------
// Created:     19 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if app.myProxyManager &lt;&gt; null then
		app.myProxyManager.showAllProxies();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadMe" id="7ab07232-00fe-4052-a660-13d40a743542">
        <updating/>
        <source>unloadMe(_isDeleteProxy:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Unloads the receiver, and optionally deletes the transient proxy object.
//
// Parameters:	_isDeleteProxy - True if the proxy is to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _isDeleteProxy then
		delete self.aMyProxyLoad;
	endif;
	
	self.unloadForm();
end;</source>
        <access>protected</access>
        <Parameter name="_isDeleteProxy" type="Boolean"/>
    </JadeMethod>
</GUIClass>
