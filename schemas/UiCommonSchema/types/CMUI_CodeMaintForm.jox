    <JadeMethod name="setUpControls" id="2c2a1551-30e5-4b9c-ae13-364518b1aa95">
        <source>setUpControls();
// ---------------------------------------------------------------------------
// Created:     17 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	buttoneHeight,
	buttonWidth	: Integer;
begin

	self.frmProdToClone.visible := false;
	
	self.frmEditCode.top := self.frmToolbar.height;

	self.frmEditCode.width := self.frmEditCode.parent.width;
	self.frmEditCode.height := self.frmEditCode.parent.height - self.frmEditCode.top;
	

	self.lblEntCode.left := HorzGap;
	self.lblEntCode.top := HorzGap;
	self.lblEntCode.width := self.lblEntCode.parent.width;
	self.lblEntCode.height := 30;
		
	buttonWidth := 65;
	buttoneHeight := 25;

	self.cbOverwriteCodes.value := true;
	
	self.btnOk.visible := false;
	self.btnCancel.visible := false;
	
	self.tblCodeData.top := self.lblEntCode.top + self.lblEntCode.height + self.HorizontalSpacing;


end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="15f3cfe5-be8f-4c96-aab3-cd26ac3fc9dc">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     01 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	prodAttr			: CM_ProductAttr;
	msg,
	productCode,
	captionStr,
	cargoTypeName		: String;
	prodCode			: CM_ProductAttributeCode;
	idx					: Integer;
	width 				: Integer;
	product 			: CM_Product;
	cargoType 			: CM_CargoType;
begin
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	inheritMethod();

	self.move(self.left, self.top, 500, 600);
	
	self.setUpControls();
	self.initTblCodeData();
	
	productCode := self.productCode;
	prodAttr := self.myProductAttr;
	
	if prodAttr &lt;&gt; null then 
		product := prodAttr.myProduct;
		if 	product &lt;&gt; null then 
			cargoType  	:= product.myCargoType;
			if cargoType  &lt;&gt; null then 	
				cargoTypeName := cargoType.description;
			else
				if self.myCargoType &lt;&gt; null then	// can be null when creating a new cargo type
					cargoTypeName := self.myCargoType.description;	// cargo type is null for hidden system dummy subcargo type (product type). ccms1080 (Par17904)
				endif;
			endif;
		endif;
	endif;
			
	//if self.myParentForm.GC_ProductMaintForm.isCloning = true or productCode = null or prodAttr = null then 
	if self.myFormIsCloning or productCode = null or prodAttr = null then 
		msg := app.getErrorString(Codes_for_new_cargoSubtype) &amp;' ';
	else 
		msg := 'Editing codes for attribute ' &amp; prodAttr.displayName &amp; ' of ' &amp; productCode &amp; ' for ' &amp; cargoTypeName;
	endif;
	
	
	self.lblEntCode.caption :=   	msg;

	//load existing codes into the code data table
	self.tblCodeData.rows := self.tblCodeData.fixedRows;
	foreach prodCode in prodAttr.allCodes do	
		self.addCodeRow(prodCode);
	endforeach;
	
	self.myForm.isCodesPressedSave := false;	//becomes true, when pressing the Save button
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCloneFrame" id="4cb67c7e-154e-4e27-99f7-81e1292bb0c2">
        <updating/>
        <source>showCloneFrame()updating;
/// ---------------------------------------------------------------------------
// Created:     17 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	buttoneHeight,
	buttonWidth	: Integer;
	cargoType	: CM_CargoType;	
begin
	self.frmCloneCodes.visible := true;
	self.frmCloneCodes.centreHorizontallyInParent();
	self.frmCloneCodes.top := self.frmCloneCodes.parent.height - self.frmCloneCodes.height - 50;
	
	self.frmCloneCodes.backColor := self.backColor;
	
//	self.frmProdToClone.top := self.frmCloneCodes.clientHeight;
//	self.frmCloneProduct.width := self.frmCloneProduct.parent.width;
	self.frmProdToClone.visible := true;
	self.frmColonCodesLwr.visible := true;
	self.frmColonCodesLwr.backColor := self.backColor;

	self.frmColonCodesLwr.top := self.frmProdToClone.top + self.frmProdToClone.height;

	self.frmColonCodesLwr.height := self.frmColonCodesLwr.parent.height - self.frmProdToClone.height;
	

	self.initTblCloneData();
	
	if self.myProduct &lt;&gt; null then 
		cargoType	:= self.myProduct.myCargoType;
		if cargoType = null then	// when there is system product type, product.myCargoType = null always.	CCMS 1080 (PAR19704) July 2009
			cargoType := self.myCargoType;	//The form uses self.myCargoType. See CM_CargoType.mySystemProductType text info.
		endif;
	endif;

	self.cmbCloneType.setObject(cargoType);	

	self.cmbCloneProduct.setObject(self.myProduct);
	self.loadCmbCloneAttr();
	self.resize();
	self.cmbCloneType.setFocus();

	
end;</source>
    </JadeMethod>
