    <JadeMethod name="getDataForDefSpecial" id="b996c30a-610b-43ff-8ee5-0d3155815d5c">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_ImexStatusString then
		_headings.add(_heading);
		if self.trackedItem &lt;&gt; null then
			_data.add(self.trackedItem.getImExStatusStringDesc(true));
		else
			_data.add(null);
		endif;
		return true;
	endif;
	
	return inheritMethod(_attrName, _heading, _headings, _data);

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
