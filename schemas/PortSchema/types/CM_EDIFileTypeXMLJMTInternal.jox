        <Parameter name="_xmlElement" type="JadeXMLElement" usage="io"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="0dbf2820-6c98-499c-be94-2d6d314188ad">
        <source>rawDataToHSA(_ediFile: CM_EDIFile; _theLines: HugeStringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2017	cnwndl1	Initial creation	TFS 3991	

*/

vars
	ediFile : CM_EDIFile;
	fileLine : String;
	pos : Integer;
	str : String;
	
begin

	_theLines.clear;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
		
	else
		//may have one Cr if it includes an &lt;?xml statement
		pos := fileLine.pos(Cr, 1);
		if pos &gt; 0 and pos &lt; fileLine.length then
			str := fileLine[1:pos];
			fileLine := fileLine[pos+1:end];
			_theLines.add(str);
		endif;

		while fileLine.length &gt; 0 do
			if fileLine.length &gt; 2047 then
				str := fileLine[1:2047];
				fileLine := fileLine[2048:end];
			else
				str := fileLine;
				fileLine := null;
			endif;
			_theLines.add(str);
		endwhile;
		
	endif; 
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
