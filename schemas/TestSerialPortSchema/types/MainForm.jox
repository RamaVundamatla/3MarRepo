    <JadeMethod name="createSerialPort" id="ef04789c-4196-49ff-aa2b-39c7bc1b85f2">
        <updating/>
        <source>createSerialPort() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	if mySerialPort &lt;&gt; null then
		deleteSerialPort();
	endif;
	
	create mySerialPort transient;
	log(mySerialPort.String &amp; " created");
	
	mySerialPort.dataBits := JadeSerialPort.DataBits8;
	mySerialPort.fillReadBuffer := true;
	mySerialPort.flowControl := JadeSerialPort.FlowControl_XonXoff;
	mySerialPort.name := "COM3";
	mySerialPort.parity := JadeSerialPort.Parity_None;
	mySerialPort.speedBps := 9600;
	mySerialPort.stopBits := JadeSerialPort.StopBits_1_0;
	mySerialPort.timeout := 5000;
	mySerialPort.usePresentationClient := true;
	
	/*	cnwns1 Settings for PIBT MT220 device
	mySerialPort.dataBits := JadeSerialPort.DataBits8;
	mySerialPort.fillReadBuffer := true;
	mySerialPort.flowControl := JadeSerialPort.FlowControl_XonXoff;
	mySerialPort.name := "COM1";
	mySerialPort.parity := JadeSerialPort.Parity_None;
	mySerialPort.speedBps := 9600;
	mySerialPort.stopBits := JadeSerialPort.StopBits_1_0;
	mySerialPort.timeout := 5000;
	mySerialPort.usePresentationClient := true;
	*/
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteSerialPort" id="2c18921a-3884-4928-874c-b060e82e94d8">
        <updating/>
        <source>deleteSerialPort() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	if mySerialPort &lt;&gt; null then
		log("About to delete " &amp; mySerialPort.String);
		delete mySerialPort;
		log("mySerialPort now deleted");
	else
		log("mySerialPort is null");
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleException" id="eea1a03b-e7c0-4009-aaf7-0eb6daa5c6d4">
        <source>handleException(_exc : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	log(method.name &amp; " " &amp; _exc.errorCode.String &amp; " " &amp; _exc.errorItem.String);
	return Ex_Abort_Action;
	

epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="803c2ed1-db12-446f-bdf4-a277b5f4e3e9">
