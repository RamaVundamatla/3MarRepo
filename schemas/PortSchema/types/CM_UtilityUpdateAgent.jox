    <JadeMethod name="utlUpdateShipMoveExport" id="8f5c2ae2-da68-4f8f-b987-388f53e71fc8">
        <source>utlUpdateShipMoveExport(_machine : CM_Machine input;_ti : CM_TrackedItem input; _task : CM_RTQueueTask;	_job : CM_VoyageJob; _newShipLocation : CM_LocationsController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	crane	:	CM_Crane;
	shipLC : CM_LocationsController;
	queue 	: CM_RadioTelemetryQueue;
	wle : CM_WorkListEntry;
	wp : CM_WorkPoint;	//13 Jul 2012	NDL	Par 30039

begin
	//----------------
	//Check the status of the TI
	//---------------
	wle := _job.getWLEForTI(_ti);
	crane := _job.myJobSheet.CM_VoyageJobSheet.getMyCrane();
	if _newShipLocation &lt;&gt; null then //cnwrd1 par 29286 ,26/7/2012  ship release may have got resequenced since we planned it
		shipLC := _newShipLocation;
	else
		shipLC	:= _ti.getPrimaryLocation(PLANNING_MODE);
	endif;
	queue := _machine.myPrimaryQueue;
	//13 Jul 2012	NDL	Par 30039
	if crane = null then
		wp := _task.myEntry.getJobWorkPoint();
	endif;
	
	_machine.executeSetDownShipLander(_task);
	if crane &lt;&gt; null then	//13 Jul 2012	NDL	Par 30039
		crane.releaseToShip(_ti, wle, shipLC);
	//13 Jul 2012	NDL	Par 30039
	else
		wp.releaseToShip(_ti, wle, shipLC);
	endif;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_newShipLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipMoveImport" id="16d776b0-d0f7-4e9e-a421-12c6f05c044b">
        <source>utlUpdateShipMoveImport(_machine : CM_Machine input; 
					_ti : CM_TrackedItem input; 
					_wle : CM_WorkListEntry; 
					_job : CM_VoyageJob;
					_quantity 	: Integer;
					_weight 	: Decimal;
					_passport : CM_Passport input);
/*
Purpose:			
Date			Who			Reason
JUNE 2015		CNWAB1		Initial creation
21 May 2019		jlgzm1		TFS 42840 MSL Direct Release between Voyages and Rail
*/
vars
	laneLC : CM_LocationsController;
	queue 	: CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	pxyJob : CM_VoyageJob;
	histEntry 			: CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
	invalidTask	: Boolean;
	setDownTask : CM_RTQueueTask;
	crane		: CM_Crane;
	wleCargo,
	moveCargo	: CM_TrackedItem;
	theWLE  : CM_WorkListEntry;
	vjob : CM_VoyageJob; // tfs42840
begin
	//----------------
	//Check the status of the TI
	//---------------
	queue := _machine.myPrimaryQueue;	
	exclusiveLock(_ti);	
	//------------------
	//OK, the TI is not in the queue, attempt an Autoplan, and queue it.
	//------------------

	if _ti.getPrimaryLocation(QUEUE_MODE) = null then
		if _ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
			_ti.doQueuedMoveToPlan(null, _passport);// ### TFS 51988 17SEP2021 NAVAB1
			// Added this secondary check to handle the autoplanning of DLRs
			if _ti.getPrimaryLocation(QUEUE_MODE) = null then
				_ti.autoPlan(QUEUE_MODE, _job, null, null, _passport);
			endif;
		else
			_ti.autoPlan(QUEUE_MODE, _job, null, null, _passport);
		endif;
		
		//epr WARNINGS are never reported to handhelds so only stop if there are errors otherwise
		// the user gets a message stating they have successfully processed the message when infact they have not
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	//cnwrd1 par 28038 23.8.11
	if _job &lt;&gt; null and not _job.isLoadedToOperations then
	//we have a job and it is not loaded to ops.	
		pxyJob := _job.pxyCreateUpdateProxy();	
		app.myUtilityUA.utlUpdateVoyageJobLoadUnload(pxyJob, true, _passport);	
	endif;	

	if not queue.getTaskImportForWLE(_wle,task,_machine) then		
		return;
	endif;

	//tfs42840 start
	vjob := _job;
	if vjob = null then
		if _wle &lt;&gt; null then
			vjob := _wle.getDRLinkedVoyageJob();
		endif;
	endif;
	if vjob &lt;&gt; null then
		laneLC := vjob.getDefaultDischargeLane();
		if vjob.myJobSheet &lt;&gt; null then //cnwrd1 par 25624 3.7.2012 
			crane := vjob.myJobSheet.CM_VoyageJobSheet.getMyCrane();
		endif;
	endif;
	//tfs42840 end
	
	if laneLC = null then
		//--------------
		//Invalid location
		//--------------
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, null, null, null);
		return;
	endif;
	
	
	_machine.checkAndResetStatus();
	_machine.setMachineStatus(STATUS_ASSIGNED , "", false);
	_machine.setMachineStatus(STATUS_WORKING , "", false);
	
	self.utlChangeTaskStatus(task,_machine,TASK_WORKING,app.myPassport);
	
		
	// 22/03/2011 cnwmh5 #25795 - Start
	histEntry := _machine.addMoveToHistoryTask(task);
	//epr par 35702 3/3/15
	moveCargo:=_ti.receiveFromShip(null, laneLC, _quantity,_weight,null, app.myPassport); // ### TFS 51988 07OCT2021 NAVAB1
		
	if app.myPassport.hasErrors then
		return;
	endif;
		
	//if  _machine.machineType = MACHINETYPE_IMVthen	//10 Mar 2010	NDL	CCMS MES 1006
	//moveTransaction := moveCargo.moveToLocation(_machine.myMachineController, null,null, _machine, REAL_MODE, false, true, false, true,  _machine.machineType &lt;&gt; MACHINETYPE_IMV ,   false, _quantity,_weight,app.myPassport);	// TFS 2651
	moveTransaction := moveCargo.moveToLocation(_machine.myMachineController, null,null, _machine, REAL_MODE, false, true, false, true,  _machine.machineType &lt;&gt; MACHINETYPE_IMV ,   false, _quantity,_weight,null,null,null,app.myPassport);	// TFS 2651
	
	if app.myPassport.hasErrors then	//19 Aug 2019	NDL	TFS 46045 - error occurred during moveToLocation, leaving moveTransaction null, so 1090 below.
		return;
	endif;
	
	//else
	//	moveTransaction := _ti.moveToLocation(_machine.myMachineController, null,null, _machine, REAL_MODE, false, true, false, true, true,   false,_quantity,_weight, app.myPassport);
	//endif;
	histEntry.setMyMoveTransaction(moveTransaction);

	on Exception do app.handleDeletedObject(exception,task,invalidTask);
	// ### update Q Task
	task.setSourceLocation( _machine.myMachineController); //laneLC;
	// 22/03/2011 cnwmh5 #25795 - End
	
	//epr par 35702 27/2/15 CCMS 2457
	wleCargo:=_wle.myTrackedItem;
	moveCargo:=moveTransaction.myTrackedItem;
	theWLE:=_wle;		// 31/1/17 MAP TFS3171
	if wleCargo &lt;&gt; null and wleCargo &lt;&gt; moveCargo then
//		theWLE:=_wle;		// 31/1/17 MAP TFS3171
		if wleCargo.myCargoType.isBreakBulkMulti  then	
			if moveCargo.totalQuantity &gt;= _wle.quantity then					
				wleCargo.splitMergeUpdateWLEsTI(theWLE,moveCargo,null);
			endif;
		elseif wleCargo.myCargoType.isBulkMulti then
			if moveCargo.totalWeight &gt;=  _wle.weight then					
				wleCargo.splitMergeUpdateWLEsTI(theWLE,moveCargo,null);
			endif;
		endif;
	endif;
	if theWLE &lt;&gt; null then
		theWLE.rebuildStatus();			// 27/1/17 MAP TFS3171 appears to have been omitted in consolidation
	endif;
		
	//10 Mar 2010	NDL	CCMS MES 1006
	if not invalidTask and task.isPickUp then
		task.setStatus(TASK_COMPLETE);
		//get the next task, i.e. the set down
		setDownTask :=task.myEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
		if setDownTask = null or not setDownTask.isSetDown then		
			return;
		endif;
		self.utlChangeTaskStatus(setDownTask,_machine,TASK_WORKING,app.myPassport);
	
	endif;
	
	
	
	
epilog
	delete pxyJob;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipMoveImport4Split" id="fa93f92c-3e71-45f1-b8d5-eb9dd03b29db">
        <source>utlUpdateShipMoveImport4Split(_machine : CM_Machine input; 
					_ti : CM_TrackedItem input; 
					_wle : CM_WorkListEntry; 
					_job : CM_VoyageJob;
					_quantity 	: Integer;
					_weight 	: Decimal;
					_passport : CM_Passport input);
/*
Purpose:	Handle the split and merging of cargo from the voyage to an IMV
			The process from receiving from a voyage has always been to do the following, queue the cargo, move instantly to the CTA/WPA, move instantly to the IMV. This is OK for cargo not being split.
			However for split cargo the queueing, queues the cargo on ship, the move to the CTA splits the cargo, the new cargo is on the iMV but the 'parent' on the voyage is still linked to the RTQ and the WLE, there is not WLE for the new cargo.
		
			This method does the following for splitting:
			Move the cargo to the CTA/WPA, this splits the cargo and creates a WLE for the cargo if there is a job.
			Queue the 'new' cargo, which uses the 'new' WLE, so the RTQ Entry is correct
			Move the new cargo to the IMV.
			
			This method does the following for merging. This happens when cargo has been split moved from the voyage and then more of the same cargo is split from the voyage and then merged into the cargo on the IMV:
			Move the on ship cargo to the IMV, for the correct quantity, merging the cargo. No new WLE is created.
			Update the quantity on the WLE and the RTQ Entry.
			


Date		Who		Reason
08OCT2021	NAVAB1	TFS 51988
*/

vars
	laneLC : CM_LocationsController;
	queue 	: CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	entry : CM_RTQueueEntry;
	pxyJob : CM_VoyageJob;
	histEntry 			: CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
	crane		: CM_Crane;
	moveCargo	: CM_TrackedItem;
	theWLE  : CM_WorkListEntry;
	vjob : CM_VoyageJob; // tfs42840
	
	control : CMIF_MoveController;
	voyage : CM_Voyage;
	wp : CM_WorkPoint;
	doingMerge : Boolean;
	params : CMIF_AutoplanParams;
begin


	// ### NOTE - WE may not have a voyage job. Cargo without a job can be moved by machine. 
	// ###        In this case the autoplan will create a special 'invisible' voyage job - CM_VoyageROROJob
	
	//----------------
	//Check the status of the TI
	//---------------
	queue := _machine.myPrimaryQueue;	
	
	if _job &lt;&gt; null and not _job.isLoadedToOperations then
	//we have a job and it is not loaded to ops.	
		pxyJob := _job.pxyCreateUpdateProxy();	
		app.myUtilityUA.utlUpdateVoyageJobLoadUnload(pxyJob, true, _passport);	
	endif;	


	vjob := _job;
	if vjob = null then
		if _wle &lt;&gt; null then
			vjob := _wle.getDRLinkedVoyageJob();
		endif;
	endif;
	if vjob &lt;&gt; null then
		laneLC := vjob.getDefaultDischargeLane();
		if vjob.myJobSheet &lt;&gt; null then
			crane := vjob.myJobSheet.CM_VoyageJobSheet.getMyCrane();
		endif;
	endif;
	
	if laneLC = null then
		voyage:= _ti.myVoyage;
			
		// If no jobs then there must be a voyage and WP queue setup
		wp := voyage.getWorkPointWithNoJS();
		if wp &lt;&gt; null then
			laneLC := wp.getDefaultDischargeLane(false);
		endif;
		
		
		if laneLC = null then
			wp := voyage.getWorkPointFirst();
			if wp &lt;&gt; null then
				laneLC := wp.getDefaultDischargeLane(false);
			endif;
		endif;
		
		if laneLC = null then
			//--------------
			//Invalid location
			//--------------
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_INVALID_LOCN, null, null, null);
			return;
		endif;
	endif;
	
	// ### ARE WE MERGING?, IF NOT MOVE THE CARGO TO THE TRANSFER AREA, TO GET THE SPLIT
	moveCargo := _machine.myMachineController.allTrackedItemsById[_ti.id,_ti.cargoType];
	
	doingMerge := moveCargo &lt;&gt; null;
	if doingMerge then
		// ### MERGING, JUST MOVE THE CARGO TO THE IMV
		theWLE := moveCargo.allWorklistEntries.first; // This will be COMPLETE, but that is OK
		
		if theWLE = null then
			app.raiseCMException(Work_list_entry_found,null,null);
			return;
		endif;

		moveTransaction := _ti.moveToLocationFromShipMerge(_machine.myMachineController, _machine, REAL_MODE, true,  _machine.machineType &lt;&gt; MACHINETYPE_IMV,   false, _quantity,_weight,app.myPassport);
		
		if app.myPassport.hasErrors then
			return;
		endif;
	
	
	else
		// ### MOVE TO THE TRANSFER AREA - CRANE or WORK POINT - this will create a NEW ti when it splits, the new TI is returned.
		moveCargo:=_ti.receiveFromShip(null, laneLC, _quantity,_weight,_wle, app.myPassport); 
		
		if app.myPassport.hasErrors then
			return;
		endif;
	
			//------------------
		//OK, the TI is not in the queue, attempt an Autoplan, and queue it.
		//------------------
		exclusiveLock(moveCargo);	

		if moveCargo.getPrimaryLocation(QUEUE_MODE) = null then

			// ### TFS 51988 - If the cargo has no discharge job predefined, get the  auto plan to create one for us.
			create params transient;
			params.isNonCraneVoyageMove := (moveCargo.getVoyageWLEUnactioned(false) = null);
			
			
			if moveCargo.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
				moveCargo.doQueuedMoveToPlan(params, _passport);// ### TFS 51988 17SEP2021 NAVAB1
				// Added this secondary check to handle the autoplanning of DLRs
				if moveCargo.getPrimaryLocation(QUEUE_MODE) = null then
					moveCargo.autoPlan(QUEUE_MODE, _job, null, params, _passport);
				endif;
			else
			
			
				moveCargo.autoPlan(QUEUE_MODE, _job, null, params, _passport);
			endif;
			
			//epr WARNINGS are never reported to handhelds so only stop if there are errors otherwise
			// the user gets a message stating they have successfully processed the message when infact they have not
			if _passport.hasErrors then
				return;
			endif;
		endif;	
		moveTransaction := moveCargo.moveToLocation(_machine.myMachineController, null,null, _machine, REAL_MODE, false, true, false, true,  _machine.machineType &lt;&gt; MACHINETYPE_IMV ,   false, _quantity,_weight,null,null,null,app.myPassport);
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		theWLE := moveCargo.getVoyageWLEUnactioned(false);
		if theWLE = null then
			theWLE := _wle;
		endif;
		if theWLE = null then
			app.raiseCMException(Work_list_entry_found,null,null);
			return;
		endif;
		
	endif;
	
	
	
	
	if not queue.getTaskImportForWLE(theWLE,task,_machine) then		
		return;
	endif;
	

	_machine.checkAndResetStatus();
	_machine.setMachineStatus(STATUS_ASSIGNED , "", false);
	_machine.setMachineStatus(STATUS_WORKING , "", false);
	
	self.utlChangeTaskStatus(task,_machine,TASK_WORKING,app.myPassport);
	
	histEntry := _machine.addMoveToHistoryTask(task);
	histEntry.setMyMoveTransaction(moveTransaction);

	
	// Tidy up the WLEs if merging
	if doingMerge then
		theWLE := moveCargo.allWorklistEntries.first;
		if theWLE &lt;&gt; null then
			theWLE.setQuantity(theWLE.quantity + _quantity);
			theWLE.causeEvent(theWLE.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, theWLE);	
			
			foreach entry in theWLE.allRTQueueEntries do
				entry.setQuantity(theWLE.quantity);
				entry.sendNotesForRelatedEntry();
			endforeach;
		endif;
		
		
		// ## CARGO STILL ON VOYAGE
		theWLE := _ti.getVoyageWLEUnactioned(false);
		if theWLE &lt;&gt; null then
			theWLE.setQuantity(theWLE.quantity - _quantity);
			theWLE.causeEvent(theWLE.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, theWLE);	
			theWLE.rebuildStatus(); // This can end up being zero
		endif;
		
	endif;
	
	
epilog
	delete pxyJob;
	delete control;
	delete params;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipPortGroup" id="1c5d9490-f9cb-453c-a9e6-1099ef06f652">
        <source>utlUpdateShipPortGroup(pProxyShipPortGroup:CM_ShipPortGroup; _passport : CM_Passport input);

vars
	cancelSave:Boolean;
	realShipPortGroup:CM_ShipPortGroup;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyShipPortGroup.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyShipPortGroup.pxyGetRealObjectAndEdition(realShipPortGroup, expectedEdition);
	
	if realShipPortGroup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ShipPortGroup.name, null, null);
		return;
	endif;

	app.myValUA.valShipPortGroup(realShipPortGroup, pProxyShipPortGroup, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realShipPortGroup);

	if _passport.noErrors and realShipPortGroup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ShipPortGroup', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realShipPortGroup, true);
	endif;
	
	if _passport.noErrors then
		realShipPortGroup.setForUpdate(pProxyShipPortGroup);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realShipPortGroup, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyShipPortGroup" type="CM_ShipPortGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
