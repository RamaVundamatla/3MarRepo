    <JadeMethod name="setupForBOL" id="f8c04962-6420-4f42-bc89-9ad4e9f607ba">
        <updating/>
        <source>setupForBOL() protected, updating;
/*

Date		Who		Reason
29 January 2015	cnwer1	Initial creation PAR 35427

*/

vars
	
begin
	if self.myBOL &lt;&gt; null then
		self.setCaption(app.getErrorString1(BOLTransactions,self.myBOL.number) );
	endif;
		
	self.fldTrans.useSheetBackColors := true;
	self.fldTrans.setDefaultSheetBackColors();
	self.fldTrans.initSheetBackColors();
	
	
	self.shtEventRequests.visible:=false;
	self.shtTemperatures.visible:=false;
	self.shtDiscrepancies.visible:=false;
	self.shtCharges.visible := true;	//28 Nov 2019	NDL	TFS 47727
	self.tblTrans.stretchToParent			:= true;

	self.btnAdd.visible:=false;
	self.btnEdit.visible:=false;
	self.btnResync.visible:=false;
	

	self.tblTrans.selectionType 		:= CM_BaseTable.SelectionType_Row;
	self.tblTrans.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.chkTransAudit.value := false;	// cnwvu1. March 2008. by default - the form doesn't show old edited transactions
	self.tblTransactions.visible := false;
	
	//28 Nov 2019	NDL	TFS 47727
	self.tblCharges.alignment := Table.Alignment_Left_Top;
	self.tblCharges.stretchToParent := true;
	self.tblCharges.selectionType := CM_BaseTable.SelectionType_Row;
	self.showCharges;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForCargo" id="c79cbfc7-3fcc-4645-a92a-5cba5376e92d">
        <updating/>
        <source>setupForCargo() updating, protected;

vars
	tmpStr : String;
begin
	if  self.myTrackedItem.isTranshipItem then
		if self.myTrackedItem.isTranshipExport() then
			tmpStr := " (Tranship Outbound)";
		elseif self.myTrackedItem.isTranshipOnInboundVoyage() then
			tmpStr := " (Tranship Inbound)";
		endif;
	endif;
	self.setCaption('Transactions for ' &amp; self.myTrackedItem.id &amp; tmpStr);
	
		
	self.tblCharges.stretchToParent			:= true;
	self.tblDiscrepances.stretchToParent	:= true;
	self.tblTemperatures.stretchToParent	:= true;
	self.tblTrans.stretchToParent			:= true;
	
	self.fldTrans.useSheetBackColors := true;
	self.fldTrans.setDefaultSheetBackColors();
	self.fldTrans.initSheetBackColors();

	self.tblCharges.selectionType		:= CM_BaseTable.SelectionType_Row;
	self.tblDiscrepances.selectionType	:= CM_BaseTable.SelectionType_Row;
	self.tblTemperatures.selectionType	:= CM_BaseTable.SelectionType_Row;
	self.tblTrans.selectionType 		:= CM_BaseTable.SelectionType_Row; // TFS 39236
	self.tblCharges.selectionType 		:= CM_BaseTable.SelectionType_Row;
	self.tblTrans.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.chkTransAudit.value := false;	// cnwvu1. March 2008. by default - the form doesn't show old edited transactions
	self.tblTransactions.visible := false;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForTransaction" id="4c273b47-64df-46ab-8df0-60f75dce0699">
        <updating/>
        <source>setupForTransaction() updating, protected;
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync

vars
	tmpStr : String;
	extraHeight	: Real;
begin
	self.setCaption(app.getErrorString(Transaction_Enquiry));
	self.isSelectorCapable := true;
	// hide the per-item tables
	self.fldTrans.visible := false;

	self.frmSearchCrit.top := self.frmToolbar.height;
	self.frmSearchCrit.left := 1;
	self.frmSearchCrit.height := 50; // ### TFS 50421 17SEP2021 NAVAB1
	self.frmSearchCrit.width := self.clientWidth;
	self.frmSearchCrit.parentAspect := Frame.ParentAspect_StretchRight; // ### TFS 50421 17SEP2021 NAVAB1
	self.frmSearchCrit.caption := "";
	self.frmSearchCrit.visible := true;
	self.lblSearchCrit.height := self.frmSearchCrit.height - 2;
	self.lblSearchCrit.width := self.frmSearchCrit.width - 2;
	self.lblSearchCrit.top := 10; // ### TFS 50421 17SEP2021 NAVAB1
	self.tblCharges.selectionType 		:= CM_BaseTable.SelectionType_Row; // TFS 39236

	self.doRepositionTables();//BUG 46339 
	
	// hide invoice-based searcher fields if no permission to view/use
	if not app.myCurrentUserCan(self.myTerminal, PmTransEnquiryInvoiceDtls) then
		self.lblSearchBusUnit.visible := false;
		self.frmQuery.height := self.lblSearchBusUnit.top + 15;
	endif;
	self.beginClassNotification(CM_Transaction, false, Object_Update_Event, Response_Continuous, 0);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="690a505c-392a-446c-b968-006759cda34d">
        <updating/>
        <source>setupForm() updating;
/*
 Created:     13 August 2003 by cnwrs2

 Purpose:     
 ---------------------------------------------------------------------------
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
07 May 2019	jlgdi1	TFS 44622 Added mnuTxnDelete in security role check
11 Jul 2023 navhl20 Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
*/
vars
	tmpStr : String;
begin
	inheritMethod();
	// modeString is set to Mode_Transaction_Enquiry by the navigator menu processing for Cargo Transactions
	// and is null when called from the cargo enquiry form for individual item transaction display
	self.mode := self.modeStr.Integer; 
	if self.mode = 0 then
		if self.myBOL &lt;&gt; null then //epr par 35427 29/1/15
			self.mode:=self.Mode_BOLItem_Enquiry;
		elseif self.myWorkOrder &lt;&gt; null or self.myWorkOrderDtl &lt;&gt; null then			//11.7.2023 navhl20 #59047
			self.mode := self.Mode_WO_Transaction_Enquiry;
		// ### JIRA 33348 22NOV2024 NAVAB1
		elseif self.myAccumulation &lt;&gt; null then
			self.mode := self.Mode_ContractAccumulation;
		else
			self.mode := self.Mode_CargoItem_Enquiry;
		endif;
	endif;
	self.showToolbar			:= true;
	self.toolbarStyle			:= self.ToolbarStyle_ShowNoHide;
	self.staLine.caption		:= "";
	self.mnuInformation.caption := "Inspect Object";
	self.frmTransferType.visible := false;				//22.11.2018 cnwma1 TFS #42118
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.setupForCargo();
	elseif 	self.mode = self.Mode_BOLItem_Enquiry then //epr par 35427 29/1/15
		self.setupForBOL();
	elseif self.mode = self.Mode_WO_Transaction_Enquiry then						//11.7.2023 navhl20 #59047
		self.setUpForWO();
	else
		self.setupForTransaction();
	endif;
	
	self.initEventNotificationTbl();
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnResync.enabled := false;
		self.btnDelete.enabled := false;
		self.mnuTxnResync.enabled:= false;
		self.mnuTxnDelete.enabled:= false;	// TFS 44622
	endif;
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.frmTableFilter.setupControl(self.tblTrans, null); //05/06/2024	navkc1 CR 63736 Task 63770
	else
		self.frmTableFilter.setupControl(self.tblTransactions, null); //05/06/2024	navkc1 CR 63736 Task 63770
	endif;
	self.frmTableFilter.setCallbackMethod(CMUI_TransactionEnquiry::doFilterTable.name); //05/06/2024	navkc1 CR 63736 Task 63770
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupNotesForTransactions" id="45a0d5d5-9d2a-4bfe-a416-b79bea57c0df">
        <source>setupNotesForTransactions(_controller : CMIF_TiTransactionResync);
// ---------------------------------------------------------------------------
// Created:     30 June 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 30/6/8			AKB				// PAR 16550
// ---------------------------------------------------------------------------

vars
	event	: Integer;
	txn : CM_Transaction;
begin
	self.endNotificationForSubscriber(self);
	
	// Feb 2012 for from-cargo enquiry transactions, just register for the last transaction and refresh everything 
	//  otherwise register for each transaction and refresh the table individually
	event := self.myTerminal.getTerminalEvent(EVENT_TRAN_RESYNC);
	if self.mode = self.Mode_CargoItem_Enquiry then
		txn := _controller.allTransactions.last;
		if txn &lt;&gt; null then
			self.beginNotification(txn, event, Response_Continuous, null);
		endif;
		
	else
		self.beginClassNotification(CM_Transaction, false, Object_Update_Event, Response_Continuous, 0);
		foreach txn in _controller.allTransactions do
			self.beginNotification(txn, event, Response_Continuous, null);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
    </JadeMethod>
    <JadeMethod name="showCharges" id="330edf43-94cc-4679-a4c1-7e9fe78be0b6">
        <source>showCharges() protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 22/09//2015  cnwma1      PAR #36493 Issues with Extra Payments in Cash collection and Transactions 
// 03/08/2016   cnwma1		TFS #2102:Sorting Issue on Tracked Item Transaction Screen
// 12/07/2017	cnwma1		TFS #4702:JMT - Invoice Line Date/Time not being displayed in local timezone
// 20/07/2019 	cnwma1		Bug 46586: New Cash collection form showing Tax codes rather than Description
// 20/09/2019   cnwma1		Bug 46656: Receipt number not displaying on Charges tab for tax payments
// 22/02/2021   cnwma1      Bug 50843: GUQ - Error 1090 in Cash Collection while trying to save
// 08/12/2023	navkc1		ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email
// ---------------------------------------------------------------------------

vars
	cp				 : CM_CashPayment;
	cr				 : CM_CashReceipt;
	status,
	receiptNumber	 : String;
	lDetails, 
	taxdetail, 
	taxcode 		 : String;
	idx				 : Integer;
	invLine			 : CM_InvoiceLine;
	charge			 : CM_Charge;
	invLineDict 	 : CM_InvoiceLineBySeqNumDict;	//28 Nov 2019	NDL	TFS 47727
	cashPayDict	 	 : CM_CashPaymentDict;	//28 Nov 2019	NDL	TFS 47727
	invLineDictTrans : CM_InvoiceLineBySeqNumDict;	//28 Nov 2019	NDL	TFS 47727
	moneyStr,
	narrStr,
	transtring,
	cashInvString,
	qtystring 		: String;
	quantity		: Decimal[23,6];  // ### JIRA 34909 16MAY2025 NAVAB1
	showMoney 	    : Boolean;
	audit			: CM_Audit;
	cooAudit		: CM_AuditLineCOOVoid;
	tiTran : CM_TITransaction;

begin

	showMoney := app.getMyUser.canDo(self.myTerminal,PmAdmInvoicelinesView);
	
	tblCharges.rows 		  := 0;
	if showMoney then
		tblCharges.columns 	  := 11;	
	else
		tblCharges.columns 	  := 9;	
	endif;
	
	self.tblCharges.selectionType 	:= CM_BaseTable.SelectionType_Row; // TFS 39236
	
	tblCharges.addItemAt(app.getErrorString(DateStr) 	    &amp; Tab &amp;
						app.getErrorString(Invoice)		    &amp; Tab &amp; 
						app.getErrorString(Seq)			    &amp; Tab &amp; 
						app.getErrorString(INV_Debtor) 	    &amp; Tab &amp;
						app.getErrorString(Manual) 		    &amp; Tab &amp; 
						app.getErrorString(Qty) 		    &amp; Tab &amp; 
						app.getErrorString(Status) 		    &amp; Tab &amp; 
						app.getErrorString(Transaction) 	&amp; Tab &amp; 
						app.getErrorString(TYPE) 		    &amp; Tab &amp; 
						app.getErrorString(CM_Narration) 	&amp; Tab &amp; 
						app.getErrorString(Amount), 1);
	
	tblCharges.fixedRows 	:= 1;
	self.setColorsForTable(self.tblCharges);			
	tblCharges.accessColumn(1);
	tblCharges.sortColumn[1] := 1;
	tblCharges.sortAsc[1]	 := false;									   //03/08/2016  cnwma1 TFS #2102
	tblCharges.accessedColumn.sortType := Table.SortType_TimeStamp;    	   //03/08/2016  cnwma1 TFS #2102 

	//28 Nov 2019	NDL	TFS 47727
	if self.myTrackedItem &lt;&gt; null then
		invLineDict := self.myTrackedItem.invoiceLines;
		cashPayDict := self.myTrackedItem.allCashPayments;
	elseif self.myBOL &lt;&gt; null then
		create invLineDictTrans transient;
		self.myBOL.getInvoiceLinesFromBOLTrns( invLineDictTrans );
		invLineDict := invLineDictTrans;
		cashPayDict := null;
		self.shtCharges.caption := app.getErrorString(Charges) &amp; " (" &amp; invLineDictTrans.size.String &amp; ")";
	// ### JIRA 33348 22NOV2024 NAVAB1
	elseif self.myAccumulation &lt;&gt; null then
		create invLineDictTrans transient;
		foreach tiTran in self.myAccumulation.allContributingTransactions do
			tiTran.allInvoiceLines.copyNoDuplicates( invLineDictTrans, false );
		endforeach;

		invLineDict := invLineDictTrans;
		cashPayDict := null;
		self.shtCharges.caption := app.getErrorString(Charges) &amp; " (" &amp; invLineDictTrans.size.String &amp; ")";
	endif;

	if invLineDict &lt;&gt; null then	//28 Nov 2019	NDL	TFS 47727
		foreach invLine in invLineDict discreteLock do
			cooAudit := null;
			
			//08/12/2023	navkc1 ChangeRequest 58261 Task 58260
			foreach audit in invLine.qualifiedAudits discreteLock, reversed where audit.isAuditLineCOOVoid() do
				cooAudit := audit.CM_AuditLineCOOVoid;
				break;
			endforeach;
			
			//08/12/2023	navkc1 ChangeRequest 58261 Task 58260
			if cooAudit &lt;&gt; null then
				status := invLine.getStatusDescription(invLine.status) &amp; " - COO issue";
			else
				status := invLine.getStatusDescription(invLine.status) ;
			endif;
			
			transtring := invLine.getTransactionColumnDisplay();                          // TFS 46924
			narrStr    := invLine.invoiceLineDesc.narration;                              // TFS 46924
			moneyStr   := "";                                                             // TFS 46924
			if showMoney then                                                             // TFS 46924
				moneyStr := invLine.lineTotal.asStringJMTWithPrecision(2, true);          // TFS 46924
			 
			endif;
			
			// ### JIRA 34909 16MAY2025 NAVAB1
			quantity := invLine.quantity;
			qtystring := quantity.asStringJMTWithPrecision(6, true);
			
			lDetails := invLine.getChargeTimeLocalTZ.shortCurrentLocaleFormat &amp; Tab &amp;
						invLine.invoice.sequenceNum.String             		  &amp; Tab &amp;
						invLine.sequenceNum.String 					 		  &amp; Tab &amp;
						invLine.debtor.name		  				 	 		  &amp; Tab &amp;
						invLine.manual.String       				 		  &amp; Tab &amp; 	
						qtystring 				   	 		  &amp; Tab &amp; 
						status												  &amp; Tab &amp;  //08/12/2023	navkc1 ChangeRequest 58261 Task 58260
						transtring 									 		  &amp; Tab &amp;  // TFS 46924
						"Invoice Line"								          &amp; Tab &amp; 
						narrStr         							          &amp; Tab &amp;
						moneyStr;											           // TFS 46924
		
		
			idx := tblCharges.addItemObject(invLine,lDetails);
	
			if (idx mod 2 = 0) then
				tblCharges.accessRow(idx).backColor := self.colorRow1;
			else
				tblCharges.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
	endif;
	
	
	
	if cashPayDict &lt;&gt; null then	//28 Nov 2019	NDL	TFS 47727
		foreach cp in cashPayDict do
			
			receiptNumber := "";
			taxdetail     := ""; 
			cashInvString := "";
			moneyStr      := ""; 
			
			if  self.getCashReceipt(cp) &lt;&gt; null then
				receiptNumber := self.getCashReceipt(cp).getExternalInvoiceNumber();
				if self.getCashReceipt(cp).myCashInvoice &lt;&gt; null then
					cashInvString := self.getCashReceipt(cp).myCashInvoice.sequenceNum.String;
				else
					if cp.myInvoice &lt;&gt; null then                              //22.02.2021 cnwma1 #50843
						cashInvString := cp.myInvoice.sequenceNum.String;
					endif;
				endif;
			endif;
			
			// TAX CASH PAYMENT
			if cp.isTaxPayment &lt;&gt; null then 				   
				continue;
			endif;
			
			invLine := cp.myInvoiceLine; // ### JIRA 34909 16MAY2025 NAVAB1 local variable
			 // TFS 46924
			if invLine &lt;&gt; null then
				transtring :=  invLine.getTransactionColumnDisplay(); // TFS 46924
				narrStr    :=  invLine.invoiceLineDesc.narration;
				
				// ### JIRA 34909 16MAY2025 NAVAB1
				quantity := invLine.quantity;
				qtystring := quantity.asStringJMTWithPrecision(6, true);
				
				if quantity = 0 then				
					// The quantity is stored on the proforma that does not exist anymore.
					// Hack out the quantity in case of over payment
					if  invLine.getRate() &gt; 0 then
						quantity := (cp.cashValue / invLine.getRate());   // ### JIRA 34909 16MAY2025 NAVAB1 show as a decimal not .Integer;
					endif;
					if quantity&lt;= 0 then
						quantity := 1;
					endif;
					qtystring := quantity.String; 
				endif;
			elseif cp.myProformaDetail &lt;&gt; null then 
				transtring  :=  cp.myProformaDetail.getTransactionTypeString();
				narrStr     :=  cp.myProformaDetail.myInvoiceLineType.narration;
				qtystring   := cp.myProformaDetail.quantity.String;
			else
				transtring  := "";
				narrStr     := "";
				qtystring   := "1";
			endif;
			
			if showMoney then                                                      // TFS 46924
				moneyStr := (-cp.cashValue).asStringJMTWithPrecision(2, true);     // TFS 46924
			endif;
	
			lDetails := cp.dateTime.shortCurrentLocaleFormat 	&amp; Tab &amp; 
						cashInvString                        	&amp; Tab &amp;
						receiptNumber 						 	&amp; Tab &amp; 
						cp.getDebtorTerminal().myDebtor.name 	&amp; Tab &amp;
						cp.manual.String 					 	&amp; Tab &amp; 
						qtystring 								&amp; Tab &amp;  		 // TFS 46924
						cp.getStatusDescription(cp.status)   	&amp; Tab &amp; 
						transtring 								&amp; Tab &amp;  		// TFS 46924
						"Cash Payment" 							&amp; Tab &amp; 
						narrStr 								&amp; Tab &amp;
						moneyStr;
						
			
			// Add the row to the table
			idx := tblCharges.addItemObject(cp, lDetails);
	
			if (idx mod 2 = 0) then
				tblCharges.accessRow(idx).backColor := self.colorRow1;
			else
				tblCharges.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
	endif;

epilog
	
	delete invLineDictTrans;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showChargesNote" id="6cc9dd61-1665-42fd-add6-8967d773806b">
        <source>showChargesNote(tmpStr : String);
// ---------------------------------------------------------------------------
// Created:		06 11 2006 By Yi Liu cnwyl1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	i : Integer;
begin
	i := tblCharges.addItem(tmpStr);
	tblCharges.accessCell(i, 1).mergeCells := Table.MergeCells_Merge;
	tblCharges.accessCell(i, 1).backColor := LightBlue;
end;</source>
        <Parameter name="tmpStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="showChargesOLD" id="3859d8f9-c7fb-4b68-b9d3-c2b7835a8355">
        <source>showChargesOLD() protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 22/09//2015  cnwma1      PAR #36493 Issues with Extra Payments in Cash collection and Transactions 
// 03/08/2016   cnwma1		TFS #2102:Sorting Issue on Tracked Item Transaction Screen
// 12/07/2017	cnwma1		TFS #4702:JMT - Invoice Line Date/Time not being displayed in local timezone
// 20/07/2019 	cnwma1		Bug 46586: New Cash collection form showing Tax codes rather than Description
// 20/09/2019   cnwma1		Bug 46656: Receipt number not displaying on Charges tab for tax payments
// ---------------------------------------------------------------------------

vars
	cp				: CM_CashPayment;
	cr				: CM_CashReceipt;
	receiptNumber	: String;
	lDetails, 
	taxdetail, 
	taxcode 		: String;
	idx				: Integer;
	invLine			: CM_InvoiceLine;
	charge			: CM_Charge;
	invLineDict 	: CM_InvoiceLineBySeqNumDict;	//28 Nov 2019	NDL	TFS 47727
	cashPayDict		: CM_CashPaymentDict;	//28 Nov 2019	NDL	TFS 47727
	invLineDictTrans : CM_InvoiceLineBySeqNumDict;	//28 Nov 2019	NDL	TFS 47727
	
begin
	
	tblCharges.rows 				:= 0;
	tblCharges.columns 				:= 7;	
	self.tblCharges.selectionType 	:= CM_BaseTable.SelectionType_Row; // TFS 39236
	
	tblCharges.addItemAt(app.getErrorString(DateStr) 	 &amp; Tab &amp;
						app.getErrorString(Seq)			 &amp; Tab &amp; 
						app.getErrorString(INV_Debtor) 	 &amp; Tab &amp;
						app.getErrorString(Manual) 		 &amp; Tab &amp; 
						app.getErrorString(Qty) 		 &amp; Tab &amp; 
						app.getErrorString(Status) 		 &amp; Tab &amp; 
						app.getErrorString(CM_Narration), 1);
	
	tblCharges.fixedRows 	:= 1;
	self.setColorsForTable(self.tblCharges);			
	tblCharges.accessColumn(1);
	tblCharges.sortColumn[1] := 1;
	tblCharges.sortAsc[1]	 := false;									   //03/08/2016  cnwma1 TFS #2102
	tblCharges.accessedColumn.sortType := Table.SortType_TimeStamp;    	   //03/08/2016  cnwma1 TFS #2102 

	//28 Nov 2019	NDL	TFS 47727
	if self.myTrackedItem &lt;&gt; null then
		invLineDict := self.myTrackedItem.invoiceLines;
		cashPayDict := self.myTrackedItem.allCashPayments;
	elseif self.myBOL &lt;&gt; null then
		create invLineDictTrans transient;
		self.myBOL.getInvoiceLinesFromBOLTrns( invLineDictTrans );
		invLineDict := invLineDictTrans;
		cashPayDict := null;
		self.shtCharges.caption := app.getErrorString(Charges) &amp; " (" &amp; invLineDictTrans.size.String &amp; ")";
	endif;

	if invLineDict &lt;&gt; null then	//28 Nov 2019	NDL	TFS 47727
		foreach invLine in invLineDict discreteLock do
			
			lDetails := invLine.getChargeTimeLocalTZ.shortCurrentLocaleFormat &amp; Tab &amp;
						invLine.sequenceNum.String 					 &amp; Tab &amp;
						invLine.debtor.name		  				 	 &amp; Tab &amp;
						invLine.manual.String       				 &amp; Tab &amp; 	
						invLine.quantity.String 				   	 &amp; Tab &amp; 
						invLine.getStatusDescription(invLine.status) &amp; Tab &amp; 
						invLine.invoiceLineDesc.narration ;
		
		
			idx := tblCharges.addItemObject(invLine,lDetails);
	
			if (idx mod 2 = 0) then
				tblCharges.accessRow(idx).backColor := self.colorRow1;
			else
				tblCharges.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
	endif;
	
	
	
	if cashPayDict &lt;&gt; null then	//28 Nov 2019	NDL	TFS 47727
		foreach cp in cashPayDict do
			
			receiptNumber := "";
			taxdetail     := ""; 
			
			if  self.getCashReceipt(cp) &lt;&gt; null then
				receiptNumber := self.getCashReceipt(cp).getExternalInvoiceNumber();
			endif;
			
			if cp.myCashPaymentForInvoice &lt;&gt; null then 				   
				
				if self.getCashReceipt(cp.myCashPaymentForInvoice) &lt;&gt; null then
					receiptNumber :=  self.getCashReceipt(cp.myCashPaymentForInvoice).getExternalInvoiceNumber();
				endif;
				
				invLine := cp.myCashPaymentForInvoice.myInvoiceLine;
				
				if invLine = null then
					taxcode := cp.getTaxCodeForPayment(false);        // 20.09.2019.cnwma1 #46586
					if taxcode= null then
						taxcode := "No Tax";
					endif;
					taxdetail := " (" &amp; taxcode &amp; ")";
				else
					foreach charge in invLine.charges do
						taxcode   := " (" &amp; charge.getTaxCode(false) &amp; ")";
						lDetails := cp.dateTime.shortCurrentLocaleFormat &amp; Tab &amp; 
									receiptNumber						 &amp; Tab &amp; 
									cp.getDebtorTerminal().myDebtor.name &amp; Tab &amp;
									cp.manual.String 					 &amp; Tab &amp;
									 "1" 								 &amp; Tab &amp; 
									cp.getStatusDescription(cp.status)   &amp; Tab &amp;
									"Cash payment " &amp; charge.getTaxAmountForCharge().Decimal.asCurrencyJMT() &amp; taxcode;
									
						idx := tblCharges.addItemObject(cp, lDetails);
						if (idx mod 2 = 0) then
							tblCharges.accessRow(idx).backColor := self.colorRow1;
						else
							tblCharges.accessRow(idx).backColor := self.colorRow2;
						endif;
					endforeach;
					continue;
				endif;
			endif;
	
			lDetails := cp.dateTime.shortCurrentLocaleFormat &amp; Tab &amp; 
						receiptNumber 						 &amp; Tab &amp; 
						cp.getDebtorTerminal().myDebtor.name &amp; Tab &amp;
						cp.manual.String 					 &amp; Tab &amp; 
						"1" 								 &amp; Tab &amp; 
						cp.getStatusDescription(cp.status)   &amp; Tab &amp; 
						"Cash payment " &amp; cp.cashValue.asCurrencyJMT  &amp; taxdetail;
			
			// Add the row to the table
			idx := tblCharges.addItemObject(cp, lDetails);
	
			if (idx mod 2 = 0) then
				tblCharges.accessRow(idx).backColor := self.colorRow1;
			else
				tblCharges.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
	endif;

epilog
	
	delete invLineDictTrans;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showDiscrepancies" id="a1af85dd-418f-45ab-8a8e-6a6e53ce7e80">
        <source>showDiscrepancies() protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	overriddenWarning 				: CMEVT_OverriddenWarning;
	lDetails 						: String;
	idx								: Integer;
	entTableDef						: EntTableDef;
	tbl								: CM_DataTable;
	bookingDiscrep					: CMEVT_BookingRefDiscrep;
begin

	// set table columns
	tbl := self.tblDiscrepances;
	tbl.rows := 0;
	entTableDef := app.myController.getEntTableDef(ETDef_SysEventWarnings);
	tbl.setTblDataEntRowsFromDef(entTableDef);

	self.setColorsForTable(tbl);		
	
	foreach overriddenWarning in self.myTrackedItem.allOverriddenWarnings do
		lDetails := overriddenWarning.getAttributeStringForDefArray(self.tblDiscrepances.allTblDataEntRows);
		idx := tbl.addItem(lDetails);
		tbl.accessRow(idx).itemObject := overriddenWarning;
		if (idx mod 2 = 0) then
			tbl.accessedRow.backColor := self.colorRow1;
		else
			tbl.accessedRow.backColor := self.colorRow2;
		endif;
	endforeach;


	foreach bookingDiscrep in self.myTrackedItem.allBookingRefDiscreps do
		lDetails := bookingDiscrep.getAttributeStringForDefArray(self.tblDiscrepances.allTblDataEntRows);
		idx := tbl.addItem(lDetails);
		tbl.accessRow(idx).itemObject := bookingDiscrep;
		if (idx mod 2 = 0) then
			tbl.accessedRow.backColor := self.colorRow1;
		else
			tbl.accessedRow.backColor := self.colorRow2;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showEventRequests" id="d9b83903-5f53-48f7-bc26-15c302bedf4c">
        <source>showEventRequests() protected;
//--------------------------------------------------
// Created:	23 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (not global.isValidObject(self.myTrackedItem)) then
		return;
	endif;
	self.tblEventNotify.rows := self.tblEventNotify.fixedRows;
	self.tblEventNotify.displayRowsForCollection(self.myTrackedItem.allEventRequestsNotify, self.colorRow1, self.colorRow2, app.myPassport);
	self.tblEventNotify.displayRowsForCollection(self.myTrackedItem.allEventRequestsStops, self.colorRow1, self.colorRow2, app.myPassport);	
	self.shtEventRequests.caption :=  'Event Requests (' &amp; (self.tblEventNotify.rows-self.tblEventNotify.fixedRows).String &amp; ')';
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showNumRowsShown" id="f26c3886-8512-4d1c-bf1a-3fee99aec5e6">
        <updating/>
        <source>showNumRowsShown() updating, protected;

vars
	
begin
	self.staLine.caption := app.getErrorString1 (Num_Rows_Found, self.numItemsShown.String);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showResyncForm" id="f8001375-d0c8-4669-bcba-790bc7b58288">
        <source>showResyncForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	form : CMUI_TransactionResync;
	oa : ObjectArray;

begin
	form := app.loadForm(	CMUI_TransactionResync, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction	).CMUI_TransactionResync;	

	if form = null then
		return;
	endif;

	create oa transient;
	if self.mode = self.Mode_CargoItem_Enquiry
	or self.mode = self.Mode_BOLItem_Enquiry	//28 Nov 219	NDL	TFS 47727
	then
		self.tblTrans.allSelectedObjects.copy(oa);
	else
		self.tblTransactions.allSelectedObjects.copy(oa);
	endif;
	if oa.isEmpty() then
		app.msgBox("Please select a transaction", app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	form.setTIAndTransactions(self.myTrackedItem, oa, self.mode);
	form.myParentForm := self;
	form.show;		

epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="showResyncFrame" id="41af1a33-62a7-4c7b-9f8c-c8a86cfc0095">
        <source>showResyncFrame();
// ---------------------------------------------------------------------------
// Created:		18 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, modified to handle multiple tracked items from the transactions
// ---------------------------------------------------------------------------
vars
	txn : CM_TITransaction;
	ti : CM_TrackedItem;
	anObj : Object;
	oa	: ObjectArray;
	tiArray	: ObjectArray;
	control	: Control;
	allChildControls	: CnEcControlArray;
begin
	if 	self.frmResync.visible then
		self.frmResync.visible := false;
		return;
	endif;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
	if self.mode = self.Mode_CargoItem_Enquiry or
	   self.mode = self.Mode_Cargo_Transaction_Enquiry then
		// show the full resync frame
		self.showResyncFrameCargo();
		return;
	endif;
	create oa transient;

	self.tblTransactions.allSelectedObjects.copy(oa);

	if oa.isEmpty() then
		app.msgBox("Please select a transaction", app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// hide all controls on the resync frame except the toolbar and log option
	create allChildControls transient;
	self.frmResync.cnEcGetAllChildControls(allChildControls, false);
	foreach control in allChildControls do
		if control.name = 'frmToolbarRP' then
			control.visible := true;
		elseif control.name = 'chkRPLog' then
			control.visible := true;
			control.top := 40;
		else
			control.visible := false;
		endif;
	endforeach;
	self.btnRPSelect.visible := false;
	self.frmResync.height := 100;

	self.chkRPLog.visible := true;
	self.chkReadOnly.top := self.chkRPLog.top + self.chkRPLog.height + 5;  // ### TFS 2682
	self.chkReadOnly.visible := true;
	
	self.frmResync.centreHorizontallyInParent();
	self.frmResync.zOrder(1);

	self.frmResync.visible := true;
epilog
	delete oa;
	delete tiArray;
	delete allChildControls;
end;</source>
    </JadeMethod>
    <JadeMethod name="showResyncFrameCargo" id="c1b905a9-0ead-49e4-afd6-ee59fc63afb6">
        <source>showResyncFrameCargo() protected;
// ---------------------------------------------------------------------------
// Created:		18 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, cargo transactions, modified to handle multiple tracked items from the transactions
//	27/10/2017 	cnwma1	TFS #3223:DPH - Select All Button in Re-sync Transactions
//	5/06/2018 	JLGNS1	Bug 38935: PNL - Transaction Resync doesn't include Freight Forwarder
//	10/01/2019	jlgzm1	TFS 41053: certain pack/unpack transactions on containers dont make sense to resync. Display warning.
// ---------------------------------------------------------------------------
constants
//	Blank = 1.Character &amp; 1.Character &amp; 1.Character &amp; 1.Character; // PAR 16552
	Blank = "    "; // PAR 16552
	Multi = "****";
/*
	Bubble = "'" &amp; Blank &amp; "' means that the transaction has no value for this attribute." &amp; Cr 
				&amp; "'" &amp; Multi &amp; "' means that more than one transaction is selected and those" &amp;  Cr
				&amp; Tab &amp; "transactions have different values for this attribute." &amp; Cr
				&amp; "RED means that the value on the transaction is different from the value on the cargo.";
	Bubble2 = "'" &amp; Blank &amp; "' means that the cargo item has no value for this attribute." &amp; Cr 
				&amp; "'" &amp; Multi &amp; "' means that transactions for more than one cargo item are selected and those" &amp;  Cr
				&amp; Tab &amp; "cargo items have different values for this attribute.";
				*/
vars
	txn : CM_TITransaction;
	ti : CM_TrackedItem;
	anObj : Object;
	oa	: ObjectArray;
	tiArray	: ObjectArray;
	control	: Control;
	allChildControls	: CnEcControlArray;
	toolTip1, toolTip2 : String;
	measureType : CM_MeasurementType;
	priorValue : Real;
	displayValue : String;
	packUnpackWarning 	: Boolean; //TFS41053
begin
	if 	self.frmResync.visible then
		self.frmResync.visible := false;
		return;
	endif;
	
	toolTip2 := app.getErrorString5(TranEnqToolTip2, Cr, Cr&amp;Tab, Cr, "'     '", "'****'");
	
	toolTip1 := app.getErrorString4(TranEnqToolTip1, Cr, Cr&amp;Tab, "'     '", "'****'");
	
	
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
	create oa transient;
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.tblTrans.allSelectedObjects.copy(oa);
	else
		self.tblTransactions.allSelectedObjects.copy(oa);
	endif;

	if oa.isEmpty() then
		app.msgBox("Please select a transaction", app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// show all controls on the resync frame (may be hidden from event/HMS transactions)
	create allChildControls transient;
	self.frmResync.cnEcGetAllChildControls(allChildControls, false);
	self.frmResync.height := 466; // PAR 31615	//Bug 38935
	self.btnRPSelect.visible := true;
	foreach control in allChildControls do
		if control.name = 'chkRPLog' then
			control.top := self.frmResync.height - 40; //359; // PAR 31615
			self.chkReadOnly.top := self.chkRPLog.top + self.chkRPLog.height + 2;  // ### TFS 2682
			self.chkReadOnly.enabled := self.chkRPLog.value;  // ### TFS 2682
		else
			if control.isKindOf(CheckBox) then
				control.CheckBox.value:=false;
			endif;
		endif;
		control.visible := true;
	endforeach;
	
	if self.lblRPBusUnitT.bubbleHelp &lt;&gt; toolTip2  then
		self.lblRPBusUnitT.bubbleHelp := toolTip2;
		self.lblRPcommT.bubbleHelp := toolTip2;
		self.lblRPconT.bubbleHelp := toolTip2;
		self.lblRPconorT.bubbleHelp := toolTip2;
		self.lblRPcontentsT.bubbleHelp := toolTip2;
		self.lblRPcustAgT.bubbleHelp := toolTip2;
		self.lblRPdestPortT.bubbleHelp := toolTip2;
		self.lblRPdischPortT.bubbleHelp := toolTip2;
		self.lblRPimexT.bubbleHelp := toolTip2;
		self.lblRPopT.bubbleHelp := toolTip2;
		self.lblRPquantityT.bubbleHelp := toolTip2;
		self.lblRPvolumeT.bubbleHelp := toolTip2;
		self.lblRPweightT.bubbleHelp := toolTip2;
		self.lblRPlengthT.bubbleHelp := toolTip2;
		self.lblRPffT.bubbleHelp := toolTip2;	//Bug 38935
	endif;
	if self.lblRPBusUnitC.bubbleHelp &lt;&gt; toolTip1 then
		self.lblRPBusUnitC.bubbleHelp := toolTip1;
		self.lblRPcommC.bubbleHelp := toolTip1;
		self.lblRPconC.bubbleHelp := toolTip1;
		self.lblRPconorC.bubbleHelp := toolTip1;
		self.lblRPcontentsC.bubbleHelp := toolTip1;
		self.lblRPcustAgC.bubbleHelp := toolTip1;
		self.lblRPdestPortC.bubbleHelp := toolTip1;
		self.lblRPdischPortC.bubbleHelp := toolTip1;
		self.lblRPimexC.bubbleHelp := toolTip1;
		self.lblRPopC.bubbleHelp := toolTip1;
		self.lblRPquantityC.bubbleHelp := toolTip1;
		self.lblRPvolumeC.bubbleHelp := toolTip1;
		self.lblRPweightC.bubbleHelp := toolTip1;
		self.lblRPlengthC.bubbleHelp := toolTip1;
		self.lblRPffC.bubbleHelp := toolTip1;	//Bug 38935		
	endif;
	self.lblRPBusUnitT.caption := Blank;
	self.lblRPcommT.caption := Blank;
	self.lblRPconT.caption := Blank;
	self.lblRPconorT.caption := Blank;
	self.lblRPcontentsT.caption := Blank;
	self.lblRPcustAgT.caption := Blank;
	self.lblRPdestPortT.caption := Blank;
	self.lblRPdischPortT.caption := Blank;
	self.lblRPimexT.caption := Blank;
	self.lblRPopT.caption := Blank;
	self.lblRPquantityT.caption := Blank;
	self.lblRPvolumeT.caption := Blank;
	self.lblRPweightT.caption := Blank;
	self.lblRPlengthT.caption := Blank;
	self.lblRPffT.caption := Blank;		//Bug 38935	

	self.lblRPBusUnitC.caption := Blank;
	self.lblRPcommC.caption := Blank;
	self.lblRPconC.caption := Blank;
	self.lblRPconorC.caption := Blank;
	self.lblRPcontentsC.caption := Blank;
	self.lblRPcustAgC.caption := Blank;
	self.lblRPdestPortC.caption := Blank;
	self.lblRPdischPortC.caption := Blank;
	self.lblRPimexC.caption := Blank;
	self.lblRPopC.caption := Blank;
	self.lblRPquantityC.caption := Blank;
	self.lblRPvolumeC.caption := Blank;
	self.lblRPweightC.caption := Blank;
	self.lblRPlengthC.caption := Blank;
	self.lblRPffC.caption := Blank;		//Bug 38935	

	self.lblRPBusUnitT.foreColor := Grey;
	self.lblRPcommT.foreColor := Grey;
	self.lblRPconT.foreColor := Grey;
	self.lblRPconorT.foreColor := Grey;
	self.lblRPcontentsT.foreColor := Grey;
	self.lblRPcustAgT.foreColor := Grey;
	self.lblRPdestPortT.foreColor := Grey;
	self.lblRPdischPortT.foreColor := Grey;
	self.lblRPimexT.foreColor := Grey;
	self.lblRPopT.foreColor := Grey;
	self.lblRPquantityT.foreColor := Grey;
	self.lblRPvolumeT.foreColor := Grey;
	self.lblRPweightT.foreColor := Grey;
	self.lblRPlengthT.foreColor := Grey;
	self.lblRPffT.foreColor := Grey;		//Bug 38935
	
	packUnpackWarning := false;	//TFS41053
	
	create tiArray transient;
	foreach anObj in oa do
		txn := anObj.CM_TITransaction;
		ti := txn.myTrackedItem;
		if not tiArray.includes(ti) then
			tiArray.add(ti);
		endif;
		
		//If is a pack/unpack transaction on a container, a resync may not make sense //TFS41053
		if ti &lt;&gt; null and ti.isParent and ti.isKindOf(CM_Container) then
			if txn.isKindOf(CM_Pack) or txn.isKindOf(CM_Unpack) then
				packUnpackWarning := true;
			endif;
		endif;
		
		if self.lblRPBusUnitT.caption &lt;&gt; txn.companyCode and self.lblRPBusUnitT.caption &lt;&gt; Blank then
			self.lblRPBusUnitT.caption := Multi;
		elseif txn.companyCode &lt;&gt; null then
			self.lblRPBusUnitT.caption := txn.companyCode;
		endif;
		if self.lblRPcommT.caption &lt;&gt; txn.commodity and self.lblRPcommT.caption &lt;&gt; Blank then
			self.lblRPcommT.caption := Multi;
		elseif txn.commodity &lt;&gt; null then
			self.lblRPcommT.caption := txn.commodity;
		endif;
		if self.lblRPconT.caption &lt;&gt; txn.consignee and self.lblRPconT.caption &lt;&gt; Blank then
			self.lblRPconT.caption := Multi;
		elseif txn.consignee &lt;&gt; null then
			self.lblRPconT.caption := txn.consignee;
		endif;
		if self.lblRPconorT.caption &lt;&gt; txn.consignor and self.lblRPconorT.caption &lt;&gt; Blank then
			self.lblRPconorT.caption := Multi;
		elseif txn.consignor &lt;&gt; null then
			self.lblRPconorT.caption := txn.consignor;
		endif;
		if self.lblRPcontentsT.caption &lt;&gt; txn.getContentsStatusDesc(false) and self.lblRPcontentsT.caption &lt;&gt; Blank then
			self.lblRPcontentsT.caption := Multi;
		elseif txn.getContentsStatusDesc(false) &lt;&gt; null then
			self.lblRPcontentsT.caption := txn.getContentsStatusDesc(false);
		endif;
		if self.lblRPcustAgT.caption &lt;&gt; txn.customsAgentCode and self.lblRPcustAgT.caption &lt;&gt; Blank then
			self.lblRPcustAgT.caption := Multi;
		elseif txn.customsAgentCode &lt;&gt; null then
			self.lblRPcustAgT.caption := txn.customsAgentCode;
		endif;
		if self.lblRPdestPortT.caption &lt;&gt; txn.destinationPort and self.lblRPdestPortT.caption &lt;&gt; Blank then
			self.lblRPdestPortT.caption := Multi;
		elseif txn.destinationPort &lt;&gt; null then
			self.lblRPdestPortT.caption := txn.destinationPort;
		endif;
		if self.lblRPdischPortT.caption &lt;&gt; txn.dischargePort and self.lblRPdischPortT.caption &lt;&gt; Blank then
			self.lblRPdischPortT.caption := Multi;
		elseif txn.dischargePort &lt;&gt; null then
			self.lblRPdischPortT.caption := txn.dischargePort;
		endif;
		if self.lblRPimexT.caption &lt;&gt; txn.getImExStatusStringDesc(true) and self.lblRPimexT.caption &lt;&gt; Blank then
			self.lblRPimexT.caption := Multi;
		elseif txn.getImExStatusStringDesc(true) &lt;&gt; null then
			self.lblRPimexT.caption := txn.getImExStatusStringDesc(true);
		endif;
		if self.lblRPopT.caption &lt;&gt; txn.operatorCode and self.lblRPopT.caption &lt;&gt; Blank then
			self.lblRPopT.caption := Multi;
		elseif txn.operatorCode &lt;&gt; null then
			self.lblRPopT.caption := txn.operatorCode;
		endif;
		if self.lblRPffT.caption &lt;&gt; txn.freightForwarderCode and self.lblRPffT.caption &lt;&gt; Blank then	//Bug 38935
			self.lblRPffT.caption := Multi;																//Bug 38935
		elseif txn.freightForwarderCode &lt;&gt; null then													//Bug 38935
			self.lblRPffT.caption := txn.freightForwarderCode;											//Bug 38935
		endif;																							//Bug 38935
		
		if self.lblRPquantityT.caption &lt;&gt; txn.totalQuantity.String and self.lblRPquantityT.caption &lt;&gt; Blank then
			self.lblRPquantityT.caption := Multi;
		elseif txn.totalQuantity.String &lt;&gt; null then
			self.lblRPquantityT.caption := txn.totalQuantity.String;
		endif;
		
		// PAR 31615
		measureType := app.getDefaultMeasurementForType(Type_Volume);
		priorValue := txn.totalVolume;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		
		if self.lblRPvolumeT.caption &lt;&gt; displayValue and self.lblRPvolumeT.caption &lt;&gt; Blank then
			self.lblRPvolumeT.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPvolumeT.caption := displayValue; // PAR 31615
		endif;
		
		
		
		// PAR 31615
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		priorValue := txn.totalWeight;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		
		
		if self.lblRPweightT.caption &lt;&gt; displayValue and self.lblRPweightT.caption &lt;&gt; Blank then
			self.lblRPweightT.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPweightT.caption := displayValue;
		endif;

		
		// PAR 31615
		measureType := app.getDefaultMeasurementForType(Type_Length);
		priorValue := txn.totalLength;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		
		if self.lblRPlengthT.caption &lt;&gt; displayValue and self.lblRPlengthT.caption &lt;&gt; Blank then
			self.lblRPlengthT.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPlengthT.caption := displayValue;
		endif;
		
		
	endforeach;

	foreach anObj in tiArray do
		ti := anObj.CM_TrackedItem;	
		if self.lblRPBusUnitC.caption &lt;&gt; ti.companyCode and self.lblRPBusUnitC.caption &lt;&gt; Blank then
			self.lblRPBusUnitC.caption := Multi;
		elseif ti.companyCode &lt;&gt; null then
			self.lblRPBusUnitC.caption := ti.companyCode;
		endif;
		if self.lblRPBusUnitT.caption &lt;&gt; self.lblRPBusUnitC.caption then
			self.lblRPBusUnitT.foreColor := Red;
		endif;
		//self.lblRPcommC.caption := ti.commodity;
		if self.lblRPcommC.caption &lt;&gt; ti.commodity and self.lblRPcommC.caption &lt;&gt; Blank then
			self.lblRPcommC.caption := Multi;
		elseif ti.commodity &lt;&gt; null then
			self.lblRPcommC.caption := ti.commodity;
		endif;
		if self.lblRPcommT.caption &lt;&gt; self.lblRPcommC.caption then
			self.lblRPcommT.foreColor := Red; 
		endif;
		//self.lblRPconC.caption := ti.consignee;
		if self.lblRPconC.caption &lt;&gt; ti.consignee and self.lblRPconC.caption &lt;&gt; Blank then
			self.lblRPconC.caption := Multi;
		elseif ti.consignee &lt;&gt; null then
			self.lblRPconC.caption := ti.consignee;
		endif;
		if self.lblRPconT.caption &lt;&gt; self.lblRPconC.caption then
			self.lblRPconT.foreColor := Red; 
		endif;
		//self.lblRPconorC.caption := ti.consignor;
		if self.lblRPconorC.caption &lt;&gt; ti.consignor and self.lblRPconorC.caption &lt;&gt; Blank then
			self.lblRPconorC.caption := Multi;
		elseif ti.consignor &lt;&gt; null then
			self.lblRPconorC.caption := ti.consignor;
		endif;
		if self.lblRPconorT.caption &lt;&gt; self.lblRPconorC.caption then 
			self.lblRPconorT.foreColor := Red; 
		endif;
		//self.lblRPcontentsC.caption := ti.getContentsStatusDesc(false);
		if self.lblRPcontentsC.caption &lt;&gt; ti.getContentsStatusDesc(false) and self.lblRPcontentsC.caption &lt;&gt; Blank then
			self.lblRPcontentsC.caption := Multi;
		elseif ti.getContentsStatusDesc(false) &lt;&gt; null then
			self.lblRPcontentsC.caption := ti.getContentsStatusDesc(false);
		endif;
		if self.lblRPcontentsC.caption &lt;&gt; self.lblRPcontentsT.caption then
			self.lblRPcontentsT.foreColor := Red; 
		endif;
		//self.lblRPcustAgC.caption := ti.getMyCustomsAgentDesc(false);
		if self.lblRPcustAgC.caption &lt;&gt; ti.getMyCustomsAgentDesc(false) and self.lblRPcustAgC.caption &lt;&gt; Blank then
			self.lblRPcustAgC.caption := Multi;
		elseif ti.getMyCustomsAgentDesc(false) &lt;&gt; null then
			self.lblRPcustAgC.caption := ti.getMyCustomsAgentDesc(false);
		endif;
		if self.lblRPcustAgT.caption &lt;&gt; self.lblRPcustAgC.caption then
			self.lblRPcustAgT.foreColor := Red; 
		endif;
		//self.lblRPdestPortC.caption := ti.destinationPort;
		if self.lblRPdestPortC.caption &lt;&gt; ti.destinationPort and self.lblRPdestPortC.caption &lt;&gt; Blank then
			self.lblRPdestPortC.caption := Multi;
		elseif ti.destinationPort &lt;&gt; null then
			self.lblRPdestPortC.caption := ti.destinationPort;
		endif;
		if self.lblRPdestPortT.caption &lt;&gt; self.lblRPdestPortC.caption then
			self.lblRPdestPortT.foreColor := Red;
		endif;
		//self.lblRPdischPortC.caption := ti.dischargePort;
		if self.lblRPdischPortC.caption &lt;&gt; ti.dischargePort and self.lblRPdischPortC.caption &lt;&gt; Blank then
			self.lblRPdischPortC.caption := Multi;
		elseif ti.dischargePort &lt;&gt; null then
			self.lblRPdischPortC.caption := ti.dischargePort;
		endif;
		if self.lblRPdischPortT.caption &lt;&gt; self.lblRPdischPortC.caption then
			self.lblRPdischPortT.foreColor := Red; 
		endif;
		//self.lblRPimexC.caption := ti.getImExStatusStringDesc(true);
		if self.lblRPimexC.caption &lt;&gt; ti.getImExStatusStringDesc(true) and self.lblRPimexC.caption &lt;&gt; Blank then
			self.lblRPimexC.caption := Multi;
		elseif ti.getImExStatusStringDesc(true) &lt;&gt; null then
			self.lblRPimexC.caption := ti.getImExStatusStringDesc(true);
		endif;
		if self.lblRPimexT.caption &lt;&gt; self.lblRPimexC.caption then
			self.lblRPimexT.foreColor := Red; 
		endif;
		//self.lblRPopC.caption := ti.operatorCode;
		if self.lblRPopC.caption &lt;&gt; ti.operatorCode and self.lblRPopC.caption &lt;&gt; Blank then
			self.lblRPopC.caption := Multi;
		elseif ti.operatorCode &lt;&gt; null then
			self.lblRPopC.caption := ti.operatorCode;
		endif;
		if self.lblRPopT.caption &lt;&gt; self.lblRPopC.caption then
			self.lblRPopT.foreColor := Red; 
		endif;
		
		if self.lblRPffC.caption &lt;&gt; ti.freightForwarderCode and self.lblRPffC.caption &lt;&gt; Blank then	//Bug 38935
			self.lblRPffC.caption := Multi;															//Bug 38935
		elseif ti.freightForwarderCode &lt;&gt; null then													//Bug 38935
			self.lblRPffC.caption := ti.freightForwarderCode;										//Bug 38935
		endif;																						//Bug 38935
		if self.lblRPffT.caption &lt;&gt; self.lblRPffC.caption then										//Bug 38935
			self.lblRPffT.foreColor := Red; 														//Bug 38935
		endif;																						//Bug 38935
		
		//self.lblRPquantityC.caption := ti.totalQuantity.String;
		if self.lblRPquantityC.caption &lt;&gt; ti.totalQuantity.String and self.lblRPquantityC.caption &lt;&gt; Blank then
			self.lblRPquantityC.caption := Multi;
		elseif ti.totalQuantity.String &lt;&gt; null then
			self.lblRPquantityC.caption := ti.totalQuantity.String;
		endif;
 		if self.lblRPquantityT.caption &lt;&gt; self.lblRPquantityC.caption then
			self.lblRPquantityT.foreColor := Red; 
		endif;
		//self.lblRPvolumC.caption := ti.getMyTotalVolume.asStringJMTWithPrecision(3, false);
		
		
		// PAR 31615
		measureType := app.getDefaultMeasurementForType(Type_Volume);
		priorValue := ti.getMyTotalVolume;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;

		if self.lblRPvolumeC.caption &lt;&gt; displayValue and self.lblRPvolumeC.caption &lt;&gt; Blank then
			self.lblRPvolumeC.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPvolumeC.caption := displayValue; // PAE 31615
		endif;
		if self.lblRPvolumeT.caption &lt;&gt; self.lblRPvolumeC.caption then
			self.lblRPvolumeT.foreColor := Red; 
		endif;
//		self.lblRPweightC.caption := ti.totalWeight.asStringWeightJMT(); // AKB2010NOV


		// PAR 31615
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		priorValue := ti.totalWeight;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;

		if self.lblRPweightC.caption &lt;&gt; displayValue and self.lblRPweightC.caption &lt;&gt; Blank then
			self.lblRPweightC.caption := Multi;
		elseif displayValue.String &lt;&gt; null then
			self.lblRPweightC.caption := displayValue;
		endif;
		if self.lblRPweightT.caption &lt;&gt; self.lblRPweightC.caption then
			self.lblRPweightT.foreColor := Red; 
		endif;
		
		// PAR 31615
		measureType := app.getDefaultMeasurementForType(Type_Length);
		priorValue := ti.length;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		
		if self.lblRPlengthC.caption &lt;&gt; displayValue and self.lblRPlengthC.caption &lt;&gt; Blank then
			self.lblRPlengthC.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPlengthC.caption := displayValue;
		endif;
		if self.lblRPlengthT.caption &lt;&gt; self.lblRPlengthC.caption then
			self.lblRPlengthT.foreColor := Red; 
		endif;
		
		
	endforeach;

	self.chkRPLog.visible := true;
	//self.btnRPSelect.visible := false;  //27/01/2017 cnwma1 TFS # 3223
	
	self.frmResync.centreHorizontallyInParent();
	self.frmResync.zOrder(1);

	self.frmResync.visible := true;
	
	if packUnpackWarning then //TFS41053
		app.msgBox(app.getErrorString(WARN_pack_unpack_resync), app.getErrorString(Warning), MsgBox_Exclamation_Mark_Icon);
	endif;
	
epilog
	delete oa;
	delete tiArray;
	delete allChildControls;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showSearchCriteria" id="f8735b41-6f84-48ac-933d-d54e43ef0472">
        <updating/>
        <source>showSearchCriteria() updating, protected;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
/*

Date		Who		Reason
06 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
	
*/

vars
	str				: String;
	ts				: TimeStamp;
	
begin
	if self.mode = self.Mode_Cargo_Transaction_Enquiry then
		str := app.getErrorString(Cargo_Transactions);
	elseif self.mode = self.Mode_Event_Transaction_Enquiry then
		str := app.getErrorString(Event_Transactions);
	elseif self.mode = self.Mode_HMS_Transaction_Enquiry then
		str := app.getErrorString(HMS_Transactions);
	elseif self.mode = self.Mode_BOL_Transaction_Enquiry then	//04 Nov 2019	NDL	TFS 47100
		str := app.getErrorString(BOL_Transactions);
	endif;
	str := str &amp; ": " &amp; app.getErrorString(Date_range) &amp; ": ";
	if self.filterDateFrom = null then
		str := str &amp; app.getErrorString(None_Lowercase);
	else
		ts.setDate(self.filterDateFrom);
		ts.setTime(self.filterTimeFrom);
		str := str &amp; self.systemToLocalTime(ts).asStringJMT();
	endif;
	str := str &amp; " - ";
	if self.filterDateTo = null then
		str := str &amp; app.getErrorString(None_Lowercase);
	else
		ts.setDate(self.filterDateTo);
		ts.setTime(self.filterTimeTo);
		str := str &amp; self.systemToLocalTime(ts).asStringJMT();
	endif;
	if self.mode = self.Mode_Event_Transaction_Enquiry then
		str := str &amp; "  " &amp; app.getErrorString(Event_type) &amp; ": ";
		if self.filterEventType = null then
			str := str &amp; app.getErrorString(Any_LowerCase);
		else
			str := str &amp; self.filterEventType.name;
		endif;
	else
		str := str &amp; "  " &amp; app.getErrorString(Transaction_Type) &amp; ": ";
		if self.filterTransactionType = null then
			str := str &amp; app.getErrorString(Any_LowerCase);
		else
			str := str &amp; self.filterTransactionType.description;
		endif;
	endif;
	str := str &amp; "  " &amp; app.getErrorString(Voyage) &amp; ": ";
	if self.filterVoyage = null then
		str := str &amp; app.getErrorString(Any_LowerCase);
	else
		str := str &amp; self.filterVoyage.code;
	endif;
	str := str &amp; "  " &amp; app.getErrorString(User) &amp; ": ";
	if self.filterUser = null then
		str := str &amp; app.getErrorString(Any_LowerCase);
	else
		str := str &amp; self.filterUser.code;
	endif;
	// if Transaction Enquiry Invoice Details permission is set, show the additional search options
	if app.myCurrentUserCan(self.myTerminal, PmTransEnquiryInvoiceDtls) then
		str := str &amp; CrLf &amp; app.getErrorString(CM_Business_Unit) &amp; ": ";
		if self.filterBusinessUnit = null then
			str := str &amp; app.getErrorString(Any_LowerCase);
		else
			str := str &amp; self.filterBusinessUnit.getDisplayDetails(false);
		endif;
		str := str &amp; "  " &amp; app.getErrorString(INV_Debtor) &amp; ": ";
		if self.filterDebtor = null then
			str := str &amp; app.getErrorString(Any_LowerCase);
		else
			str := str &amp; self.filterDebtor.name;
		endif;
		str := str &amp; "  " &amp; app.getErrorString(CM_Invoice_Number) &amp; ": ";
		if self.filterInvoiceNumber = 0 then
			str := str &amp; app.getErrorString(Any_LowerCase);
		else
			str := str &amp; self.filterInvoiceNumber.String;
		endif;
		str := str &amp; "  " &amp; app.getErrorString(Charged) &amp; ": ";
		if self.filterCharged = 0 then
			str := str &amp; app.getErrorString(CM_LIT_ALL);
		elseif self.filterCharged = Is_Charged then
			str := str &amp; app.getErrorString(Yes);
		elseif self.filterCharged = Not_Charged then
			str := str &amp; app.getErrorString(No);
		endif;
	endif;
	
	if self.allColumnFilters &lt;&gt; null and self.allColumnFilters.includesFiltersFor( self.tblTransactions ) then
		str := str &amp; "                         ** Additional Column Organiser filtering applied!";
	endif;
	
	if self.numItemsShown &gt;= JadeTableRowLimit then
		str := str &amp; "  ** " &amp; app.getErrorString1( Unable_To_Display_More_Rows, JadeTableRowLimit.display) &amp; " **";
	elseif self.searchCancelled then
		str := str &amp; "  " &amp; app.getErrorString(TransSearchCancelled);
	endif;
	
	self.lblSearchCrit.caption := str;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTemperatures" id="96ccd3b2-ce70-4ad3-953b-b726e0149084">
        <source>showTemperatures() protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Reefer properties now on separate class, other cargo can be reefer
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
// ---------------------------------------------------------------------------

vars
	tr				: CM_TempReading; //CM_DailyReeferTemp;
	lDetails		: String;
	idx				: Integer;
	refconDetail	: String;
	userStr,
	typeStr			: String;
	tempReadings	: CM_TempReadingByDateTimeDict;
begin
	// CCMS 1007 other cargo can be reefers
	if not self.myTrackedItem.isKindOf(CM_Container) and not (self.myTrackedItem.isReefer) then		// PAR #22938
		return; //error only container have a temp
	endif;
	
	tblTemperatures.rows := 0;	//Par 19006 Mar 2009
	
	// Make it look pretty
	tblTemperatures.columns := 4;
	tblTemperatures.addItemAt(app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(Reading) &amp; Tab &amp; app.getErrorString(User) &amp; Tab &amp; app.getErrorString(Detail), 1);
	tblTemperatures.fixedRows := 1;
	self.setColorsForTable(self.tblTemperatures);	
	
	tempReadings := self.myTrackedItem.getAllTemperatureReadings;					// PAR #23150
	if tempReadings &lt;&gt; null then													// PAR #23150
		foreach tr in tempReadings do		//temperatureLog do		// CCMS 1007	// PAR #23150
			// Get Details - returns a TAB delimited string ready for the enquiry table
			lDetails := tr.dateTime.shortCurrentLocaleFormat &amp; Tab;
	
			lDetails := lDetails &amp; tr.getAltDisplayTemp(false) &amp; Tab;
			
			if tr.userId.trimBlanks = "" and tr.myTemperatureReading &lt;&gt; null then
				userStr := tr.myTemperatureReading.userId;
			else
				userStr := tr.userId;
			endif;
			
			if tr.isKindOf(CM_PackTempReading) then
				typeStr := "Pack temperature reading";
			else
				typeStr := "Temperature reading";
			endif;
			
			lDetails := lDetails &amp; userStr &amp; Tab &amp; typeStr;
			
			// Add the row to the sheet
			idx := tblTemperatures.addItem(lDetails);
			if (idx mod 2 = 0) then
				tblTemperatures.accessRow(idx).backColor := self.colorRow1;
			else
				tblTemperatures.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTransactionCharges" id="44151200-1509-43c9-9380-caf640218108">
        <source>showTransactionCharges(_trans : CM_Transaction) protected;
// Feb 2012 CCMS 1262 Transaction Enquiry show invoice lines for selected transaction
// 12/07/2017	cnwma1	TFS #4702:JMT - Invoice Line Date/Time not being displayed in local timezone
//		added invoice number and void status
vars
	invLineDict	: CM_InvoiceLineByDateTimeDict;
	il : CM_InvoiceLine;
	lDetails : String;
	idx	: Integer;
begin
	if not app.myCurrentUserCan(self.myTerminal, PmTransEnquiryInvoiceDtls) then
		return;
	endif;

	if _trans.isKindOf(CM_EventTransaction) then
		invLineDict := _trans.CM_EventTransaction.allInvoiceLines;
	elseif _trans.isKindOf(CM_TITransaction) then
		invLineDict := _trans.CM_TITransaction.allInvoiceLines;
	elseif _trans.isKindOf(HMS_VTMISTransaction) then
		invLineDict := _trans.HMS_VTMISTransaction.allInvoiceLines;
	elseif _trans.isKindOf(CM_WOTransaction) then  // TFS 39236
		invLineDict := _trans.CM_WOTransaction.allInvoiceLines;  // TFS 39236
	elseif _trans.isKindOf(CM_BOLTransaction) then  // 28 Nov 2019	NDL	TFS 47727
		invLineDict := _trans.CM_BOLTransaction.allInvoiceLines; 
	else
		return;
	endif;

	tblCharges.rows := 0;
	tblCharges.columns := 8;
	
	tblCharges.addItemAt(app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(INV_Invoice) &amp; Tab &amp; app.getErrorString(Invoice_line) &amp; Tab
				&amp; app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(Manual) &amp; Tab &amp; app.getErrorString(Qty) &amp; Tab &amp; app.getErrorString(CM_Narration) &amp; Tab &amp; app.getErrorString(Void), 1);
	tblCharges.fixedRows := 1;
	self.setColorsForTable(self.tblCharges);			
	tblCharges.accessColumn(1);
	tblCharges.sortColumn[1] := 1;
	tblCharges.sortAsc[1] := true;

	foreach il in invLineDict do
		//lDetails := il.getChargeTime.shortCurrentLocaleFormat &amp; Tab &amp; il.invoice.sequenceNum.String &amp; Tab &amp; il.sequenceNum.String &amp; Tab &amp; il.debtor.name        //12.7.2017 cnwma1 TFS #4702
		lDetails := il.getChargeTimeLocalTZ.shortCurrentLocaleFormat &amp; Tab &amp; il.invoice.sequenceNum.String &amp; Tab &amp; il.sequenceNum.String &amp; Tab &amp; il.debtor.name   //12.7.2017 cnwma1 TFS #4702
					&amp; Tab &amp; il.manual.String &amp; Tab &amp; il.quantity.String &amp; Tab &amp; il.invoiceLineDesc.narration &amp; Tab &amp; il.voided.getYes();
		idx := tblCharges.addItemObject(il, lDetails);

		if (idx mod 2 = 0) then
			tblCharges.accessRow(idx).backColor := self.colorRow1;
		else
			tblCharges.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_trans" type="CM_Transaction"/>
    </JadeMethod>
    <JadeMethod name="showTransactions" id="ea075a19-7514-413b-ae79-a55f34570bef">
        <source>showTransactions() protected;
// ---------------------------------------------------------------------------
// Created:   May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/05/2010		cnwdap1			CCMS 1116 Tranship changes
// 08 Jun 2010	NDL	Par 23498	- convert to populate via entable def
// ---------------------------------------------------------------------------

vars
	tr 		: CM_TITransaction;
	i 		: Integer;
	tmpTi, tmpTSti	: CM_TrackedItem;
	tship : Boolean;
	tmpStr, tmpCode1, tmpCode2	: String;
	tmpUser : CM_User;
	sortIndex : Integer;	//08 Jun 2010	NDL	Par 23498
begin
	
	tmpUser := app.getMyUser();
	
	// clear sort fields prior to load. ( populating adds keys for sections, so that we can sort within the sections of the table)
	tblTrans.sortColumn[1] := 0;
	tblTrans.sortColumn[2] := 0;
		
	self.setColorsForTable(self.tblTrans);	
	// populate the sheet

	sortIndex := sortIndex + 1;	//08 Jun 2010	NDL	Par 23498
	self.addDetailsForTI(sortIndex, self.myTrackedItem);	//08 Jun 2010	NDL	Par 23498

	global.getExtraData(self.myTrackedItem.allExtraData, TranshipImport, tmpTSti);
	if tmpTSti &lt;&gt; null then
		tmpStr := '&lt; ' &amp; self.myTrackedItem.id &amp; ' was a tranship, these are the Import Tranship Transactions that occured &gt;';
		sortIndex := sortIndex + 1;	//08 Jun 2010	NDL	Par 23498
		self.showTransactionsNote(sortIndex, tmpStr);	//08 Jun 2010	NDL	Par 23498
		sortIndex := sortIndex + 1;	//08 Jun 2010	NDL	Par 23498
		self.addDetailsForTI(sortIndex, tmpTSti);	//08 Jun 2010	NDL	Par 23498
	endif;
	
	tmpTi := self.myTrackedItem;
	while true do
		tmpTi := tmpTi.myMoveCloneFromTI;
		if tmpTi = null then
			break;
		endif;
		if tmpTi.myTerminal = null or tmpUser.canDo(tmpTi.myTerminal, self.permissionView) then
			tmpStr := '&lt; Transactions that occured at terminal ' &amp; tmpTi.myTerminal.name &amp; ' &gt;';
			sortIndex := sortIndex + 1;	//08 Jun 2010	NDL	Par 23498
			self.showTransactionsNote(sortIndex, tmpStr);	//08 Jun 2010	NDL	Par 23498

			sortIndex := sortIndex + 1;	//08 Jun 2010	NDL	Par 23498
			self.addDetailsForTI(sortIndex, tmpTi);	//08 Jun 2010	NDL	Par 23498
		else
			tmpStr := '&lt; Transactions that occured at terminal ' &amp; tmpTi.myTerminal.name &amp; ' are not visible &gt;';
			sortIndex := sortIndex + 1;	//08 Jun 2010	NDL	Par 23498
			i := tblTrans.addItem(sortIndex.String &amp; Tab &amp; " " &amp; Tab &amp; tmpStr);	//08 Jun 2010	NDL	Par 23498
			tblTrans.setCellText(i, 2, i.String.padLeadingZeros(3));	//08 Jun 2010	NDL	Par 23498
			tblTrans.accessRow(i).backColor := Blue;
		endif;
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTransactionsNote" id="dd1b55a0-5152-4028-92ab-366b6b24d241">
        <source>showTransactionsNote(_sortIndex : Integer; tmpStr : String);
// ---------------------------------------------------------------------------
// Created:		04 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	i : Integer;
begin
	i := tblTrans.addItem(_sortIndex.String &amp; Tab &amp; " " &amp; Tab &amp; tmpStr);	//08 Jun 2010	NDL	Par 23498
	tblTrans.setCellText(i, 2, i.String);	//08 Jun 2010	NDL	Par 23498
	tblTrans.accessCell(i, 3).mergeCells := Table.MergeCells_Merge;
	tblTrans.accessCell(i, 3).backColor := LightBlue;

end;</source>
        <Parameter name="_sortIndex" type="Integer"/>
        <Parameter name="tmpStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="showTxnMaint" id="0b93a300-bed8-4399-b21f-7d7cf9edf048">
        <updating/>
        <source>showTxnMaint(_doUpdate : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//18/01/2023	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

vars
	transMaintForm			: CMUI_TITransMaintModal;
	txn						: CM_TITransaction;
	multiEditForm : CMUI_TIMultiTransMaint;
	allSelectedObjects : ObjectArray;
begin
	
	// CCMS 1262 transaction enquiry, no add in enquiry mode,
	//   no edit for event or HMS transactions
	if not _doUpdate and
	   self.mode &lt;&gt; self.Mode_CargoItem_Enquiry then
		return;
	endif;
	if self.mode = self.Mode_Event_Transaction_Enquiry or
		self.mode = self.Mode_BOL_Transaction_Enquiry or	//04 Nov 2019	NDL	TFS 47100
		self.mode = self.Mode_HMS_Transaction_Enquiry or 
		self.mode = self.Mode_WO_Transaction_Enquiry then 	//18.01.2023 navcs2 #56633:[56211] 
		return;
	endif;
	
	//21 Mar 2014	NDL	Par 27441
	//epr par 37116 21/1/16
	if self.mode = self.Mode_CargoItem_Enquiry then
		allSelectedObjects:=self.tblTrans.allSelectedObjects;
	else
		allSelectedObjects:=self.tblTransactions.allSelectedObjects;
	endif;
	
	txn := allSelectedObjects.first.CM_TITransaction;
	
	if _doUpdate then
		if txn = null then
			app.msgBox(app.getErrorString(Please_select_txn),app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;	
		if txn.myTrackedItem &lt;&gt; null and
		   txn.myTrackedItem.myTerminal &lt;&gt; self.myTerminal then
			app.msgBox(app.getErrorString(Cant_edit_txn_terminal),app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;
		elseif (not txn.canUpdateTransaction) then
			app.msgBox(app.getErrorString1(Cant_edit_type_txn, ' "' &amp; txn.typeString &amp; '"'), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;		
		elseif txn.superseded then //epr TFS 2996 8/12/16
			app.msgBox(app.getErrorString(Cannot_edit_transac_audit), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;				
		elseif txn.deleted then
			app.msgBox(app.getErrorString(Cant_edit_deleted_txn)  , app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;			
		endif;
		
		if allSelectedObjects.size &gt; 1 and self.canMultiEdit()  then	
		
			multiEditForm := app.loadForm(CMUI_TIMultiTransMaint, 
									CMUI_Assistant, 
									false, 
									false,
									false, 
									self.myTerminal,
									null).CMUI_TIMultiTransMaint;
			if multiEditForm = null then
				return;
			endif;
			
			multiEditForm.setAllTransactions( allSelectedObjects );
			multiEditForm.caption := self.caption;
			multiEditForm.isForCargoEdit := false;
			multiEditForm.show;
	
			return;
		endif; 
		
	endif;
	
	
	transMaintForm := app.loadForm(CMUI_TITransMaintModal, 
								CMUI_Assistant, 
								false, 
								false,
								false, 
								self.myTerminal,
								null).CMUI_TITransMaintModal;

	if transMaintForm = null then
		return;
	endif;
		
	if _doUpdate then
		transMaintForm.myCurrentTransaction := txn;
	else
		if txn	&lt;&gt; null then
			transMaintForm.myCurrentTransactionType := txn.type;	
		endif;
	endif;
	
	transMaintForm.editModeOnly := true;
	transMaintForm.caption := self.caption;
	transMaintForm.isForCargoEdit := false;
	if txn &lt;&gt; null then
		// as we now sometimes show txns for related tracked items 
		// (e.g. transships) set currentTrackedItem to be the
		// one on the txn.  Otherwise save will change txn.myTrackedItem!
		transMaintForm.myCurrentTrackedItem := txn.myTrackedItem;
	else
		transMaintForm.myCurrentTrackedItem := self.myTrackedItem;
	endif;
	
	transMaintForm.showModal;

	if self.mode = self.Mode_CargoItem_Enquiry then
		self.initTblTrans();
		self.showTransactions();
	endif;

epilog
	delete transMaintForm;
	
end;</source>
        <access>protected</access>
        <Parameter name="_doUpdate" type="Boolean"/>
    </JadeMethod>
