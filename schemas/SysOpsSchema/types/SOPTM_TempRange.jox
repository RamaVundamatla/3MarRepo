    <JadeMethod name="doSave" id="ba824cda-cdec-4644-88b2-fd1e12841cd9">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	proxyTempRange:CM_TempRange;
	lColour:Integer;
	lValue,lLower,lUpper : Real;
	theForm : SOP_TableMaintForm;
begin
  theForm := self.myForm; 


	lValue := theForm.tblInput1.getValueByName(ETRow_Value).String.asRealJMT;	//27 Apr 2017	NDL	TFS 4054
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
    lUpper := theForm.tblInput1.getValueByName(ETRow_Upper).String.asRealJMT;	//27 Apr 2017	NDL	TFS 4054
    lLower := theForm.tblInput1.getValueByName(ETRow_Lower).String.asRealJMT;	//27 Apr 2017	NDL	TFS 4054
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_TempRange transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyTempRange := theForm.myProxyObject.CM_TempRange;
	proxyTempRange.setProxy(lValue, lColour,lUpper,lLower);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateTempRange(proxyTempRange, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateTempRange(proxyTempRange, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return rtnValue;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
