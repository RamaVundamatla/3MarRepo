    <JadeMethod name="utlUpdYardActivityActionTime" id="3e618ad2-2ecb-4841-b19a-72903719bba0">
        <updating/>
        <source>utlUpdYardActivityActionTime(	_real : CM_YardActivity input;
								_newActionTime : TimeStamp;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars
	ti : CM_TrackedItem;
	information : StringArray512;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	exclusiveLock(_real);
	_real.setActionTime( _newActionTime );
	
	 // ### TFS 51300 01JUL2021 NAVAB1
	ti := _real.myTrackedItem;
	if ti &lt;&gt; null then
		create information transient;
		information.addTruncated(_real.getTypeString() &amp; " UPDATED");
		information.addTruncated("Time changed to " &amp; _newActionTime.asStringJMT());
		ti.createInfomationTransaction(_real.getTypeString() &amp; " Job UPDATED" , information, null, app.myPassport);
	endif;

epilog

end;</source>
        <Parameter name="_real" type="CM_YardActivity" usage="input"/>
        <Parameter name="_newActionTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
