    <JadeMethod name="setProxyFromObject" id="d9b0f2cc-d591-4046-ba8f-3fe21379f313">
        <updating/>
        <source>setProxyFromObject(_object: CM_CargoType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
22/07/2016  cnwma1  TFS #1979  - JMT Mobile Apps - Cargo - Damage
05/09/2016  cnwrh7  TFS2437    Add VGM details to Weight data entry for Mobile Web apps
10/10/2019  cnwma1	Bug 46793: Web Portal - Prenotes for non container cargo that has a commodity that requires temperature does not show reefer section
15/08/2022	navma1	ChangeRequest 54219: EUP - Cargo Group to be mandatory
*/

vars

begin
	inheritMethod(_object);
	
	self.id 		 		  := _object.id;
	self.description 		  := _object.description;
	self.measureType          := _object.trackByMeasureType;
	self.isDefault            := app.getMyTerminalDO_NOT_USE().defaultCargoType = _object.id;
	self.allowDuplicates      := _object.allowDuplicates;
	self.showDamageCodes      := _object.showDamageCodes and _object.allDamageDefinitionCodes.size &gt; 0; // cnwma1 22/07/2016 TFS 1979
	self.canWeightBeCertified := _object.canWeightBeCertified;	  //+TFS2437   
	self.isCommodityRequired  := _object.isCommodityRequired;     //epr TFS7402 16/10/17 new development for webportal
	self.hasProductTypes      := _object.hasProductTypes;         //01/05/2018 cnwma1 TFS# 37957: WP - Release Requests - Edit a Release Request
	self.showCargoTareWeight  := _object.useTareCargoWeight;      //epr TFS7401 14/11/17 new development for webportal
	self.isReefer             := _object.isReefer();              //10.10.2019 cnwma1 #46793
	self.trackAs     		  := _object.productType;	 
	self.isCargoGroupRequired := _object.isCargoGroupRequired;	 //15.08.2022 navma1 #54219	
	if self.trackAs = ProductType_PieceBreakBulk then
		self.trackAs := ProductType_BreakBulk;
	endif;
		
	//epr TFS 37541 13/3/18
	if _object.isBulkByWeight then
		if _object.myWeightMeasurementType &lt;&gt; null then
			self.defaultWeightMeasurement := _object.myWeightMeasurementType.shortName;
		endif;
	elseif _object.isBulkByVolume then		
		if _object.myVolumeMeasurementType &lt;&gt; null then
			self.defaultVolumeMeasurement := _object.myVolumeMeasurementType.shortName;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_CargoType"/>
    </JadeMethod>
</Class>
