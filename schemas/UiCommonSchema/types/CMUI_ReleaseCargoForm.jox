    <JadeMethod name="checkCargoAvailability" id="4aebf319-4d98-495d-b34f-981a3e5d3eea">
        <source>checkCargoAvailability(_trackedItems : CM_TISet io) : Collection;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
18 Mar 2019	jlgdi1	41721 	Initial creation
26 Aug 2019 jlgdi1	46271 	Added the following criteria to improve query performance {Terminal, Site/State, Imex Status, not Child, Available}
*/
	
vars
	queryBuilderAgent : CM_QueryBuilderAgent;
	object : Object;
	validImexStatuses : IntegerArray;
	
begin
	create queryBuilderAgent transient;	
	
	queryBuilderAgent.setResultArray(_trackedItems);
	queryBuilderAgent.setQueryMode(self.myCargoType);
		
	// 46271 &gt;&gt; start
	// Terminal = this terminal
	queryBuilderAgent.addCriteria(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
	
	// Site / State = On Site
	queryBuilderAgent.addCriteria(CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NORMAL);
		
	// Imex Status = {Import, Storage}
	create validImexStatuses transient;
	validImexStatuses.add(TI_IMEX_STATUS_IMPORT);
	validImexStatuses.add(TI_IMEX_STATUS_STORAGE);
	queryBuilderAgent.addCriteria(CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_IsOneOf, validImexStatuses);
	
	// NOT isChild
	queryBuilderAgent.addCriteria(CM_TrackedItem::isChild.name, CM_QueryOperator.Operator_Equal, null);
	
	// Available = yes
	queryBuilderAgent.addCriteria(CM_TrackedItem::isAvailable.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);
	// 46271 &lt;&lt; end	
	
	// Operator
	object := self.cmbOperatorCode.listObject;	
	if object &lt;&gt; null then 
		queryBuilderAgent.addCriteria(CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, object.CM_Operator);
	endif;
			
	// Cargo Type
	object := self.cmbTiType.getObject();
	if object &lt;&gt; null then 
		queryBuilderAgent.addCriteria(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, object.CM_CargoType);
	endif;
		
	// Cargo Sub Type
	object := self.cmbSubCargo.getObject();
	if object &lt;&gt; null then 
		queryBuilderAgent.addCriteria(CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, object.CM_Product);
	endif;
	
	if queryBuilderAgent.query &lt;&gt; null then 
		queryBuilderAgent.doQuery();
	endif;
	
	return queryBuilderAgent.allObjects;
	
epilog
	delete validImexStatuses;
	delete queryBuilderAgent;
end;</source>
        <Parameter name="_trackedItems" type="CM_TISet" usage="io"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="chkAnyIdChanged" id="6e723bc3-4efa-4962-b0fa-c939b3e7dfea">
        <updating/>
        <source>chkAnyIdChanged() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2014	cnwndl1	Initial creation	Par 34675
02 Apr 2019	jlgdi1	TFS# 41721 Change the visibility of btnCargoAvailCheck
25 Apr 2024 navhn30 ChangeRequest 62403: TPT | Cargo Group Release by Type (Any ID) - Default Screen Display
*/

begin
	
	if self.chkAnyId.getBoolean then
		self.switchToReleaseByIdMulti();
		//self.switchToReleaseFull();			//25.04.24	navhn30	TFS #62403
	else
		self.chkAnyAmount.isHidden:= true;	//21 Mar 2017	NDL	TFS 3813
		self.chkAnyAmount.setValue(false);	//21 Mar 2017	NDL	TFS 3813
		self.switchToReleaseFull();
		self.setFieldsFromBulkRelease();
	endif;
	
	self.btnCargoAvailCheck.visible := false;
	self.setByTypeByWeight();			//14.Dec.2023 navsp1 TFS 61547
	
end;</source>
    </JadeMethod>
