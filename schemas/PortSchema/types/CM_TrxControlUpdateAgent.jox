    <JadeMethod name="trxUpdateLRReasonCode" id="53b807b7-e5db-4b7f-85b2-8f72239026f0">
        <updating/>
        <source>trxUpdateLRReasonCode(_proxyLabourRestrictReasonCode : CM_LabourRestrictionReasonCode; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 May 2005 by cnhjg1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	realLabourRestrictReasonCode : CM_LabourRestrictionReasonCode;
	expectedEdition:Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	_proxyLabourRestrictReasonCode.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyLabourRestrictReasonCode.pxyGetRealObjectAndEdition(realLabourRestrictReasonCode, expectedEdition);
	
	if realLabourRestrictReasonCode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LoggingOrganisation.name, null, null);
		return;
	endif;

	self.raiseExceptionIfNull(_proxyLabourRestrictReasonCode, 'Labour Restriction Reason Code Proxy');
	self.raiseExceptionIfNull(realLabourRestrictReasonCode, "Labour Restriction Reason Code Existing");
	_proxyLabourRestrictReasonCode.raiseExceptionIfNotProxy(method);
	if realLabourRestrictReasonCode.description = _proxyLabourRestrictReasonCode.description then
		_proxyLabourRestrictReasonCode.validateForUpdate();
	else
		_proxyLabourRestrictReasonCode.validateForCreate();
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realLabourRestrictReasonCode);

	if _passport.noErrors and realLabourRestrictReasonCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Labour Restriction Reason Code', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realLabourRestrictReasonCode, true);
	endif;
	
	if _passport.noErrors then
		realLabourRestrictReasonCode.setForUpdate(_proxyLabourRestrictReasonCode);
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realLabourRestrictReasonCode, false);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyLabourRestrictReasonCode" type="CM_LabourRestrictionReasonCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
