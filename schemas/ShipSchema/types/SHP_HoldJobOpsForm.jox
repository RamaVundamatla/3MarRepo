    <JadeMethod name="btnPrint_click" id="07c464ec-fde3-4155-8aff-d0c107da60ae">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrint_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	workPoint : IF_VoyageWorkPoint;

begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		
		
	if self.cmbWorkPoint.listObject &lt;&gt; null then
		workPoint := self.cmbWorkPoint.listObject.CM_WorkPoint.IF_VoyageWorkPoint;
	endif;
	
	myAssistant.SHP_Assistant.showOrderOfWorkPrint(	self,
													self.myMasterMenuAction, 
													self.myTerminal,
													self.myCurrentVoyage,
													1,
													workPoint);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRefresh_click" id="fe84e2f3-f6e7-42b6-8aea-8f491b9fa2b3">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRefresh_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
