    <JadeMethod name="canDoForRoot" id="c8e3860d-c40a-4961-aa2f-514ee4d7c55e">
        <source>canDoForRoot(_menuRoot: CM_MenuRoot): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 December 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpValue	: Integer;
	isLicensed	: Boolean;
begin

	/*
	if self.childValue &gt; 0 and
	   (not _menuRoot.canDo(self.childValue, null)) then
		// this option is not licensed
		return false;
	endif;
	*/

	isLicensed := true;
	foreach tmpValue in self.allChildValues do
		// only really need to do this first time but ...
		isLicensed := false;
		if _menuRoot.canDo(tmpValue, null) then
			isLicensed := true;
			break;
		endif;
	endforeach;
	
	if (not isLicensed) then
		return false;
	endif;

	return _menuRoot.canDo(self.constantValue, null);

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserDo" id="4335c520-a096-4602-98a3-24c54fe69a86">
        <source>canUserDo(_user: CM_User; _terminal: CM_Terminal; _permValue: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     12 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnValue	: Boolean;
	isLicensed	: Boolean;
	tmpValue	: Integer;
begin

	rtnValue := _user.canDo(_terminal, _permValue);

	if rtnValue and (not self.allChildValues.isEmpty) then
		//rtnValue := _user.canDo(_terminal, self.childValue);

		isLicensed := false;
		foreach tmpValue in self.allChildValues do
			if _user.canDo(_terminal, tmpValue) then
				isLicensed := true;
				break;
			endif;
		endforeach;
		
		if (not isLicensed) then
			return false;
		endif;

	endif;
	
	return rtnValue;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_permValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
