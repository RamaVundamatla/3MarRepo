    <JadeMethod name="getTITransactionType" id="ae0c765a-351f-4b6d-ba46-9a690674de56">
        <source>getTITransactionType(_toDoTaskDesc : CM_ToDoTaskDesc): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Aug 2018	jlgab1	Initial creation
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	todoTaskDesc : CM_ToDoTaskDesc;
begin

	//todoTaskDesc := self.myToDoTaskDesc;							//06.03.2023 navma1 #56457:[56458]	//15.3.2023 navhl20	#56614[56615]
	todoTaskDesc := _toDoTaskDesc;																	 	//15.3.2023 navhl20	#56614[56615]
	
	if todoTaskDesc&lt;&gt; null then
		if todoTaskDesc.trxTypeOnCreation &lt;&gt; 0 then
			return todoTaskDesc.trxTypeOnCreation;
		else
			return todoTaskDesc.trxTypeOnCompletion;
		endif;
	endif;
	
	//return inheritMethod();																			//15.3.2023 navhl20	#56614[56615]
	return inheritMethod(_toDoTaskDesc);																//15.3.2023 navhl20	#56614[56615]

epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
