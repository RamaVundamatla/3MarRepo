    </JadeMethod>
    <JadeMethod name="deleteAllThresholds" id="b9d2c2c4-37e8-4b0e-8345-d726dd95b592">
        <source>deleteAllThresholds( _term : CM_Terminal ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	allMTThresholds : CM_MTThresholdDict;

begin

	create allMTThresholds transient;
	
	if not self.getTerminal.allMTThresholds.isEmpty then
		self.getTerminal.allMTThresholds.copy( allMTThresholds );
	endif;

epilog

	if not allMTThresholds.isEmpty then
		beginTransaction;
		allMTThresholds.purge();
		commitTransaction;
	endif;
	
	delete allMTThresholds;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="deleteToDoTasks" id="51ea01ff-414f-4b76-956a-7b85a2edb052">
        <source>deleteToDoTasks( _taskDesc : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	toDoDesc : CM_ToDoTaskDesc;
	toDoDescToDel : CM_ToDoTaskDesc;

begin

	toDoDescToDel := null;
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions do
		if toDoDesc.description &lt;&gt; _taskDesc then
			continue;
		endif;
		toDoDescToDel := toDoDesc;
		break;
	endforeach;
	
	if toDoDescToDel &lt;&gt; null then
	//	beginTransaction;
	//	delete toDoDescToDel;
	//	commitTransaction;
		self.deleteToDoTaskDescription(toDoDescToDel);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_taskDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextPriorityNumber" id="709ad7ec-14b9-4767-bfc9-8884532c0473">
        <source>getNextPriorityNumber() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
17 Sep 2019	jlgdi1	46124	Initial creation
*/

vars
	allMTThresholds : CM_MTThresholdDict;
	mtThreshold : CM_MTThreshold;
	priority : Integer;
	
begin
	create allMTThresholds transient;
	if not self.getTerminal.allMTThresholds.isEmpty then
		self.getTerminal.allMTThresholds.copy( allMTThresholds );
	endif;

	foreach mtThreshold in allMTThresholds do
		if mtThreshold.processingPriority &gt; priority then 
			priority := mtThreshold.processingPriority;
		endif;
	endforeach;
	
	return priority + 1;
	
epilog
	delete allMTThresholds;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeTIEmpty" id="447ccffe-dfa2-48bf-b150-e11fb3770bed">
        <source>makeTIEmpty(_container : CM_Container io);
/*

Purpose: Configure TI as empty container

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 September 2019	jlgdi1			Initial creation
*/

vars
	contentStatus : CM_ContentsStatus;
	
begin

	beginTransaction;
	_container.setContentsStatus(TI_CONTENTS_STATUS_EMPTY);
	commitTransaction;
end;</source>
        <Parameter name="_container" type="CM_Container" usage="io"/>
    </JadeMethod>
    <JadeMethod name="makeTIPreNoted" id="0275ba78-a0ee-4ec6-9c15-d273a5d94f1d">
        <source>makeTIPreNoted(_ti : CM_TrackedItem io; _transMode : Integer);
/*

Purpose: Set TI as pre notified

Parameters:			

Return Value:		

Date		Who		TFS		Reason
17 Sep 2019	jlgdi1	46124	Initial creation
*/

begin
	beginTransaction;
	_ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
	_ti.setReceiptTransportMode(_transMode);
	commitTransaction;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_transMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupAgentBGPmode" id="e78dee0a-f7c1-4537-9cb5-c481d56280b0">
        <source>setupAgentBGPmode(	_term : CM_Terminal;
					_agent : CM_MTThresholdAgent output;
					_allBreachLines : CM_MTPoolingEnquiryLineDict output
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731
12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
05 Sep 2019	jlgdi1	46124	Pass in null value in the _agent.processEmpties mthod
*/

vars
	ts : TimeStamp;

begin
	create _agent transient;
	
	_agent.clear();
	_agent.setBaseData(	_term,	//_terminal : CM_Terminal;	
						null,	//_operator : CM_Operator;
						null,	//_isoGroup : CM_ISOTypeGroup;
						null,	//_grade : CM_MTGrade;
						null,	//_receivalDate : Date;
						null	//_releaseDate : Date
						);
									
	_agent.processEmpties(null);
	
	ts := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	//clear the last notifieds on thresholds whose last notified value is expired.	
	_agent.clearAllExpiredLastNotified( ts );
	
	//Get current lines that have breaches.
	create _allBreachLines transient;
	_agent.getAllBreachedPoolingEnqLines( _allBreachLines );
	
	//Find all thresholds that have a last notified value (these will be current), and clear any that are no longer included in the breaches.
	// I.e. the ones that someone has remedied within the re-notify time.
	_agent.clearLastNotifiedOnNonBreached( _allBreachLines );
end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_agent" type="CM_MTThresholdAgent" usage="output"/>
        <Parameter name="_allBreachLines" type="CM_MTPoolingEnquiryLineDict" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupAgentReportMode" id="b372cbc5-6d84-4b4e-8036-52282209cab0">
        <source>setupAgentReportMode(_term : CM_Terminal;
					 _agent : CM_MTThresholdAgent output;
					 _operator : CM_Operator;
					 _isoGroup : CM_ISOTypeGroup;
					 _subTerminal : CM_SubTerminal
					 ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	par 27731
12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
17 Sep 2019	jlgdi1	46124	Update method signature to consider sub terminal
*/

vars
	ts : TimeStamp;
	endDate : Date;

begin
	ts := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endDate := ts.Date + 5;

	create _agent transient;
	
	_agent.clear();
	_agent.setBaseData(	_term,	//_terminal : CM_Terminal;	
						_operator,	//_operator : CM_Operator;
						_isoGroup,	//_isoGroup : CM_ISOTypeGroup;
						null,	//_grade : CM_MTGrade;
						endDate,	//_receivalDate : Date;
						endDate	//_releaseDate : Date
						);
						
	_agent.processEmpties(_subTerminal);
	_agent.processBulkReleases(_subTerminal);
	_agent.processPreNotes(_subTerminal);
end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_agent" type="CM_MTThresholdAgent" usage="output"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="tAdvancedThresholdUse" id="77aeaf32-022d-40b3-84ab-1ef74915b7cd">
        <source>tAdvancedThresholdUse();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731
17 Sep 2019	jlgdi1	46124	Update method call setupAgentReportMode
*/

constants
	MTThreshYA : String = "MTThreshYA";
	
vars
	term : CM_Terminal;
	isoType : CM_ISOType;
	iSOTypeGroup : CM_ISOTypeGroup;
	mTGrade : CM_MTGrade;
	operator : CM_Operator;
	washTA : CM_TerminalAreaMaster;
	repairTA : CM_TerminalAreaMaster;
	pretripTA : CM_TerminalAreaMaster;
	washToDo : CM_ToDoTaskDesc;
	repairToDo : CM_ToDoTaskDesc;
	pretripToDo : CM_ToDoTaskDesc;
	ptiRepairToDo : CM_ToDoTaskDesc;
	surveyToDo : CM_ToDoTaskDesc;
	voyage : CM_Voyage;
	reportAgent : CM_MTThresholdAgent;
	reportAgentOpOnly : CM_MTThresholdAgent;
	reportAgentPackCheck : CM_MTThresholdAgent;
	bgpAgent : CM_MTThresholdAgent;
	dataLine : CM_MTPoolingEnquiryLine;
	allBreachLinesTrans : CM_MTPoolingEnquiryLineDict;
	breachLine : CM_MTPoolingEnquiryLine;
	thresh : CM_MTThreshold;
	_ts	: TimeStamp;
	newLastNotified	: TimeStamp;
	bulkRelease : CM_BulkRelease;
	ti : CM_TrackedItem;
	packingArea : CM_IrregularBlockArea;
	ground : CM_IrregularBlockController;
	moveRequest: CM_YardDeliveryRequest;
	wle : CM_WorkListEntry;
	straddle : CM_Machine;
	queueEntry : CM_RTQueueEntry;
	queuetask : CM_RTQueueTask;
	lcArray : CM_LCArray;
	ya : CM_YardAllocation;
	tas : StringArray;
	isDoClearanceCheck : Boolean;
	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	
	term := self.getTerminal;
	isoType := app.myRoot.allISOTypes.getAtKey("2200");
	iSOTypeGroup := isoType.myISOTypeGroup;
	mTGrade := app.myRoot.allAvailableAvailabilityGrades.getAtKey(1);
	
	// delete  data.
	self.deleteAdvancedData( term );
	
	operator := self.addOperatorSimple("UTTH", "Threshold Test Operator");
	
	// setup thresholds
	self.addMTThresholds(	term,	//_term : CM_Terminal;
							iSOTypeGroup,	//_iSOTypeGroup : CM_ISOTypeGroup;
							mTGrade,	//_mTGrade : CM_MTGrade;
							operator	//_operator : CM_Operator
							);

	// setup a wash, a pretrip, a survey, a repair and a ptirepair area.
	self.addTaAreas( term, washTA, repairTA, pretripTA );
	
	// setup the to do tasks
	self.addToDoTaskDescs( term, washToDo, repairToDo, pretripToDo, ptiRepairToDo, surveyToDo );
	
	// add one of each of packing, rail, road, ship and pending release requests
	self.addReleaseRequests(voyage, operator, mTGrade);
	
	// add cargo to each area
	self.addAllCargo( washTA, repairTA, pretripTA, washToDo, repairToDo, pretripToDo, ptiRepairToDo, surveyToDo, mTGrade, operator );
	
	// add prenotes by road  and by train
	self.addAllPreNotes( mTGrade, operator );
	
	// add ship receivals
	self.addShipReceivals( voyage, operator, mTGrade );
	
	// create and call the Threshold agent (report version for a specific operator and iso type)
	self.setupAgentReportMode(term, reportAgentOpOnly, operator, iSOTypeGroup, null);
	
	// check agent results ( numbers in each cell/collection )	
	self.assertTrueMsg(reportAgentOpOnly.allMTPoolingEnquiryLines.size = 2, "Wrong number of enquiry lines for 'Operator ISO only' report" );	
	foreach dataLine in reportAgentOpOnly.allMTPoolingEnquiryLines do
		self.checkOpReportDataLine( dataLine, operator, iSOTypeGroup );
	endforeach;
	
	// create and call the Threshold agent (report version - All)
	self.setupAgentReportMode(term, reportAgent, null, null, null);
	
	// check agent results ( numbers in each cell/collection )
	self.assertTrueMsg(reportAgent.allMTPoolingEnquiryLines.size = 4, "Wrong number of enquiry lines for 'ALL' report" );	
	foreach dataLine in reportAgent.allMTPoolingEnquiryLines do
		self.checkReportDataLine( dataLine, operator );
	endforeach;
	
	//Set up for later Pack request check... TFS 1814
	self.setupAgentReportMode(term, reportAgentPackCheck, operator, iSOTypeGroup, null);
	
	// create and call the Threshold agent (bgp version)
	self.setupAgentBGPmode( term, bgpAgent, allBreachLinesTrans );
	
	// check we have appropriate breach lines.
	self.assertTrueMsg(allBreachLinesTrans.size = 2, "Wrong number of breach lines for agent in BGP mode" );	
	foreach breachLine in allBreachLinesTrans do
		thresh := breachLine.myMTThreshold;
		if thresh.processingPriority = 1 then
			self.assertTrueMsg( false, "Background agent incorrectly shows breach for threshold with processingPriority 1.  Should be 1 available, min = 1, max = 2" );
		elseif thresh.processingPriority = 3 then
			self.assertTrueMsg( false, "Background agent incorrectly shows breach for threshold with processingPriority 3.  Should be 1 available, min = 1, max = 2" );
		elseif thresh.processingPriority = 4 then
			self.assertTrueMsg( false, "Background agent incorrectly shows breach for threshold with processingPriority 4.  It is inactive" );
		endif;
	endforeach;
	
	breachLine := allBreachLinesTrans.first;
	thresh := breachLine.myMTThreshold;
	self.assertTrueMsg(thresh.processingPriority = 2, "Wrong breach line s/be 2, for agent in BGP mode" );
	self.assertTrueMsg(breachLine.isMinBreached, "Line 2 s/be minimum breach, for agent in BGP mode" );
	
	breachLine := allBreachLinesTrans.last;
	thresh := breachLine.myMTThreshold;
	self.assertTrueMsg(thresh.processingPriority = 5, "Wrong breach line s/be 5, for agent in BGP mode" );
	self.assertTrueMsg(breachLine.isMaxBreached, "Line 5 s/be maximum breach, for agent in BGP mode" );
	
	
	// TFS 1814 testing...
	
	bulkRelease := self.getTerminal.getBulkReleaseFromCode("UTRRPACKTH");
	self.assertTrueMsg(bulkRelease &lt;&gt; null, "Couldn't find the packing release" );
	ti := self.getTrackedItemByCargoType("THRS1110112", 1);
	self.assertTrueMsg(ti &lt;&gt; null, "Couldn't find THRS1110112" );
	
	self.assertTrueMsg(reportAgentPackCheck.allMTPoolingEnquiryLines.first.allPackReqs.first = bulkRelease, "Original query failed to find Pack Request");
	self.assertTrueMsg( bulkRelease.getMTTotalOutstanding = 2,"Mts remaining should count as 2 on the pack Release");
	
	// add general cargo area and ground location (I.e. where packing may occur)
	packingArea := self.addGeneralCargoArea("UT_PA", "", 5, 5, 10, null, null);
	self.assertNotNull(packingArea);	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	ground := self.addGCRackOrGround(packingArea,3,4,3,4,"PA01");
	
	//create a special internal move for the ti against the packig request...
	self.opts.purge();
	self.opts.addAssoc( "Release",  bulkRelease );
	self.opts.addAssoc( "ReserveDetail", bulkRelease.allReserveDetails.first );
	moveRequest := self.moveDirector(	"THRS1110112",	//_id: String;
										1, 	//_totalRequested: Integer;
										operator.code, //_operatorCode: String;
										"2200", // _isoTypeCode: String;
										ti.myPrimaryActualLocation.myTerminalArea,	// _sourceTA: Any; 
										null, //	_sourceBays: CM_GridObjectArray;
										packingArea	//	_targetTA: CM_TerminalArea
										); 
	wle := moveRequest.allWorkListEntries.first;
	queueEntry := wle.allRTQueueEntries.first;
	self.opts.purge();
	
	//add a machine to move ti
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(ti.myPrimaryActualLocation.myTerminalArea.id); 
	tas.add(packingArea.getID); 
	self.addStraddle("UTS1", 91, tas, null);
	
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	
	
	// set the config value whihc causes 'packing' ti's to be marked as 'released' during the move process.
	self.setTerminalConfig(PackingRelAsInternalRel,true);
	
	//Make sure teh autoplan matches for teh move.
	self.disableAllYA(true);
	create lcArray transient;
	lcArray.add( packingArea.allLocationsControllers.first );
	ya := self.addYA1(MTThreshYA, YACriteriaType_ISO, "2200", lcArray);
	
	// use the machine to do the move.
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	self.machineAcceptSpecifiedTask(straddle, queueEntry);
	self.machineDirector(straddle, ti);
	queuetask := queueEntry.allTasks.last;
	self.machineSetdownTask(straddle, queuetask, queuetask.targetLocationId);
	self.machineLogOff(straddle);
	
	//Pack request should now be done.
	self.assertTrueMsg( bulkRelease.allTrackedItemsReleased.includes(ti), "Ti should be marked as released as far as the Packing Bulk Release is concerned.");
	self.assertTrueMsg( bulkRelease.getMTTotalOutstanding = 1,"Mts remaining should count as 1 on the pack Release");
	
	//recheck after the request has been satisfied
	delete reportAgentPackCheck;
	self.setupAgentReportMode(	term, reportAgentPackCheck, operator, iSOTypeGroup, null);
	self.assertTrueMsg(reportAgentPackCheck.allMTPoolingEnquiryLines.first.allPackReqs.first = bulkRelease, "Subsequent query should still find the Pack Request");

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.setTerminalConfig(PackingRelAsInternalRel,false);

	self.deleteYA(MTThreshYA);
	self.disableAllYA(false);
	app.isRTApp:=false; 

	// delete  data.
	delete reportAgentOpOnly;
	delete reportAgent;
	delete reportAgentPackCheck;
	delete bgpAgent;
	delete allBreachLinesTrans;
	delete lcArray;
	delete tas;
	
	//self.deleteAdvancedData( term );	
end;</source>
    </JadeMethod>
    <JadeMethod name="tMTPoolingWithSubTerminal" id="06756d97-9f89-4b33-b63d-2efc4a01a71b">
        <source>tMTPoolingWithSubTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
17 Sep 2019	jlgdi1	46124	Initial creation
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
*/

constants
	SUBTERMA : String = "UTSubTA";
	SUBTERMB : String = "UTSubTB";
	
	UT_CODE : String = "UTDI";
	ISOCONT : String = "CONT";
	
	// Sub Terminal A - Containers
	CA1 : String = "CA1WASH";
	CA2 : String = "CA1REP";
	CA3 : String = "CA1PTI";
	
	// Sub Terminal B - Containers
	CB1 : String = "CB1WASH";
	CB2 : String = "CB1REP";
	CB3 : String = "CB1PTI";
	
	// Sub Terminal A - Area
	TA1 : String = "TA1";
	TA2 : String = "TA2";
	TA3 : String = "TA3";
	
	// Sub Terminal B - Area
	TB1 : String = "TB1";
	TB2 : String = "TB2";
	TB3 : String = "TB3";
	
	// ----- Pre Notes -----
	CAPN1 : String = "CA1PN1";
	CAPN2 : String = "CA1PN2";
	CBPN1 : String = "CB1PN1";
	CBPN2 : String = "CB1PN2";
	
	// ----- Release Request -----	
	MYVESSEL : String = "UTDPI";
	MYVOYAGE : String = "UTDPIVOY";
	RRAROAD : String = "RRAROAD";
	RRARAIL : String = "RRARAIL";
	RRBSHIP : String = "RRBSHIP";
	
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	isoType : CM_ISOType;
	cargoType : CM_CargoType;
	isoTypeColl	: CM_ISOTypeByCodeDict;
	isoTypeGroupSub	: CM_ISOTypeGroupByCodeDict;	
	isoGroup : CM_ISOTypeGroup;

	subTerminal1 : CM_SubTerminal;
	subTerminal2 : CM_SubTerminal;
	
	termConfigIsSubTermOn : Boolean;
	termConfigIsSubTermDefined : Boolean;
	
	selectedAreas : ObjectSet;
	bsA1 : CM_BlockStack;
	bsA2 : CM_BlockStack;
	bsA3 : CM_BlockStack;
	bsB1 : CM_BlockStack;
	bsB2 : CM_BlockStack;
	bsB3 : CM_BlockStack;	
	subTerminalAreaDef : CM_SubTerminalAreaDef;
	
	contA1 : CM_TrackedItem;
	contA2 : CM_TrackedItem;
	contA3 : CM_TrackedItem;
	contB1 : CM_TrackedItem;
	contB2 : CM_TrackedItem;
	contB3 : CM_TrackedItem;	
	
	reportAgentOpOnly : CM_MTThresholdAgent;
	
	startObject : CM_TrackedItem;
	container : CM_Container;
	contentStatus : CM_ContentsStatus;
	
	dataLine : CM_MTPoolingEnquiryLine;
	
	chosenSubTerminal : CM_SubTerminal;
	expectedCount : Integer;
	
	expectedAvail : Integer;
	expectedOnSite : Integer;
	expectedPreNoteRail : Integer;
	expectedPreNoteRoad : Integer;
	

	contPNA1 : CM_TrackedItem;
	contPNA2 : CM_TrackedItem;
	contPNB1 : CM_TrackedItem;
	contPNB2 : CM_TrackedItem;
	
	vessel: CM_Vessel;
	voyage : CM_Voyage;
	dischargePort: CM_Port;	
	releaseRequest: CM_BulkRelease;

	expectedRailReqs : Integer;
	expectedRoadReqs : Integer;
	expectedShipReqs : Integer;	
	
begin
	/* ----- Arrange -----
	Terminal
	Operator
	ISO Type
	ISO Group
	Sub Terminal
	*/
	
	terminal := self.getTerminal();
	assertTrue(terminal &lt;&gt; null);
	
	cargoType := self.getCargoType(ISOCONT);
	assertTrue(cargoType &lt;&gt; null);
	
	// Operator
	operator := app.myRoot.allOperators[UT_CODE];
	if operator = null then
		operator := self.addOperatorSimple(UT_CODE, "UT DPI Operator");
	endif;
	assertTrue(operator &lt;&gt; null);
	
	// ISO Types
	isoType := app.myRoot.allISOTypes[UT_CODE];
	if isoType = null then
		isoType := self.addISOType(UT_CODE, "UT DPI ISO Type", 
								   cargoType, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false,
								   2000);
	endif;
	assertTrue(isoType &lt;&gt; null);
	
	// ISO Type Group
	create isoTypeColl transient;
	//isoTypeColl.add(isoType);
	create isoTypeGroupSub transient;
	//isoTypeGroupSub.add(app.myRoot.allISOTypeGroups[UT_CODE]);
	isoGroup := app.myRoot.allISOTypeGroups[UT_CODE];
	if isoGroup = null then
		isoGroup := self.addISOGroup(UT_CODE, "UT DPI ISO type Group", isoTypeColl, isoTypeGroupSub);
	endif;
	assertTrue(isoGroup &lt;&gt; null);	
	
	beginTransaction;
	isoType.setMyISOTypeGroup(isoGroup);
	commitTransaction;
	
	termConfigIsSubTermOn := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	termConfigIsSubTermDefined := self.getTerminalConfig(IsSubTerminalAreaDefined).Boolean;
	
	self.setTerminalConfig(IsSubTerminalsOn, true);
	self.setTerminalConfig(IsSubTerminalAreaDefined, true);
	
	self.deleteContainer(CA1);
	self.deleteContainer(CA2);
	self.deleteContainer(CA3);
	self.deleteContainer(CB1);
	self.deleteContainer(CB2);
	self.deleteContainer(CB3);
	
	self.deleteTerminalArea(TA1);
	self.deleteTerminalArea(TA2);
	self.deleteTerminalArea(TA3);
	self.deleteTerminalArea(TB1);
	self.deleteTerminalArea(TB2);
	self.deleteTerminalArea(TB3);
	
	self.deleteSubTerminal(SUBTERMA);
	self.deleteSubTerminal(SUBTERMB);
	
	subTerminal1 := self.addSubTerminal(SUBTERMA, SubTermType_Depot_Int);
	self.assertTrueMsg( subTerminal1 &lt;&gt; null, "Sub Terminal " &amp; SUBTERMA &amp; " not created");
	
	subTerminal2 := self.addSubTerminal(SUBTERMB, SubTermType_Marine_Int);
	self.assertTrueMsg( subTerminal2 &lt;&gt; null, "Sub Terminal 2 not created");
	
	bsA1 := self.addBlockStack( TA1, 10, null );
	self.assertTrueMsg( bsA1 &lt;&gt; null, "Terminal Area 1 in Terminal A not created");
	bsA2 := self.addBlockStack( TA2, 10, null );
	self.assertTrueMsg( bsA2 &lt;&gt; null, "Terminal Area 2 in Terminal A not created");
	bsA3 := self.addBlockStack( TA3, 10, null );
	self.assertTrueMsg( bsA3 &lt;&gt; null, "Terminal Area 3 in Terminal A not created");
	
	bsB1 := self.addBlockStack( TB1, 10, null );
	self.assertTrueMsg( bsB1 &lt;&gt; null, "Terminal Area 1 in Terminal A not created");
	bsB2 := self.addBlockStack( TB2, 10, null );
	self.assertTrueMsg( bsB2 &lt;&gt; null, "Terminal Area 2 in Terminal A not created");
	bsB3 := self.addBlockStack( TB3, 10, null );
	self.assertTrueMsg( bsB3 &lt;&gt; null, "Terminal Area 3 in Terminal A not created");
	
	create selectedAreas transient;

	selectedAreas.clear();
	selectedAreas.add(bsA1);
	selectedAreas.add(bsA2);
	selectedAreas.add(bsA3);
	subTerminalAreaDef := self.addSubTerminalWorkAreaDef( subTerminal1, selectedAreas );
	self.assertTrueMsg( subTerminalAreaDef &lt;&gt; null, "Terminal Area " &amp; TA1 &amp; " associated areas def not created");
	self.assertTrueMsg( subTerminalAreaDef = subTerminal1.mySubTerminalAreaDef, "Terminal Area " &amp; TA1 &amp; " 'associated areas def' not set");
	self.assertTrueMsg( subTerminalAreaDef.allTerminalAreas.includes(bsA1), "Terminal Area " &amp; TA1 &amp; " NOT in allTerminalAreas of Sub Term 1");

	selectedAreas.clear();
	selectedAreas.add(bsB1);
	selectedAreas.add(bsB2);
	selectedAreas.add(bsB3);
	subTerminalAreaDef := self.addSubTerminalWorkAreaDef( subTerminal2, selectedAreas );
	self.assertTrueMsg( subTerminalAreaDef &lt;&gt; null, "Terminal Area " &amp; TB1 &amp; " associated areas def not created");
	self.assertTrueMsg( subTerminalAreaDef = subTerminal2.mySubTerminalAreaDef, "Terminal Area " &amp; TB1 &amp; " 'associated areas def' not set");
	self.assertTrueMsg( subTerminalAreaDef.allTerminalAreas.includes(bsB1), "Terminal Area " &amp; TB1 &amp; " NOT in allTerminalAreas of Sub Term 1");
		
	// ----- Empty Containers -----
	contA1 := self.addContainerAtLocation(CA1, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsA1);
	self.assertTrueMsg(contA1 &lt;&gt; null, CA1 &amp; " not created");
	self.assertTrueMsg(contA1.cargoType = TI_CargoType_Container, CA1 &amp; " not a container");
	self.assertTrueMsg(contA1.getImExStatus() = TI_IMEX_STATUS_STORAGE, CA1 &amp; " Imex Status is not Storage");
	container := contA1.CM_Container;
	self.makeTIEmpty(container);
	self.assertTrueMsg(container.isEmpty, CA1 &amp; " is not a empty container");

	contA2 := self.addContainerAtLocation(CA2, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsA2);
	self.assertTrueMsg(contA2 &lt;&gt; null, CA2 &amp; " not created");
	self.assertTrueMsg(contA2.cargoType = TI_CargoType_Container, CA2 &amp; " not a container");
	self.assertTrueMsg(contA2.getImExStatus() = TI_IMEX_STATUS_STORAGE, CA2 &amp; " Imex Status is not Storage");
	container := contA2.CM_Container;
	self.makeTIEmpty(container);
	self.assertTrueMsg(container.isEmpty, CA2 &amp; " is not a empty container");
	
	contA3 := self.addContainerAtLocation(CA3, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsA3);
	self.assertTrueMsg(contA3 &lt;&gt; null, CA3 &amp; " not created");
	self.assertTrueMsg(contA3.cargoType = TI_CargoType_Container, CA3 &amp; " not a container");
	self.assertTrueMsg(contA3.getImExStatus() = TI_IMEX_STATUS_STORAGE, CA3 &amp; " Imex Status is not Storage");
	container := contA3.CM_Container;
	self.makeTIEmpty(container);
	self.assertTrueMsg(container.isEmpty, CA3 &amp; " is not a empty container");
	
	contB1 := self.addContainerAtLocation(CB1, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsB1);
	self.assertTrueMsg(contB1 &lt;&gt; null, CB1 &amp; " not created");
	self.assertTrueMsg(contB1.cargoType = TI_CargoType_Container, CB1 &amp; " not a container");
	self.assertTrueMsg(contB1.getImExStatus() = TI_IMEX_STATUS_STORAGE, CB1 &amp; " Imex Status is not Storage");
	container := contB1.CM_Container;
	self.makeTIEmpty(container);
	self.assertTrueMsg(container.isEmpty, CB1 &amp; " is not a empty container");

	contB2 := self.addContainerAtLocation(CB2, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsB2);
	self.assertTrueMsg(contB2 &lt;&gt; null, CB2 &amp; " not created");
	self.assertTrueMsg(contB2.cargoType = TI_CargoType_Container, CB2 &amp; " not a container");
	self.assertTrueMsg(contB2.getImExStatus() = TI_IMEX_STATUS_STORAGE, CB2 &amp; " Imex Status is not Storage");
	container := contB2.CM_Container;
	self.makeTIEmpty(container);
	self.assertTrueMsg(container.isEmpty, CB2 &amp; " is not a empty container");
	
	contB3 := self.addContainerAtLocation(CB3, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsB3);
	self.assertTrueMsg(contB3 &lt;&gt; null, CB3 &amp; " not created");
	self.assertTrueMsg(contB3.cargoType = TI_CargoType_Container, CB3 &amp; " not a container");
	self.assertTrueMsg(contB3.getImExStatus() = TI_IMEX_STATUS_STORAGE, CB3 &amp; " Imex Status is not Storage");
	container := contB3.CM_Container;
	self.makeTIEmpty(container);
	self.assertTrueMsg(container.isEmpty, CB3 &amp; " is not a empty container");
	
	
	// ---------------------------- Pre Notes (start) ---------------------------- 
	self.deleteContainer(CAPN1);
	self.deleteContainer(CAPN2);
	self.deleteContainer(CBPN1);
	self.deleteContainer(CBPN2);
	
	// Sub Terminal 1
	contPNA1 := self.addContainerAtLocation(CAPN1, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsA1);
	self.assertTrueMsg(contPNA1 &lt;&gt; null, CAPN1 &amp; " not created");
	self.assertTrueMsg(contPNA1.cargoType = TI_CargoType_Container, CAPN1 &amp; " not a container");
	self.assertTrueMsg(contPNA1.getImExStatus() = TI_IMEX_STATUS_STORAGE, CAPN1 &amp; " Imex Status is not Storage");
	self.makeTIPreNoted(contPNA1, TI_TRANSMODE_RAIL);
	
	// Sub Terminal 2
	contPNA2 := self.addContainerAtLocation(CAPN2, operator, isoType.code, "MT", TI_IMEX_STATUS_STORAGE, bsB1);
	self.assertTrueMsg(contPNA2 &lt;&gt; null, CAPN2 &amp; " not created");
	self.assertTrueMsg(contPNA2.cargoType = TI_CargoType_Container, CAPN2 &amp; " not a container");
	self.assertTrueMsg(contPNA2.getImExStatus() = TI_IMEX_STATUS_STORAGE, CAPN2 &amp; " Imex Status is not Storage");
	self.makeTIPreNoted(contPNA2, TI_TRANSMODE_ROAD);
	// ---------------------------- Pre Notes (end) ---------------------------- 

	// ---------------------------- Release Request (start) ---------------------------- 
	// 2 Release Request Sub Terminal A (Road, Rail)
	// 1 Release Request Sub Terminal B (Ship)
		
	dischargePort := app.myRoot.allPorts["NZAKL"];
	
	self.deleteVoyage(MYVOYAGE);
	self.deleteVessel(MYVESSEL);
	self.deleteReleaseRequest(RRAROAD);
	self.deleteReleaseRequest(RRARAIL);
	self.deleteReleaseRequest(RRBSHIP);	
	
	vessel := addVesselCellular(MYVESSEL, operator);
	voyage := addVoyageWithContainerStructur(MYVOYAGE, MYVESSEL, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal);
	
	// Sub Terminal A - Release Request by ROAD (#1)
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", isoGroup.code);
	self.opts.addAssoc("Operator", operator);
	//self.opts.addAssoc("Grade", mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 3);
	
	releaseRequest := addReleaseByTypeRequestOpts(RRAROAD, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	beginTransaction;
	releaseRequest.setSubTerminal(subTerminal1);
	commitTransaction;
	
	// Sub Terminal A - Release Request by RAIL (#2)
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", isoGroup.code);
	self.opts.addAssoc("Operator", operator);
	//self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 3);
	
	releaseRequest := addReleaseByTypeRequestOpts(RRARAIL, BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	beginTransaction;
	releaseRequest.setSubTerminal(subTerminal1);
	commitTransaction;	
	
	// Sub Terminal B - Release Request by RAIL (#2)
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", isoGroup.code);
	self.opts.addAssoc("Operator", operator);
	//self.opts.addAssoc("Grade", _mtGrade);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	
	releaseRequest := addReleaseByTypeRequestOpts(RRBSHIP, BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	assertEqual(releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, voyage.code);
	beginTransaction;
	releaseRequest.setSubTerminal(subTerminal2);
	commitTransaction;		
	// ---------------------------- Release Request (End) ----------------------------
	
	self.addMTThreshold(terminal,
						 isoGroup,
						 null,
						 operator);
	/*
	self.addMTThreshold(terminal,
						 isoGroup,
						 null,
						 null);
	*/
	
	// Test Case #1 | Sub Terminal = null (NOT CHOSEN)
	expectedAvail := 6;
	expectedOnSite := 6;
	expectedPreNoteRail := 1;	// Rail for Sub Terminal 1
	expectedPreNoteRoad := 1;	// Road for Sub Terminal 2
	expectedRailReqs := 1;
	expectedRoadReqs := 1;
	expectedShipReqs := 1;
	
	chosenSubTerminal := null;
	self.setupAgentReportMode(terminal,
							  reportAgentOpOnly,
							  operator,
							  isoGroup,
							  chosenSubTerminal);
	
	self.assertTrueMsg(reportAgentOpOnly.allMTPoolingEnquiryLines.size = 1, "Wrong number of enquiry lines for Operator, ISO Group" );
	foreach dataLine in reportAgentOpOnly.allMTPoolingEnquiryLines do
		self.assertTrueMsg(dataLine.allOnsiteTis.size = expectedOnSite, " allOnsiteTis expected to have " &amp; expectedOnSite.String &amp;
																	   " but return " &amp; dataLine.allOnsiteTis.size.String);
		self.assertTrueMsg(dataLine.allAvailable.size = expectedAvail, " allAvailable expected to have " &amp; expectedAvail.String &amp;
																	   " but return " &amp; dataLine.allAvailable.size.String);
		self.assertTrueMsg(dataLine.allRailPreNotes.size = expectedPreNoteRail, " allRailPreNotes expected to have " &amp; expectedPreNoteRail.String &amp;
																	   " but return " &amp; dataLine.allRailPreNotes.size.String);
		self.assertTrueMsg(dataLine.allRoadPreNotes.size = expectedPreNoteRoad, " allRoadPreNotes expected to have " &amp; expectedPreNoteRoad.String &amp;
																	   " but return " &amp; dataLine.allRoadPreNotes.size.String);
		self.assertTrueMsg(dataLine.allRailReqs.size = expectedRailReqs, " allRailReqs expected to have " &amp; expectedRailReqs.String &amp;
																	   " but return " &amp; dataLine.allRailReqs.size.String);
		self.assertTrueMsg(dataLine.allRoadReqs.size = expectedRoadReqs, " allRoadReqs expected to have " &amp; expectedRoadReqs.String &amp;
																	   " but return " &amp; dataLine.allRoadReqs.size.String);
		self.assertTrueMsg(dataLine.allShipReqs.size = expectedShipReqs, " allShipReqs expected to have " &amp; expectedShipReqs.String &amp;
																	   " but return " &amp; dataLine.allShipReqs.size.String);
	endforeach;
	delete reportAgentOpOnly;
	
	// Test Case #2
	// Sub Terminal = Sub Terminal 1
	// Expected : 3 Available/OnSite
	expectedAvail := 3;
	expectedOnSite := 3;
	expectedPreNoteRail := 1;	// Rail for Sub Terminal 1
	expectedPreNoteRoad := 0;	// Road for Sub Terminal 2
	expectedRailReqs := 1;
	expectedRoadReqs := 1;
	expectedShipReqs := 0;
	
	chosenSubTerminal := subTerminal1;
	self.setupAgentReportMode(terminal,
							  reportAgentOpOnly,
							  operator,
							  isoGroup,
							  chosenSubTerminal);
							  
	self.assertTrueMsg(reportAgentOpOnly.allMTPoolingEnquiryLines.size = 1, "Wrong number of enquiry lines for Operator, ISO Group" );
	foreach dataLine in reportAgentOpOnly.allMTPoolingEnquiryLines do
		self.assertTrueMsg(dataLine.allOnsiteTis.size = expectedOnSite, " allOnsiteTis expected to have " &amp; expectedOnSite.String &amp;
																	   " but return " &amp; dataLine.allOnsiteTis.size.String);
		self.assertTrueMsg(dataLine.allAvailable.size = expectedAvail, " allAvailable expected to have " &amp; expectedAvail.String &amp;
																	   " but return " &amp; dataLine.allAvailable.size.String);
		self.assertTrueMsg(dataLine.allRailPreNotes.size = expectedPreNoteRail, " allRailPreNotes expected to have " &amp; expectedPreNoteRail.String &amp;
																	   " but return " &amp; dataLine.allRailPreNotes.size.String);
		self.assertTrueMsg(dataLine.allRoadPreNotes.size = expectedPreNoteRoad, " allRoadPreNotes expected to have " &amp; expectedPreNoteRoad.String &amp;
																	   " but return " &amp; dataLine.allRoadPreNotes.size.String);
		self.assertTrueMsg(dataLine.allRailReqs.size = expectedRailReqs, " allRailReqs expected to have " &amp; expectedRailReqs.String &amp;
																	   " but return " &amp; dataLine.allRailReqs.size.String);
		self.assertTrueMsg(dataLine.allRoadReqs.size = expectedRoadReqs, " allRoadReqs expected to have " &amp; expectedRoadReqs.String &amp;
																	   " but return " &amp; dataLine.allRoadReqs.size.String);
		self.assertTrueMsg(dataLine.allShipReqs.size = expectedShipReqs, " allShipReqs expected to have " &amp; expectedShipReqs.String &amp;
																	   " but return " &amp; dataLine.allShipReqs.size.String);																	   
	endforeach;
	delete reportAgentOpOnly;
	
	// Test Case #3
	// Sub Terminal = Sub Terminal 2
	// Expected : 3 Available/OnSite
	expectedAvail := 3;
	expectedOnSite := 3;
	expectedPreNoteRail := 0;	// Rail for Sub Terminal 1
	expectedPreNoteRoad := 1;	// Road for Sub Terminal 2
	expectedRailReqs := 0;
	expectedRoadReqs := 0;
	expectedShipReqs := 1;
	
	chosenSubTerminal := subTerminal2;
	self.setupAgentReportMode(terminal,
							  reportAgentOpOnly,
							  operator,
							  isoGroup,
							  chosenSubTerminal);
							  
	self.assertTrueMsg(reportAgentOpOnly.allMTPoolingEnquiryLines.size = 1, "Wrong number of enquiry lines for Operator, ISO Group" );
	foreach dataLine in reportAgentOpOnly.allMTPoolingEnquiryLines do
		self.assertTrueMsg(dataLine.allOnsiteTis.size = expectedOnSite, " allOnsiteTis expected to have " &amp; expectedOnSite.String &amp;
																	   " but return " &amp; dataLine.allOnsiteTis.size.String);
		self.assertTrueMsg(dataLine.allAvailable.size = expectedAvail, " allAvailable expected to have " &amp; expectedAvail.String &amp;
																	   " but return " &amp; dataLine.allAvailable.size.String);
		self.assertTrueMsg(dataLine.allRailPreNotes.size = expectedPreNoteRail, " allRailPreNotes expected to have " &amp; expectedPreNoteRail.String &amp;
																	   " but return " &amp; dataLine.allRailPreNotes.size.String);
		self.assertTrueMsg(dataLine.allRoadPreNotes.size = expectedPreNoteRoad, " allRoadPreNotes expected to have " &amp; expectedPreNoteRoad.String &amp;
																	   " but return " &amp; dataLine.allRoadPreNotes.size.String);
		self.assertTrueMsg(dataLine.allRailReqs.size = expectedRailReqs, " allRailReqs expected to have " &amp; expectedRailReqs.String &amp;
																	   " but return " &amp; dataLine.allRailReqs.size.String);
		self.assertTrueMsg(dataLine.allRoadReqs.size = expectedRoadReqs, " allRoadReqs expected to have " &amp; expectedRoadReqs.String &amp;
																	   " but return " &amp; dataLine.allRoadReqs.size.String);
		self.assertTrueMsg(dataLine.allShipReqs.size = expectedShipReqs, " allShipReqs expected to have " &amp; expectedShipReqs.String &amp;
																	   " but return " &amp; dataLine.allShipReqs.size.String);																	   
	endforeach;
	delete reportAgentOpOnly;
	
	
epilog
	delete selectedAreas;	
	
	self.setTerminalConfig(IsSubTerminalsOn, termConfigIsSubTermOn);
	self.setTerminalConfig(IsSubTerminalAreaDefined, termConfigIsSubTermDefined);
	
	self.deleteAllThresholds(terminal);
	
	// ----- Release Requests -----
	self.deleteVoyage(MYVOYAGE);
	self.deleteVessel(MYVESSEL);
	self.deleteReleaseRequest(RRAROAD);
	self.deleteReleaseRequest(RRARAIL);
	self.deleteReleaseRequest(RRBSHIP);	
	
	// ----- Empty Containers -----
	self.deleteContainer(CA1);
	self.deleteContainer(CA2);
	self.deleteContainer(CA3);
	self.deleteContainer(CB1);
	self.deleteContainer(CB2);
	self.deleteContainer(CB3);

	// ----- Pre Notes -----
	self.deleteContainer(CAPN1);
	self.deleteContainer(CAPN2);
	self.deleteContainer(CBPN1);
	self.deleteContainer(CBPN2);
	
	self.deleteISOGroup(UT_CODE);	
	self.deleteOperator(UT_CODE);
	self.deleteISOType(UT_CODE);
	
	delete isoTypeColl;
	delete isoTypeGroupSub;	
	
	self.deleteTerminalArea(TA1);
	self.deleteTerminalArea(TA2);
	self.deleteTerminalArea(TA3);
	self.deleteTerminalArea(TB1);
	self.deleteTerminalArea(TB2);
	self.deleteTerminalArea(TB3);
	
	self.deleteSubTerminal(SUBTERMA);
	self.deleteSubTerminal(SUBTERMB);
end;</source>
    </JadeMethod>
    <JadeMethod name="tMTThresholdMaint" id="0dde6afd-c363-4a70-907e-da7035946c0b">
        <source>tMTThresholdMaint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	proxyThreshold : CM_MTThreshold;
	isActive : Boolean;
	maxLevel : Integer;
	minLevel : Integer;
	iSOTypeGroup : CM_ISOTypeGroup;
	mTGrade : CM_MTGrade;
	operator : CM_Operator;
	priority : Integer;
	reNotifyMins : Integer;
	term : CM_Terminal;
	thresh : CM_MTThreshold;
	threshToDel : CM_Threshold;
	load : Boolean;

begin

	term := self.getTerminal;
	self.deleteAllThresholds( term );
	
	//add a threshold
	
	create proxyThreshold transient;
	
	isActive := true;
	maxLevel := 5;
	minLevel := 1;
//	iSOTypeGroup := theForm.cmbISOTypeGroup.listObject.CM_ISOTypeGroup;
//	mTGrade := theForm.cmbGrade.listObject.CM_MTGrade;
//	operator := theForm.cmbOperator.listObject.CM_Operator;
	priority := 1;
	reNotifyMins := 10;
	
	
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	delete proxyThreshold;
	
	//try adding with same details
	create proxyThreshold transient;
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	
	if not app.myPassport.allErrors.includesErrorCode(MTThreshold_same_priority) then
		self.assertTrueMsg(false, "Expected error '" &amp; MTThreshold_same_priority.String &amp; "'");
	endif;
	app.myPassport.clearErrorsWarnings();
	
	
	priority := 2;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								6,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	
	if not app.myPassport.allErrorWarnings.includesErrorCode(Min_greater_than_max) then
		self.assertTrueMsg(false, "Expected warning '" &amp; Min_greater_than_max.String &amp; "'");
	endif;
	app.myPassport.clearErrorsWarnings();
	

	// and this one should work...
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	delete proxyThreshold;
	

	//maintain a threshold
	app.cmsBeginLoad(load);
	proxyThreshold := thresh.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	mTGrade := app.myRoot.allAvailableAvailabilityGrades.getAtKey(1);
	iSOTypeGroup := app.myRoot.allISOTypeGroups.getAtKey("20BX");
	
	proxyThreshold.setProxy(	false,	//_isActive : Boolean;
								10,	//_maxThresholdLevel : Integer;
								2,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								null,	//_myOperator : CM_Operator;
								3,	//_processingPriority : Integer;
								20,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxUA.trxUpdateThreshold(proxyThreshold, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertTrueMsg(thresh.isActive = false, "'isActive' not updated");
	self.assertTrueMsg(thresh.maxThresholdLevel = 10, "'maxThresholdLevel' not updated");
	self.assertTrueMsg(thresh.minThresholdLevel = 2, "'minThresholdLevel' not updated");
	self.assertTrueMsg(thresh.myISOTypeGroup = iSOTypeGroup, "'myISOTypeGroup' not updated");
	self.assertTrueMsg(thresh.myOperator = null, "'myOperator' not updated");
	self.assertTrueMsg(thresh.processingPriority = 3, "'processingPriority' not updated");
	self.assertTrueMsg(thresh.reNotificationMinutes = 20, "'reNotificationMinutes' not updated");
	self.assertTrueMsg(thresh.myMTGrade = mTGrade, "'myMTGrade' not updated");
	
	
	
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								null,	//_myISOTypeGroup : CM_ISOTypeGroup;
								null,	//_myOperator : CM_Operator;
								1,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(null);
	
	app.myTrxUA.trxUpdateThreshold(proxyThreshold, app.myPassport);
	if not app.myPassport.allErrors.includesErrorCode(MTThreshold_same_priority) then
		self.assertTrueMsg(false, "Expected error '" &amp; MTThreshold_same_priority.String &amp; "'");
	endif;
	if not app.myPassport.allErrors.includesErrorCode(MTThreshold_exists) then
		self.assertTrueMsg(false, "Expected error '" &amp; MTThreshold_exists.String &amp; "'");
	endif;	
	app.myPassport.clearErrorsWarnings();
	
	delete proxyThreshold;
	app.cmsBeginLoad(load);
	proxyThreshold := thresh.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								null,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								3,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(null);
	
	app.myTrxUA.trxUpdateThreshold(proxyThreshold, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	
	
	
	
	//delete a threshold - testing validations
	beginTransaction;
	thresh.setLastNotified( app.actualTimeServer );// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	commitTransaction;
	threshToDel := thresh;
	app.myTrxDA.trxDeleteThreshold( threshToDel, app.myPassport);
	if not app.myPassport.allErrors.includesErrorCode(Threshold_active) then
		self.assertTrueMsg(false, "Expected error '" &amp; Threshold_active.String &amp; "'");
	endif;
	if not app.myPassport.allErrors.includesErrorCode(Threshold_last_notified_set) then
		self.assertTrueMsg(false, "Expected error '" &amp; Threshold_last_notified_set.String &amp; "'");
	endif;
	app.myPassport.clearErrorsWarnings();
	
	
	
	beginTransaction;
	thresh.setLastNotified( null );
	commitTransaction;
	
	delete proxyThreshold;
	app.cmsBeginLoad(load);
	proxyThreshold := thresh.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	proxyThreshold.setProxy(	false,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								null,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								3,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(null);
	
	app.myTrxUA.trxUpdateThreshold(proxyThreshold, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// this delete should work.
	app.myTrxDA.trxDeleteThreshold( threshToDel, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	
epilog

	delete proxyThreshold;

end;</source>
    </JadeMethod>
</Class>
