    <JadeMethod name="sortTestsByTime" id="d5cf7314-3718-47e3-a2a7-85949b64742a">
        <source>sortTestsByTime();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwmc5	Initial creation

*/

vars
	result,	
	pastResult		: UT_TestResult;
	sortedResults 	: UT_TestResultsByName;
	summary 		: String;
begin
	create sortedResults transient;
	
	//sort results by time run
	foreach result in self.getTestResults() do
		if sortedResults.size = 0 then
			sortedResults.add(result);
		endif;
		
	endforeach;
	
	//sortedResults.
	
	//build summary string 
	foreach result in sortedResults do
		summary := summary &amp; result.summaryDetails(false) &amp; CrLf;
	endforeach;
epilog
	delete sortedResults;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopAllBGPProcesses" id="1c0f86a4-b750-40ee-a185-273cb6fdef58">
        <source>stopAllBGPProcesses();

/*

Purpose:		This method will stop all BGP procoess that are running.  Reason for doing this is that 
				it has the potential to cause lock exceptions to occur, which causes the test(s) to fail
				when they may not have.

Date			Who		Reason
14/02/2013		cnwmh5	Initial creation

*/

vars

    bgpManager   	  		: BGP_Manager;

    iter                    : Iterator;

begin

    iter := app.myRoot.allBGPManagers.createIterator;

    while iter.next(bgpManager) do

		// check to see if the manager is running, if not then don't care
		if not bgpManager.isRunning() then
			app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was not terminated as it was not running" , LogINFO);
			continue;
		endif;
	
		if bgpManager.isRunOnServer or (bgpManager.machineNameSpecific = null and not bgpManager.isManagedService) then
			app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was terminated (server)", LogINFO);
			bgpManager.terminateProcessing(app.myPassport.userCode);
			continue;
		endif;
	
		// is managed service and not special
		if bgpManager.isManagedService and not app.isSpecial() then
			app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was terminated as is a managed service and not isSpecial", LogINFO);
			continue;
		endif;
	
		// non server bgp manager
		app.writeLog("BGPManager (" &amp; bgpManager.name &amp; ") was terminated (non server)", LogINFO);
		bgpManager.terminateProcessing(app.myPassport.userCode);
		
	endwhile;

epilog

    delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="stripNONASCIICharacters" id="18a9f3d1-2e96-4bf9-90e9-24994ac63e81">
        <source>stripNONASCIICharacters(_details : String) : String;
/*

Purpose:		Strip Non ASCII Characters from details string

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2019	jlgmh5	Initial creation

*/

vars

	tempStr					: String;
	linePtr					: Integer;

begin

	linePtr := 0;
	
	while linePtr &lt; _details.length do
		linePtr := linePtr + 1;
		if _details[linePtr].Character.Integer &gt; 127 or _details[linePtr].Character.Integer = null then
			continue;
		endif;
		tempStr := tempStr &amp; _details[linePtr];
	endwhile;
	
	return tempStr;
		
epilog

end;</source>
        <Parameter name="_details" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="6abd7064-bf23-4a4f-9fc8-fcc36d74ffb9">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//29 April 2009	cnwdw1	
//
vars
	sm	:	CnSmtpConnection;
	result: UT_TestResult;
begin
	if eventType = CnSmtpConnection.Completion_Event_Type then
		sm	:=	theObject.CnSmtpConnection;
		emailComplete := true;
		delete sm;
	endif;
	
	if eventType = UT_UnitTest.TestCompleted_Event then
		if theObject &lt;&gt; null and theObject.isKindOf(UT_TestResult) then
			result := theObject.UT_TestResult;
			write result.summaryDetails(false);
		endif;
	endif;
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
