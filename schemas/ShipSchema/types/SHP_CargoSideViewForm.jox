    <JadeMethod name="deactivate" id="fb25d2d7-523a-4c1d-9c4c-fbf70fe93c91">
        <controlMethod name="Form::deactivate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>deactivate() updating;
/*
Date		    Who			Reason
26 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	idx : Integer;
	f : Form;
begin
	f := app.activeForm;
	if f = null or f = self then
		return;
	endif;
	if f &lt;&gt; self.myParentForm then
		self.myParentForm.deactivate();
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doArrangeFramesAndGroups" id="3f9eb87a-ba24-4cf1-86ad-a7a420304418">
        <updating/>
        <source>doArrangeFramesAndGroups() updating;
/*
Date		    Who			Reason
26 July 2011	cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
31 July 2012	cnwcs5		par 29124 - improve positioning of hazards table (see also doResize)
*/
constants
	LeftMargin	= 5;
	TopMargin	= 5;
	RightMargin = 5;
	BottomMargin = 5;
	Gap = 5;
vars
	frameLoc, frameSlot	:SHP_ROROLocnDrawingFrame;
	table				:CMUI_HazardsListTable;
	groupbox			:CMUI_GroupBox;
	toolbar				:CMUI_Toolbar;
begin
	frameLoc 	:= self.frmLocationPos;
	frameSlot	:= self.frmLocationSlots;
	table		:= self.lstHazard;
	groupbox	:= self.grpHazDetails;
	toolbar		:= self.frmToolbar;
	
	// Always in same position
	groupbox.move (LeftMargin, self.clientHeight - 200 - BottomMargin, 360, 200); 
	
	groupbox.transparent	:= true;								
	groupbox.parentAspect	:= Control.ParentAspect_AnchorBottom;	
		
	// locaztions
	frameLoc.move (LeftMargin,
					toolbar.height + TopMargin,
					360,
					groupbox.top - Gap - toolbar.height - TopMargin);
					
	frameLoc.parentAspect	:= Control.ParentAspect_StretchBottom;			
		
	// slots
	frameSlot.move (LeftMargin + frameLoc.width + Gap, 
					frameLoc.top, 
					self.clientWidth - frameLoc.width - LeftMargin - Gap - RightMargin, 
					frameLoc.height + Gap + groupbox.height);		
		
	frameSlot.parentAspect	:= Control.ParentAspect_StretchBoth;	
	
	// hazards table
	table.move (10, 25, groupbox.clientWidth - 20, groupbox.clientHeight - 35);						

	table.accessColumn(5).visible 	:= false;
	table.accessColumn(4).visible 	:= false;
	table.readOnly 					:= true;
	table.disableEvents 			:= true;
	
	table.showOnlySelectedFromObjectRORO(null);
epilog

end;</source>
    </JadeMethod>
