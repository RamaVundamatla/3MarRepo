    <JadeMethod name="jtdRunRecordApp" id="63a2e02e-c001-456b-ad14-79ede2310c5e">
        <source>jtdRunRecordApp();

vars
	i,j:Integer; s,t:String;
	tran:JmtTransactionGenerator;
begin
	app.controlLockAcquire;
	app.controlLockRelease;
	app.initialize;
	app.sequenceId:=5;
	create tran;
	tran.startup;
epilog
	delete tran;
end;</source>
