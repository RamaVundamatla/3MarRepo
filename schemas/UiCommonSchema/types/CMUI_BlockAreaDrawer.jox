    <JadeMethod name="setForCreate" id="7a8af883-0f44-406b-8ba2-90c0a8c4882e">
        <updating/>
        <source>setForCreate(terminalArea : CM_IrregularBlockArea; blockAreaFrame : CMUI_BlockAreaFrame; _parentForm : CM_BaseForm) updating;
// Set up the drawer after it has been created
vars
	yalloc : CM_YardAllocation;
begin
	self.myTerminalArea := terminalArea;
	self.myDrawingFrame := blockAreaFrame.myDrawingFrame;
	self.myYardAllocationDrawingFrame := blockAreaFrame.myYardAllocationDrawingFrame;
	self.myHLabels		:= blockAreaFrame.myScrollableFrame.myHLabels;
	self.myVLabels		:= blockAreaFrame.myScrollableFrame.myVLabels;
	
	self.initYardAllocations();
	self.setScale(2, true, true);
	self.gridLineWidth := 1;
	self.gridBorderWidth := 2;
	self.colourBorder := Blue;
	self.colourCell := White;
	self.colourGridLine := LightGray;
	self.colourLocation := Grey;
	self.colourSelectedCell := Blue;
	self.colourSelectedLocation := Red;
	self.colourSelectedForCopy := Yellow;	//23 Aug 2013	NDL	Par 32308
end;</source>
        <Parameter name="terminalArea" type="CM_IrregularBlockArea"/>
        <Parameter name="blockAreaFrame" type="CMUI_BlockAreaFrame"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setFrameSize" id="8b195bf0-e0d8-45b4-9293-102b3de67f20">
        <source>setFrameSize() protected;
// Calculate the size of the grid frame then resize the frame
vars
	x, y : Integer;
begin	
	// The extra 2 pixels are added to hack around the fact that drawRectangle centers the border line
	x := (gridBorderWidth * 2) + 2 + (self.myTerminalArea.columns * cellSize.x) + ((self.myTerminalArea.columns - 1) * gridLineWidth);
	y := (gridBorderWidth * 2) + 2 + (self.myTerminalArea.rows * cellSize.y) + ((self.myTerminalArea.rows - 1) * gridLineWidth);
	self.myDrawingFrame.resize(x, y);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMode" id="f7050df5-683c-4f5b-b2e1-5830d1e3786b">
