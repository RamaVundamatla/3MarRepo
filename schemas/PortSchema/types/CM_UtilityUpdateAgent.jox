        <source>utlUpdateShipBlockController(pProxyShipBlockController:CM_ShipBlockController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 	navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	cancelSave				: Boolean;
	realShipBlockController	: CM_ShipBlockController;
	expectedEdition			: Integer;
	
begin

	self.initialiseActivity();

	pProxyShipBlockController.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyShipBlockController.pxyGetRealObjectAndEdition(realShipBlockController, expectedEdition);
	
	if realShipBlockController = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ShipBlockController.name, null, null);
		return;
	endif;

	app.myValUA.valShipBlockController(realShipBlockController, pProxyShipBlockController, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realShipBlockController);

	if _passport.noErrors and realShipBlockController.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ShipBlockController', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realShipBlockController.setForUpdate(pProxyShipBlockController);
	endif;

epilog
end;</source>
        <Parameter name="pProxyShipBlockController" type="CM_ShipBlockController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipDeck" id="440c0024-0ab1-497a-bc5d-1c0cc3956cb2">
        <updating/>
        <source>utlUpdateShipDeck(_pxyObject : CM_ShipDeck; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realObject		: CM_ShipDeck;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Ship Deck Object');

	app.setContinueCMExceptions(true);
	
	app.myValCA.valShipDeck(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Ship Deck Object', _passport).CM_ShipDeck;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_ShipDeck"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipDeckLayer" id="08a86765-a884-42ec-b432-eae2dc78cd52">
