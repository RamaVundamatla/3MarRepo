        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFormsInSchema" id="7627ddf4-d548-411b-879f-71c5ea8f23c5">
        <source>getFormsInSchema(allForms : ObjectSet io);

vars
	startime, endtime	: Integer;
	form				: Form;
	schema				: Schema;

begin
	allForms.clear();
	schema := lblOptions_schema.listObject.Schema;
	
	if schema = null then 
		Form.instances.copy(allForms);
		return;
	endif;

	foreach form in Form.instances do
		if schema.superschema.getClass(form.name) &lt;&gt; null then	
			// it's in a superschema, thereform is not unique
		elseif schema.getClass(form.name) &lt;&gt; null then
			allForms.add(form);	// form is in this schema
		elseif chkSubschemas.value and schema.findClassInSubschema(form.name) &lt;&gt; null then
			allForms.add(form);	// form is in a subschema
		endif;
	endforeach;
end;</source>
        <Parameter name="allForms" type="ObjectSet" usage="io"/>
    </JadeMethod>
