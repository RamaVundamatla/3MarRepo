    <JadeMethod name="isTerminal_PortsOfCallTranship" id="c6596382-3214-495d-bc86-ee4e64cae970">
        <source>isTerminal_PortsOfCallTranship( _terminal : CM_Terminal ) : Boolean;

/*

Purpose:		This method will either establish if the supplied terminal has the configuration option
				of ShowPortOfCallTranship on or if no terminal is supplied then if ANY terminal has the
				configuration option of ShowPortOfCallTranship on.

Date				Who		Reason
29 May 2009			cnwrl1	Initial creation as part of PAR 19672

*/
	
vars
	cm_Terminal		: CM_Terminal;
	
begin
	if _terminal = null then
		foreach cm_Terminal in app.myRoot.allTerminals do
			if cm_Terminal.getConfig( ShowPortOfCallTranship ).Boolean then
				return true;
			endif;
		endforeach;
	else
		return _terminal.getConfig( ShowPortOfCallTranship ).Boolean;
	endif;
	
	return false;
	
epilog
	
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
