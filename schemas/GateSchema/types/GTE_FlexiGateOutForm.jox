    <JadeMethod name="setTblDataDetailCellText" id="305d9aa7-1bec-4565-a116-29b4f701e093">
        <updating/>
        <source>setTblDataDetailCellText(_tbl : CM_DataTable input) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//----------------------------------------------------------------------

vars
	cntrl : Control;
	table : CM_DataTable;
begin
	table := _tbl;
	
	if (not table.userInputEnabled)
	or table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblWorkEntryCols" id="0fbdfa18-3b4c-442e-9389-c5de91f03a65">
        <updating/>
        <source>setTblWorkEntryCols() protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 June 2007
//
//----------------------------------------------------------------------

vars

begin
	//Receivals Table
	self.locationColumn := self.tblReceivals.getColumnByRowName(ETRow_TargetLocation);
	self.cargoTypeColumn := self.tblReceivals.getColumnByRowName(ETRow_CargoTypeDescr);	
	//Release Table
	self.cargoIdColumnRelease := self.tblReleases.getColumnByRowName(ETRow_Id);
	self.cargoTypeColumnReleaseTable := self.tblReleases.getColumnByRowName(ETRow_CargoTypeDescr);
end;</source>
