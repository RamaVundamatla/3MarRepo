    <JadeMethod name="getForm" id="b5bc5e93-4680-4eba-be90-4b1fb1d4b786">
        <source>getForm(formName : String) : Form;

vars
	object	: Object;
	form	: Form;

begin
	foreach object in aAllForms do
		form := object.Form;
		
		if form.name = formName then
			return form;
		endif;
	endforeach;

	return null;
end;</source>
        <Parameter name="formName" type="String"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="getOptionButtons" id="62f56ecf-20aa-4a20-835f-acc0bd797e09">
        <source>getOptionButtons() : Integer;

// returns the appropriate value - 0, 1, 2 - corresponding to the listing options

begin
	if optList.value then
		return self.LIST_ONLY;
	elseif optStatistics.value then
		return self.STATS_ONLY;
	elseif optAllDetails.value then
		return self.ALL_DETAILS;
	else
		return self.LIST_ONLY;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedForms" id="6299159d-6333-4a13-a82f-3178e5636f8c">
        <updating/>
        <source>getSelectedForms(pAllForms : ClassColl io) updating;

// updates the Collection filled with the forms selected in the table tblSelectedForms

vars
	rowPointer		: Integer;
	
begin
	pAllForms.clear();

	rowPointer := 1;

	while rowPointer &lt;= tblSelectedForms.rows do
		tblSelectedForms.row	:= rowPointer;
		tblSelectedForms.column	:= 1;
		
		if tblSelectedForms.selected then
			pAllForms.add(tblSelectedForms.itemObject.Class);
		endif;
		
		rowPointer := rowPointer + 1;
	endwhile;
/*	
	foreach cls in allValidForms do
		tblSelectedForms.row := myRow;
		if tblSelectedForms.selected then
			myForms.add( cls );
		endif;
		myRow := myRow + 1;
	endforeach;
*/
end;</source>
        <Parameter name="pAllForms" type="ClassColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getValidForms" id="2bbc8305-0fb4-46cc-8c39-64a08d2ab4c6">
        <updating/>
        <source>getValidForms(pDate : Date; pTheSchema : Schema; pAllForms : ClassColl io) updating;

// Adds forms from schema to myForms...
// 	... provided that the form was created or modified after the Date date. 
// Does not add duplicates

vars
	theClass	: Class;
	formDate	: Date;
	allClasses	: ClassColl;
	
begin
	allClasses	:=	pTheSchema.getAllClasses(false);
	
	foreach theClass in allClasses do	// false = do not include system classes
		if theClass.inheritsFrom(Form) and (theClass.schema = pTheSchema) then

			// cls is valid to be added
			// check date eligibility - then check if already added (which is slow...)

			formDate := theClass.cnEcGetModifyTimeStamp().Date;

  			if (pDate = null) or (formDate &gt;= pDate) then		// can add
				if not pAllForms.includes(theClass) then	// don't add if already added 
					pAllForms.add(theClass);
	  			endif;
			endif;
		endif;		
	endforeach;
epilog
	delete allClasses;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pAllForms" type="ClassColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleForm" id="83b7593b-f05c-4901-a9d9-218f0b94978b">
        <source>handleForm(pTheClass:Class; pTheFile:File; pDetailLevel:Integer);

//	produces output for a single class (form) 

vars
	theForm			: Form;
	theControl		: Control;
	theButton		: Button;
	theJadeMask		: JadeMask;
	theSheet		: Sheet;
	modifyDate		: Date;
	isNewForm		: Boolean;
	controlRating	: Integer;		// estimate of time to do online help
	adjustedRating	: Integer;
	sheetCount		: Integer;		// recording how many sheets
	buttonsCount	: Integer;		// for record defining how many buttons...
	juiceCount		: Integer;		// for how many juice controls (aka buttons)
	allButtons		: StringArray;	// most info about buttons
	allBubbles		: StringArray;	// 'cos of limit on StringArray
	allSheets		: StringArray;	// names of sheets
	arrayPointer	: Integer;
	bubbleText		: String;
	guiCaption		: String;
	helpChar		: Character;
	newChar			: Character;

begin
	theForm := self.getForm(pTheClass.name);
	modifyDate := pTheClass.cnEcGetModifyTimeStamp().Date;
	
	if theForm &lt;&gt; null then
		isNewForm := theForm.creationTime().Date &gt;= self.aEarliestDate;
		create allButtons transient;
		create allBubbles transient;
		create allSheets transient;
	endif;

	if pDetailLevel = self.LIST_ONLY then
		if theForm = null then
			pTheFile.writeLine(pTheClass.name &amp; Tab &amp; "NO FORM " &amp; Tab &amp; " " &amp; Tab &amp; "!" &amp; Tab &amp; "*" &amp; Tab &amp; modifyDate.String &amp; Tab); 	
			return;
		endif;

		if theForm.helpKeyword &lt;&gt; null then
			if theForm.helpKeyword &lt;&gt; theForm.name then
				helpChar := "!";	// possible error in helpKeyword
			else
				helpChar := " ";	// probably ok
			endif;
		else
			helpChar := "?";		// no helpKeyword
		endif;

		if isNewForm then
			newChar := "1";			// newly created file
		else
			newChar := "0";
		endif;

		pTheFile.writeLine(theForm.name &amp; Tab &amp; theForm.caption &amp; Tab &amp; theForm.helpKeyword &amp; Tab &amp; helpChar &amp; Tab &amp; newChar &amp; Tab &amp; modifyDate.String &amp; Tab &amp; theForm.creationTime.Date.String);

	elseif pDetailLevel = self.STATS_ONLY then
		if theForm = null then
			pTheFile.writeLine(pTheClass.name &amp; Tab &amp; "NO FORM" &amp; Tab &amp; " " &amp; Tab &amp; "0" &amp; Tab &amp; "0" &amp; Tab &amp; "0" &amp; Tab &amp; "0" &amp; Tab &amp; "0");
			return;
		endif;

	   	arrayPointer := 1;
	   	buttonsCount := 0;
	   	sheetCount := 0;
	   	controlRating := 0;

       	while arrayPointer &lt;= theForm.controlCount do 
			theControl := theForm.controls(arrayPointer);
			if theControl.isKindOf(Button) then
				buttonsCount := buttonsCount + 1;
			elseif theControl.isKindOf(JadeMask) then
				juiceCount := juiceCount + 1;
			elseif theControl.isKindOf(Sheet) then
				sheetCount := sheetCount + 1;
			endif;
			arrayPointer := arrayPointer + 1;
		endwhile;

		if sheetCount = 0 then
			if buttonsCount + juiceCount &lt; 3 then
				controlRating := 1;
			elseif buttonsCount + juiceCount &lt; 5 then
				controlRating := 2;
			elseif theForm.controlCount &lt; 30 then
				controlRating := 3;
			else
				controlRating := 4;
			endif;
		elseif sheetCount &lt; 3 then
			if theForm.controlCount &lt; 50 then
				controlRating := 5;
			else
				controlRating := 6;
			endif;		
		elseif sheetCount &lt; 6 then
			if theForm.controlCount &lt; 100 then
				controlRating := 7;
			else
				controlRating := 8;
			endif;
		else
			if theForm.controlCount &lt; 150 then
				controlRating := 9;
			else
				controlRating := 10;
			endif;		
		endif;

		adjustedRating := controlRating;

		if not isNewForm then	// halve rating for modify
			adjustedRating := (adjustedRating + 1) div 2;
			pTheFile.writeLine(	pTheClass.name &amp;
								Tab &amp; theForm.caption &amp;
								Tab &amp; theForm.helpKeyword &amp; " * " &amp;
								Tab &amp; theForm.controlCount.String &amp;
								Tab &amp; (buttonsCount + juiceCount).String &amp;
								Tab &amp; sheetCount.String &amp;
								Tab &amp; controlRating.String &amp;
								Tab &amp; adjustedRating.String ); 
		else
			pTheFile.writeLine(	pTheClass.name &amp;
								Tab &amp; theForm.caption &amp;
								Tab &amp; theForm.helpKeyword &amp;
								Tab &amp; theForm.controlCount.String &amp;
								Tab &amp; (buttonsCount + juiceCount).String &amp;
								Tab &amp; sheetCount.String &amp;
								Tab &amp; controlRating.String &amp;
								Tab &amp; adjustedRating.String);
		endif;

	elseif pDetailLevel = self.ALL_DETAILS then	// All details
		if theForm = null then
			pTheFile.writeLine("#" &amp; Tab &amp; pTheClass.name &amp; Tab &amp; "NO FORM" &amp; Tab &amp; " " &amp; Tab &amp; " ");
			return;
		endif;

		guiCaption := theForm.caption.trimBlanks();

		if guiCaption.pos(" Form", 1)  = 0 then	// add " Form" to caption
			guiCaption := guiCaption &amp; " Form";
		endif;

		pTheFile.writeLine("#" &amp; Tab &amp; theForm.name &amp; Tab &amp; guiCaption &amp; Tab &amp; theForm.helpKeyword &amp; Tab &amp; theForm.bubbleHelp);

	   	arrayPointer := 1;
	   	buttonsCount := 0;
	   	sheetCount := 0;

       	while arrayPointer &lt;= theForm.controlCount do 
			theControl := theForm.controls(arrayPointer);
			if theControl.isKindOf( Button ) then
				theButton := theControl.Button;
				bubbleText := theButton.bubbleHelp;
				bubbleText.replaceChar(Lf, " ");
				bubbleText.replaceChar(Cr.Character, " ");	// Cr is a String!
                                                        // StringArray has limit of 62 characters per string!
				if bubbleText.length &gt; self.MAX_LENGTH then 
//	write( form.name &amp; Tab &amp; str &amp; Tab &amp; str.length.String );
					bubbleText := bubbleText[1:self.MAX_LENGTH]; 
				endif;
				buttonsCount := buttonsCount + 1;								
				allButtons.add(theButton.tabIndex.String &amp; Tab &amp; theButton.name &amp; Tab &amp; theButton.caption);
				allBubbles.add(bubbleText);

			elseif theControl.isKindOf(JadeMask) then
				theJadeMask := theControl.JadeMask;
				bubbleText := theJadeMask.bubbleHelp;
				bubbleText.replaceChar(Lf, " ");
				bubbleText.replaceChar(Cr.Character, " ");	// Cr is a String!
                                                        // StringArray has limit of 62 characters per string!
				if bubbleText.length &gt; self.MAX_LENGTH then 
//	write( form.name &amp; Tab &amp; str &amp; Tab &amp; str.length.String );
					bubbleText := bubbleText[1:self.MAX_LENGTH]; 
				endif;
				juiceCount := juiceCount + 1;								
				allButtons.add(theJadeMask.tabIndex.String &amp; Tab &amp; theJadeMask.name &amp; Tab &amp; theJadeMask.caption );
				allBubbles.add(bubbleText);

			elseif theControl.isKindOf(Sheet) then
				sheetCount := sheetCount + 1;
				theSheet := theControl.Sheet;
				allSheets.add(theSheet.caption);
			endif;
			arrayPointer := arrayPointer + 1;
		endwhile;

		if (buttonsCount + juiceCount) &gt; 0 then
			pTheFile.writeLine("b" &amp; (buttonsCount + juiceCount).String);
			arrayPointer := 1;
			while arrayPointer &lt;= (buttonsCount + juiceCount) do
				pTheFile.writeLine(allButtons[arrayPointer] &amp; Tab &amp; allBubbles[arrayPointer]);
				arrayPointer := arrayPointer + 1;
			endwhile;
		endif;
		
		if sheetCount &gt; 0 then
			pTheFile.writeLine("s" &amp; sheetCount.String);
			arrayPointer := 1;
			while arrayPointer &lt;= sheetCount do
				if theForm.name.length &gt; 0 then
					pTheFile.writeLine(allSheets[arrayPointer] &amp; " tab for " &amp; theForm.caption);
				else
					pTheFile.writeLine(allSheets[arrayPointer] &amp; " tab for " &amp; theForm.name);
				endif;
				arrayPointer := arrayPointer + 1;
			endwhile;
		endif;
//		f.writeLine("i" &amp; Tab &amp; form.controlCount.String &amp; " controls (" &amp; numSheets.String &amp; " sheets)"); 
	endif;	// All details
epilog
	delete allButtons;
	delete allBubbles;
	delete allSheets;
end;</source>
        <Parameter name="pTheClass" type="Class"/>
        <Parameter name="pTheFile" type="File"/>
        <Parameter name="pDetailLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleOK" id="fe86b8c1-a553-495d-8686-4539bfdeb2f3">
        <updating/>
        <source>handleOK() updating;

//	processes a click on the OK button

vars
	detailLevel	: Integer;
	theFile		: File;
	theClass	: Class;
	numForms	: Integer;
	countForms	: Integer;
    todaysDate	: Date;
    
begin
	detailLevel := self.getOptionButtons();
	
	if optSelectedForms.value then 
		self.getSelectedForms(self.aAllValidFormsAsClasses);
	endif;

	theFile := self.openFile(detailLevel);

	if theFile &lt;&gt; null then
		numForms := self.aAllValidFormsAsClasses.size();

		theFile.writeLine("Forms information extracted " &amp; todaysDate.display);
		theFile.writeLine("Copyright Aoraki Corporation " &amp; todaysDate.format("yyy"));
		theFile.writeLine(" ");

		if detailLevel = self.LIST_ONLY then
			theFile.writeLine("Forms (" &amp; numForms.String &amp; ") modified since " &amp; aEarliestDate.display);
			theFile.writeLine(" ");
			theFile.writeLine("1 form is new");
			theFile.writeLine("! Help Keyword does not match form name");
			theFile.writeLine("? Help Keyword is undefined");
			theFile.writeLine(" ");
			theFile.writeLine("Form" &amp; Tab &amp; "Caption" &amp; Tab &amp; "Help Keyword" &amp; Tab &amp; "Attn" &amp; Tab &amp; "New" &amp; Tab &amp; "Last Modified" &amp; Tab &amp; "Created");
		elseif detailLevel = self.STATS_ONLY then
			theFile.writeLine("Forms (" &amp; numForms.String &amp; ") modified since " &amp; aEarliestDate.display);
			theFile.writeLine(" ");		
			theFile.writeLine("Forms with name followed by an asterisk (*) are NOT new, and will have adjusted values.");
			theFile.writeLine(" ");
			theFile.writeLine("Form" &amp; Tab &amp; "Caption" &amp; Tab &amp; "Help Keyword" &amp; Tab &amp; "Controls" &amp; Tab &amp; "Buttons" &amp; Tab &amp; "Sheets" &amp; Tab &amp; "Rating" &amp; Tab &amp; "Adjusted");
		elseif detailLevel = self.ALL_DETAILS then
			theFile.writeLine("Online help skeletons for forms (" &amp; numForms.String &amp; ") modified since " &amp; self.aEarliestDate.display);
		endif;
		
		theFile.writeLine(" ");
		progressBar.partsInJob := numForms;
		countForms := 0;

		foreach theClass in self.aAllValidFormsAsClasses do
			countForms := countForms + 1;
			progressBar.partsDone := countForms;
			self.handleForm(theClass, theFile, detailLevel);
		endforeach;

		theFile.close();
		delete theFile;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="b10a17f4-65bd-47b2-86bf-0176ca3a582d">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
