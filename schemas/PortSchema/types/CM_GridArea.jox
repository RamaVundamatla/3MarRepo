    <JadeMethod name="testOverstowForkLiftOld" id="9ba31083-e00c-41a0-b1bc-045ca673474d">
        <updating/>
        <source>testOverstowForkLiftOld(obj: CMIF_AutoMovePlan io; lOrdinalColumns	: IntegerArray; originalTI, _toMoveTI : CM_TrackedItem; lWorkingFromFront : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2001 By Andrew Bishop cnwab1
//
// Purpose:		Tests locations that are suitable to have overstow TIs moved to. These locations must be accessible from the front/back of the yard
//				i.e. they must not be full and they must not have anything infront of them. They cannot be in the same column as the source or target 
//				for the original move
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lcToTest 							: CM_LocationsController;
	closestNextLC,
	nextLC,
	priorLC, 
	closestPriorLC 						: CM_StackController;
	startCol,	lSauceAccess, 
	lTargetAccess, lCol,
	lRow, i, 
	closestNext, closestPrior, 
	lLoop,rowAccessHeight,
	lORow, lOCol,
	startRow							: Integer;
	ta									: CM_ForkLiftStack;
	lLeft, lTIToMoveIs40, 
	lTIOriginalIs40						: Boolean;
	sourceLocn, targetLocn, 
	toMoveSource						: CM_StackController;
	lControllerArray					: CM_LCArray;
	
begin
/*
	write 'Moving TI ' &amp; _toMoveTI.id;
	lTIToMoveIs40 := _toMoveTI.getNumberOfControllers(REAL_MODE) &gt; 1;
	lTIOriginalIs40 := originalTI.getNumberOfControllers(REAL_MODE) &gt; 1;

	sourceLocn		:= originalTI.getPrimaryLocation(REAL_MODE).CM_StackController;
	toMoveSource	:= _toMoveTI.getPrimaryLocation(REAL_MODE).CM_StackController;
	ta := sourceLocn.myTerminalArea.CM_ForkLiftStack;
	// if the target is not a STack i.e. it is a wagon or a slot then for the purposes of this overstow logic make it the same as the source
	// this should not matter as the target location in this method is used to check ordinal columns and rows etc to make sure that the overstow TI
	// is not put in the way of the traget location of the actual TI move
	if originalTI.getPrimaryLocation(QUEUE_MODE).isKindOf(CM_StackController) then
		targetLocn := originalTI.getPrimaryLocation(QUEUE_MODE).CM_StackController;
	else
		targetLocn := sourceLocn;
	endif;
	
	startCol := sourceLocn.myGridColumn.column;
	if startCol &lt; (self.numberOfColumns / 2) then // try to a bit more efficient by looking which side of the area we are on roughly
		lLeft := true;
	else
		lLeft := false;
	endif;
	
	lLoop := 0;
	rowAccessHeight := 0;
	// added loop so that if we are working from the back, but we can not find anywhere to place the overstow, then 
	// we come around again and look from the front
	while lLoop &lt; 2 do
	// With FLS not every location is available. If containers are in front or behind then the pad is inaccessible
	if not lWorkingFromFront or (lLoop = 1 and self.CM_ForkLiftStack.accessFront and obj.getController = null ) then
		// go through all the locations that are in my row and the rows in front of me, test whether they can be accessed. 
		// We start in my row and work out to try to get the nearest location
			if not lWorkingFromFront then 
				startRow := sourceLocn.myGridRow.row;
	
			else
				startRow := sourceLocn.myGridRow.row - 1;			
			endif;
	      foreach lRow in 1 to startRow reversed do : rowLoopFront // note ordinals are zero based

			// pass in the first controller in this row to test for the height availability for this whole row.
			// if it is empty this will pass back the max height for the area,
			// if the system is set to stack evenly it will check the stagger height etc
   			rowAccessHeight := self.testOverstowLCAvailability(self.allGridRows[lRow].allControllersByColumn[1].CM_StackController);
   			obj.iteration := rowAccessHeight;
   			
	      	if lLeft then // on the left hand side

		    	  	foreach lcToTest in self.allGridRows[lRow].allControllersByColumn do
		    	  	write 'working from Back left ' &amp; lcToTest.ident;
					if (lcToTest.isKindOf(CM_GapController)) or (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs) &gt;= rowAccessHeight then
						write 'Failed first test';
						continue;
					endif;
		    	  	
		    	  		// if lLoop equals 1  it means that we are working from the back and are now trying the front, so we do not need to check the ordinal columns
		    	  		if lLoop &lt;&gt; 1 then
						// not in front the source or the target, or any overstow 40s, thank you very much..
						lcToTest.CM_StackController.getMyRowColOrdinal( lORow, lOCol);
						if lOrdinalColumns.includes(lOCol) then
							write 'Ordinal Columns includes';
							continue;
						endif;
					endif;			
				
					if lcToTest.CM_StackController.testIsControllerSuitable(lTIOriginalIs40,lTIToMoveIs40, lLoop &gt; 0, sourceLocn,targetLocn, TA_ACCESS_BACK) then		
						lcToTest.testOverstowMoveLocation(obj);
						if obj.getController &lt;&gt; null then  //found a space
							write 'Is suitable';
							obj.addLogEntry(obj.getController.CM_StackController.getFullId &amp; " is suitable", IsForLogging);
				    		break rowLoopFront;
				    	else
				    		write lcToTest.ident &amp; ' failed testOverStowMoveLocation';
	    				endif;
	    			else
	    				write lcToTest.ident &amp; ' failed testIsControllerSuitable';
					endif;
				endforeach;			
			else // RIGHT

		    	  	foreach lcToTest in self.allGridRows[lRow].allControllersByColumn reversed do
		    	  	write 'working from back right ' &amp; lcToTest.ident;
					if (lcToTest.isKindOf(CM_GapController)) or (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs) &gt;= rowAccessHeight then
						continue;
					endif;
		    	  		// if lLoop equals 1  it means that we are working from the back and are now trying the front, so we do not need to check the ordinal columns
		    	  		if lLoop &lt;&gt; 1 then
						// not in front the source or the target, or any overstow 40s, thank you very much..
						lcToTest.CM_StackController.getMyRowColOrdinal( lORow, lOCol);
						if lOrdinalColumns.includes(lOCol) then
							write 'Ordinal Columns includes';
							continue;
						endif;
					endif;					
					if lcToTest.CM_StackController.testIsControllerSuitable(lTIOriginalIs40,lTIToMoveIs40, lLoop &gt; 0, sourceLocn,targetLocn,TA_ACCESS_BACK) then		

						// this tests the pad. Is it available, need power, is it full and in our case it 
						// should also work out a nice even stacking height
						lcToTest.testOverstowMoveLocation(obj);

						if obj.getController &lt;&gt; null then  //found a space

	  						closestNextLC := obj.getController.CM_StackController;
							obj.addLogEntry(closestNextLC.getFullId &amp; " is suitable");
				    			break rowLoopFront;
	    				else
				    		write lcToTest.ident &amp; ' failed testOverStowMoveLocation';
	    				endif;
	    			else
	    				write lcToTest.ident &amp; ' failed testIsControllerSuitable';
					endif;
				endforeach;			
			
			endif;
		endforeach;
	endif;

	// working from the back OR working from the front could not find anywhere, and we have access from the back, look around the back
	if ( lWorkingFromFront and lLoop = 0)
	or (obj.getController = null and ta.accessBack and lLoop = 0) then
		// go through all the container that are in my row and the rows behind me, test whether they can be accessed. 
		// We start in my row and work out to try to get the nearest location
			if not lWorkingFromFront then 
				startRow := sourceLocn.myGridRow.row + 1;
			else
				startRow := sourceLocn.myGridRow.row;
			endif;
	      foreach lRow in startRow to self.numberOfRows do : rowLoopBack // note ordinals are zero based
			// pass in the first controller in this row to test for the height availability for this whole row.
			// if it is empty this will pass back the max height for the area,
			// if the system is set to stack evenly it will check the stagger height etc
   			rowAccessHeight := self.testOverstowLCAvailability(self.allGridRows[lRow].allControllersByColumn[1].CM_StackController);
   			obj.iteration := rowAccessHeight;
	      	if lLeft then

		    	  	foreach lcToTest in self.allGridRows[lRow].allControllersByColumn do
						write 'Working from front left ' &amp; lcToTest.ident;
					if  (lcToTest.isKindOf(CM_GapController)) or (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs) &gt;= rowAccessHeight then
						write 'Failed first test working from back';
						continue;
					endif;

		    	  		// if lWorkingFromFront equals TRUE it means that we are working from the front and are now trying the back (cos we did not finding anywhere), 
		    	  		// so we do not need to check the ordinal columns
		    	  		if lWorkingFromFront then
						// not in front the source or the target, or any overstow 40s, thank you very much..
						lcToTest.CM_StackController.getMyRowColOrdinal( lORow, lOCol);
						if lOrdinalColumns.includes(lOCol) then
							write 'Ordinal Columns includes';
							continue;
						endif;
					endif;					
					if lcToTest.CM_StackController.testIsControllerSuitable(lTIOriginalIs40,lTIToMoveIs40, lLoop &gt; 0, sourceLocn,targetLocn, TA_ACCESS_FRONT) then		

						// this tests the pad. Is it available, need power, is it full and in our case it 
						// should also work out a nice even stacking height
						lcToTest.testOverstowMoveLocation(obj);

						if obj.getController &lt;&gt; null then  //found a space
							write 'Is suitable';
				   			closestPriorLC := obj.getController.CM_StackController;
							obj.addLogEntry(closestPriorLC.getFullId &amp; " is suitable");
				    			break rowLoopBack;
	    				else
				    		write lcToTest.ident &amp; ' failed testOverStowMoveLocation';
	    				endif;
	    			else
	    				write lcToTest.ident &amp; ' failed testIsControllerSuitable';
					endif;
				endforeach;			
			else
		    	foreach lcToTest in self.allGridRows[lRow].allControllersByColumn reversed do
					write 'Working from front right ' &amp; lcToTest.ident;
					if (lcToTest.isKindOf(CM_GapController)) or (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs) &gt;= rowAccessHeight then
						continue;
					endif;

		    	  		// if lWorkingFromFront equals TRUE it means that we are working from the front and are now trying the back (cos we did not finding anywhere), 
		    	  		// so we do not need to check the ordinal columns
		    	  		if lWorkingFromFront then
						// not in front the source or the target, or any overstow 40s, thank you very much..
						lcToTest.CM_StackController.getMyRowColOrdinal( lORow, lOCol);
						if lOrdinalColumns.includes(lOCol) then
							write 'Ordinal Columns includes';
							continue;
						endif;
					endif;					
					if lcToTest.CM_StackController.testIsControllerSuitable(lTIOriginalIs40,lTIToMoveIs40, lLoop &gt; 0, sourceLocn,targetLocn,TA_ACCESS_FRONT) then		

						// this tests the pad. Is it available, need power, is it full and in our case it 
						// should also work out a nice even stacking height
						lcToTest.testOverstowMoveLocation(obj);

						if obj.getController &lt;&gt; null then  //found a space
							write 'Is suitable';
				   			closestPriorLC := obj.getController.CM_StackController;
							obj.addLogEntry(closestPriorLC.getFullId &amp; " is suitable");
				    			break rowLoopBack;
	    					else
				    		write lcToTest.ident &amp; ' failed testOverStowMoveLocation';
	    				endif;
	    			else
	    				write lcToTest.ident &amp; ' failed testIsControllerSuitable';
					endif;
				endforeach;			
			
			endif;
		endforeach;
	endif;
	write 'Loop - ' &amp; lLoop.String;
	if obj.getController = null then
		lLoop := lLoop + 1;
	else
		lLoop := 10;
	endif;
	endwhile;
*/
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="io"/>
        <Parameter name="lOrdinalColumns" type="IntegerArray"/>
        <Parameter name="originalTI" type="CM_TrackedItem"/>
