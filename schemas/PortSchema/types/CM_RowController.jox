    <JadeMethod name="getProximity" id="fad2b281-ca93-4761-9e57-cab727548990">
        <source>getProximity(_otherLC: CM_RowController; vertProx: Integer output; horzProx: Integer output; depthProx: Integer output);
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	vertical span = accross rows
			horizontal span = N/A - rows only
			depth span = N/A 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myRow = null or _otherLC.myRow = null then
		return;
	endif;
	
	vertProx := (self.myRow.getRowPosition - _otherLC.myRow.getRowPosition).positive;

	
	
end;


</source>
        <Parameter name="_otherLC" type="CM_RowController"/>
        <Parameter name="vertProx" type="Integer" usage="output"/>
        <Parameter name="horzProx" type="Integer" usage="output"/>
        <Parameter name="depthProx" type="Integer" usage="output"/>
    </JadeMethod>
