    <JadeMethod name="create" id="449ccb51-e969-4557-9e42-fabec7eb2aa2">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
03 Sep 2024	navnk30		Bug 65602: FR - 54089 - Invoice Contract - permissions

*/

vars

begin
	//self.permissionView := PmInvContractEnqView ;		//03.09.2024 navnk30 #65602
	self.permissionView := PmInvContractMaintView;		//03.09.2024 navnk30 #65602
	self.permissionMaint := PmInvContractMaintMaint; 
	
	self.helpFileName		:= HelpFile_Invoicing;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createContractDetail" id="2a14f3b7-1638-4c62-8b85-33643fc31408">
        <updating/>
        <source>createContractDetail()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
07 Mar 2023 navtnr20 	Bug 56765: EUP - Criteria Priority not being saved
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/
vars
	pxyCon, realCon 		: CM_InvoiceContractDetails;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	involeceLine 					: CM_InvoiceLineDesc;
	desc,contractID			: String;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	
	volumeBased,receiveRoad, receiveShip, receiveRail				: Boolean;
	unitofMeasure : CM_InvoiceUnitOfMeasure;
	shipTerm : CM_InvoiceContractShipTerm;
	calculationType : CM_CalculationType;
	realcontracr : CM_InvoiceContract;
	type, accumulationType : Integer;
		theReturn : Integer;
	criteria  : CM_YACriteria;
	priority : Integer;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if self.cmbInvoiceLine.listIndex &lt;&gt; -1 then
		involeceLine := self.cmbInvoiceLine.itemObject[self.cmbInvoiceLine.listIndex].CM_InvoiceLineDesc;
	endif;
	if self.cmbUnitOfMeasure.listIndex &lt;&gt; -1 then
		unitofMeasure := self.cmbUnitOfMeasure.itemObject[self.cmbUnitOfMeasure.listIndex].CM_InvoiceUnitOfMeasure;
	endif;
	if self.cmbShippingTerm.listIndex &lt;&gt; -1 then
		shipTerm := self.cmbShippingTerm.itemObject[self.cmbShippingTerm.listIndex].CM_InvoiceContractShipTerm;
	endif;
	if self.cmbCalculationTypes.listIndex &lt;&gt; -1 then
		calculationType := self.cmbCalculationTypes.itemObject[self.cmbCalculationTypes.listIndex].CM_CalculationType;
	endif;
	scheduleTSstart.setDate(self.mskContractFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskContractFromStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskContractFromEnd.text.asDateJMT());
	scheduleTSend.setTime(self.mskContractFromEndTime.text.asTimeJMT());
	if self.chkVolume.value then
		type := INV_CONTRACT_TYPE_VOLUME_BASED;
	else
		type := INV_CONTRACT_TYPE_STANDARD;
	endif;
	//Start  //15-03-2023 navtnr20 CR 55647 TASK 55696
	receiveRoad := self.chkReceiveRoad.value;
	receiveRail := self.chkReceiveRail.value;
	receiveShip := self.chkReceiveShip.value;
	
	if self.optAccPeriod.value then
		accumulationType := INV_VOL_BASED_PERIOD;
	else
		accumulationType := INV_VOL_BASED_VOYAGE;
	endif;
	//End  //15-03-2023 navtnr20 CR 55647 TASK 55696
	if self.myPxyContractDetails.myInvoiceContractCriteria &lt;&gt; null then // ### TFS BUG 56879 02MAR2023 NAVAB1
		priority := self.myPxyContractDetails.myInvoiceContractCriteria.priority; // ### TFS BUG 56879 02MAR2023 NAVAB1
	endif;
	//create pxyCon transient;
	 self.myPxyContractDetails.setProxy(null,type,priority, self.localToSystemTime(scheduleTSstart), self.localToSystemTime(scheduleTSend),calculationType , self.myInvoiceContract, involeceLine, self.myCurrentBank,shipTerm,unitofMeasure); // ### BUG 58796 26JUN2023 NAVAB1 'localToSystemTime'
	 if self.myPxyContractDetails.isKindOf(CM_InvoiceContractDtlsVolBased) then	 //15-03-2023 navtnr20 CR 55647 TASK 55696
		self.myPxyContractDetails.CM_InvoiceContractDtlsVolBased.setProxyVolBased(receiveRail,receiveRoad,receiveShip,accumulationType); //15-03-2023 navtnr20 CR 55647 TASK 55696
	endif;
	
	while true do
		app.myTrxCA.trxCreateInvContractDtl(self.myPxyContractDetails, realCon, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.myContractDetails	:= realCon;
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoic_contra_detail_create_su), app.getErrorString(Message),MsgBox_OK_Only);
			self.btnAdd.enabled := true;
			self.btnRemoveRate.enabled := true;
			self.btnRemoveRtEnt.enabled := true;
			self.btnUpdate.enabled := true;
			self.cmbService.enabled := true;
			//self.updateMode := true; //31/01/2023	navkc1 Bug 61578
			self.mode := self.MODE_UPDATE; //31/01/2023	navkc1 Bug 61578
			//self.btnUpdateDates.visible := true; //23-03-2023 navtnr20 57226 //25/10/2023 navmv20 CR 60503 Task 60505
			self.chkVolume.enabled := false;	//15-03-2023 navtnr20 CR 55647 TASK 55696
			self.handleService(); //navtnr20 06-03-2023 56765
			delete self.myPxyContractDetails ;
 // ### TFS BUG 56908 15MAR2023 NAVAB1			self.myPxyContractDetails := app.createUpdateProxy(self.myContractDetails).CM_InvoiceContractDetails;
			self.pxyObjMatchCriteria := null; // ### TFS BUG 56765 03MAR2023 NAVTNR20
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contrac_details_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
 // ### BUG 57015 13MAR2023 NAVAB1	delete self.myPxyContractDetails;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCopiedContractDetail" id="8f9aab9b-1b55-43f9-861d-b801ac81426d">
        <updating/>
        <source>createCopiedContractDetail() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2023	navkc1 Bug 61578: EUP | FR 54089 - Invoice Contracts - Copy function extended

*/
vars
	pxyCon, realCon 		: CM_InvoiceContractDetails;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	involeceLine 					: CM_InvoiceLineDesc;
	desc,contractID			: String;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	
	volumeBased,receiveRoad, receiveShip, receiveRail				: Boolean;
	unitofMeasure : CM_InvoiceUnitOfMeasure;
	shipTerm : CM_InvoiceContractShipTerm;
	calculationType : CM_CalculationType;
	realcontracr : CM_InvoiceContract;
	type, accumulationType : Integer;
		theReturn : Integer;
	criteria  : CM_YACriteria;
	priority : Integer;
	service	: CM_Service;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if self.cmbInvoiceLine.listIndex &lt;&gt; -1 then
		involeceLine := self.cmbInvoiceLine.itemObject[self.cmbInvoiceLine.listIndex].CM_InvoiceLineDesc;
	endif;
	if self.cmbUnitOfMeasure.listIndex &lt;&gt; -1 then
		unitofMeasure := self.cmbUnitOfMeasure.itemObject[self.cmbUnitOfMeasure.listIndex].CM_InvoiceUnitOfMeasure;
	endif;
	if self.cmbShippingTerm.listIndex &lt;&gt; -1 then
		shipTerm := self.cmbShippingTerm.itemObject[self.cmbShippingTerm.listIndex].CM_InvoiceContractShipTerm;
	endif;
	if self.cmbCalculationTypes.listIndex &lt;&gt; -1 then
		calculationType := self.cmbCalculationTypes.itemObject[self.cmbCalculationTypes.listIndex].CM_CalculationType;
	endif;
	scheduleTSstart.setDate(self.mskContractFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskContractFromStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskContractFromEnd.text.asDateJMT());
	scheduleTSend.setTime(self.mskContractFromEndTime.text.asTimeJMT());
	if self.chkVolume.value then
		type := INV_CONTRACT_TYPE_VOLUME_BASED;
	else
		type := INV_CONTRACT_TYPE_STANDARD;
	endif;
	
	receiveRoad := self.chkReceiveRoad.value;
	receiveRail := self.chkReceiveRail.value;
	receiveShip := self.chkReceiveShip.value;
	
	if self.optAccPeriod.value then
		accumulationType := INV_VOL_BASED_PERIOD;
	else
		accumulationType := INV_VOL_BASED_VOYAGE;
	endif;
	if self.myPxyContractDetails.myInvoiceContractCriteria &lt;&gt; null then
		priority := self.myPxyContractDetails.myInvoiceContractCriteria.priority;
	endif;
	 self.myPxyContractDetails.setProxy(null,type,priority, self.localToSystemTime(scheduleTSstart), self.localToSystemTime(scheduleTSend),calculationType , self.myInvoiceContract, involeceLine, self.myCurrentBank,shipTerm,unitofMeasure); // ### BUG 58796 26JUN2023 NAVAB1 'localToSystemTime'
	 if self.myPxyContractDetails.isKindOf(CM_InvoiceContractDtlsVolBased) then	
		self.myPxyContractDetails.CM_InvoiceContractDtlsVolBased.setProxyVolBased(receiveRail,receiveRoad,receiveShip,accumulationType);
	endif;
	
	if self.cmbService.listIndex &gt; 0 then
		service := self.cmbService.listObject.CM_Service;
	endif;
	
	while true do
		app.myTrxCA.trxCreateCopiedContractDtl(self.myPxyContractDetails, realCon, service, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.myContractDetails	:= realCon;
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoic_contra_detail_create_su), app.getErrorString(Message),MsgBox_OK_Only);
			self.cmbService.enabled := true;
			self.mode := self.MODE_UPDATE;
			self.cmbInvoiceLine.enabled := false;
			self.handleService();
			delete self.myPxyContractDetails ;
			self.pxyObjMatchCriteria := null;
			
			//31/01/2023	navkc1 Bug 61578 - Contract is now created, enable these buttons so user can update the rates.
			self.btnAdd.enabled := true;
			self.btnAdd.setBubbleHelpForTranslation(app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0025716).text);
			self.btnRemoveRate.enabled := true;
			self.btnRemoveRate.setBubbleHelpForTranslation(app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0025718).text);
			self.btnRemoveRtEnt.enabled := true;
			self.btnRemoveRtEnt.setBubbleHelpForTranslation(app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0025719).text);
			self.btnUpdate.enabled := true;
			self.btnUpdate.setBubbleHelpForTranslation(app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0025721).text);
			self.btnNew.enabled := true;
			self.btnNew.setBubbleHelpForTranslation(app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0025717).text);
			
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contrac_details_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAddClick" id="63dd2c16-d992-422a-9c6d-0c6b9367448a">
        <source>doBtnAddClick();
/*
Purpose:			

Date		Who		Reason
26 June 2023	navab1	 BUG 58796
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/

vars

	form : INV_ContractRateEntryMaint;
	rateEntriesForm : INV_ContractRateEntriesMaint; //25/10/2023 navmv20 CR 60503 Task 60505
	cmifRateEntryDates : CMIF_ContractRateEntryDates; //25/10/2023 navmv20 CR 60503 Task 60505
	bank :CM_Bank;
	serv : CM_Service;
	rate : CM_InvoiceContractRate;
	defaultEntry : CM_InvoiceContractRateEntry;
	localTS : TimeStamp;
	calctype : CM_CalculationType;
begin
	serv := self.cmbService.listObject.CM_Service;
	if serv = null then
		app.msgBox(app.getErrorString(Please_select_service), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
		
	endif;
	
	if self.myInvLineDescription &lt;&gt; self.myContractDetails.myInvoiceLineType then // ### TFS BUG 56879 02MAR2023 NAVAB1
		app.msgBox(app.getErrorString(Invoi_line_type_chang_pleas_sa), app.getErrorString(Problem), MsgBox_OK_Only); // ### TFS BUG 56879 02MAR2023 NAVAB1
		return; // ### TFS BUG 56879 02MAR2023 NAVAB1
	endif;

	rate := self.myContractDetails.allInvContractRatesByService[serv];
	//25/10/2023 navmv20 CR 60503 Task 60505 - start
	rateEntriesForm := app.loadForm(INV_ContractRateEntriesMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateEntriesMaint;
	if rateEntriesForm &lt;&gt; null then
		rateEntriesForm.updateMode := false;
		rateEntriesForm.setInvoiceContractRate(rate);
		rateEntriesForm.setMyCurrentBank(self.myCurrentBank);
		rateEntriesForm.myService := serv;
		rateEntriesForm.myParentForm := self;
		cmifRateEntryDates := self.tblData.accessRow(self.tblData.row).itemObject.CMIF_ContractRateEntryDates;
		if cmifRateEntryDates &lt;&gt; null then
			defaultEntry := cmifRateEntryDates.allInvoiceContractRateEntries.last.CM_InvoiceContractRateEntry;
			if defaultEntry &lt;&gt; null then
				localTS := self.systemToLocalTime(defaultEntry.toTS.addDays(1));
				rateEntriesForm.mskStartDate.setDate(localTS.date);
				rateEntriesForm.mskStartTime.setTime(defaultEntry.myInvoiceContractRate.myInvoiceContractDetail.fromTS.time);
				rateEntriesForm.setFromTS(localTS);
				localTS := self.systemToLocalTime(rate.myInvoiceContractDetail.toTS);
				
				
				rateEntriesForm.mskEndDate.setDate(localTS.date);
				rateEntriesForm.mskEndTime.setTime(localTS.time);
				rateEntriesForm.setToTS(localTS);
			endif;
		endif;
			
		if defaultEntry = null then
			localTS := self.systemToLocalTime( self.myContractDetails.fromTS);
			rateEntriesForm.mskStartDate.setDate(localTS.date);
			rateEntriesForm.mskStartTime.setTime(localTS.time);
			rateEntriesForm.setFromTS(localTS);
			localTS := self.systemToLocalTime(self.myContractDetails.toTS);
			rateEntriesForm.mskEndDate.setDate(localTS.date);
			rateEntriesForm.mskEndTime.setTime(localTS.time);
			rateEntriesForm.setToTS(localTS);
		endif;
		rateEntriesForm.myContractDetail := self.myContractDetails;
		rateEntriesForm.centreWindow();
// ### TFS BUG 61374 27NOV2023 NAVAB1		rateEntriesForm.showModal;
		rateEntriesForm.show; // ### TFS BUG 61374 27NOV2023 NAVAB1
	endif;

	//25/10/2023 navmv20 CR 60503 Task 60505 - END
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCriteriaClick" id="d7b059cc-a244-4b92-bdc1-e19afac86aa9">
        <updating/>
        <source>doBtnCriteriaClick()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
07 Mar 2023 navtnr20 	Bug 56765: EUP - Criteria Priority not being saved
*/

vars

	pxyObjMatchCriteria : CM_InvoiceContractCriteria;
	form : CMUI_ObjectCriteriaLineForm;
	form1 : CMUI_YAMaintContractFrom;
	str : String;
	contObj : CM_InvoiceContractDetails;
	myForm : CM_BaseForm;
	criteriaForm 		  : CMUI_ObjectCriteriaLineForm;
begin
	if self.myPxyContractDetails = null 	//navtnr20 08-03-2023 bug 56765
		//and self.updateMode 	//navtnr20 08-03-2023 bug 56765
		and (self.mode = self.MODE_UPDATE or self.mode = self.MODE_COPY)//31/01/2023	navkc1 Bug 61578
		and self.myContractDetails &lt;&gt; null then	//navtnr20 08-03-2023 bug 56765
		self.myPxyContractDetails := app.createUpdateProxy(self.myContractDetails).CM_InvoiceContractDetails;	//navtnr20 08-03-2023 bug 56765
	endif;
	create form1;
	contObj := self.myPxyContractDetails;
	pxyObjMatchCriteria := contObj.myInvoiceContractCriteria;
	form1.setMyTerminal(self.myTerminal);
	form1.setBaseData(	contObj,	
						pxyObjMatchCriteria,
						null,	
						self,
						//self.updateMode // ### TFS BUG 56908 15MAR2023 NAVAB1
						self.mode = self.MODE_UPDATE //31/01/2023	navkc1 Bug 61578
					);
	
	if form1.showModal()= MsgBox_Return_OK then
		self.setCriteriaLabel(contObj);
	else
	endif;
	self.setCriteriaLabel(contObj); //navtnr20 08-03-2023 bug 56765
	self.pxyObjMatchCriteria := form1.doSaveCriteria();	//navtnr20 08-03-2023 bug 56765
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="5d06faa3-196d-40a3-a272-41d893afb36b">
        <updating/>
        <source>doBtnUpdateClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
15 March 2023	navmk20		Bug 57096: MTN - Minor UX issue when using contract maintenance
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	form : INV_ContractRateEntryMaint;
	bank :CM_Bank;
	contractRate : CM_InvoiceContractRateEntry;
	rateEntriesMaintForm : INV_ContractRateEntriesMaint; ///25/10/2023 navmv20 CR 60503 Task 60505
	rateEntryDates : CMIF_ContractRateEntryDates; //25/10/2023 navmv20 CR 60503 Task 60505
begin
		//25/10/2023 navmv20 CR 60503 Task 60505 - start
		rateEntryDates := self.tblData.accessRow(self.tblData.row).itemObject.CMIF_ContractRateEntryDates;
		if rateEntryDates = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		//25/10/2023 navmv20 CR 60503 Task 60505 - end
		
		if self.myInvLineDescription &lt;&gt; self.myContractDetails.myInvoiceLineType then
			app.msgBox(app.getErrorString(Invoi_line_type_chang_pleas_sa), app.getErrorString(Problem), MsgBox_OK_Only);
			return;
		endif;
		
		//25/10/2023 navmv20 CR 60503 Task 60505 - start
		if rateEntryDates &lt;&gt; null then
			if self.myRateEntryForm = null then // ### TFS BUG 61268 28NOV2023 NAVAB1
				self.myRateEntryForm := app.loadForm(INV_ContractRateEntriesMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateEntriesMaint;  // ### TFS BUG 61268 28NOV2023 NAVAB1
			endif;
			if self.myRateEntryForm &lt;&gt; null then
				rateEntriesMaintForm := self.myRateEntryForm; // ### TFS BUG 61268 28NOV2023 NAVAB1
				rateEntriesMaintForm.updateMode := true;
				rateEntriesMaintForm.setCMIFRateEntryDates(rateEntryDates);
				rateEntriesMaintForm.setInvoiceContractRate(self.myInvoiceContractRate);
				rateEntriesMaintForm.setMyCurrentBank(self.myCurrentBank);
				rateEntriesMaintForm.myContractDetail := self.myContractDetails;
				rateEntriesMaintForm.myService := self.myInvoiceContractRate.myService;
				rateEntriesMaintForm.myCalculationType := self.myInvoiceContractRate.myCalculationType; // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
				rateEntriesMaintForm.myParentForm := self;
				rateEntriesMaintForm.centreWindow();
				rateEntriesMaintForm.mdiChild := Form.MdiChild_IsMdi;
				rateEntriesMaintForm.show;
			endif;
		endif;
	//25/10/2023 navmv20 CR 60503 Task 60505- end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickChkVolume" id="7656f485-7960-4c92-8c55-b74df40e55af">
        <updating/>
        <source>doClickChkVolume() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15-03-2023 navtnr20 CR 55647 Task 55696: UI - Volume Based Contracts	

*/

vars
	contractcriteria : CM_InvoiceContractCriteria;
begin
	contractcriteria := self.myPxyContractDetails.myInvoiceContractCriteria;
	if contractcriteria &lt;&gt; null then
		contractcriteria.setProxyDetail(null);
	endif; 
	delete self.myPxyContractDetails;

	if self.chkVolume.value = true then	
		create self.myPxyContractDetails as CM_InvoiceContractDtlsVolBased transient;
		self.optAccPeriod.value := true;
		self.grpAmountFrom.visible := true;
		self.grpAccumulateFor.visible := true;
		self.tblGrp.height	:=self.tblGrp.height-60;
		self.tblGrp.top	:= 350;
		self.grpAmountFrom.top := 260;
		self.grpAccumulateFor.top := 300;
	else
		create self.myPxyContractDetails transient;
		self.grpAmountFrom.visible := false;
		self.grpAccumulateFor.visible := false;
		self.tblGrp.height	:= 307;
		self.tblGrp.top	:= 265;
	endif;
	if contractcriteria &lt;&gt; null then
		contractcriteria.setProxyDetail(self.myPxyContractDetails);
	endif;
	self.tblGrp.height := self.btnSave.top - self.tblGrp.top - 10;
	
	self.frmSplitter.cnEcResizeContents(); // ### TFS CR 61268 29NOV2023 NAVAB1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalculationTypes" id="2c828b5d-83c9-48eb-844a-74a5408659e2">
        <source>doCmbCalculationTypes(_invLineType : CM_InvoiceLineDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
28 Aug 2023 navhl20 	Bug 59914: FR | EUP 54089 - Inv Contract - Default UOM and Calc Type

BUG 59913 31AUG2023 NAVAB1 - refactored correctly
*/

vars
	tmpDesc : String;
	aCT,defaultCT : CM_CalculationType;
	
begin
	
    if _invLineType &lt;&gt; null then									//28.8.2023 navhl20 #59914
        defaultCT := _invLineType.myCalculationType;
		 // BUG 59913 31AUG2023 NAVAB1 
		self.btnCriteria.enabled := true;
		if defaultCT &lt;&gt; null
		and not defaultCT.isCargoCalcType then
			self.btnCriteria.enabled := false;
		endif;
    endif;
	
	self.cmbCalculationTypes.clear;
	self.cmbCalculationTypes.sorted := true;

	foreach aCT in app.myRoot.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if _invLineType &lt;&gt; null
		and not _invLineType.isSameCalcType(aCT) then
			continue;
		endif;
		
		tmpDesc := aCT.getComboDescription();               
		
		self.cmbCalculationTypes.addItemObject(tmpDesc,aCT);
	endforeach;
	

    if defaultCT &lt;&gt; null then													//28.8.2023 navhl20 #59914
 // BUG 59913 31AUG2023 NAVAB1       self.cmbDeriveQuantity.text := "Cargo - " &amp; defaultCT.description;
		if self.cmbCalculationTypes.findObject(defaultCT) &lt; 1 then
			tmpDesc := defaultCT.getComboDescription();               
			self.cmbCalculationTypes.addItemObject(tmpDesc,defaultCT);
		endif;
		self.cmbCalculationTypes.listObject := defaultCT;
		
    endif;
epilog

end;</source>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="doCmbInvoiceLinesBuild" id="e3bfb6b1-9a2f-48fa-a998-710fd8e64c34">
        <updating/>
        <source>doCmbInvoiceLinesBuild() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details

*/
vars

	idx : Integer;
	anILD : CM_InvoiceLineDesc;

begin
	
	//self.cmbInvoiceLine.clear;
	foreach anILD in self.myCurrentBank.invoiceLineDescriptors where not anILD.isNotAvailableForEntry do
		idx := self.cmbInvoiceLine.addItem(anILD.getComboDescription()); // ### TFS BUG 59913 31AUG2023 NAVAB1 narration);
		self.cmbInvoiceLine.itemObject[idx] := anILD;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbServicesBuild" id="5dd46462-38e3-46e8-9620-33007d981b1c">
        <updating/>
        <source>doCmbServicesBuild() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details

*/

vars

	idx : Integer;
	service : CM_Service;
	bank : CM_Bank;
	invoice : CM_InvoiceLineDesc;

begin
	self.cmbService.clear();
	
	foreach service in self.myInvLineDescription.services do
		idx := self.cmbService.addItem(service.name);
		self.cmbService.itemObject[idx] := service;
	endforeach;
	
	if idx = 1 then // ### TFS BUG 56879 02MAR2023 NAVAB1
		self.cmbService.listIndex := 1; // ### TFS BUG 56879 02MAR2023 NAVAB1
		self.handleService(); // ### TFS BUG 56879 02MAR2023 NAVAB1
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbShippingterm" id="be7aced5-9f31-4303-909d-78f2d0fe6e62">
        <source>doCmbShippingterm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details

*/

vars
	shippingTerm : CM_InvoiceContractShipTerm;

begin
	self.cmbShippingTerm.clear;	
	foreach shippingTerm in self.myCurrentBank.allInvoiceShippingTerms  do
		self.cmbShippingTerm.addItem(shippingTerm.code);
		self.cmbShippingTerm.itemObject[self.cmbShippingTerm.newIndex] := shippingTerm;
