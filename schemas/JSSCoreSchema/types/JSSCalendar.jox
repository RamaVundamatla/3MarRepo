    <JadeMethod name="setSelectedDate" id="0334a0aa-c652-49bd-ad1e-1c83098627b0">
        <updating/>
        <source>setSelectedDate(pDate:Date; pIsHighlight:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Move the calendar display to the month including the specified date,
//				set it as the internal selected date, and highlight it if highlight
//				is true.
//
// Parameters:	pDate (Date) - The date to make as the currently selected date.
//				pIsHighlight (Boolean) - If true, the date will be highlighted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj	: Control;
	
begin
	if self.selectedDate &lt;&gt; pDate then
		if self.selectedDate &lt;&gt; null then
			self.findControlForDay(self.selectedDate.day).JSSCalendarDay.clearSelected();
		endif;
		
		if pDate &lt;&gt; null then
			self.setDisplayMonth(pDate.month, pDate.year);
			self.findControlForDay(pDate.day).JSSCalendarDay.showSelected();
		endif;
		
		self.selectedDate	:= pDate;
	endif;

	if pIsHighlight then
		controlObj				:=	self.findControlForDay(pDate.day);
		controlObj.backColor	:=	self.highlightColor;
		controlObj.foreColor	:=	self.highlightTextColor;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pIsHighlight" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setShowMonthHeading" id="1e2aa172-c246-416f-9fd5-a5654f4ca7eb">
        <updating/>
        <source>setShowMonthHeading(pValue:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets a flag that determines whether or not month headings are
//				displayed.
//
// Parameters:	pValue - True if headings are displayed, otherwise false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isShowMonthHeading &lt;&gt; pValue then 
		self.isShowMonthHeading := pValue;
		self.redrawSelf();
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
