    <JadeMethod name="getPeerSchema" id="c38f8ec0-61fa-4801-b690-261d3a06ec51">
        <source>getPeerSchema():Schema protected;
// --------------------------------------------------------------------------------
// Created:		27 March 2002 by cnwdad2
//
// Purpose:		This method will return the Root-Type schema for the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the peer schema.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.class().rootType().schema;
end;</source>
        <access>protected</access>
        <ReturnType type="Schema"/>
    </JadeMethod>
