epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClick" id="d635255d-61ec-47d5-ad71-cea80ba51e07">
        <updating/>
        <source>doClick(x : Real; y : Real; isShift, isCtrl : Boolean) updating;
// the grid has been clicked
vars
	cell : Point;
	location: CM_IrregularBlockController;
begin
	cell := pixelToCell(x, y);
// PAR 32308 	self.deselectAll();
	location := self.getLocationForCell(cell);
	if location &lt;&gt; null then
		
	// PAR 32308 	self.selectLocation(location);
		if self.nOTUSEDeditingYardAllocations() then
			self.nOTUSEDupdateYardAllocations(location, isShift or isCtrl);
		endif;
		myTopFrame.locClick(myTopFrame, location);
	endif;
end;
</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="isShift" type="Boolean"/>
        <Parameter name="isCtrl" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDblClick" id="f39099f1-0dbe-4d1f-8470-fa292b681877">
        <updating/>
        <source>doDblClick(x : Real; y : Real) updating;
// the grid has been doubled clicked
vars
	cell : Point;
	location: CM_IrregularBlockController;
begin
	cell := pixelToCell(x, y);
	location := self.getLocationForCell(cell);
	if location &lt;&gt; null then
		myTopFrame.locDblClick(myTopFrame, location);
	endif;
end;
</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="7da5c8c1-b37a-4501-9ef0-417d95e598fa">
        <updating/>
        <source>doDragDrop(win : Window input; x : Real; y : Real) updating;
// Something has been dropped here. If it is on a controller then send an event
vars
	cell : Point;
	location: CM_IrregularBlockController;
begin
	cell := pixelToCell(x, y);
	location := self.getLocationForCell(cell);
	if location &lt;&gt; null then
		myTopFrame.locDragDrop(myTopFrame, win, location);
	endif;
end;
</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLocation" id="ab1f7cbb-6d27-4fb8-8d1c-1ab4e5787873">
        <source>drawLocation(location : CM_IrregularBlockController; _drawAll : Boolean) protected;
// draw the location 
vars
	topLeft, bottomRight: Point;
	totalTrackedItems : Integer;
	colour, edgeColour : Integer;
	colourInverse : Integer;
	cumulativePercentage : Integer;
	numberOfTrackedItems : Integer;
	trackedItem : CM_TrackedItem;
	colourCounts : CM_ColourCountDict;
	colourCount : CM_ColourCount;
	left, right, width : Integer;
	x1, y1, x2, y2 : Integer;
begin
		create colourCounts transient;
	topLeft := cellToPixel(location.region.first);
	bottomRight := cellToPixel(location.region.last.add(1, 1));
	x1 := topLeft.x;
	y1 := topLeft.y;
	x2 :=  bottomRight.x-gridLineWidth;
	y2 := bottomRight.y-gridLineWidth;

	if _drawAll then
		self.allDrawnObjects.putAtKey(x1, y1, x2, y2, location );
	endif;
	
	edgeColour := LightBlue;
	if self.viewMode = VIEW_YARD_ALLOC then
	// OLD STUFF	self.drawYardAllocation(location);
	
		self.myDrawingFrame.drawFillColor := location.getYAColour();
		self.myDrawingFrame.drawSolidRectangle(x1, y1, x2, y2, self.myDrawingFrame.drawFillColor);
		edgeColour := self.myDrawingFrame.drawFillColor;
		if edgeColour = White then
			edgeColour := LightBlue;
		endif;
		colourInverse := self.myDrawingFrame.drawFillColor.getInverseColour();
	else
		location.getTIs(self.allTrackedItems,REAL_MODE, true);
		if self.allTrackedItems.size &gt; 0 then
			foreach trackedItem in self.allTrackedItems do
				if self.isInSelector(trackedItem) then
					colour := self.getFillColourForTI(trackedItem);
					if colour = -1 then
						colour := self.colourLocation;
					else
						totalTrackedItems := totalTrackedItems + trackedItem.totalQuantity;
					endif;
					colourCount := colourCounts[colour];
					if colourCount = null then
						create colourCount transient;
						colourCount.colour := colour;
						colourCounts[colour] := colourCount;
					endif;
					colourCount.count := colourCount.count + 1;
				endif;
			endforeach;
		else
		endif;
		if colourCount = null then
			// No tracked items at this location so just create a dummy entry so it still
			// gets displayed
			create colourCount transient;
			colourCount.colour := self.colourLocation;
			colourCount.count := 1;
			colourCounts[colour] := colourCount;
		endif;
		
		self.calculateColourPercent(colourCounts);
		
		self.myDrawingFrame.drawWidth := 1;
		// Draw a stripped rectangle
		left := topLeft.x;
		width := bottomRight.x-gridLineWidth - left ;
		foreach colourCount in colourCounts do
			cumulativePercentage := cumulativePercentage + colourCount.percent;
			right := topLeft.x + ((cumulativePercentage * width) / 100).Integer ;
			self.myDrawingFrame.drawSolidRectangle(left, topLeft.y, right, bottomRight.y-gridLineWidth, colourCount.colour);
			left := right + 1;
		endforeach;
		/*Date		      Who		Reason
		   18 June 2008	 cnwdz2	    Par16978 - Set the colour of the location text the inverse colour of whatever is underneath it
											   if the adjacent colours inverse to each other then just use LightGray.
		*/
		colourInverse := colourCount.colour.getInverseColour();
	endif;
	
	
	// PAR 32308
	if self.allSelectedObjects.includes(location) then
		self.myDrawingFrame.drawWidth := 2;
		self.myDrawingFrame.drawRectangle(x1+1, y1+1, x2-1, y2-1, Red);
	elseif self.viewMode = VIEW_YARD_ALLOC then
		self.myDrawingFrame.drawWidth := 1;
		self.myDrawingFrame.drawRectangle(x1+1, y1+1, x2-1, y2-1, edgeColour);
	endif;

	if colourInverse = self.getFillColourForTI(trackedItem) then
		self.drawLocationText(location, totalTrackedItems, LightGray);
	else 
		self.drawLocationText(location, totalTrackedItems, colourInverse);
	endif;
	

epilog
	colourCounts.purge;
	delete colourCounts;
	self.allTrackedItems.clear();
end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
        <Parameter name="_drawAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFillColourForTI" id="44217c70-1272-4a0f-8f7f-3ab2a179eee3">
        <source>getFillColourForTI(_ti: CM_TrackedItem): Integer;
begin
	if _ti &lt;&gt; null and self.viewMode = VIEW_DWELL and self.viewModeCode &lt;&gt; null then
		// In Dewll days mode want to show how many items meet the criteria
		if self.viewModeCode.startsWith(" &lt;=") then
			if _ti.isDaysSinceReceival(self.myDrawingAttrController.number1, false) then
				return Blue;
			endif;
		else
			if _ti.isDaysSinceReceival(self.myDrawingAttrController.number1, true) then
				return Red;
			endif;
		endif;
		return -1;
	else 
		return inheritMethod(_ti);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleMouseUp" id="ac73dffe-b349-49c7-8e4c-5149e475715a">
        <updating/>
        <source>handleMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			 // PAR 32308
Date		Who		Reason
02 September 2013	cnwab1	Initial creation
*/

vars
	cell : Point;
	location: CM_IrregularBlockController;
begin
	if button &lt;&gt; Frame.MouseButton_Left then
		return;
	endif;
	
	cell := pixelToCell(x, y);
	location := self.getLocationForCell(cell);
	if location = null then
		self.deselectAll();
		self.drawLocations();
	else
		if shift.isControlKeyPressed() then
			self.selectLocation(location);
		elseif shift.isShiftKeyPressed() then
			self.selectLocationBlock(location);
			

			self.drawLocations();
		else
			self.deselectAll();
			self.drawLocations();
			self.selectLocation(location);
		
		endif;
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="isInSelector" id="e30ad137-2ce1-45e5-aae4-6066072ff914">
        <source>isInSelector(trackedItem : CM_TrackedItem) : Boolean protected;
// Return true if there is an active selector and in includes this tracked item
// Will also return true if there is no active selector
begin
	return not self.useSelectorObjects or self.allSelectorTIs.includes(trackedItem);
end;
</source>
        <access>protected</access>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="nOTUSEDdrawYardAllocation" id="f4f39771-58fd-4273-90a5-d39d47f9c186">
        <source>nOTUSEDdrawYardAllocation(location : CM_IrregularBlockController) protected;
// draw the location's yard allocation (if it has one)
vars
	topLeft, bottomRight: Point;
	colour : Integer;
	yardAllocation : CM_YardAllocation;
	yardAllocations : CM_YardAllocationSet;
	count, inset : Integer;
begin
	create yardAllocations transient;
	self.nOTUSEDgetYardAllocations(location, yardAllocations);
	yardAllocations.rebuild();
	count := 0;
	foreach yardAllocation in yardAllocations do
		if self.canDisplayYardAllocation(yardAllocation) then
			topLeft := cellToPixel(location.region.first);
			bottomRight := cellToPixel(location.region.last.add(1, 1));
			colour := yardAllocation.color;
			self.myYardAllocationDrawingFrame.drawWidth := self.gridBorderWidth+1;
			self.myYardAllocationDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
			// Draw a border rectangle around in the colour associated with the yard allocation
			inset := (self.gridBorderWidth+1) * count;
			topLeft := topLeft.add(inset, inset);
			bottomRight := bottomRight.subtract(inset + 2, inset + 2);
			if (topLeft.above(bottomRight) and topLeft.leftOf(bottomRight)) then
				self.myYardAllocationDrawingFrame.drawRectangle(topLeft.x, topLeft.y, bottomRight.x, bottomRight.y, colour);
			endif;
			count := count + 1;
		endif;
	endforeach;
epilog
	delete yardAllocations;
end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="nOTUSEDdrawYardAllocations" id="5291a571-e13c-4661-93aa-3ade09bfa077">
        <source>nOTUSEDdrawYardAllocations() protected;
// Draw all the yard allocations in the area
vars
	location: CM_LocationsController;
begin
	foreach location in myTerminalArea.allLocationsControllers do
		self.nOTUSEDdrawYardAllocation(location.CM_IrregularBlockController);
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="nOTUSEDeditingYardAllocations" id="cb45a271-8ec2-4ec3-93fe-4921201be637">
        <source>nOTUSEDeditingYardAllocations() : Boolean protected;
//29 May 2008	cnwdw1	
// Return treu if we are editing the Yard allocations
begin
	return self.canEditYardAllocations;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="nOTUSEDgetYardAllocations" id="694afe57-2abf-402d-84f2-1cc455f6ddf9">
        <source>nOTUSEDgetYardAllocations(location : CM_IrregularBlockController; yardAllocations : CM_YardAllocationSet input) protected;
//29 May 2008	cnwdw1	
// Get the yard allocations for this location;
// If we are editing yard allocations then check to see if the location is still in the yard allocation 
vars
	selectedYardAllocation : CM_YardAllocation;
begin
	if self.nOTUSEDeditingYardAllocations() then
		selectedYardAllocation := self.getSelectedYardAllocation();
		if selectedYardAllocation &lt;&gt; null and myYardAllocationLocations.includes(location) then
			yardAllocations.add(selectedYardAllocation);
		endif;
	else
		location.allYardAllocations.copy(yardAllocations);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
        <Parameter name="yardAllocations" type="CM_YardAllocationSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="nOTUSEDupdateYardAllocations" id="09a943a2-9778-4b40-86d3-b47774c3a3ae">
        <source>nOTUSEDupdateYardAllocations(location : CM_LocationsController; extendSelection : Boolean) protected;
//29 May 2008	cnwdw1	
// Update the yard allocations. If a new location is selected, unselect all existing locations
// unless extendSelection is true
begin
	if extendSelection then
		if not self.myYardAllocationLocations.includes(location) then
			self.myYardAllocationLocations.add(location);
		endif;
	else	
		self.myYardAllocationLocations.clear();
		self.myYardAllocationLocations.add(location);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="location" type="CM_LocationsController"/>
        <Parameter name="extendSelection" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="refreshYardAllocations" id="4e574f9b-7d62-49e9-b2c9-3d98f7718173">
        <updating/>
        <source>refreshYardAllocations() updating;
//28 May 2008	cnwdw1	
// Redraw all the yard allocations in the area
vars
begin

// ########################################
// ########################################
// ########################################
// ########################################
// ########################################
// ######### NOT USED
	return;

	self.myYardAllocationDrawingFrame.clearGraphics();
	self.initYardAllocations();
	self.nOTUSEDdrawYardAllocations();
end;</source>
    </JadeMethod>
    <JadeMethod name="selectLocation" id="0e2da729-4e6c-498a-9a5b-ca0768b99bd6">
        <updating/>
        <source>selectLocation(location: CM_IrregularBlockController) updating, protected;
/*
Purpose:			
Date		Who		Reason
02 September 2013	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(location);

	self.allSelectedObjects.add(location);
	
	self.topLeft := null;
	self.bottomRight := null;
	mySelectedLocation := location;
	self.drawLocation(location, false);
	
	
	self.myGCBlockAreaForm.sendMsgWithParams("showSelectedInfo", self.allSelectedObjects.size);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
