	topMMs := 201;	bottomMMs := 205;	leftMMs := 15;	rightMMs := 42;		self.moveLabel( self.lblAR, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 60
	topMMs := 205;	bottomMMs := 209;	leftMMs := 15;	rightMMs := 42;		self.moveLabel( self.lblAS, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 61
	topMMs := 209;	bottomMMs := 213;	leftMMs := 25;	rightMMs := 49;		self.moveLabel( self.lblAT, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 62
	topMMs := 213;	bottomMMs := 217;	leftMMs := 18;	rightMMs := 49;		self.moveLabel( self.lblAU, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 63
	topMMs := 218;	bottomMMs := 222;	leftMMs := 13;	rightMMs := 59;		self.moveLabel( self.lblAV, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 64
	topMMs := 223;	bottomMMs := 227;	leftMMs := 17;	rightMMs := 58;		self.moveLabel( self.lblAW, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 65
	topMMs := 228;	bottomMMs := 232;	leftMMs := 18;	rightMMs := 52;		self.moveLabel( self.lblAX, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 66
	topMMs := 232;	bottomMMs := 236;	leftMMs := 10;	rightMMs := 54;		self.moveLabel( self.lblAY, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 67
	topMMs := 236;	bottomMMs := 240;	leftMMs := 10;	rightMMs := 56;		self.moveLabel( self.lblAZ, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 68
	topMMs := 244;	bottomMMs := 279;	leftMMs := 0;	rightMMs := 67;		self.moveLabel( self.lblBA, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 69
	topMMs := 280;	bottomMMs := 284;	leftMMs := 19;	rightMMs := 55;		self.moveLabel( self.lblBB, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 70
	topMMs := 285;	bottomMMs := 289;	leftMMs := 14;	rightMMs := 44;		self.moveLabel( self.lblBC, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 71
	topMMs := 290;	bottomMMs := 294;	leftMMs := 10;	rightMMs := 57;		self.moveLabel( self.lblBD, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 72
	
	topMMs := 185;	bottomMMs := 194;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBE, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 38
	topMMs := 198;	bottomMMs := 208;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBF, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 39
	topMMs := 220;	bottomMMs := 230;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBG, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 50
	topMMs := 234;	bottomMMs := 238;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBH, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 51
	topMMs := 245;	bottomMMs := 249;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBI, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 52
	topMMs := 250;	bottomMMs := 254;	leftMMs := 80;	rightMMs := 119;		self.moveLabel( self.lblBJ, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 53
	topMMs := 258;	bottomMMs := 262;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBK, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 54
	topMMs := 266;	bottomMMs := 270;	leftMMs := 72;	rightMMs := 131;		self.moveLabel( self.lblBL, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 55
	topMMs := 290;	bottomMMs := 294;	leftMMs := 106;	rightMMs := 131;		self.moveLabel( self.lblBV, topMMs, leftMMs, rightMMs, bottomMMs );	// Ticket No
	
	topMMs := 190;	bottomMMs := 207;	leftMMs := 136;	rightMMs := 200;		self.moveLabel( self.lblBM, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 45
