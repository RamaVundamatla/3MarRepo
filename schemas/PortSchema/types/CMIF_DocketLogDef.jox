    <JadeMethod name="displayOffload" id="26697ffb-e0c7-409d-a6ef-c71bd9ce7b6c">
        <source>displayOffload() : String;

vars

	display,
	theLocation,
	theOperator,
	noNumber,
	theLot		: String;

begin

	if self.myOperator &lt;&gt; null then
		theOperator := self.myOperator.code;
	endif;
	if self.myLocationsController &lt;&gt; null then
		theLocation := self.myLocationsController.getID();
		theLot		:= self.myLocationsController.CM_LogVoyageController.myLogLot.lotNo;
	endif;

	if self.isNoNumber then
		noNumber := 'NN';
	else
		noNumber := 'LOG';
	endif;
																									//19/02/2009 cnwdz2 par 18586 change the delimiter '/' to ':'
	display := false.Integer.String &amp; Tab &amp; theLot &amp; Tab &amp; theLocation &amp; Tab &amp; theOperator &amp; Tab &amp; self.species &amp; ':' &amp; self.grade &amp; ':' &amp; self.type &amp; ':' &amp;
				self.treatment &amp; Tab  &amp;  self.length &amp; Tab &amp; noNumber &amp; Tab &amp; self.numberOfLogs.String &amp; Tab &amp; self.volume.String;
	return display;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayTransitTransfer" id="4009186f-20b1-4d24-85cb-1670fb5f235b">
        <source>displayTransitTransfer() : String;

vars

	noNumber,
	display,
	lot,
	hatch,
	placeStr,
	theOperator	: String;
	place		: Integer;

begin

	if self.myOperator &lt;&gt; null then
		theOperator := self.myOperator.code;
	endif;
	if self.myLocationsController &lt;&gt; null then
		if self.myLocationsController.isKindOf(CM_LogVoyageController) then
			lot		:= self.myLocationsController.CM_LogVoyageController.myLogLot.lotNo;
			hatch	:= self.myLocationsController.CM_LogVoyageController.hatch.String;
			place	:= self.myLocationsController.CM_LogVoyageController.place;
		endif;
	endif;
	if place = PlaceDeck then
		placeStr := 'DCK';
	elseif place = PlaceHold then
		placeStr := 'HLD';
	endif;
	
	if self.isNoNumber then
		noNumber := 'NN';
	else
		noNumber := 'LOG';
	endif;
																//19/02/2009 cnwdz2 par 18586 change the delimiter '/' to ':'
	display := false.Integer.String &amp; Tab &amp; theOperator &amp; Tab  &amp; self.species &amp; ':' &amp; self.grade &amp; ':' &amp; self.type &amp; ':' &amp;
				self.treatment &amp; Tab  &amp;  self.length &amp; Tab &amp; noNumber &amp; Tab &amp; lot &amp; Tab &amp; hatch &amp; Tab &amp; placeStr &amp; Tab &amp; self.numberOfLogs.String &amp; Tab &amp; self.volume.String;
	return display;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ed169960-6ee9-48e0-8ba7-2e7f90a1ed8c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	place : Integer;
begin

	if _attrName = ETRow_BgpPic
	or _attrName = ETRow_Filler then
		return Tab;
	elseif _attrName = ETRow_SelLocation then
		if self.myLocationsController &lt;&gt; null then
			return self.myLocationsController.getID;
		endif;
		return null;
	elseif _attrName = ETRow_Operator
	or _attrName = ETRow_OperatorCode
	or _attrName = ETRow_Supplier then
		if self.myOperator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return self.myOperator.description;						// TFS 53362
			else														// TFS 53362
				return self.myOperator.code;
			endif;														// TFS 53362
		endif;
		return null;
	elseif _attrName = ETRow_LogSpecies then
		return self.species;
	elseif _attrName = ETRow_Specs then		// PAR 17880 - show log specs 
		return self.species &amp; ':' &amp; self.grade &amp; ':' &amp; self.type &amp; ':' &amp; self.treatment;//3/12/2008 cnwdz2 par 18586 change the delimiter '/' to ':'
	elseif _attrName = ETRow_LogGrade then
		return self.grade;
	elseif _attrName = ETRow_LogTreatment then
		return self.treatment;
	elseif _attrName = ETRow_LogType then
		return self.type;
	elseif _attrName = ETRow_LogLength 
	or _attrName = ETRow_Length then	
		return self.length;
	elseif _attrName = ETRow_Logs then
		return self.numberOfLogs.String;
	elseif _attrName = ETRow_LogVolume 
	or _attrName = ETRow_Volume then		
		return self.volume.String;
	elseif _attrName = ETRow_NoNumber then
		if self.isNoNumber then
			return 'NN';
		else
			return 'LOG';
		endif;

	elseif _attrName = ETRow_Lot then
		if CM_LogVoyageController.hasInstance(self.myLocationsController) then
			return self.myLocationsController.CM_LogVoyageController.myLogLot.lotNo;
		endif;
		return null;
	elseif _attrName = ETRow_Hatch then
		if CM_LogVoyageController.hasInstance(self.myLocationsController) then
			return self.myLocationsController.CM_LogVoyageController.hatch.String;
		endif;
		return null;	
	elseif _attrName = ETRow_Place then
		if CM_LogVoyageController.hasInstance(self.myLocationsController) then
			return app.vesselPlaceEnumToStr(self.myLocationsController.CM_LogVoyageController.place);
		endif;
		return null;		
	elseif _attrName = ETRow_Pieces then
		return self.numberOfLogs.String;
	elseif _attrName = ETRow_WeightTonnes then
		return self.weightTonnes.String;
	elseif _attrName = ETRow_SedAverage then
		return self.sedAverage.String;
	elseif _attrName = ETRow_Docket then		// 17/09/2008 cnwar2 #17957 (CCMS1095)
		return self.id;
	else
		return null;
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
