    <JadeMethod name="setTypeForUpgrade753" id="dd6fdc81-9d22-4c23-b5c8-aedf219c5916">
        <updating/>
        <source>setTypeForUpgrade753() updating;
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.isCargoType then
		return;
	endif;
	
	if self.isVoyageType() then
		beginTransaction;
		self.isVoyageCalcType := true;
		commitTransaction;
	elseif self.isEventType() then
		beginTransaction;
		self.isEventCalcType := true;
		commitTransaction;
	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="53616585-f00e-4f22-8fc1-1b7be7d5b479">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
27 Mar 2020 cnwma1  Bug 49001: STWO - Calculation type changes in remark hook code not logged in audit trail

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
		
	if	propName = CM_CalculationType::theCalcTypeUnit.name    or
		propName = CM_CalculationType::calculationType.name    or
		propName = CM_CalculationType::amountMax.name          or
		propName = CM_CalculationType::amountMin.name          or
		propName = CM_CalculationType::myCalendarType1.name    or
		propName = CM_CalculationType::myCalendarType2.name    or 
		propName = CM_CalculationType::isVoyageCalcType.name   or 
		propName = CM_CalculationType::isCargoCalcType.name    or 
		propName = CM_CalculationType::isWorkOrderType.name    or // TFS 39198
		propName = CM_CalculationType::isBolCalcType.name      or	//30 Oct 2019	NDL	TFS 47100
		propName = CM_CalculationType::isEventCalcType.name    or
		propName = CM_CalculationType::myChildQuantityMap.name or 
		propName = CM_CalculationType::myHookCodeQuantity.name or 
		propName = CM_CalculationType::myHookCodeRate.name     or 
		propName = CM_CalculationType::myHookCodeRemarks.name
	
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateChargeRate" id="2aec756f-ee11-482c-a701-033ccf2b2333">
        <source>updateChargeRate() protected;
// CCMS 1264 Apr 2012 non-virtual CM_Charge rate, update it from HMS calculation type change
//22.06.2024 navrv30 Task 64598: Jade - ReserveLock on Invoice
vars
	event	: Integer;
	service	: CM_Service;
	iter	: Iterator;
	status	: Integer;
	charge	: CM_Charge;
	invoiceLine	: CM_InvoiceLine;
	term	: CM_Terminal;
	inv : CM_Invoice;
	invoices : CM_InvoiceSet;
begin
	
	create invoices transient; // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1

	foreach service in self.allServices do
	
		iter := service.charges.createIterator();
		// open and pending invoices
		service.charges.startKeyGeq(CM_Invoice.INVOICE_OPEN, 0, iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(1).Integer;
			if status &gt; CM_Invoice.INVOICE_PENDING then
				break;
			endif;
			invoiceLine := charge.invoiceLine;
			if invoiceLine &lt;&gt; null then
				invoiceLine.recalculate();
				
				if invoices.tryAddIfNotNull(invoiceLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
					reserveLock(invoiceLine.invoice);              //22.06.2024 navrv30 Task 64598
				endif;
				
				term := invoiceLine.getTerminal();
				if term &lt;&gt; null then
					event := term.getTerminalEvent(Event_InvoiceLineUpdate);
					invoiceLine.causeEvent(event, false, invoiceLine);
				endif;
			endif;
		endwhile;
		// suspense invoices
		service.charges.startKeyGeq(CM_Invoice.INVOICE_SUSPENSE, 0, iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(1).Integer;
			if status &gt; CM_Invoice.INVOICE_SUSPENSE then
				break;
			endif;
			invoiceLine := charge.invoiceLine;
			if invoiceLine &lt;&gt; null then
				invoiceLine.recalculate();
				
				if invoices.tryAddIfNotNull(invoiceLine.invoice) then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
					reserveLock(invoiceLine.invoice);              //22.06.2024 navrv30 Task 64598
				endif;
				
				term := invoiceLine.getTerminal();
				if term &lt;&gt; null then
					event := term.getTerminalEvent(Event_InvoiceLineUpdate);
					invoiceLine.causeEvent(event, false, invoiceLine);
				endif;
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	foreach inv in invoices do
		inv.setTaxDetailsFromLines();
		inv.setTotalAmountFromLines();
	endforeach;

epilog 
	delete invoices;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateTranMaps" id="e81cdfd9-5598-436b-a559-7ddaaaec78f7">
        <source>updateTranMaps() protected;
// CCMS 1279 Storage Escalating Charges, update transaction map quantity ranges
vars
	idx	: Integer;
	isDifferent	: Boolean;
	qm	: CM_QuantityMap;
	qrm	: CM_QuantityRangeMap;
	qr	: CM_QuantityRange;
	term	: CM_Terminal;
	oa	: ObjectArray;
begin

	create oa transient;
	foreach qr in self.allQuantityRanges do
		oa.add(qr);
	endforeach;
	// from TFS 2108 07/2016 get the quantity maps directly so none are missed
	foreach qm in CM_QuantityMap.instances do
		if qm.myCalculationType = self then
			idx := 0;
			isDifferent := false;
			if oa.size &lt;&gt; qm.allQuantityRanges.size then
				isDifferent := true;
			endif;
			foreach qrm in qm.allQuantityRanges do
				idx := idx + 1;
				qr := null;
				if idx &lt;= oa.size then
					qr := oa[idx].CM_QuantityRange;
				endif;
				if qr = null then
					isDifferent := true;
					break;
				else
					if qr.rangeStart &lt;&gt; qrm.rangeStart or
					   qr.rangeEnd &lt;&gt; qrm.rangeEnd then
						isDifferent := true;
						break;
					endif;
				endif;
			endforeach;
			if isDifferent then
				app.myUtilityCA.utlCreateInvoiceTMQRFromCT(qm, self, app.myPassport);
				term := qm.getBank().terminal;
				term.causeEvent(term.getTerminalEvent(EVENT_TRANSACTIONMAP_NEWQRMS), false, qm);
			endif;
		endif;
	endforeach;
	
epilog
	delete oa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="cd0ada06-e332-43f8-9648-8de389ac71fb">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myRoot.allCalculationTypesByCode[self.code] &lt;&gt; null or
	   (self.isStandardCargo and	// use app.myPassport.useBGPCreateCharge, set in CM_Root::createInvoiceCalcTypes, to allow internal creation of system calc types
	    not app.myPassport.useBGPCreateCharge) then		// reserve 'CCT' code prefix for non-user cargo types - need a better error message ***
		app.raiseCMException2(ERR_INVALID_VALUE,"Code","It is already in use.",ETRow_Code,null);
	
	endif;
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Code",ETRow_Code,null);
		app.raiseCMException(Input_required_field_code,ETRow_Code,null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Description",ETRow_Description,null);
		app.raiseCMException(Input_required_field_Desc,ETRow_Description,null); // cnwdb2	PAR 35364

	endif;
	if self.timeFrom &gt; self.timeTo then
		app.raiseCMException2(ERR_INVALID_VALUE,"Time From","It is greater than the 'Time To'.",ETRow_HoursMin,null);
	endif;
	if self.hoursMin &gt; self.hoursMax and self.hoursMax &lt;&gt; 0 then
		app.raiseCMException2(ERR_INVALID_VALUE,"Minimum Hours","It is greater than the maximum hours.",ETRow_HoursMin,null);
	endif;
	if self.amountMin &gt; self.amountMax and self.amountMax &lt;&gt; 0 then
		if self.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS
		or self.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT
		or self.calculationType = INV_CALC_TYPE_VESSEL_TON then
			app.raiseCMException2(ERR_INVALID_VALUE,"Minimum Block Rate","It is greater than the maximum block rate.",ETRow_AmountMin,null);	// 34764 Amount to Block Rate
		else
			app.raiseCMException2(ERR_INVALID_VALUE,"Minimum Chargeable","It is greater than the maximum chargeable.",ETRow_AmountMin,null);	// 34764 Amount to Chargeable
		endif;
	endif;
	
	if self.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
	or self.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
	or self.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT then		// PAR 31615
		if self.myMeasurementType = null then
		app.raiseCMException(Measu_type_must_selec_this_typ,ETRow_Code,null);
		
		endif;
	
	endif;
	//	CCMS SFW 1279 May 2012 Storage Escalating Charges
	self.validateQuantityRange();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1fd2507a-8315-48bc-9bee-e351d6696de2">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	qtyMap : CM_QuantityMap;
	iter : Iterator;

begin

	if not self.allServices.isEmpty then
		app.raiseCMException2(ERR_CANNOT_DELETE_BANK, "Calculation Type '" &amp; self.code &amp; "'","It is used by Services: " &amp; self.allServices.getServiceList(),null, null);
	endif;
	
	//07 Mar 2017	NDL	TFS 3672
	iter := CM_QuantityMap.instances.createIterator;
	while iter.next(qtyMap) do
		if qtyMap.myCalculationType = self then
			app.raiseCMException2(ERR_CANNOT_DELETE_BANK, "Calculation Type '" &amp; self.code &amp; "'","It is used by : " &amp; qtyMap.getTranMapBreadCrumb(), null, null);
			return;
		endif;
	endwhile;

	
	/* 24024 can have and delete user cargo calculation types
	if self.isCargoCalcType then
		app.raiseCMException2(ERR_CANNOT_DELETE, "Calculation Type '" &amp; self.code &amp; "'","It is used for Cargo calculations. You can only delete VTMIS calculation types.",null, null);
	endif;
	*/

	epilog
	
		delete iter;
		
	end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="947d5a92-3163-4526-bdf1-c51f3b4902a1">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Apr 2016   cnwma1 PAR #37792 PNL - GRT Range in Calc Types and Rates
// ---------------------------------------------------------------------------

vars
	oneOfMe : SelfType;
	service : CM_Service;
	debtorRate :CM_DebtorRate;
	rateEntry : CM_RateEntry;
begin
	oneOfMe :=  app.myRoot.allCalculationTypesByCode[self.code];
	if oneOfMe &lt;&gt; null and oneOfMe &lt;&gt; self.pxyGetRealObject() then
		app.raiseCMException2(ERR_INVALID_VALUE,"Code","It is already in use.",ETRow_Code,null);
	
	endif;
	if self.code = null then
		app.raiseCMException(Input_required_field_code,ETRow_Code,null); // cnwdb2	PAR 35364

	endif;
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc,ETRow_Description,null); // cnwdb2	PAR 35364
	endif;
	if self.timeFrom &gt; self.timeTo then
		app.raiseCMException2(ERR_INVALID_VALUE,"Time From","It is greater than the 'Time To'.",ETRow_HoursMin,null);
	endif;
	if self.hoursMin &gt; self.hoursMax and self.hoursMax &lt;&gt; 0 then
		app.raiseCMException2(ERR_INVALID_VALUE,"Minimum Hours","It is greater than the maximum hours.",ETRow_HoursMin,null);
	endif;
	if self.amountMin &gt; self.amountMax and self.amountMax &lt;&gt; 0 then
		if self.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS
		or self.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT
		or self.calculationType = INV_CALC_TYPE_VESSEL_TON then
			app.raiseCMException2(ERR_INVALID_VALUE,"Minimum Block Rate","It is greater than the maximum block rate.",ETRow_AmountMin,null);	// 34764 Amount to Block Rate
		else
			app.raiseCMException2(ERR_INVALID_VALUE,"Minimum Chargeable","It is greater than the maximum chargeable.",ETRow_AmountMin,null);	// 34764 Amount to Chargeable
		endif;
	endif;
	
	if self.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
	or self.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
	or self.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT then		// PAR 31615
		if self.myMeasurementType = null then
			app.raiseCMException(Measu_type_must_selec_this_typ,ETRow_Code,null);
		endif;
	
	endif;
	//	CCMS SFW 1279 May 2012 Storage Escalating Charges
	self.validateQuantityRange();
	
	// TFS 2105 07/2016 check for null, from changing the code value
	if oneOfMe &lt;&gt; null then
		if oneOfMe.allServices.size &gt; 0 and oneOfMe.integerRange1.size &gt; 0 then 								// 26/04/2016 cnwma1 PAR #37792
			foreach service in oneOfMe.allServices discreteLock do
				if service.debtorNodeRates.size &gt; 0 then
					foreach debtorRate in service.debtorNodeRates  discreteLock do
						if debtorRate.rateEntries.size &gt; 0 then
							foreach rateEntry in debtorRate.rateEntries discreteLock do 
								if rateEntry.allCostPerUnits.size &gt; 0 then
									if rateEntry.allCostPerUnits.size &gt; self.integerRange1.size then
										app.raiseCMException2(ERR_CANNOT_DELETE_BANK, "this range" ,"It is used by Services:"&amp;oneOfMe.allServices.getServiceList(),null,null);
									endif;
								endif;
							endforeach;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateQuantityRange" id="b0e24e12-3480-46f4-81bd-40fe389c344e">
        <source>validateQuantityRange() protected;
// ---------------------------------------------------------------------------
// Created:		May 2012
//
// Purpose:		Check escalating quantity ranges - no overlap (gaps are OK) and daysIncrement on the last entry only
//				NOTE: functional spec allows for more than one escalating range, but this hasn't been implemented yet
//				(ran out of time in initial implementation)
//
// ---------------------------------------------------------------------------

vars
	priorStart, priorEnd	: Integer;
	thisStart, thisEnd		: Integer;
	size,
	count					: Integer;
	qtyRange	: CM_QuantityRange;
begin
	size := self.allQuantityRanges.size;
	foreach qtyRange in self.allQuantityRanges do
		count := count + 1;
		priorStart := thisStart;
		priorEnd := thisEnd;
		thisStart := qtyRange.rangeStart;
		thisEnd := qtyRange.rangeEnd;
		// simple error validation - stop on first
		if thisEnd &lt;= thisStart then
			app.raiseCMException2(ERR_INVALID_VALUE,"Escalating Charges","Entry " &amp; count.String &amp; " 'To' value is less than 'From' value.",ETRow_EscalatingCharges,null);
			break;
		endif;
		if thisStart &lt;= priorEnd then
			app.raiseCMException2(ERR_INVALID_VALUE,"Escalating Charges","Entry " &amp; count.String &amp; " Range overlaps with prior range.",ETRow_EscalatingCharges,null);
			break;
		endif;
		// last entry, and only last entry, must have a days increment value
		if qtyRange.daysIncrement &gt; 0 and
		   count &lt;&gt; size then
			app.raiseCMException2(ERR_INVALID_VALUE,"Escalating Charges","Entry " &amp; count.String &amp; " 'Per Days' must be set on the last entry only.",ETRow_EscalatingCharges,null);
			break;
		endif;
		if qtyRange.daysIncrement = 0 and
		   count = size then
			app.raiseCMException2(ERR_INVALID_VALUE,"Escalating Charges","Entry " &amp; count.String &amp; " 'Per Days' must be set on the last entry.",ETRow_EscalatingCharges,null);
			break;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
