    <JadeMethod name="validateMe" id="8416b779-242c-4ce3-b5ae-2f5fca8f36d7">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/

vars
	xlationTable : CM_XlationTable;
	xlation : CM_Xlation_In;
	coll : CM_MemberKeyDictionary;
	iter : Iterator;
	foreignCodeUC : String;
	haveCriteria : Boolean;
	operatorTerminal : CM_OperatorTerminal;
begin
	foreignCodeUC := self.myXlation.foreignCode;
	xlationTable := self.myXlation.myXlationTable;
	if xlationTable.isTransient then
		operatorTerminal := xlationTable.myOperatorTerminal;
		xlationTable := operatorTerminal.allXlationTables[XLATION_TYPE_VOYAGETERMINAL, null];
		if xlationTable = null then		//this means this is the first voyageTerminal for this operator/terminal so no need to check for duplcates
			return;
		endif;
	endif;
	coll := xlationTable.allInwardTranslations;
	iter := coll.createIterator();
	coll.startKeyGeq(foreignCodeUC, iter);
	while iter.next(xlation) do 
		if xlation = self.myXlation then
			continue;
		endif;
		if xlation.foreignCode &lt;&gt; foreignCodeUC then
			break;
		endif;
		if xlation.myXlationCriteria &lt;&gt; null then		// a import criteria will only exist if isImport is true
			haveCriteria := true;
			break;
		endif;
	endwhile;
	if haveCriteria then
		app.raiseCMException(CMUI_Selector_DupCriteria, null, self);
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
</Class>
