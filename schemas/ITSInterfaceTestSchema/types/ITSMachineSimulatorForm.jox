    <JadeMethod name="initialiseQueueTable" id="3458f5c7-3866-4895-8ec1-c311779af00d">
        <source>initialiseQueueTable() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	columnArray		: StringArray;
	columnName		: String;
	table			: Table;
	
begin
	table := self.tblQueueEntries;
	
	table.rows := 0;
	table.columns := 0;
	
	table.rows := 1;
	table.fixedRows := 1;
	
	table.selectMode := Table.SelectMode_WholeRows;
	
	create columnArray transient;
	columnArray.add(XML_Tag_QueueEntryId);
	columnArray.add(XML_Tag_DespatchNow);
	columnArray.add(XML_Tag_EntryType);
	columnArray.add(XML_Tag_CargoId);
	columnArray.add(XML_Tag_CargoAttributes);
	columnArray.add(XML_Tag_SourceLocation);
	columnArray.add(XML_Tag_SourceAttributes);
	columnArray.add(XML_Tag_TargetLocation);
	columnArray.add(XML_Tag_Weight);
	columnArray.add(XML_Tag_RequiresWeighing);
	
	foreach columnName in columnArray do
		table.columns := table.columns + 1;
		table.setCellText(1, table.columns, columnName);
	endforeach;
	

epilog
	delete columnArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="a9806676-8049-4148-9983-eb05a028e71a">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	self.myControl := ITSServerControl.firstInstance;
	
	if self.myControl = null then
		app.msgBox("ITS Server Application is not yet running, will terminate", "Error", MsgBox_OK_Only);
		terminate;
	endif;
	
	if self.tryLock(self.myControl, Reserve_Lock, Transaction_Duration, LockTimeout_Immediate) then
		self.unlock(self.myControl);
		app.msgBox("ITS Server Application is not yet running, will terminate", "Error", MsgBox_OK_Only);
		terminate;
	endif;
	
	self.txtHostname.text := self.myControl.remoteAddress;
	self.txtPort.text := self.myControl.remotePort.String;
	self.txtTimeout.text := self.myControl.timeout.String;
	self.chkUsePresent.value := self.myControl.usePresentationTCP;
	
	self.setDefaults();
		
	self.registerForStartStop();
		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logMessage" id="1d1acaf1-5196-4f8e-b822-7a8f2d97334d">
        <source>logMessage(msg: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Dec 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

begin
	inheritMethod(msg);

	self.txtOutput.text := app.actualTimeServer.time.displayWithMilliseconds() &amp; " " &amp; msg.replace(CrLf, null) &amp; CrLf &amp; self.txtOutput.text;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	
epilog

end;</source>
        <Parameter name="msg" type="String"/>
