    <JadeMethod name="getWorkOrder" id="1555c569-1d23-442e-beed-a51825658272">
        <source>getWorkOrder() : CM_WorkOrder;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 20 Mar 2023  navma1		Defect 57196: MTN - WO - Work Order field is empty on the Yard Operations form for wle's and jobs
// 07 Jun 2023  navhl20 	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
// 02 Oct 2023  navma1		Bug 60530: MTN - Cargo Group will be cleared when using Receive Cargo Form
// 22 Nov 2023	navhl20 	Bug 61048: EUP - Spinning wheel appears when performing the Rail Load using WO Operations app.
// 29 Jan 2023 	navhl20 	ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
// 06 Mar 2025  navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// -----------------------------------------------------------------------------

vars
	wle		: CM_WorkListEntry;
	woWle	: CM_WOWLE;
begin
	if self.myWODtl &lt;&gt; null then
		return self.myWODtl.myParent;
	elseif self.myWorkOrderDtlToDo &lt;&gt; null then							  //20.03.2023 navma1 #57196
		return self.myWorkOrderDtlToDo.myParent;
	else 
		foreach wle in self.workListEntries discreteLock do					//29.01.2023 navhl20 #62166
			if wle.isChassis then
				continue;
			endif;
			woWle := wle.myWorkOrderWLE;
			if woWle &lt;&gt; null and
				woWle.job &lt;&gt; null and
				woWle.job.myWODtl &lt;&gt; null then
				return woWle.job.myWODtl.myParent;
			endif;
		endforeach;
	endif;	
	
epilog

end;</source>
        <ReturnType type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderDtl" id="8044f9a4-2be0-4d2c-87f1-283cbf76f67f">
        <source>getWorkOrderDtl():CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues

*/

vars
	wle 	: CM_WorkListEntry;
	woWle	: CM_WOWLE;
begin
	if self.myWODtl &lt;&gt; null then
		return self.myWODtl;
	elseif self.myWorkOrderDtlToDo &lt;&gt; null then
		return self.myWorkOrderDtlToDo;
	else
		wle := self.workListEntries.first;
		if  wle &lt;&gt; null then
			woWle := wle.myWorkOrderWLE;
			if woWle &lt;&gt; null and
				woWle.job &lt;&gt; null and
				woWle.job.myWODtl &lt;&gt; null then
				return woWle.job.myWODtl;
			endif;
		endif;
	endif;	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderForDisplay" id="25b92177-c77b-40c6-80e6-46fd50604220">
        <source>getWorkOrderForDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2024	navbs1	Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job
18 Dec 2024	navbs1	Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders

*/

vars
	wo 		: CM_WorkOrder;
	str 	: String;
	woSet 	: CM_WorkOrderSet;
begin
	
	create woSet transient;
	self.getWorkOrders(woSet);
	
	str := woSet.listString(Comma,CM_WorkOrder::id.name);
	
	return str;
	//18.12.2024 navbs1 #33554 END
	
epilog
	delete woSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrders" id="c114bf14-8460-42ff-b6ba-b407b988cf43">
        <source>getWorkOrders(_woSet :CM_WorkOrderSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2024	navbs1	Initial Creation Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars	
	wle 	: CM_WorkListEntry;
	woWle	: CM_WOWLE;
	job 	: CM_Job;
	wod 	: CM_WorkOrderDtl;
begin
	if self.myWODtl &lt;&gt; null  then
		_woSet.addNoDuplicates(self.myWODtl.myParent, false);	
	
	elseif self.myWorkOrderDtlToDo &lt;&gt; null then					
		_woSet.addNoDuplicates(self.myWorkOrderDtlToDo.myParent, false);
	else 
		foreach wle in self.workListEntries discreteLock do			//06.03.2025 navma1 #MTN-34179			
			if wle.isChassis then
				continue;
			endif;
			
			woWle := wle.myWorkOrderWLE;
			
			if woWle = null then
				continue;
			endif;
			
			job := woWle.job;
			
			if job = null then
				continue;
			endif;
			
			wod := woWle.job.myWODtl;
			
			if wod = null then
				continue;
			endif;
			
			_woSet.addNoDuplicates(wod.myParent, false);

		endforeach;
		
	endif;	
	
epilog

end;</source>
        <Parameter name="_woSet" type="CM_WorkOrderSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWorkPoint" id="8dc60c25-5acc-41dc-8699-4450d7b81d1d">
        <source>getWorkPoint():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs

*/

vars

begin
	if self.myJobSheetForWorkPoint &lt;&gt; null and self.myJobSheetForWorkPoint.myWorkPoint &lt;&gt; null then
		return self.myJobSheetForWorkPoint.myWorkPoint.code;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointTypeCode" id="5d659b3e-2730-4b5c-b74a-52b631d8c45c">
        <source>getWorkPointTypeCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 Jul 2024			navbs1	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
12 December 2024	navpw1	JIRA: MTN-33528 - Fixed 1090's

*/

vars
	jobSheet		: CM_WorkPointJobSheet;
	workPoint		: CM_WorkPoint;
	workPointType	: CM_WorkPointType;
	
begin
	jobSheet := self.myJobSheetForWorkPoint;
	
	if jobSheet = null then
		return null;
	endif;
	
	workPoint := jobSheet.myWorkPoint;
	
	if workPoint = null then
		return null;
	endif;
	
	workPointType := workPoint.myWorkPointType;
	
	if workPointType = null then
		return null;
	endif;
	
	return workPointType.code;
	
end;</source>
        <ReturnType type="String"/>
