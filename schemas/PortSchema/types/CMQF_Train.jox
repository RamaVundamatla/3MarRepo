vars

begin
	inheritMethod(_runDate);

	self.scheduledArrivalDateFrom := self.setDateFromTemplate(self.scheduledArrivalDateFromType, self.scheduledArrivalDateFromFactor, _runDate);
	self.scheduledArrivalDateTo := self.setDateFromTemplate(self.scheduledArrivalDateToType, self.scheduledArrivalDateToFactor, _runDate);
	
	//30 oct 2012	NDL	Par 30394
	self.scheduledDepartDateFrom := self.setDateFromTemplate(self.scheduledDepartDateFromType, self.scheduledDepartDateFromFactor, _runDate);
	self.scheduledDepartDateTo := self.setDateFromTemplate(self.scheduledDepartDateToType, self.scheduledDepartDateToFactor, _runDate); 
	
	//29 Oct 2012	NDL	Par 30394
	self.departDateFrom := self.setDateFromTemplate(self.departDateFromType, self.departDateFromFactor, _runDate);
	self.departDateTo := self.setDateFromTemplate(self.departDateToType, self.departDateToFactor, _runDate);
	
	//30 oct 2012	NDL	Par 30394
	self.arrivalDateFrom := self.setDateFromTemplate(self.arrivalDateFromType, self.arrivalDateFromFactor, _runDate);
	self.arrivalDateTo := self.setDateFromTemplate(self.arrivalDateToType, self.arrivalDateToFactor, _runDate); 

epilog

end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
