<Class name="CM_EnstructureInterface" id="baa676e8-9261-4d0e-94c9-ab41c9101c18">
    <superclass name="CM_ExtFinanceIO"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="createDetailRecords" id="346f0e47-1c0b-4592-887e-bc7810c0ecc8">
        <source>createDetailRecords(_file : File io; _inv : CM_Invoice; _newFile : Boolean);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
14 Mar 2023         navmp20     ChangeRequest 56278: PRP - Financial Data Extract Additional Attributes
****************************************************/

constants
	DELIMITER = ",";
	
vars
 	isVoyageInvoice	: Boolean;
	str, itemNumber : String;
	glSummaryDict 	: CM_GLSummaryByGLCodeRateDict;
	glSummary 		: CM_GLSummary;
	invoiceLine 	: CM_InvoiceLine;
	charge 			: CM_Charge;
	serv 			: CM_Service;
	
begin
	//isVoyageInvoice := _inv.invoiceType.isVoyageSpecific();
	isVoyageInvoice := _inv.invoiceType.isVoyageSpecificDebtor(_inv.debtor); // ### TFS 54565 (54384) 22Sep2022 NAVPW1
	create glSummaryDict transient;
	
	foreach	invoiceLine in _inv.invoiceLines do
		foreach charge in invoiceLine.charges do
			charge.getGLRateSummaryStats(glSummaryDict);
		endforeach;
	endforeach;
	
	if _newFile then
		//str := "Document Number,Item Number, Quantity, Unit Price, Item Description, Unit Of Measure";
		str := "Document Number,Item Number, Quantity, Unit Price, Item Description, Unit Of Measure, Cargo Type";  //14.03.2023 navmp20 TFS 56278
		_file.writeLine(str);
	endif;
	
	foreach glSummary in glSummaryDict do //We are including zero amount lines so export everthing.
		str := "";
		
		serv := glSummary.getServiceObject(); 
		itemNumber := ""; 
		if serv &lt;&gt; null then 
			itemNumber := serv.remarks.trimBlankCharacters(); 
		else
			itemNumber := glSummary.serviceName;
		endif;
		
		str := _inv.sequenceNum.String &amp; DELIMITER; 															// Document Number
		str := str &amp; itemNumber &amp; DELIMITER; 																	// Item Id
		str := str &amp; glSummary.quantity.asStringJMTWithPrecision(4,false) &amp; DELIMITER; 							// Quantity
		str := str &amp; glSummary.rate.asStringJMTWithPrecision(4,false) &amp; DELIMITER; 								// Rate
		str := str &amp; glSummary.myInvoiceLine.invoiceLineDesc.narration.asDoubleQuotedString() &amp; DELIMITER;		// Narration
		//str := str &amp; self.getMeasurementTypeName(serv).asDoubleQuotedString();									// Unit Of Measurement
		str := str &amp; self.getInvoiceLineTypeUnitNarr(glSummary.myInvoiceLine).asDoubleQuotedString() &amp; DELIMITER;//14.03.2023 navmp20 TFS 56278
		str := str &amp; self.getCargoType(glSummary.myInvoiceLine).asDoubleQuotedString();                          //14.03.2023 navmp20 TFS 56278
		
		_file.writeLine(str);	
	endforeach;
	
epilog
	glSummaryDict.purge();
	delete glSummaryDict;
	
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_inv" type="CM_Invoice"/>
        <Parameter name="_newFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createGLRecords" id="53165c8c-b8cc-4d9c-a2b6-201737878485">
        <source>createGLRecords(_file : File io; _inv : CM_Invoice; _newFile : Boolean);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
****************************************************/

constants
	DELIMITER = ",";
	TheA :String = #"C5";
	
vars
 	isVoyageInvoice	: Boolean;
	str, glAccount 	: String;
	glSummaryDict 	: CM_GLSummaryByGLCodeDict;
	glSummary 		: CM_GLSummary;
	invoiceLine 	: CM_InvoiceLine;
	charge 			: CM_Charge;
	pos 			: Integer;
	lineTot 		: Decimal[15,2];
	docTot 			: Decimal[15,2];	
	
begin
	//isVoyageInvoice := _inv.invoiceType.isVoyageSpecific();
	isVoyageInvoice := _inv.invoiceType.isVoyageSpecificDebtor(_inv.debtor); // ### TFS 54565 (54384) 22Sep2022 NAVPW1
	create glSummaryDict transient;
	
	foreach	invoiceLine in _inv.invoiceLines do
		foreach charge in invoiceLine.charges do
			charge.getGLSummStatSumByGLCodeInvDes(glSummaryDict);
		endforeach;
	endforeach;
	
	if _newFile then
		str := "Document Number,Account Number, Distribution Type, Debit Amount, Credit Amount";
		_file.writeLine(str);
	endif;
	
	foreach glSummary in glSummaryDict do 	
		lineTot := glSummary.amount;
		pos := 1;
		glAccount := glSummary.glCode.scanUntil(TheA, pos);
		if glAccount.length &gt; 24 then
			glAccount := glAccount[1:24];
		endif;
		
		str := _inv.sequenceNum.String &amp; DELIMITER; 							// Document Number
		str := str &amp; glAccount &amp; DELIMITER; 									// GL Code
		str := str &amp; "1" &amp; DELIMITER &amp; DELIMITER &amp; lineTot.String &amp; DELIMITER; 	// credit or debit the line amount is always '1'
		
		docTot := docTot + lineTot;
		
		_file.writeLine(str);	
	endforeach;
	
	str := _inv.sequenceNum.String &amp; DELIMITER; 								// Document Number
	// ###  For each document number you specify in the distribution file you need a row for the 1210-0000 AR acct as a debit in order to create a balancing of debits equalling credits. 
	str := str &amp; "1210-0000" &amp; DELIMITER; 										// GL Code
	str := str &amp; "2" &amp; DELIMITER &amp; docTot.String &amp; DELIMITER &amp; DELIMITER;  		// credit or debit the total amount is always '2'
	
	_file.writeLine(str);		
	
epilog
	glSummaryDict.purge();
	delete glSummaryDict;
	
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_inv" type="CM_Invoice"/>
        <Parameter name="_newFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createHeaderRecord" id="c17180da-ca24-4a99-9fc5-729e5b55bc54">
        <source>createHeaderRecord(_file : File io; _inv : CM_Invoice; _newFile : Boolean);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	DELIMITER = ",";
vars
	str 		: String;
	idx, pos 	: Integer;
	voyage		: CM_Voyage;
begin	
	if _newFile then
		str := "Type,Type ID,Document Number, Date, Batch ID, Customer ID, Site ID, Comment Text, User Defined Text 1, User Defined Text 2, User Defined Text 3, User Defined Text 4, User Defined Text 5, Full Vessel Name"; 
		_file.writeLine(str);
	endif;
	
	str := "3" &amp; DELIMITER;															//Record Type 1 = Quote; 2 = Order; 3 = Invoice; 4 = Return; 5 = Back Order; 6 = Fulfillment Order
	str := str &amp; "TOSINV".asDoubleQuotedString() &amp; DELIMITER; 						// Type ID
	str := str &amp; _inv.sequenceNum.String &amp; DELIMITER; 								// Invoice Number 
	str := str &amp; _inv.toDT.date.format("MM/dd/yy") &amp; DELIMITER; 					// use END date not posted date
	
	
	str := str &amp; "TRX FROM TOS".asDoubleQuotedString() &amp; DELIMITER; 				// Batch ID
	str := str &amp; _inv.debtor.decfinName.asDoubleQuotedString() &amp; DELIMITER; 		// External Customer ID. 
	str := str &amp; self.getSiteId(_inv.bank).asDoubleQuotedString() &amp; DELIMITER; 		//Site ID. 
	str := str &amp; DELIMITER; 														// Comment Text. 
	str := str &amp; DELIMITER; 														// User Defined Text 1
	str := str &amp; DELIMITER; 														// User Defined Text 2
	str := str &amp; DELIMITER; 														// User Defined Text 3
	str := str &amp; DELIMITER; 														// User Defined Text 4
	str := str &amp; DELIMITER; 														// User Defined Text 5
	
	voyage := _inv.myVoyage;	
	if voyage = null then
		voyage := getVoyage(_inv);
	endif;
	
	if voyage &lt;&gt; null then	// (can happen in unit tests)
		str := str &amp; voyage.vesselName.asDoubleQuotedString(); 						// Full Vessel Name
	endif;
	
	//strip CrLf
	if str.length &lt;&gt; 0 then
		pos := str.pos(CrLf, 1);
		while pos &gt; 0 do
			if pos + 2 &gt; str.length then 
				str := str[1:pos - 1];
				break;
			endif;
			str := str[1:pos] &amp; ' ' &amp; str[pos+2:end];
			pos := str.pos(CrLf, 1);
		endwhile;
		str.replaceChar(Cr.Character, ' ');
		str.replaceChar(Lf.Character, ' ');
	endif;
	_file.writeLine(str);
epilog
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_inv" type="CM_Invoice"/>
        <Parameter name="_newFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="export" id="b97bc6a7-3057-4c8f-9218-b55279d99454">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	ExportDirectory = "processed\";

	SLEEP = 3000;
	TRYS = 10;
vars
	fFolder		: FileFolder;
	file,
	tmpFile 	: File;
	path,
	exportDir 	: String; 

begin
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	
	exportDir := path;
	if not app.isJMTUnitTest then	
		exportDir := path &amp; ExportDirectory;
		create fFolder transient;
		fFolder.fileName := exportDir;

		if not fFolder.isAvailable() then
			fFolder.make();
		endif;
	endif;
	
	
	create file;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.hidden := false;
	
	// ### SALES HEADER - INDIVIDUAL
	file.fileName := exportDir &amp; invoice.myTerminal.code &amp; invoice.sequenceNum.String &amp; "SalesHeader.csv"; 
	createHeaderRecord(file, invoice, true);
	file.close;

	// ### SALES LINES - INDIVIDUAL
	file.fileName := exportDir &amp; invoice.myTerminal.code &amp; invoice.sequenceNum.String &amp; "SalesLines.csv"; 
	createDetailRecords(file, invoice, true);
	file.close;

	// ### SALES DISTRIBUTION - INDIVIDUAL
	file.fileName := exportDir &amp; invoice.myTerminal.code &amp; invoice.sequenceNum.String &amp; "SalesDistribution.csv"; 
	createGLRecords(file, invoice, true);
	file.close;


	// ### SALES HEADER - MERGED
	self.exportMerge(file, path, "SalesHeader.csv","createHeaderRecord", invoice);

	// ### SALES LINES - MERGED
	self.exportMerge(file, path, "SalesLines.csv","createDetailRecords", invoice);

	// ### SALES DISTRIBUTION - MERGED
	self.exportMerge(file, path, "SalesDistribution.csv","createGLRecords", invoice);	

	invoice.incrementExportCount(false);	
	
epilog
	delete file;
	delete tmpFile;
	delete fFolder;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportMerge" id="3b0fdec7-3695-47d8-9015-dd49b5692dae">
        <source>exportMerge(_file : File io; _path : String; _fileName : String; _methodName : String; _inv : CM_Invoice);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	SLEEP = 3000;
	TRYS = 10;

vars
	idx 	: Integer;
	newFile : Boolean;
begin

	// ### SALES LINES - MERGED
	_file.fileName := _path &amp; _fileName; 
	_file.mode := File.Mode_Append;
	_file.kind := File.Kind_Unknown_Text;
	_file.shareMode := File.Share_Exclusive;

	if not _file.isAvailable() then
		newFile := true;
	endif;
	
	idx := 0;
	while true do
		if _file.tryOpen() then
			self.sendMsgWithParams(_methodName, _file, _inv, newFile);
			break;
		else
		
			idx := idx + 1;
			if idx &gt; TRYS then
				app.raiseCMException2(Invoi_expor_not_occur_becau_fi, self.getNiceName(),_file.fileName, null, null);
				break;
			endif;
			process.sleep(SLEEP);
		endif;
		
	endwhile;
	_file.close;

epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_path" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="a2a26328-f89a-4041-874f-2c202a00df3b">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description
21/09/2022		jlika1		54888		Invoice Export has "Testing" in title and not saving to expected location.
****************************************************/

vars
	file 	   : File;
	fFolder    : FileFolder;
	filePrefix : String;
	fileDirStr : String;
	prefixIdx  : Integer;
	message    : String;
begin
	filePrefix := invoice.myTerminal.code &amp; invoice.sequenceNum.String;
	
	prefixIdx := fileNameBase.pos(filePrefix,1);
	if prefixIdx &lt;=0 then
		prefixIdx := fileNameBase.reversePos("\");
	endif;
	fileDirStr := fileNameBase[1:prefixIdx-1];
	if fileDirStr[fileDirStr.length] &lt;&gt; "\" then
		fileDirStr := fileDirStr &amp; "\";
	endif;

	create fFolder;
	fFolder.fileName := fileDirStr;
	if not fFolder.isAvailable then
		message := app.getErrorString2(Expor_path_does_not_exist_cann,fileDirStr,invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create file;
	file.allowReplace := true;
	file.mode := File.Mode_Output;	

	file.fileName := fileDirStr &amp;  filePrefix &amp; "SalesHeader.csv"; 
	createHeaderRecord(file, invoice, true);
	file.close;

	file.fileName := fileDirStr &amp; filePrefix &amp; "SalesLines.csv"; 
	createDetailRecords(file, invoice, true);
	file.close;

	file.fileName := fileDirStr &amp; filePrefix &amp; "SalesDistribution.csv"; 
	createGLRecords(file, invoice, true);
	file.close;

	invoice.incrementExportCount(false);		
epilog
	delete fFolder;
	delete file;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="39423e19-d1ba-494f-90fd-a64a173cc157">
        <source>getCargoType(_invoiceLine : CM_InvoiceLine) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		    Who		Reason
13 March 2023	navmp20	ChangeRequest 56278: PRP - Financial Data Extract Additional Attributes

*/

vars
    cargoType : Integer;
    cargoTyepObj : CM_CargoType;
    cargoTypeDesc : String;
begin
	if _invoiceLine = null then
		return null;
	endif;
	
	if _invoiceLine.trackedItem &lt;&gt; null then
		cargoType := _invoiceLine.trackedItem.cargoType;
	endif;
	
	if _invoiceLine.myTransactionTI &lt;&gt; null then
		cargoType := _invoiceLine.myTransactionTI.cargoType;
	elseif _invoiceLine.myTransactionWO &lt;&gt; null then
		cargoType := _invoiceLine.myTransactionWO.getCargoTypes;
	elseif _invoiceLine.myTransactionEvent &lt;&gt; null then
		cargoType := _invoiceLine.myTransactionEvent.getCargoTypeId;
	endif;

	if cargoType &lt;&gt; null then
		cargoTyepObj := app.myRoot.allCargoTypesById[cargoType];
		if cargoTyepObj &lt;&gt; null then
			cargoTypeDesc := cargoTyepObj.description;
		endif;
	endif;

	return cargoTypeDesc;
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineTypeUnitNarr" id="fcaa7d9d-1cf2-40b9-903b-d383d7860811">
        <source>getInvoiceLineTypeUnitNarr(_invoiceLine : CM_InvoiceLine) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		    Who		Reason
13 March 2023	navmp20	ChangeRequest 56278: PRP - Financial Data Extract Additional Attributes

*/

vars

begin
	
	if _invoiceLine &lt;&gt; null and _invoiceLine.invoiceLineDesc &lt;&gt; null then
		return _invoiceLine.invoiceLineDesc.unitNarration;
	endif;
	return null;
	
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementTypeName" id="6c865277-2402-44a7-8827-65986376950a">
        <source>getMeasurementTypeName(_service : CM_Service) : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin

	if _service = null then
		return null;
	endif;
	
	if _service.myCalculationType &lt;&gt; null then
		return _service.myCalculationType.getMeasurementTypeName();
	endif;

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="String"/>
    </JadeMethod>
