<Class name="CM_EDIItemFieldCSV" id="4622a220-2b4b-4f24-9972-40deed6c7359">
    <superclass name="CM_EDIItemField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="columnIndex" id="2060c680-9ad2-433e-b9e7-fbc69e7b0f3c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getFieldKey" id="9f03639c-b0b9-43a5-967a-0fba89c68417">
        <source>getFieldKey(): Any;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.columnIndex;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getMatchListDisplay" id="2d2e8c0a-63b9-4f5e-942b-817f589d09c7">
        <source>getMatchListDisplay(): String;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.allFieldAdditionals.isEmpty then
		return "(" &amp; self.columnIndex.String &amp; ") " &amp; self.name &amp; " &gt;&gt; " &amp; self.systemName &amp; "  {" &amp; self.stringFormatMethodName &amp; "}";
	endif;
	
	return self.getOtherFieldsStr();
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="e08041e9-7b8d-4218-95e5-ff70d3455f78">
        <updating/>
        <source>setFromXML(_xmlElement: JadeXMLElement) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElement		: JadeXMLElement;
begin

	inheritMethod(_xmlElement);

	xmlElement := _xmlElement.getElementByTagName('columnIndex');
	if xmlElement &lt;&gt; null then
		self.columnIndex:= xmlElement.textData.Integer;
	endif;


end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="setNonSystemAttributes" id="a05ba024-a7e7-49a1-983d-3d98aa474158">
        <updating/>
        <source>setNonSystemAttributes(_name: String; _formatMethodName: String; _fieldIndex: Any) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_name, _formatMethodName, null);

	if _fieldIndex.isKindOf(Integer) then
		self.columnIndex := _fieldIndex.Integer;
	endif;
	
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_formatMethodName" type="String"/>
        <Parameter name="_fieldIndex" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setXMLElement" id="47c084a6-d678-4f74-9b20-2d4690a2823e">
        <source>setXMLElement(_xmlElement: JadeXMLElement input);
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpXMLElem 	: JadeXMLElement;
begin

	inheritMethod(_xmlElement);

	tmpXMLElem := _xmlElement.addElement("columnIndex");
	tmpXMLElem.setText(self.columnIndex.String);

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
</Class>
