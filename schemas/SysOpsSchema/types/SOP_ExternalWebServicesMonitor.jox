    <JadeMethod name="getBGPStatusDetails" id="b9c39505-01e1-4989-960c-8ef5ae5153a3">
        <source>getBGPStatusDetails();
/*
Purpose:			

Date		Who		Reason
26 July 2021	navab1	TFS 50669
*/

vars
	controller : BGP_Controller;
begin

	if app.isAppropriateBGPConfigured(BGP_OpsViewWSRequest.name, null) &lt; 1 then // BGP FOR OPSVIEW NOT CONFIGURED
		self.picBGPStatus.picture := self.picUnavailable.picture;
		self.picBGPStatus.bubbleHelp := app.getErrorString(Control_opsview_not_configu); // "BGP Controller for OpsView is not configured";
	elseif app.isAppropriateBGPRunning(BGP_OpsViewWSRequest.name) then // BGP FOR OPSVIEW RUNNING
		controller := app.getBGPControllerForRequest(BGP_OpsViewWSRequest.name, true);
		
		if controller.getStatus() = EWS_STATUS_IDLE then
			self.picBGPStatus.picture := self.picIdle.picture;
			self.picBGPStatus.bubbleHelp := app.getErrorString(Contr_opsvi_idle_state_waiti_s); // "BGP Controller for OpsView is in IDLE state, it is waiting for the START to be manually sent from the Ops View EWS Definition";
		elseif controller.getStatus() = EWS_STATUS_STARTING 
		or  controller.getStatus() = EWS_STATUS_READYTORUN then
			self.picBGPStatus.picture := self.picStarting.picture;
			self.picBGPStatus.bubbleHelp := app.getErrorString(Producer_opsview_starting); // "BGP Producer for OpsView is Starting";
		elseif controller.getStatus() = EWS_STATUS_RUNNING then
			self.picBGPStatus.picture := self.picRunning.picture;
			self.picBGPStatus.bubbleHelp := app.getErrorString(Controller_opsview_running); // "BGP Controller for OpsView is Running";
		else
			self.picBGPStatus.picture := self.picStopped.picture;
			self.picBGPStatus.bubbleHelp := app.getErrorString(Controller_opsview_stopped); // "BGP Controller for OpsView is Stopped";
		endif;
	else
		self.picBGPStatus.picture := self.picStopped.picture; // BGP FOR OPSVIEW NOT RUNNING
		self.picBGPStatus.bubbleHelp := app.getErrorString(Control_opsview_not_running);// "BGP Controller for OpsView is not running";
	endif;
		
	self.lblBGPStatus.bubbleHelp := self.picBGPStatus.bubbleHelp;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getHttpResponseStrings" id="c739783c-c9c5-4f3d-aede-78c1a67675f5">
        <source>getHttpResponseStrings(): StringArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened
*/

vars
	rowIndex		: Integer;
	include			: Boolean;
	code 			: String;
	strArray		: StringArray;
begin
	create strArray transient;
	
	foreach rowIndex in 1 to self.tblResponse.rows do
		include := self.tblResponse.accessCell(rowIndex, 1).text = "1";
		if include then
			code := Space &amp; self.tblResponse.accessCell(rowIndex, 2).text;
			strArray.add(code);
		endif;
	endforeach;
	
	return strArray;
epilog
	
end;</source>
        <ReturnType type="StringArray"/>
    </JadeMethod>
