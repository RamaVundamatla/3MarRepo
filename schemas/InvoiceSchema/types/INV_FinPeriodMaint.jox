    <JadeMethod name="addToolbarControls" id="43a67a3e-dc0d-4acd-ba3f-8c2739eba36b">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
//	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNewType, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUpdate, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnBulk, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropNext, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnBulk_click" id="5336ebca-a2d8-4d68-ad14-9f662a7b065b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBulk_click(btn: Button input) updating;
/*
Purpose:			
Date		Who		Reason
10 February 2015	cnwab1	Initial creation
*/

vars


	form : CMUI_CalendarDateBulkAddForm;
	
begin

	form := app.loadForm(CMUI_CalendarDateBulkAddForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CalendarDateBulkAddForm;
	
	if form &lt;&gt; null then
		form.financialPeriodMode := true;
		form.myCurrentFinancialPeriodType := self.myCurrentFPType;
		form.show;
	endif;


epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="45f584b1-571b-4842-bec3-4421ae4fd0b8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.setUpdateMode(self.UpdateMode_Delete);
	if self.myCurrentFPDate &lt;&gt; null then
		self.modePropertyUpdate := self.MODEPROPERTY_DATE;
	elseif self.myCurrentFPType &lt;&gt; null then
		self.modePropertyUpdate := self.MODEPROPERTY_PERIOD;
	else
		global.beep;
		return;
	endif;
	self.doDelete();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
