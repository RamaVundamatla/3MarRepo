    <JadeMethod name="addRejectedMoveToHistory" id="d90d5281-367e-4ef6-83a2-1c9829bfd6f9">
        <updating/>
        <source>addRejectedMoveToHistory(aTask: CM_RTQueueTask) updating;
/*
Based on the current QueueTask reference set, when this happens, we create
a new machineHistory object, and add it to the collection.
We may also be set when availability code is set!
*/
vars
	histEntry:   CM_MachineMoveHistory;
	userCode : String;
begin
	create histEntry;
	if user &lt;&gt; null then
		userCode :=user.code;
	else
		userCode := CM_MachineHistory.Unknown_Value;	//Par 32542
	endif;
	histEntry.rejected(aTask, userCode, self);
end;</source>
        <Parameter name="aTask" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="addRejectedRTQueueTask" id="30e62545-cc0e-4edd-bb04-7c6944da6fd2">
        <updating/>
        <source>addRejectedRTQueueTask(task : CM_RTQueueTask) updating;

/*

Purpose:			Adds this rejected task to the Machine's list of tasks.

Parameters:			Task being rejected

Return Value:		None


Date		Who		Reason
08 Nov 2010	cnwkpd1	PAR #26113 - Change behaviour of overstowed moves for ITS Interface

*/

vars
	alert			: CM_SystemAlert;
	now				: TimeStamp;
	str				: String;

begin
	if rejectedRTQueueTasks.includes(task) then
		//-------------
		//Already there
		//-------------
		return;
	endif;
	//epr CCMS 1391 - 11/8/14 refactored common code that is alwasys called after this method
	task.myEntry.addAlert(app.getErrorString2(Machine_rejected_entry,self.id,task.myEntry.id.trimRight), SEVERE_INFO);
	self.addRejectedMoveToHistory(task);
	
	// PAR #26113 - For ITS interface, do not save rejected tasks
	if self.myITSInterfaceLoggedOn &lt;&gt; null then
		return;
	endif;
	

	rejectedRTQueueTasks.add(task);
	
	
	//----------------------
	//Purge out rejectedQueueTasks that have been destroyed
	//----------------------

	if maxRejectedTasks = 0 or rejectedRTQueueTasks.size &lt; maxRejectedTasks then
		return;
	endif;
	//----------------
	//Create a System Alert, number of rejections has been exceeded
	//----------------
	create alert;
	str	:= app.getErrorString2(ALERT_MACH_REJECTS, id.trimBlanks, maxRejectedTasks.String);
	alert.details := str;
	alert.setSeverity(SEVERE_INFO);
	alert.myTerminal := self.myTerminal;
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
	
end;</source>
        <Parameter name="task" type="CM_RTQueueTask"/>
    </JadeMethod>
