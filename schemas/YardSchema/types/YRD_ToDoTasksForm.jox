    <JadeMethod name="doCancel" id="208bd531-8402-40e1-a789-9b9c8bef9564">
        <updating/>
        <source>doCancel() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	if self.mode = self.Mode_Enquire then
		inheritMethod();//close the form
