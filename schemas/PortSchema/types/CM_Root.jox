	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_POSTED,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_POSTED),
