		endif;
		
		delete wMastFileNode;
		wMastFileNode := dMastFileNode.cloneSelf(true);
		wMastFileNode.fileName := wMastFolder.fileName &amp; '\' &amp; JadeRegex@replaceAll(dMastFileNode.name, "", "^[0-9]*|[0-9]*$", true);
		if not wMastFileNode.isAvailable() then
			devSourceCompareAgent.logMessage('"' &amp; dMastFileNode.name &amp; '" exists in ' &amp; dMastFolder.fileName &amp; ' but not in ' &amp; wMastFolder.fileName, LogERROR);
		endif;
	endforeach;
	delete wMastFileNode;

	// Now compare each file (or folder) in the left side with the matching one on the right
	foreach wMastFileNode in wMastFolder.files do
		if self.excludeFilename(wMastFileNode.fileName) then
			devSourceCompareAgent.logMessage('Excluding file "' &amp; wMastFileNode.fileName &amp; '"', LogINFO);
			continue;
		endif;

		delete dMastFileNode;
		dMastFileNode := wMastFileNode.cloneSelf(true);
		dMastFileNode.fileName := dMastFolder.fileName &amp; '\' &amp; JadeRegex@replaceAll(wMastFileNode.name, "", "^[0-9]*|[0-9]*$", true);
		if not dMastFileNode.isAvailable() then
			devSourceCompareAgent.logMessage('"' &amp; wMastFileNode.name &amp; '" exists in ' &amp; wMastFolder.fileName &amp; ' but not in ' &amp; dMastFolder.fileName, LogERROR);
			continue;
		endif;
		
