    <JadeMethod name="addPortsOfCall" id="e6f09e35-35c4-4eda-9d3c-a0f8283bfd6c">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_PortCodeSelector::addPorts"/>
        </interfaceImplements>
        <source>addPortsOfCall(_objectArray : ObjectArray; _areTranshipPorts : Boolean);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27 April 2009	cnwer1	Initial creation
03 Jun 2009		concms1	par 19013 - make any ports being added active
*/

vars

	obj : Object;
	port : CM_Port;
	currentIndex,
	newLevel,
	newIndex : Integer;
	displayText : String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.mode &lt;&gt; self.Mode_Add and self.mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveInactive(_objectArray, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Make Code Active', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	currentIndex:=self.lstPortsOfCall.listIndex;
	newIndex:=currentIndex;
	newLevel:=1;
	if _areTranshipPorts then
		if currentIndex &lt; 0 then
			return;
		endif;
		if self.lstPortsOfCall.itemLevel[currentIndex] &lt;&gt; 1 then
			return;
		endif;
		newLevel:=2;
	else
		if currentIndex &gt; 0 and self.lstPortsOfCall.itemHasSubItems(currentIndex) then
			newIndex:=self.lstPortsOfCall.getNextIndexAtLevel(currentIndex,1,false);
		endif;
	endif;
	
	foreach obj in _objectArray do
		if not obj.isKindOf(CM_Port) then
			continue;
		endif;
		port:=obj.CM_Port;
		displayText:=self.myAssistant.displayEntryPort(port);
		if currentIndex &lt; 0 then
			self.lstPortsOfCall.addTreeObject(displayText,port,newLevel,true);
		else
			self.lstPortsOfCall.addObjectAt(displayText,newIndex+1,port,newLevel,true);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
        <Parameter name="_areTranshipPorts" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="b95df907-cbe5-4391-84a1-f5e3d2a92078">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On   	Changed By  	Reason
// 20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCopyVoyage, CMUI_Toolbar.Control_Alignment_Left);									
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		

	// R Barr 26/10/2006 Comalco - Global Voyage
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366

//	if app.myCurrentUserCan(self.myTerminal, PmShipPlanning) then
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then//07 Oct 2019	NDL	TFS 46169
		// licensed for cargo module
		toolbar.addButton(self.btnBayDefinition, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnExchangeSum, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					
//	endif;
	
	if app.myCurrentUserCan(self.myTerminal, Mod_Harbour) then
		toolbar.addButton(self.btnDocuments, CMUI_Toolbar.Control_Alignment_Left); // 04/03/2022 jlizm1 TFS 52834
	endif;

	if app.myCurrentUserCan(self.myTerminal, Mod_VesselRORO) then
		toolbar.addButton(self.btnROROEnquiry, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	//09 Jul 2013	NDL	Par 31965
	toolbar.addButton(self.btnHoldDef, CMUI_Toolbar.Control_Alignment_Left);
	
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then
		toolbar.addButton(self.btnTranslations, CMUI_Toolbar.Control_Alignment_Left);
//	endif;		
	
	toolbar.addButton(self.btnOpenSchedule, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnArchive, CMUI_Toolbar.Control_Alignment_Left);								
	toolbar.addButton(self.btnCheckList, CMUI_Toolbar.Control_Alignment_Left);					// TFS 4793
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left); // PAR 35478
	toolbar.addButton(self.btnEventAlloc, CMUI_Toolbar.Control_Alignment_Left); // 25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	toolbar.addButton(self.btnOOWConfirm,CMUI_Toolbar.Control_Alignment_Left); //16 Mar 2018	NDL	TFS 37447	

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
 // ### TFS 54485 09AUG2022 NAVAB1	toolbar.addFrame(self.frmAllStatuses, CMUI_Toolbar.Control_Alignment_Left);	//21 Jun 2018	NDL	TFS 39216
	
	if self.shtHMSHarborData.visible then
		// licensed for HMS module
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);						
		toolbar.addButton(self.btnShippingAgent, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnShippingLine, CMUI_Toolbar.Control_Alignment_Left);
		if app.myRoot.canDo(Mod_Invoicing) // Invoice License
		and self.myTerminal.getConfig(FinancialsEnabled).Boolean then // Invoicing Turned On
			self.btnResourcesUsed.caption := "Resources Used...";
			toolbar.addButton(self.btnResourcesUsed, CMUI_Toolbar.Control_Alignment_Left);
		endif;
	endif;

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnVesselDef, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addButton(self.btnColourCode, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCargoForecast, CMUI_Toolbar.Control_Alignment_Left); 	// 20-Apr-2022 TFS# 53142
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	self.frmtbPOC.visible:=true;
	self.frmtbPOC.setHorizontalOffsetLeft(self.lblPOC.width.Integer);
	self.frmtbPOC.addButton(self.btnPOCAdd, CMUI_Toolbar.Control_Alignment_Left);
	self.frmtbPOC.addButton(self.btnPOCRemove, CMUI_Toolbar.Control_Alignment_Left);
	self.frmtbPOC.addButton(self.btnPOCUp, CMUI_Toolbar.Control_Alignment_Left);
	self.frmtbPOC.addButton(self.btnPOCDown, CMUI_Toolbar.Control_Alignment_Left);
	self.frmtbPOC.positionToolbarControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustProxyCutoffs" id="0be82a80-5319-4aec-b5d3-c8f6a1aa1677">
        <updating/>
        <source>adjustProxyCutoffs(_relative : Integer) updating;
/*
Purpose:	

Date		Who		Reason
13 March 2025	navab1	JIRA 34233
*/

vars
	originTS, earliestTS, cutoffTS,
	earliestTSPN, cutoffTSPN : TimeStamp;
	cutoff : CM_ReceivalCutoffVoyage;
	changed : Boolean;
	idx : Integer;

begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	originTS := self.getCutoffRelativeToTS(_relative);
	originTS := self.localToSystemTime(originTS);  // ### JIRA 34524 08APR2025 NAVAB1 this must be server timestamps, what we display will be in the UI's local
	
	foreach cutoff in self.allProxyCutoffs do
	
		if cutoff.defaultRelativeTo &lt;&gt; _relative then
			continue;
		endif;
		
		changed := true;
		
		if cutoff.defaultRelativeTo = DefaultRelativeTo_RecCutOff 
		or cutoff.isEDIType then
			earliestTS := null;
			cutoffTS := originTS.subtractHoursAndMinutes (cutoff.hoursCutoff);
			earliestTSPN := null;
			cutoffTSPN := originTS.subtractHoursAndMinutes (cutoff.hoursCutoffPN);
		else
			earliestTS := originTS.subtractHoursAndMinutes (cutoff.hoursEarly);
			cutoffTS := originTS.subtractHoursAndMinutes (cutoff.hoursCutoff);
			earliestTSPN := originTS.subtractHoursAndMinutes (cutoff.hoursEarlyPN);
			cutoffTSPN := originTS.subtractHoursAndMinutes (cutoff.hoursCutoffPN);
		endif;
		
		if cutoff.defaultRelativeTo = DefaultRelativeTo_ShipExchange then
			earliestTS := null;
			earliestTSPN := null;
		endif;

		cutoff.setProxyTimes(cutoffTS,earliestTS, cutoffTSPN, earliestTSPN);
		idx := 0;
		if self.tblVoyageCutoffs.findObjectInRow(cutoff, idx) then // ### JIRA 34549 07APR 2025 NAVAB1
			self.loadRecCutoffsRow(cutoff,idx);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_relative" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustProxyCutoffsHours" id="42e6b254-382c-4bf2-9692-af63834a9a39">
        <updating/>
        <source>adjustProxyCutoffsHours(_relative : Integer) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2025
ADO - JIRA 34524
*/

vars
	originTS, earliestTS, cutoffTS,
	earliestTSPN, cutoffTSPN : TimeStamp;
	cutoff : CM_ReceivalCutoffVoyage;
	changed : Boolean;
	idx, minutes : Integer;
	hoursCutoff, hoursCutoffPN, hoursEarly, hoursEarlyPN : Decimal[23,2];
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	if self.myCurrentVoyage = null then
		return;
	endif;
	

	originTS := self.getCutoffRelativeToTS(_relative);
	originTS := self.localToSystemTime(originTS);  // ### JIRA 34524 08APR2025 NAVAB1
	
	// When overidden do not adjust the date/times, just change the hours.
	if self.myCurrentVoyage.overrideDefaults then
		foreach cutoff in self.allProxyCutoffs do
		
			if cutoff.defaultRelativeTo &lt;&gt; _relative then
				continue;
			endif;
			
			changed := true;
			
			if cutoff.isEDIType then
				minutes := cutoff.cutoffDateTime.getDifferenceInMinutes(originTS);
				hoursCutoff := minutes / 60;
				minutes := cutoff.cutoffDateTimePN.getDifferenceInMinutes(originTS);
				hoursCutoffPN := minutes / 60;
				hoursEarly := 0;
				hoursEarlyPN := 0;
			else
				minutes := cutoff.cutoffDateTime.getDifferenceInMinutes(originTS);
				hoursCutoff := minutes / 60;
				minutes := cutoff.cutoffDateTimePN.getDifferenceInMinutes(originTS);
				hoursCutoffPN := minutes / 60;

				minutes := cutoff.earliestDateTime.getDifferenceInMinutes(originTS);
				hoursEarly := minutes / 60;
				minutes := cutoff.earliestDateTimePN.getDifferenceInMinutes(originTS);
				hoursEarlyPN := minutes / 60;
				
			endif;
			
			cutoff.setProxyHours(hoursCutoff, hoursCutoffPN, hoursEarly, hoursEarlyPN);
			idx := 0;
			if self.tblVoyageCutoffs.findObjectInRow(cutoff, idx) then 
				self.loadRecCutoffsRow(cutoff,idx);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_relative" type="Integer"/>
    </JadeMethod>
