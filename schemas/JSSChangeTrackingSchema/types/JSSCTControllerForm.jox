    <JadeMethod name="btnBounce_click" id="25c4cce6-f6e0-4729-a09a-3941271d6af5">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBounce_click(jadeMask: JadeMask input) updating;

vars
	obj: Object;
begin
	obj := tblTracker.accessRow(tblTracker.row).itemObject;
	if obj &lt;&gt; null then
		obj.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Bounce());
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
