    <JadeMethod name="getCurrentTIForTerminal" id="3dde88ab-e5c2-4c24-8347-809982cea6b4">
        <source>getCurrentTIForTerminal(_terminal : CM_Terminal) : CM_TrackedItem ;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 16 August 2007
//
//	GET THE LAST TRACKEDITEM INSTANCE THAT APPEARED IN THE PASSED IN TERMINAL FOR THIS HEADER.
//  WE CAN THEN DO THINGS LIKE CHECK IF IT IS ONSITE OR WHAT ITS STATUS IS.
//----------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
begin
	
	foreach ti in self.allTis reversed do 
		if ti.myTerminal = _terminal then
			return ti;
		endif;
	endforeach;
	
	return ti;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
