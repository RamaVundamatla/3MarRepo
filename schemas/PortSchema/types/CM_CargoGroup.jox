/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ncg : CM_NotifiedCargoGroup;

begin

	_allPreAssignedCargoIdsDict.clear();

	if not self.allPreAssignedCargoIdsDict.isEmpty then
		self.allPreAssignedCargoIdsDict.copy( _allPreAssignedCargoIdsDict );
	else
		ncg := self.getMyNotifiedGroup;
		if ncg &lt;&gt; null then
			ncg.allPreAssignedCargoIdsDict.copy( _allPreAssignedCargoIdsDict );
		endif;
