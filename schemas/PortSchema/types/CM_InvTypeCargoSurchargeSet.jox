<CollClass name="CM_InvTypeCargoSurchargeSet" id="e6ff00a1-3704-42b0-bbf9-ca8d7c2b518e">
    <loadFactor>98</loadFactor>
    <memberType name="CM_InvTypeCargoSurcharge"/>
    <superclass name="ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="findFirstUsing" id="8108e445-49fa-4444-a591-d8921ede697f">
        <source>findFirstUsing(	_invLineType : CM_InvoiceLineDesc ):CM_InvTypeCargoSurcharge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2018	jlgndl1	Initial creation	TFS 39305

*/

vars

	surCharge : CM_InvTypeCargoSurcharge;

begin

	if _invLineType = null then
		return null;
	endif;

	foreach surCharge in self do
		if surCharge.allSelectedInvLineTypes.includes( _invLineType ) then
			return surCharge;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_InvTypeCargoSurcharge"/>
    </JadeMethod>
</CollClass>
