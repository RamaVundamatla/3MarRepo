<CollClass name="CM_TradeByDescriptionDict" id="445612be-d873-4a78-9277-09e4f23a6622">
    <memberType name="CM_Trade"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_Trade::description"/>
    </MemberKey>
    <JadeMethod name="getByCode" id="8b5f4d85-b284-4f7b-aaf3-5df45b1b43a8">
        <source>getByCode(_code : String) : CM_Trade;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 March 2023	navpw1	Initial creation TFS: 57242

*/

vars
	iter	: Iterator;
	trade	: CM_Trade;
	
begin
	iter := self.createIterator;
	
	while iter.next(trade) do
		if trade.code &lt;&gt; _code then
			continue;
		endif;
		
		return trade;
		
	endwhile;
	
	return null;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Trade"/>
    </JadeMethod>
</CollClass>
