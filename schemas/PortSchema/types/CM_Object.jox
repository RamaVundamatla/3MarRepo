    <JadeMethod name="getExtensionObjectValue" id="ec7d3407-c4c0-4046-be7f-b2f262755116">
        <source>getExtensionObjectValue(_key : String) : Any;
/*

Purpose:			Get the value associated with the passed in key from the 
					receiver's extension object

Parameters:			Key for the value

Return Value:		Stored value for the named key

Date		Who		Reason
26 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	objExtension	: CM_ObjectExtension;
	
begin
	objExtension := self.getMyObjectExtension();
	
	if objExtension = null then
		return null;
	endif;
	
	return objExtension.getValue(_key);
	
epilog

end;</source>
