	BadLogin : String = '{
	"userId": "baduser",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "LWT",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';

vars
	incomingJsonString,
	terminalCode,
	loginJson				: String;
	terminal				: CM_Terminal;
	expectFailure			: Boolean;
	root					: CM_Root;
	booking					: CM_BookingRef;
	bookingItem				: CM_BookingRefItem;
	contCargoType			: CM_CargoType;
	contCargoTypeId			: Integer;
	releaseRequest			: CM_BulkRelease;
	subTerminal				: CM_SubTerminal;
	isSubTerminalsOn 		: Any;
begin
	root := self.getRoot();
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myRoot.allTerminals[terminalCode];
	
	app.writeLog("Changing MaxLiftWeightWarnOnly Terminal Config to true", LogINFO);
	app.writeLog("Changing IsSubTerminalsOn Terminal Config to true", LogINFO);
	self.setTerminalConfig(MaxLiftWeightWarnOnly, true);
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, true);
	
	//Delete Booking
	self.deleteBooking(self.TFS57264);
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	incomingJsonString := HappyDayScenarioJson;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Assert Booking and Booking items to make sure they match request
	
	booking := terminal.allBookingRefsByRef[BookingRef];
	
	self.assertTrueMsg(booking &lt;&gt; null, "Booking Ref (" &amp; BookingRef &amp; ") has not been created/is null");
	//Assert Booking Fields
	self.assertTrueMsg(booking.bookingReference = BookingRef, "Field: " &amp; CM_BookingRef::bookingReference.name &amp; " | Expected: '" &amp; BookingRef &amp; "' | Actual: '" &amp; booking.bookingReference &amp; "'");
	self.assertTrueMsg(booking.consignorCode = ConsignorCode, "Field: " &amp; CM_BookingRef::consignorCode.name &amp; " | Expected: '" &amp; ConsignorCode &amp; "' | Actual: '" &amp; booking.consignorCode &amp; "'");
	self.assertTrueMsg(booking.myConsignor &lt;&gt; null, "Field: " &amp; CM_BookingRef::myConsignor.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myConsignor.code = ConsignorCode, "Field: " &amp; CM_BookingRef::myConsignor.name &amp; " | Expected: '" &amp; ConsignorCode &amp; "' | Actual: '" &amp; booking.myConsignor.code &amp; "'");
	self.assertTrueMsg(booking.destinationPort = DestinationPort, "Field: " &amp; CM_BookingRef::destinationPort.name &amp; " | Expected: '" &amp; DestinationPort &amp; "' | Actual: '" &amp; booking.destinationPort &amp; "'");
	self.assertTrueMsg(booking.dischargePort = DischargePort, "Field: " &amp; CM_BookingRef::dischargePort.name &amp; " | Expected: '" &amp; DischargePort &amp; "' | Actual: '" &amp; booking.dischargePort &amp; "'");
	
	//Loop to validate hazards on booking
	self.assertTrueMsg(booking.allTIHazards.isNotEmpty, "Field: " &amp; CM_BookingRef::allTIHazards.name &amp; " | Expected: 'not empty' | Actual: 'empty'");
	//Extend the above to check all ti hazards on booking header
	
	self.assertTrueMsg(booking.consigneeCode = ConsigneeCode, "Field: " &amp; CM_BookingRef::consigneeCode.name &amp; " | Expected: '" &amp; ConsigneeCode &amp; "' | Actual: '" &amp; booking.consigneeCode &amp; "'");
	self.assertTrueMsg(booking.myConsignee &lt;&gt; null, "Field: " &amp; CM_BookingRef::myConsignee.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myConsignee.code = ConsigneeCode, "Field: " &amp; CM_BookingRef::myConsignee.name &amp; " | Expected: '" &amp; ConsigneeCode &amp; "' | Actual: '" &amp; booking.myConsignee.code &amp; "'");
	self.assertTrueMsg(booking.operatorCode = OperatorId, "Field: " &amp; CM_BookingRef::operatorCode.name &amp; " | Expected: '" &amp; OperatorId &amp; "' | Actual: '" &amp; booking.operatorCode &amp; "'");
	self.assertTrueMsg(booking.myOperator &lt;&gt; null, "Field: " &amp; CM_BookingRef::myOperator.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myOperator.code = OperatorId, "Field: " &amp; CM_BookingRef::myOperator.name &amp; " | Expected: '" &amp; OperatorId &amp; "' | Actual: '" &amp; booking.myOperator.code &amp; "'");
	self.assertTrueMsg(booking.voyageCode = VoyageCode, "Field: " &amp; CM_BookingRef::voyageCode.name &amp; " | Expected: '" &amp; VoyageCode &amp; "' | Actual: '" &amp; booking.voyageCode &amp; "'");
	self.assertTrueMsg(booking.myVoyage &lt;&gt; null, "Field: " &amp; CM_BookingRef::myVoyage.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myVoyage.code = VoyageCode, "Field: " &amp; CM_BookingRef::myVoyage.name &amp; " | Expected: '" &amp; VoyageCode &amp; "' | Actual: '" &amp; booking.myVoyage.code &amp; "'");
	self.assertTrueMsg(booking.bookingRefRemarks = Remarks, "Field: " &amp; CM_BookingRef::remarks.name &amp; " | Expected: '" &amp; Remarks &amp; "' | Actual: '" &amp; booking.bookingRefRemarks &amp; "'");
	self.assertTrueMsg(booking.shippingReference = ShippingReference, "Field: " &amp; CM_BookingRef::shippingReference.name &amp; " | Expected: '" &amp; ShippingReference &amp; "' | Actual: '" &amp; booking.shippingReference &amp; "'");
	self.assertTrueMsg(booking.noEmptiesOut = NoEmptiesOut, "Field: " &amp; CM_BookingRef::noEmptiesOut.name &amp; " | Expected: '" &amp; NoEmptiesOut.asStringJMT &amp; "' | Actual: '" &amp; booking.noEmptiesOut.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.status = Status.asIntegerJMT, "Field: " &amp; CM_BookingRef::status.name &amp; " | Expected: '" &amp; Status &amp; "' | Actual: '" &amp; booking.status.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.receiveAsTranship = ReceiveAsTranship, "Field: " &amp; CM_BookingRef::receiveAsTranship.name &amp; " | Expected: '" &amp; ReceiveAsTranship.asStringJMT &amp; "' | Actual: '" &amp; booking.receiveAsTranship.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.myTranshipVoyage &lt;&gt; null, "Field: " &amp; CM_BookingRef::myTranshipVoyage.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myTranshipVoyage.code = TransVoyageCode, "Field: " &amp; CM_BookingRef::myTranshipVoyage.name &amp; " | Expected: '" &amp; TransVoyageCode &amp; "' | Actual: '" &amp; booking.myTranshipVoyage.code &amp; "'");
	self.assertTrueMsg(booking.packAs = app.bookingPackAsStringToEnumb(PackAs), "Field: " &amp; CM_BookingRef::packAs.name &amp; " | Expected: '" &amp; app.bookingPackAsStringToEnumb(PackAs).asStringJMT &amp; "' | Actual: '" &amp; booking.packAs.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.customsAgent = CustomsAgent, "Field: " &amp; CM_BookingRef::customsAgent.name &amp; " | Expected: '" &amp; CustomsAgent &amp; "' | Actual: '" &amp; booking.customsAgent &amp; "'");
	self.assertTrueMsg(booking.directDelivery = DirectDelivery, "Field: " &amp; CM_BookingRef::directDelivery.name &amp; " | Expected: '" &amp; DirectDelivery.asStringJMT &amp; "' | Actual: '" &amp; booking.directDelivery.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.myFreightForwarder &lt;&gt; null, "Field: " &amp; CM_BookingRef::myFreightForwarder.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myFreightForwarder.code = FreightForwarderCode, "Field: " &amp; CM_BookingRef::myFreightForwarder.name &amp; " | Expected: '" &amp; FreightForwarderCode &amp; "' | Actual: '" &amp; booking.myFreightForwarder.code &amp; "'");
	self.assertTrueMsg(booking.myCarrier &lt;&gt; null, "Field: " &amp; CM_BookingRef::myCarrier.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myCarrier.code = CarrierCode, "Field: " &amp; CM_BookingRef::myCarrier.name &amp; " | Expected: '" &amp; CarrierCode &amp; "' | Actual: '" &amp; booking.myCarrier.code &amp; "'");
	self.assertTrueMsg(booking.myStevedore &lt;&gt; null, "Field: " &amp; CM_BookingRef::myStevedore.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myStevedore.code = StevedoreCode, "Field: " &amp; CM_BookingRef::myStevedore.name &amp; " | Expected: '" &amp; StevedoreCode &amp; "' | Actual: '" &amp; booking.myStevedore.code &amp; "'");
	
	contCargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UTCargoType1);
	
	if contCargoType &lt;&gt; null then
		contCargoTypeId := contCargoType.id;
	endif;
	
	//Assert Booking Items
	foreach bookingItem in booking.allBookingRefItems do
			self.assertTrueMsg(bookingItem.cargoType = contCargoTypeId, "Field: " &amp; CM_BookingRefItem::id.name &amp; " | Expected: '" &amp; contCargoTypeId.String &amp; "' | Actual: '" &amp; booking.cargoType.String &amp; "'");
			self.assertTrueMsg(booking.myCargoType &lt;&gt; null, "Field: " &amp; CM_BookingRefItem::myCargoType.name &amp; " | Expected: 'not null' | Actual: 'null'");
			self.assertTrueMsg(bookingItem.myCargoType.id = contCargoTypeId, "Field: " &amp; CM_BookingRefItem::myCargoType.name &amp; " | Expected: '" &amp; contCargoTypeId.String &amp; "' | Actual: '" &amp; booking.myCargoType.id.String &amp; "'");
			
			self.assertTrueMsg(bookingItem.commodity = UTCommodityCode1, "Field: " &amp; CM_BookingRefItem::commodity.name &amp; " | Expected: '" &amp; UTCommodityCode1 &amp; "' | Actual: '" &amp; bookingItem.commodity &amp; "'");
			self.assertTrueMsg(bookingItem.isoType = UTIsoType1, "Field: " &amp; CM_BookingRefItem::isoType.name &amp; " | Expected: '" &amp; UTIsoType1 &amp; "' | Actual: '" &amp; bookingItem.isoType &amp; "'");
			
			self.assertTrueMsg(bookingItem.myISOType &lt;&gt; null, "Field: " &amp; CM_BookingRefItem::myISOType.name &amp; " | Expected: 'not null' | Actual: 'null'");
			self.assertTrueMsg(bookingItem.myISOType.code = UTIsoType1, "Field: " &amp; CM_BookingRefItem::myISOType.name &amp; " | Expected: '" &amp; UTIsoType1 &amp; "' | Actual: '" &amp; bookingItem.myISOType.code &amp; "'");
			
			self.assertTrueMsg(bookingItem.weight = UTWeight1, "Field: " &amp; CM_BookingRefItem::weight.name &amp; " | Expected: '" &amp; UTWeight1.String &amp; "' | Actual: '" &amp; bookingItem.weight.String &amp; "'");
			self.assertTrueMsg(bookingItem.height = UTHeight1, "Field: " &amp; CM_BookingRefItem::height.name &amp; " | Expected: '" &amp; UTHeight1.String &amp; "' | Actual: '" &amp; bookingItem.height.String &amp; "'"); // navlw1 #62948
			self.assertTrueMsg(bookingItem.description = UTDescription1, "Field: " &amp; CM_BookingRefItem::description.name &amp; " | Expected: '" &amp; UTDescription1 &amp; "' | Actual: '" &amp; bookingItem.description &amp; "'");
			self.assertTrueMsg(bookingItem.purchaseOrder = UTPurchaseOrder1, "Field: " &amp; CM_BookingRefItem::purchaseOrder.name &amp; " | Expected: '" &amp; UTPurchaseOrder1 &amp; "' | Actual: '" &amp; bookingItem.purchaseOrder &amp; "'");
			self.assertTrueMsg(bookingItem.remarks = UTRemarks1, "Field: " &amp; CM_BookingRefItem::remarks.name &amp; " | Expected: '" &amp; UTRemarks1 &amp; "' | Actual: '" &amp; bookingItem.remarks &amp; "'");
			self.assertTrueMsg(bookingItem.serviceOrder = UTServiceOrder1, "Field: " &amp; CM_BookingRefItem::serviceOrder.name &amp; " | Expected: '" &amp; UTServiceOrder1 &amp; "' | Actual: '" &amp; bookingItem.serviceOrder &amp; "'");
			
			self.assertTrueMsg(bookingItem.mySpecialStow &lt;&gt; null, "Field: " &amp; CM_BookingRefItem::mySpecialStow.name &amp; " | Expected: 'not null' | Actual: 'null'");
			self.assertTrueMsg(bookingItem.mySpecialStow.code = UTSpecialStow1, "Field: " &amp; CM_BookingRefItem::mySpecialStow.name &amp; " | Expected: '" &amp; UTSpecialStow1 &amp; "' | Actual: '" &amp; bookingItem.mySpecialStow.code &amp; "'");
			
			self.assertTrueMsg(bookingItem.allTIHazards.isNotEmpty, "Field: " &amp; CM_BookingRefItem::allTIHazards.name &amp; " | Expected: 'not empty' | Actual: 'empty'");
			//Extend the above to check all ti hazards on booking item
			
			self.assertTrueMsg(bookingItem.getCurtainsIn = UTCurtains1, "Field: " &amp; CM_BookingReeferProperties::curtainsIn.name &amp; " | Expected: '" &amp; UTCurtains1.String &amp; "' | Actual: '" &amp; bookingItem.getCurtainsIn.String &amp; "'");
			self.assertTrueMsg(bookingItem.getCarbonDioxide = UTCarbonDioxide1, "Field: " &amp; CM_BookingReeferProperties::carbonDioxide.name &amp; " | Expected: '" &amp; UTCarbonDioxide1.String &amp; "' | Actual: '" &amp; bookingItem.getCarbonDioxide.String &amp; "'");
			self.assertTrueMsg(bookingItem.getHumidity = UTHumidity1, "Field: " &amp; CM_BookingReeferProperties::humidity.name &amp; " | Expected: '" &amp; UTHumidity1.String &amp; "' | Actual: '" &amp; bookingItem.getHumidity.String &amp; "'");
			self.assertTrueMsg(bookingItem.getOxygen = UTOxygen1, "Field: " &amp; CM_BookingReeferProperties::oxygen.name &amp; " | Expected: '" &amp; UTOxygen1.String &amp; "' | Actual: '" &amp; bookingItem.getOxygen.String &amp; "'");
			self.assertTrueMsg(bookingItem.getVentilation = UTVentilation1, "Field: " &amp; CM_BookingReeferProperties::ventilation.name &amp; " | Expected: '" &amp; UTVentilation1.String &amp; "' | Actual: '" &amp; bookingItem.getVentilation.String &amp; "'");
			self.assertTrueMsg(bookingItem.getVentilationUnits = UTVentUnits1, "Field: " &amp; CM_BookingReeferProperties::ventilationUnits.name &amp; " | Expected: '" &amp; UTVentUnits1.String &amp; "' | Actual: '" &amp; bookingItem.getVentilationUnits.String &amp; "'");
			self.assertTrueMsg(bookingItem.getTemperature = UTTemperature1, "Field: " &amp; CM_BookingReeferProperties::temperature.name &amp; " | Expected: '" &amp; UTTemperature1.String &amp; "' | Actual: '" &amp; bookingItem.getTemperature.String &amp; "'");
			self.assertTrueMsg(bookingItem.quantity = UTCargoQuantity1, "Field: " &amp; CM_BookingRefItem::quantity.name &amp; " | Expected: '" &amp; UTCargoQuantity1.String &amp; "' | Actual: '" &amp; bookingItem.quantity.String &amp; "'");	//TFS 63028
		break;
	endforeach;
	
	// Assert Release Request
	// navlw1 #62571
	releaseRequest := self.getReleaseRequest("RELBOOK1234");
	self.assertNotNullMsg(releaseRequest,"Should have created the release request RELBOOK1234");
	// subTerminals should be set to true so we can check this
	subTerminal := booking.myTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
	self.assertNotNullMsg(subTerminal,"Should have a subTerminal");
	self.assertNotNullMsg(releaseRequest.mySubTerminal,"Release Request should have a subTerminal");
	self.assertTrueMsg(releaseRequest.mySubTerminal.code = subTerminal.code, "SubTerminal should be set to " &amp; subTerminal.code);
	
	//Assert Reserve Selection
	
	// navlw1 #62948
	self.deleteBooking(self.TFS57264);
	
	// create a booking without dimensions/weight objects, check that we do not get any errors
	incomingJsonString := NoDimensionsWeightObjectsInJson;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Assert Booking and Booking items to make sure they match request
	booking := terminal.allBookingRefsByRef[BookingRef];
	self.assertNotNullMsg(booking, "Booking has not been created");
	
	//Test for errors:
	expectFailure := true;
	
	//Test empty json string
	incomingJsonString := "[]";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :87054. No Data");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Test errors raised in web service endpoint when parameters/requried fields not filled in (Web validation not db)
	//Input_req_booking_ref_field
	incomingJsonString := self.bookingBuildJsonRequest(null, OperatorId, CargoType1, HazardCode1, VoyageCode, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :95957. An input required for the Booking Ref field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Input_required_field_operator
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, null, CargoType1, HazardCode1, VoyageCode, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :89203. An input is required for the Operator field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	/*//Input_required_field_cargoId
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, null, CargoType1, HazardCode1, VoyageCode, null, CargoId2, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :89114. An input is required for the Cargo Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);*/
	
	//Input_required_field_cargoType
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, null, HazardCode1, VoyageCode, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :88993. An input is required for the Cargo Type field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Input_Required_Hazard_Code1
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoType1, null, VoyageCode, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :95966. An input is required for the Hazard Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Voyage_code_found
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoType1, HazardCode1, VoyageCodeNotFound, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :84755. Voyage code " &amp; VoyageCodeNotFound &amp; " not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Tranship_voyage_code_invalid
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoType1, HazardCode1, VoyageCode, VoyageCodeNotFound, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :86326. Tranship Voyage code '" &amp; VoyageCodeNotFound &amp; "' is invalid!");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Cargo_Type_Not_Found
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoTypeNotFound1, HazardCode1, VoyageCode, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :85492. The Cargo Type (" &amp; CargoTypeNotFound1 &amp; ") was not found.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Cargo_SubType_Not_Found_CType
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoType1, HazardCode1, VoyageCode, null, CargoType2, CargoSubTypeNotFound2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :86555. Cargo Sub-Type (" &amp; CargoSubTypeNotFound2 &amp; ") not found for Cargo Type " &amp; CargoType2);
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Special_stow_not_found
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoType1, HazardCode1, VoyageCode, null, CargoType2, CargoSubType2, SpecialStowNotFound1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :95967. Special Stow (" &amp; SpecialStowNotFound1 &amp; ") not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	//Hazard_code_not_found
	incomingJsonString := self.bookingBuildJsonRequest(BookingRef, OperatorId, CargoType1, HazardCodeNotFound, VoyageCode, null, CargoType2, CargoSubType2, SpecialStow1);
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :95968. Hazard Code (" &amp; HazardCodeNotFound &amp; ") not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
	// Unauthorized - Username / Password not OK
	loginJson := BadLogin;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "401 Unauthorized - Username / Password not OK");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostBooking.name, loginJson, incomingJsonString, expectFailure);
	
epilog
	app.writeLog("Changing MaxLiftWeightWarnOnly Terminal Config to false", LogINFO);
	app.writeLog("Changing IsSubTerminalsOn Terminal Config back to what it was at the start of this unit test", LogINFO);
	self.setTerminalConfig(MaxLiftWeightWarnOnly, false);
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostCargo" id="4445a5e4-6f9b-4b48-a8b6-a43f7fca5c26">
        <updating/>
        <source>tPostCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
16 Feb 2024 	navsaa30	Initial creation
22 Apr 2024		naviv1		TFS 63619 : CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
22 May 2024		navmd1		TFS 64234 Return Pin information when creating prenotes
16 Jun 2024 	navhn30		ChangeRequest 64067: CUX | Include additional fields in APIs (Free Text)
10 Jul 2024		navlw1		TFS 65030: Fixed up Customer Priority as part of this bug as data difference between D/WMAST
13 Sep 2024     navsp1      TFS Bug 66117: CUX - Go Live 02 issue - Contents Status ignored by POST /cargo API
17 Sep 2024 	navhn30		ChangeRequest 65706: MTN | POST/cargo to ignore "child" item prenotified flag: [TECH DEBT]
30 Apr 2025		navpw1		JIRA: MTN-34769 - Fixing unit test on overnight run
*/

constants
	UTRealBooking				: String = "UT_6232";
	ThisVoyage = "UTVOY63113";
	ThisVessel = "UTVES63113";
	IncomingJsonString = '
	[
    {
        "id": "API804A25",
        "bookingId":"1236",
        "cargoTypeId": "REBAR",
        "weights": {
            "gross": 2250,
            "net": 250,
            "tare": 2000
        },
        "alternativeId": "TESTY1234",
        "voyageId": "'&amp; ThisVoyage &amp;'",
        "prenotified":"True",
        "locationId": "BS01",
        "operatorId": "WEST",
        "consigneeId": "ABCNR",
        "consignorId": "ABCNR",
        "contentsStatusId": "LCL",
        "imexStatus": "IMP",
        "hazards": [
            {
                "id": "2.2",
                "undgNumber": "3340",
                "limitedQuantity": true,
                "packingGroupId": "II",
                "marinePollutant": 1,
                "acidBase": "ACID",
                "flashpointTemperature": 2
            }
        ],
        "dischargePortId": "NZBLU",
        "destinationPortId": "NZAKA",
        "loadPortId": "NZPOE",
        "receivalDetails": {
            "id": "US00010",
            "type": "Wagon",
            "dateTime": "2023-12-07T10:22:59+12:00"
        },
        "remarks": "Test Remarks",
        "customsReferences": [
            {
                "id": "Test",
                "alternateId": "Test",
                "typeId": "Test",
                "position": 1,
                "status": "Test Status",
                "packages": {
                    "total": 10,
                    "remaining": 5
                },
                "remarks": "Test Remarks",
                "retentionPeriod": "2023-04-12T10:22:59+12:00"
            }
        ]
        
    }
    
]';
IncomingJson2 = '
	[
    {
        "id": "API804A29",
        "bookingId":"'&amp; UTRealBooking &amp; '",
        "cargoTypeId": "REBAR",
        "weights": {
            "gross": 2250,
            "net": 250,
            "tare": 2000
        },
        "alternativeId": "TESTY1234",
        "voyageId": "'&amp; ThisVoyage &amp;'",
        "prenotified":"True",
        "locationId": "BS01",
        "operatorId": "WEST",
        "consigneeId": "ABCNR",
        "consignorId": "ABCNR",
        "contentsStatusId": "LCL",
        "imexStatus": "IMP",
        "hazards": [
            {
                "id": "2.2",
                "undgNumber": "3340",
                "limitedQuantity": true,
                "packingGroupId": "II",
                "marinePollutant": 1,
                "acidBase": "ACID",
                "flashpointTemperature": 2
            }
        ],
        "dischargePortId": "NZBLU",
        "destinationPortId": "NZAKA",
        "loadPortId": "NZPOE",
        "receivalDetails": {
            "id": "US00010",
            "type": "Wagon",
            "dateTime": "2023-12-07T10:22:59+12:00"
        },
        "remarks": "Test Remarks",
        "customsReferences": [
            {
                "id": "Test",
                "alternateId": "Test",
                "typeId": "Test",
                "position": 1,
                "status": "Test Status",
                "packages": {
                    "total": 10,
                    "remaining": 5
                },
                "remarks": "Test Remarks",
                "retentionPeriod": "2023-04-12T10:22:59+12:00"
            }
        ]
        
    }
    
]';

	
	UTRealBooking1			: String = "BK-63619-04";
	PostJsonString = '
	[
		{
			"operatorId": "UTOP",
			"destinationPortId": "NZAKL",
			"dischargePortId": "NZBLU",
			"loadPortId": "NZPOE",
			"imexStatus": "EXP",
			"prenotified": true,
			"receivalDetails": {
				"type": "Truck"
			},
