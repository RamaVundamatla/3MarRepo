<Class name="CMQF_FilterReports">
    <JadeMethod name="setFromAgent" id="82ee26ed-bf2c-48cc-98d0-78a99e7b7b99">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rowStr		: String;
	tmpTAType	: CM_TerminalAreaType;
	tmpConsigneeConsignor	: CM_ConsigneeConsignor;
begin

	self.allTerminals.clear();
	_agent.allTerminals.copy(self.allTerminals);

	self.blockLength := _agent.getValueByNameIfVisible(ETRow_BlockLength).Integer;

	if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
		/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_BaseDate).String, 
								self.baseDateTplType, self.baseDateTplFactor, ETRow_BaseDate);
		self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_StartDate).String, 
		//					self.startDateTplType, self.startDateTplFactor, ETRow_StartDate);
		
		self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_EndDate).String, 
							self.endDateTplType, self.endDateTplFactor, ETRow_EndDate);*/
		self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_BaseDate), 
								self.baseDateTplType, self.baseDateTplFactor, ETRow_BaseDate);
		self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_StartDate), 
							self.startDateTplType, self.startDateTplFactor, ETRow_StartDate);
		
		self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_EndDate), 
							self.endDateTplType, self.endDateTplFactor, ETRow_EndDate);
							
	else	
		//PAR16192 - cnwsh3	Reports with date values were not being processed correctly by locale (ie. NZ is "dd/mm/yy" where US is "mm/dd/yy")
		//self.startDate := _agent.getValueByNameIfVisible(ETRow_StartDate).String.asDateJMT;
		//self.endDate := _agent.getValueByNameIfVisible(ETRow_EndDate).Date;
		//self.baseDate := _agent.getValueByNameIfVisible(ETRow_BaseDate).Date;
		self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_StartDate);
		self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_EndDate);
		self.baseDate := _agent.getValueByNameForDateIfVisible(ETRow_BaseDate);
		
	endif;
	
	if _agent.isRowIncluded(ETRow_Operator) then
		self.myOperator := _agent.getSelectedOperator();
	endif;
	
	self.locationComment := _agent.getValueByNameIfVisible(ETRow_LocationComment).String;
	
	if _agent.isRowIncluded(ETRow_AgeType) then
		self.ageType := _agent.getSelectedAgeType();
	else
		self.ageType := TI_AGE_RECEIVEDDT;
	endif;
	
	rowStr := _agent.getValueByNameIfVisible(ETRow_TerminalAreaId).String;

	if (rowStr &lt;&gt; null) and (rowStr &lt;&gt; Any_String) then
		self.setMyTerminalArea( _agent.getSelectedTerminalArea() );
	endif;

	if _agent.isRowIncluded(ETRow_RowId) then
		self.setMyLocationsController( _agent.getSelectedRowId() );
	endif;
	
	if _agent.isRowIncluded(ETRow_CargoType) then
		self.setMyCargoType( _agent.getSelectedCargoType() );
	endif;
	
	if _agent.isRowIncluded(ETRow_TerminalAreaType) then
		tmpTAType := _agent.getSelectedTAType();
		if tmpTAType &lt;&gt; null then
			self.terminalAreaTypes.clear();
			self.terminalAreaTypes.add(tmpTAType.type);
		endif;
	endif;

	if _agent.isRowIncluded(ETRow_Consignor) then
		tmpConsigneeConsignor := _agent.getSelectedConsignor(); 
		if tmpConsigneeConsignor &lt;&gt; null then
			self.consignor := tmpConsigneeConsignor.code;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_Consignee) then
		tmpConsigneeConsignor := _agent.getSelectedConsignee(); 
		if tmpConsigneeConsignor &lt;&gt; null then
			self.consignee := tmpConsigneeConsignor.code;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_MySubTerminal) then //27/04/2009 cnwdz2 ccms1735
		self.setMySubTerminal( _agent.getSelectedSubTerminal() );
	endif;
	
	if _agent.getValueByNameIfVisible(ETRow_Product).String &lt;&gt; null then
		self.setMyProduct( _agent.getSelectedProduct() );
	endif;
	
	if _agent.isRowIncluded(ETRow_IsLocationInspected) then		// 28/09/2009 cnwar2 CCMS1107/#20638
		self.isLocationInspected := _agent.getSelectedRowInspect();
	endif;
	if _agent.isRowIncluded(ETRow_IsLocationFumigated) then		// 28/09/2009 cnwar2 CCMS1107/#20638
		self.isLocationFumigated := _agent.getSelectedRowFumigate();
	endif;
		
	_agent.setFilterProfile(self);
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
