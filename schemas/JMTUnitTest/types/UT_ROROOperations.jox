    <JadeMethod name="uCheckGetCargoDetailsCorrect2" id="e15ae220-adc2-4f80-95ec-ce7629330328">
        <updating/>
        <source>uCheckGetCargoDetailsCorrect2() updating;

/*

Purpose:		Check that CM_ROROLocnDefnVoyage::getCargoDetails returns the correct information

Date			Who		Reason
06/09/2012		cnwmh5	Initial creation

*/

constants

	VesselId				: String = "JGRIG";
	VoyageId				: String = "UT_MDHVOY12";
	OperatorId				: String = "UTOP";
	DeckName 				: String = "4";   						// WEATHER DECK

vars

	voyage					: CM_Voyage;
	deck					: CM_DeckVoyage;
	voyageJob				: CM_VoyageJob;
	locnDefnVoyage			: CM_ROROLocnDefnVoyage;
	tempTI					: CM_TrackedItem;
	bs						: CM_BlockStack;

	slots					: CM_LCArray;
	tiArray					: CM_TIArray;
	
	strs 					: StringArray;
	failedArray				: HugeStringArray;		//cnwmc5 - 8/10/2012
	
	detailsToCheck			: String;
	str1, str2				: String;				//cnwmc5 - 8/10/2012
	idx						: Integer;
	
begin

	// setup non ship cargo
	bs := self.addBlockStack("UTMHBSE", 100, null);
	self.assertNotNull(bs);

	// Create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, OperatorId, "UTSL", "Chief Tasman", 0, false, true);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	create slots transient;
	create tiArray transient;
	create failedArray transient;		//cnwmc5 - 8/10/2012
	
	// set up the areas and containers on the voyage
	if voyage.myROROStructure &lt;&gt; null then
		deck := voyage.myROROStructure.allDecksByCode[DeckName];
		self.assertNotNull(deck);
		
		// setup the cargo
		self.xSetupCargoForGCDC2(voyage, deck);
		
		// check that the details are correct
		self.xCheckGCDCorrect2(ShpDisplayMode_Actual, 0, deck, failedArray);
		self.xCheckGCDCorrect2(ShpDisplayMode_Proposed, 0, deck, failedArray);
		self.xCheckGCDCorrect2(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, deck, failedArray);
		self.xCheckGCDCorrect2(ShpDisplayMode_Proposed, ShpDisplayMode_ColCodeLoad, deck, failedArray);
		
	endif;
	
	//cnwmc5 - 8/10/2012 - added new style of error handling
	foreach str1 in failedArray do
		str2 := str2 &amp; str1 &amp; CrLf;
	endforeach;

	self.assertEqualMsg(failedArray.size, 0, str2);
	
epilog
	
	delete failedArray;			//cnwmc5 - 8/10/2012
	
	delete slots;
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uROROSOBMachRuleCTAToAny" id="5b60be36-5ea0-4e9c-890a-8126f06813e6">
        <updating/>
        <source>uROROSOBMachRuleCTAToAny() updating;

/*

Purpose:		Check RORO SOB move with machine rule CTA -&gt; Any

Date			Who		Reason
14/08/2012		cnwmh5	Initial creation

*/
constants

	CTAId						: String = "UTCV";
	VoyageId					: String = "UT_MDHVOY10";
	VesselId					: String = "UT_MDHVES10";
	ContainerId					: String = "SOBMDH22452";
	DeckId						: String = "D1";
	CraneId						: String = "UTC7";
	BlockStackId				: String = "UTMHBS3";
	
vars

	taType						: CM_TerminalAreaType;
	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	operator					: CM_Operator;
	trackedItem					: CM_TrackedItem;
	port						: CM_Port;
	realAlloc 					: CM_VoyageAllocation;
	voyageJob					: CM_VoyageJob;
	theDeck						: CM_DeckVoyage;
	bs							: CM_BlockStack;

	theTIs						: CM_TIArray;
	altRoroLCs					: CM_LCArray;
	roroLCs 					: CM_LCArray;

	theEditions 				: CM_ObjectByOidEditionDict;

begin
	// get the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// create the vessel and voyage
	deleteVoyage(VoyageId);
	deleteVessel(VesselId);
	vessel := self.addVesselLOLOholdsRORO(VesselId, operator);
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage);
	
	// create a block stack
	bs := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(bs);
	
	// get the port
	port := app.myRoot.allPorts["NZBLU"];
	
	// create the machine rule cta -&gt; ANY
	taType := self.getRoot.allTerminalAreaTypes[TA_TYPE_BLOCK_STACK];
	self.addMachineRuleType(taType, null, RTMoveMethod_16, FullMoveQueuing);

	// create the container
	create theTIs transient;
	self.opts.purge();
	trackedItem := self.addContainerAtLocation(ContainerId, operator, "U20G", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	self.assertNotNull(trackedItem);
	self.opts.purge();
	self.opts.addAssoc(UTTI_DischargePort, "NZNSN");
	self.opts.addAssoc("Voyage", voyage);
	self.updateTI(trackedItem);
	self.deleteStops(trackedItem);
	theTIs.add(trackedItem);
	
	if voyage.myROROStructure &lt;&gt; null then
		theDeck := voyage.myROROStructure.allDecksByCode[DeckId];
		if theDeck &lt;&gt; null then
			create roroLCs transient;
			create altRoroLCs transient;
			realAlloc := self.addVoyageAllocation(voyage, "NZNSN", "GEN2", "", 1, false, false);		// ISO Container
			roroLCs.add(theDeck.allROROLocnDefnByCode["AUTOLOCN30"].getLC());
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs, 1);
			voyageJob := self.addVoyageROROJob(voyage, theDeck, "UT_MRCTA", roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
		endif;
	endif;
	
	self.planTIsRORO(theTIs, roroLCs, realAlloc.allRequests.first.CM_ROROSlotRequest);
	
	self.moveAllCargoOnVoyage(voyage, QUEUE_MODE);
	
epilog

	// if the machine rule was created then delete it as it'll cause issues for other tests
	self.deleteMachineRuleType(taType, null);

	delete theTIs;
	delete altRoroLCs;
	delete roroLCs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uRotateOOTLFullTest" id="6b8517b9-95a8-4267-a4e7-76bca0fb68d8">
        <updating/>
        <source>uRotateOOTLFullTest(_voyage : CM_Voyage; _isLoad : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2012	cnwmc5	Initial creation

*/

vars
	voyageDeck 	: CM_DeckVoyage;
	location	: CM_ROROLocnDefn;
	
begin
	// Get the deck
	voyageDeck := _voyage.myROROStructure.allDecksByCode['D1'];
	
	// Create the OOTL cells for Load
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, false, true, 3, -15, voyageDeck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, 12, -10, voyageDeck, app.myPassport);

	// Rotate the cells
	location := voyageDeck.allROROLocnDefnByCode['DD1071O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['DD1071OR'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 1, "Expected size to be 1 - OOTL 20'");
	self.assertTrueMsg(location.isPlannedRotated = true, "1x1 is not planned rotated - OOTL 20'");
	
	location := voyageDeck.allROROLocnDefnByCode['DD1073O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['DD1073OR'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 1, "Expected size to be 1 - OOTL 40'");
	self.assertTrueMsg(location.isPlannedRotated = true, "1x1 is not planned rotated - OOTL 40'");
	
	//Un-rotate OOTL cells
	location := voyageDeck.allROROLocnDefnByCode['DD1071OR'];
	app.myTrxUA.trxUpdateROROLocnDefnUnRotate(_isLoad, location,  app.myPassport);
	location := voyageDeck.allROROLocnDefnByCode['DD1071O'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 0, "Expected size to be 0 - OOTL 20'");
	self.assertTrueMsg(location.isPlannedRotated = false, "1x1 is planned rotated - OOTL 20'");
	
	location := voyageDeck.allROROLocnDefnByCode['DD1073OR'];
	app.myTrxUA.trxUpdateROROLocnDefnUnRotate(_isLoad, location,  app.myPassport);
	location := voyageDeck.allROROLocnDefnByCode['DD1073O'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 0, "Expected size to be 0 - OOTL 40'");
	self.assertTrueMsg(location.isPlannedRotated = false, "1x1 is planned rotated - OOTL 40'");
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="uRotateROROCells" id="97f4618a-5885-4b4c-9fcb-3292474eb4a1">
        <updating/>
        <source>uRotateROROCells(_voyage : CM_Voyage; _isLoad : Boolean; _rLoadNull : Boolean; _rDischargeNull : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2012	cnwmc5	Initial creation

*/

vars
	voyageDeck 	: CM_DeckVoyage;
	location	: CM_ROROLocnDefn;

begin
	// Get the deck
	voyageDeck := _voyage.myROROStructure.allDecksByCode['D1'];
	
	//////////////////////////////////////////////////
	////                                          ////
	////                Horizontal                ////
	////                                          ////
	//////////////////////////////////////////////////

	// Rotate the cells (horizontal)
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN31'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN31R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 10, "Expected size to be 10 - horizontal");
	self.assertTrueMsg(location.isPlannedRotated = true, "2x5 is not planned rotated");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 2x5 horizontal");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 2x5 horizontal");
	
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN34'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN34R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 6, "Expected size to be 6 - horizontal");
	self.assertTrueMsg(location.isPlannedRotated = true, "2x3 is not planned rotated - horizontal");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 2x3 horizontal");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 2x3 horizontal");
	
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN33'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN33R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 5, "Expected size to be 5 - horizontal");
	self.assertTrueMsg(location.isPlannedRotated = true, "1x5 is not planned rotated - horizontal");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 1x5 horizontal");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 1x5 horizontal");
	
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN19'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN19R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 3, "Expected size to be 3 - horizontal");
	self.assertTrueMsg(location.isPlannedRotated = true, "1x3 is not planned rotated - horizontal");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 1x3 horizontal");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 1x3 horizontal");
	
	//////////////////////////////////////////////////
	////                                          ////
	////                Vertical                  ////
	////                                          ////
	//////////////////////////////////////////////////
	
	// Rotate the cells (vertical)
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN42'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN42R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 10, "Expected size to be 10 - vertical");
	self.assertTrueMsg(location.isPlannedRotated = true, "2x5 is not planned rotated - vertical");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 2x5 vertical");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 2x5 vertical");
	
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN40'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN40R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 6, "Expected size to be 6 - vertical");
	self.assertTrueMsg(location.isPlannedRotated = true, "2x3 is not planned rotated - vertical");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 2x3 vertical");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 2x3 vertical");
	
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN38'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN38R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 5, "Expected size to be 5 - vertical");
	self.assertTrueMsg(location.isPlannedRotated = true, "1x5 is not planned rotated - vertical");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 1x5 vertical");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 1x5 vertical");
	
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN37'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, _isLoad);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN37R'];
	self.assertTrueMsg(location.allPlannedRotatedLocnDefns.size() = 3, "Expected size to be 3 - vertical");
	self.assertTrueMsg(location.isPlannedRotated = true, "1x3 is not planned rotated - vertical");
	self.assertTrueMsg((location.myRotateLoad = null) = _rLoadNull, "myRotateLoad is set incorrectly - 1x3 vertical");
	self.assertTrueMsg((location.myRotateDischarge = null) = _rDischargeNull, "myRotateDischarge is set incorrectly - 1x3 vertical");
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_rLoadNull" type="Boolean"/>
        <Parameter name="_rDischargeNull" type="Boolean"/>
