    <JadeMethod name="validateForCreate" id="c8240c85-a28e-4c30-8151-d3b82509a5e9">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin

	inheritMethod();
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Terminal), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.mySubTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(SubTerminal), null, null);
	//	app.raiseCMException1(Input_required_field_Required, app.getErrorString(SubTerminal), null, null); // cnwdb2	PAR 35364
		app.raiseCMException(Input_required_field_subTermCd, null, null); //13 Jul 2018	NDL	TFS 39702
	endif;

epilog

end;</source>
