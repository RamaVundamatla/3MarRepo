    <JadeMethod name="listShit" id="6da968de-21c5-45bd-bbd9-f27bd9489bb4">
        <source>listShit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2015	cnwndl1	Initial creation

*/

vars
	class : Class;
	schema : Schema;
	classColl : ClassColl;
	borderStyle: Integer;
	form : Form;
begin
	app.initialiseMobileApp;
	schema := currentSchema.getSchema("MobileUISchema");
	classColl := schema.getAllClasses(false);
	foreach class in classColl where class.inheritsFrom(MOB_HandHeldForm) do
		create form as class transient;
		borderStyle := form.getPropertyValue("borderStyle").Integer;
		if borderStyle &lt;&gt; 2 then
			write class.name;
		endif;
		delete form;
	endforeach;
	
epilog
	delete classColl;
end;</source>
    </JadeMethod>
</Class>
