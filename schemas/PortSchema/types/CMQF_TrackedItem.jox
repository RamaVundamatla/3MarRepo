    <JadeMethod name="cloneReferences" id="d7411fec-5f64-49e3-b10f-1edeafbeed24">
        <updating/>
        <source>cloneReferences(_obj: CMQF_TrackedItem; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);

	self.allQryIMEXStatuses.clear();
	_obj.allQryIMEXStatuses.copy(self.allQryIMEXStatuses);
	self.allQryStopTables.clear();
	_obj.allQryStopTables.copy(self.allQryStopTables);
	self.allQryStopTables.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	
	self.allQryVoyageJobs.clear();
	_obj.allQryVoyageJobs.copy(self.allQryVoyageJobs);
	self.allQryVoyageJobs.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	
	self.setMyLoadPort( _obj.getMyLoadPort );
	self.setMyPort( _obj.getMyPort );
	self.setMyProduct( _obj.getMyProduct );
	self.setMyVoyage( _obj.getMyVoyage );
	self.setMyCargoType( _obj.getMyCargoType );
	self.mySiteState	:= _obj.mySiteState;
	//self.myVoyage		:= _obj.myVoyage;
	self.setMyISOTypeGroup( _obj.getMyISOTypeGroup );
	self.setMyOperatorGroup( _obj.getMyOperatorGroup );
	self.setMyVVR(_obj.getMyVehicleVisit());	// 24/4/18 MAP TFS37340
	self.setMyShippingLine(_obj.getMyShippingLine);	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	
end;</source>
        <Parameter name="_obj" type="CMQF_TrackedItem"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
