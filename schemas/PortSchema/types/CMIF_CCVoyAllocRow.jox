    <JadeMethod name="addCargo" id="271c0f2e-e43a-4ec7-9cc8-2090939b36c9">
        <updating/>
        <source>addCargo( _ti : CM_TrackedItem; _export, _rh, _sob, _planned : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	if _export then
		self.allActualCargoExports.add( _ti );
		self.addLinkObject( ETRow_MatchingTIsCollection, _ti );
		
	elseif _rh then
		self.allActualCargoRH.add( _ti );
		self.addLinkObject( ETRow_NumRehandles, _ti );
		
	elseif _sob then
		self.allActualCargoSoB.add( _ti );
		self.addLinkObject( ETRow_NumSoB, _ti );
		
	elseif _planned then
		if not self.allPlanned.includes( _ti ) then
			self.allPlanned.add( _ti );
			self.addLinkObject( ETRow_SlotReqWithPlannedTIs, _ti );
		endif;
		
	endif;
	
	self.myCCVoyAllocTableRoot.addNoteableObject( _ti );
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_export" type="Boolean"/>
        <Parameter name="_rh" type="Boolean"/>
        <Parameter name="_sob" type="Boolean"/>
        <Parameter name="_planned" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addLinkObject" id="cfb01ffd-5adf-4252-bd2b-13962266aa9a">
        <updating/>
        <source>addLinkObject( _entTableRowName : String; _obj : CM_Object ):CMIF_CCVoyAllocObjectLink protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	linkObject : CMIF_CCVoyAllocObjectLink;
	dupKey : Boolean;

begin

	on Exception do self.handleException1310( exception, dupKey );	//21 Sep 2012	NDL	Par 30251

	create linkObject transient;

	linkObject.setDetails(	_entTableRowName,	//_entTableRowName : String;
							_obj,	//_myCollectedObject : CM_Object;
							self	//_myCCVoyRowAllocRow : CMIF_CCVoyAllocRow
							);
							
	//21 Sep 2012	NDL	Par 30251
	if dupKey then
		delete linkObject;
		//02 Apr 2015	NDL	Par 35941 Don't queue the refresh, effectively causes a loop.
		//self.myCCVoyAllocTableRoot.doQueueFullRefresh();  // somethiongs not right, queue a complete refresh of the form.
		return null;
	endif;
							
	self.setHasBeenUpdated( true );
			
	return linkObject;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entTableRowName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="CMIF_CCVoyAllocObjectLink"/>
    </JadeMethod>
    <JadeMethod name="addRequest" id="ae73005f-2072-44b2-ab9f-099edc1e2c8e">
        <updating/>
        <source>addRequest( _req : CM_Request; _export, _rh, _sob : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	slot : CM_SlotRequest;
	slotCont : CM_SlotController;
	roroReq : CM_RORORequest;
	roroSlotCont : CM_VoyageROROController;
	realTi : CM_TrackedItem;
	wle : CM_WorkListEntry;

begin

	if _export then
		self.allColourCodingExports.add( _req );
		self.addLinkObject( ETRow_ColourCodedExports, _req );
		
	elseif _rh then
		self.allColourCodingRH.add( _req );
		self.addLinkObject( ETRow_ColourCodedRehandles, _req );
		
	elseif _sob then
		self.allColourCodingSoB.add( _req );
		self.addLinkObject( ETRow_ColourCodedSobs, _req );
		
	endif;
	
	wle := _req.allWorkListEntries.first;
	if wle &lt;&gt; null and not wle.isCompleteForJob then
		realTi := wle.myTrackedItem;
	endif;
	if realTi &lt;&gt; null then
		self.addCargo( realTi, false, false, false, true );
	endif;
	

epilog

end;</source>
        <Parameter name="_req" type="CM_Request"/>
        <Parameter name="_export" type="Boolean"/>
        <Parameter name="_rh" type="Boolean"/>
        <Parameter name="_sob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColourCodingExportSize" id="94fef06a-ffb0-458d-b83b-39395b96b6ec">
        <source>getColourCodingExportSize() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	size : Integer;
	req : CM_Request;
	qty : Integer;

begin

	size := self.allColourCodingExports.size;
	
	foreach req in self.allColourCodingExports discreteLock where req.isVoyageRequest  do		
		qty := req.CM_VoyageRequest.quantity.Integer;
		if qty &lt; 2 then
			continue;
		endif;
		size := size + ( qty - 1 );
	endforeach;
	
	return size;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
