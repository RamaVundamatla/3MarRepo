    <JadeMethod name="translateForm" id="33dd195b-c64e-4af7-b94f-ade0785a6b6c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 May 2023 18:06:26.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026015, locale);
	btnAudits.translateCaption(Xlat_0026016, locale);
	btnClose.translateCaption(Xlat_0026017, locale);
	btnNew.translateCaption(Xlat_0026018, locale);
	btnRemove.translateCaption(Xlat_0026019, locale);
	btnUpdate.translateCaption(Xlat_0026020, locale);
	lblBusinessUnit.translateCaption(Xlat_0026021, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026022, locale);
	mnuContextMenu.translateCaption(Xlat_0026023, locale);
end;</source>
    </JadeMethod>
