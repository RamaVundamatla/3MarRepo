    <JadeMethod name="processAttributeDependencies" id="09a9a7e1-e979-46d0-a015-7af04653cf35">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist: CMIF_EDIUserDefinedAssist input; _strIdentifier: String; _reset : Boolean; _xlationOperator: CM_Operator) updating;
/*
Date		Who		Reason
11 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 20 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
*/
vars
	ediTI : CM_EDITrackedItem;
	str : String;
begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then 
		foreach ediTI in _ediUserDefinedAssist.allChildrenEDITIs do
			str := str &amp; ediTI.String&amp;' ';
			if ediTI.id = null then
				ediTI.setId(self.id);
			endif;
		endforeach;
		_ediUserDefinedAssist.allChildrenEDITIs.clear;
//write class.name&amp;'::'&amp;method.name&amp;' self='&amp;self.String&amp;' assist.myMasterEDITI='&amp;_ediUserDefinedAssist.myMasterEDITI.String&amp;' reset='&amp;_reset.String&amp;' str='&amp;str;
	else
		if self.commodity &lt;&gt; null then
			if app.myRoot.isAnEmptyCommodity(self.commodity, false) then
				self.fullOrMT := "E";
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
