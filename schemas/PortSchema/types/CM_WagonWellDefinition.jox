    <JadeMethod name="getDisplayStringForAttribute" id="b940aae2-7992-4eaf-811b-fe82e8bd77cc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	locId : String;
	str : String;

begin
	
	if _attrName = ETRow_LocationIds then
		foreach locId in self.wellLocationIds do
			if str = null then
				str := wellId &amp; locId;
			else
				str := str &amp; "," &amp; wellId &amp; locId;
			endif;
		endforeach;
		return str;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWellDescription" id="1e5cb4ce-1259-40d6-8d3f-ccb2d7f80198">
        <source>getWellDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	str : String;
	weightMeasureType : CM_MeasurementType;
	lengthMeasureType : CM_MeasurementType;

begin

	weightMeasureType := app.getDefaultMeasurementForType(Type_Weight);
	lengthMeasureType := app.getDefaultMeasurementForType(Type_Length);

	str := "Tare Weight = " &amp; app.convertMeasurementForDisplay(weightMeasureType.shortName, self.tareWeight) &amp; " " &amp; weightMeasureType.shortName;
	str := str &amp; ", Max Load Weight = " &amp; app.convertMeasurementForDisplay(weightMeasureType.shortName, self.maxLoadWeight) &amp; " " &amp; weightMeasureType.shortName;
	str := str &amp; ", Overall Length = " &amp; app.convertMeasurementForDisplay(lengthMeasureType.shortName, self.overallLength) &amp; " " &amp; lengthMeasureType.shortName;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6380019c-3ff3-4eb6-9b27-516ab3fbac46">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

	proxy : CM_WagonWellDefinition;

begin

	proxy := inheritMethod();
	proxy.myWagonClass := self.myWagonClass;
	return proxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDefaultValueOnCreate" id="b0d841fc-268a-4c3a-b14b-b5b9665e1158">
        <updating/>
        <source>setDefaultValueOnCreate( 	_myWagonClass : CM_WagonClass;
							_wellId : String
							) updating;
/*

Purpose:		Bare bones default data.	

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

begin

	self.wellId := _wellId;
	self.setMyWagonClass( _myWagonClass );
	if self.myWagonClass &lt;&gt; null then
		self.deckHeight := self.myWagonClass.deckHeight;
	endif;
	self.lenInUnits := 4;
	self.wellLocationIds.clear();
	self.wellLocationIds.add("1");
	self.wellLocationIds.add("2");
	self.wellLocationIds.add("3");
	self.wellLocationIds.add("4");

epilog

end;</source>
        <Parameter name="_myWagonClass" type="CM_WagonClass"/>
        <Parameter name="_wellId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4b7973b4-b671-4520-9546-e63f7e5047a0">
        <updating/>
        <source>setForUpdate( _proxy : CM_WagonWellDefinition ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

begin

	self.deckHeight := _proxy.deckHeight;		
	self.lenInUnits := _proxy.lenInUnits;	
	self.maxCargoHeight := _proxy.maxCargoHeight;	
	self.maxLoadWeight := _proxy.maxLoadWeight;	
	self.overallLength := _proxy.overallLength;	
	self.overallWidth := _proxy.overallWidth;	
	self.tareWeight := _proxy.tareWeight;	
	self.wellId := _proxy.wellId;	
	
	self.wellLocationIds.clear();
	if not _proxy.wellLocationIds.isEmpty then
		_proxy.wellLocationIds.copy( self.wellLocationIds );
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_WagonWellDefinition"/>
    </JadeMethod>
    <JadeMethod name="setMyWagonClass" id="90f11f1a-0193-421c-92f0-fcce73186288">
        <updating/>
