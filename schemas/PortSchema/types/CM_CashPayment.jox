    <JadeMethod name="getTokensForDelimiter" id="9896e5ac-23d7-4d90-9dcf-5b6ce83c21ab">
        <source>getTokensForDelimiter(_value : String; _delimiter : String; _array : StringArray input) protected;
// 34990 copy of String getTokensForDelimiter to make a change that breaks other usage of the original
vars
	theStr,
	theToken	: String;
	pos, delimLen,
	theLen		: Integer;

begin

	theStr := _value;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen := theStr.length;
	delimLen := _delimiter.length;

	pos := 1;
	while (pos &gt; 0) do
		theToken := theStr.scanUntil(_delimiter, pos);
		_array.add(theToken);
		if pos = 0 then
			break;
		endif;
		pos := pos + delimLen;
		if pos &gt; theLen then
			_array.add(null);
			break;
		endif;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="StringArray" usage="input"/>
    </JadeMethod>
