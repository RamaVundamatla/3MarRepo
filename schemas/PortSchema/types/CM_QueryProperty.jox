    <JadeMethod name="removeOperator" id="115d3d4e-9e9a-4b06-9c1f-362ba83f8a69">
        <source>removeOperator( _class : Class );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	
	oper : CM_QueryOperator;
	operToDelete : CM_QueryOperator;

begin

	foreach oper in self.allAllowedOperators do
		if oper.class = _class then
			operToDelete := oper;
			break;
		endif;
	endforeach;
	
	if operToDelete &lt;&gt; null then
		delete operToDelete;
	endif;

epilog

end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
