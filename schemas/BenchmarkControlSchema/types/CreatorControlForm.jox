    <JadeMethod name="postProcessLogFiles" id="074a38ba-8b52-4083-8e10-bd9bebe0f789">
        <updating/>
        <source>postProcessLogFiles() updating;

vars
	s,t,folder:String;
begin
	addResults("Select log file folder to post process");
	
	if lastStatsFile = null then
		lastStatsFile:=app.dbPath[1:2]&amp;"\BenchMarkResults";
	endif;

	//folder:=lastStatsFile.replace("T:", "\\cnwchcm24\cnwjbl$");
	read folder;

	if folder &lt;&gt; null then
		addResults("Post processing log files from "&amp;folder&amp;"...");
	endif;
epilog
end;
</source>
    </JadeMethod>
