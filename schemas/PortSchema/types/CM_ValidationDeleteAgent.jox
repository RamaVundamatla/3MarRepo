    <JadeMethod name="valInterfaceHistory" id="4f36ffed-4dee-4955-9a90-7caa38f00ac4">
        <source>valInterfaceHistory( _obj : CM_InterfaceHistory io );
	
/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	
begin
	self.raiseExceptionIfNull( _obj, app.getErrorString( InterfaceHistory ) );
	
	if not self.exclusiveLockObjectToDelete( _obj ) then
		// toDelete is null, invalid or has already been deleted.
		// most methods seem to have this return removed?
		return;
	endif;
	
	_obj.validateForDelete();
	
epilog
	
end;
</source>
        <Parameter name="_obj" type="CM_InterfaceHistory" usage="io"/>
    </JadeMethod>
