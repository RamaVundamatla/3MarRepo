    <JadeMethod name="setFromROROLaneDefn" id="a781e949-10c8-4f1a-811a-d682dd27628c">
        <updating/>
        <source>setFromROROLaneDefn() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	self.ident:=self.myLaneDefn.code;
	self.ordinalLane:=self.myLaneDefn.ordinal;
	self.myDeck:=self.myLaneDefn.myDeck.CM_DeckVoyage;
	self.myVoyage:=self.myDeck.CM_DeckVoyage.getVoyage();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="spareLength" id="9b7fd733-f9d0-4ada-86d9-514a271199f4">
        <methodInvocation>mapping</methodInvocation>
        <source>spareLength(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			// TFS 39254		

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlgab1:1	Initial creation

*/

vars

begin
	if not set then
		_value := self.myLaneDefn.length - self.usedLength;
	 
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerAvailable" id="d2f0ec41-fd63-430a-b22a-a19f0b2a7402">
        <source>testIsControllerAvailable(_autoMovePlan: CMIF_AutoMovePlan input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars

begin
	_autoMovePlan.updateController(null);
	if not self.myLaneDefn.myLayout.isVisible then
		_autoMovePlan.addLogEntry(app.getErrorString1(Unavailable, self.getFullId) &amp; " " &amp; app.getErrorString(Disch_lane_roro_area_not_visib), IsError, Unavailable);
		return;
	endif;
	
	//We are happy, so set ref to us.
	_autoMovePlan.updateController(self);
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="usedLength" id="83059061-2e42-4c88-9019-f3cc87df9b81">
        <methodInvocation>mapping</methodInvocation>
        <source>usedLength(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			// TFS 39254		

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlgab1	Initial creation

*/
 
vars
		lanePos : CM_ROROLanePositionController;
begin
	if not set then
		foreach lanePos in  self.allLanePositionsLCs do
			if lanePos.myLanePositionDefn&lt;&gt; null then
				_value := _value + lanePos.myLanePositionDefn.length;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
</Class>
