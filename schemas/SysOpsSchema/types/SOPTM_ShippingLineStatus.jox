    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="fdc0347a-e240-42a7-9557-f2d489a52c8d">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars
	theForm : SOP_TableMaintForm;
	theCmb	: CMUI_ComboBox;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ShipLineStatMaintList);
	
	theCmb := theForm.cmbType;
	theCmb.clear();
	theCmb.addItemWithData(app.getErrorString(Exempt), CM_ShippingLineStatus.Type_Exempt);
	theCmb.addItemWithData(app.getErrorString(Not_exempt), CM_ShippingLineStatus.Type_NotExempt);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ShipLineStatMaintTbl);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="74f417bf-ecce-4e91-ba89-e51bf12ab79d">
        <updating/>
        <source>showThumbnail(pShippingLineStatus: CM_ShippingLineStatus) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

*/

vars
	theForm 			: SOP_TableMaintForm;
	theCmb				: CMUI_ComboBox;
begin

	theForm := self.myForm;
	
	theForm.tblInput1.clearValues;
	
	theForm.tblInput1.setValueByName(ETRow_Code, pShippingLineStatus.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pShippingLineStatus.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailForEntry, pShippingLineStatus.notAvailForEntry);
	theCmb := theForm.cmbType;
	theCmb.listIndex := theCmb.findItemData(pShippingLineStatus.type);
	theForm.tblInput1.setValueByName(ETRow_Type, pShippingLineStatus.getTypeIntToString(pShippingLineStatus.type));
	theForm.tblInput1.showRowByName(ETRow_SetCriteria, false);
	theForm.tblInput1.setValueByName(ETRow_SetCriteria, pShippingLineStatus.getCriteriaDisplay());
epilog

end;</source>
        <Parameter name="pShippingLineStatus" type="CM_ShippingLineStatus"/>
    </JadeMethod>
</Class>
