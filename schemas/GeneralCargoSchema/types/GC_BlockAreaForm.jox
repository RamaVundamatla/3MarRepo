    <JadeMethod name="getCurrentViewMode" id="d6b1cf89-bca8-427a-8ac3-a90ee1d768d4">
        <source>getCurrentViewMode(): Integer protected;
//29 May 2008	cnwdw1	
// 07 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// Return the id of the currently pushed view button
begin
	if self.btnViewProduct.value then
		return VIEW_PRODUCT;
	elseif self.btnViewOperator.value then
		return VIEW_OPERATOR;
	elseif self.btnViewVoyage.value then
		return VIEW_VOYAGE;
	elseif self.btnViewCargoType.value then
		return VIEW_CARGO_TYPE;
	elseif self.btnViewStockBRef.value then
		return  VIEW_BOOKREF_STOCK;
	elseif self.btnViewExpBRef.value then
		return VIEW_BOOKREF_EXPORT;
	elseif self.btnViewReleaseRq.value then
		return VIEW_RELEASE_REQUEST;
	elseif self.btnViewShippingLine.value then
		return VIEW_SHIPPINGLINE; 	//07-06-2022	navtnr20 53204
	endif;
	
	return VIEW_PRODUCT;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
