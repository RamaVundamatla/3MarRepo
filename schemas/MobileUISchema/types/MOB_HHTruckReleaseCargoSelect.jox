    <JadeMethod name="clickOnTruckItem" id="62a42016-bd76-4f66-9960-2d214542f519">
        <updating/>
        <source>clickOnTruckItem(_ti : CM_TrackedItem) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2015	cnwer1	Initial creation

*/

vars

	loadedWle : CM_WorkListEntry;
	delRequest : CM_DeliveryRequest;

begin

	
	self.myMobileGenericAgent.setMyNextTiToAction(_ti);
	//self.myHandHeldCheckerAgent.setChecksState(MOB_HandHeldCheckerAgent.GateReceipt);
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckUnload);//28 May 2010	NDL	Par 23698
	
	//15 Nov 2010	NDL	Par 26055 - This has been loaded against a delivery request and
	//								is going to be unloaded again...
	loadedWle := self.myMobileGenericAgent.getLoadedWleFor(_ti);
	if loadedWle &lt;&gt; null and loadedWle.myRequest &lt;&gt; null and loadedWle.status = WLE_COMPLETED then
		if loadedWle.myRequest.isKindOf(CM_DeliveryRequest) and CM_DeliveryRequest.hasInstance(loadedWle.myRequest) then
			delRequest := loadedWle.myRequest.CM_DeliveryRequest;
		endif;
		if delRequest &lt;&gt; null then
			self.myMobileGenericAgent.setDoingReversal( true );
		endif;
	endif;
	
	self.gotoForm( MOB_HHTruckUnloaderCargo, false );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doMoveReleaseCargoToTruck" id="39eb4de9-2c35-4f6b-8598-6b9e41f3506c">
        <source>doMoveReleaseCargoToTruck()  : Boolean protected;
/*

Date		Who		Reason
15 September 2015	cnwer1	Initial creation PAR

*/

vars
	moveController : CMIF_MoveController;
	allMoveControllers : ObjectSet;
	result : Integer;
begin
	create allMoveControllers transient;
	if  self.myCargo1 &lt;&gt; null then
		//epr TFS 3094 9/12/16
		moveController:=self.setupMoveController(allMoveControllers, self.myCargo1);	
	endif;
	
	if self.txtCargo2.visible and self.myCargo2 &lt;&gt; null then
		//epr TFS 3094 9/12/16
		moveController:=self.setupMoveController(allMoveControllers, self.myCargo2);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTIs(allMoveControllers, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		else
			return true;
		endif;
		break;
	endwhile;
	
	return false;
epilog
	
	allMoveControllers.purge;
	delete allMoveControllers;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="7d0e3289-918d-494a-9544-d5106ccc482c">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars
	
	folderHeight : Real;
	stdHeight : Real;
	offSet : Real;
	vTop : Real;
	vHeight : Real;
	
	buttonWidth : Real;
	menuButton : MOB_Button;
	index : Integer;
	buttonHeight : Integer;
	buttonTop : Integer;
	top : Real;
	height : Real;
	singleWidth : Integer;
	left : Real;
begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	
	buttonHeight := self.getScrollingButtonHeight();
	
	vTop := self.resizedMargin;
	folderHeight:= (self.clientHeight - vTop - self.getCMDButtonsHeight() - stdHeight - ( self.resizedMargin * 3 ) );

	self.fldCargo.move(	self.resizedMargin,
						vTop,
						self.clientWidth - ( self.resizedMargin * 2 ),
						folderHeight
						);
						
	self.frmCargoOnTruck.move(	self.resizedMargin / 2,
								self.resizedMargin / 2,
								self.shtOnTruck.width - self.resizedMargin,
								self.shtOnTruck.height - self.resizedMargin
								);
								

	self.frmCargoInYard.move(	self.resizedMargin / 2,
								self.resizedMargin / 2,
								self.shtInYard.width - self.resizedMargin,
								self.shtInYard.height - self.resizedMargin
								);
									
	self.lblNoCargoTruck.move(	self.resizedMargin,
								self.resizedMargin,
								self.frmCargoOnTruck.width - ( self.resizedMargin * 2 ),
								buttonHeight - ( self.resizedMargin * 2 )
								);
																

	
	if self.onTruckButtonCount &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnOnTruckTemp.height := buttonHeight;
		buttonWidth := getButtonWidthSetScrollBar( self.onTruckButtonCount, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.onTruckButtonCount do
			menuButton := self.btnOnTruckTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnOnTruckTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
	
	self.txtCargo1.top:=self.lblRelease.top + self.lblRelease.clientHeight + self.resizedMargin;
	self.lblCargo1.top:=self.txtCargo1.top + self.txtCargo1.clientHeight + self.resizedMargin;
	self.txtCargo2.top:=self.lblCargo1.top + self.lblCargo1.clientHeight + self.resizedMargin;
	self.lblCargo2.top:=self.txtCargo2.top + self.txtCargo2.clientHeight + self.resizedMargin;
	
	if  self.txtCargo2.visible	then
		self.lblDoor.top:= self.lblCargo2.top + self.lblCargo2.clientHeight + self.resizedMargin;
	else
		self.lblDoor.top:= self.lblCargo1.top + self.lblCargo1.clientHeight + self.resizedMargin;
		
	endif;
	self.txtDoor.top :=self.lblDoor.top  + self.lblDoor.clientHeight + self.resizedMargin;
	
	inheritMethod(_initialSetup);
	top := self.fldCargo.top + self.fldCargo.height + self.resizedMargin;
	height := self.getStdControlHeight;
	singleWidth := (( self.fldCargo.width - 2 ) / 3 ).Integer;
	left := self.resizedMargin;

	if _initialSetup then
		self.lblWeightValue.visible := true;
	endif;
	self.lblWeightValue.move(	left,
								top,
								singleWidth * 2,
								height );
								
	left := left + lblWeightValue.width + self.resizedMargin;
	if _initialSetup then
		self.lblCountValue.visible := true;
	endif;
	self.lblCountValue.move(	left,
								top,
								singleWidth,
								height );
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMatchingCargo" id="081885fc-9d72-4f26-b970-6f6bf52c02ba">
        <updating/>
        <source>getMatchingCargo(_cargoID : String;
				_wle : CM_WorkListEntry input;
				_searchIfNoTIsFound : Boolean) : CM_TrackedItem updating;
/*

Date		Who		Reason
15 September 2015	cnwer1	Initial creation PAR

*/

vars
	numberMatching :Integer;
	matchingTI,
	ti : CM_TrackedItem;
	iter : Iterator;
begin
	
	
	iter :=self.allMatchingTIs.createIterator;
	self.allMatchingTIs.startKeyGeq(_cargoID,iter);
	while iter.next(ti) do
		if ti.id &lt;&gt; _cargoID then
			break;
		endif;
		matchingTI:=ti;
		numberMatching:=numberMatching + 1;
	endwhile;
	
	if numberMatching = 1 then
		return matchingTI;
	elseif numberMatching &gt; 1 or (_searchIfNoTIsFound and numberMatching = 0 )  then
		return null;
		self.myMobileGenericAgent.allConfirmedTis.clear;
		self.myMobileGenericAgent.allConfirmedTis.add(self.myCargo1);
		self.myMobileGenericAgent.allConfirmedTis.add(self.myCargo2);	
		self.myMobileGenericAgent.setStringField1(self.txtDoor.text.trimBlanks);
		
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setID( _cargoID );
		app.myMobileCargoFindAgent.setMyCargoType(_wle.myRequest.getCargoType());
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setPreventSiteChange(true); 
		app.myMobileCargoFindAgent.setDoSearchImmediate(true);
		app.myMobileCargoFindAgent.setMyWLE(_wle);
		app.myMobileCargoFindAgent.allSearchResults.clear;
		self.allMatchingTIs.copy(app.myMobileCargoFindAgent.allSearchResults);
		if self.myCargo1 &lt;&gt; null then
			app.myMobileCargoFindAgent.allSearchResults.remove(self.myCargo1);
		endif;
		if self.myCargo2 &lt;&gt; null then
			app.myMobileCargoFindAgent.allSearchResults.remove(self.myCargo2);
		endif;
		app.myMobileCargoFindAgent.onlyShowResults:=self.myMobileGenericAgent.myReserveSelection = null;
		self.gotoForm( MOB_HHCargoFind, false );
	endif;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_searchIfNoTIsFound" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getReserveDesciption" id="78089082-7093-4c24-945f-4d21de796412">
        <source>getReserveDesciption() : String;
/*

Date		Who		Reason
07 October 2015	cnwer1	Initial creation PAR
// 07/05/2017 cnwrh7         TFS4255      	#UE (Null) in app MobileUISchema::HandHeldApp of PENPJMT

*/

vars
	reserveDetail : CM_ReserveDetail;
	amount : String;
	wle : CM_WorkListEntry;
	cargoType : CM_CargoType;
	moveQuantity : Integer;
	moveWeight 	: Decimal[14,4];
begin

	//epr TFS 3094 9/12/16
	if (not self.myMobileGenericAgent.allWlesToLoad.isEmpty) and (self.myMobileGenericAgent.allWlesToLoad.first.myRequest &lt;&gt; null)then						//+TFS4255
		reserveDetail:=self.myMobileGenericAgent.allWlesToLoad.first.myRequest.myReserveDetail;
	endif;
	if reserveDetail &lt;&gt; null then																																																													//+TFS425																																																								
		cargoType:=reserveDetail.getCargoType();	
	endif;
	foreach wle in self.myMobileGenericAgent.allWlesToLoad do
		if cargoType.isBulkMulti then
			moveWeight:=moveWeight + wle.weight;			
		else
			moveQuantity:= moveQuantity + wle.getQuantity;			
		endif;
	endforeach;
	if moveWeight &lt;&gt; null then
		amount:=wle.getMoveAmountForWeight(moveWeight,true);
	else
		amount:=moveQuantity.asStringJMT;
	endif;

	if reserveDetail &lt;&gt; null then
		return reserveDetail.myReserveHeader.code &amp; " " &amp; amount &amp;  " x " &amp;    reserveDetail.getProductISOTypeDescr();	
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="eafee30f-85fb-4b05-9252-a0224bb394a8">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Date		Who		Reason
11 September 2015	cnwer1	Initial creation PAR

*/

vars
	roadJob : CM_RoadJob;
	door	: String;
	truck   : CM_Vehicle;
begin
	
	if not validateWarehouseDoor then
		app.myPassport.clearErrorsWarnings;
		app.myPassport.addErrorFull(The_wrong_door,app.getErrorString1(The_wrong_door, self.myMobileGenericAgent.warehouseDoor),null,null,null);
		
		app.showErrorWarningDialog(app.getErrorString(Error),app.myPassport,MsgBox_OK_Only);
		self.txtDoor.setFocus();
		return;
	endif;
	
	if self.myCargo1 = null and self.txtCargo1.text &lt;&gt; null then
		app.myPassport.clearErrorsWarnings;
		app.myPassport.addErrorFull(Cargo_not_found_release,app.getErrorString1(Cargo_not_found_release,self.txtCargo1.text),null,null,null);	
		app.showErrorWarningDialog(app.getErrorString(Error),app.myPassport,MsgBox_OK_Only);
		return ;
	endif;
	
	if self.myCargo2 = null and self.txtCargo2.visible and self.txtCargo2.text &lt;&gt; null then
		app.myPassport.clearErrorsWarnings;
		app.myPassport.addErrorFull(Cargo_not_found_release,app.getErrorString1(Cargo_not_found_release,self.txtCargo2.text),null,null,null);	
		app.showErrorWarningDialog(app.getErrorString(Error),app.myPassport,MsgBox_OK_Only);
		return ;
	endif;
	
		
	if self.doMoveReleaseCargoToTruck() then
		self.setupCargo();
		self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
		self.txtDoor.text:=null; //epr par 36983 30/9/15
		if not self.txtCargo1.visible then
			roadJob:=self.myMobileGenericAgent.myTruck.getCurrentRoadJob;
			//epr par 37075
			if roadJob &lt;&gt; null and not roadJob.areBulkReleaseWlesComplete then
				door := self.myMobileGenericAgent.warehouseDoor;
				truck:= self.myMobileGenericAgent.myTruck;
				
				self.myMobileGenericAgent.clearAll;
				self.myMobileGenericAgent.setWarehouseDoor(door);
				self.myMobileGenericAgent.myTruck :=truck;
				self.goBackToFirst(MOB_HHTruckReleaseSelect);		
			else	
				self.myMobileGenericAgent.clearAll;
				self.goBackToFirst(MOB_HHTruckReleaseEntry);		
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="d4d14ed4-d913-4b0c-95e6-c8c01986f5ff">
