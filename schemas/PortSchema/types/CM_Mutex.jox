    <JadeMethod name="setDetails" id="d973fa84-95a9-496a-bfb4-ad36c68bbd71">
        <updating/>
        <source>setDetails(	_root : CM_Root;
			_term : CM_Terminal;
			_name : String;
			_context : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	self.name := _name;
	self.context := _context;
	self.myTerminal := _term;	//15 Sep 2021	NDL	TFS 51142
	self.myRoot := _root;

epilog

end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c5d72f87-6c6d-422f-afe1-ca6ac1678a0e">
        <updating/>
        <source>setForCreate( _proxyMutex : CM_Mutex ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

begin

	self.name := _proxyMutex.name;
	self.context := _proxyMutex.context;
	self.myTerminal := _proxyMutex.myTerminal;	//15 Sep 2021	NDL	TFS 51142
	self.myRoot := _proxyMutex.myRoot;

epilog

end;</source>
        <Parameter name="_proxyMutex" type="CM_Mutex"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="3730302f-7055-44dc-ab39-f98c230126ec">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

	existingMutex : CM_Mutex;

begin
	
	if self.myRoot &lt;&gt; null and self.myTerminal &lt;&gt; null then
		//May only use Root or Terminal, not both.
		app.raiseCMException(Mutex_Term_or_root, null, null);
	elseif self.myRoot = null and self.myTerminal = null then
		//Must have at least one set
		app.raiseCMException(Termina_system_referen_require, null, null);
	endif; 
	
	if self.myRoot &lt;&gt; null then
		existingMutex := self.myRoot.allMutexes.getAtKey( self.name, self.context );
	elseif self.myTerminal &lt;&gt; null then
		existingMutex := self.myTerminal.allMutexes.getAtKey( self.name, self.context );
	endif;
	
	if existingMutex &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
</Class>
