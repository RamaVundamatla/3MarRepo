        <Parameter name="_isPassive" type="Boolean"/>
        <Parameter name="_useProxy" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_serverGMTBias" type="Integer"/>
        <Parameter name="_serverType" type="Integer"/>
        <Parameter name="_port" type="Integer"/>
        <Parameter name="_timeOut" type="Integer"/>
        <Parameter name="_singleFileCopy" type="Boolean"/>
        <Parameter name="_saveUndeletedFilesList" type="Boolean"/>
        <Parameter name="_passPhrase" type="String"/>
        <Parameter name="_privateKey" type="String"/>
        <Parameter name="_publicKey" type="String"/>
