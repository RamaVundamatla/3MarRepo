    <JadeMethod name="populateCriteriaFrames" id="6e14ec6a-00d5-47bc-b6f9-724fd400eaeb">
        <updating/>
        <source>populateCriteriaFrames(_autoSetFocus: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria

*/

vars
	i: Integer;
	criteria: CM_YACriteria;
	criteriaFrame: CMUI_YACriteriaCntl;
	saveChangeMethod: String;
	cmifObject: CMIF_Object;
	tabIndex: Integer;
	adjustment: Real;
	new: Boolean;
	defaultNumCriteria : Integer;
begin

	tabIndex := self.frmCriteria.tabIndex;					

	self.hideAllOpCriteriaFrames();
	
	defaultNumCriteria := 10;
	
	while i &lt; defaultNumCriteria do
		i := i + 1;
		criteria := null;
		if myObjectMatchCriteria &lt;&gt; null and not myObjectMatchCriteria.allCriteria.isEmpty and myObjectMatchCriteria.allCriteria.size &gt;= i then
			criteria := myObjectMatchCriteria.allCriteria[i];
		endif;
		if criteria = null then
			criteriaFrame := self.addCriteriaFrame(i, null, tabIndex);
		else
			criteriaFrame := self.addCriteriaFrame(i, criteria.myYACriteriaType, tabIndex);
		endif;
		saveChangeMethod := criteriaFrame.formCriteriaChangeMethodName;
		criteriaFrame.formCriteriaChangeMethodName := null;  // prevent invoke of criteria change method
		criteriaFrame.setCriteria( criteria );
		criteriaFrame.setMasterControl(self.frmCriteria);	
		criteriaFrame.formCriteriaChangeMethodName := saveChangeMethod;
		
	//	if criteria &lt;&gt; null and self.excludeCriteriaType(criteriaFrame, criteria.myYACriteriaType) then
	//		criteriaFrame.setCriteria( null );
	//	endif;
		
		if _autoSetFocus and i = 1 then
			criteriaFrame.CMUI_YACriteriaCntl.txtCriteriaValue.setFocus();
		endif;
	endwhile;
	
epilog
end;</source>
        <Parameter name="_autoSetFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="78129d33-95af-4044-837d-8ce1651482f7">
        <updating/>
        <source>populateForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria
24 Feb 2023 navtnr20 	Bug 56765: EUP - Criteria Priority not being saved
*/

vars

begin
	if self.myObjectMatchCriteria &lt;&gt; null then
		self.txtDescription.text := self.myObjectMatchCriteria.description;
	else
		self.formatDescription();
	endif;
	if self.myObjectMatchCriteria &lt;&gt; null then //navtnr20 24-02-2023 TFS 56765
		self.txtpriority.text := self.myObjectMatchCriteria.priority.String;
	endif;
	self.doSetupCriteriaFrames();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeForContract" id="9251b8c2-a081-4a4a-9c8e-ae4aaac0563f">
        <updating/>
        <source>resizeForContract()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria
08 Mar 2023 navtnr20	Bug 56765: EUP - Criteria Priority not being saved
28/11/2023	navkc1 		Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars

begin
	
	self.minimumHeight := 550;
	self.lblDescription.top := self.shtCriteria.clientHeight - 60;
	self.txtDescription.top := self.lblDescription.top;
	self.lblDescription.left := 20;
	self.txtDescription.left := 130;
	self.lblDescription.parentAspect := Label.ParentAspect_AnchorBottom;
	//self.txtDescription.parentAspect := TextBox.ParentAspect_AnchorBottom; // 28/11/2023	navkc1 Bug 60782
	self.lblPriority.top := self.shtCriteria.clientHeight - 30;
	self.txtpriority.top := self.lblPriority.top;
	self.lblPriority.left := 20;
	self.txtpriority.left := 130;
	self.lblPriority.parentAspect := Label.ParentAspect_AnchorBottom;
	//self.txtpriority.parentAspect := TextBox.ParentAspect_AnchorBottom; // 28/11/2023	navkc1 Bug 60782
	self.btnSave.left := self.btnNext.left - 35; //navtnr20 08-03-2023 bug 56765
	self.btnSave.width := self.btnNext.width +25;	//navtnr20 08-03-2023 bug 56765
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="fc49d73b-4c68-4fdd-aa45-4d3afe274df3">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria
29 Aug 2023 navnk30 Bug 59915: FR | EUP 54089 - Inv Contract - Auto Priority
*/

vars
	priority 				: Integer;
	allTransientCriteriaObj	: CMIF_Array;
	pxyObjMatch 			: CM_InvoiceContractCriteria;
	loadState				: Boolean;
	deleteProxy				: Boolean;
	contract 				: CM_InvoiceContractDetails;
begin
	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	contract := self.contextObject.CM_InvoiceContractDetails;
	
	if self.myObjectMatchCriteria &lt;&gt; null and not self.myObjectMatchCriteria.isTransient then
		deleteProxy := true;
		app.cmsBeginLoad(loadState);
		pxyObjMatch := self.myObjectMatchCriteria.pxyCreateUpdateProxy.CM_InvoiceContractCriteria;
		app.cmsEndLoad(loadState);
		
	elseif self.myObjectMatchCriteria &lt;&gt; null and self.myObjectMatchCriteria.isTransient then
		// let the real updating occur on the source from
		pxyObjMatch := self.myObjectMatchCriteria;
		
	else
		deleteProxy := true;
		create pxyObjMatch as CM_InvoiceContractCriteria transient;
	endif;
	
	priority := self.txtpriority.text.Integer;
	
	//Auto Calculated if not passed 
	if priority = null then									//	28.8.2023 navnk30 #59915
		self.setPriority(allTransientCriteriaObj, priority);		//	28.8.2023 navnk30 #59915
	endif;
	pxyObjMatch.setProxy(allTransientCriteriaObj,		//_criterias: CMIF_Array;
							priority						//_priority : Integer
							);
							
	pxyObjMatch.setProxyContract(	allTransientCriteriaObj,	
														priority,
														self.name,	
														self.txtDescription.text,	
														contract);

	self.myObjectMatchCriteria := pxyObjMatch;
	
	self.unloadForm;
	
	return true;
	
epilog

	delete allTransientCriteriaObj;
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="48841d59-37f7-4e0c-838b-c285723bd512">
        <updating/>
        <source>setBaseData(	_contextObj : CM_InvoiceContractDetails;
				_myObjectMatchCriteria : CM_InvoiceContractCriteria io;
				_myListForm : CMUI_ObjectCriteriaListForm;
				_myParentForm: CM_BaseForm;
				_mode : Boolean // ### TFS BUG 56908 15MAR2023 NAVAB1
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria

*/

vars

begin
	self.contextObject := _contextObj;
