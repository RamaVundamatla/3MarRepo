    <JadeMethod name="validateRequiresLengthOfTime" id="107644b8-0ae8-4850-84be-eae7c28ed48b">
        <source>validateRequiresLengthOfTime() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2018	jlgndl1	Initial creation	TFS 39932

*/

vars

	parent : CM_WorkOrderVoyage;
	voyage : CM_Voyage;
	berth : HMS_Berth;
	workOrder : CM_WorkOrder;

begin

	if self.class = CM_WodCargoRequest
//	or  self.class = CM_WodMarineServicesDepart //14 Sep 2018	NDL TFS 39932 - take it out again
	or  self.class = CM_WodMarineServicesInitial
	or  self.class = CM_WodShiftMovement
	or  self.class = CM_WodVoyageCargoRequest
	then
		parent := self.getMyParent.CM_WorkOrderVoyage;
		if parent = null then
			return true;
		endif;
		if parent.lengthOfTime &gt; 0 then
			return true;
		endif;
		voyage := parent.myVoyage;
		if voyage = null or voyage.myHMSVoyageData = null then
			return true;
		endif;
		
		//23 Aug 2018	NDL	TFS 39932 - New rules
		if self.class = CM_WodCargoRequest then
			berth := self.CM_WodCargoRequest.myBerth;
		elseif self.class = CM_WodMarineServicesInitial then
			berth := self.CM_WodMarineServicesInitial.myBerth;
		elseif self.class = CM_WodShiftMovement then
			berth := self.CM_WodShiftMovement.myToBerth;
		elseif self.class = CM_WodVoyageCargoRequest then
			berth := self.CM_WodVoyageCargoRequest.myBerth;
		else
			berth := voyage.myHMSVoyageData.getBerthForDateTime( parent.requiredByDT );
		endif;
		if berth = null then
			return true;
		endif;
		if berth.requiresLengthOfTime then
		
			//14 Sep 2018	NDL TFS 39932 - Now not required for initail service request if a cargo request has been approved.
			if self.class = CM_WodMarineServicesInitial then
				foreach workOrder in voyage.allWorkOrders do
					if workOrder.isWorkOrderForVoyageCargo and workOrder.hasBeenApproved then
						return true;
					endif;
				endforeach;
			endif;
		
			// if we get to here we have a berth that requires a time, and a workorder that doesn't have one.
			app.raiseCMException2( Total_days_work_order_must_gre, parent.getFullDescription, berth.description, null, null );
			return false;
		endif;
		
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTowingVoyage" id="29100673-ef1c-4a2d-aa4c-219b29bcdccf">
        <source>validateTowingVoyage();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2019	jlgndl1	Initial creation	TFS 43245
11 Oct 2021 	jlier1			TFS 51963 removed inaportnet
*/

vars

	voyage : CM_Voyage;

begin

	voyage := self.getMyVoyageObject();
	if voyage = null then
		//will have already had a problem somewhere else
		return;
	endif;

	if self.myTowingVoyage &lt;&gt; null and self.myTowingVoyage = voyage then
		app.raiseCMException(Voyage_not_itself, null, null);
	endif;
		
	if not voyage.isBarge then
		//nothing to check;
		return;
	endif;
	
	if self.myTowingVoyage = null then
		app.raiseCMException(Must_select_towing_voyage, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
