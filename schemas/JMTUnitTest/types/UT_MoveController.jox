    <JadeMethod name="tMove20ToGridLCUnavailable" id="fc72d55c-4465-4bc8-9a4f-dd2d5a671907">
        <source>tMove20ToGridLCUnavailable();
/*

Date		Who		Reason
13 August 2013	cnwer1	Initial creation PAR 31492

*/
constants
	BS1 = "UT_MBS1";
	CargoID1 = "MOVE0000001";
	CargoID2 =  "MOVE0000002";
	ForkStack = "UT_MFL1";
vars
	mc : CMIF_MoveController;
	bs : CM_BlockStack;
	gbs : CM_ForkLiftStack;
	ti1, ti2 : CM_TrackedItem;
	lcs 	: CM_LCSet;
		debugFlag : Boolean;
begin
	
	bs:=self.addBlockStack(BS1,999,null);
	self.assertNotNull(bs);
	//set up ti to move 
	//create in block stack
	
	ti1:=self.addContainerAtLocation(CargoID1,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT",TI_IMEX_STATUS_STORAGE,bs.myLocationsController);
	self.assertNotNull(ti1);
	
	ti2:=self.addContainerAtLocation(CargoID2,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT",TI_IMEX_STATUS_STORAGE,bs.myLocationsController);
	self.assertNotNull(ti2);
	
	//set up to gridded terminal area
	gbs:=self.addForkLiftStack(ForkStack,4,4,3);
	self.assertNotNull(gbs);
	
	create lcs transient;
	
	lcs.add(gbs.allGridControllersByRowColumn[1,1]);
	self.updateGridLocationAvailability(gbs,lcs, PAD_HEIGHT_2_UNAVAIL);
	self.assertNotNull(gbs);
	
	create mc transient;
	mc.setMyTrackedItem(ti1);
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	self.ignoreTrxWarnings(false);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	//should be no errors or warnings location is available
	self.assertNoTrxErrorsOrWarnings();
	
	//plan another container to same location should get warning about stack will be full
	
	delete mc;
	create mc transient;
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	
	// REMOVE - logging as works during day but not overnight.
	self.zzzMDHDONOTUSE(gbs.allGridControllersByRowColumn[1,1], ti2, mc);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Plann_alrea_full_will_over_cap);
	
	delete mc;
	create mc transient;
	mc.setMyTrackedItem(ti1);
	mc.setMoveMode(REAL_MODE);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	//should be no errors or warnings location is available
	self.assertNoTrxErrorsOrWarnings();
	
	
	//because location is unavailable from height 1 should give warning trying to plan into location
	delete mc;
	create mc transient;
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Move_WillBeOverCap);
	
	//because location is unavailable from height 1 should give warning trying to queue into location
	delete mc;
	create mc transient;
	mc.setMoveMode(QUEUE_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Move_WillBeOverCap);
	
	//should give error trying to move REAL_MODE into location
	delete mc;
	create mc transient;
	mc.setMoveMode(REAL_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	self.expectTrxError(Move_WillBeOverCap);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
//	self.assertNoTrxErrorsOrWarnings();
	self.assertTrxError(Move_WillBeOverCap);	//10 Sep 2020	NDL	TFS 49984
	

epilog
	delete mc;
	delete lcs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMove40ToGridLCUnavailable" id="05d9b984-72d3-447d-80e8-d988758b24da">
        <source>tMove40ToGridLCUnavailable();
/*

Date		Who		Reason
13 August 2013	cnwer1	Initial creation PAR

*/
constants
	BS1 = "UT_MBS1";
	CargoID1 = "MOVE0000001";
	CargoID2 =  "MOVE0000002";
	ForkStack = "UT_MFL1";
vars
mc : CMIF_MoveController;
	bs : CM_BlockStack;
	gbs : CM_ForkLiftStack;
	ti1, ti2 : CM_TrackedItem;
	lcs 	: CM_LCSet;
begin
	
	bs:=self.addBlockStack(BS1,999,null);
	self.assertNotNull(bs);
	//set up ti to move 
	//create in block stack
	
	ti1:=self.addContainerAtLocation(CargoID1,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"4200", "MT",TI_IMEX_STATUS_STORAGE,bs.myLocationsController);
	self.assertNotNull(ti1);
	
	ti2:=self.addContainerAtLocation(CargoID2,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"4200", "MT",TI_IMEX_STATUS_STORAGE,bs.myLocationsController);
	self.assertNotNull(ti2);
	
	//set up to gridded terminal area
	gbs:=self.addForkLiftStack(ForkStack,4,4,3);
	self.assertNotNull(gbs);
	
	create lcs transient;
	
	lcs.add(gbs.allGridControllersByRowColumn[1,1]);
	lcs.add(gbs.allGridControllersByRowColumn[2,2]);
	self.updateGridLocationAvailability(gbs,lcs, PAD_HEIGHT_2_UNAVAIL);
	self.assertNotNull(gbs);
	
	create mc transient;
	mc.setMyTrackedItem(ti1);
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	self.ignoreTrxWarnings(false);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	//should be no errors or warnings location is available
	self.assertNoTrxErrorsOrWarnings();
	
	//plan another container to same location should get warning about stack will be full
	
	delete mc;
	create mc transient;
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Plann_alrea_full_will_over_cap);
	
	delete mc;
	create mc transient;
	mc.setMyTrackedItem(ti1);
	mc.setMoveMode(REAL_MODE);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	//should be no errors or warnings location is available
	self.assertNoTrxErrorsOrWarnings();
	
	
	//because location is unavailable from height 1 should give warning trying to plan into location
	delete mc;
	create mc transient;
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Move_WillBeOverCap);
	
	//because location is unavailable from height 1 should give warning trying to queue into location
	delete mc;
	create mc transient;
	mc.setMoveMode(QUEUE_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Move_WillBeOverCap);
	
	//should give error trying to move REAL_MODE into location
	delete mc;
	create mc transient;
	mc.setMoveMode(REAL_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[1,1]);
	
	self.expectTrxError(Move_WillBeOverCap);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//move into location where  40 backend is height restricted
	delete mc;
	create mc transient;
	mc.setMyTrackedItem(ti1);
	mc.setMoveMode(REAL_MODE);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[2,1]);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
	//should be no errors or warnings location is available
	self.assertNoTrxErrorsOrWarnings();
	
	
	//because backend location is unavailable from height 1 should give warning trying to plan into location
	delete mc;
	create mc transient;
	mc.setMoveMode(PLANNING_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[2,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Err_Cannot_Move);
	self.assertTrxWarning(Suitab_contai_longer_than_foot);
	
	//because backend location is unavailable from height 1 should give warning trying to queue into location
	delete mc;
	create mc transient;
	mc.setMoveMode(QUEUE_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[2,1]);
	
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);

	//should of got warning and aborted
	self.assertTrue(not app.myPassport.trxCompletedOK());
	self.assertTrxWarning(Err_Cannot_Move);
	self.assertTrxWarning(Suitab_contai_longer_than_foot);
	//should backend give error trying to move REAL_MODE into location
	delete mc;
	create mc transient;
	mc.setMoveMode(REAL_MODE);
	mc.setMyTrackedItem(ti2);
	mc.setMyToPrimaryLocation(gbs.allGridControllersByRowColumn[2,1]);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Err_Cannot_Move);
	self.expectedTrxErrors.add(Suitab_contai_longer_than_foot);
	app.myTrxUA.trxMoveTrackedItem(mc,app.myPassport);
//	self.assertNoTrxErrorsOrWarnings();
	self.assertIncludesExceptions();
	
	

epilog
	delete mc;
	delete lcs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveTIOnsiteToRTA" id="d7969845-bac6-4723-8b44-3133280a328e">
        <source>tMoveTIOnsiteToRTA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2025 navhl20 Story MTN-36263: AAT | Auto Releasing from Release Trans Area SHOULD not allow auto release if cargo has a Stop but it does

*/
constants
	REF 		: String = "36263";
	StopId				 = 263;
vars
	autoRel,
	blockStack		: CM_BlockStack;
	operator		: CM_Operator;
	voyage			: CM_Voyage;
	vessel			: CM_Vessel;
	dischargePort	: CM_Port;
	terminal		: CM_Terminal;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	ti1				: CM_TrackedItem;	
	stopsTable		: CM_StopsTable;
	selectedTypes	: CM_CargoBOLTypeSet;
	isChildIgnore	: Boolean;
	isChildOnly		: Boolean;
	isCoastalIgnore	: Boolean;
	isCoastalOnly	: Boolean;
	isFull			: Boolean;
	isMT			: Boolean;	
	setStopAreas,
	checkStopAreas,
	processStopAreas: IntegerArray;
begin
	terminal := self.getMyTerminal();
	
	self.deleteTerminalArea("UTRTA"&amp;REF);
	autoRel := self.addReleaseTransAreaAuto("UTRTA"&amp;REF).CM_BlockStack;
	assertTrueMsg(autoRel &lt;&gt; null, "Failed to add auto release area " &amp; "UTRTA" &amp; REF);
	assertEqualMsg(autoRel.maxCapacity, 99, "Max capacity not 99");
	self.deleteStopsTable(StopId);
	
	create selectedTypes transient;
	create setStopAreas transient;
	create checkStopAreas transient;
	create processStopAreas transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[12185]);
	isChildIgnore := false;
	isChildOnly := false;
	isCoastalIgnore := false;
	isCoastalOnly := false;
	isFull := false;
	isMT := false;
	self.opts.addAssoc(ETRow_IsChildIgnore, isChildIgnore);
	self.opts.addAssoc(ETRow_IsChildOnly, isChildOnly);
	self.opts.addAssoc(ETRow_IsCoastalIgnore, isCoastalIgnore);
	self.opts.addAssoc(ETRow_IsCoastalOnly, isCoastalOnly);
	self.opts.addAssoc(ETRow_IsFull, isFull);
	self.opts.addAssoc(ETRow_IsMT, isMT);
	checkStopAreas.add(StopPreventReleaseFromTranArea);
	self.opts.addAssoc(ETRow_CheckStopAreas, checkStopAreas);
	self.opts.addAssoc(ETRow_ProcessStopAreas, processStopAreas);
	self.opts.addAssoc(ETRow_RequiresInfo, false);
	self.opts.addAssoc(ETRow_CustomsInfoEntry, null);
	self.opts.addAssoc(ETRow_IsNotAvailableForEntry, false);
	self.opts.addAssoc(ETRow_AllowClearanceExpiryDate, false);
	setStopAreas.add(TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(ETRow_SetStopAreas, setStopAreas);
	
	stopsTable := self.addStopsTable(StopId,
										'UT' &amp; StopId.display,
										method.name[1 : 30],		// to help identify what has created it
										selectedTypes,
										self.opts);
	
	self.assertNotNullMsg(stopsTable, 'Stop Table ' &amp; StopId.display &amp; ' does not exist');
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteTerminalArea("BS"&amp;REF);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	self.opts.purge();
	self.opts.addAssoc("ActAsRelPoint", false);
	blockStack := self.addBlockStack("BS"&amp;REF, 10, null);
	
	self.deleteVoyage("UTVOY" &amp; REF);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTVOY" &amp; REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("PAPER").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("REELS");
	self.assertNotNullMsg(product, "product");
	
	self.deleteCargo("UTBB"&amp;REF, cargoType);
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	ti1 := self.addCargoBreakBulkAtLocation("UTBB"&amp;REF, cargoType, 10, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertNotNullMsg(ti1, "TrackedItem");
	self.assertEqual(ti1.myPrimaryActualLocation, blockStack.myLocationsController);
	
	self.addStop(ti1, stopsTable);
	self.assertNotEqual(ti1.getAllStops.size, 0);
	self.assertEqual(ti1.myPrimaryActualLocation, blockStack.myLocationsController);
	
	self.opts.purge();
	self.opts.addAssoc("MoveMode", REAL_MODE);
	self.opts.addAssoc("ExpectErrors", true);
	self.move(ti1,autoRel);
	
	self.assertEqual(ti1.myPrimaryActualLocation, blockStack.myLocationsController);
epilog
	delete selectedTypes;
	delete setStopAreas;
	delete checkStopAreas;
	delete processStopAreas;
end;</source>
    </JadeMethod>
