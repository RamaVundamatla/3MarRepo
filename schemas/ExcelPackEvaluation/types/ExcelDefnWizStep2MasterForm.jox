    <JadeMethod name="btnBack_click" id="1d36ba06-25be-4bb2-a0d5-7f95ba919f6b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBack_click(btn: Button input) updating;

/*****************************************************
	Written by	:	cnwgrp1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if self.trySaveData() then
		self.myExcelWorkbookDefinitionDA.setIntCurrentWizardStep(self.myExcelWorkbookDefinitionDA.intCurrentWizardStep - 1);
		self.myExcelWorkbookDefinitionDA.wizardControl();
		self.unloadForm();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="fc2fc3d4-b55b-4739-9681-264e4a7dea12">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars
	

begin
	self.myExcelWorkbookDefinitionDA.setIntCurrentWizardStep(9);
	self.myExcelWorkbookDefinitionDA.doCancelled();
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNext_click" id="75987e8e-dcde-4a1e-a198-cd7466e5aeab">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;

vars

begin
	if self.trySaveData() then
		self.myExcelWorkbookDefinitionDA.setIntCurrentWizardStep(self.myExcelWorkbookDefinitionDA.intCurrentWizardStep + 1);
		self.myExcelWorkbookDefinitionDA.wizardControl();
		self.unloadForm();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
