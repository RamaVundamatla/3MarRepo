<Class name="UT_SourceCompareJade" id="6691c00e-c75c-4b42-bf53-5455d5546b79">
    <superclass name="JadeTestCase"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="iSourceComparison" id="f9636fda-e5ec-4f87-a1d5-78ec90a24425">
        <unitTestFlags>Test</unitTestFlags>
        <source>iSourceComparison() unitTest;
/*

Purpose:			A Unit test created to compare Source Code from WMast or DMast against the local environment this unit test is run from
					Outputs a list of Missing Global Constant Categories/Global Constants/Classes/Methods and Differing Methods
					Will eventually be extended to compare Missing Class Attributes/References/Constants, 
					Differing Class Attributes/References/Constants, Map Files and Differing Global Constants

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	SchemaFilePathDMast = "C:\JMTDailyExtracts\schemas"; //S11 Daily Extract path
	//SchemaFilePathWMast = "\\cnwchcm24\cnwpod$\releases\862\Daily\JadeMaster\schemas"; //WMast release extract path
	SchemaFilePathWMast = "\\cnwchcm24\cnwpod$\Releases\22024\Daily\JadeMaster\schemas";//WMast release extract path
	
vars
	devSourceCompareAgent 	: Object;
	scm 					: Schema;
	cls 					: Class;
	
	fileNode				: FileNode;
	folder					: FileFolder;
	str, 
	concatanatedMessage,
	schemaFilePath			: String;
	logLevel				: Integer;
	
begin
	app.initialize();
	logLevel := app.logLevel; //Get original Log Level as we revert it back at the end of this method to stop garbage being printed
	
	app.changeLogLevel(LogERROR); //Change the log lvel to Error
	
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		//schemaFilePath := SchemaFilePathDMast; //Original
		schemaFilePath := SchemaFilePathWMast;
	else
		schemaFilePath := SchemaFilePathWMast;
	endif;
	
	//Because of the schema we are running from, we need to use getSchema, getClass and sendMsgWithParams to run our unit test
	scm := rootSchema.getSchema("DevSchema"); //Get the DevSchema
	if scm = null then
		self.logMessage("DevSchema not found exiting..."); //If not exists Log and exit
		info("DevSchema not found exiting...");
		jmtRaiseException("DevSchema not found exiting...");
		return;
	endif;
	
	cls := scm.getClass("DEV_SourceCompareAgent"); //get our DEV_SourceCompareAgent class
	
	if cls = null then
		self.logMessage("DEV_SourceCompareAgent not found exiting..."); //If not exists Log and exit
		info("DEV_SourceCompareAgent not found exiting...");
		jmtRaiseException("DEV_SourceCompareAgent not found exiting...");
		return;
	endif;

	create devSourceCompareAgent as cls transient; //Create our devSourceCompareAgent as the class we got above using the cls reference (DEV_SourceCompareAgent)
	create folder transient;
	
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm"; //We only want scm files at this stage
	
	if not folder.isAvailable() then
		devSourceCompareAgent.sendMsgWithParams("logMessage", "Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		info("Folder " &amp; folder.fileName &amp; " not found, exiting");
		//assertTrue(false);
		jmtRaiseException("Folder " &amp; folder.fileName &amp; " not found, exiting");
		return; //If our folder in not available then send a message to our class to run the logMessage method and exit
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
			//Foreach scm file in the folder send a message to our class to run the doSchemaComparison method for the current file
			devSourceCompareAgent.sendMsgWithParams("doSchemaComparison", fileNode.fileName, fileNode.name.replace(".scm", ""), false, 2);
		endif;
	endforeach;

	/*
	**	Missing Global Constant Categories
	**	Write out the missing global constant categories
	*/
	concatanatedMessage := concatanatedMessage &amp; "Missing Global Constant Categories:" &amp; CrLf;
	foreach str in devSourceCompareAgent.getPropertyValue("missingGConstantCategories").StringArray do 
		concatanatedMessage := concatanatedMessage &amp; str &amp; CrLf;
	endforeach;
	
	/*
	**	Missing Global Constants
	**	Write out the missing global constants
	*/
	concatanatedMessage := concatanatedMessage &amp; CrLf &amp; "Missing Global Constants:" &amp; CrLf;
	foreach str in devSourceCompareAgent.getPropertyValue("missingGlobalConstants").StringArray do 
		concatanatedMessage := concatanatedMessage &amp; str &amp; CrLf;
	endforeach;

	/*
	**	Missing Classes
	**	Write out the missing classes
	*/
	concatanatedMessage := concatanatedMessage &amp; CrLf &amp; "Missing Classes:" &amp; CrLf;
	foreach str in devSourceCompareAgent.getPropertyValue("missingClasses").StringArray do 
		concatanatedMessage := concatanatedMessage &amp; str &amp; CrLf;
	endforeach;
	
	/*
	**	Missing Methods
	**	Write out the missing methods
	*/
	concatanatedMessage := concatanatedMessage &amp; CrLf &amp; "Missing Methods:" &amp; CrLf;
	foreach str in devSourceCompareAgent.getPropertyValue("missingMethods").StringArray do 
		concatanatedMessage := concatanatedMessage &amp; str &amp; CrLf;
	endforeach;
	
	/*
	**	Differing Methods
	**	Write out the differing methods
	*/
	concatanatedMessage := concatanatedMessage &amp; CrLf &amp; "Differing Methods:" &amp; CrLf;
	foreach str in devSourceCompareAgent.getPropertyValue("differingMethods").StringArray do 
		concatanatedMessage := concatanatedMessage &amp; str &amp; CrLf;
	endforeach;
	
	//If we have something to report/output then send a message to our class to run the logMessage method
	if concatanatedMessage.length &gt; 0 then
		devSourceCompareAgent.sendMsgWithParams("logMessage", concatanatedMessage, LogERROR);
	endif;
	
	assertFalse(devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean); //Fails the test if any errors occurred
	app.changeLogLevel(logLevel); //Resets the log level back to default in case other unit tests need it at a specific level.
	
epilog
	delete devSourceCompareAgent; //Clear our transients
	delete folder;
	
end;</source>
    </JadeMethod>
</Class>
