    <JadeMethod name="doAddTemplateGroup" id="0f74d8b9-5db0-4ac7-b870-b842162f1671">
        <updating/>
        <source>doAddTemplateGroup() protected, updating;

// Created by cnwdvb1 on 07 August 2006

vars

	groupName	: String;
	inputBox	: CMUI_InputBox;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	// PAR 16394
	create inputBox transient;
	inputBox.init(	app.getErrorString(LBL_Template_group), app.getErrorString(LBL_Enter_name_tempate_group),
					"", 0, TextBox.DataType_AlphaNumeric, TextBox.Case_None, true, false);
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;

	groupName := inputBox.txtInput.text;
	if groupName = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateYASnapshotView(self.myCurrentTemplateGroup, groupName, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Create Template Group', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	self.setupTemplateGrpsCombo();
	self.doRefresh();
	
epilog

	delete inputBox;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="8c7e100a-9a9c-4af1-ac5f-32fba69a70d8">
