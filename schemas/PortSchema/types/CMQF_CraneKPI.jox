<Class name="CMQF_CraneKPI" id="b38067ba-2131-4bc9-81b7-caf0bb6b18e9">
    <superclass name="CMQF_FilterReports"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Dec 2010 CCMS 1134 KPI reporting</text>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allCranes" id="47cf67e7-a43f-4a2c-88ed-a34e21289695">
        <memberTypeInverse/>
        <type name="CM_MachineSet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="endTS" id="435f850b-2d9c-4eb0-8fa6-b76a074c6d81">
