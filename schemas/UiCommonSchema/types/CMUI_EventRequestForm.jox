    <JadeMethod name="doResetSearch" id="07178d98-a98f-4f04-8547-88d9a203d05b">
        <source>doResetSearch();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464
vars
	table	:CM_EntryTable;
	row		:Integer;
begin
	table := self.tblSearch;
	
	table.clearValues();
	
	row := table.getRow(ETRow_Status);
	
	table.setValue(row, EventRequestAnyStr);
	
	
	if table.isRowVisible(ETRow_UpdateType) then
		self.cmbUpdateType.listObject:=null;
		self.doChangeUpdateType();
	endif;
	self.cmbCargoType.listIndex := self.cmbCargoType.findObject(app.myPassport.getDefaultCargoType());
	self.cmbCargoType.lostFocus(self.cmbCargoType);
	self.lstTable.setSelected(null);	
end;</source>
