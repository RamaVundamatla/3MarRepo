    <JadeMethod name="draw" id="619a6dec-7024-4c84-aee8-a6ed0077c2ac">
        <source>draw(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandscape, _flipH, _flipV : Boolean; _mode : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
begin
	if _mode = self.MODE_TOPDOWN then
		self.drawTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);
	elseif _mode = self.MODE_FACE then
		self.drawFace(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);	
	elseif _mode = self.MODE_END then
		self.drawEnd(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode);		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "unsupported drawing mode specified");
	endif;
epilog

end;</source>
