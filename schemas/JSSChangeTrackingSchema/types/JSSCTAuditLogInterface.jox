/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Oct 2014	cnwkpd1	PAR #35072 - Prevent 1429 exceptions when using server execution option

*/

vars

begin
	if _serverExecution then
		self.doGetChangeUserDataSE(_userName, _index, _byUserName, _byIndex);
	else
		self.doGetChangeUserData(_userName, _index, _byUserName, _byIndex);
	endif;
			
epilog

end;</source>
