<Class name="WS_IMEXStatus" id="eb20916c-c83f-4fab-a14a-f0bbb5665e39">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>IMEX status of cargo. Import, Export Storage, etc.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="abbreviation" id="da72233c-ff9b-4947-808b-b8322885edb5">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <text>Abbrevation of IMEX status. E.g. EXP, IMP.</text>
    </PrimAttribute>
    <PrimAttribute name="allowInterModalTransit" id="247e4761-4ff4-43f2-a5db-5c29ce6498ba">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="code" id="aff0252c-b5fc-4268-9137-18d33feacc45">
        <embedded/>
        <type name="Integer"/>
        <text>Unique code of the IMEX status. Refer to the System Table in Master Terminal for a list of unique codes.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="350ba029-855a-4e04-93b4-2bc9511c0591">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <text>Description of the IMEX status. E.g. Export, Import, Storage.</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="2dc14316-bfed-4df9-8918-d5c19f8d5e8c">
        <updating/>
        <source>setProxyFromObject(_object: CM_IMEXStatus) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
03 May 2022		jlizm1	TFS 53084 GPHA revceival/release of tranship cargo

*/

vars

begin
	inheritMethod(_object);
	self.abbreviation := _object.abbreviation;
	self.code := _object.code;
	if _object.description &lt;&gt; null then
		self.description := _object.description;
//	else
//		self.description := app.getErrorString(Unknown);
	endif;
	
	self.allowInterModalTransit := _object.allowInterModalTransit;	// TFS 53084
	
epilog

end;</source>
        <Parameter name="_object" type="CM_IMEXStatus"/>
    </JadeMethod>
</Class>
