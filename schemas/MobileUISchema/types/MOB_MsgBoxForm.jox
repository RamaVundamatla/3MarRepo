    <JadeMethod name="setMessage" id="d5cdcead-e9dd-4598-bc6e-8b7cc7a0e734">
        <updating/>
        <source>setMessage(_message: String; _title: String; _flags: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin
	self.aMessage	:=	_message;
	self.aTitle		:=	_title;
	self.aFlags		:=	_flags;
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_title" type="String"/>
        <Parameter name="_flags" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8866250c-0a9f-46b8-a73c-e37e6fe24a88">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
//	lbl_Text.caption			:=	self.aMessage;//mbHandleAmpersands();
//	self.caption				:=	self.aTitle;
	
	self.setupFormLayout();	
	self.txt_Text.setBackForeColor(app.colorBackTables, app.colorForeTables);
	//epr par 16981 19/6/08 resize it so it doesn't stretch on the ce devices
	self.doResize();
	self.repositionControls();
	inheritMethod();
epilog	
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupFormLayout" id="a2f85a11-ef54-458f-a8b2-4ef1d1fc4210">
        <updating/>
        <source>setupFormLayout() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2006 by cnwdad1
//
// Purpose:		Sets up the caption and the buttons that are available etc.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	buttonFlag		: Integer;
	defaultFlag		: Integer;
	delta			: Real;
	defaultButton	: MOB_Button;
	
begin
	//self.aIsKeyStrokeReceived	:=	false;
//	centreWindow;
	txt_Text.text				:=	self.aMessage;//mbHandleAmpersands();
	self.caption				:=	self.aTitle;

	buttonFlag	:=	self.aFlags.bitAnd(7);
	//iconFlag	:=	self.aFlags.bitAnd(MsgBox_Stop_Icon + MsgBox_Question_Mark_Icon + MsgBox_Information_Icon + MsgBox_Exclamation_Mark_Icon);
	defaultFlag	:=	self.aFlags.bitAnd(MsgBox_Default_Second + MsgBox_Default_Third);
/*
	if iconFlag = MsgBox_Stop_Icon then 
		self.pic_Stop.visible		:=	true;
	elseif iconFlag = MsgBox_Question_Mark_Icon then 
		self.pic_Question.visible	:=	true;
	elseif iconFlag = MsgBox_Exclamation_Mark_Icon then 
		self.pic_Exclam.visible	:=	true;
	elseif iconFlag = MsgBox_Information_Icon then 
		self.pic_Info.visible		:=	true;
	else
		delta			:=	lbl_Text.left - 12;
		lbl_Text.left	:=	lbl_Text.left - delta;		// No icon, so move the message to the left,
		lbl_Text.width	:=	lbl_Text.width + delta;		// and make it wider.
	endif;
*/
	if buttonFlag = MsgBox_OK_Only or buttonFlag &gt; MsgBox_Retry_Cancel then
		modalResult			:=	MsgBox_Return_OK;
		btn_Dialog2.caption	:=	"OK";//$MsgBox_Caption_OK;
		btn_Dialog2.default := true;
		btn_Dialog2.tag		:=	MsgBox_Return_OK.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btn_Dialog2;
		endif;

		if buttonFlag = MsgBox_OK_Only then
			btn_Dialog2.cancel	:=	true;
		endif;

		btn_Dialog1.visible	:=	false;
		btn_Dialog3.visible	:=	false;

	elseif buttonFlag = MsgBox_OK_Cancel then
		modalResult			:=	MsgBox_Return_Cancel;
		btn_Dialog2.caption	:=	"OK";//$MsgBox_Caption_OK;
		btn_Dialog2.tag		:=	MsgBox_Return_OK.String;
		btn_Dialog2.default := true;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btn_Dialog2;
		endif;

		btn_Dialog3.caption	:=	app.getErrorString(Cancel);//$MsgBox_Caption_Cancel;
		btn_Dialog3.tag		:=	MsgBox_Return_Cancel.String;
		btn_Dialog3.cancel	:=	true;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btn_Dialog3;
		endif;

		btn_Dialog1.visible	:=	false;

	elseif buttonFlag = MsgBox_Abort_Retry_Ignore then
		btn_Dialog1.caption	:=	app.getErrorString(Abort);//$MsgBox_Caption_Abort;
		btn_Dialog1.tag		:=	MsgBox_Return_Abort.String;
		btn_Dialog1.default := true;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btn_Dialog1;
		endif;

		btn_Dialog2.caption	:=	app.getErrorString(Retry);//$MsgBox_Caption_Retry;
		btn_Dialog2.tag		:=	MsgBox_Return_Retry.String;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btn_Dialog2;
		endif;

		btn_Dialog3.caption	:=	app.getErrorString(Ignore);//$MsgBox_Caption_Ignore;
		btn_Dialog3.tag		:=	MsgBox_Return_Ignore.String;
		
		if defaultFlag = MsgBox_Default_Third then
			defaultButton	:=	btn_Dialog3;
		endif;

	elseif buttonFlag = MsgBox_Yes_No_Cancel then
		modalResult			:=	MsgBox_Return_Cancel;
		btn_Dialog1.caption	:=	app.getErrorString(Yes);//$MsgBox_Caption_Yes;
		btn_Dialog1.tag		:=	MsgBox_Return_Yes.String;
		btn_Dialog1.default := true;
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btn_Dialog1;
		endif;

		btn_Dialog2.caption	:=	app.getErrorString(No);//$MsgBox_Caption_No;
		btn_Dialog2.tag		:=	MsgBox_Return_No.String;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btn_Dialog2;
		endif;

		btn_Dialog3.caption	:=	app.getErrorString(Cancel);//$MsgBox_Caption_Cancel;
		btn_Dialog3.tag		:=	MsgBox_Return_Cancel.String;
		btn_Dialog3.cancel	:=	true;
		
		if defaultFlag = MsgBox_Default_Third then
			defaultButton	:=	btn_Dialog3;
		endif;

	elseif buttonFlag = MsgBox_Yes_No then
		btn_Dialog2.caption	:=	app.getErrorString(Yes);//$MsgBox_Caption_Yes;
		btn_Dialog2.tag		:=	MsgBox_Return_Yes.String;
		btn_Dialog2.default := true;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btn_Dialog2;
		endif;

		btn_Dialog3.caption	:=	app.getErrorString(No);//$MsgBox_Caption_No;
		btn_Dialog3.tag		:=	MsgBox_Return_No.String;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btn_Dialog3;
		endif;

		btn_Dialog1.visible	:=	false;

	elseif buttonFlag = MsgBox_Retry_Cancel then
		modalResult			:=	MsgBox_Return_Cancel;
		btn_Dialog2.caption	:=	app.getErrorString(Retry);//$MsgBox_Caption_Retry;
		btn_Dialog2.tag		:=	MsgBox_Return_Retry.String;
		btn_Dialog2.default := true;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btn_Dialog2;
		endif;

		btn_Dialog3.caption	:=	app.getErrorString(Cancel);//$MsgBox_Caption_Cancel;
		btn_Dialog3.tag		:=	MsgBox_Return_Cancel.String;
		btn_Dialog3.cancel	:=	true;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btn_Dialog3;
		endif;

		btn_Dialog1.visible	:=	false;
	else
		modalResult	:=	0;
	endif;

	if defaultButton &lt;&gt; null then
//		setDefaultButton(defaultButton);
	endif;

	if btn_Dialog1.visible then
		if btn_Dialog1.default then
			btn_Dialog1.setFocus();
		endif;
	endif;

	if btn_Dialog2.visible then
		if btn_Dialog2.default then
			btn_Dialog2.setFocus();
		endif;
	endif;

	if btn_Dialog3.visible then
		if btn_Dialog3.default then
			btn_Dialog3.setFocus();
		endif;
	else
		if btn_Dialog2.visible then							// Change container position and width
			delta	:=	btn_Dialog2.left - btn_Dialog1.left;
		else
			delta	:=	btn_Dialog3.left - btn_Dialog1.left;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5331509e-6ed4-4a74-b0b9-995fb4fa5e24">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017612, locale);
	btn_Dialog1.translateCaption(Xlat_0013186, locale);
	btn_Dialog2.translateCaption(Xlat_0013187, locale);
	btn_Dialog3.translateCaption(Xlat_0013188, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
