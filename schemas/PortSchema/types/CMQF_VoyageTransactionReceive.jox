<Class name="CMQF_VoyageTransactionReceive" id="ba437467-f580-4bec-b147-1acf7357c11f">
    <superclass name="CMQF_VoyageTransaction"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="includesObject" id="b6a76462-774f-4b80-a758-e45612fb7e87">
        <updating/>
        <source>includesObject(_trx: CM_TITransaction; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2010	cnwndl1	Initial creation	Par 23056

*/

vars

	rtnValue : Boolean;
	
begin

	rtnValue := inheritMethod(_trx, _passport, _breakOut);
	
	if rtnValue then
		//we don' want transactions that were for children
		if _trx.isChild then
			rtnValue := false;
		endif;
	endif;
	
	return rtnValue;
	
end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="a594cd10-0704-44ca-9d28-2bbdcf1627e6">
        <updating/>
        <source>initFields() updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allTxnTypes.clear();
	self.allTxnTypes.add(TRANS_TYPE_REC_SHIP);

end;</source>
    </JadeMethod>
</Class>
