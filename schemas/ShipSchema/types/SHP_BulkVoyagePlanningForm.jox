    <JadeMethod name="frmBay_dblClick" id="bf8baa11-7643-4145-9b43-b16a998a8853">
        <controlMethod name="CMUI_GridAreaDrawingFrame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBay_dblClick(frame : SHP_BulkDrawingFrame input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	obj : Object;
	hold : CM_LocationsController;
	objArray : ObjectArray;
	mode : Integer;
	move : CM_FutureMove;

begin
	app.mousePointer := MousePointer_HourGlass;
	obj := frame.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer); 
	
	if obj = null or (not obj.isKindOf(CM_GeneralCargoController)and not obj.isKindOf(CM_ShipBlockController)) then
		return;
	endif;
	
	hold := obj.CM_LocationsController;
	mode := self.myBulkDrawingController.actPlanQueMode;
	create objArray transient;
	
	if mode = ShpDisplayMode_Actual then
		if not hold.allTrackedItemsById.isEmpty then
			hold.allTrackedItemsById.copy(objArray);
		endif;
	elseif mode = ShpDisplayMode_Proposed then
		foreach move in hold.allPlannedFutureMoves discreteLock do
			if move.myWorkListEntry &lt;&gt; null and move.myWorkListEntry.myTrackedItem &lt;&gt; null then
				objArray.add(move.myWorkListEntry.myTrackedItem);
			endif;
		endforeach;
	elseif mode = ShpDisplayMode_Queued then
		foreach move in hold.allQueuedFutureMoves discreteLock do
			if move.myWorkListEntry &lt;&gt; null and move.myWorkListEntry.myTrackedItem &lt;&gt; null then
				objArray.add(move.myWorkListEntry.myTrackedItem);
			endif;
		endforeach;
	endif;
	
	if not objArray.isEmpty then
		self.myAssistant.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;
	
epilog
	delete objArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="frame" type="SHP_BulkDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="frmBay_dragDrop" id="64991638-cbf0-40d3-925c-6de26d2148e7">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBay_dragDrop(frame : SHP_BulkDrawingFrame input; win : Window input; x : Real; y : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	if (self.displayMode = ShpDisplayMode_Ops and self.myBulkDrawingController.actPlanQueMode = ShpDisplayMode_Proposed)
	or self.displayMode = ShpDisplayMode_Actual
	then
		self.doGridAreaDragDropEvent(frame, win, x, y);
	else
		if frame.isDrawDeskTopRectangle then
		
		else
			app.msgBox("Can only drag drop in Planning Mode or when viewing Actuals","Drag Drop Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
