    <ExternalMethod name="createProcess" id="b0af0bfd-f567-4eda-8684-73e589179fad">
        <entrypoint>emCreateProcess</entrypoint>
        <library name="karma"/>
        <source>createProcess(
			obj: Object; 
			cmdLine: String; 
			modal: Boolean; 
			notifyStdOut: Boolean; 
			childStdIntext: String; 
			tag: Integer; 
			exitCode: Integer output): Integer is "emCreateProcess" in "karma" number = 1001;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="cmdLine" type="String"/>
        <Parameter name="modal" type="Boolean"/>
        <Parameter name="notifyStdOut" type="Boolean"/>
        <Parameter name="childStdIntext" type="String"/>
        <Parameter name="tag" type="Integer"/>
        <Parameter name="exitCode" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </ExternalMethod>
    <JadeMethod name="delete" id="9dc1108a-e3d3-4e3d-8b5d-f2dfab9bae91">
        <updating/>
        <source>delete() updating;

begin
	// Tell the ProcessLogger to shut down ....
	self.causeEvent(Process_Logger_End,true,Process_Logger_End);
end;</source>
    </JadeMethod>
    <JadeMethod name="run" id="54de0cdd-3891-47dc-85af-a7a4ecfae7ef">
        <updating/>
        <source>run():Boolean updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	reslt,extCode,prevLen:Integer;
begin
	// Start ProcessLogger if it is not running ....
	if proc = null or not global.isValidObject(proc) then
		beginTransientTransaction;
		proc := app.startApplicationWithParameter(currentSchema.name, "ProcessLogger", self);
		commitTransientTransaction;
		while stdOut&lt;&gt;Process_Logger_Ready do
//			write "waiting for ready...";
			app.doWindowEvents(250);
		endwhile;
		beginTransientTransaction;
		stdOut:="";
		commitTransientTransaction;
	endif;

	// Execute the cmdLine ....
	reslt := createProcess(self, 
							cmdLine, 
							true, 
							true, 
							null, 
							Process_Std_Out_Event, 
							extCode);
	prevLen:=-1;
	while stdOut.length&lt;&gt;prevLen do
//		write "waiting for the rest...";
		app.doWindowEvents(2000);
		prevLen:=stdOut.length;
	endwhile;

	// save results where caller can see them
	beginTransientTransaction;
	exitCode:=extCode;
	result:=reslt;
	if reportWhenFinished then
		if logFileName&lt;&gt;null then
			create logFile sharedTransient;  //Shared transient objects cannot reference non-shared transient objects in Jade 6
			logFile.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
			logFile.fileName:=logFileName;
			logFile.mode:=File.Mode_Append;
			logFile.usePresentationFileSystem:=false;
			if doingWinZip then
				logFile.writeLine(app.actualTimeServer.logFormat&amp;" "&amp;errors.String&amp;" errors, "&amp;warnings.String&amp;" warnings");// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			endif;
			logFile.writeLine(app.actualTimeServer.logFormat&amp;" "&amp;Command_Finished&amp;" ("&amp;result.String&amp;","&amp;exitCode.String&amp;")");// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			logFile.close;
			delete logFile;
		endif;
		stdOut:=stdOut&amp;CrLf&amp;Command_Finished&amp;CrLf;
	endif;
	commitTransientTransaction;
	if extCode=0 and reslt=0 then
		return true;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
