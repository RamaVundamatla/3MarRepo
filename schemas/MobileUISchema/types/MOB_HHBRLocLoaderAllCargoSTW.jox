    <JadeMethod name="getQuantityLoaded" id="1ffc525a-8cff-4d96-a62c-083c09b75c9a">
        <source>getQuantityLoaded( _weightLoaded : Decimal output) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2015	cnwndl1	Initial creation	Par 37153

*/

vars
	count: Integer;
	ti: CM_TrackedItem;
	release : CM_BulkRelease;
	primLoc : CM_LocationsController;
begin
	release := self.myBulkRelease;	//13 Jun 2016	NDL	TFS 2133 - only show per release
	
	if self.isWagon then	//25 Jan 2017	NDL	TFS 3198/2877
		foreach ti in release.allTrackedItemsAssigned discreteLock do
			primLoc := ti.myPrimaryActualLocation;
			if primLoc = null or not primLoc.isWagon then
				continue;
			endif;
			if primLoc.CM_WagonController.myWagon &lt;&gt; self.myWagon then
				continue;
			endif;
			count := count + ( ti.totalQuantity.max(1) );
			_weightLoaded := _weightLoaded + ti.totalWeight;
		endforeach;
		
	else
		foreach ti in self.myTargetLocation.allTrackedItems do
			if ti.isROB then	//09 Dec 2015	NDL	TFS 752-12
				continue;
			endif;
			//13 Jun 2016	NDL	TFS 2133 - Count should be relative to the Release 
			if release &lt;&gt; null and not ti.allBulkReleasesAssigned.includes( release) then
				continue;
			endif;
			count := count + ( ti.totalQuantity.max(1) );
			_weightLoaded := _weightLoaded + ti.totalWeight;
		endforeach;
	endif;
	return count;
epilog

end;</source>
        <Parameter name="_weightLoaded" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQuantityToLoad" id="a7102271-8868-4c93-9380-a28e9c5657f2">
        <source>getQuantityToLoad( _weightToLoad : Decimal io ) : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwdw1	Initial creation
*/
vars
	wles: CM_WLESet;
	wle: CM_WorkListEntry;
	quantity: Integer;
	request : CM_Request;
begin
	create wles transient;
	self.getWLEsForRelease(wles);
	foreach wle in wles do
		quantity := quantity + wle.quantity.max(1);	//20 May 2015	NDL	Par 36127
		_weightToLoad := _weightToLoad + wle.weight;
	endforeach;
	
	return quantity;
epilog
	delete wles;
end;</source>
        <Parameter name="_weightToLoad" type="Decimal" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRoadJob" id="163077ba-5aa9-4c47-a4e0-92eaf88e1d3a">
        <source>getRoadJob():CM_RoadJob;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2015	cnwndl1	Initial creation	Par 37153

*/

vars

	roadJob : CM_RoadJob;
	job : CM_Job;

begin

	if self.isVehicle then
		foreach job in self.myTruck.allRoadJobs do
			if job.status = JOB_COMPLETE then
				continue;
			endif;
			if not job.isRelease then
				continue;
			endif;
			roadJob := job.CM_RoadJob;
		endforeach;
		
		//19 Dec 2018	NDL	TFS 38083	
		if roadJob = null and not self.myTruck.allRoadJobs.isEmpty then
			roadJob := self.myTruck.allRoadJobs.first.CM_RoadJob;
		endif;
		
	elseif self.isTrailer then
		roadJob := self.myTrailer.jobRoadRelease;	
	
	endif;
	
	return roadJob;
	
epilog

end;</source>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="getWLEsForRelease" id="ca3a77b8-4d23-408f-bd02-0c87fb4fd338">
        <source>getWLEsForRelease(_wles: CM_WLESet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2015	cnwndl1	Initial creation	Par 37153

*/

vars

	roadJob : CM_RoadJob;
	job : CM_Job;
	wle : CM_WorkListEntry;
	lc : CM_LocationsController;

begin

	if self.isWagon then	//25 Jan 2017	NDL	TFS 3198/2877
		foreach lc in self.myWagon.allLocationsControllersArray discreteLock do
			foreach wle in lc.CM_WagonController.allRailWLELoad do
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.bulkRelease = self.myBulkRelease then
						_wles.addNoDuplicates(wle,false);
					endif;
				endif;
			endforeach;
		endforeach;

	else
		roadJob := self.getRoadJob();
		
		if roadJob &lt;&gt; null then
			foreach wle in roadJob.workListEntries do
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
						_wles.add(wle);
					endif;
				endif;
			endforeach;
		endif;
	
	endif;
	
	return;

epilog

end;</source>
        <Parameter name="_wles" type="CM_WLESet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getWleForYardItem" id="473f6e0c-9525-4184-b87e-921553c2f82f">
        <source>getWleForYardItem( ti : CM_TrackedItem) : CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2017	cnwndl1	Initial creation	TFS 3198/2877

*/

vars

	wle : CM_WorkListEntry;
	selectedWle : CM_WorkListEntry;
	reserveDetail : CM_ReserveDetail;
	mess : String;
	wleSet : CM_WLEArray;
	wagon : CM_Wagon;
	req : CM_Request;
	resDetail : CM_ReserveDetail;
	lc : CM_LocationsController;

begin
	// cnwmc5 - 2 Feb 2016 - PAR 37483
	reserveDetail := self.myMobileGenericAgent.myReserveSelection;
	if reserveDetail = null then
		reserveDetail := self.myMobileGenericAgent.getReserveDetailCargoMatches( ti, 0, 0, mess );
	endif;
	
	if self.isWagon then
		//Rail version.
		
		foreach wle in ti.allWorklistEntries do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if not wle.isRail then
				continue;
			endif;
			selectedWle := wle; 
			break;
		endforeach;
		
		//OK, so the cargo isn't actually assigned to the wle. find the matching director task wle that is assigned to a 
		// location on the selected wagon.
		if selectedWle = null then
			selectedWle := getWleFromLocation( ti, reserveDetail );
		endif;
		
		
	else
		//code migrated from "clickInYardItem" when it was still just for loading trucks.....
		foreach wle in ti.allWorklistEntries do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			selectedWle := wle; 
			break;
		endforeach;
		
		//12 Nov 2015	NDL	Par 37092
		if selectedWle = null then
			
			//dir task, i.e by type
			if self.isVehicle then
				create wleSet transient;
				self.myTruck.getAllWLE( wleSet );
				if not wleSet.isEmpty then
					foreach wle in wleSet do
						if wle.status = WLE_COMPLETED then
							continue;
						endif;
						if wle.isReceipt then
							continue;
						endif;
						
						// cnwmc5 - 2 Feb 2016 - PAR 37483
						if reserveDetail &lt;&gt; null then
							if wle.myRequest &lt;&gt; null and wle.myRequest.myReserveDetail &lt;&gt; reserveDetail then
								continue;
							endif;
						endif;
						
						selectedWle := wle;
						break;
					endforeach;
				endif;
			endif;
		endif;

	endif;

epilog

	delete wleSet;
	
	return selectedWle;

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWleFromLocation" id="7d723831-ab67-4427-921e-c8d5d48212ab">
        <source>getWleFromLocation( _ti : CM_TrackedItem; _reserveDet : CM_ReserveDetail ):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2015	cnwndl1	Initial creation	Par 37153
19 Jan 2017	NDL	TFS 3198/2877 - Add isRail stuff

*/

vars

	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	
	req : CM_Request;
	resDetail : CM_ReserveDetail;
	lc : CM_LocationsController;
	validWleSet : CM_WLESet;

begin

	if self.isWagon then
		//26 Jan 2017	NDL	TFS 3198/2877
		create validWleSet transient;
		foreach lc in self.myWagon.allLocationsControllersArray discreteLock do
			foreach wle in lc.CM_WagonController.allRailWLELoad do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.myTrackedItem = null
				or wle.myTrackedItem.isRRP	//31 Mar 2020	NDL	TFS 47004
				or wle.myTrackedItem = _ti
				then
					req := wle.myRequest;
					if req = null then
						continue;
					endif;
					if _reserveDet &lt;&gt; null then
						if req.myReserveDetail &lt;&gt; _reserveDet then
							continue;
						endif;
					endif;
					if wle.myTrackedItem = _ti then
						// if its actually this one, use it
						return wle;
						break;
					else
						//otherwise add to the valid set of wles to consider
						validWleSet.addNoDuplicates( wle, false );
					endif;
				endif;
			endforeach;
		endforeach;
		
		return validWleSet.first;
	
	
	else

		roadJob := self.getRoadJob();
		
		if roadJob = null then
			return null;
		endif;
		
		wle := roadJob.getWLEForTI( _ti );
		if wle &lt;&gt; null then
			return wle;
		endif;
		
		foreach wle in roadJob.workListEntries do  
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
		
			if wle.myRequest &lt;&gt; null then
				if wle.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
					if _reserveDet = null or _reserveDet = wle.myRequest.myReserveDetail then	//12 Feb 2016	NDL	Par 37537
						return wle;
					endif;
				endif;
			endif;
		endforeach;
	
	endif;
	
	return null;

epilog

	delete validWleSet;
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reserveDet" type="CM_ReserveDetail"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="handleBtnFour" id="f9f35e4d-a4f6-4a13-863f-8a8f24a2e097">
        <updating/>
        <source>handleBtnFour() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

begin

	if self.checkFullyLoaded() then
		self.doBackButtonClick();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="212f802f-246c-4e42-81c3-86d56b74fe49">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384
15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
25/01/2017 cnwma1 TFS #3260:PAR38596 STWR - Fatal error when completing the unloading of a truck in JMT
*/

vars

	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	incompleteWleSet : CM_WLESet;

begin

	//15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
	if self.isVehicle then  // 25/01/2017	cnwma1	3260
		if self.myTruck.getCurrentVisit.isBulkGateVVR() then
			app.raiseCMException1(Vehicle_visit_Bulk_Only,app.getErrorString(Bulk_gate_out),"wrongGate", null);
			//err you cant process bulk gate job here
			return;
		endif;
	endif;
	if self.isWagon then	//02 Feb 2017	NDL	TFS 3198/2877
	
		//nothing special to do for wagons...
	
	elseif self.isVehicle or self.isTrailer then
	
		if self.isTrailer then	//21 Jan 2018	NDL	TFS 42928
			self.myMobileGenericAgent.setTruck( self.myTargetLocation.CM_TILCController.getVehicle()  );
			roadJob := self.myMobileGenericAgent.myTruck.allRoadJobs.first.CM_RoadJob;
		else
			self.myMobileGenericAgent.setTruck( self.myTruck );
			roadJob := self.myTruck.allRoadJobs.first.CM_RoadJob;
		endif;
		
		create incompleteWleSet transient;
		foreach wle in roadJob.workListEntries do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if wle.isReceipt then
				continue;
			endif;
			if wle.myTrackedItem &lt;&gt; null then
				continue;
			endif;
			incompleteWleSet.add( wle );
		endforeach;
		if not incompleteWleSet.isEmpty then
			if self.msgBox( app.getErrorString(Truck_still_incom_jobs_want_co),  app.getErrorString(Continue), MsgBox_Yes_No, false ) &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
		foreach wle in incompleteWleSet do
			app.myTrxUA.trxUpdateWLEStatusDirectWLE(wle.CM_YardWLE, WLE_COMPLETED, app.myPassport);	
			if app.myPassport.hasErrors then
				self.msgBox(app.myPassport.getErrorsAsString,app.getErrorString(Error), MsgBox_OK_Only, true);
				return;
			endif;
		endforeach;
		
		if not self.doComplete() then
			return;
		endif;
		
		self.myMobileGenericAgent.setGateAreaLaneController( null, true );
		
//	elseif self.isTrailer then
//		self.myMobileGenericAgent.setTruck( self.myTargetLocation.CM_TILCController.getVehicle()  );

//		if not self.doComplete() then
//			return;
//		endif;
		
		self.myMobileGenericAgent.setGateAreaLaneController( null, true );
	endif;

	self.myMobileGenericAgent.clearAll();
	self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
	self.goBackToFirst(MOB_HHPackRequestViewSTW);

epilog

	delete incompleteWleSet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnThree" id="ede906a8-8b16-420e-9c3c-1fb6f4df08d1">
