<CollClass name="GTE_KioskProxyCargoArray" id="6a4c46af-98fe-4623-9495-63f7131f1b15">
    <loadFactor>66</loadFactor>
    <memberType name="GTE_KioskProxyCargo"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="gate"/>
    <JadeMethod name="getCargoCount" id="2db46b04-a51b-45d3-89e5-81d3dc655e87">
        <source>getCargoCount(_cargoItemObj:CM_Object):Integer;
// --------------------------------------------------------------------------------
// Created:		05 October 2006 by cnwdad1
//
// Purpose:		Returns the number of times the specified Cargo item is used in the
//				receiver.
//
// Parameters:	_cargoItemObj - A reference to the Cargo item to count.
//
// Returns:		The number of times the Cargo item is used.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	cargoCount		: Integer;
	
begin
	cargoCount	:=	0;
	
	foreach proxyCargoObj in self do
		if proxyCargoObj.myCargoItem = _cargoItemObj then
			cargoCount	:=	cargoCount + 1;
		endif;
	endforeach;
	
	return cargoCount;
end;</source>
        <Parameter name="_cargoItemObj" type="CM_Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFortyCount" id="054724d8-8104-412a-9e1c-0b1c784e2dda">
        <source>getFortyCount():Integer;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns the number of 40' cargo containers in the receiver.
//
// Parameters:	None
//
// Returns:		The number of 40' cargo containers.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	fortyCount		: Integer;
	
begin
	fortyCount	:=	0;
	
	foreach proxyCargoObj in self do
		if proxyCargoObj.isForty then
			fortyCount	:=	fortyCount + 1;
		endif;
	endforeach;
	
	return fortyCount;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWidths" id="08124597-1b2b-4bf6-bfa8-c2ac5be73c07">
        <source>getWidths(_cargo1:Integer output; _cargo2:Integer output; _cargo3:Integer output; _cargo4:Integer output);
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns the width of each of the receiver's cargo containers./
//
//				Note that "width" in the context of this method is actually length,
//				because we're looking at the truck from side-on.
//
// Parameters:	_cargo1 - The width of container 1.
//				_cargo2 - The width of container 2.
//				_cargo3 - The width of container 3.
//				_cargo4 - The width of container 4.
//
// Returns:		The container widths in the output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DEFAULT_WIDTH	: Integer = 171;	// The default container width.
	TRAY_WIDTH		: Integer = 399;	// The amount of space available on the truck/trailer.
	
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	totalCount		: Integer;
	fortyCount		: Integer;
	standardWidth	: Integer;
	actualWidth		: Integer;
	cargoPointer	: Integer;
	
begin
	totalCount		:=	self.size();
	fortyCount		:=	self.getFortyCount();
	standardWidth	:=	(TRAY_WIDTH div (totalCount + fortyCount)) - totalCount;
	cargoPointer	:=	0;
	
	foreach proxyCargoObj in self do
		cargoPointer	:=	cargoPointer + 1;
		
		if proxyCargoObj.isForty then
			actualWidth	:=	standardWidth * 2;
		else
			actualWidth	:=	standardWidth;
		endif;
		
		if cargoPointer = 1 then
			_cargo1	:=	actualWidth;
		elseif cargoPointer = 2 then
			_cargo2	:=	actualWidth;
		elseif cargoPointer = 3 then
			_cargo3	:=	actualWidth;
		elseif cargoPointer = 4 then
			_cargo4	:=	actualWidth;
		endif;
	endforeach;
end;</source>
        <Parameter name="_cargo1" type="Integer" usage="output"/>
        <Parameter name="_cargo2" type="Integer" usage="output"/>
        <Parameter name="_cargo3" type="Integer" usage="output"/>
        <Parameter name="_cargo4" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="includesBR" id="6e3990d6-ae3e-4227-add1-ef8adeda5a7e">
        <source>includesBR( _br : CM_BulkRelease ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2020	jlgndl1	Initial creation	TFS 49167

*/

vars

	iter : Iterator;
	kCargo : GTE_KioskProxyCargo;

begin

	iter := self.createIterator;
	while iter.next( kCargo ) do
		if kCargo.myCargoItem = _br then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_br" type="CM_BulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
