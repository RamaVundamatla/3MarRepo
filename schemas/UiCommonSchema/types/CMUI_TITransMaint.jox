    </JadeMethod>
    <JadeMethod name="translateForm" id="321ab35b-87ce-4ebe-88a6-e8c0d283d1ce">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008203, locale);
	btnAdd.translateCaption(Xlat_0001057, locale);
	btnCancel.translateCaption(Xlat_0001058, locale);
	btnDelete.translateCaption(Xlat_0001059, locale);
	btnSave.translateCaption(Xlat_0001060, locale);
	btnUpdate.translateCaption(Xlat_0001061, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateTITxnController" id="3f5a95a4-1b1f-4704-a1f3-d1e66b2ec31f">
        <source>validateTITxnController(_txnController : CMIF_TITransactionController) : Boolean;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	existingTxnController 				: CMIF_TITransactionController;
begin
	if _txnController.myTrackedItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "TxnController's myTrackedItem is null");
		return false;
	endif;
	
	if _txnController.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "TxnController's myTerminal is null");
		return false;
	endif;
	
	if (not _txnController.dateTime.isValid) then
		app.msgBox('The date time field is invalid', 'Error', 0);
		return false;
	endif;
	
	if self.state = self.State_Add then //check for duplicates
		existingTxnController := self.allTITxnControllers[_txnController.type, _txnController.dateTime];
		if existingTxnController &lt;&gt; null then
			app.msgBox('A transaction of that type, at that time, for this item' &amp; CrLf &amp;
						'already exists - you should update that one instead','Duplicate transaction', 0);
			return false;
		endif;
	endif;
		
	return true;

end;</source>
        <Parameter name="_txnController" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
