    <JadeMethod name="getDetailForDisplay" id="cca48bf3-9f08-467e-9ef9-fd9b50c336de">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
// -------------------------------------------
// Created 28 February 2005 by cnwdvb1
// -------------------------------------------
vars

	str : String;
begin

	if not inheritMethod(_array) then
		return false;
	endif;

	if self.allExtraDetail &lt;&gt; null then
		self.allExtraDetail.copy(_array);
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
