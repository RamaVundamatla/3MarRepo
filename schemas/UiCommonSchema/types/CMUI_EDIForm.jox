    <JadeMethod name="setFilterForType" id="c615c1e5-7757-4c1e-a924-dd7b9309694e">
        <updating/>
        <source>setFilterForType(_class: Class)updating;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	dataTypes : IntegerArray;
	
begin
	create dataTypes transient;
	self.filterFileType	:= self.getFileType(_class);

	if self.filterFileType = null then
		return;
	endif;
	
	//cnwgb1 MES1011 7.9.09 prototype
	//self.cmbFiltEdiType.listIndex := self.filterFileType; remove
	self.myEDIConfig.getDataTypeFromClass( _class, dataTypes );
	if dataTypes.size = 1 then
		self.cmbFiltEdiType.listIndex := self.cmbFiltEdiType.findItemData( dataTypes[1] );
	endif;
	//end; cnwgb1 MES1011 7.9.09 prototype 
	self.tblSearch.setValueByControlName(self.cmbFiltEdiType.name, self.cmbFiltEdiType.text);
epilog
	delete dataTypes;
end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setFilterTblDef" id="8ad834a2-3e75-4f52-9229-8eabe4fdbe23">
