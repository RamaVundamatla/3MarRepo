    <JadeMethod name="setControlsForAddEdit" id="c233f54e-5133-4095-a973-71dc75bf507e">
        <updating/>
        <source>setControlsForAddEdit() updating;

//
// 10 April 2013 	PJS		PAR # 31408
// 06 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 14 Aug 2023 	navhl20 	ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.btnSingle1Edit.enabled:=true;
	theForm.btnSingle1Delete.enabled:=true;
	theForm.btnSingle1New.enabled:=true;
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setValueByName(ETRow_Colour,White.String);	//06-06-2022	navtnr20 53204
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.shtSingleSelect1.visible := false;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.cmbDebtor.setObject(null);				//14.8.2023 navhl20 #56642
		theForm.mulSelect1.setSelected(null);			
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors();	
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ShippingLine);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.shtSingleSelect1.visible := false;
	endif;
	theForm.tblInput1.disableRowByName(ETRow_FinancialId);//04.Mar.24 navsp1 TFS 57177
	theForm.mulSelect1.userInputEnabled := true;
	self.enableMulSelect1Contents();
	
	// 31408
	//disallow access to ports group sheet if tehrearte none setup for any shipping lines
	
	if not allowAccessPortsGroups then
		theForm.shtSingleSelect1.visible := false;
	endif;
	

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="a66d683d-6b08-4ab6-9b6a-47232299c822">
        <updating/>
        <source>setCtrlsForView() updating;

//
// 10 April 2013	PJS		PAR #31408
//

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.shtSingleSelect1.visible := allowAccessPortsGroups;   // 31408
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="2437dd0c-09f8-457c-b3e8-3564a2d95185">
        <updating/>
        <source>setupThumbnailDetails() updating;
// 06 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
vars
	theForm : SOP_TableMaintForm;
	tmpCol : ObjectSet;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ShippingLineTbl);
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);	//06-06-2022 navtnr20	53204
//	theForm.zAddColumn('ShippingLine Id', 'code', Table.InputType_None, 30);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ShippingLineMaint);
	theForm.shtTblInput1.visible := true;
	
   

	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b7ce7db0-3f25-48a7-a7da-40039b1dab2a">
        <updating/>
        <source>showThumbnail(pShippingLine : CM_ShippingLine) updating;
// 06 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 14 Aug 2023 	navhl20 	ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link
vars

	theForm : SOP_TableMaintForm;

begin
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pShippingLine.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pShippingLine.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pShippingLine.isNotAvailableForEntry);	
	if pShippingLine.myDebtor &lt;&gt; null then																			//14.8.2023 navhl20 #56642
		theForm.tblInput1.setValueByName(ETRow_Debtor,pShippingLine.myDebtor.name); 
		theForm.tblInput1.setValueByName(ETRow_FinancialId, pShippingLine.myDebtor.code);							//04.Mar.24 navsp1 TFS 57177
	endif; 
	theForm.cmbDebtor.setObject(pShippingLine.myDebtor); 															//14.8.2023 navhl20 #56642
	theForm.lstSingleSelect1.listCollection(pShippingLine.shipPortGroups,false,0);
	theForm.mulSelect1.setSelected(pShippingLine.allContacts);	
	theForm.tblInput1.setValueByName(ETRow_Colour,pShippingLine.colour);	//06-06-2022	navtnr20 	53204
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pShippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="6a0031f2-bd33-4740-a270-c84bd4e42eed">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
07 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars
	lshippingLine:CM_ShippingLine;
	cell     :JadeTableCell;
begin

	lshippingLine := _obj.CM_ShippingLine;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := lshippingLine.colour;
		endif;
	endif;
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
