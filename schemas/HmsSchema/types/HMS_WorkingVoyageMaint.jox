		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadAddVoyage" id="dcfe818b-03ae-44b6-b7e1-c2b08cfe86d1">
        <updating/>
        <source>loadAddVoyage() updating;

vars
 	newClonedVoyage:	CMIF_HMS_WorkingVoyage;
 	vesselData:			HMS_VesselData;
 	ship:				CM_Vessel;
 	arrvDT:				TimeStamp;
 	deptDT:				TimeStamp;
 	defVoyCode:			String;
 	posn:				Integer;
 	tmpTerm:			CM_Terminal;
	arrivedLocal,
	departedLocal:		TimeStamp;
begin
	self.setMyCurrentVessel(null);	
	// Notify controller that a voyage is being added or edited - delay any database updates until user finishes this action
	if self.myViewController &lt;&gt; null then
		self.myViewController.set_AddEditVoyageActiveState(true);
	endif;

    // Set default properties for newVoyage
	defVoyCode := "XXX999";

	ship := self.cmbVessel.listObject.CM_Vessel;	
	if ship = null then
		return;
	endif;
	vesselData := ship.myHMSVesselData;
	if vesselData = null then
		if self.isFirstActivateComplete then
			if app.msgBox(app.getErrorString1(HMS_Cannot_Create_Voyage, ship.name), app.getErrorString(HMS_Vessel_Data_Required), MsgBox_Stop_Icon+MsgBox_Yes_No) = MsgBox_Return_Yes then
				//Open vessel definition
				self.showVesselMaintenance(ship);
			endif;
		endif;
		self.cmbVessel.listIndex := self.cmbVessel.findObject(self.myCurrentVessel);		
		return;
	endif;	
	
	tmpTerm := self.cmbTerminalHMS.listObject.CM_Terminal;	
// cnwdad1 17/06/2009 - PAR #19942.
//	arrvDT := (txtDateArrival.text &amp; ", " &amp; txtTimeArrival.getTime().roundToNearestMinute.String).TimeStamp;
//	deptDT := (txtDateDepart.text &amp; ", " &amp; txtTimeDepart.getTime().roundToNearestMinute.String).TimeStamp;
	arrivedLocal.setDate(txtDateArrival.text.asDateJMT());
	arrivedLocal.setTime(txtTimeArrival.getTime().roundToNearestMinute());	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	arrvDT := self.localToSystemTime(arrivedLocal);
	departedLocal.setDate(txtDateDepart.text.asDateJMT());
	departedLocal.setTime(txtTimeDepart.getTime().roundToNearestMinute());
	deptDT := self.localToSystemTime(departedLocal);

	create newClonedVoyage;
	newClonedVoyage.newVoyageAsClone(defVoyCode,ship,arrvDT,deptDT, tmpTerm, self.myViewController);
	self.myViewController.addProxyObject(newClonedVoyage.myHMSVoyageData);
	
	self.setMyCurrentWorkingVoyage(newClonedVoyage);
	if self.myCurrentVessel &lt;&gt; ship then
		self.setMyCurrentVessel(ship);
	endif;

    // Load movements table
    self.loadMovementTable();
    
    // Load ship summary table
	self.loadSummaryTbl;

	self.loadPreferredBerthList;

	// Set default class in 
	if myCurrentWorkingVoyage.ofClassIn&lt;&gt;null then
		posn := cbxClassIn.findObject(myCurrentWorkingVoyage.ofClassIn);
		if posn &gt; 0 then
			cbxClassIn.listIndex := posn;
			cbxClassIn.text:=cbxClassIn.itemText[cbxClassIn.listIndex];
		endif;
	endif;

	// Set default class out 
	if myCurrentWorkingVoyage.ofClassOut &lt;&gt; null then
		posn := cbxClassOut.findObject(myCurrentWorkingVoyage.ofClassOut);
		if posn &gt; 0 then
			cbxClassOut.listIndex := posn;
			cbxClassOut.text := cbxClassOut.itemText[cbxClassOut.listIndex];
		endif;
	endif;

	// Modified by Russell 01/04/99
	// -----------------------------------------------------------
	if myCurrentWorkingVoyage.code = "XXX999" then  // Code not yet set
		myCurrentWorkingVoyage.code := self.createSystemVoyCode();
		tbxVoyageCode.text := myCurrentWorkingVoyage.code;   // Will be removed later
	endif;
	// -----------------------------------------------------------

	// Modified by Russell 14/07/99
	// --------------------------------------------------------
	// Enable/Disable Stevedore Load/Discharge group boxes
	//gbxStevedoreDis.enabled := ckbxDischarge.value;
	//gbxStevedoresLoad.enabled := ckbxLoad.value;	

	self.setLastVoyageDefaults(ship);

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCollections" id="c7114a91-84d5-4131-b986-2dcabee9c76e">
        <updating/>
        <source>loadCollections() updating;

vars
	timeNow:			Time;
	dateToday:			Date;
	delay,			
	workingDelay:		CMIF_HMS_VoyageDelay;
	stevedore: 			CM_Stevedore;
	root: 				CM_Root;
	displayNameFirst: 	Boolean;
	now:				TimeStamp;
begin

	self.disableMoveMaint();
	now := self.systemToLocalTime(app.actualTimeServer());	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	timeNow := now.Time;
	dateToday := now.Date;
	root := app.myRoot;
	
	// now handelled in combo init.	myTerminal for combo needs to be set though
		//Indicate how we would like to display configurable display combo boxes
		//	displayNameFirst := self.myTerminal.getConfig(PortComboByName).Boolean;
		//	self.cbxPortFrom.isPortByName := displayNameFirst;
		//	self.cbxPortTo.isPortByName := displayNameFirst;
	self.cbxPortFrom.myTerminal := self.myTerminal;
	self.cbxPortFrom.myAssistant:= self.myAssistant;
	self.cbxPortTo.myTerminal := self.myTerminal;
	self.cbxPortTo.myAssistant:= self.myAssistant;
	
	
	/*// Load Vessels with HMS data
	self.cmbVesselData.clear();
	self.cmbVesselData.initialise();
	if self.cmbVesselData.listCount &gt; 0 then
		self.cmbVesselData.listIndex := 1;
	endif;*/

	// Load Vessels 
	self.cmbVessel.clear();
	self.cmbVessel.initialise(false);
	if self.cmbVessel.listCount &gt; 0 then
		self.cmbVessel.listIndex := 1;
	endif;	
	
	// Load Terminals
	self.buildCombosForHarbour();
	
	// Load ports
	//if root.allPorts.size&gt;0 then
	if root.allActivePorts.size&gt;0 then
		//cbxPortArriveFrom.listCollection(root.allPorts,true,0);
		//cbxPortDepartTo.listCollection(root.allPorts,true,0);
		// Set selected item to first in list
		//cbxPortArriveFrom.listIndex := 1;
		//cbxPortDepartTo.listIndex := 1;
		//cbxPortArriveFrom.text := cbxPortArriveFrom.itemText[1];
		//cbxPortDepartTo.text := cbxPortDepartTo.itemText[1];

		self.cbxPortFrom.setObject(root.allActivePorts.first);
		self.cbxPortTo.setObject(root.allActivePorts.first);
				
//		self.cbxPortFrom.setObject(root.allPorts.first);
//		self.cbxPortTo.setObject(root.allPorts.first);
	endif;

    // Modified by Russell 04/05/99
    // ---------------------------------------------------------------------
    // Load "All Stevedores" listboxes
    if (not root.allStevedores.isEmpty) then
		foreach stevedore in root.allStevedores do
			if stevedore.notAvailableForEntry then
				continue;
			endif;
			lbxAllSteveDis.itemObject[lbxAllSteveDis.addItem(stevedore.description &amp; ' (' &amp; stevedore.code&amp;')')] := stevedore;
			lbxAllSteveLoad.itemObject[lbxAllSteveLoad.addItem(stevedore.description &amp; ' (' &amp; stevedore.code&amp;')')] := stevedore;			
		endforeach;    	
    endif;
    // ---------------------------------------------------------------------

    // Set current time
    txtTimeArrival.setTime(timeNow);
    txtTimeDepart.setTime(timeNow);
    txtDateArrival.setDate(dateToday.Date);
    txtDateDepart.setDate((txtDateArrival.getDate()+2).Date);

 	// Load "All Cargo" listboxes
    if root.allCommodities.size &gt; 0 then
    	lbxAllCargoDis.listCollection(root.allCommodities,true,0);
    	lbxAllCargoLoad.listCollection(root.allCommodities,true,0);
    endif;

    // Load "Ship Class" comboboxes
    if root.allVesselCategories.size &gt; 0 then
    	cbxClassIn.listCollection(root.allVesselCategories,true,0);
    	cbxClassIn.listIndex := 1;
    	cbxClassIn.text := cbxClassIn.itemText[cbxClassIn.listIndex];
    	cbxClassOut.listCollection(root.allVesselCategories,true,0);
    	cbxClassOut.listIndex := 1;
    	cbxClassOut.text := cbxClassOut.itemText[cbxClassOut.listIndex];
    endif;

    // Modified by Russell 06/04/99
    // --------------------------------------------------------------------
    // Set default voyage number to invalid
 	tbxShipVoyageCode.text := app.getErrorString(ShipVoyageCodeInvalid);
 	// --------------------------------------------------------------------
	

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDelayTable" id="404f905f-702b-449b-b9ad-8a0b1ada1b42">
        <source>loadDelayTable();
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	voyageDelay: CMIF_HMS_VoyageDelay;
	str		:	String;
begin
	// clear the table
	self.tblDelays.rows := self.tblDelays.fixedRows;
	
	// load the tableSet enteries in
	if self.myCurrentWorkingVoyage &lt;&gt; null then
		foreach voyageDelay in self.myCurrentWorkingVoyage.allCMIFVoyageDelays do
			str := voyageDelay.getAttributeStringForDefArray(self.tblDelays.allTblDataEntRows);
			self.tblDelays.addItemObject(voyageDelay, str);
		endforeach;
	endif;
	self.setDelayButtonState();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadEditVoyage" id="de285a6e-fa38-4c4e-a3e3-47ccfafab7f8">
        <updating/>
        <source>loadEditVoyage() updating;

vars
 	shipPosn:	Integer;
 	cbxPosn:	Integer;
 	posn:		Integer;
 	cargo:    	CM_Commodity;
 	stevedore:	CM_Stevedore;
	arrivedLocal,
	departedLocal: TimeStamp;
begin
	// Notify controller that a voyage is being added or edited - delay any database updates until user finishes this action
	self.myViewController.set_AddEditVoyageActiveState(true);

	// Disable apply button until the user makes a change to the data
	self.enableDisableApplyBtn(false);

	// Clone voyage and its movements
	if self.myCurrentWorkingVoyage.myClone = null then
		self.myCurrentWorkingVoyage.createClone();
		self.setMyCurrentWorkingVoyage(self.myCurrentWorkingVoyage.myClone);
	endif;
	self.mode := self.Mode_Update;	

	// Load details for self.myCurrentWorkingVoyage
	// --------------------------------------------------------------------------------------
	self.tbxVoyageCode.text := self.myCurrentWorkingVoyage.code;
	self.cmbVessel.listIndex := self.cmbVessel.findObject(self.myCurrentVessel);

	if self.myCurrentWorkingVoyage.arrivedDT.String &lt;&gt; "null" then
		arrivedLocal := self.systemToLocalTime(self.myCurrentWorkingVoyage.arrivedDT);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
		self.txtDateArrival.setDate(arrivedLocal.date);
		self.txtTimeArrival.setTime(arrivedLocal.time);
	endif;
	if self.myCurrentWorkingVoyage.departedDT.String &lt;&gt; "null" then
		departedLocal := self.systemToLocalTime(self.myCurrentWorkingVoyage.departedDT);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
		self.txtDateDepart.setDate(departedLocal.date);
		self.txtTimeDepart.setTime(departedLocal.time);
	endif;

	// Disable arrival and departure date/time editing on voyage details form
	// if arrival and departure have already created
	if self.myCurrentWorkingVoyage.allClonedMovements.size &gt; 0 then
		//Enable movement maintenance.
		self.enableMoveMaint();
	endif;

	// Set port arriving from
	if self.myCurrentWorkingVoyage.ofPortFrom &lt;&gt; null then
		//self.cbxPortFrom.listIndex := self.cbxPortFrom.findObject(self.myCurrentWorkingVoyage.ofPortFrom);
		self.cbxPortFrom.setObject(self.myCurrentWorkingVoyage.ofPortFrom);
	endif;

	// Set port departing to
	if self.myCurrentWorkingVoyage.ofPortTo &lt;&gt; null then
		//self.cbxPortTo.listIndex := self.cbxPortTo.findObject(self.myCurrentWorkingVoyage.ofPortTo);
		self.cbxPortTo.setObject(self.myCurrentWorkingVoyage.ofPortTo);
	endif;

	// Modified by Russell 25/05/99
    // -------------------------------------------
    // Load comments
	self.tbxComments.text := self.myCurrentWorkingVoyage.shortComment;
    // -------------------------------------------

    // Load movements table
    self.loadMovementTable();

    // Load ship summary table
	self.loadSummaryTbl();

	// Load delay table
	self.loadDelayTable();

	self.loadPreferredBerthList();

	// Set class in 
	if self.myCurrentWorkingVoyage.ofClassIn &lt;&gt; null then
		self.cbxClassIn.listIndex := self.cbxClassIn.findObject(self.myCurrentWorkingVoyage.ofClassIn);
	endif;

	// Set class out 
	if self.myCurrentWorkingVoyage.ofClassOut &lt;&gt; null then
		self.cbxClassOut.listIndex := self.cbxClassOut.findObject(self.myCurrentWorkingVoyage.ofClassOut);
	endif;

	// Set discharge cargo
	foreach cargo in self.myCurrentWorkingVoyage.allCargoDischarge do
		posn := lbxAllCargoDis.findObject(cargo);
		if posn &gt; 0 then
			lbxAllCargoDis.listIndex := posn;
			// Add this cargo to the discharge list
			lbxAllCargoDis.dblClick(lbxAllCargoDis);
		endif;
	endforeach;	

	// Set load cargo
	foreach cargo in self.myCurrentWorkingVoyage.allCargoLoad do
		posn := lbxAllCargoLoad.findObject(cargo);
		if posn &gt; 0 then
			lbxAllCargoLoad.listIndex := posn;
			// Add this cargo to the load list
			lbxAllCargoLoad.dblClick(lbxAllCargoLoad);
		endif;
	endforeach;	

	// Modified by Russell 04/05/99
	// ----------------------------------------------------------------
	// Set discharge stevedore
	foreach stevedore in self.myCurrentWorkingVoyage.allStevedoresDischarge do
		posn := lbxAllSteveDis.findObject(stevedore);
		if posn &gt; 0 then
			lbxAllSteveDis.listIndex := posn;
			// Add this stevedore to the discharge list
			lbxAllSteveDis.dblClick(lbxAllSteveDis);
		endif;
	endforeach;	

	// Set load stevedore
	foreach stevedore in self.myCurrentWorkingVoyage.allStevedoresLoad do
		posn := lbxAllSteveLoad.findObject(stevedore);
		if posn &gt; 0 then
			lbxAllSteveLoad.listIndex := posn;
			// Add this stevedore to the load list
			lbxAllSteveLoad.dblClick(lbxAllSteveLoad);
		endif;
	endforeach;	

 	// Display voyage number if vessel and voyage arrival date have not
 	// changed from the values that are saved in the database
 	if self.myCurrentWorkingVoyage.ofPermanentVoyage &lt;&gt; null then
 		if self.myCurrentVessel &lt;&gt; null
 		and self.myCurrentWorkingVoyage.ofPermanentVoyage.arrivedDT = self.myCurrentWorkingVoyage.arrivedDT then
 			// Arrived DT and vessel have not changed for the voyage, Calc voyage number
 			self.tbxShipVoyageCode.text := self.myHarbour.getVesselVisitCountStr(self.myCurrentVessel.code, self.myCurrentWorkingVoyage.arrivedDT);
 		else
 			// Arrived DT or vessel have changed for the voyage, Voyage number is no longer valid
 			self.tbxShipVoyageCode.text := app.getErrorString(ShipVoyageCodeInvalid);
 		endif;
		self.cmbVessel.enabled := false;
 	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadMovementTable" id="cfd9b1d7-037f-493b-ba8d-e7b14c3cbbc6">
        <source>loadMovementTable();
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	workingMovement:		CMIF_HMS_WorkingMovement;
	count:					Integer;
	loadDefault:			Boolean;
begin
	// Load New Movements Table
    if self.myCurrentWorkingVoyage.ofClonedVoyage = null then
    	// New ADDED voyage - do not display default movements
 		self.tblMovements.setCurrentVoyage(null);
 		self.tblMovements.ofViewController := self.myViewController;
 		self.tblMovements.showAllVoyages := false;
 		self.tblMovements.loadFullTable(self.colorRow1, self.colorRow2);
 	else
 		// Edited movement
 		self.tblMovements.setCurrentVoyage(self.myCurrentWorkingVoyage);
 		self.tblMovements.ofViewController := self.myViewController;
 		self.tblMovements.showAllVoyages := false;
 		self.tblMovements.loadFullTable(self.colorRow1, self.colorRow2);
 	endif;
	if self.tblMovements.rows &gt; self.tblMovements.fixedRows then
		self.tblMovements.row := self.tblMovements.fixedRows+1;
		self.tblMovements.rowColumnChg(self.tblMovements);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadPreferredBerthList" id="3223348a-343d-47be-a085-c894289c9b62">
        <source>loadPreferredBerthList();

vars
	cmifMovement:	CMIF_HMS_WorkingMovement;
 	ship:			CM_Vessel;
 	arrivalBerth:	HMS_Berth;
 	posnInList:		Integer;
 	posnInPrefList:	Integer;
 	berthPref:		HMS_BerthPreference;
 	tmpData:		HMS_VesselDataHarbour;
begin
	self.cbxPrefBerth.clear();
	if self.myHarbour = null then
		return;
	endif;
	// This method loads the preferred berth list for the selected ship
	// Load berth collections (preferred and other)
	ship := self.myCurrentVessel;
	
	if ship &lt;&gt; null then
		if ship.myHMSVesselData &lt;&gt; null then
	 		tmpData := ship.myHMSVesselData.allVesselDataForHarbour[self.myHarbour];
		 	if tmpData &lt;&gt; null then	
				self.cbxPrefBerth.listCollection(tmpData.allBerthPrefByOrder,true,0);
			endif;
		endif;
	elseif self.myCurrentWorkingVoyage &lt;&gt; null then
		self.cbxPrefBerth.listCollection(self.myCurrentWorkingVoyage.myHMSVoyageData.allBerthPreferencesByName, true, 0);				
	endif;
	
	// Set default to first in list
	if cbxPrefBerth.listCount&gt;0 then
		cbxPrefBerth.listIndex:=1;
		cbxPrefBerth.text:=cbxPrefBerth.itemText[cbxPrefBerth.listIndex];
	endif;

	cbxOtherBerth.listCollection(self.myHarbour.allBerths,true,0);
	// Set default to first in list
	if cbxOtherBerth.listCount &gt; 0 then
		cbxOtherBerth.listIndex := 1;
		cbxOtherBerth.text := cbxOtherBerth.itemText[cbxOtherBerth.listIndex];
	endif;

	// Get arrival berth
	//arrivalBerth:=selectedVoyage.allClonedMovements.first.myBerth;
	if myCurrentWorkingVoyage &lt;&gt; null then	
		cmifMovement := myCurrentWorkingVoyage.allClonedMovements.first.CMIF_HMS_WorkingMovement;
		if cmifMovement &lt;&gt; null then
			arrivalBerth := cmifMovement.myBerth;
		endif;
	endif;

	// Set to arrival berth
	if arrivalBerth &lt;&gt; null then
		posnInList:=cbxOtherBerth.findObject(arrivalBerth);
	endif;

	if posnInList&lt;1 then
		// arrivalBerth not in otherberth list - assume to be preferred berth
		if tmpData &lt;&gt; null then
			if tmpData.allBerthPrefByName.size &gt; 0 then
				berthPref := tmpData.allBerthPrefByName.getAtKey(arrivalBerth.description);
			endif;
			
			if berthPref=null then
				// Preferred berth not found - set to first berth in other berth list (which is default) 
			else
				// Select preferred berth
				posnInPrefList:=cbxPrefBerth.findObject(berthPref);
				if posnInPrefList&gt;0 then
					// Select this berth
					optPrefBerth.value:=true;
					optOtherBerth.value:=false;
					cbxOtherBerth.enabled:=false;
					cbxPrefBerth.enabled:=true;
					cbxPrefBerth.listIndex:=posnInPrefList;
					cbxPrefBerth.text:=cbxPrefBerth.itemText[cbxPrefBerth.listIndex];
				endif;
			endif;
		endif;
	else
		// Set arrival berth in other berth list  
		cbxOtherBerth.listIndex:=posnInList;
		cbxOtherBerth.text:=cbxOtherBerth.itemText[cbxOtherBerth.listIndex];
		optPrefBerth.value:=false;
		cbxPrefBerth.enabled:=false;
		optOtherBerth.value:=true;
		cbxOtherBerth.enabled:=true;		
	endif;


    // Disable the ability to select a preferred berth is the user is not adding a new voyage
	if myCurrentWorkingVoyage &lt;&gt; null then
		if myCurrentWorkingVoyage.ofClonedVoyage&lt;&gt;null then
			// Voyage is being edited - Disable preferred berth selection
			// This can be done by editing the arrvial movement
			optPrefBerth.enabled:=false;
			cbxPrefBerth.enabled:=false;
			optOtherBerth.enabled:=false;
			cbxOtherBerth.enabled:=false;
		endif;	
	else
		// For new voyage - set preferred berth and other berth defaults to first on
		// the list

		//AJA 17/10/00: No, they take the value of the default arrival and departure berths
		/*if cbxPrefBerth.listCount&gt;0 then
			cbxPrefBerth.listIndex:=1;
			cbxPrefBerth.text:=cbxPrefBerth.itemText[cbxPrefBerth.listIndex];
			optPrefBerth.enabled:=true;
			optPrefBerth.value:=true;
			cbxPrefBerth.enabled:=true;
			optOtherBerth.enabled:=true;
			cbxOtherBerth.enabled:=false;	
		endif;
		if cbxOtherBerth.listCount&gt;0 then
			cbxOtherBerth.listIndex:=1;
			cbxOtherBerth.text:=cbxOtherBerth.itemText[cbxOtherBerth.listIndex];
		endif; */

	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadSummaryTbl" id="bc095ea2-6119-4e48-a6ea-cb156c7fd8da">
        <updating/>
        <source>loadSummaryTbl() updating;

// CCMS 1020 Remove unnessesary decimal points (i.e. if .00) with cnEcStripDecimalZeros
vars
	tmpVesselData :	HMS_VesselData;
	tmpData : HMS_VesselDataHarbour;
begin

	// Set enteries in "Values" column
	if self.myCurrentVessel &lt;&gt; null then
		tmpVesselData := self.myCurrentVessel.myHMSVesselData;
		if tmpVesselData &lt;&gt; null
		and self.myHarbour &lt;&gt; null then
		 	tmpData := tmpVesselData.allVesselDataForHarbour[self.myHarbour];						
		endif;
		picShipBitmapSmmy.picture := self.myCurrentVessel.bitmap;			
	else
		picShipBitmapSmmy.picture := null;			
	endif;

	if self.tblSummary.column &lt; 2 then
		self.initSummaryTable();
	endif;
		
	tblSummary.column:=2;
	// Load ship name
	tblSummary.row:=1;
	if tmpVesselData &lt;&gt; null then
		tblSummary.text := self.myCurrentVessel.name.trimBlanks;
	else
		tblSummary.text := ' ';
	endif;

	// Load ship class
	tblSummary.row := 2;
	if tmpVesselData = null then
		tblSummary.text := app.getErrorString(NoneSelected);	
	elseif tmpData &lt;&gt; null then
		if tmpData.myVesselCategoryIn &lt;&gt; null then
			tblSummary.text := tmpData.myVesselCategoryIn.description;
		else
			tblSummary.text := app.getErrorString(NoneSelected);		
		endif;
	else
		tblSummary.text := app.getErrorString(NoneSelected);
	endif;

	// Load ship type
	tblSummary.row := 3;
	if tmpVesselData &lt;&gt; null then
		if tmpVesselData.myVesselType &lt;&gt; null then
			tblSummary.text := tmpVesselData.myVesselType.description;
		else
			tblSummary.text := app.getErrorString(NoneSelected);		
		endif;
	else
		tblSummary.text := app.getErrorString(NoneSelected);
	endif;

	// Load LOA 
	tblSummary.row := 4;
	if tmpVesselData &lt;&gt; null then
		tblSummary.text := tmpVesselData.dim_LengthOverall.rounded().asStringJMT &amp; "m";
	else
		tblSummary.text := "m";
	endif;	

	// Load GRT 
	tblSummary.row:=5;
	if tmpVesselData &lt;&gt; null then
		tblSummary.text := tmpVesselData.dim_GrossRegTonnes.String &amp; "T";
	else
		tblSummary.text := "T";
	endif;	

	// Load preferred berth
	tblSummary.row:=6;
	if tmpData &lt;&gt; null then 
		if tmpData.allBerthPrefByOrder.size&gt;0 then
			tblSummary.text := tmpData.allBerthPrefByOrder[1].berthName;
		else
			tblSummary.text := app.getErrorString(NoneSelected);
		endif;
	else
		tblSummary.text := app.getErrorString(NoneSelected);
	endif;

	// Load shipping line			
	tblSummary.row := 7;
	if tmpVesselData = null then
		tblSummary.text := app.getErrorString(NoneSelected);	
	elseif tmpVesselData.myDefaultShippingLine &lt;&gt; null then
		tblSummary.text := tmpVesselData.myDefaultShippingLine.description;
	else 
		tblSummary.text := app.getErrorString(NoneSelected);
	endif;

	// Load shippingLine contact
	tblSummary.row := 8;
	if tmpVesselData = null then
		tblSummary.text := app.getErrorString(NoneSelected);	
	elseif tmpData &lt;&gt; null then
		if tmpData.myShippingAgent &lt;&gt; null then
			tblSummary.text := tmpData.myShippingAgent.description;
		else
			tblSummary.text := app.getErrorString(NoneSelected);		
		endif;
	else 
		tblSummary.text := app.getErrorString(NoneSelected);
	endif;

	// Load tidal class
	tblSummary.row:=9;
	if tmpVesselData = null then
		tblSummary.text := app.getErrorString(NoneSelected);	
	elseif tmpData &lt;&gt; null then 
		if tmpData.myTidalClassDeparture &lt;&gt; null
		and tmpData.myTidalClassArrival &lt;&gt; null then 
			tblSummary.text := "Arrive [" &amp; tmpData.myTidalClassArrival.description &amp; "]; Depart [" &amp; tmpData.myTidalClassDeparture.description &amp; "]";
		else
		 	tblSummary.text := app.getErrorString(NoneSelected);		
		endif;
	else
	 	tblSummary.text := app.getErrorString(NoneSelected);
	endif;
	// ---------------------------------------------------------
	
end;</source>
    </JadeMethod>
