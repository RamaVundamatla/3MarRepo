    <JadeMethod name="tCamECNMOTIntMarineRec" id="0a269f4f-ec6c-4c03-9e11-9734df9440d3">
        <source>tCamECNMOTIntMarineRec();
// cnwrs1
// par 27653
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//17/06/2016    cnwma1  TFS# 2159:CPL - Wrong Header for CODECO D.95B
constants
	VoyageName		= 'VYPAR27653';				// all upper case!
	BoatName		= 'VSPAR27653';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
//	BlockStackName	= 'BS27653';
	CamGroup = "P27653";
	CamProtocol = "PAR27653";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
	subTerminalDepot : CM_SubTerminal;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	create objArray transient;
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR27653",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveMarineIntern), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Marine_Int then
			subTerminalDepot := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReceiveMarineIntern.setPropertyValue(CM_SubTermReceiveMarineIntern::mySubTerminal.name, subTerminalDepot);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalFrom);
	commitTransaction;
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["MOT-ECN CODECO"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNA:+.? '");
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR27653+1++UTOP:172:20+++:146::VSPAR27653'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+UTOP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("GID+1'");
	strArray.add("FTX+AAA+++General'");
	strArray.add("PIA+5+GENL:ZZZ'");
	strArray.add("SGP+PARC1230001'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR27653'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("TDT+1'");
	strArray.add("LOC+7+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:172:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+20+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamGroup" id="9348934d-b345-42b5-bc3a-d83787fc4d8d">
        <source>tCamGroup();
/*

Purpose:			

Date		Who		Reason
24/04/2014	cnwma1	Initial creation

*/
constants

	CamGroup ="UT_CAMG";
vars
	camGroup : CM_CamGroup;
		operatorDict : CM_OperatorByCodeDict;
		freightForwarders : CM_ConsigneeConsignorSet;
		operator : CM_Operator;
	
begin
	//Delete Cam Group
	self.deleteCamGroup(CamGroup);
	
	
	operator := self.getOperator("APL");
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	
	// Add Cam Group
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	
	// Update SubTerminal
	self.opts.purge();
	self.opts.addAssoc("CamDesc", "UT_CAMGUP");
	self.updateCamGroup(camGroup);
	
epilog
	delete operatorDict;
	delete freightForwarders;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCamMaerskStockReport" id="d010e447-4c6f-46cc-a1ff-75822a9be595">
        <source>tCamMaerskStockReport();
//06 Aug 2012	cnwrs1	Par 30155
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR30155';				// all upper case!
	BoatName		= 'VSPAR30155';
	ContainerName	= 'PARC3015502';
	TestOperator	= 'MSL';
	BlockStackName	= 'BS30155';
	CamGroup = "P30155";
	CamProtocol = "PAR30155";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
//	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	tiUpdateCntrlr : CMIF_TIUpdateController;
	lRegisteredCargoTypes : IntegerArray;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;

	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2232",					// ISOType is not needed
										"REEF",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	create tiUpdateCntrlr transient;
	tiUpdateCntrlr.userCode := app.getMyUserCode();
	beginTransaction;
	container.setTemperature(-21.1);
	container.setTotalWeight(40, tiUpdateCntrlr, app.myPassport);
	commitTransaction;
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, bs);//voyage.myShipBlockStack);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Stock Report"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	endDateTime := startDateTime.addMinutes(1);
	beginTransaction;
	camProtocol.setPropertyValue(CM_CamProtocol::tempLeadingZerosNoDecimal.name, false);
	commitTransaction;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		if tempStr[1:11] = ContainerName then
			self.assertEqual(tempStr[1:60], "PARC301550222327         NN               -21C   40EVSPVYPA ''"[1:60]);	// an Any cant handle a string with ''
		endif;
	endforeach;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete tiUpdateCntrlr;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamShipMarineRec" id="e7269f3d-eeac-4dc0-bbe0-15160ed2df16">
        <source>tCamShipMarineRec();
// cnwrs1
// par 30739
//22 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//08/09/2016    cnwma1	TFS #2596:PNL- Delay on CODECO messages not working
// 14 Dec 2016	cnwrs1	TFS #3086 Delay for Codeco not working correctly
constants
	VoyageName		= 'VYPAR30739';				// all upper case!
	BoatName		= 'VSPAR30739';
	ContainerName	= 'PARC1230739';
	TestOperator	= 'UTOP';
//	BlockStackName	= 'BS27653';
	CamGroup = "P30739";
	CamProtocolCodeco = "PAR30739";
	CamProtocolCoarri = "PAR30739_Coarri";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocolCodeco : CM_CamProtocol;
	camProtocolCodecoDesc : String;
	camProtocolCoarri : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	subTerminal : CM_SubTerminal;
//	subTerminalDepot : CM_SubTerminal;
	subTerminalMarine : CM_SubTerminal;
//	strArray : StringArray;
	dtStr : String;
	dtCodeco : TimeStamp;
	dtCoarri : TimeStamp;
	camProtocolDescArray : ObjectArray;
	object : Object;
	dir : String;
	assoc :CM_Association;
	int : Integer;
	theLines : HugeStringArray;
begin
	create theLines transient;
//******************************************************

//******************************************************
	assoc := self.getProfileSetting(UT_Profile.P_CAMS_DIRECTORY);
	if assoc &lt;&gt; null then
		dir := assoc.asString&amp;'\transfer';
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	create objArray transient;
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_IMPORT,	// import not export
										"PAR30739",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_SubTermReceiveMarineShip), null);
	objArray.add(transObj);
	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal.type =  SubTermType_Marine_Int then
			subTerminalMarine := subTerminal;
			break;
		endif;
	endforeach;
	beginTransaction;
	transObj.CM_SubTermReceiveMarineShip.setPropertyValue(CM_SubTermReceiveMarineShip::mySubTerminal.name, subTerminalMarine);
//	transObj.CM_SubTermReceiveDepotIntern.setPropertyValue(CM_SubTermReceiveDepotIntern::mySubTerminalFrom.name, subTerminalDepot);
	commitTransaction;
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_ReceiveShip), null);
	objArray.add(transObj);
	
	create camProtocolDescArray transient;
	CM_CamCODECODesc.allInstances(camProtocolDescArray, 0, true);
	foreach object in camProtocolDescArray do
		camProtocolDesc := object.CM_CamCODECODesc;
		camProtocolCodecoDesc := (CamProtocolCodeco&amp;camProtocolDesc.name).removeString('/').removeString('\').trimBlanks[1:30];
		self.deleteCamProtocol(camProtocolCodecoDesc);
	endforeach;
	self.deleteCamProtocol(CamProtocolCoarri);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	foreach object in camProtocolDescArray do
		camProtocolDesc := object.CM_CamCODECODesc;
		camProtocolDesc := object.CM_CamCODECODesc;
		camProtocolCodecoDesc := (CamProtocolCodeco&amp;camProtocolDesc.name).removeString('/').removeString('\').trimBlanks[1:30];
		camProtocolCodeco := self.getCamProtocol(camProtocolCodecoDesc);
		self.assertIsDeleted(camProtocolCodeco);
	endforeach;
	camProtocolCoarri := self.getCamProtocol(CamProtocolCoarri);
	self.assertIsDeleted(camProtocolCoarri);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	// 
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Hapag COARRI"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocolCoarri := self.addCamProtocol(CamProtocolCoarri, CamProtocolCoarri, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, "z", "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, true, true, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', dir, '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, false, false, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocolCoarri, tempStr);
	self.assertNotNull(camProtocolCoarri);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocolCoarri);
	camTaskHistory := camProtocolCoarri.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do

		if tempStr[1:6] = "DTM+7:" then
			dtCoarri.setFromYYYYMMDDHHmm(tempStr[7:12]);

		endif;
	endforeach;
	
	registeredTransactions.clear;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineShip).asStringJMT);
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	foreach object in camProtocolDescArray do
		camProtocolDesc := object.CM_CamCODECODesc;
		camProtocolCodecoDesc := (CamProtocolCodeco&amp;camProtocolDesc.name).removeString('/').removeString('\').trimBlanks[1:30];

		camProtocolCodeco := self.addCamProtocol(camProtocolCodecoDesc, camProtocolCodecoDesc, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
										   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
										   false, 1, false, scheduleTimes, true, true, false, false, false, false, false, false, false, false, false, false, 
										   false, false, false, false, false, false, false, false, false, false, false, false,
										   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, false, true, true, false, false, false, false, false, true, 
										   allPackAreas, null, null, lRegisteredCargoTypes);
		tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
		self.assertNotNullMsg(camProtocolCodeco, tempStr);
		self.assertNotNull(camProtocolCodeco);
	
//		endDateTime := endDateTime.addMinutes(1);
		self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocolCodeco);
		camTaskHistory := camProtocolCodeco.taskHistoryByProtocolSeq.first;
		self.assertNotNull(camTaskHistory);
		theLines.clear();
		camTaskHistory.rawDataToHSA(theLines);
		foreach tempStr in theLines do

			if tempStr[1:6] = "DTM+7:" then
				dtCodeco.setFromYYYYMMDDHHmm(tempStr[7:12]);

				if camProtocolCodecoDesc = "PAR30739PIL Codeco" then
					dtCodeco := dtCodeco.utcToLocalTime;
					dtCodeco := dtCodeco.addMinutes(-2);
				elseif camProtocolCodecoDesc = "PAR30739PON Codeco" then
//					dtCodeco := dtCodeco.addMinutes(0);
				else
					dtCodeco := dtCodeco.addMinutes(-2);
				endif;
			endif;
		endforeach;
//		dtCodeco := dtCodeco.addMinutes(-2);
		//self.assertEqualMsg(dtCoarri, dtCodeco, ' For '&amp;camProtocolCodecoDesc);  //cnwma1 TFS #2596 08/09/2016
		//self.assertEqualMsg(dtCoarri, dtCodeco.addMinutes(-1), ' For '&amp;camProtocolCodecoDesc); //cnwma1 TFS #2596 08/09/2016
		self.assertEqualMsg(dtCoarri, dtCodeco, ' For '&amp;camProtocolCodecoDesc&amp;' dtCoarri='&amp;dtCoarri.String&amp;' dtCodeco='&amp;dtCodeco.String&amp;' '&amp;camProtocolCodecoDesc); //cnwrs1
	endforeach;
/*	create strArray transient;
	strArray.add("UNA:+.? '");
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+VYPAR27653+1++UTOP:172:20+++:146::VSPAR27653'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+UTOP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("GID+1'");
	strArray.add("FTX+AAA+++General'");
	strArray.add("PIA+5+GENL:ZZZ'");
	strArray.add("SGP+PARC1230001'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR27653'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("TDT+1'");
	strArray.add("LOC+7+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:172:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+20+1'");
	strArray.add("UNZ+1+0'");
	foreach tempStr in camTaskHistory.fileData do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;*/
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
//	delete strArray;
	delete camProtocolDescArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamTrainArriveDepartEvents" id="318632ae-d464-426a-992d-0750cffc4192">
        <source>tCamTrainArriveDepartEvents();
//22 Apr 2014 cnwrs1 Par 33035-33593
//Purpose:	To verify that Arrival and Departure transactions are proceced by cams train event 
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
constants
	TrainCode : String = "UT-TR33593";
	WagonCode1 : String = "JX_33593";
	WagonClassCode : String = "JX";
	WagonMasterCode1 : String = "UT_WM_J4";
	RailAreaId : String = "UT33593";
	EventName : String = "UT_33593";
	CamGroup = "P33593";
	CamProtocol = "PAR33593";
	TestOperator	= 'MSL';
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	train: CM_Train;
	pxyTrain : CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	eventType : CM_EventType;
	trans : CM_EventTransaction;
	foundTransaction : Boolean;
	now : TimeStamp;
	railLine : CM_RailLine;
	trainSet : CM_TrainSet;
	foundArrival,
	foundDeparture	: Boolean;
	postdatedTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	operatorDict : CM_OperatorByCodeDict;
	operator : CM_Operator;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	tempStr	: String;
	daysToLookBack : Integer;
	findArrival : Boolean;
	theLines : HugeStringArray;
begin
	create theLines transient;
	///daysToLookBack 	:= self.getTerminal.getConfig(CamsDaysToLookBack).Integer;
	startDateTime := app.actualTimeServer;
//	startDateTime := startDateTime.addMinutes(-1);
	operator := self.getOperator(TestOperator);

	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	train := self.getTrain(TrainCode, null);
	if train &lt;&gt; null then
		// ****** DELETE EVERYTHING FROM LAST TEST
		self.deleteTrain(TrainCode,null);
		self.deleteTrain(TrainCode,null);
	endif;
	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	self.deleteRailArea(RailAreaId);

	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	railLine := railArea.allRailLinesByIndex.first;  //hope this works
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** CREATE MASTER WAGON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	// ****** ADD AND PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	//not going to bother with any tracked items on the wagon.  the train is just coming in and going out.
	
	// ***** ATTACH WAGON TO TRAIN
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	self.assertNotNullMsg(wagon,"Couldn't create a wagon");
	// ****** LETS ARRIVE
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	now := app.actualTimeServer;
	pxyTrain.setProxyDetails(now);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
//	create trainSet transient;  //everyone loves train sets.
//	trainSet.add(train);
//	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  //lets use the transaction thing
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	postdatedTime := postdatedTime.addMinutes(-4);
	self.updateTrainEvent(train, EVT_TrainArrive, postdatedTime);	//test event update
	
	//ok.  time to check Arrival and Departures.
	foreach trans in train.allTransactions do
		if trans.type = EVT_TrainArrive then

			if foundDeparture = false then
				foundArrival := true;
			else
				assertTrueMsg(false,"Arrival Transanction found but Departure has already occured.");
			endif;
		elseif trans.type = EVT_TrainDepart then
			if foundArrival = true then
				foundDeparture := true;
			else
				assertTrueMsg(false,"Departure Transanction found but Arrival has not occurred.");
			endif;
		endif;
	endforeach;
	
	self.assertTrueMsg(foundArrival,"No Arrival Transanction found on train");
//	self.assertTrueMsg(foundDeparture,"No Departure Transanction found on train");
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
//	beginTransaction;
//	self.getTerminal.setConfig(CamsDaysToLookBack, 1);
//	commitTransaction;
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainArrive]);
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["User Defined Event JRW-Report"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, true, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, 'csv', 'c:\cams\gmast\transfer', 'CM_TrainArrives', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	endDateTime := startDateTime.addMinutes(1);
	beginTransaction;
	camProtocol.setPropertyValue(CM_CamProtocol::tempLeadingZerosNoDecimal.name, false);
	commitTransaction;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
//	foreach tempStr in camTaskHistory.fileData do
//	endforeach;
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
//		write tempStr;
		if tempStr[1:10] = TrainCode then
			self.assertEqual(tempStr[26:13], "Train Arrived");	// an Any cant handle a string with ''
			findArrival := true;
		elseif tempStr[2:5] = "Train" then //header
		elseif tempStr[3:5] = "Train" then //header unicode
		else
			self.assertEqual(tempStr[1:5], "This is invalid");	// an Any cant handle a string with ''
		endif;
	endforeach;
	self.assertEqual(findArrival, true);	// an Any cant handle a string with ''
	
	//finished clean up
	train := self.getTrain(TrainCode, null);
	if train &lt;&gt; null then
		wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
		if wagonClass &lt;&gt; null then
			self.deleteWagonClassAndWagons(wagonClass);
		endif;	
		self.deleteTrain(TrainCode,null);
		self.deleteTrain(TrainCode,null);
	endif;
	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	self.deleteRailArea(RailAreaId);
	
epilog
	///beginTransaction;
	///self.getTerminal.setConfig(CamsDaysToLookBack, daysToLookBack);
	///commitTransaction;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete pxyMaster;
	delete trainSet;
	delete pxyTrain;
	delete allTrackedItems;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamsJRWwithnonUTFChar" id="2a17b9e9-4f86-4d86-b4b5-1b0035e54d50">
        <source>tCamsJRWwithnonUTFChar();
/*

Date		Who		Reason
27 July 2016	cnwer1	Initial creation TFS 2434
31 Mar 2017  cnwma1  TFS #3756:MSL - Fw: CAMS (1035). (String too long)

*/

vars
	camFile : CM_CamFileJRW;
	fileData : String;
	f  		: File;
	lines : HugeStringArray;
	line : String;
	i : Integer;
begin
	fileData:='VER,,Moved,CMA,ECMU4695599,42G1,1,"ISO Container",,24/07/2016,19:33:45,4030813,Yes,,"De: 161202 500282","A: CTA_G8 1",,161202,"CMA CGM JAMAICA",,1515955,CTA_G8,IMP,303182,,
VER,,Unplanned,CMA,ECMU4695599,42G1,1,"ISO Container",,24/07/2016,19:33:46,4030813,,,"De: CTA_G8 1","A: Nowhere",,161202,"CMA CGM JAMAICA",,1515955,CTA_G8,IMP,303182,,
VER,"CARRILES TMU","Moved - Picked Up",CMA,SEGU5214534,45G1,1,"ISO Container",,24/07/2016,19:33:06,2011231,Yes,,"De: T083","A: G017",,161202,"CMA CGM JAMAICA",,1515933,Ń,IMP,6439307,,
VER,"CARRILES TMU","Moved - Set Down",CMA,SEGU5214534,45G1,1,"ISO Container",,24/07/2016,19:33:20,2011231,Yes,,"De: G017","A: Ń1003 2",,161202,"CMA CGM JAMAICA",,1515933,Ń,IMP,6439307,,
VER,,"Moved - Picked Up",CMA,UESU8533581,45G1,1,"ISO Container",,24/07/2016,19:33:47,4030938,Yes,,"De: CTA_G8 1","A: H018",,161202,"CMA CGM JAMAICA",,1516097,,IMP,113256,,';
	create f transient;
	f.fileName:="C:\Temp\" &amp; method.name &amp; ".csv";
	f.mode := File.Mode_Output;
	
	f.writeString(fileData);
	f.close;
	
	create camFile transient;
	camFile.setJRWFilename(f.fileName);
	camFile.updateFileContentFromFile;
	
	/*self.assertEqual(camFile.allFileContent.size,5);  //31/03/2017 cnwma1 TFS #3756
	
	create lines transient;
	fileData := fileData.replaceString(CrLf, Cr);
	fileData := fileData.replaceString(Lf, Cr);
	fileData.getTokensForDelimiterHugeNoNul(Cr,lines);
	
	i:= 1;
	foreach line in camFile.allFileContent do
	
		self.assertEqual(line,lines[i]);
		i:=i+1;
	endforeach;
	*/
	//31/03/2017 cnwma1 TFS #3756
	create lines transient;  
	fileData := camFile.myFileDataStorageHeader.getDataAsBinary().String;
	fileData := fileData.replaceString(CrLf, Cr);
	fileData := fileData.replaceString(Lf, Cr);
	fileData.getTokensForDelimiterHugeNoNul(Cr,lines);
	self.assertEqual(lines.size,5);
epilog
	delete camFile;
	if f &lt;&gt; null then
		f.purge;
	endif;
	delete f;
	delete lines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tChestnutHillXML" id="289cda3f-2d60-4c8c-af5c-2d59037a616b">
        <updating/>
        <source>tChestnutHillXML() updating;
//
//19 May 2015	cnwrs1	Par36271 - Chestnut Hill truck release XML 
//
//17 Jun 2015	cnwrs1	Par36462 - not separating items by sub-type 
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	USER_DEF_NAME : String = "JMTInternalCargoOnSite";
	Cargo_Type = "CANNONBALL";
//	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOYCNUT';				
	BoatName		= 'UT_VESCNUT';
	PortName		= "NZAKL";
	BlockStackName	= 'BSCHESTNUT';
	CamGroup 		= "UT_CNUT";
	CamProtocol 	= "UT_CHESTNUTHILL";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
	TruckVehicle = "UTTRUCKCNUT";
	ReleaseReq = "Chestnut?Rel0123456789012345";
	Cargo1 = VoyageName&amp;'_CANB001';
	Cargo2 = VoyageName&amp;'_CANB002';
	Cargo3 = VoyageName&amp;'_CANB003';
	Cargo4 = VoyageName&amp;'_CANB004';
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
	vehicle : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
//	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TISet;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	gate : CM_Gate;
	releaseRequest	:CM_BulkRelease;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
begin
	create camEditTriggerFields transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
//	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	voyage := self.createVesselVoyage ( VoyageName, BoatName,operator);
	
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoOnSite&gt;
    &lt;AllCargoOnSite&gt;
    &lt;CargoOnSite&gt;
      &lt;site&gt;1&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Cannon Balls&lt;/cargoTypeDescr&gt;
	  &lt;product&gt;12POUNDER-12&lt;/product&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;Cargo1&amp;'&lt;/id&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
	  &lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;CargoOnSite&gt;
	  &lt;site&gt;1&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Cannon Balls&lt;/cargoTypeDescr&gt;
	  &lt;product&gt;12POUNDER-12&lt;/product&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;Cargo2&amp;'&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;CargoOnSite&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;1&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;product&gt;12POUNDER-6&lt;/product&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Cannon Balls&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;Cargo3&amp;'&lt;/id&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;CargoOnSite&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;1&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Cannon Balls&lt;/cargoTypeDescr&gt;
	  &lt;product&gt;12POUNDER-12&lt;/product&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
      &lt;id&gt;'&amp;Cargo4&amp;'&lt;/id&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
    &lt;/AllCargoOnSite&gt;
 &lt;/JMTInternalCargoOnSite&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	
	// Create the Receives
 	self.opts.addAssoc("CENum", "123456");
	create cargoItems transient;
	cargo1 := self.getTrackedItem(Cargo1);
	beginTransaction;
	cargo1.setCustomsEntryNumber("12345");
	commitTransaction;
	cargoItems.add(cargo1);
	cargo2 := self.getTrackedItem(Cargo2);
	beginTransaction;
	cargo2.setCustomsEntryNumber("12345");
	commitTransaction;
	cargoItems.add(cargo2);
	cargo3 := self.getTrackedItem(Cargo3);
	beginTransaction;
	cargo3.setCustomsEntryNumber("12345");
	commitTransaction;
	cargoItems.add(cargo3);
	cargo4 := self.getTrackedItem(Cargo4);
	beginTransaction;
	cargo4.setCustomsEntryNumber("12345");
	commitTransaction;
	cargoItems.add(cargo4);
	deleteVehicle(TruckVehicle);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("TotalRequested", 4);
	releaseRequest := self.addReleaseById(ReleaseReq, BR_TYPE_ROAD, cargoItems);
//	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", releaseRequest);
	self.gateOutPinRelease(releaseRequest.myPinNo.pinNo, TruckVehicle);
	vehicle := self.getVehicle(TruckVehicle);
	vvr := vehicle.visitRecords.first;
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Chestnut Hill Release XML"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.assertEqual(camTaskHistory.fileName, ReleaseReq.removeFileNamInvalidChars.toUpper &amp; ".xml"); //epr par 36867 7/9/15
	self.zOutput_ChestnutHillXML(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "Delivery");
epilog
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri213_BGMChange" id="96f0b068-29c3-4202-b6de-f1b32ba55d7f">
        <updating/>
        <source>tCoarri213_BGMChange()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Dec 2020 cnwma1  Bug 50555: GPHA - BGM+98 and BGM+270 not working in COARRI SMDG 213

*/

constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	VoyageName2				= 'UT_VOYAGE2';				
	ForeignVoyageCodeMSK2 	= 'MSK_VOYAGE2';
	ForeignVoyageCodeUTOP2 	= 'UTOP_VOYAGE2';
	BoatName				= 'UT_VESSEL';
	PortName				= "NZAKL";
	Bol1                    = 'BOLUTXT000001';
	Bol2                    = 'BOLUTXT000002';
	Bol3                    = 'BOLUTXT000003';
	Bol4                    = 'BOLUTXT000004';
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_213_COARRIBGMChange";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot	 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	voyage2 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; //jlgka1 TFS 44020
	controller 			: CMIF_TranshipTIController;
	isDoClearanceCheck : Boolean;
	voyageNames : StringArray;
	voyageArray : CM_VoyageArray;
	tiHazard : CM_TIHazard;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName1);
//	voyage1 := self.getVoyage(VoyageName1);
//	self.assertIsDeleted(voyage1);
//	voyage1 := self.createVesselVoyage(BoatName, VoyageName1, operatorMSK);
	
	create voyageNames transient;
	voyageNames.add(VoyageName1);
	voyageNames.add(VoyageName2);
	create voyageArray transient;
	self.createVesselVoyages( BoatName, voyageNames, operatorMSK, voyageArray );
	voyage1 := voyageArray[1];
	voyage2 := voyageArray[2];

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK2, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName2);
//	voyage2 := self.getVoyage(VoyageName2);
//	self.assertIsDeleted(voyage2);
//	voyage2 := self.createVesselVoyage(BoatName, VoyageName2, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003");
	container3.setSealNumShippers("SHIP003");
	container3.setSealNumVent("VENT003");
	container3.setBOL(Bol3);
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	container4.setBOL(Bol4);
	commitTransaction;
	
	//07 May 2020	NDL	TFS 49211 - Add multiple hazards with multiple dangerous goods codes to check for
	self.addTIHazard ( container4, '3', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('1169');
		tiHazard.allUNDGCodes.add ('1170');
		tiHazard.allUNDGCodes.add ('1993');
	commitTransaction;
	self.addTIHazard ( container4, '8', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('1824');
		tiHazard.allUNDGCodes.add ('3265');
		tiHazard.allUNDGCodes.add ('2491');
		tiHazard.allUNDGCodes.add ('3253');
		tiHazard.allUNDGCodes.add ('1791');
		tiHazard.allUNDGCodes.add ('1760');
		tiHazard.allUNDGCodes.add ('3267');
		tiHazard.allUNDGCodes.add ('3262');
		tiHazard.allUNDGCodes.add ('1823');
		tiHazard.allUNDGCodes.add ('2922');
	commitTransaction;
	self.addTIHazard ( container4, '9', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('3083');
	commitTransaction;
	self.assertTrueMsg( not container4.allTIHazards.isEmpty, "Container does not have hazards");
	
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	//
	// Make the Containers tranship
	//
	create controller transient;

//	container4 := self.getTrackedItemOnVoy(ContainerID4, VoyageName1);
	self.assertNotNull(container4);
	controller.allTrackedItems.add(container4);
	controller.myExportDestPort := app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort := app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage := voyage2;
	controller.remarks := "UT Tranship";
	// controller.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	self.assertEqualMsg(container4.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item:" &amp; container4.id &amp; " is not Tranship");
	self.assertEqualMsg(container4.myExportVoyage, voyage2, "TI:" &amp; container4.id &amp; " has wrong export voyage");
	self.assertEqualMsg(container4.myImportVoyage, voyage1, "TI:" &amp; container4.id &amp; " has wrong import voyage");
	self.assertEqualMsg(container4.myVoyage, voyage1, "TI:" &amp; container4.id &amp; " myVoyage reference is not the import voyage");

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	container1.setBOL(Bol1);
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	beginTransaction;
	container2.setBOL(Bol2);
	commitTransaction;
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
		
	self.moveAllCargo(voyage1);
	beginTransaction; // --&gt; TFS 47450 - add this seal *after* discharge/Receive-Ship - shouldn't be in output...
	container4.setSealNumVent("VENT999");
	commitTransaction; // &lt;-- TFS 47450
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, true);

	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG213", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	

	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri213_BGMChange);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
	delete controller;
	delete voyageNames;
	delete voyageArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri213_BGMChange4446" id="2e0fa5bf-e7c6-4dbb-8dbc-8a8b3d32a0d1">
        <updating/>
        <source>tCoarri213_BGMChange4446()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30Jan2023 	navsp1 	TFS ChangeRequest 56282: AAT - SMDG213 BGM Segment Config

*/

constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	VoyageName2				= 'UT_VOYAGE2';				
	ForeignVoyageCodeMSK2 	= 'MSK_VOYAGE2';
	ForeignVoyageCodeUTOP2 	= 'UTOP_VOYAGE2';
	BoatName				= 'UT_VESSEL';
	PortName				= "NZAKL";
	Bol1                    = 'BOLUTXT000001';
	Bol2                    = 'BOLUTXT000002';
	Bol3                    = 'BOLUTXT000003';
	Bol4                    = 'BOLUTXT000004';
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_213_COARRIBGMChange4446";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot	 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	voyage2 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; //jlgka1 TFS 44020
	controller 			: CMIF_TranshipTIController;
	isDoClearanceCheck : Boolean;
	voyageNames : StringArray;
	voyageArray : CM_VoyageArray;
	tiHazard : CM_TIHazard;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName1);
//	voyage1 := self.getVoyage(VoyageName1);
//	self.assertIsDeleted(voyage1);
//	voyage1 := self.createVesselVoyage(BoatName, VoyageName1, operatorMSK);
	
	create voyageNames transient;
	voyageNames.add(VoyageName1);
	voyageNames.add(VoyageName2);
	create voyageArray transient;
	self.createVesselVoyages( BoatName, voyageNames, operatorMSK, voyageArray );
	voyage1 := voyageArray[1];
	voyage2 := voyageArray[2];

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK2, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName2);
//	voyage2 := self.getVoyage(VoyageName2);
//	self.assertIsDeleted(voyage2);
//	voyage2 := self.createVesselVoyage(BoatName, VoyageName2, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003");
	container3.setSealNumShippers("SHIP003");
	container3.setSealNumVent("VENT003");
	container3.setBOL(Bol3);
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	container4.setBOL(Bol4);
	commitTransaction;
	
	//07 May 2020	NDL	TFS 49211 - Add multiple hazards with multiple dangerous goods codes to check for
	self.addTIHazard ( container4, '3', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('1169');
		tiHazard.allUNDGCodes.add ('1170');
		tiHazard.allUNDGCodes.add ('1993');
	commitTransaction;
	self.addTIHazard ( container4, '8', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('1824');
		tiHazard.allUNDGCodes.add ('3265');
		tiHazard.allUNDGCodes.add ('2491');
		tiHazard.allUNDGCodes.add ('3253');
		tiHazard.allUNDGCodes.add ('1791');
		tiHazard.allUNDGCodes.add ('1760');
		tiHazard.allUNDGCodes.add ('3267');
		tiHazard.allUNDGCodes.add ('3262');
		tiHazard.allUNDGCodes.add ('1823');
		tiHazard.allUNDGCodes.add ('2922');
	commitTransaction;
	self.addTIHazard ( container4, '9', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('3083');
	commitTransaction;
	self.assertTrueMsg( not container4.allTIHazards.isEmpty, "Container does not have hazards");
	
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	//
	// Make the Containers tranship
	//
	create controller transient;

//	container4 := self.getTrackedItemOnVoy(ContainerID4, VoyageName1);
	self.assertNotNull(container4);
	controller.allTrackedItems.add(container4);
	controller.myExportDestPort := app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort := app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage := voyage2;
	controller.remarks := "UT Tranship";
	// controller.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	self.assertEqualMsg(container4.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item:" &amp; container4.id &amp; " is not Tranship");
	self.assertEqualMsg(container4.myExportVoyage, voyage2, "TI:" &amp; container4.id &amp; " has wrong export voyage");
	self.assertEqualMsg(container4.myImportVoyage, voyage1, "TI:" &amp; container4.id &amp; " has wrong import voyage");
	self.assertEqualMsg(container4.myVoyage, voyage1, "TI:" &amp; container4.id &amp; " myVoyage reference is not the import voyage");

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	container1.setBOL(Bol1);
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	beginTransaction;
	container2.setBOL(Bol2);
	commitTransaction;
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
		
	self.moveAllCargo(voyage1);
	beginTransaction; // --&gt; TFS 47450 - add this seal *after* discharge/Receive-Ship - shouldn't be in output...
	container4.setSealNumVent("VENT999");
	commitTransaction; // &lt;-- TFS 47450
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM4446.name, true);

	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG213", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	

	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri213_BGMChange4446);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
	delete controller;
	delete voyageNames;
	delete voyageArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCoarriCodeco_MSC" id="5f65b3b9-cf07-4cf8-85ab-022486dbb806">
        <updating/>
        <source>tCoarriCodeco_MSC()updating;
// cnwrs1
/*
Date		Who		Reason
09 Aug 2013	cnwcs5	par 32148
*/
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'UT_32148';				
	BoatName		= 'UT_32148';
	PortName		= "NZAKL";
	ContainerName1	= 'MSC000001';
	ContainerName2	= 'MSC000002';
	ContainerName3	= 'MSC000003';
	ContainerName4	= 'MSC000004';
	ContainerName5	= 'MSC000005';
	BlockStackName	= 'BS32148';
	CamGroup 		= "UT-MSC";
	CamCoarri 	= "UT_MSC_COARRI";
	CamCodecoTerm	 	= "UT_MSC_CODECO_Term";
	CamCodecoDepot	 	= "UT_MSC_CODECO_Depot";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	runDateTime : TimeStamp;
	tempStr : String;
	codecoTime3, codecoTime4, coarriTime3, coarriTime4 : TimeStamp; 
	tempDT : TimeStamp;
	lastEQD			: String;
	idx 			: Integer;
	container1, container2, container3, container4 : CM_Container;
	operator	 	: CM_Operator;
	voyage	 		: CM_Voyage;
	passport 		: CM_Passport;
	bs 				: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime 	:= app.actualTimeServer;
	passport 		:= app.myPassport;
	operator 		:= self.getOperator(("MSC"));
	codecoTime3 := null;
	codecoTime4 := null;
	coarriTime3 := null;
	coarriTime4 := null;
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; "MSC");
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setOperatorCode (operator.code, passport);
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setOperatorCode (operator.code, passport);
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	container1.setOperatorCode (operator.code, passport);
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);

	beginTransaction;
	container2.setOperatorCode (operator.code, passport);
	commitTransaction;
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs (voyage, PortName, crane.id);
	self.planLoadItems (voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo (voyage);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamCoarri);
	self.deleteCamProtocol(CamCodecoTerm);
	self.deleteCamProtocol(CamCodecoDepot);

	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamCoarri);
	self.assertIsDeleted(camProtocol);

	camProtocol		:= self.createCamProtocolCoarri (CamCoarri, camGroup,"MSC Coarri", "NZCHC",operator.code);

	// run cams - COARRI first
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		if tempStr.startsWith ("EQD+CN+" &amp; ContainerName3) then
			lastEQD := ContainerName3;
		elseif tempStr.startsWith ("EQD+CN+" &amp; ContainerName4) then
			lastEQD := ContainerName4;
		elseif  tempStr.startsWith ("EQD+CN+") then
			lastEQD		:= null;
		endif;
		if tempStr.startsWith ("DTM+203:") then
			if lastEQD = ContainerName3 then
				coarriTime3.setFromYYYYMMDDHHmm(tempStr[9:12]);
			elseif lastEQD = ContainerName4 then
				coarriTime4.setFromYYYYMMDDHHmm(tempStr[9:12]);
			endif;
			lastEQD		:= null;
		endif;
	endforeach;
	
	self.assertNotNull (coarriTime3);
	self.assertNotNull (coarriTime4);

	// now run CODECO for Teminal
	strs.clear;
	strs.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	strs.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	
	camProtocol		:= self.createCamProtocolCodeco (CamCodecoTerm, camGroup, "MSC Codeco", "NZCHC", operator.code, strs, true, false);
	
	beginTransaction;
	camProtocol.setPropertyValue (CM_CamProtocol::depotActivity.name, false);
//	camProtocol.setPropertyValue (CM_CamProtocol::terminalActivity.name, false);
	commitTransaction;
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	lastEQD := null;
	
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		if tempStr.startsWith ("EQD+CN+" &amp; ContainerName3) then
			lastEQD := ContainerName3;
		elseif tempStr.startsWith ("EQD+CN+" &amp; ContainerName4) then
			lastEQD := ContainerName4;
		elseif  tempStr.startsWith ("EQD+CN+") then
			lastEQD		:= null;
		endif;
		if tempStr.startsWith ("DTM+7:") then
			if lastEQD = ContainerName3 then
				codecoTime3.setFromYYYYMMDDHHmm(tempStr[7:12]);
			elseif lastEQD = ContainerName4 then
				codecoTime4.setFromYYYYMMDDHHmm(tempStr[7:12]);
			endif;
			lastEQD		:= null;
		endif;
	endforeach;	
	
	self.assertNotNull (codecoTime3);
	self.assertNotNull (codecoTime4);
	tempDT := codecoTime3.addMinutes(-1);
	if coarriTime3 &lt;&gt; tempDT then
		self.assertEqual(null, "the discharge MT must be before the gate-out to depot");
	endif;
	
	tempDT := codecoTime4.addMinutes(-1);
	if coarriTime4 &lt;&gt; tempDT then
		self.assertEqual(null, "the discharge MT must be before the gate-out to depot");
	endif;

	// now run CODECO for Depot
	codecoTime3 := null;
	codecoTime4 := null;
	strs.clear;
	strs.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	strs.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	
	camProtocol		:= self.createCamProtocolCodeco (CamCodecoDepot, camGroup, "MSC Codeco", "NZCHC", operator.code, strs, true, false);
	
	beginTransaction;
//	camProtocol.setPropertyValue (CM_CamProtocol::depotActivity.name, false);
	camProtocol.setPropertyValue (CM_CamProtocol::terminalActivity.name, false);
	commitTransaction;
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	lastEQD := null;
	
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		if tempStr.startsWith ("EQD+CN+" &amp; ContainerName3) then
			lastEQD := ContainerName3;
		elseif tempStr.startsWith ("EQD+CN+" &amp; ContainerName4) then
			lastEQD := ContainerName4;
		elseif  tempStr.startsWith ("EQD+CN+") then
			lastEQD		:= null;
		endif;
		if tempStr.startsWith ("DTM+7:") then
			if lastEQD = ContainerName3 then
				codecoTime3.setFromYYYYMMDDHHmm(tempStr[7:12]);
			elseif lastEQD = ContainerName4 then
				codecoTime4.setFromYYYYMMDDHHmm(tempStr[7:12]);
			endif;
			lastEQD		:= null;
		endif;
	endforeach;	

	
	self.assertNotNull (codecoTime3);
	self.assertNotNull (codecoTime4);
	
	tempDT := codecoTime3.addMinutes(-2);
	if coarriTime3 &lt;&gt; tempDT then
		self.assertEqual(null, "the discharge MT must be before the gate-in to depot");
	endif;
	
	tempDT := codecoTime3.addMinutes(-2);
	if coarriTime4 &lt;&gt; tempDT then
		self.assertEqual(null, "the discharge MT must be before the gate-in to depot");
	endif;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete theLines;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCoarri_AllFormats_VGM" id="685db3d0-f1df-446b-8ad8-a4e3f00d5716">
        <updating/>
        <source>tCoarri_AllFormats_VGM() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/05/2016	cnwdap1		Initial creation TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 30/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 20 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 20 Sep 2017	jlgrs1	TFS 7034 Standard COARRI Corrections
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName		= 'UT_VOYAGE_VGM';
	BoatName		= 'UT_VESSEL_VGM';
	PortName		= "NZAKL";
	ContainerName1	= 'UTXTVGM001';
	ContainerName2	= 'UTXTVGM002';
	ContainerName3	= 'UTXTVGM003';
	ContainerName4	= 'UTXTVGM004';
	BlockStackName	= 'BSVGM';
	CamGroup 		= "UT-ECN1";
	CamProtocol 	= "UT_COARRI";
	CamProtocolPIL	= "UT_COARRI_PIL";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";

vars
	passport		: CM_Passport;
	operator		: CM_Operator;
	crane			: CM_Crane;
	container1,
	container2,
	container3,
	container4		: CM_Container;
	bs				: CM_BlockStack;
	voyage 			: CM_Voyage;
	port			: CM_Port;
	strs			: StringArray;
	theSlot			: CM_LocationsController;
	idx				: Integer;
	tempStr			: String;
	camGroup		: CM_CamGroup;
	camProtocol		: CM_CamProtocol;
	operatorDict	: CM_OperatorByCodeDict;
	freightFwdrs	: CM_ConsigneeConsignorSet;
	startDateTime,	
	endDateTime,
	runDateTime,
	timeStamp		: TimeStamp;
	formattedTS		: String;
	camTaskHistory	: CM_CamTaskHistory;
	autoBol			: Boolean;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.opts.purge();
	passport := app.myPassport;
	autoBol := self.setTerminalConfig(GateInAutoBOLNumber, false).Boolean;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	startDateTime := app.actualTimeServer;
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);

	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	voyage := self.createVesselVoyage(VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull(port);
	
	// create on-ship cargo
	// ### 20 GENERAL
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	// ### 20 REEFER
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	
	beginTransaction;
	container3.setLoadPort("NZWEL");
	container4.setLoadPort("NZLYT");
	commitTransaction;
	
	// create on-site cargo
	// ### 20 MT
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	// ### 20 REEFER
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	self.createVoyageDischargeJobs(voyage, crane.id);
	self.createVoyageLoadJobs(voyage, PortName, crane.id);
	self.planLoadItems(voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo(voyage);
	
	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);

	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	// set isWeightCertified, weightCertifiedName and weightCertifiedReference
	// TFS 4492 and some other fields, so we get COARRI DTM and FTX segments for verified gross mass
	beginTransaction;
	container1.setPropertyValue (CM_TrackedItem::totalWeight.name, 12345.Decimal);
	container1.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "John Weigher");					// TFS 4492
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "Certified Weighing Ltd");	// TFS 4492
	container1.setMyVGMDetails(	"Certified Weighing Ltd".toUpper, "John Weigher".toUpper,						// TFS 4492
								null, "SM1", "SM1-DOC-DETAILS", null, null, null,								// TFS 4492
								null, null, null, "15/07/2017 18:00".TimeStamp, 								// TFS 4492
								"15/07/2017 12:00".TimeStamp, null	);											// TFS 4492
	
	container3.setPropertyValue (CM_TrackedItem::totalWeight.name, 4000.Decimal);
	container3.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "Bob Weigher");					// TFS 4492
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "SOLAS Certified Weighing Ltd");	// TFS 4492
	container3.setMyVGMDetails(	"SOLAS Certified Weighing Ltd".toUpper, "Bob Weigher".toUpper,					// TFS 4492
								null, "SM2", "SM2-DOC-DETAILS", null, null, null,								// TFS 4492
								null, null, null, "25/07/2017 08:00".TimeStamp, 								// TFS 4492
								"25/07/2017 06:00".TimeStamp, null	);											// TFS 4492
	commitTransaction;
	
	create operatorDict transient;
	create freightFwdrs transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightFwdrs, 16, ShipperCode);
	self.assertNotNull(camGroup);

	self.opts.addAssoc(CM_CamProtocol::setIncludeExtraVGM.name, true);
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, true);
	self.zRunCAMS (CamProtocol&amp; "_ANL", camGroup, "ANL Coarri", operator, self.zCoarri_ANL_VGM, false, container1, container2, container3, container4, true );
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, false);
	
	self.zRunCAMS (CamProtocol&amp; "_UN", camGroup, "UN/EDIFACT Coarri", operator, self.zCoarri_UN_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_UN2", camGroup, "UN/EDIFACT Coarri", operator, self.zCoarri_UN2_VGM, false, container1, container2, container3, container4, true );
	
	self.zRunCAMS (CamProtocol&amp; "_CMA", camGroup, "CMA Coarri", operator, self.zCoarri_CMA_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_CON", camGroup, "ContShip Coarri", operator, self.zCoarri_CON_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_COS", camGroup, "Cosco Coarri", operator, self.zCoarri_COS_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR2", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR2_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR3", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR3_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_HLC", camGroup, "Hapag COARRI", operator, self.zCoarri_HLC_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MOT", camGroup, "MOT-ECN COARRI", operator, self.zCoarri_ECNMOT_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MSC", camGroup, "MSC Coarri", operator, self.zCoarri_MSC_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MSK", camGroup, "Maersk Coarri", operator, self.zCoarri_MSK_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_NYK", camGroup, "NYK Coarri", operator, self.zCoarri_NYK_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_OOCL", camGroup, "OOCL Coarri", operator, self.zCoarri_OOCL_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_ZIM", camGroup, "UN/EDIFACT Coarri Zim", operator, self.zCoarri_ZIM_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_SNO", camGroup, "STANDARD COARRI SMDG162", operator, self.zCoarri_SNO_VGM, false, container1, container2, container3, container4, true );	

	self.deleteCamProtocol(CamProtocolPIL);
	camProtocol := self.createCamProtocolCoarri(CamProtocolPIL, camGroup,"PIL Coarri", "NZCHC", operator.code);
	beginTransaction;
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::useVGM.name, true);
	commitTransaction;
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	timeStamp := camTaskHistory.runDateTime.localToUTCTime();
	formattedTS := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_PIL_VGM(formattedTS));
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightFwdrs;
	delete strs;
	app.setIsBackGroundApp (false);
	self.setTerminalConfig(GateInAutoBOLNumber, autoBol);
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCoarri_AllFormats_VGM2" id="6ef01bc8-d335-442c-a61b-10b8685b7522">
        <updating/>
        <source>tCoarri_AllFormats_VGM2() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/05/2016	cnwdap1		Initial creation TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 30/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 20 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 20 Sep 2017	jlgrs1	TFS 7034 Standard COARRI Corrections
//
constants
	VoyageName		= 'UT_VOYAGE_VGM';
	BoatName		= 'UT_VESSEL_VGM';
	PortName		= "NZAKL";
	ContainerName1	= 'UTXTVGM001';
	ContainerName2	= 'UTXTVGM002';
	ContainerName3	= 'UTXTVGM003';
	ContainerName4	= 'UTXTVGM004';
	BlockStackName	= 'BSVGM';
	CamGroup 		= "UT-ECN1";
	CamProtocol 	= "UT_COARRI";
	CamProtocolPIL	= "UT_COARRI_PIL";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";

vars
	passport		: CM_Passport;
	operator		: CM_Operator;
	crane			: CM_Crane;
	container1,
	container2,
	container3,
	container4		: CM_Container;
	bs				: CM_BlockStack;
	voyage 			: CM_Voyage;
	port			: CM_Port;
	strs			: StringArray;
	theSlot			: CM_LocationsController;
	idx				: Integer;
	tempStr			: String;
	camGroup		: CM_CamGroup;
	camProtocol		: CM_CamProtocol;
	operatorDict	: CM_OperatorByCodeDict;
	freightFwdrs	: CM_ConsigneeConsignorSet;
	startDateTime,	
	endDateTime,
	runDateTime,
	timeStamp		: TimeStamp;
	formattedTS		: String;
	camTaskHistory	: CM_CamTaskHistory;
	autoBol			: Boolean;

begin
	self.opts.purge();
	passport := app.myPassport;
	autoBol := self.setTerminalConfig(GateInAutoBOLNumber, false).Boolean;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	startDateTime := app.actualTimeServer;
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);

	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	voyage := self.createVesselVoyage( VoyageName,BoatName, operator);
	
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull(port);
	
	// create on-ship cargo
	// ### 20 GENERAL
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	// ### 20 REEFER
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	
	beginTransaction;
	container3.setLoadPort("NZWEL");
	container4.setLoadPort("NZLYT");
	commitTransaction;
	
	// create on-site cargo
	// ### 20 MT
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	// ### 20 REEFER
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	self.createVoyageDischargeJobs(voyage, crane.id);
	self.createVoyageLoadJobs(voyage, PortName, crane.id);
	self.planLoadItems(voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo(voyage);
	
	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);

	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	// set isWeightCertified, weightCertifiedName and weightCertifiedReference
	// TFS 4492 and some other fields, so we get COARRI DTM and FTX segments for verified gross mass
	beginTransaction;
	container1.setPropertyValue (CM_TrackedItem::totalWeight.name, 12345.Decimal);
	container1.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "John Weigher");					// TFS 4492
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "Certified Weighing Ltd");	// TFS 4492
	container1.setMyVGMDetails(	"Certified Weighing Ltd".toUpper, "John Weigher".toUpper,						// TFS 4492
								null, "SM1", "SM1-DOC-DETAILS", null, null, null,								// TFS 4492
								null, null, null, "15/07/2017 18:00".TimeStamp, 								// TFS 4492
								"15/07/2017 12:00".TimeStamp, null	);											// TFS 4492
	
	container3.setPropertyValue (CM_TrackedItem::totalWeight.name, 4000.Decimal);
	container3.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "Bob Weigher");					// TFS 4492
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "SOLAS Certified Weighing Ltd");	// TFS 4492
	container3.setMyVGMDetails(	"SOLAS Certified Weighing Ltd".toUpper, "Bob Weigher".toUpper,					// TFS 4492
								null, "SM2", "SM2-DOC-DETAILS", null, null, null,								// TFS 4492
								null, null, null, "25/07/2017 08:00".TimeStamp, 								// TFS 4492
								"25/07/2017 06:00".TimeStamp, null	);											// TFS 4492
	commitTransaction;
	
	create operatorDict transient;
	create freightFwdrs transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightFwdrs, 16, ShipperCode);
	self.assertNotNull(camGroup);

	self.opts.addAssoc(CM_CamProtocol::setIncludeExtraVGM.name, false);
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, true);
	self.zRunCAMS (CamProtocol&amp; "_ANL", camGroup, "ANL Coarri", operator, self.zCoarri_ANL_VGM2, false, container1, container2, container3, container4, true );
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, false);
	
	self.zRunCAMS (CamProtocol&amp; "_UN", camGroup, "UN/EDIFACT Coarri", operator, self.zCoarri_UN_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_UN2", camGroup, "UN/EDIFACT Coarri", operator, self.zCoarri_UN2_VGM2, false, container1, container2, container3, container4, true );
	
	self.zRunCAMS (CamProtocol&amp; "_CMA", camGroup, "CMA Coarri", operator, self.zCoarri_CMA_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_CON", camGroup, "ContShip Coarri", operator, self.zCoarri_CON_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_COS", camGroup, "Cosco Coarri", operator, self.zCoarri_COS_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR2", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR2_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR3", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR3_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_HLC", camGroup, "Hapag COARRI", operator, self.zCoarri_HLC_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MOT", camGroup, "MOT-ECN COARRI", operator, self.zCoarri_ECNMOT_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MSC", camGroup, "MSC Coarri", operator, self.zCoarri_MSC_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MSK", camGroup, "Maersk Coarri", operator, self.zCoarri_MSK_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_NYK", camGroup, "NYK Coarri", operator, self.zCoarri_NYK_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_OOCL", camGroup, "OOCL Coarri", operator, self.zCoarri_OOCL_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_ZIM", camGroup, "UN/EDIFACT Coarri Zim", operator, self.zCoarri_ZIM_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_SNO", camGroup, "STANDARD COARRI SMDG162", operator, self.zCoarri_SNO_VGM2, false, container1, container2, container3, container4, true );	

	self.deleteCamProtocol(CamProtocolPIL);
	camProtocol := self.createCamProtocolCoarri(CamProtocolPIL, camGroup,"PIL Coarri", "NZCHC", operator.code);
	beginTransaction;
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::useVGM.name, true);
	commitTransaction;
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	timeStamp := camTaskHistory.runDateTime.localToUTCTime();
	formattedTS := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_PIL_VGM2(formattedTS));
	
epilog
	delete operatorDict;
	delete freightFwdrs;
	delete strs;
	app.setIsBackGroundApp (false);
	self.setTerminalConfig(GateInAutoBOLNumber, autoBol);
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
