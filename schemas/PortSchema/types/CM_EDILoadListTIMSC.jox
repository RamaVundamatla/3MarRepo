<Class name="CM_EDILoadListTIMSC" id="d5458239-bd8a-43a9-8fc7-397fda093865">
    <superclass name="CM_EDILoadListTI"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="setDefault" id="fe37a439-378c-4edf-86da-4dc8610f4971">
        <updating/>
        <source>setDefault(_infoTI: StringArray) updating;
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	infoTI			: StringArray;
	loadPortCode	: String;
	defCommodity	: String;
	xlationOperator : CM_Operator;
	foundMatch : Boolean;
	mtCmdty, refCmdty, hazCmdty : String;	//01 Mar 2021	NDL	TFS 50740
begin

	loadPortCode := self.getMyTerminal.getConfig(PortDestCode).String;
//	defCommodity := self.getMyTerminal.getConfig(DefCommodity).String;
	app.getTerminalDefCmdty( mtCmdty, defCommodity, refCmdty, hazCmdty );	//01 Mar 2021	NDL	TFS 50740


	infoTI := _infoTI;
	
	self.operatorCode		:= "MSC";					
	self.locationId			:= "null";
	self.commodity			:= defCommodity;
	xlationOperator := app.myRoot.allOperators["MSC"];
	
	//count,1
	
	self.setID(infoTI[1]);								//cargo ID
	self.setISOType(xlationOperator.getXlationSystemCode(infoTI[5], XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4]);
	self.bookingRef			:= infoTI[2];				//bookingRef
	self.setLoadPort(loadPortCode);						// [6] loadPort
	self.setDischargePort(infoTI[7].toUpper.trimBlanks);	//discharge
	self.setDestinationPort(infoTI[9].toUpper.trimBlanks);	//dest		// PAR 12693, CCMS 1029		
//	self.setFull(infoTI[9]);							//full
//	self.setEmpty(infoTI[10]);						//empty
	self.setTemp(infoTI[12]);							//temp
	self.setWeight(infoTI[10].Integer);							//Weight
	//self.??? := infoTI[13];							//SOC
	
end;</source>
        <Parameter name="_infoTI" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setEmpty" id="d9c69871-75df-489b-a70e-892864d45d5b">
        <updating/>
        <source>setEmpty(_mt: String) updating;
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _mt &lt;&gt; null then
		self.fullOrMT := "E";
	endif;

end;</source>
        <Parameter name="_mt" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFull" id="62ab536f-f29c-46b5-a9d1-8e2c38d1a2c2">
        <updating/>
        <source>setFull(_full: String) updating;
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _full &lt;&gt; null then
		self.fullOrMT := "F";
	endif;

end;</source>
        <Parameter name="_full" type="String"/>
    </JadeMethod>
</Class>
