    <JadeMethod name="isReEditable" id="fa57edfd-fe74-48c0-b74e-301f51091a92">
        <source>isReEditable(): Boolean;
/*

Date		Who		Reason
24 November 2015	cnwer1	Initial creation PAR

*/

vars

begin
	return false;
	if self.isReleaseById then
		return false;
	endif;
	
	if self.isTrailer then
		return false;
	endif;

	if self.myYardRequest &lt;&gt; null and self.myYardRequest.isKindOf(CM_DeliveryRequest) 
		 and 
		self.myYardRequest.allWorkListEntries.first.status &lt;&gt; WLE_COMPLETED and self.myYardRequest.allWorkListEntries.first.myTrackedItem = null then
		
		return true;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseOfSameBBCargo" id="7c2a4c5c-1d81-43d2-bd1d-972a0bdffed2">
        <source>isReleaseOfSameBBCargo()  : Boolean protected;
/*

Date		Who		Reason
03 March 2015	cnwer1	Initial creation PAR

*/

vars
	gteEntity : CMGTE_Entity;
begin
	if self.myTrackedItem = null then
		return false;
	endif;
	
	if self.myVehicleVisitRecord = null then
		return false;
	endif;
	
	if self.myTrackedItem.myCargoType.isBreakBulkMulti or self.myTrackedItem.myCargoType.isBulkMulti then
		foreach gteEntity in self.myVehicleVisitRecord.allGateEntities do
			if gteEntity = self then
				continue;
			endif;
			if not gteEntity.isKindOf(CMGTE_Release) then
				continue;
			endif;
			if gteEntity.CMGTE_Release.myTrackedItem = self.myTrackedItem then
				 return true;

			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrailer" id="b7ae07aa-48b7-4fcd-bef6-f690ce7313b7">
        <source>isTrailer() : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpCargoType  : CM_CargoType;
begin
	if self.isReleaseById then 
		tmpCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	
		if tmpCargoType &lt;&gt; null and tmpCargoType.isTrailer() then
			return true;
		endif;
	else
		if self.myCargoType = null then
			return false;
		endif;
		
		if self.myCargoType.isTrailer() then
			return true;
		endif;	
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myTILCType" id="39ddbeaf-3a53-4d4b-ba55-3fd66fc319b0">
        <methodInvocation>mapping</methodInvocation>
        <source>myTILCType(_set : Boolean; _value : CM_TILCType io) mapping;
/*
Date		Who		Reason
06 Dec 2012	cnwcs5	Initial creation - par 30852
*/
vars
	type	:CM_TILCType;
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// new trailer type is null
		self.myTILCType = _value then	// not changing trailer type
		return;
	endif;
	
	_value.updateForNonInversedReference;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_TILCType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="48a369fc-3abe-4cca-8e6c-4bd7e65297e1">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2009	cnwjk3	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
15/05/2014	cnwdap1	PAR #34157 Move setting of booking ref item to CNGTE_Entity level - this is where the reference is declared
19/07/2024	navpw1	TFS: 61525 (61527) - Added vbsti so this is populated when a proxy is created.
*/

vars
	pxyGTE 			: CMGTE_Release;
	completedOK		: Boolean;
begin
	pxyGTE := inheritMethod();
	pxyGTE.mySubTerminalSource := self.mySubTerminalSource;
	//pxyGTE.myBookingRefItem := self.myBookingRefItem;					// PAR #34157
	pxyGTE.myBulkRelease := self.myBulkRelease;
	pxyGTE.myReserveDetail := self.myReserveDetail;
	pxyGTE.myVbsti	:= self.myVbsti;	// ### TFS 61525 (61527) 19Jul2024 NAVPW1
	pxyGTE.myBOLDtl := self.myBOLDtl;	//09 Oct 2020	NDL	TFS 49189
	
	if self.isReleaseById then
		pxyGTE.myTrackedItem := self.myTrackedItem;
	else
		pxyGTE.myCargoType := self.myCargoType;
		pxyGTE.myOperatorGroup := self.myOperatorGroup;
		pxyGTE.myTILCType := self.myTILCType;
	endif;
	
	if self.myParent &lt;&gt; null then
		pxyGTE.myParent:=self.myParent;
		
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGTE;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGTE;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
