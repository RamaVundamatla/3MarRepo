    <JadeMethod name="doExport" id="4e3dca1d-049b-4513-85f4-b9b818bb38bc">
        <source>doExport(_cash : CM_Cash; _toFile : Boolean);
// SFeb 2016 TFS 985 allow export of credit and receipt
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
// 24 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
// 23 Dec 2019  cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud
vars

	fs		: CMDFileSave;
	finIO	: CM_ExtFinanceIO;
	credit	: CM_CashCredit;
	receipt	: CM_CashReceipt;
	today	: Date;
begin

	today := app.actualTimeServer().date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _cash = null then
		return;
	endif;
	if not _cash.isKindOf(CM_CashReceipt) and
	   not _cash.isKindOf(CM_CashCredit) then
		return;
	endif;

	if _cash.isKindOf(CM_CashCredit) then
		credit := _cash.CM_CashCredit;
	else
		receipt := _cash.CM_CashReceipt;
	endif;

	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIO = null or
		not global.isValidObject(finIO) then
		create finIO as CM_DefaultFinanceIO transient;
	endif;
	
	if _toFile then
		create fs;
		// get the default export name based on the invoice external financial system

		if finIO.isKindOf(CM_OracleFinancials) or  finIO.isKindOf(CM_QTSInterface)  then                  //23.12.2019 cnwma1 TFS #47851
			fs.dialogTitle	    := app.getErrorString(SpecifyFileForHeader);
			fs.resetCurrentPath := true;
			
			if finIO.isKindOf(CM_OracleFinancials) then
				fs.initDir 		    := finIO.CM_OracleFinancials.exportPath.normaliseDirectory().substituteDirectory();
			elseif finIO.isKindOf(CM_QTSInterface) then
				fs.initDir 		    := finIO.CM_QTSInterface.exportPath.normaliseDirectory().substituteDirectory();
			endif;
			if credit &lt;&gt; null then
				fs.fileName := "ar_credit_" &amp; credit.getExportSequence().padLeadingWith('0', 6) &amp; ".csv";
			else
				fs.fileName := "ar_receipt_" &amp; receipt.getExportSequence().padLeadingWith('0', 6) &amp; ".csv";
			endif;
	
		else	
			// default
			fs.dialogTitle 		:= app.getErrorString(SpecifyFileForHeader);
			fs.resetCurrentPath := true;
			fs.initDir 			:= finIO./*CM_DefaultFinanceIO.*/getExportFileNameBase(true);      // TFS 44265 - moved to CM_ExtFinanceIO
			fs.fileName 		:= /*"Inv*/"RecHead" &amp; today.userFormat($CM_YearFormat) &amp; "_"; // TFS 44265 - Inv -&gt; Rec
		endif;
		if fs.open = 0 then
			app.mousePointer := MP_HOURGLASS;
			if credit &lt;&gt; null then
				finIO.exportCreditToFile(credit, fs.fileName);
			else
				finIO.exportReceiptToFile(receipt, fs.fileName);
			endif;
		endif;
	else
		if credit &lt;&gt; null then
			finIO.exportCredit(credit);
		else
			finIO.exportReceipt(receipt);
		endif;
	endif;
	global.beep;

epilog
	delete fs;
	if finIO &lt;&gt; null and finIO.isTransient then
		delete finIO;
	endif;
	app.mousePointer := MP_DEFAULT;
end;
</source>
        <Parameter name="_cash" type="CM_Cash"/>
        <Parameter name="_toFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="ecd175a2-3644-44df-815e-0dfddbaa6b15">
        <source>doMnuContextBuild(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Aug 2012	cnwndl1	Initial creation
21 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
31 Jan 2020 cnwma1 ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars
	invoice	: CM_Invoice;
	cash : CM_Cash;

begin

	self.mnuExpand.visible		 	:= false;
	self.mnuInvoice.visible 	 	:= false;
	self.mnuShowCargo.visible 	 	:= false;
	self.mnuCashReceipt.visible  	:= false;
	self.mnuCreditNote.visible 	 	:= false;
	self.mnuPrintPayRec.visible  	:= false;
	self.mnuPrintCashRec.visible	:= false;
	self.mnuExportCred2File.visible := false;
	self.mnuExportCredit.visible 	:= false;
	self.mnuExportRec2File.visible 	:= false;
	self.mnuExportReceipt.visible 	:= false;
	self.mnuAudits.visible 			:= false;
	self.mnuInspect.visible 		:= false;
	self.btnPrintRec.enabled 		:= false;
	
	self.mnuInvoice.userObject 		:= null;
	self.mnuShowCargo.userObject 	:= null;
	self.mnuCashReceipt.userObject  := null;
	self.mnuCreditNote.userObject   := null;
	self.mnuPrintPayRec.userObject  := null;
	self.mnuPrintCashRec.userObject := null;
	self.mnuAudits.userObject 	    := null;
	


	cash :=  table.accessRow(table.row).itemObject.CM_Cash;
	if cash = null or not app.isValidObject(cash) then
		return false;
	endif;
	
	self.mnuInspect.userObject := cash;
	
	if cash.isProformaPayment then
		self.mnuExpand.visible 		   := true;
		self.mnuShowCargo.userObject   := cash.CM_CashPayment.myTrackedItem;
		self.mnuPrintPayRec.userObject := cash;
		self.mnuPrintPayRec.caption    := app.getErrorString(INV_Print) &amp; " " &amp; app.getErrorString(Proforma);
		self.btnPrintRec.enabled 	   := true;
	endif;
	
	if cash.isPayment and not cash.isProformaPayment then
		self.mnuInvoice.userObject 		:= cash.CM_CashPayment.myInvoice;
		self.mnuShowCargo.userObject 	:= cash.CM_CashPayment.myTrackedItem;
		self.mnuPrintPayRec.userObject  := cash;
		self.mnuPrintPayRec.caption	    := app.getErrorString(INV_Print) &amp; " " &amp; app.getErrorString(Invoice_receipt);
		self.btnPrintRec.enabled 		:= true;
	endif;
	
	if cash.isReceipt then
		invoice := cash.CM_CashReceipt.getCashInvoice;		
		self.mnuInvoice.userObject 		:= invoice;
		self.mnuPrintCashRec.userObject := cash;
		self.mnuPrintCashRec.caption 	:= "Print Cash Receipt";
		self.btnPrintRec.enabled 		:= true;
		self.mnuCashReceipt.userObject  := cash;
		self.mnuCreditNote.userObject   := cash;
		self.mnuAudits.userObject 		:= cash;
		self.mnuInvoice.visible 		:= (invoice &lt;&gt; null);
		self.mnuInvoice.userObject 		:= invoice;
		self.mnuCashReceipt.visible 	:= ( not self.myTerminal.isDutyDocEnabled );	
		self.mnuCreditNote.visible 		:= true;
		self.mnuAudits.visible 			:= true;	
		self.mnuAudits.enabled 			:= (cash.qualifiedAudits.size &gt; 0);
		self.mnuExportRec2File.visible  := true;
		self.mnuExportReceipt.visible   := true;
		
	endif;
	
	if cash.isCredit then			
		self.mnuPrintCashRec.userObject := cash;
		self.mnuPrintCashRec.caption    := "Print Cash Credit";
		self.btnPrintRec.enabled 	    := true;
		self.mnuExportCred2File.visible := true;
		self.mnuExportCredit.visible    := true;
	endif;
	
	self.mnuInvoice.visible 		   := self.mnuInvoice.userObject &lt;&gt; null;
	self.mnuShowCargo.visible 		   := self.mnuShowCargo.userObject &lt;&gt; null;
	self.mnuPrintPayRec.visible 	   := self.mnuPrintPayRec.userObject &lt;&gt; null;
	self.mnuPrintCashRec.visible 	   := self.mnuPrintCashRec.userObject &lt;&gt; null;
	
	if app.isAllowedToInspect then
		self.mnuInspect.visible := true;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefreshExportCell" id="8f72f1da-e68a-497e-a313-e4220a4c4d5e">
        <source>doRefreshExportCell(_row : Integer);
/*

Date		Who		Reason
01 April 2016	cnwer1	Initial creation TFS 1754

*/

vars
	cash : CM_Cash;
	exported  : String;
begin
	cash :=  self.tblCash.accessRow(_row).itemObject.CM_Cash;
	if cash = null then
		return;
	endif;
	if _row &lt; 1 then
		return;
	endif;
	if _row &gt;  self.tblCash.rows then
		return;
	endif;
	
	if cash.isCredit then
		exported := app.getYesBlank(cash.CM_CashCredit.exportedCount &lt;&gt; 0);
	elseif cash.isReceipt then
		exported := app.getYesBlank(cash.CM_CashReceipt.exportedCount &lt;&gt; 0);
	endif;
	
	 self.tblCash.accessCell(_row,4).text:=exported;
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="d99c3d01-8828-4f6e-8e37-94c9afb75431">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	newHeight : Real;

begin

	inheritMethod();
	
	self.frmMain.move(5,self.frmToolbar.clientHeight + 5,self.clientWidth - 10,self.clientHeight - 10 - self.frmToolbar.clientHeight);
	
	newHeight := self.lblSearchCrit.getTextHeight( self.lblSearchCrit.caption );
	
	self.lblSearchCrit.move(	self.tblCash.left, //left
								0,//top
								self.clientWidth - 10,//width
								newHeight //heigth
								);
	
	self.frmTables.move(	self.frmTables.left, //left
							newHeight,//top
							self.frmTables.width,//width
							self.frmMain.height - self.frmToolbar.clientHeight - newHeight - 5 //heigth
							); 
	
//	self.btnClose.top := self.frmMain.height - self.btnClose.height;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="b6a75e55-3526-43a3-9493-eb07692d6832">
        <updating/>
        <source>doSearch() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2012	cnwndl1	Initial creation
30/04/2014	cnwjre1	33885 Remove refund, journal options as no longer used.  Also change the sorting to always put the receipt before the payments (looks better).
02/03/2016	cnwdap1	PAR #37608 Added a receipt number text box for sites that have &gt; 32,000 cash receipts
25/05/2016	cnwns1	TFS 488 - Multi Timezone Support
03/07/2019	NDL	TFS 45296 - changes to add Bank and Cash Receipt for improved filtering / performance
27/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
31/01/2020  cnwma1 ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars
	total,
	amount,		
	totalCash,
	totalInvoice,
	totalCredits,
	tax,
	totalTax,
	totalCashTax,
	totalInvoiceTax,
	totalCreditsTax		: Decimal[23,6];
	selectedDr 			: CM_Debtor;
	dr 					: CM_Debtor;
	selectedTerm 		: CM_Terminal;
	allDebtors 			: CM_DebtorSet;
	index 				: Integer;
	drTerm 				: CM_DebtorTerminal;
	obj					: Object;
	cash 				: CM_Cash;
	dict				: DynaDictionary;
	allCashTrx 			: CM_CashDict;
	includeArchived 	: Boolean;
	includePayments 	: Boolean;
	includeProformas 	: Boolean;
	includeReceipts 	: Boolean;
	includeCredits		: Boolean;
	type				: Integer;
	startTSLocal,
	endTSLocal 			: TimeStamp;
	startDateServer,
	endDateServer,
	startDateLocal,
	endDateLocal 		: Date;
	startDateIsValid,
	endDateIsValid,
	allDebtorsSelected,
	useDates 			: Boolean;
	bolNumber,	
	voyageCode,
	customsNumber,
	receiptNumber,
	cargoId,
	tableLine 			: String;
	cashPay 			: CM_CashPayment;
	cashRec 			: CM_CashReceipt;
	idx 				: Integer;
	cashReceiptObj 		: CM_CashReceipt;
	bankObj 			: CM_Bank;
	
begin

	app.mousePointer    := MousePointer_HourGlass;
	self.tblCash.rows   := self.tblCash.fixedRows;
	startDateLocal      := self.txtFromDate.getDate;						
	endDateLocal        := self.txtToDate.getDate;						
	startDateIsValid    := startDateLocal.isValid;						
	endDateIsValid      := endDateLocal.isValid;							
	useDates 		    := startDateIsValid or endDateIsValid;					
	self.showServiceTax := (self.myTerminal.getConfig(CashAllCashTax).String = null) and self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;																
	
	startTSLocal.cnEcSetDateAndTime(startDateLocal,TimeStartOfDay);	
	endTSLocal.cnEcSetDateAndTime(endDateLocal,TimeEndOfDay);		
																	
	startDateServer := self.localToSystemTime(startTSLocal).date();	
	endDateServer 	:= self.localToSystemTime(endTSLocal).date();		
	
	
	self.tblCash.accessColumn(7).visible := self.showServiceTax;
	
	if useDates then
		if startDateIsValid and endDateIsValid then
			if startDateServer &gt; endDateServer then
				app.mousePointer := MousePointer_Default;
				app.msgBox( app.getErrorString2(ERR_DateRangeInvalid, self.lblFromDate.caption, self.lblToDate.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
	endif;

	includeArchived  := self.chkIncludeArch.value;
	includePayments  := self.chkIncludePay.value;
	includeProformas := self.chkIncludePro.value;
	includeReceipts  := self.chkIncludeRec.value;
	includeCredits  := self.chkIncludeCred.value;
	
	if not includePayments and not includeProformas and not includeReceipts and not includeCredits then
		app.mousePointer := MousePointer_Default;
		app.msgBox( app.getErrorString(Must_select_type), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	bolNumber     := self.cmbBOL.text;
	cargoId 	  := self.txtCargoIds.text.toUpper();
	voyageCode    := self.cmbBolVoyage.text;
	customsNumber := self.txtCEN.text;
	selectedDr    := self.cmbDebtors.listObject.CM_Debtor;
	selectedTerm  := self.cmbTerminals.listObject.CM_Terminal;
	
	index         := self.cmbBanks.listIndex;
	
	if index &gt; 0 then
		bankObj := self.cmbBanks.itemObject[index].CM_Bank;
	endif;
	
	if self.cmbReceiptNo.enabled and self.cmbReceiptNo.listObject &lt;&gt; null then									
		cashReceiptObj     := self.cmbReceiptNo.listObject.CM_CashReceipt;
		if cashReceiptObj &lt;&gt; null then
			receiptNumber  := cashReceiptObj.getExternalInvoiceNumber.toUpper();	
		endif;
	else																
		receiptNumber     := self.txtReceiptNo.text.trimBlanks.toUpper();	
	endif;																
	
	
	create allDebtors transient;
	create allCashTrx transient;
	
	if selectedDr &lt;&gt; null then
		allDebtors.add( selectedDr );
	else
		foreach index in 1 to cmbDebtors.listCount do
			dr := self.cmbDebtors.itemObject[index].CM_Debtor;
			if dr &lt;&gt; null then
				allDebtors.add( dr );
			endif;
		endforeach;
		allDebtorsSelected := true;
	endif;
	
	if self.myQueryWorkOrder = null then // TFS 39349
	
		if cashReceiptObj &lt;&gt; null and selectedDr &lt;&gt; null and selectedTerm &lt;&gt; null then
			//Just one cash receipt, which we have already identified.
			self.getRawSearchData(	allCashTrx,	         //allCashTrx : CM_CashDict input;
									selectedDr,	        //dr : CM_Debtor;
									selectedTerm,	    //term : CM_Terminal;
									includeArchived,	//includeArchived : Boolean;
									includePayments,	//includePayments : Boolean;
									includeProformas,	//includeProformas : Boolean;
									includeReceipts,	//includeReceipts : Boolean;
									includeCredits,		// includeCredits : Boolean
									startDateServer,	//startDate : Date;
									endDateServer,  	//endDate : Date;
									startDateIsValid,	//startDateIsValid : Boolean;
									endDateIsValid, 	//endDateIsValid : Boolean;
									useDates,			//useDates : Boolean
									voyageCode,
									bolNumber,
									customsNumber,
									receiptNumber,
									cargoId,
									cashReceiptObj,		//cashReceiptObj : CM_CashReceipt;
									bankObj				//bankObj : CM_Bank
									);
		
		elseif ( allDebtorsSelected = true or selectedTerm = null ) and useDates and cashReceiptObj = null then
			//very generic date search, will use bank collections in date order
			self.getRawSearchData(	allCashTrx,			//allCashTrx : CM_CashDict input;
									selectedDr,			//dr : CM_Debtor;  // selectedDr will be null if allDebtors is true
									selectedTerm,		//term : CM_Terminal;
									includeArchived,	//includeArchived : Boolean;
									includePayments,	//includePayments : Boolean;
									includeProformas,	//includeProformas : Boolean;
									includeReceipts,	//includeReceipts : Boolean;
									includeCredits,		// includeCredits : Boolean
									startDateServer,	//startDate : Date;
									endDateServer,		//endDate : Date;
									startDateIsValid,	//startDateIsValid : Boolean;
									endDateIsValid,		//endDateIsValid : Boolean;
									useDates,			//useDates : Boolean
									voyageCode,
									bolNumber,
									customsNumber,
									receiptNumber,
									cargoId,
									null,				//cashReceiptObj : CM_CashReceipt;
									bankObj				//bankObj : CM_Bank
									);
									
		else
			foreach dr in allDebtors do
				self.getRawSearchData(	allCashTrx,			//allCashTrx : CM_CashDict input;
										dr,				    //dr : CM_Debtor;
										selectedTerm,		//term : CM_Terminal;
										includeArchived,	//includeArchived : Boolean;
										includePayments,	//includePayments : Boolean;
										includeProformas,	//includeProformas : Boolean;
										includeReceipts,	//includeReceipts : Boolean;
										includeCredits,		// includeCredits : Boolean
										startDateServer,	//startDate : Date;
										endDateServer,	   //endDate : Date;
										startDateIsValid,  //startDateIsValid : Boolean;
										endDateIsValid,   //endDateIsValid : Boolean;
										useDates,		  //useDates : Boolean
										voyageCode,
										bolNumber,
										customsNumber,
										receiptNumber,
										cargoId,
										cashReceiptObj,	//cashReceiptObj : CM_CashReceipt;
										bankObj			//bankObj : CM_Bank
										);
			endforeach;
		endif;
		
		
		// from 33885 this used to show receipts and payments mixed (all keyed on the same dateTime)
		//	sort the receipt before the payments
		create dict transient;
		dict.setMembership(CM_Cash);
		dict.addExternalKey(TimeStamp, null, false, true);			// dateTime of the cash instance
		dict.addExternalKey(Integer, null, false, true);			// type, 1 for receipt/credit and 2 for payment/detail, 0 for anything else
		dict.endKeys(true);
		
		foreach cash in allCashTrx do
			type := 0;
			if cash.isKindOf(CM_CashReceipt) or
			   cash.isKindOf(CM_CashCredit) then
				type := 1;
			elseif cash.isKindOf(CM_CashPayment) or
				cash.isKindOf(CM_CashCreditDetail) then
				type := 2;
				if cash.isKindOf(CM_CashPayment) and cash.CM_CashPayment.isTaxPayment then	
					continue;
				endif;
				if cash.isKindOf(CM_CashCreditDetail) and cash.CM_CashCreditDetail.myCashPayment &lt;&gt; null and cash.CM_CashCreditDetail.myCashPayment.myCashPaymentForInvoice &lt;&gt; null then	// this is a credit detail for tax
					continue;
				endif;
			endif;
			dict.putAtKey(cash.dateTime, type, cash);
		endforeach;
		
	else		 // TFS 39349
		create dict transient;
		dict.setMembership(CM_Cash);
		dict.addExternalKey(Integer, null, false, true);			
		dict.endKeys(true);
		
		foreach cashRec in self.myQueryWorkOrder.allCashReceipts do
			idx := idx + 1;
			dict.putAtKey(idx, cashRec);
			
			foreach cashPay in cashRec.allCashPayments	discreteLock do
				idx := idx + 1;
				dict.putAtKey(idx, cashPay);
		
			endforeach;
		endforeach;
	endif;			
	
	
	foreach obj in dict do
		cash := obj.CM_Cash;
	
		drTerm := cash.getDebtorTerminal();
		if drTerm = null then	//04 Jul 2019	NDL TFS 45296
			//WTF! This happened in testing, probably crap data in DMAST 
			continue;
		endif;
		
		amount := self.addLineToTable(cash,drTerm, tax);
	
		if not cash.isKindOf(CM_CashCreditDetail) then
			total 	 := total	 +  amount;
			totalTax := totalTax +  tax;
		endif;
		// 33527 additional totals, 37141 add credits
		if cash.isReceipt then
			totalCash 		:= totalCash    + amount;
			totalCashTax	:= totalCashTax + tax;
		elseif cash.isPayment or cash.isProformaPayment then
			totalInvoice 	:= totalInvoice    + amount;
			totalInvoiceTax := totalInvoiceTax + tax;
		elseif cash.isCredit then
			totalCredits 	:= totalCredits    + amount;
			totalCreditsTax := totalCreditsTax + tax;
		endif;		
	endforeach;
	
	if self.chkAddTotal.value then
	
		tableLine := Space  			  &amp; Tab &amp;
					 Space  			  &amp; Tab &amp;
					 Space  			  &amp; Tab &amp;
					 Space  			  &amp; Tab &amp;
					 "Total Transactions" &amp; Tab &amp;
					 total.asCurrencyJMT  &amp; Tab &amp;
					 totalTax.asCurrencyJMT();
				
		index := self.tblCash.addItem( tableLine );
		self.tblCash.accessCell(index,6).fontBold := true;
		self.tblCash.accessCell(index,7).fontBold := true;
		self.tblCash.accessRow(index).backColor   := self.tblCash.accessCell(index,1).backColor;
		
		// 33527 additional totals
		if includeReceipts then
			tableLine := Space 					 &amp; Tab &amp;
						 Space 					 &amp; Tab &amp; 
						 Space                   &amp; Tab &amp;
						 Space   				 &amp; Tab &amp; 
						 "Total Cash Received"   &amp; Tab &amp;
						 totalCash.asCurrencyJMT &amp; Tab &amp; 
						 totalCashTax.asCurrencyJMT();
			
			index := self.tblCash.addItem( tableLine );
			self.tblCash.accessCell(index,6).fontBold := true;
			self.tblCash.accessCell(index,7).fontBold := true;
			self.tblCash.accessRow(index).backColor   := self.tblCash.accessCell(index,1).backColor;
		endif;
		if includePayments or includeProformas then
			tableLine := Space 						 &amp; Tab &amp;
						 Space 						 &amp; Tab &amp; 
					 	 Space						 &amp; Tab &amp;
						 Space						 &amp; Tab &amp;
						 "Total Invoice Amount" 	 &amp; Tab &amp;
						 totalInvoice.asCurrencyJMT  &amp; Tab &amp;
						 totalInvoiceTax.asCurrencyJMT();
			index := self.tblCash.addItem( tableLine );
			self.tblCash.accessCell(index,6).fontBold := true;
			self.tblCash.accessCell(index,7).fontBold := true;
			self.tblCash.accessRow(index).backColor := self.tblCash.accessCell(index,1).backColor;
		endif;

		if includeCredits and
		   totalCredits &lt;&gt; 0 then
			tableLine := Space 				 		&amp; Tab &amp;
						 Space 				 		&amp; Tab &amp;
						 Space				 		&amp; Tab &amp;
						 Space 				 		&amp; Tab &amp;
						 "Total Credits" 			&amp; Tab &amp;
						 totalCredits.asCurrencyJMT &amp; Tab &amp;
						 totalCreditsTax.asCurrencyJMT();
			index := self.tblCash.addItem( tableLine );
			self.tblCash.accessCell(index,6).fontBold := true;
			self.tblCash.accessCell(index,7).fontBold := true;
			self.tblCash.accessRow(index).backColor := self.tblCash.accessCell(index,1).backColor;
		endif;
	
	endif;
	
	if self.myQueryWorkOrder = null then
		self.setSearchCriteriaLabel();
	endif;
	self.hideSearchFrame;

epilog

	app.mousePointer := MousePointer_Default;

	delete allCashTrx;
	delete allDebtors;
	delete dict;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="expandCollapseRow" id="29672658-01c8-4171-975b-5afd152c8929">
        <updating/>
        <source>expandCollapseRow()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Aug 2012	cnwndl1	Initial creation
31 Oct 2020 cnwma1	ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes  
*/

vars

	row,
	defaultRowHeight,
	rowHeight,
	numRows		    : Integer;
	expandContract, 
	typeString,   
	amountString    : String;
	invalidObject   : Boolean;
	cash            : CM_Cash;
begin

	row := self.tblCash.row;
	
	if row &gt; self.tblCash.fixedRows and row &lt;= self.tblCash.rows then
		cash := self.tblCash.accessRow( row ).itemObject.CM_Cash;
	endif;
	
	if cash = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, cash, invalidObject );
	
	if cash.isPayment then
		if cash.isProformaPayment then
			defaultRowHeight := self.tblCash.accessRow( 1 ).height;
			rowHeight        := self.tblCash.accessRow( row ).height;
			if rowHeight &lt;&gt; defaultRowHeight then
				self.tblCash.accessRow( row ).restoreAutoSize();
				amountString := cash.getAmountForBalanceTotal(null).asCurrencyJMT;
				typeString   := cash.getTypeString( null ).replaceString(Tab, " ");		// 33688 stop Tab moving some of the text into the next cell
				expandContract := "+";
		
			else
				cash.CM_CashPayment.expandedRows(	numRows,	//_numRows : Integer output;
													typeString,	//_type : String output;
													amountString	//_amount : String output
													);
				self.tblCash.accessRow( row ).height :=  numRows * rowHeight;
				expandContract := "-";
			endif;
			self.tblCash.setCellText( row, 4, expandContract &amp; Tab &amp; typeString &amp; Tab &amp; amountString );
		endif;
	endif;
	
	if invalidObject then
		app.msgBox( app.getErrorString(Object_Deleted_Reload), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.doSearch();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getRawSearchData" id="28690177-c8e7-4bf0-9554-a02e30c1dbd6">
        <source>getRawSearchData(	allCashTrx : CM_CashDict input;
					dr : CM_Debtor;
					term : CM_Terminal;
					includeConsolidated : Boolean;
					includePayments : Boolean;
					includeProformas : Boolean;
					includeReceipts : Boolean;
					includeCredits : Boolean;
					startDate : Date;
					endDate : Date;
					startDateIsValid : Boolean;
					endDateIsValid : Boolean;
					useDates : Boolean;
					bolNumber : String;
					voyageCode : String;
					customsNumber : String;
					receiptNumber : String;
					cargoId : String;
					cashReceiptObj : CM_CashReceipt;
					bankObj : CM_Bank
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation
03 Jul 2019	NDL	TFS 45296 - changes to add Bank and Cash Receipt for improved filtering / performance
*/

vars

	drTerm : CM_DebtorTerminal;
	cash : CM_Cash;
	cashPayment	: CM_CashPayment;
	cashCredit	: CM_CashCredit;
	creditDetail	: CM_CashCreditDetail;
	iter : Iterator;
	recPayMeth : CM_PaymentMethod;
	refPayMeth : CM_PaymentMethod;
	cashReceiptsByDate : CM_CashReceiptDateDict;
	cashCreditsByDate : CM_CashCreditDateDict;
	startObjectCR : CM_CashReceipt;
	startObjectCC : CM_CashCredit;
	startTimeStamp : TimeStamp;
	cashBank : CM_Bank;

begin

	if self.cmbRefPayMeth.listIndex &gt; 1 then
		refPayMeth := self.cmbRefPayMeth.listObject.CM_PaymentMethod;
	endif;
	if self.cmbRecPayMeth.listIndex &gt; 1 then
		recPayMeth := self.cmbRecPayMeth.listObject.CM_PaymentMethod;
	endif;

	//We have a cash receipt just use this sucker.
	if cashReceiptObj &lt;&gt; null then
		self.searchUsingCashReceiptObj(	allCashTrx,	//allCashTrx : CM_CashDict input;
										includeConsolidated,	//includeConsolidated : Boolean;
										includePayments,	//includePayments : Boolean;
										includeProformas,	//includeProformas : Boolean;
										includeReceipts,	//includeReceipts : Boolean;
										includeCredits,		// includeCredits : Boolean
										startDate,	//startDate : Date;
										endDate,	//endDate : Date;
										startDateIsValid,	//startDateIsValid : Boolean;
										endDateIsValid,	//endDateIsValid : Boolean;
										useDates,	//useDates : Boolean
										voyageCode,	// : String;
										bolNumber,	// : String;
										customsNumber,	// : String;
										receiptNumber,	// : String;
										cargoId,	// : String;
										cashReceiptObj,	//cashReceiptObj : CM_CashReceipt;
										bankObj,	//bankObj : CM_Bank;
										recPayMeth,	//recPayMeth : CM_PaymentMethod;
										refPayMeth	//refPayMeth : CM_PaymentMethod
										);
		return;
	endif;
	
	if dr = null or term = null and useDates then
		//very generic date search, will use bank collections in date order, should be quicker than using all drs or all terms
		//dr = null - means any debtor
		//term = null means any terminal
		//bankObj = null means any bank ( business unit )
		self.searchBusUnitDateColls(	allCashTrx,	//allCashTrx : CM_CashDict input;
										dr,	//dr : CM_Debtor;
										term,	//term : CM_Terminal;
										includeConsolidated,	//includeConsolidated : Boolean;
										includePayments,	//includePayments : Boolean;
										includeProformas,	//includeProformas : Boolean;
										includeReceipts,	//includeReceipts : Boolean;
										includeCredits,	//includeCredits : Boolean;
										startDate,	//startDate : Date;
										endDate,	//endDate : Date;
										startDateIsValid,	//startDateIsValid : Boolean;
										endDateIsValid,	//endDateIsValid : Boolean;
										bolNumber,	//bolNumber : String;
										voyageCode,	//voyageCode : String;
										customsNumber,	//customsNumber : String;
										receiptNumber,	//receiptNumber : String;
										cargoId,	//cargoId : String;
										bankObj,	//bankObj : CM_Bank;
										recPayMeth,	//recPayMeth : CM_PaymentMethod;
										refPayMeth	//refPayMeth : CM_PaymentMethod
										);
		return;
	endif;
	
	//All non specific searches from here on
	create cashReceiptsByDate transient;
	create cashCreditsByDate transient;
	
	foreach drTerm in dr.allDebtorTerminals do
	
		if term &lt;&gt; null then
			if term &lt;&gt; drTerm.myTerminal then
				continue;
			endif;
		endif;
	
		if includeConsolidated then
			if not drTerm.allConsolidatedCashTrx.isEmpty then
				iter := drTerm.allConsolidatedCashTrx.createIterator();
				while iter.next( cash ) do
					if not includeConsolidatedItem( 	cash,	//cash : CM_Cash;
														includePayments,	//includePayments : Boolean;
														includeReceipts,	//includeReceipts : Boolean;
														recPayMeth,	//recPayMeth : CM_PaymentMethod;
														refPayMeth,	//refPayMeth : CM_PaymentMethod;
														bolNumber,	//bolNumber : String;
														voyageCode,	//voyageCode : String;
														customsNumber,	//customsNumber : String;
														receiptNumber,	//receiptNumber : String;
														cargoId,	//cargoId : String;
														startDateIsValid,	//startDateIsValid : Boolean;
														startDate,	//startDate : Date;
														bankObj,	//bank : CM_Bank
														dr	//dr : CM_Debtor
														) then
						continue;
					endif;
					
					if endDateIsValid then
						if cash.dateTime.Date &gt; endDate then
							break;
						endif;
					endif;
					
					allCashTrx.add( cash );
					
				endwhile;
				delete iter;
			endif;
		endif;
		
		if includeReceipts and not drTerm.allCashReceipts.isEmpty then
			if useDates then
				
				cashReceiptsByDate.clear();
				drTerm.allCashReceipts.copy( cashReceiptsByDate );
				
				iter := cashReceiptsByDate.createIterator();
				if startDateIsValid then
					startTimeStamp.setDate(startDate);
					startTimeStamp.setTime("00:00:00".Time);
					startObjectCR := cashReceiptsByDate.getAtKeyGeq( startTimeStamp );
					if startObjectCR &lt;&gt; null then
						iter.startAtObject( startObjectCR );
					endif;
				endif;
				
				if not startDateIsValid or startObjectCR &lt;&gt; null then
					while iter.next( cash ) do
						if endDateIsValid then
							if cash.dateTime.Date &gt; endDate then
								break;
							endif;
						endif;
						if not includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
														recPayMeth,	//recPayMeth : CM_PaymentMethod;
														bolNumber,	//bolNumber : String;
														voyageCode,	//voyageCode : String;
														customsNumber,	//customsNumber : String;
														receiptNumber,	//receiptNumber : String;
														cargoId,	//cargoId : String;
														bankObj,	//bank : CM_Bank
														dr	//dr : CM_Debtor
														) then
							continue;
						endif;
						allCashTrx.add( cash );
					endwhile;
				endif;
				delete iter;
				
			else
				iter := drTerm.allCashReceipts.createIterator();
				while iter.next( cash ) do
					if not includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
													recPayMeth,	//recPayMeth : CM_PaymentMethod;
													bolNumber,	//bolNumber : String;
													voyageCode,	//voyageCode : String;
													customsNumber,	//customsNumber : String;
													receiptNumber,	//receiptNumber : String;
													cargoId,	//cargoId : String;
													bankObj,	//bank : CM_Bank
													dr	//dr : CM_Debtor
													) then
						continue;
					endif;
					allCashTrx.add( cash );
				endwhile;
				delete iter;
				
			endif;
		endif;
		
		if ( includePayments or includeProformas )and not drTerm.allCashPayments.isEmpty then
			if useDates or (not includePayments) or (not includeProformas) then
				//at least one of the above is true so have to check each one.
				iter := drTerm.allCashPayments.createIterator();
				while iter.next( cash ) do
					if not includePayments then
						if not cash.isProformaPayment then
							continue;
						endif;
					elseif not includeProformas then
						if cash.isProformaPayment then
							continue;
						endif;
					endif;
					if startDateIsValid then
						if cash.dateTime.Date &lt; startDate then
							continue;
						endif;
					endif;
					if endDateIsValid then
						if cash.dateTime.Date &gt; endDate then
							break;
						endif;
					endif;
					// 33983 extend the selective search to payments as well
					if not cash.CM_CashPayment.matches(bolNumber, voyageCode, customsNumber, receiptNumber, cargoId) then
						continue;
					endif;
					if bankObj &lt;&gt; null then
						cashBank := cash.CM_CashPayment.getBank();
						if cashBank &lt;&gt; null and cashBank &lt;&gt; bankObj then
							continue;
						endif;
					endif;
					allCashTrx.add( cash );
				endwhile;
				delete iter;
			else
				//no dates in use and wants proformas and actual payments.
				// 33983 extend the selective search to payments as well
				foreach cashPayment in drTerm.allCashPayments do
					if not cashPayment.matches(bolNumber, voyageCode, customsNumber, receiptNumber, cargoId) then
						continue;
					endif;
					allCashTrx.add (cashPayment );
				endforeach;
			endif;
		endif;
	
		if includeCredits and not drTerm.allCashCredits.isEmpty then
			if useDates then
				
				cashCreditsByDate.clear();
				drTerm.allCashCredits.copy( cashCreditsByDate );
				
				iter := cashCreditsByDate.createIterator();
				if startDateIsValid then
					startTimeStamp.setDate(startDate);
					startTimeStamp.setTime("00:00:00".Time);
					startObjectCC := cashCreditsByDate.getAtKeyGeq( startTimeStamp );
					if startObjectCC &lt;&gt; null then
						iter.startAtObject( startObjectCC );
					endif;
				endif;
				
				if not startDateIsValid or startObjectCR &lt;&gt; null then
					while iter.next( cash ) do
						if endDateIsValid then
							if cash.dateTime.Date &gt; endDate then
								break;
							endif;
						endif;
						if bankObj &lt;&gt; null and cash.CM_CashCredit.myBank &lt;&gt; bankObj then
							continue;
						endif;
						
						allCashTrx.add( cash );
						cashCredit := cash.CM_CashCredit;
						foreach creditDetail in cashCredit.allDerivedFromCreditDetails do
							allCashTrx.add(creditDetail);
						endforeach;
					endwhile;
				endif;				
				delete iter;
				
			else
				iter := drTerm.allCashCredits.createIterator();                    //03.02.2020 cnwma1 #4828
				while iter.next( cash ) do
				
					if bankObj &lt;&gt; null and cash.CM_CashCredit.myBank &lt;&gt; bankObj then
						continue;
					endif;
					
					allCashTrx.add( cash );
					cashCredit := cash.CM_CashCredit;
					foreach creditDetail in cashCredit.allDerivedFromCreditDetails do
						allCashTrx.add(creditDetail);
					endforeach;
				endwhile;
				delete iter;
			endif;
		endif;

	endforeach;

epilog

	delete iter;
	delete cashReceiptsByDate;
	delete cashCreditsByDate;

end;</source>
        <access>protected</access>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
        <Parameter name="dr" type="CM_Debtor"/>
        <Parameter name="term" type="CM_Terminal"/>
        <Parameter name="includeConsolidated" type="Boolean"/>
        <Parameter name="includePayments" type="Boolean"/>
        <Parameter name="includeProformas" type="Boolean"/>
        <Parameter name="includeReceipts" type="Boolean"/>
        <Parameter name="includeCredits" type="Boolean"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startDateIsValid" type="Boolean"/>
        <Parameter name="endDateIsValid" type="Boolean"/>
        <Parameter name="useDates" type="Boolean"/>
        <Parameter name="bolNumber" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="customsNumber" type="String"/>
        <Parameter name="receiptNumber" type="String"/>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="cashReceiptObj" type="CM_CashReceipt"/>
        <Parameter name="bankObj" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d8a834d7-6481-405e-9b81-3d3676513da0">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str	:=	inheritMethod();
	
	str := str &amp; global.formatAsXML( self.chkIncludeArch.name, self.chkIncludeArch.value.String);
	str := str &amp; global.formatAsXML( self.chkIncludeCred.name, self.chkIncludeCred.value.String);
	str := str &amp; global.formatAsXML( self.chkIncludePay.name, self.chkIncludePay.value.String);
	str := str &amp; global.formatAsXML( self.chkIncludePro.name, self.chkIncludePro.value.String);
	str := str &amp; global.formatAsXML( self.chkIncludeRec.name, self.chkIncludeRec.value.String);
	str := str &amp; global.formatAsXML( self.chkIncludeRef.name, self.chkIncludeRef.value.String);
	str := str &amp; global.formatAsXML( self.chkAddTotal.name, self.chkAddTotal.value.String);
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="764b09a6-9164-4ba1-875a-923cd2eeaf0a">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	    cnwndl1	Initial creation
31 Jan    2020  	cnwma1 ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars
	cash 	: CM_Cash;
	row	    : Integer;
	payment : CM_CashPayment;
	receipt : CM_CashReceipt;
	dr 		: CM_Debtor;
	invalid : Boolean;
	edition : Integer;

begin

	dr := self.cmbDebtors.listObject.CM_Debtor;
	if dr = null then
		return;
	endif;

	if eventType = Object_Delete_Event then
		if self.tblCash.fixedRows = self.tblCash.rows then
			// no data loaded, nothing to do
			return;
		endif;
		foreach row in self.tblCash.fixedRows + 1 to self.tblCash.rows do 
			cash := self.tblCash.accessRow(row).itemObject.CM_Cash;
			if cash = theObject then
				//we need to rebuild to get rid of this one.
				self.doSearch();
				return;
			endif;
		endforeach;
		return;
	endif;
	

	if theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, theObject, invalid );
		edition := theObject.edition;
		if invalid then
			return;
		endif;
	endif;

	if theObject.isKindOf( CM_CashPayment ) then
		payment := theObject.CM_CashPayment;
		if payment.getDebtorTerminal.myDebtor = dr then
			self.doSearch();
			return;
		endif;
	elseif theObject.isKindOf( CM_CashReceipt ) then
		receipt := theObject.CM_CashReceipt;
		if receipt.getDebtorTerminal.myDebtor = dr then
			self.doSearch();
			return;
		endif;
	else
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handlePrintTableRowException" id="3501fd99-e4fe-4876-a710-21d1c452137b">
        <source>handlePrintTableRowException(_exc : Exception) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	Par 29968

*/

constants

	InvalidNumberOfRows		= 14049;
	InvalidTableRow			= 14051;
	
vars

begin

	if _exc.errorCode = InvalidNumberOfRows or
	   _exc.errorCode = InvalidTableRow then
		app.msgBox(app.getErrorString(ERR_MAX_TABLE_ROW_EXCEEDED), 'Error', MsgBox_OK_Only + MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	endif;
	
	// Not our exception
	return Ex_Pass_Back;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
