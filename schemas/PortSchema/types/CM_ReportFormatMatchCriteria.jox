    <JadeMethod name="getReportTypeAsNiceName" id="e791a0eb-dfa2-47ef-9af0-ae3361d00b0f">
        <source>getReportTypeAsNiceName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184
04/01/2017                    cnwrh7     TFS    2899 Cargo Attribute Filter for Driver Instructions
*/

vars

begin

	if self.reportType = self.RoadReceiptReportInt then
		return self.RoadReceiptReportName;
	elseif self.reportType = self.DriverCriteriaInt then			//+TFS2899
		return self.DriverInstructionReportName;
	elseif self.reportType = self.RpDriverCriteriaInt then 	//+TFS2899
		return self.RpDriverInstructionReportName;
	else
		return "Unknown";
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="a238dfdd-ced1-45e3-82c0-5ac5a7df0adf">
