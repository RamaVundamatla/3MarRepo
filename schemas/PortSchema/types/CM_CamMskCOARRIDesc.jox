    <JadeMethod name="makeMessageNAD_CF" id="d34b6c80-56e2-4782-867a-9ec30d5d9833">
        <source>makeMessageNAD_CF(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*
Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	value, msg	:String;
	foundMatch	:Boolean;
begin
	// CCMS 5158 treat generators differently for Maersk
	if _ti.cargoType = TI_CargoType_Generator then
		msg := self.makeNADSegment (_protocol, _group, "CF", "GEN", '172', '20');
	else
		value := app.myRoot.getXlationForeignOperatorCode(null, _ti.operatorCode.trimRight, foundMatch)[1:4]; // cnwrd1 par 19675 14.5.09

		msg := self.makeNADSegment (_protocol, _group, "CF", value, '172', '20');
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_ABT" id="cbd5598c-b894-42c6-8dac-cd977c43236e">
        <source>makeMessageRFF_ABT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	value, msg	:String;
begin
	value := _ti.customExportEntryNumber.trimRight; 
	
	if app.myRoot.isClientCentrePort then 
		if _ti.isCoastal() and (_ti.isExport or _ti.isTranshipExport) then		// PAR #25021
			msg := self.makeRFFSegment (_protocol, _group, "ABT", "COASTAL");
		else
			if value &lt;&gt; null then
				msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
			endif;
		endif;
	else
		if value &lt;&gt; null then
			msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
		endif;
	endif;
	
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="45a3e99f-03af-40f8-a69d-9176dfe07196">
        <source>makeMessageSealsData(_ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
23 Jan 2013 cnwmc5	Changes for CCMS 2238
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	strSeal		: String;
	plus, 
	singleQuote	: Character;	
//	custSeals 	: StringArray;
	sealParty	: String;
	
begin
	//23 Mar 2012	NDL	Par 29144
	if _contentsStatus = '4' then
		//Empty Containers should never include seals data...
		return;
	endif;
	
	plus 		:= _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	
	if _ti.getSealNum.trimRight &lt;&gt; null then
		strSeal := formatSealMsk(SealType_Operator, _camProtocol.camGroup, _ti.CM_Container, sealParty);
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; sealParty &amp; singleQuote);
	endif;
	
	if sealParty &lt;&gt; "SH" then
		if _ti.getSealNumShipper.trimRight &lt;&gt; null then
			strSeal := formatSealMsk(SealType_Shipper, _camProtocol.camGroup, _ti.CM_Container, sealParty);
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; sealParty &amp; singleQuote);
		endif;
	endif;
	
	if _ti.getSealNumCustoms.trimRight &lt;&gt; null then
		//Need better wat to do this...
		strSeal := formatSealMsk(SealType_Customs, _camProtocol.camGroup, _ti.CM_Container, sealParty);
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; sealParty &amp; singleQuote);
	endif;
	
	/*// no inheritMethod!
	//23 Mar 2012	NDL	Par 29144
	if _contentsStatus = '4' then
		//Empty Containers should never include seals data...
		return;
	endif;
	
	strSeal := self.formatSeal(null, _camProtocol.camGroup, _ti.CM_Container);

	if strSeal &lt;&gt; null then //ccms1393
		plus 		:= _camProtocol.elementSeparator;	
		singleQuote	:= _camProtocol.segmentTerminator;	
		
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);		
	endif;*/
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="f2fd0d1a-84db-48dd-bead-22b7a6e4b8bc">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
//
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 10/02/2011	cnwcs5		CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 10 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - user defined special characters
// 30/05/2016	cnwdap1		TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 07/092/107	jlgdap1		TFS 6880 POL CODECO Failure in EDI Server
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	strSeal 		: String;
	ti			 	: CM_TrackedItem;
	contentsStatus 	: String;
	foundMatch      : Boolean;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
// MSK
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contentsStatus 	:= self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);

	// CCMS 5158 treat generators differently for Maersk
	if ti.cargoType = TI_CargoType_Generator then
		// EQD segment
		//self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", ti.id.trimRight, ti.getISOType(), '102', '5', null, null, "4"); // par 27460 09/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
		isoCode := ti.CM_Generator.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
		self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", ti.id.trimRight,fIsoCode, '102', '5', null, null, "4"); //23/08/2017 cnwma1 TFS #5834
	else
		// EQD segment
		//23/08/2017 cnwma1 TFS #5834
		if ti.isKindOf(CM_Container) then
			isoCode := ti.CM_Container.isoType;
			fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
			self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, self.imExStatusToString(ti),contentsStatus); //23/08/2017 cnwma1 TFS #5834 	
		else
			self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", ti.id.trimRight, ti.getISOType(), '102', '5', null, self.imExStatusToString(ti),contentsStatus); // par 27460 09/05/2011 cnwcs5 	
		endif;
	endif;

	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group3,  ti);	// par 27460 cnwcs5

	// RFF+CN
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group3, ti);	// par 27460 cnwcs

	//PAR 13944 CCMS 1065 cnwrs1 changes for Wellington only
	// RFF+ABT
	self.makeMessageRFF_ABT (_camProtocol, _camMessage.group3,  _camMessage.activity, ti);	// par 27460 cnwcs5

	// DTM - transaction date/time
	self.makeDTMSegment(_camProtocol, _camMessage.group3, '203', _transaction.dateTime, "203"); // TFS 53754
		if includeVGM and
		   _camProtocol.getIncludeExtraVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group3, ti);					// TFS 4492
	endif;

	// LOC segments
	self.makeMessageLOC (_camProtocol, _camMessage.group3, _camMessage.activity, ti);	// par 27460 cnwcs5

	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3,ti,null); //epr par 37551 TFS 1429 16/2/16

	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group3, ti);		// par 27460 09/05/2011 cnwcs5

	// TMP Segment
	self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 09/05/2011 cnwcs5 				

	//the SEL for the seal number
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group3, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608

	
	// Dangerous Goods
	self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
	
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group3, 'RG', ti);	// par 27460 09/05/2011 cnwcs5

	// NAD+CF
	self.makeMessageNAD_CF (_camProtocol, _camMessage.group3, ti);	// par 27460 cnwcs5	
	
	// TFS 6880 remove all extra VGM data for Maersk CODECO
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group3, ti);									// TFS #2061
	endif;																								// TFS #2061
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="3475de1f-8367-4e88-b068-8d49352471d6">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	
begin
	return self.outputFileMessage (_camTaskHistory, 
									self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), null, 
									_protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, _camTaskHistory.runDateTime),
									_coll);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
