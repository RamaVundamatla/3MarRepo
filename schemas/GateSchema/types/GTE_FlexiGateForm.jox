    <JadeMethod name="cmbDriver_displayEntry" id="024c6da3-535b-445a-829e-e352bd2a8526">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDriver_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Date		Who		Reason
26 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	driver : CM_DriverDetails;
begin
	driver:=obj.CM_DriverDetails;
	if driver = null then
		return null;
	endif;
	
	if driver.myTerminal &lt;&gt; self.myTerminal then
		return null;
	endif;
	
	if driver.code &lt;&gt; driver.name then
	
		return driver.code &amp; " " &amp; driver.name;
	else
		return driver.code;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
