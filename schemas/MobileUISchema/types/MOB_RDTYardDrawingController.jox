    </JadeMethod>
    <JadeMethod name="calcMaxRowsCols" id="15a3d972-dd44-4282-a50f-8d06d2722e91">
        <updating/>
        <source>calcMaxRowsCols() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.isLandscape then
		if self.isLocationInGriddedArea(self.myTargetLocation) then
			if self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				self.maxGridRow := self.myGridArea.numberOfRows;
				self.maxGridCol := self.myGridArea.numberOfColumns;
			else
				self.maxGridRow := self.myGridArea.getHeightOfStack();
				self.maxGridCol := self.myGridArea.numberOfColumns;				
			endif;
		else
			self.maxGridRow := self.myDisplayBuilder.getMaxGridRow();
			self.maxGridCol := self.myDisplayBuilder.getMaxGridCol();			
		endif;
	else
		if self.isLocationInGriddedArea(self.myTargetLocation) then
			if self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				self.maxGridRow := self.myGridArea.numberOfColumns;
				self.maxGridCol := self.myGridArea.numberOfRows;
			else
				self.maxGridRow := self.myGridArea.numberOfColumns;
				self.maxGridCol := self.myGridArea.getHeightOfStack();			
			endif;
		else
			self.maxGridRow := self.myDisplayBuilder.getMaxGridCol();
			self.maxGridCol := self.myDisplayBuilder.getMaxGridRow();		
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcNumFullyVisibleGridCols" id="65067d02-45ab-46a4-b8c5-17c134005499">
        <source>calcNumFullyVisibleGridCols() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	maxX,
	gridWidth : Real;
	numFullyVisibleCols : Integer; 
begin
	if self.flipH then
		maxX := self.myDrawingFrame.clientWidth() + self.hScrollOffset - self.rightOffset;
	else
		maxX := self.myDrawingFrame.clientWidth() - self.hScrollOffset - self.leftOffset;
	endif;
	
	gridWidth := self.getGridWidth();
	
	// Remember drawing portrait for now, so width and length are swapped
	numFullyVisibleCols := (maxX div gridWidth).Integer;
	
	return numFullyVisibleCols;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcNumFullyVisibleGridRows" id="2cac7b7e-f159-4b08-92e2-4201785baa92">
        <source>calcNumFullyVisibleGridRows() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	maxY,
	gridHeight : Real;
	numFullyVisibleRows : Integer; 
begin
	if self.flipV then
		maxY := self.myDrawingFrame.clientHeight() + self.vScrollOffset - self.bottomOffset;
	else
		maxY := self.myDrawingFrame.clientHeight() - self.vScrollOffset - self.topOffset;
	endif;
	
	gridHeight := self.getGridHeight();
	
	// Remember drawing portrait for now, so width and length are swapped
	numFullyVisibleRows := (maxY div gridHeight).Integer;

	return numFullyVisibleRows;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcNumFullyVisibleGridRowsOLD" id="c7675eff-f661-4c9d-b32e-eed8e2e9ee84">
        <source>calcNumFullyVisibleGridRowsOLD() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	maxY,
	gridHeight : Real;
	numFullyVisibleRows : Integer; 
begin
	//maxY := self.myDrawingFrame.height;
	maxY := self.myDrawingFrame.height - self.vScrollOffset;
	
	gridHeight := self.getGridHeight();
	
	// Remember drawing portrait for now, so width and length are swapped
	numFullyVisibleRows := (maxY div gridHeight).Integer;

	return numFullyVisibleRows;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcViewRowsColsFromLC" id="e3e4fdb0-7c3d-4a07-be7c-f4523c979751">
        <updating/>
        <source>calcViewRowsColsFromLC() updating, protected;

/*

Purpose:			
	Adjust rows and columns so that the current location is visible within the viewport
Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars

begin
	// Calculate top row to display from, based on how many can fit in the view
	self.topGridRow := self.rowLC - (numGridRowsFit / 2).Integer;
	if self.topGridRow &lt; 1 then
		self.topGridRow := self.rowLC;
	elseif self.topGridRow &gt; self.maxGridRow then
		self.topGridRow := self.maxGridRow;
	endif;
	
	
	// Calculate bottom row to display from, based on how many can fit in the view
	//self.bottomRow := self.row + (numRowsFit / 2).Integer;
	//if self.bottomRow &gt; self.maxRow then
	//	self.bottomRow := self.maxRow;
	//endif;

	self.bottomGridRow := self.topGridRow + self.numGridRowsFit-1;
	if self.bottomGridRow &gt; self.maxGridRow then
		self.bottomGridRow := self.maxGridRow;
	elseif self.bottomGridRow &lt; 1 then
		self.bottomGridRow := 1;
	endif;


	// Adjust for special case, where a single row can't fit in the viewport
	if self.numGridRowsFit = 0 then
		self.topGridRow := self.rowLC;
		self.bottomGridRow := self.rowLC;
	endif;

	
	// Calculate left column to display from, based on how many can fit in the view
	self.leftGridCol := self.colLC - (numGridColsFit / 2).Integer;
	if self.leftGridCol &lt; 1 then
		self.leftGridCol := self.colLC;
	elseif self.leftGridCol &gt; self.maxGridCol then
		self.leftGridCol := self.maxGridCol;
	endif;
		
	// Calculate right column to display from, based on how many can fit in the view
	//self.rightCol := self.col + (numColsFit / 2).Integer;
	//if self.rightCol &gt; self.maxCol then
	//	self.rightCol := self.maxCol;
	//endif;
	
	self.rightGridCol := self.leftGridCol + self.numGridColsFit-1;
	if self.rightGridCol &gt; self.maxGridCol then
		self.rightGridCol := self.maxGridCol;
	elseif self.rightGridCol &lt; 1 then
		self.rightGridCol := 1;
	endif;

	// Adjust for special case, where a single column can't fit in the viewport
	if self.numGridColsFit = 0 then
		self.leftGridCol := self.colLC;
		self.rightGridCol := self.colLC;
	endif;

	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcViewSizes" id="49de4f7f-9072-4aca-b24e-328e29075bd1">
        <updating/>
        <source>calcViewSizes() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.calcMaxRowsCols();
	
	// Calculate the number of rows we can fit on screen
	self.numGridRowsFit := self.calcNumFullyVisibleGridRows();
	if self.numGridRowsFit &gt; self.maxGridRow then
		self.numGridRowsFit := self.maxGridRow;
	endif;
	
	// Calculate the number of columns we can fit on screen
	self.numGridColsFit := self.calcNumFullyVisibleGridCols();
	if self.numGridColsFit &gt; self.maxGridCol then
		self.numGridColsFit := self.maxGridCol;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="canBottomRowFitOnScreen" id="d89eee04-b7ee-4e1c-b0e6-a9b0d1012c16">
        <source>canBottomRowFitOnScreen( _row : Integer) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.flipV then
		if _row &gt; self.topGridRow - self.numGridRowsFit then
			return true;
		else
			return false;
		endif;
	else
		if _row &lt; self.topGridRow + self.numGridRowsFit then
			return true;
		else
			return false;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
