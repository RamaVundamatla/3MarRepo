    <JadeMethod name="initializeAgents" id="50c2c3b1-f5dc-4a14-9587-e2efa29d2dd9">
        <updating/>
        <source>initializeAgents() updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
/*
Date		Who		Reason
21 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/
vars

begin

	inheritMethod();
	if self.myTrxRT = null then
		create self.myTrxRT transient;
	endif;
	
	if self.myUtlRT = null then
		create self.myUtlRT transient;
	endif;
	
	if self.myEnquiryAgent = null then
		create self.myEnquiryAgent transient;
	endif;
	
	
	if self.myValRT = null then
		create self.myValRT transient;
	endif;
	
	// Make sure Mobile Apps use silent locking PAR 17377
	app.myPassport.useSilentLockExHandler := true;
	app.myPassport.silentLockRetries := 3;
	
	app.myPassport.silentDeadlockLimit := 3;
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeComm" id="b2b2e5c3-013f-48de-9397-20d9a28262a4">
        <source>initializeComm(_stateInfo : DTO_StateInfo input) : Boolean;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

	mediator	: CM_RadioTelemetryMediator;
begin


	if currentSession.myWebServerAgent = null then
		_stateInfo.errorString	:= 'Session Web Server Agent reference null.';
		_stateInfo.guiState		:= RadioTelemetryAgent.LoggedOff;
		return false;
	endif;
	
	if currentSession.myWebServerAgent.myMediator = null then
		_stateInfo.errorString	:= 'Session Mediator reference is null.';
		_stateInfo.guiState		:= RadioTelemetryAgent.LoggedOff;
		return false;
	endif;
	
	mediator := currentSession.myWebServerAgent.myMediator;
	app.myPassport.setMyTerminal(app.myRoot.allTerminals[mediator.terminalCode]);
	app.myPassport.setMyUser(mediator.user);

	return true;

end;</source>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendHeyYouMessage" id="5822f725-ff90-4059-8130-1f9eebbe807f">
        <source>sendHeyYouMessage(_machineName : String; _portNumber : Integer; _message : String);
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpStr	: String;
	
begin
	tmpStr	:=	'jadehttp.tcp://' &amp;
				_machineName &amp; ':' &amp;
				_portNumber.String &amp;
				'//jadehttp.dll?JMMobileListener&amp;serviceName=JMTMobileListener';



//	self.myMobileListener.setEndpointURL(tmpStr);


//	self.myMobileListener.sendHeyYouMessage(_message);
end;</source>
        <Parameter name="_machineName" type="String"/>
        <Parameter name="_portNumber" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
