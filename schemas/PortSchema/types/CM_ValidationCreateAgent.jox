    <JadeMethod name="valTempReading" id="fe9c86f6-4935-4a30-85f4-26d1ba0f5e1e">
        <source>valTempReading(_tempParams: CMIF_TempReading);
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	params		: CMIF_TempReading;
	//today		: Date;
begin
	params := _tempParams;
	if params.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam,method.name,'tempParams.myContainer','myContainer',null);
		return;
	endif;

	if not params.dateTime.isValid then
		app.raiseCMException2(ERR_INVALID_VALUE, "date/time", "Make sure the date and time fields are valid.", 'dateTime',null);
		return;
	endif;
	
	//if not params.dateTime.date &lt;= today then
	if not params.dateTime.date &lt;= app.actualTimeServer().date then	// 16/03/2010 cnwar2 #23202
		app.raiseCMException2(ERR_INVALID_VALUE, "date", "You cannot add a temperature reading later than today.", 'dateTime',null);
		return;
	endif;
	
	//cnwmc5 - 20 Oct 2015 - PAR 37057
	if params.myTrackedItem &lt;&gt; null and params.myTrackedItem.getExternalMonitoring() then
		if params.myTerminal.getConfig(ReeferExternalCauseError).Boolean then
			app.raiseCMException(Temp_not_recorded_external, null, null);
		endif;
		//app.raiseCMWarning(Temp_not_recorded_external, null, null, params.myTrackedItem);
		return;
	endif;
end;</source>
        <Parameter name="_tempParams" type="CMIF_TempReading"/>
    </JadeMethod>
