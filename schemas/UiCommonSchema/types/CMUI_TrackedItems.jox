    <JadeMethod name="addExceptionHandler" id="4ee77a6e-7557-4f93-b5fd-216d23becb8a">
        <updating/>
        <source>addExceptionHandler(exObj : Exception; _passport : CM_Passport input) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index : Integer;
	obj   : Object;

begin

	if exObj.isKindOf(CM_Exception) then
		if exObj.CM_Exception.isWarning then
			app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
			return Ex_Continue;
		endif;
		
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		
		if exObj.continuable then
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;
	
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTIs" id="5d7e022b-b492-4340-9d2b-63ee16000740">
        <updating/>
        <source>addTIs() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	Delimeter = ",";
vars
	frm						: Form;
	pxyBulkRelease			: CM_BulkRelease;
	allSelectedItems		: CM_TIArray;
	obj						: Object;
	row						: Integer;
	result 					: Boolean;
	ti						: CM_TrackedItem;
	allCargoNums				: StringArray;
		cargoNum,
		cargoNums,
		isoString : String;
	searchCargoIds		: Boolean;
	isoType 			: CM_ISOType;
	
begin
	frm := self.myParentForm;
	if frm = null  then
		app.msgBox(app.getErrorString(Edit_screen_closed) &amp;
					app.getErrorString(Drag_drop),app.getErrorString(Error_parent_screen_closed), MsgBox_Exclamation_Mark_Icon); // Par 16947 AER 21/07/2008
		return;
	endif;

	if not frm.IF_CMUI_TrackedItems.validateParentState then
		return;
	endif;
	
	searchCargoIds:=self.shtIDs.isMySheetVisible;
	
	
	if searchCargoIds then
		if self.txtCargoIds.text.trimBlanks = null then
			app.msgBox(app.getErrorString(CARGO_NOT_SELECTED),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);//  Par 16947 AER 21/07/2008
			return;
		else
			//try to just add the enter ids straight away
			create allCargoNums transient;
			self.txtCargoIds.text.getTokensForDelimiter(Delimeter,allCargoNums);
			create allSelectedItems transient;
			self.doTryToAddSearchTIs(allCargoNums,allSelectedItems);
			
			if self.cmbISOType.listIndex &gt; 0 then
				isoType:= self.cmbISOType.itemObject[self.cmbISOType.listIndex].CM_ISOType;
			endif;
			if isoType &lt;&gt; null then
				isoString:=isoType.code;
			endif;
			cargoNums:=allCargoNums.concatenate(",");
			if allCargoNums.size &gt; 0  then
				app.msgBox(app.getErrorString3(Find_Onsite_Containers_ISOType,cargoNums,self.cmbVoyage.text, isoString),app.getErrorString(CMUI_Items_Found), MsgBox_Exclamation_Mark_Icon);//  Par 16947 AER 21/07/2008
				
			endif;
				
		endif;

	
	else
	
		create allSelectedItems transient;
		self.tblListAll.allSelectedObjects.copy(allSelectedItems);
		if allSelectedItems.size = 0  then
			app.msgBox(app.getErrorString(CARGO_NOT_SELECTED),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);//  Par 16947 AER 21/07/2008
			return;
		endif;
	endif;	
	
	
	result :=frm.IF_CMUI_TrackedItems.addTrackedItems(allSelectedItems);
	
	if not result then
		return;
	endif;
	
	
	foreach obj in allSelectedItems do
		row := -1;
		self.tblListAll.findObjectInRow(obj,row);
		if row &gt; 0 then
			self.tblListAll.removeItem(row);//this also removes from allSelectedObjects collection
		endif;
	endforeach;
	
	
	foreach ti in allSelectedItems do
		if not self.allTrackedItems.includes(ti) then
			self.allTrackedItems.add(ti);
			self.tblList_ShowTI(ti, 0,self.tblList);
		endif;
	endforeach;
	
epilog
	delete allSelectedItems;
	if allCargoNums &lt;&gt; null then
		delete allCargoNums;
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
