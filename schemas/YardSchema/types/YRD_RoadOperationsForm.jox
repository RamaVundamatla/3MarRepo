    <JadeMethod name="doReturnWorkEntry" id="018e327c-9aad-44d7-8640-8d9ac9786874">
        <updating/>
        <source>doReturnWorkEntry()updating;
//--------------------------------------------------------------
//Created: 11 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	result : Integer;
begin

	app.mousePointer := MousePointer_HourGlass;
		
	if self.myCurrentWLE = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEReturnWorkEntry(self.myCurrentWLE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Return Work Entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
				
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
