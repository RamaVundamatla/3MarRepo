        <source>getDefaultQFCamTransTemplate() : CMQF_CamTransactionTemplate protected;
/* ---------------------------------------------------------------------------
Created:	16 October 2009	by cnwvu1

Purpose:	Getting default "None" Filter Transaction Template for "User Defined Report"
			CAM protocols. PAR 20994
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	templDict	: CMQF_CamTransactionTemplatDict;
	
begin

	templDict := app.myRoot.allCamProtocolDescs[CM_CamUserDefRepDesc.UserDefinedDescName].CM_CamUserDefRepDesc.allQFCamTransactionTemplates;
	
	if templDict = null then
		return null;
	endif;
	
	return templDict[QFCam_None];
	
end;</source>
