<Class name="CM_WOPackParentWLE" id="9ba091f3-cc00-4676-b7c6-1f1a917db6ee">
    <superclass name="CM_WOPackWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getChildren" id="272102d8-8def-493b-b2a2-580cd5e9aa52">
        <source>getChildren(_childColl: CM_TISet input);
// -----------------------------------------------------------------------------
//
// Purpose:		Get the cargo that is going to be packed into containers
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// Date			Who		Reason
// 10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// -----------------------------------------------------------------------------

vars
	wodPack : CM_WodPack;
	
begin
	wodPack := self.getWorkOrderTIDtl();
	
	if wodPack &lt;&gt; null then
		wodPack.allPackingTIs.copy(_childColl);
	endif;
	
epilog

end;</source>
        <Parameter name="_childColl" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeDesc" id="1b0133a9-cb96-4dbd-8eb6-1172865a462a">
        <source>getTaskTypeDesc(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin
	return 'Pack Parent';

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
