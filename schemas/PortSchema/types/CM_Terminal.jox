    <JadeMethod name="createBOL" id="1dbe20de-d465-43ed-a292-959b7980975e">
        <source>createBOL(_class : Class; pTransient : Boolean) : CM_BOL;
// ---------------------------------------------------------------------------
// Created:     03 January 2001 by cnwrs2
//
// Purpose:     Creates a tracked item of the type specified
//
// Parameters:  The TI type to create.
//				Flag to indicate if ti created is persistent or transient
//
// Returns:     The TI created.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bol		: CM_BOL;
	class	: Class;

begin

//	class := pBOLType.myClassToCreate;
	
	if pTransient then
		create bol as _class transient;
	else
		create bol as _class persistent;
	endif;
	
	return bol;
	
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="pTransient" type="Boolean"/>
        <ReturnType type="CM_BOL"/>
