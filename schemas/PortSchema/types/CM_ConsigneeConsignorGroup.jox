<Class name="CM_ConsigneeConsignorGroup" id="073265e9-1e91-4c33-ba0f-1bc46dca34db">
    <superclass name="CM_Group"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allConsigneeConsignors" id="061caf81-8a59-40d3-92da-86574ad1bd66">
        <transientToPersistentAllowed/>
        <type name="CM_ConsignByCodeDict"/>
        <access>readonly</access>
        <text>Only man/auto for creating proxies - should be auto</text>
        <Inverse name="CM_ConsigneeConsignor::myConsignGroup"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="d0d3a4cc-bc83-4c54-9b76-ac06f5f7f5db">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allConsignGroups"/>
    </ExplicitInverseRef>
    <JadeMethod name="checkEntriesDict" id="7a01ba12-017b-427a-8210-2cbcbba7bfb3">
        <source>checkEntriesDict();

vars
	consign:CM_ConsigneeConsignor;
	object:Object;
begin
	if entries.size &lt;&gt; allConsigneeConsignors.size then
		app.writeStatement( "Port size mismatch by " &amp; (entries.size - allConsigneeConsignors.size).String);
	endif;
	foreach object in entries do
		consign := object.CM_ConsigneeConsignor;
		if not allConsigneeConsignors.includes(consign) then
			app.writeStatement( "Port " &amp;  consign.code &amp; " is not in old entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
	foreach consign in allConsigneeConsignors do
		if not entries.includes(consign) then
			app.writeStatement( "Port " &amp;  consign.code &amp; " is not in new entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="4c77e2c3-0547-4a65-96e3-ace6e74324ad">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	cc  : CM_ConsigneeConsignor;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach cc in self.allConsigneeConsignors do
		if tmpStr = null then
			tmpStr := cc.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; cc.code;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Consignee/onsignors' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c2dc2a26-a3d7-4d67-b976-6064fa4247e3">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 01 September 2003
//
//-----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	consigGrp	:	CM_ConsigneeConsignorGroup;
	completedOK	: Boolean;
begin
	consigGrp := inheritMethod();
	
	self.allConsigneeConsignors.copy(consigGrp.allConsigneeConsignors);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return consigGrp;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete consigGrp;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0ba4c0d2-10b6-4eb4-a6e0-bcf2c60bb164">
        <updating/>
        <source>setForCreate(pProxyConsigneeConsignorGroup:CM_ConsigneeConsignorGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyConsigneeConsignorGroup);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyConsigneeConsignorGroup" type="CM_ConsigneeConsignorGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7276dcab-af3b-45b2-94f3-7dfc1ad884a5">
        <updating/>
        <source>setForUpdate( pProxyConsigneeConsignorGroup : CM_ConsigneeConsignorGroup ) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	consignee	:	CM_ConsigneeConsignor;
begin
	self.code := pProxyConsigneeConsignorGroup.code.trimBlanks;
	self.description := pProxyConsigneeConsignorGroup.description.trimBlanks;

//Clear and update the collection from the other end of the relationship (avoids duplicate entry exception)	
	self.allConsigneeConsignors.clear;
	foreach consignee in pProxyConsigneeConsignorGroup.allConsigneeConsignors do
		consignee.setMyConsignGroup(self);
	endforeach;
	

end;</source>
        <Parameter name="pProxyConsigneeConsignorGroup" type="CM_ConsigneeConsignorGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="b51660b3-19ea-4bad-abf3-bb7b9c1ed681">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="31326d4a-9e85-4764-b637-96c49e780d7a">
        <updating/>
        <source>setProxy( pCode, 
		  pDescription 	: 	String;
		  pConsigCol	:	CM_ConsignByCodeDict) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pCode[1:4];
	self.description 	:= pDescription[1:30];
	self.myRoot 		:= app.myRoot;
	
	self.allConsigneeConsignors.clear;
	pConsigCol.copy(self.allConsigneeConsignors);
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pConsigCol" type="CM_ConsignByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="68859235-917a-4d7f-80ec-7aa6823dcfef">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

// cnwdvb1 25 June 2003 

vars
	propName	: String;

begin

	propName := _property.name;

	if	propName = CM_Group::isAvailableForEntry.name or
		propName = CM_Group::colour.name or
		propName = CM_Group::reportGroupOrder.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="33824574-c43b-4239-b098-3f94d93e8ba8">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allConsignGroups[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="0f1bd7a3-6c2b-451c-a229-9a24f72e1a2a">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allConsigneeConsignors.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Consignee/Consignor", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="441f86b3-f979-41fe-81fd-711244c6111f">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin
	if self.code = null then
		str := app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionSingular, 'Consignor'); 
	//	app.raiseCMException1(REQUIRED_FIELD, 'Consignee/' &amp; str &amp; ' Group Code', null, null);
		app.raiseCMException1(Input_required_field_congGrpCd,  str , null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
		str := app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionSingular, 'Consignor'); 
//		app.raiseCMException1(REQUIRED_FIELD, 'Consignee/' &amp; str &amp; ' Group Description', null, null);
		app.raiseCMException1(Input_required_field_conGrpDes, str , null, null); // cnwdb2	PAR 35364


	endif;
end;</source>
    </JadeMethod>
</Class>
