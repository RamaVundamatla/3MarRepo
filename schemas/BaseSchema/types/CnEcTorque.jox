    <JadeMethod name="convertBaseToTarget" id="83c2c3a1-cc11-4c7b-a699-37f115a51f7f">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.DYNE_CENTIMETRES then
		convertedMeasure	:=	pMeasure * 10000000;

	elseif pUnitTo = self.GRAM_FORCE_CENTIMETRES then
		convertedMeasure	:=	pMeasure / 0.0000980665;

	elseif pUnitTo = self.KG_FORCE_CENTIMETRES then
		convertedMeasure	:=	pMeasure / 0.0980665;

	elseif pUnitTo = self.KG_FORCE_METRES then
		convertedMeasure	:=	pMeasure / 9.80665;

	elseif pUnitTo = self.NEWTON_CENTIMETRES then
		convertedMeasure	:=	pMeasure * 100;

	elseif pUnitTo = self.NEWTON_METRES then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.OUNCE_FORCE_INCHES then
		convertedMeasure	:=	pMeasure * 141.612;

	elseif pUnitTo = self.POUND_FORCE_FEET then
		convertedMeasure	:=	pMeasure / 1.355818;

	elseif pUnitTo = self.POUND_FORCE_INCHES then
		convertedMeasure	:=	pMeasure / 0.112984;

	elseif pUnitTo = self.POUNDAL_FEET then
		convertedMeasure	:=	pMeasure / 0.042140;

	elseif pUnitTo = self.TON_UK_FORCE_FEET then
		convertedMeasure	:=	pMeasure / 3037.032;

	elseif pUnitTo = self.TON_US_FORCE_FEET then
		convertedMeasure	:=	pMeasure / 2711.636;

	elseif pUnitTo = self.TONNE_FORCE_METRES then
		convertedMeasure	:=	pMeasure / 9806.65;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of torque to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="1f94e01e-8520-4b23-8979-15fde42719eb">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.DYNE_CENTIMETRES then
		convertedMeasure	:=	self.measure / 10000000;

	elseif pUnitFrom = self.GRAM_FORCE_CENTIMETRES then
		convertedMeasure	:=	self.measure * 0.0000980665;

	elseif pUnitFrom = self.KG_FORCE_CENTIMETRES then
		convertedMeasure	:=	self.measure * 0.0980665;

	elseif pUnitFrom = self.KG_FORCE_METRES then
		convertedMeasure	:=	self.measure * 9.80665;

	elseif pUnitFrom = self.NEWTON_CENTIMETRES then
		convertedMeasure	:=	self.measure / 100;

	elseif pUnitFrom = self.NEWTON_METRES then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.OUNCE_FORCE_INCHES then
		convertedMeasure	:=	self.measure / 141.612;

	elseif pUnitFrom = self.POUND_FORCE_FEET then
		convertedMeasure	:=	self.measure * 1.355818;

	elseif pUnitFrom = self.POUND_FORCE_INCHES then
		convertedMeasure	:=	self.measure * 0.112984;

	elseif pUnitFrom = self.POUNDAL_FEET then
		convertedMeasure	:=	self.measure * 0.042140;

	elseif pUnitFrom = self.TON_UK_FORCE_FEET then
		convertedMeasure	:=	self.measure * 3037.032;

	elseif pUnitFrom = self.TON_US_FORCE_FEET then
		convertedMeasure	:=	self.measure * 2711.636;

	elseif pUnitFrom = self.TONNE_FORCE_METRES then
		convertedMeasure	:=	self.measure * 9806.65;

	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of torque to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="0e418323-5aca-4431-8c2f-ed91ea042cd2">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.DYNE_CENTIMETRES);
	pAllUnits.add(self.GRAM_FORCE_CENTIMETRES);
	pAllUnits.add(self.KG_FORCE_CENTIMETRES);
	pAllUnits.add(self.KG_FORCE_METRES);
	pAllUnits.add(self.NEWTON_CENTIMETRES);
	pAllUnits.add(self.NEWTON_METRES);
	pAllUnits.add(self.OUNCE_FORCE_INCHES);
	pAllUnits.add(self.POUNDAL_FEET);
	pAllUnits.add(self.POUND_FORCE_FEET);
	pAllUnits.add(self.POUND_FORCE_INCHES);
	pAllUnits.add(self.TONNE_FORCE_METRES);
	pAllUnits.add(self.TON_UK_FORCE_FEET);
	pAllUnits.add(self.TON_US_FORCE_FEET);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="bdf78d7a-fd32-4e5c-adb8-8f8761a6fa77">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.DYNE_CENTIMETRES then
		return "Dyne-Centimetres";
	elseif pUnit = self.GRAM_FORCE_CENTIMETRES then
		return "Grams Force per Centimetre";
	elseif pUnit = self.KG_FORCE_CENTIMETRES then
		return "Kilograms Force per Centimetre";
	elseif pUnit = self.KG_FORCE_METRES then
		return "Kilograms Force per Metre";
	elseif pUnit = self.NEWTON_CENTIMETRES then
		return "Newton Centimetres";
	elseif pUnit = self.NEWTON_METRES then
		return "Newton Metres";
	elseif pUnit = self.OUNCE_FORCE_INCHES then
		return "Ounce Force per Inch";
	elseif pUnit = self.POUNDAL_FEET then
		return "Poundal Feet";
	elseif pUnit = self.POUND_FORCE_FEET then
		return "Pounds Force per Foot";
	elseif pUnit = self.POUND_FORCE_INCHES then
		return "Pounds Force per Inch";
	elseif pUnit = self.TONNE_FORCE_METRES then
		return "Tonnes Force per Metre";
	elseif pUnit = self.TON_UK_FORCE_FEET then
		return "Tons (UK) Force per Foot";
	elseif pUnit = self.TON_US_FORCE_FEET then
		return "Tons (US) Force per Foot";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Torque to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
