    <JadeMethod name="setupCargoBtns" id="a3d1150d-2e0c-4570-8411-fd0ec8e8d6c6">
        <updating/>
        <source>setupCargoBtns( _allowUpdate : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215
14 Oct 2014	NDL	Par 35040

*/

vars

	allTis : CM_TIArray;
	posWidth : Real;
	btnLeft : Real;
	btnTop : Real;
	btnHeight : Real;
	btnWidth : Real;
	wagon : CM_Wagon;
	btn : Button;
	index : Integer;
	pos : Integer;
	ti : CM_TrackedItem;
	//cargoLengthFt : Real;
	primWagCont : CM_WagonController;
	primWagContOffset : Real;
	heightIndex : Integer;
	btn2 : Button;
	
begin

	
	btnHeight := self.frmCargoBtns.height;
	btnTop := 0;
	
	
	wagon := self.cmbWagon.listObject.CM_Wagon;
	self.setMultiStackWagon( wagon );
	
	// find or create a button for each container on the wagon.
	if wagon &lt;&gt; null then
	
		if wagon.isBoxcar then	//21 Mar 2013	NDL	Par 31278
		
			btnWidth := self.frmCargoBtns.width;
			//primWagCont := wagon.allLocationsControllers.first;
			primWagCont := wagon.allLocationsControllersArray[1];	//04 Dec 2014	NDL	Par 35345
			index := 1;
			
			btn := self.btnCargo.getControl(index).Button;
			if btn = null then
				btn := self.btnCargo.loadControl(index).Button;
				self.maxCargoBtnCount := index;
			endif;
			
			if _allowUpdate then
				btn.backColor := self.getButtonColour(ti, wagon);
			else
				btn.backColor := White;
			endif;
			
			btn.parent := frmCargoBtns;
			btn.tabStop := false;
			btn.visible := true;
			btn.enabled := false;
			btn.move(	btnLeft,
						btnTop,
						btnWidth,
						btnHeight );
			self.drawBoxcarBody(btn, wagon, btnLeft, btnTop, btnWidth, btnHeight );
			btn.zOrder(1);
		
		
		elseif wagon.isFlatcar or wagon.isWellcarVisit then
	
			posWidth := ( self.frmCargoBtns.width / wagon.allLocationsControllersArray.size );	// a std 10 foot position width...
			
			create allTis transient;
			wagon.getAllTrackedItems(self.myMobileGenericAgent.inward, allTis, false);
			
			foreach ti in allTis do
				//cargoLengthFt := ti.getActualLength;
				//btnWidth := ( cargoLengthFt / 10 ) * posWidth;
				btnWidth := wagon.getLengthInUnitsForWagon( ti ) * posWidth;
				//if ti.myPrimaryActualLocation = null or not ti.myPrimaryActualLocation.isKindOf(CM_WagonController) then
				if ti.myPrimaryActualLocation = null or not ti.myPrimaryActualLocation.isWagon then//27 May 2013	NDL	Part of Boxcar conversion
					continue;
				endif;
				primWagCont := ti.myPrimaryActualLocation.CM_WagonController;
				heightIndex := ti.myPrimaryActualLocation.CM_WagonController.allTrackedItems.indexOf(ti);
				index := index + 1;
				if primWagCont.offsetFlexi &gt; 0 then
					btnLeft := (( wagon.allLocationsControllersArray.indexOf(primWagCont) - 1 ) + primWagCont.offsetFlexi / 10 ) * posWidth;
				else
					btnLeft := ( wagon.allLocationsControllersArray.indexOf(primWagCont) - 1 ) * posWidth;
				endif;
				self.hideOverlappedPriorPosi(primWagCont,heightIndex);
				if heightIndex = 2 then
					btn := self.btnCargo2.getControl(index).Button;
					if btn = null then
						btn := self.btnCargo2.loadControl(index).Button;
						self.maxCargoBtnCount := index;
					endif;
				else
					btn := self.btnCargo.getControl(index).Button;
					if btn = null then
						btn := self.btnCargo.loadControl(index).Button;
						self.maxCargoBtnCount := index;
					endif;
				endif;
				btn.clearGraphics;	//20 Mar 2013	NDL	Par 31278
				if _allowUpdate then
					btn.backColor := self.getButtonColour(ti, wagon);
				else
					btn.backColor := White;
				endif;
				btn.userObject := ti;
				if heightIndex = 2 then
					btn.parent := frmCargoBtns2;
				else
					btn.parent := frmCargoBtns;
				endif;
				btn.tabStop := false;
				btn.visible := true;
				//btn.enabled := _allowUpdate;
				btn.enabled := _allowUpdate;
				btn.move(	btnLeft,
							btnTop,
							btnWidth,
							btnHeight );
				self.setTextOnCargoButton(btn, ti.id &amp; CrLf &amp; ti.getISOType());	// 	27016 04/2011 show ISO type as well as id where possible
				btn.zOrder(1);
	
			endforeach;
			
		elseif wagon.isSkeletonCar then
			btnWidth := self.frmCargoBtns.width;
			//primWagCont := wagon.allLocationsControllers.first;
			primWagCont := wagon.allLocationsControllersArray[1];
			index := 1;
			
			btn := self.btnCargo.getControl(index).Button;
			if btn = null then
				btn := self.btnCargo.loadControl(index).Button;
				self.maxCargoBtnCount := index;
			endif;
			
			if _allowUpdate then
				btn.backColor := self.getButtonColour(ti, wagon);
			else
				btn.backColor := White;
			endif;
			//btn.drawRectangle(btnLeft, btnTop, btnWidth, btnHeight, btn.backColor);
			btn.borderStyle := BorderStyle_None;
			
			btn.parent := frmCargoBtns;
			btn.tabStop := false;
			btn.visible := true;
			btn.enabled := false;
			btn.move(	btnLeft,
						btnTop,
						btnWidth,
						btnHeight );
			self.drawSkeletonCarArms(btn, wagon, btnLeft, btnTop, btnWidth, btnHeight);
			btn.zOrder(1);
		
		endif;
				
	endif; 
	
	//hide the excess buttons if they show a wagon with less positions.
	if self.maxCargoBtnCount &gt; index then
		index := index + 1;
		foreach pos in index to self.maxCargoBtnCount do
			btn := self.btnCargo.getControl(pos).Button;
			if btn &lt;&gt; null then
				btn.visible := false;
			endif;
			if self.multiStackWagon then
				btn2 := self.btnCargo2.getControl(pos).Button;
				if btn2 &lt;&gt; null then
					btn2.visible := false;
				endif;
			endif;
		endforeach;
	endif; 
	
	
	if not self.multiStackWagon then
		foreach pos in 1 to self.maxCargoBtnCount do
			btn2 := self.btnCargo2.getControl(pos).Button;
			if btn2 &lt;&gt; null then
				btn2.visible := false;
			endif;
		endforeach;
	endif;

epilog

	delete allTis;
	
end;</source>
        <Parameter name="_allowUpdate" type="Boolean"/>
    </JadeMethod>
