	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.mulSelect1.setSelected(null);	//PAR 19074, CCMS 1080 MAy 2009 cnwvu1

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="0b04fd57-0436-4b2d-b69c-94c28a3f1d2d">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CommodityMaintTbl);
	//theForm.zAddColumn('Commodity Id', 'code', Table.InputType_None, 25);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 60);
	//theForm.zAddColumn('Colour','colour',Table.InputType_None,15);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CommodityMaint);
		
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="c44232fc-422a-48ae-8bc9-121fdf09a4a4">
        <updating/>
        <source>showThumbnail(pCommodity : CM_Commodity) updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
// 09/10/2017	jlgdao1		TFS 7204 STWR Correct real handling for non-standard locales
vars
	theForm : SOP_TableMaintForm;
	lCommodityGroup:CM_CommodityGroup;
	tmpTbl	: CM_EntryTable;
begin
  
  	theForm := self.myForm;
  	tmpTbl	:= theForm.tblInput1;
  	
  	tmpTbl.clearValues;
	tmpTbl.userInputEnabled := false;
	
	tmpTbl.setValueByName(ETRow_Code, pCommodity.code);
	tmpTbl.setValueByName(ETRow_Description,	pCommodity.description);
	tmpTbl.setValueByName(ETRow_ShortDescription,	pCommodity.shortDescription);
	tmpTbl.setValueByName(ETRow_BayplanPrintAs, pCommodity.bayplanPrintAs); 
	tmpTbl.setValueByName(ETRow_Colour, pCommodity.colour.String);
	tmpTbl.setValueByName(ETRow_HasTemp, pCommodity.hasTemp.String);
	//tmpTbl.setValueByName(ETRow_MaxTemp, pCommodity.maxTemp.String);			// TFS 7204
	//tmpTbl.setValueByName(ETRow_MinTemp, pCommodity.minTemp.String);			// TFS 7204
	tmpTbl.setValueByName(ETRow_MaxTemp, pCommodity.maxTemp.asStringJMT);		// TFS 7204
	tmpTbl.setValueByName(ETRow_MinTemp, pCommodity.minTemp.asStringJMT);		// TFS 7204
	tmpTbl.setValueByName(ETRow_RequiresPower, pCommodity.requiresPower);
	tmpTbl.setValueByName(ETRow_RequiresPackInfo, pCommodity.requiresMAFFields);
	tmpTbl.setValueByName(ETRow_IsNotAvailableForEntry, pCommodity.isNotAvailableForEntry);
	tmpTbl.setValueByName(ETRow_IsEmpty, pCommodity.isEmpty);

	theForm.cmbCommodityGrp.setObject(pCommodity.myCommodityGroup);
	tmpTbl.setValueByName(ETRow_MyCommodityGroup, theForm.cmbCommodityGrp.text);
	
	theForm.myAssistant.comboBoxSpecialStow(theForm.cmbSpecialStow,pCommodity.mySpecialStow);
	tmpTbl.setValueByName(ETRow_SpecialStow, theForm.cmbSpecialStow.text);
	
	tmpTbl.setValueByName(ETRow_IsUsedForPacking, pCommodity.isUsedForPacking);				// PAR #35895
	tmpTbl.setValueByName(ETRow_RequiresWeighing, pCommodity.requiresWeighing);	//05 Jul 2019	NDL	TFS 44965
	
	//PAR 19074, CCMS 1080 May 2009 cnwvu1
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(pCommodity.allCargoTypes);
	self.disableMulSelect1Contents();

end;</source>
        <Parameter name="pCommodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="2c9191b8-e0b1-4eec-bd99-79ee2611e842">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	lCommodity:CM_Commodity;
	cell : JadeTableCell;
begin

	lCommodity := _obj.CM_Commodity;
	if(_idxRow &lt;&gt; 1) then
		if self.colourColumn &gt; 0 then
			cell := myForm.tblData.accessCell(_idxRow, self.colourColumn);
			cell.text := null;
			cell.backColor := lCommodity.colour;
		endif;
	endif;	

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
