    <JadeMethod name="delete" id="c1fda342-c8c3-4e7b-b2b5-13b4cf443977">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 02 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allCMIF_WHStorageLines.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="a1570eab-1cfd-4ec2-8a6d-8787fbdcaea8">
        <source>noOutputReturned(): Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allBOLs.isEmpty() and
		self.allCMIF_WHStorageLines.isEmpty() and
		self.allLocations.isEmpty() and
		self.allProducts.isEmpty() and 
		self.allSOHLocations.isEmpty() and
		self.allSOHReporters.isEmpty() and
		self.allStorageTransactions.isEmpty() and
		self.allTITransactions.isEmpty() then
		return true;
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
