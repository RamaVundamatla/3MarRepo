    <JadeMethod name="setupIterator" id="d640901a-2e4b-4be4-a18c-d523f2d73dfa">
        <source>setupIterator(organisation : CM_Organisation): Iterator protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/
vars
	iter : Iterator;	
begin	
	iter := organisation.allEventRequestsNofity.createIterator();
	organisation.allEventRequestsNofity.startKeyLeq(self.status, Max_Integer.Binary.TimeStamp, iter);
	return iter;
end;
</source>
        <access>protected</access>
        <Parameter name="organisation" type="CM_Organisation"/>
        <ReturnType type="Iterator"/>
    </JadeMethod>
</Class>
