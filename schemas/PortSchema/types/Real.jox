    <JadeMethod name="asWords" id="43d14585-e775-43a3-a135-241fd31fe0e0">
        <source>asWords() : String;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theString : String;
	theInteger : Integer;
	theDecimal : Decimal[3,2];
begin
	theInteger := self.Integer;
	theDecimal := self - theInteger;
	
	if theInteger = 0 then
		theString := "";
	elseif theInteger &gt;= 1 then
		theString := theInteger.String;
	endif;
	
	if theDecimal &gt; 0 then
		if theDecimal &lt;= .2 then
			theString := theString &amp; " and a bit";
		elseif theDecimal &lt;= .25 then
			theString := theString &amp; " and a quarter";
		elseif theDecimal &lt;= .4999 then
			theString := theString &amp; " and a just under a half";
		elseif theDecimal &lt;= .5 then
			theString := theString &amp; " and a half";
		elseif theDecimal &lt;= .7499999 then
			theString := theString &amp; " and just over half";
		elseif theDecimal &lt;= .75 then
			theString := theString &amp; " and three quarters";
		elseif theDecimal &lt;= .99999 then
			theString := "just under " &amp; (theInteger + 1).String;
		endif;
	endif;
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
