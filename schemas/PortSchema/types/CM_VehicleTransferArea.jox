epilog

end;</source>
        <Parameter name="_maxCapacity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setNumGateLanes" id="c17e3c68-c5b5-43ad-9136-45fc69241110">
        <updating/>
        <source>setNumGateLanes(_numGateLanes : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if numGateLanes &lt;&gt; _numGateLanes then
		numGateLanes:=_numGateLanes;	
