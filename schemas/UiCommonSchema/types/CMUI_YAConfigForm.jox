    <JadeMethod name="populateAutoPlan" id="609d8553-ca60-4e0c-908d-5f36c70c5262">
        <source>populateAutoPlan();

/*

Purpose:			Populate Auto Plan sheet

Parameters:			

Return Value:		


Date		Who		Reason
30 Jul 2008	consw1	Initial creation
16 Jun 2022 navhl20	TFS 53765 EUP - Warehouse Yard Allocation Desktop Application

*/

vars
	configOpts : CMIF_YAConfig;

begin
	create configOpts transient;
	configOpts.setFromTerminal(self.getRealYAConfig.myTerminal);

	self.chkAPAllowLog.value		:= configOpts.autoPlanAllowLogging;
	self.chkAPEnabled.value			:= configOpts.autoPlanEnabled;
	self.chkAPGenSwapYard.value		:= configOpts.autoPlanGenerateSwapForYardInt;
	self.chkAPGenSwapJob.value		:= configOpts.autoPlanGenerateSwapJob;
	self.txtAPEmail.text			:= configOpts.autoPlanPreNotiEmail;
	self.chkAPPreNotif.value		:= configOpts.autoPlanPreNotifications;
	self.chkAPUseOstowRul.value		:= configOpts.autoPlanUseOverstowRules;
	self.chkOsIgnorePandQ.value		:= configOpts.autoPlanOsIgnorePandQ;	//16 Jan 2018	NDL	TFS 42292
	//self.chkAPUseRestrict.value		:= configOpts.autoPlanUserRestrictions;			//-cnwml2 PAR19304
	self.chkAPYAGroupBlk.value		:= configOpts.autoPlanYAGroupedBlocks;
	self.setAPOverstowCombo(self.getRealYAConfig.autoPlanOverstowRule); //cnwjo3 par 22338
	self.cmbDefaultFill.setIndexForItemData( configOpts.fillOption );
	self.setMTReleaseStrategyCombo(configOpts.autoPlanMTReleaseStrategy);		// PAR 23677

	self.chkUsePriLookup.value    := configOpts.autoPlanUsePriorityLookup;     // PAR 24673
	/* 15/11/2011 cnwdz2 28387
	if app.isSpecial then	
		self.chkUsePriLookup.enabled := true;
	else
		self.chkUsePriLookup.enabled := false;
	endif;
	*/
	self.chkUseBestPickDr.value 	:= configOpts.autoPlanUseBestPickDirector; //cnwrd1 par 28628 3.11.11
	self.chkFullGCArea.value		:= configOpts.autoPlanAllowFullGCArea;		//16 June 2022 navhl20 TFS 53765		
	
epilog
	delete configOpts;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDefaultCriteria" id="61522290-4696-488b-b6e1-adf9e61eec69">
        <source>populateDefaultCriteria();

/*

Purpose:		Populate Default Criteria sheet			

Parameters:			

Return Value:		


Date		Who		Reason
14/08/2008	consw1	Initial creation
26/04/2016  cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
25/08/2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
*/

vars
	yaCriteriaTypeArr	: CM_YACriteriaTypeArray;
	critType			: CM_YACriteriaType;
begin
	create yaCriteriaTypeArr transient;      				//26/04/2016 cnwma1 PAR #36914 TFS1768 
	foreach critType in app.myRoot.allYACriteriaTypes do
	
		// TFS 51219 - do not show invoice allocation types e.g. transaction type
		if not critType.isForCargo() then
			continue;
		endif;

		if  critType.isUsed then
			yaCriteriaTypeArr.add(critType);
		endif;
	endforeach;
	
	self.mltTemplateDef.userInputEnabled := true;
	self.mltTemplateDef.formDisplayEntryMethodName 	:= CMUI_YAConfigForm::displayCriteria.name;
	self.mltTemplateDef.displayOrderBtns(true, false);			//cnwmc5 - 23 Oct 2013 - PAR 32833
	self.mltTemplateDef.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltTemplateDef.myAvailableListBox.sorted 	:= true;		
	self.mltTemplateDef.mySelectedListBox.sorted 	:= false;
	self.mltTemplateDef.setTabIndex();
	self.mltTemplateDef.displayAddRemoveBtns(true, false);		//cnwmc5 - 23 Oct 2013 - PAR 32833

	//self.mltTemplateDef.setAvailable(app.myRoot.allYACriteriaTypes, true);     //26/04/2016 cnwma1 PAR #36914 TFS1768 
	self.mltTemplateDef.setAvailable(yaCriteriaTypeArr, true); 					 //26/04/2016 cnwma1 PAR #36914 TFS1768 
	
	self.mltTemplateDef.setSelected(self.getRealYAConfig.allDefaultCriteriaTypes);

	self.mltSearchDef.userInputEnabled := true;
	self.mltSearchDef.formDisplayEntryMethodName 	:= CMUI_YAConfigForm::displayCriteria.name;
	self.mltSearchDef.displayOrderBtns(true, false);			//cnwmc5 - 23 Oct 2013 - PAR 32833
	self.mltSearchDef.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltSearchDef.myAvailableListBox.sorted 	:= true;		
	self.mltSearchDef.mySelectedListBox.sorted 		:= false;
	self.mltSearchDef.setTabIndex();
	self.mltSearchDef.displayAddRemoveBtns(true, false);		//cnwmc5 - 23 Oct 2013 - PAR 32833
	
	//self.mltSearchDef.setAvailable(app.myRoot.allYACriteriaTypes, true);       //26/04/2016 cnwma1 PAR #36914 TFS1768 
	self.mltSearchDef.setAvailable(yaCriteriaTypeArr, true); 			        //26/04/2016 cnwma1 PAR #36914 TFS1768 
	
	self.mltSearchDef.setSelected(self.getRealYAConfig.allDefaultSearchCriteriaTypes);
	
	// MTN-35615 start
	self.mltBulkDef.userInputEnabled := true;
	self.mltBulkDef.formDisplayEntryMethodName := CMUI_YAConfigForm::displayCriteria.name;
	self.mltBulkDef.displayOrderBtns(true, false);
	self.mltBulkDef.multiSelect := ListBox.MultiSelect_Extended;
	self.mltBulkDef.myAvailableListBox.sorted := true;		
	self.mltBulkDef.mySelectedListBox.sorted := false;
	self.mltBulkDef.setTabIndex();
	self.mltBulkDef.displayAddRemoveBtns(true, false);
	
	self.mltBulkDef.setAvailable(yaCriteriaTypeArr, true);
	self.mltBulkDef.setSelected(self.getRealYAConfig.allDefaultBulkCriteriaTypes);
	// MTN-35615 end

epilog
	delete yaCriteriaTypeArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateMTReleaseStrategy" id="289016a9-7f37-473f-b73f-1ea00c2aaec8">
        <source>populateMTReleaseStrategy();
// PAR 23677
vars

begin
	self.cmbMTRelStrategy.addItem(app.getErrorString(MTRelStratYAOnly));
	self.cmbMTRelStrategy.addItem(app.getErrorString(MTRelStratBoth));
	self.cmbMTRelStrategy.addItem(app.getErrorString(MTRelStratTerminalOnly));
end;</source>
