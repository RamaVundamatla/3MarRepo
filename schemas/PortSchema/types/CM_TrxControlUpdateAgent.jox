    <JadeMethod name="trxUpdatePackage" id="5264d747-70d7-4efe-9b0e-6db10191ebf3">
        <updating/>
        <source>trxUpdatePackage(_pxyPackage : CM_Package;
				 _pxyTask : CM_AutoTaskPackage input;
				 _pxySchedule : CM_AutoSchedule input;
				 _passport : CM_Passport input) updating;
/*

Purpose:			Apply updates to a CM_Package object

Parameters:			_pxyPackage: the package to be updated; _pxyTask/_pxySchedule: can update related objects if needed

Return Value:		

Date			Who			Reason
15 Jan 2003		cnwdvb1		Initial creation
25 Jan 2019		jlgzm1		TFS42936 Editing invoice package should edit its autoSchedule

*/
vars

	desc			: String;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityUA.utlUpdatePackage(_pxyPackage, _passport);
	
	if _passport.noErrors and _pxyPackage.isKindOf(CM_PackageInvoice) then
		if _pxyTask &lt;&gt; null then
			app.myUtilityUA.utlUpdateAutoTask(_pxyTask, _passport);
			
			if _passport.noErrors then
				if _pxySchedule &lt;&gt; null then
					app.myUtilityUA.utlUpdateAutoSchedule(_pxySchedule, _passport);
					
				endif;
			endif;
		endif;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyPackage" type="CM_Package"/>
        <Parameter name="_pxyTask" type="CM_AutoTaskPackage" usage="input"/>
        <Parameter name="_pxySchedule" type="CM_AutoSchedule" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
