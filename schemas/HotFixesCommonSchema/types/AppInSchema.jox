<Class name="AppInSchema" id="8297af2e-cb91-4fb9-8daa-177689b803cc">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="HotFixesCommonSchema"/>
    <PrimAttribute name="dateOfLastEdition" id="412d68b8-1960-40cc-8a6d-c65c61e40325">
        <embedded/>
        <type name="TimeStamp"/>
        <access>protected</access>
    </PrimAttribute>
    <ExplicitInverseRef name="mySchemaInPatch" id="06462272-abeb-43b0-a755-8616f3af0dc6">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="SchemaInPatch"/>
        <Inverse name="SchemaInPatch::allAppsInSchema"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="fd3c698f-1285-40ee-9ab8-ba1d9779f9e7">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getAppInJADE" id="2bdc51e3-0323-4f4a-9edb-5b268cfc62b2">
        <source>getAppInJADE() : Application;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	schema	: Schema;
	appl	: Application;
	scm		: SchemaInPatch;
	coll	: AppNameDict;
	
begin

	scm 	:= self.mySchemaInPatch;
	schema	:= scm.getSchemaInJADE();
	if schema = null then
		return null;
	endif;

	coll := schema.getPropertyValue("_applications").AppNameDict;

	appl := coll[ self.name ];
	if appl = null then
		app.msgBox('The application not found - ' &amp; self.name, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return null;
	endif;

	return appl;

end;</source>
        <ReturnType type="Application"/>
    </JadeMethod>
    <JadeMethod name="set" id="95b29488-ca0e-4308-a3c6-2ead2c8a4e2c">
        <updating/>
        <source>set( name : String ) updating;
// created by cnwvu1 on 08/04/2008
vars

begin

	self.name				:= name;
	self.dateOfLastEdition	:= app.actualTimeServer();

end;
</source>
        <Parameter name="name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="399c0f50-0998-4dea-ac5e-1360a71136ec">
        <updating/>
        <source>setForCreate( _name: String; _schema : SchemaInPatch ) updating;
// created by cnwvu1 on 08/04/2008
vars

begin

	self.set( _name );
	self.mySchemaInPatch := _schema;

end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_schema" type="SchemaInPatch"/>
    </JadeMethod>
    <JadeMethod name="validate" id="904bce84-4e76-4fa2-b3ff-8b221a5868eb">
        <source>validate() : Boolean;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	appl : Application;

begin

	appl := self.getAppInJADE();
	if appl = null then
		app.writeLogMessage('Application ' &amp; self.name &amp; ' - not found.');
		return false;
	else
		app.writeLogMessage('Application ' &amp; self.name &amp; ' - ok.');
	endif;

	return true;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
