    <JadeMethod name="b_Sample_click" id="7b686de7-65a5-4cd7-8bcd-78c1b2613250">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Sample_click(btn: Button input) updating;
constants

vars
	item      : String;
	max       : Integer;
	index     : Integer;
	hostPort  : String;

begin
	max := lbx_Nodes.listCount;
	if 	b_Sample.caption = 'Stop Sampling' then
		b_Sample.caption := 'Start Sampling';
		v_tcpHandler.stopSampling(v_selectedNodeArray);
		v_tcpHandler.messageCount := 0;
	else
		v_selectedNodeArray.clear;
		foreach index in 1 to max do
			item := lbx_Nodes.itemText [index];
			if lbx_Nodes.itemSelected [index] then
				hostPort := tbx_Host.text.trimBlanks &amp; ', ' &amp; tbx_Port.text.trimBlanks;
				v_selectedNodeArray.add(lbx_Nodes.itemObject[index]);
			endif;
		endforeach;
		if b_Listen.caption  &lt;&gt; 'Listening' then
			app.msgBox('Initiate Listener prior to Sampling', "No Listener", MsgBox_OK_Only + MsgBox_Stop_Icon);
			return;
		endif;
		if v_selectedNodeArray.size = 0 then
			app.msgBox('No Node selected', "Select a Node", MsgBox_OK_Only + MsgBox_Stop_Icon);
			return;
		endif;
		if v_selectedNodeArray.includes(node) then
			app.msgBox('Can not sample Node running Sample Application', "Same Node", MsgBox_OK_Only + MsgBox_Stop_Icon);
			return;
		endif;
		v_tcpHandler.setupSampling(hostPort, v_selectedNodeArray, chx_Remote.value);
		b_Sample.caption := 'Stop Sampling';
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Snapshot_click" id="b5415b4f-4629-486d-8a12-c55d92fa4999">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Snapshot_click(btn: Button input) updating;

vars
	item      : String;
	max       : Integer;
	index     : Integer;
	hostPort  : String;
begin
	max := lbx_Nodes.listCount;
	v_selectedNodeArray.clear;
	foreach index in 1 to max do
		item := lbx_Nodes.itemText [index];
		if lbx_Nodes.itemSelected [index] then
			hostPort := tbx_Host.text.trimBlanks &amp; ', ' &amp; tbx_Port.text.trimBlanks;
			v_selectedNodeArray.add(lbx_Nodes.itemObject[index]);
		endif;
	endforeach;
	if b_Listen.caption  &lt;&gt; 'Listening' then
		app.msgBox('Initiate Listener prior to Sampling', "No Listener", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	if v_selectedNodeArray.size = 0 then
		app.msgBox('No Node selected', "Select a Node", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	clearSnapshotData;
	v_tcpHandler.takeCacheSnapshot(hostPort, v_selectedNodeArray, opt_tran.value);
	tbl_cache.displayCollection(v_tcpHandler.v_snapshotMessageSet, false, 0, null);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_findCancel_click" id="56c276cd-eb8f-4156-a141-cb1e88ba8e30">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_findCancel_click(btn: Button input) updating;
//
//	Interupt search
//
begin
	v_break := true;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_findNext_click" id="3e76c3f3-437f-44ca-8eda-39c96f2083df">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_findNext_click(btn: Button input) updating;
//
//  Find the next occurrence.
//  Note - we allow you to change the target so it is possible to search for a new target
//  starting at the current location.
//
vars
	count      : Integer;
	target     : String;
	found      : Boolean;
	sample     : SampleMessages;
begin
	if chx_case.value = true then
		target         :=  tbx_searchText.text;
	else
		target         :=  tbx_searchText.text.toLower;
	endif;
	v_searchOffset := 1;
	v_break        := false;
	while  v_sampleIterator.next(sample) do
		count := count + 1;
		found  := findTextString(sample, target, v_searchOffset);
		if found = true then
			break;
		endif;

		if count mod 1000 = 0 then
			b_findCancel.doWindowEvents(100);
			if v_break = true then
				sl_Status.caption := "'" &amp; target &amp; "'" &amp; ' search interrupted after ' &amp; count.String;
				return;
			endif;
		endif;
	endwhile;

	if found = false then
		sl_Status.caption := "'" &amp; target &amp; "'" &amp; ' not found';
	else
		sl_Status.caption := v_searchFoundCount.String &amp; " '" &amp; target &amp; "'" &amp; ' found ' &amp; count.String;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_find_click" id="0fb22114-5425-4924-9eee-c697842ad1d4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_find_click(btn: Button input) updating;
//
// Setup for initial search - all in lower case
//
vars
	count      : Integer;
	source     : String;
	target     : String;
	found      : Boolean;
	sample     : SampleMessages;
begin
	if chx_case.value = true then
		target         :=  tbx_searchText.text;
	else
		target         :=  tbx_searchText.text.toLower;
	endif;
	v_searchOffset     := 1;
	v_searchFoundCount := 0;
	v_sampleIterator.reset;
	v_break            := false;
	while  v_sampleIterator.next(sample) do
		count := count + 1;
		found  := findTextString(sample, target, v_searchOffset);
		if found = true then
			break;
		endif;

		if count mod 1000 = 0 then
			b_findCancel.doWindowEvents(100);
			if v_break = true then
				sl_Status.caption := "'" &amp; target &amp; "'" &amp; ' search interrupted ' &amp; count.String;
				return;
			endif;
		endif;
	endwhile;

	if found = false then
		sl_Status.caption := "'" &amp; target &amp; "'" &amp; ' not found';
	else
		sl_Status.caption := v_searchFoundCount.String &amp; " '" &amp; target &amp; "'" &amp; ' found after ' &amp; count.String;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
