Purpose:	 // PAR 36631		
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
*/

vars

begin
	return "MS Dynamics GPHA"; 

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setExternalInvoiceNumber" id="f2ddc811-015d-4203-bed0-e8ae629a891a">
        <source>setExternalInvoiceNumber(_invoice: CM_Invoice): String;
/*
Purpose:			Generate a new external invoice number at invoice creation time.

Parameters:			

Return Value:		

Date		Who		Reason
14/10/2015	cnwjre1	36704 GPHA cash receipt reporting
*/
vars
	tranNum		: String;
	term : CM_Terminal;
begin

	term := _invoice.myTerminal;
	tranNum := term.code &amp; "-CDI-" &amp; _invoice.sequenceNum.padLeadingWith('0', 6);
	return tranNum;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
