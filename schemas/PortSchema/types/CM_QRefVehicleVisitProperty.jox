    <JadeMethod name="translateToSearchValue" id="af085280-3792-47ae-aaac-3fec57a5445f">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	vvr : CM_VehicleVisitRecord;
	ts : TimeStamp;

begin
	if _value &lt;&gt; null then
		if _value.isKindOf (Collection) then
			return _value;
		endif;
		
		if _value.isKindOf (CM_VehicleVisitRecord) then
			vvr := _value.CM_VehicleVisitRecord;
		endif;
		
		if _value.isKindOf (String) then
			if _value.String &lt;&gt; null then
				if app.myPassport.myTerminal &lt;&gt; null then
					ts := app.actualTimeAppServer;
					vvr := app.myPassport.myTerminal.allVehicleVisitsByNumDT.getAtKeyGeq( _value.String, ts ).CM_VehicleVisitRecord;
				endif;
			endif;
		endif;
		
	endif;
	
	return vvr;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
