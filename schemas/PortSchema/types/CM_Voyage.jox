    <JadeMethod name="getWPOpHrsInTSRangeFor" id="5e64f353-083a-4153-938b-fc35f37559c3">
        <source>getWPOpHrsInTSRangeFor( _opHrsSet : CM_WorkPointOperatingHoursSet input; _craneWorkPointId : String; _startTS : TimeStamp; _endTS : TimeStamp );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	localExchangeEnd : TimeStamp;
	
begin

	iter := self.allWorkPointOperatingHours.createIterator;
	
	while iter.next( opHr ) do
		if _craneWorkPointId &lt;&gt; null and opHr.craneWorkPointId &lt;&gt; _craneWorkPointId then
			continue;
		endif;
		if not opHr.exchangeStart.Date.isValid then	// 28 Aug 2012	NDL	Par 30279
			// this one has no details yet.
			continue;
		endif;
		if opHr.exchangeStart &gt;= _endTS then
			//this one starts after my range
			continue;
		endif;
		//these must start before or during my range....
		localExchangeEnd := opHr.exchangeEnd; 
		if localExchangeEnd.Date.isValid then
			//this one ends sometime
			if localExchangeEnd &lt;= _startTS then
				//finishes before my range.
				continue;
			endif;
		endif;
		_opHrsSet.add( opHr );
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_opHrsSet" type="CM_WorkPointOperatingHoursSet" usage="input"/>
        <Parameter name="_craneWorkPointId" type="String"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWPOpHrsTotalDownHrs" id="8e7ee886-7081-486f-a5dd-410254bf37a5">
        <source>getWPOpHrsTotalDownHrs():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	opHrs : CM_WorkPointOperatingHours;
	totWPExchangeHrs : Real;
	availableWorkPoints : ObjectArray;
	numAvailCranesWps : Integer;
	voyExchangeHrs : Real;
	totAvailExchangeHrs : Real;
	totDownHrs : Real;
	relativeExchEndTime : TimeStamp;

begin

	if self.allWorkPointOperatingHours.isEmpty then
		return 0;
	endif;
	if not self.shipExchangeDate.Date.isValid then
		return 0;
	endif;

	numAvailCranesWps := self.getNumberOfCranesOrWpsUsed();
	if numAvailCranesWps = 0 then
		return 0;
	endif;
	
	relativeExchEndTime := app.actualTimeServer;
	if self.shipExchangeCompleteDT.date.isValid and self.shipExchangeCompleteDT &lt; relativeExchEndTime then
		relativeExchEndTime := self.shipExchangeCompleteDT;
	endif;
	
	voyExchangeHrs := relativeExchEndTime.differenceInHoursReal( self.shipExchangeDate );
	totAvailExchangeHrs := numAvailCranesWps * voyExchangeHrs;
	
	if totAvailExchangeHrs = 0 then
		return 0;
	endif;
	
	foreach opHrs in self.allWorkPointOperatingHours do
		totWPExchangeHrs := totWPExchangeHrs + opHrs.getGrossExchangeHrs();
	endforeach;
	
	totDownHrs := totAvailExchangeHrs - totWPExchangeHrs;
	
	return totDownHrs;

epilog

	delete availableWorkPoints;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getWPOpHrsTotalNetOpHrs" id="e48979cf-1ba5-404f-bd31-9825dbba5f95">
        <source>getWPOpHrsTotalNetOpHrs():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	opHrs : CM_WorkPointOperatingHours;
	netTimeInterval : TimeStampInterval;
	netHours : Real;
	totNetHours : Real;

begin

	if self.allWorkPointOperatingHours.isEmpty then
		return 0;
	endif;
	
	foreach opHrs in self.allWorkPointOperatingHours do
		netTimeInterval := opHrs.getNetExchangeInterval();
		netHours := netTimeInterval.asHours;
		totNetHours := totNetHours + netHours;
	endforeach;
	
	return totNetHours;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getWPOpHrsTotalWorkHrs" id="bf8ad67b-cc8a-4822-ae62-de7fb6adce73">
        <source>getWPOpHrsTotalWorkHrs():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	opHrs : CM_WorkPointOperatingHours;
	sum : Real;

begin

	foreach opHrs in self.allWorkPointOperatingHours do
		sum := sum + opHrs.getGrossAboardHrs();
	endforeach;
	
	return sum;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getWPOpHrsWorkEndedFor" id="1824fb5a-f5b0-499b-abd0-9f49461e884c">
        <source>getWPOpHrsWorkEndedFor( _craneWorkPointId : String ):TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	latestExchangeEnd : TimeStamp;
	localExchangeEnd : TimeStamp;
	
begin

	iter := self.allWorkPointOperatingHours.createIterator;
	
	latestExchangeEnd := null;
	while iter.next( opHr ) do
		if _craneWorkPointId &lt;&gt; null and opHr.craneWorkPointId &lt;&gt; _craneWorkPointId then
			continue;
		endif;
		localExchangeEnd := opHr.getExchangeEnd;
		if latestExchangeEnd = null or localExchangeEnd &gt; latestExchangeEnd then
			latestExchangeEnd := localExchangeEnd;
		endif;
	endwhile;

	return latestExchangeEnd;

epilog

	delete iter;

end;</source>
        <Parameter name="_craneWorkPointId" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWPOpHrsWorkStartedFor" id="35287190-896f-42b8-811c-5e0a921b6f5e">
        <source>getWPOpHrsWorkStartedFor( _workpointOrCraneId : String ):TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	earliestExchangeStart : TimeStamp;
		
begin

	iter := self.allWorkPointOperatingHours.createIterator;
	earliestExchangeStart := null;
	while iter.next( opHr ) do
		if _workpointOrCraneId &lt;&gt; null and opHr.craneWorkPointId &lt;&gt; _workpointOrCraneId then
			continue;
		endif;
		if opHr.exchangeStart.Date.isValid then
			if earliestExchangeStart = null or opHr.exchangeStart &lt; earliestExchangeStart then
				earliestExchangeStart := opHr.exchangeStart;
			endif;
		endif;
	endwhile;
	
	return earliestExchangeStart;

epilog

	delete iter;

end;</source>
        <Parameter name="_workpointOrCraneId" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWodShiftForMovement" id="893c8c4b-e8a0-4411-b5d1-617ea89f8c8f">
        <source>getWodShiftForMovement( movement : HMS_VoyageMovement ):CM_WodShiftMovement;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	iter : Iterator;
	wo : CM_WorkOrder;
	wodDtl : CM_WorkOrderDtl;
	wodShiftMove : CM_WodShiftMovement;

begin

	if movement = null or not movement.moveType = HMSMovementTypeShift then
		return null;
	endif;
	
	iter := self.allWorkOrders.createIterator;
	while iter.next( wo ) do
		wodDtl := wo.allWoDtls.first;
		if not wodDtl.isWorkOrderForShift then
			continue;
		endif;
		wodShiftMove := wodDtl.CM_WodShiftMovement;
		if movement = wodShiftMove.myHMSVoyageMovement then	//10 Dec 2018	NDL	TFS 42043
			return wodShiftMove;
		endif;
		if wodShiftMove.myHMSVoyageMovement = null and movement.occursOnDTNEW = wodShiftMove.occursOnDT then
			return wodShiftMove;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="movement" type="HMS_VoyageMovement"/>
        <ReturnType type="CM_WodShiftMovement"/>
    </JadeMethod>
    <JadeMethod name="getWorkActualRate" id="859e3229-1141-4546-b34f-6ce175d909e6">
        <source>getWorkActualRate() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		How many moves per hour
//
// ---------------------------------------------------------------------------

vars
	toDoDuration,aveDuration,duration,rate : Integer;
	numCranes, tmpRate : Integer;
	movesDone : Integer;
	etc : TimeStamp;
	aJS : CM_JobSheet;
begin
	if self.allJobSheets.isEmpty then
		return 0;
	endif;
	
	foreach aJS in self.allJobSheets do
		if aJS.allJobsByOrder.isEmpty then
			continue;
		endif;
		
		numCranes := numCranes + 1;
//		tmpRate := tmpRate + aJS.getWorkActualRate(); // PAR 8436 removed
		tmpRate := tmpRate + aJS.getWorkActualRateNoDelays(); // PAR 8436 new
		
	
	endforeach;

	if numCranes &gt; 0 then // PAR 9712
		rate := (tmpRate / numCranes).Integer;
	endif;
	return rate;
	
/*	
	duration := self.getWorkDurationTime(); // get total seconds so far worked
	movesDone := self.getWorkTotalMovesCompleted();
	if movesDone = 0 then
		return null;
	endif;
			
	aveDuration := (duration / movesDone).Integer; // average for each move done so far
	if aveDuration &lt;&gt; null then
		rate := (SecondsPerHour / aveDuration).Integer;
		
		if rate &lt;= 0 then
			rate := 1;
		endif;
		return rate;
	else
		return null;
	endif;
	*/
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkDepartureTargetRatePH" id="1ef396eb-9f8a-4289-a254-c30bb0f32edf">
        <source>getWorkDepartureTargetRatePH() : Integer;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		They can enter when they want the voyage to depart, so this method works out how many moves per hour they need to do to reach that
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	duration : Integer;
	totHours : Decimal[6,2];
	tmpHours : Real;
	movesDone,movesToDo, movesTotal : Integer;
	targetDepart : TimeStamp;
begin
	targetDepart := self.departTargetDT;
	if not targetDepart.isValid then // PAR 9475
		targetDepart := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	duration := self.getWorkDurationTime(targetDepart); // get total seconds 
	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
	if movesDone = 0 then
		return null;
	endif;
	movesTotal := movesDone + movesToDo;

	tmpHours := (duration / SecondsPerHour).roundedTo(2);

	if tmpHours &gt; 0 then
		return (movesTotal / tmpHours).Integer;
	else
		return (movesTotal / 1).Integer;
	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkDurationTime" id="cd2a14ef-8938-4089-a327-433def010638">
        <source>getWorkDurationTime(_endTS : TimeStamp) : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
	day : Integer;
	duration : Time;
	seconds : Integer;
	sinceMN,pos : Integer;
 	midnight:	Time;
begin
	now := _endTS;
	midnight.setTime(24,0,0,0);
	if self.shipExchangeDate &lt;&gt; null then
//		now := app.actualTimeAppServer;
		duration := now.differenceAsTime(self.shipExchangeDate,pos,day);
		seconds := (day * SecondsPerDay);
		sinceMN := duration - midnight;
		sinceMN := (sinceMN / 1000).Integer;
		seconds := seconds + sinceMN;
		return seconds;
	endif;
	return null;
end;</source>
        <Parameter name="_endTS" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCActual" id="d167bee7-7ec2-4cd2-9537-2d87371f78c6">
        <source>getWorkETCActual() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		get Estimated Time to Completion
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin
	
	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
	if movesDone = 0 then
		return null;
	endif;
	ratePH := self.getWorkActualRate();

	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCActualLocalTZ" id="f1e3cd83-2f89-4d1c-88b1-9ae43575a762">
        <source>getWorkETCActualLocalTZ(): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin
	
	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
	if movesDone = 0 then
		return null;
	endif;
	ratePH := self.getWorkActualRate();

	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return self.systemToLocalTime(etc);
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCEntered" id="c7e6c64f-bba2-412a-9069-2476ce16d01e">
        <source>getWorkETCEntered(_crane: CM_Crane) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		get Estimated Time to Completion using the Entered TI Per Hour Rate
//
// ---------------------------------------------------------------------------

vars
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin

	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
	if movesDone = 0 then
		return null;
	endif;
	
//	ratePH := self.tiPerHour;
	ratePH := _crane.targetRatePH;

	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderForDMSR" id="fd9352ef-9bea-4e79-88cf-a1571eeda8c9">
