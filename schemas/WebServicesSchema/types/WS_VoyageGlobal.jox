<Class name="WS_VoyageGlobal" id="6e910457-2627-4a44-a97e-57705ce3caa7">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A system wide voyage for log voyages between terminals</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="bec1002f-c5be-4fcd-8c11-0e5294cceeb4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Voyage code</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="25d907a8-56a6-40ae-a105-f777363c2cca">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Internal use only. No external support</text>
    </PrimAttribute>
    <PrimAttribute name="vesselName" id="d9478b1c-0a54-4d85-b0c1-86503abb0d47">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Vessel Name</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="9fe1a3ce-0a6d-4a5e-8059-68462df2e1bb">
        <updating/>
        <source>setProxyFromObject(_object: CM_VoyageGlobal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2009	#cnwdz2	 

*/

vars

begin
	inheritMethod(_object);
	self.code			:= _object.code;
	self.vesselName	:= _object.vesselName;
	self.comboboxDescription := self.code &amp; " " &amp; self.vesselName;
epilog

end;</source>
        <Parameter name="_object" type="CM_VoyageGlobal"/>
    </JadeMethod>
</Class>
