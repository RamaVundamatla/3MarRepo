    <JadeMethod name="initTblInExtra" id="8a5a3be0-dc70-4c42-bf19-19ae5adff1fb">
        <updating/>
        <source>initTblInExtra(pTbl : CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

