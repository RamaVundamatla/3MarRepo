    <JadeMethod name="trxMachineAcceptTask" id="0ed47490-3c11-435e-8786-b6be26cca721">
        <updating/>
        <source>trxMachineAcceptTask(_machine 			  : CM_Machine input; 
					 _rtQueueTask,
					 _twinQueueTask	 	  : CM_RTQueueTask input;					
					 _sideAccessDirection : Integer input;							
					 _passport 			  : CM_Passport input) updating;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 moved from MobileServerSchema::CM_TrxControlRTAgent::trxAcceptSpecifiedTaskTwin
					got rid of _useEntryFirstTask param as only used in old redundant gdansk apps
25 Jun 2019 jlgmd1	TFS 42848 Bail early if rtQueueEntry is null or invalid
20 Jan 2020	jlgka1 	TFS 47394 - Tandem Movement Enhancement. Revert code back before the Tandem Movement changes.
14 Sep 2021 jlier1	TFS 51580 - if best pick tandem try and use the box on top of the first selected
08 Oct 2025 navlc30 JIRA 36094 MTN | Deferred update required on trxMachineAcceptTask
*/

vars
	sideAccessDirection : Integer;
	rtQueueTask,	
	twinTask		: CM_RTQueueTask;
	twinRTQueueEntry,
	rtQueueEntry	: CM_RTQueueEntry;
	messageLogger 	: CM_MachineRTQueueEntryLogger;
	tandemLift		: Boolean;
	tandemTI 		: CM_TrackedItem;
	ostowTIs		: CM_TIArray;
	vehicleConfig	: CM_RTVehicleConfig;
	exObj			: CM_Exception;
	bbMaster		: CM_RTQueueTask;
	invalidTask		: Boolean;
	tasks			: CM_RTQueueTaskArray;
begin
		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport);
	
	// Arm our specific exception handlers
	on Exception do app.handleDeletedObject(exception, _rtQueueTask, invalidTask);
	
	
	app.setContinueCMExceptions(false);
	
	// if we are a director and system is set up to do best pick 
	// we need to check the first task
	// then go find a suitable cargo item and assign it to the entry, create pickup/setdown tasks etc and complete the director task.
	if _rtQueueTask &lt;&gt; null then
		rtQueueEntry :=_rtQueueTask.myEntry;
	endif;
	
	if _rtQueueTask = null or rtQueueEntry = null or invalidTask then
		app.raiseCMException1(Err_QueueEntryNotFound,null,null,null);
		return;
	endif;
	
	_passport.useTIDictDeferUpdate := true;					//08.10.2025 navlc30 #36094			
	_passport.useTITransactionDeferUpdate := true;			//08.10.2025 navlc30 #36094
	
	// cnwkpd1 - Process here cloned from trxRTGAcceptTask
	beginTransaction;
	
	
	if _rtQueueTask.checkAssignBestPickTIToWLE then	

		app.myUtilityUA.utlMachineBestPickAssignTI( _rtQueueTask ,_twinQueueTask,_machine,  _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endif;	
	
	if _twinQueueTask &lt;&gt; null then
		twinRTQueueEntry := _twinQueueTask.myEntry;
		if _twinQueueTask.checkAssignBestPickTIToWLE then		
			if twinRTQueueEntry.getTrackedItem = null then
				app.myUtilityUA.utlMachineBestPickAssignTI( _twinQueueTask ,null,_machine,  _passport);
			endif;
		endif;	
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if rtQueueEntry.isBreakBulkGenericMaster then
		app.myUtilityUA.utlBreakBulkMasterAccept( _rtQueueTask, rtQueueTask);
		if _rtQueueTask &lt;&gt; rtQueueTask then 
			bbMaster:=_rtQueueTask;
		endif;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if rtQueueTask = null then
		//if already offered don't call _rtQueueEntry.getATaskForMachine
		rtQueueTask:=rtQueueEntry.findOfferedTask;
		if twinRTQueueEntry &lt;&gt; null then
			twinTask:=twinRTQueueEntry.findOfferedTask;
		endif;
	endif;
	
	//like wise if control have allocated then don't call _rtQueueEntry.getATaskForMachine
	if rtQueueTask = null then
		rtQueueTask:=rtQueueEntry.findControlAllocatedTaskToMach(_machine);
		if twinRTQueueEntry &lt;&gt; null then
			twinTask:=twinRTQueueEntry.findControlAllocatedTaskToMach(_machine);
		endif;
	endif;

	if twinRTQueueEntry &lt;&gt; null and _machine.machineLiftType = TANDEM_LIFT then
		tandemLift := true;
	endif;
	//if it was offered we can assume that it has already been through the get a task code 
	// also the get a task code won't return any task that is not unactioned
	if rtQueueTask = null then
		create messageLogger transient;
		if tandemLift  then
			tandemTI := twinRTQueueEntry.getTrackedItem;
		endif;
		rtQueueEntry.getATaskForMachine(rtQueueTask,_machine,tandemTI,_sideAccessDirection,messageLogger);
		
		if _passport.hasErrors() then
			return;
		endif;
		//if an overstow task has been generated then don't do the twin task
		if rtQueueTask &lt;&gt; null and not rtQueueTask.isOverstowTask then
		
			if twinRTQueueEntry &lt;&gt; null then
				messageLogger.allMessages.clear;
				if tandemLift then
					tandemTI := rtQueueEntry.getTrackedItem;
				endif;
				twinRTQueueEntry.getATaskForMachine(twinTask,_machine,tandemTI,_sideAccessDirection,messageLogger);
			
				if _passport.hasErrors() then
					return;
				endif;
				// if the twin task generated an overstow task then just accept this twin overstow task
				if twinTask &lt;&gt; null and twinTask.isOverstowTask then
					rtQueueTask := twinTask;
					twinTask:=null;
				endif;		
			endif;		
		endif;
		
		//CCMS 1099 epr 13/5/10 if we don't have a task and the container is overstowed but shift overstows is set to false
		create ostowTIs transient;
		vehicleConfig:=rtQueueEntry.getMyTerminal.getRTVehicleConfigForObject(_machine);
		if rtQueueTask = null  then
			sideAccessDirection := null;					
			//epr par 35981 16/4/15
			if _rtQueueTask &lt;&gt; null then
				_rtQueueTask.getAllOverstowedTIs(ostowTIs,sideAccessDirection,_machine) ; //cnwrd1 27.2.2012
				if not ostowTIs.isEmpty then			
					if vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_AUTOPLAN then
						//give a better error i.e. could not auto plan overstowing container
						app.raiseCMException2(Not_Accept_TI_OS_fail_to_plan,rtQueueEntry.allTasks.first.tiId,ostowTIs.first.id,null,null);
					elseif vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_NONE then //epr 2/7/10 par 24710 if no task returned and ostowed and config set to none return error
						app.raiseCMException1(Mach_cannot_move_ostow,rtQueueEntry.allTasks.first.tiId,null,null);
					endif;
					
				/*	if vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_MANUAL then
						app.myUtilityUA.utlMachineCreateInitiatedMove(
					endif;*/
					
					return;
				endif;
			endif;
		endif;
		
		//epr 23/2/12 par 28126
		if tandemLift and twinTask = null then
			ostowTIs.clear;
			sideAccessDirection := null;
			if twinRTQueueEntry &lt;&gt; null then //08 Oct 2012	NDL	Par 30472
				twinRTQueueEntry.allTasks.first.getAllOverstowedTIs(ostowTIs,sideAccessDirection,_machine) ;
			endif;
			if not ostowTIs.isEmpty then
				if vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_AUTOPLAN then
					//give a better error i.e. could not auto plan overstowing container
					app.raiseCMException2(Not_Accept_TI_OS_fail_to_plan,twinRTQueueEntry.allTasks.first.tiId,ostowTIs.first.id,null,null);
				elseif vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_NONE then //epr 2/7/10 par 24710 if no task returned and ostowed and config set to none return error
					app.raiseCMException1(Mach_cannot_move_ostow,twinRTQueueEntry.allTasks.first.tiId,null,null);
				endif;
				
				return;
			endif;
		
		endif;
	endif;
	
	//epr par 34667 21/11/14
	if twinTask &lt;&gt; null and _twinQueueTask &lt;&gt; null and _twinQueueTask.checkAssignBestPickTIToWLE then	
		if twinTask.ti = null and rtQueueTask.ti &lt;&gt; null then
		twinTask:=null;
		endif;
	endif;
	
	//epr par 36103 23/4/15 tfs 297 if connected to power raise appropriate mesage
	if rtQueueTask = null and messageLogger &lt;&gt; null and messageLogger.allErrorCodesUsed.size &gt; 0 then
		create exObj transient;
		exObj.set(messageLogger.allErrorCodesUsed.first, messageLogger.allMessages.first, false, null, rtQueueEntry.getTrackedItem(), null);
		
		raise exObj;
		return;
	endif;
	
	//4/9/17 epr VMT found issue trying to twin lift with an overstow move
	if _twinQueueTask &lt;&gt; null and twinTask = null then
		if rtQueueTask.isOverstowTask then
			//jlgka1 TFS 47394 --&gt;
			if _machine.machineLiftType = TANDEM_LIFT then
				app.raiseCMException2(Not_twin_lift_overstow, "Tandem", rtQueueTask.tiId, null, null);
			else
				app.raiseCMException2(Not_twin_lift_overstow,"Twin", rtQueueTask.tiId, null, null);
			endif;
			//jlgka1 TFS 47394 &lt;--
			return;
		endif;
	endif;
	
	app.myValUA.valMachineAcceptTask(_machine,rtQueueTask,twinTask,tandemLift,messageLogger=null,true);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.myUtilityUA.utlMachineAcceptTask(_machine,rtQueueTask,_passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	if twinTask &lt;&gt; null then
		app.myUtilityUA.utlMachineAcceptTask(_machine,twinTask,_passport);
	endif;
	
	if bbMaster &lt;&gt; null and bbMaster.status = TASK_OFFERED then
		app.myUtilityUA.utlChangeTaskStatus(bbMaster,null,TASK_UNACTIONED,_passport);
	endif;
	
	if _passport.noErrors then				//08.10.2025 navlc30 #36094
		_passport.doDeferredUpdates();
	endif;	

epilog
	delete tasks;
	delete ostowTIs;
	delete messageLogger;	// 07 Jan 2011	NDL	transient leak in unit tests
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
