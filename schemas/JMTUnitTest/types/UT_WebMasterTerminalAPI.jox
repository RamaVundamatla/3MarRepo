    <JadeMethod name="uNewjlirs1Booking" id="8aad543c-4eea-4506-a0f9-7e7d39521525">
        <updating/>
        <source>uNewjlirs1Booking() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2023	jlirs1	Initial creation

*/
constants
	VesselCodeString = "EUP_VES02";
	VoyageCodeString = "EUP_VES02VOY01";
	ManifestId = "115319258";
	CargoGroupId = "CGJLIRS1";
	BookingId = "BOOKINGJLIRS1";
	ContId = "CONTJLIRS12";
	BOLId = "BOLJLIRS1";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	hmsVoyageData : HMS_VoyageData;
	terminal : CM_Terminal;
	workOrder : CM_WorkOrder;
	workOrderDtl : CM_WorkOrderDtl;
	cargoGroup : CM_CargoGroup;
	cargoGroupDtl : CM_CargoGroupDetail;
	container1 : CM_TrackedItem;
	booking1 : CM_BookingRef;
	allCargoToAssign : CM_TISet;
	terminalCode : String;
	allCG : CM_ObjectArray;
//	totQuant : Real;
begin
	create allCargoToAssign transient;
	create allCG transient;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
//		terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	terminal := CM_Root.firstInstance.allTerminals[terminalCode];
	
	// before deleting the voyage cleanup the cargoGroups and WorkOrderReceives
	voyage := self.getVoyage(VoyageCodeString);
	if voyage &lt;&gt; null then
		foreach cargoGroupDtl in voyage.allCargoGroupDetails do
			cargoGroup := cargoGroupDtl.myCargoGroup;
			if cargoGroup &lt;&gt; null then
				write "010 Delete CargoGroup="&amp;cargoGroup.id;
				self.deleteCargoGroup(cargoGroup.id);
			endif;
		endforeach;
		foreach workOrderDtl in voyage.allWOReceives do
			workOrder := workOrderDtl.myParent;
			if workOrder &lt;&gt; null then
				write "020 Delete WorkOrder="&amp;ManifestId;
				self.deleteWorkOrderNoValidation(ManifestId);
			endif;
		endforeach;
	endif;
	workOrder := terminal.allWorkOrders[ManifestId];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		write "030 Delete WorkOrder="&amp;workOrder.id;
		self.deleteWorkOrderNoValidation(workOrder.id);
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId, null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = CargoGroupId then
		write "036 CargoGroup CGJLIRS1 found";
			self.deleteCargoGroup(cargoGroup.id);
	endif;
	self.deleteVoyage(VoyageCodeString);
	self.deleteVessel(VesselCodeString);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(VesselCodeString, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 10);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	//Create a general cargo voyage 
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageCodeString, 
												  VesselCodeString,
												  self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
												  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
												  10);
	self.assertNotNullMsg(voyage, "Add voyage failed");
	beginTransaction;
	create hmsVoyageData persistent;
	hmsVoyageData.setMyHarbour(terminal.myHarbour);
	hmsVoyageData.setDefaultBerthPreferences(app.myPassport); 
	voyage.setHMSVoyageData(hmsVoyageData);
	commitTransaction;

	self.deleteBOL(BOLId, null);
	self.deleteBooking("BOOKINGjlirs1");
	self.deleteBooking(BookingId);
	self.deleteContainer(ContId);
	opts.addAssoc("number", 3);
	booking1 := self.addBookingForContainer(BookingId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "4400", "APPL");
	addBookingItemForContainer(booking1, "4400", "APPL", 2);
	assertEqual(booking1.myVoyage, voyage);
	assertEqual(booking1.allBookingRefItems.size, 2);
	self.deleteContainer(ContId);
	container1 := self.addContainerOpts(ContId, "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	self.updateTIBooking(container1, booking1, booking1.allBookingRefItems.first);
	assertEqual(container1.myBookingRef, booking1);
	assertEqual(container1.myBookingRefItem, booking1.allBookingRefItems.first);
	assertEqual(container1.myVoyage, voyage);
	allCargoToAssign.add(container1);
	self.opts.purge;
	self.opts.addAssoc("BookingRef", booking1);
	cargoGroup := self.addCargoGroup(CargoGroupId, allCargoToAssign);
	write "040 totalQuantity="&amp;cargoGroup.totalQuantity.String;
	beginTransaction;
//	totQuant := cargoGroup.totalQuantity;
	cargoGroup.setPropertyValue("totalQuantity", 1);
	commitTransaction;
	beginTransaction;
	cargoGroup.setPropertyValue("myBookingRef", booking1);
//	cargoGroup.setMyBooking(booking1, container1.myBookingRefItem);
	commitTransaction;
	write "080 totalQuantity="&amp;cargoGroup.totalQuantity.String;
	allCG.add(cargoGroup);
	app.myTrxCA.trxCreateWOForManifest(ManifestId,  WO_TASK_RECEIVE, allCG, null, null);
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq(CargoGroupId, null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = CargoGroupId then
		write "090 CargoGroup "&amp;CargoGroupId&amp;" found";
	endif;
	workOrder := terminal.allWorkOrders[ManifestId];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "100 Found first workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
epilog
	delete allCargoToAssign;
	delete allCargoToAssign;
	delete allCG;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPostCargo1" id="2c7f07e2-021f-412c-b82b-635ade9e90d6">
        <source>uPostCargo1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2024	naviv1	Initial creation

*/

constants
	UTRealBooking				: String = "BK-63619-04";
	IncomingJsonString = '
	[
    {
        "operatorId":"WEST",
        "destinationPortId":"NZAKA",
        "dischargePortId":"NZBLU",
        "loadPortId":"NZPOE",
        "imexStatus":"EXP",
        "prenotified":true,
        "receivalDetails":
            {
                "type":"Truck"
            },
            "id":"TEST6361904",
            "alternativeId":"6361904-ALT",
            "bookingId":"'&amp; UTRealBooking &amp;'",
            "cargoTypeId":"MAFI",
            "trailerTypeId":"MAFI 60 CUX",
            "weights":
                {
                    "gross":2000,
                    "tare":3000
                },
                "description":null,
                "childCargo":
                [
                    {
                        "operatorId":"WEST",
                        "destinationPortId":"GBIMM",
                        "dischargePortId":"GBIMM",
                        "loadPortId":"DECUX",
                        "imexStatus":"EXP",
                        "prenotified":true,
                        "receivalDetails":
                        {
                            "type":"Truck"
                        },
                        "id":"CH-63619-04",
                        "alternativeId":"",
                        "bookingId":"",
                        "cargoTypeId":"PAPER",
                        "cargoSubTypeId":"ROLLS",
                        "weights":
                            {"gross":2000,
                            "tare":0
                            },
                        "description":"SINGLE TRAILER",
                        "childCargo":[],
                        "hazards":[],
                        "customsReferences":
                        [{
                            "id":"CH-CR63619-04",
                            "typeId":"AESEXIT",
                            "position":1
                            }
                        ]
                        }  
                ],
                "hazards":[],
                "customsReferences":[{
                            "id":"CR63619-04",
                            "typeId":"AESEXIT",
                            "position":1
                            }],
                "voyageId":"UTBOLV10"
        }
    ]';

vars
	realTI, realTI2		: CM_TrackedItem;
	incomingJsonString,
	terminalCode,
	incomingJson2,
	loginJson			: String;
	expectFailure		: Boolean;
	booking				: CM_BookingRef;
	root				: CM_Root;
	operator 			: CM_Operator;
	voyageOrig			: CM_Voyage;
	terminal 			: CM_Terminal;
	cargoType			: CM_CargoType;
begin

	//create utHelperTerminal transient;
	
	root := app.myRoot;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	self.deleteCargo("TEST6361904","MAFI");
	self.deleteCargo("CH-63619-04","PAPER");
	voyageOrig := terminal.lookupVoyage("UTBOLV10", null, true);
	self.assertTrueMsg(voyageOrig &lt;&gt; null, method.name &amp; " | Setup: voyage is null/could not be found | Voyage Code: " &amp; "UTBOLV10");
	operator := root.allOperators["WEST"];
	self.assertTrueMsg(operator &lt;&gt; null, method.name &amp; " | Setup: operator is null/could not be found | Operator Code: " &amp; "WEST");
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("MAFI");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Cargo Type MAFI not found");
	
	incomingJsonString := IncomingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("CH-63619-04");
	assertEqual(realTI.allCustomsReferences.size, 1);
	realTI := self.getTrackedItem("TEST6361904");
	
	assertEqual(realTI.alternativeId, "6361904-ALT");
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(realTI.totalWeight, 5000.Decimal);
	assertEqual(realTI.bookingReference, "BK-63619-04");
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode, "WEST");
	assertEqual(realTI.voyageCode,"UTBOLV10");
	
	
epilog
	
end;</source>
    </JadeMethod>
