    <JadeMethod name="checkMethodExists" id="bc305cff-0d0c-473b-9749-dc79fa686d9c">
        <source>checkMethodExists(_listBox : ListBox; _method : DEV_Method) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	schemaName,
	className 		: String;
	currentMethod 	: Method;
	currentSource,
	newSource		: String;
	dialogResult	: Integer;
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	selectedMethod 	: DEV_Method;
	selIndex : Integer;
	devEnt : DEV_SchemaObjectEntity;
	
begin
	self.slStatus.caption := "Source Comparison: Method does not exist";
	
	if _method.myClass = null then
		return;
	endif;
	
	if _method.myClass.mySchema = null then
		return;
	endif;
	
	className := _method.myClass.name;
	schemaName := _method.myClass.mySchema.name;
	currentMethod := rootSchema.getSchema(schemaName).getClass(className).getMethod(_method.name);
	
	// Prevent the user from changing methods again until we're finished
	self.qlbMissingMethods.enabled := false;
	self.qlbMissingMethods.refreshNow();
	
	if currentMethod = null then
		return;
	endif;
	
	if _method.resolvedBy = null then
		dialogResult := app.msgBox('Method has been found, continue?', 'Method Found', MsgBox_Yes_No);
		if dialogResult = MsgBox_Return_Yes then
			selIndex := _listBox.listIndex;
			if selIndex &lt; 1 then
				return;
			endif;
			
			devEnt := _listBox.itemObject[selIndex].DEV_SchemaObjectEntity;
			
			// Mark the difference object as 'resolved'
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
					devEnt.setResolved(process.getComputerName);
				endif;
			endif;
			
			self.removeItemForIndex(selIndex, _listBox);
		endif;
	endif;
	
	if _method.resolvedBy &lt;&gt; null then
		self.slStatus.caption &amp;= " - Resolved by: " &amp; _method.resolvedBy &amp; "@" &amp; _method.resolvedAt.String;
	endif;
	
epilog
	self.qlbMissingMethods.enabled := true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_listBox" type="ListBox"/>
        <Parameter name="_method" type="DEV_Method"/>
    </JadeMethod>
    <JadeMethod name="checkNppAvailable" id="eb5758c2-53bd-4b75-b3c2-d284d18242a9">
        <updating/>
        <source>checkNppAvailable() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	nppProg86,
	nppProg	: File;
	
begin
	//Check if Notepad ++ is installed in default path either Program Files or Program Files (x86)
	create nppProg86 transient;
	nppProg86.fileName := node.getEnvironmentVariable("PROGRAMFILES(X86)") &amp; "\Notepad++\notepad++.exe";
	
	create nppProg transient;
	nppProg.fileName := node.getEnvironmentVariable("PROGRAMFILES") &amp; "\Notepad++\notepad++.exe";
	
	if nppProg86.isAvailable() or nppProg.isAvailable() then
		self.isNppAvailable := true;
	else
		self.isNppAvailable := false;
	endif;

epilog
	delete nppProg86;
	delete nppProg;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkWinMergeAvailable" id="0a0420d8-aba4-49c0-99d7-3c2005b6e7b9">
        <updating/>
        <source>checkWinMergeAvailable() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	winMergeProg86,
	winMergeProg	: File;
	
begin
	//Check if WinMerge is installed in default path either Program Files or Program Files (x86)
	
	create winMergeProg86 transient;
	winMergeProg86.fileName := "C:\Program Files (x86)\WinMerge\WinMergeU.exe";
	
	create winMergeProg transient;
	winMergeProg.fileName := "C:\Program Files\WinMerge\WinMergeU.exe";
	
	if winMergeProg86.isAvailable() or winMergeProg.isAvailable() then
		self.isWinMergeAvailable := true;
	else
		self.isWinMergeAvailable := false;
	endif;

epilog
	delete winMergeProg86;
	delete winMergeProg;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbSelectReport_click" id="184449e9-df7d-4610-887b-700421d35112">
