    <JadeMethod name="setupForm" id="b1908950-8e9e-4717-827d-279ee3196eb5">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2015	cnwndl1	Initial creation

*/

vars

	wagonCheck : CM_CargoCheck;

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myWagon := self.myMobileGenericAgent.myCurrentWagon;
	
	self.setupCmdButtons( 1, app.getErrorString(Back), null, null, null, null );
	
	
	inheritMethod();
	
	wagonCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if wagonCheck &lt;&gt; null then
		self.context := wagonCheck.context;
	endif;
	
	self.setupControls();


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblCargoChecks_click" id="cb6fdd78-5e1a-40dc-8fee-1a2ce08b9cbc">
        <controlMethod name="CM_MobEntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoChecks_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin
	
	self.doHandleTblCargoChecksClick(self.myHandHeldCheckerAgent, table.CM_MobEntryTable, false, self.myWagon );

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="366d1733-4ffb-4e41-9575-0a63812d14c9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020378, locale);
	lblWagonId.translateCaption(Xlat_0020379, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
