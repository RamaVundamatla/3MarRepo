    <JadeMethod name="comboBoxCountryRegion" id="7d26772b-0939-4eb6-b0ef-8ebf3704dba0">
        <source>comboBoxCountryRegion(_cmb : CMUI_ComboBox input; _country : CM_Country);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	countryRegion 		: CM_CountryRegion;
	
begin
	_cmb.clear();
	
	foreach countryRegion in app.myRoot.allCountryRegions discreteLock do
		//if countryRegion.allCountries.isEmpty() or countryRegion.allCountries.includes(_country) then
			_cmb.addItemObject(countryRegion.code &amp; Tab &amp; countryRegion.description, countryRegion);
