    <JadeMethod name="setProxy" id="72fd6253-6fbc-4268-b2a5-5ea281c53925">
        <updating/>
        <source>setProxy(	_cashValue : Decimal;
			_dateTime : TimeStamp;
			_myUser : CM_User;
			_sequenceNum : Integer;
			_chequeBank : String;
			_chequeBranch : String;
			_chequeNumber : String;
			_chequeDate : Date;
			_myPaymentMethod : CM_PaymentMethod;
			_myDebtorTerminal : CM_DebtorTerminal;
			_paymentType : Integer
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.cashValue        := _cashValue;
	self.dateTime         := _dateTime;
	self.sequenceNum      := _sequenceNum;
	self.chequeBank       := _chequeBank;
	self.chequeBranch     := _chequeBranch;
	self.chequeNumber     := _chequeNumber;
	self.chequeDate 	  := _chequeDate;
	self.paymentType 	  := _paymentType;			//09 Oct 2018	NDL:	TFS 41281
	self.myUser           := _myUser;
	self.myPaymentMethod  := _myPaymentMethod;
	self.myDebtorTerminal := _myDebtorTerminal;

epilog

end;</source>
        <Parameter name="_cashValue" type="Decimal"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_myUser" type="CM_User"/>
        <Parameter name="_sequenceNum" type="Integer"/>
        <Parameter name="_chequeBank" type="String"/>
        <Parameter name="_chequeBranch" type="String"/>
        <Parameter name="_chequeNumber" type="String"/>
        <Parameter name="_chequeDate" type="Date"/>
        <Parameter name="_myPaymentMethod" type="CM_PaymentMethod"/>
        <Parameter name="_myDebtorTerminal" type="CM_DebtorTerminal"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy2" id="299325ee-bd5f-4f09-a93b-3ee8612a8b82">
        <updating/>
        <source>setProxy2(_cashId1, 
		_cashId2, 
		_cashId3, 
		_cashId4 			 	 : String; 
		_payment1, 
		_payment2 		    	 : Decimal;
		_effectiveDate 			 : Date; 
		_externalInvoiceNumber,
		_externalReferenceNumber : String;
		_totalCargoCharges, 
		_cashAlreadyAllocated,
		_cashAllocationRequired,
		_cashPaymentRequired 	 : Decimal; 
		_voyage					 : CM_Voyage; 
		_agent 					 : CM_Object;
		_wo 					 : CM_WorkOrder; 
		_terminal 				 : CM_Terminal) updating;
// 32498 set the additional properties
// TFS 38524 WORK ORDER


vars

begin
	self.cashId1 				:= _cashId1;
	self.cashId2 				:= _cashId2;
	self.cashId3 			    := _cashId3;
	self.cashId4 				:= _cashId4;
	self.cashPayment1 			:= _payment1;
	self.cashPayment2 			:= _payment2;
	self.effectiveDate 			:= _effectiveDate;
	self.externalInvoiceNumber  := _externalInvoiceNumber;
	self.externalReceiptNumber  := _externalReferenceNumber;
	self.totalCargoCharges 		:= _totalCargoCharges;
	self.cashAllocationRequired := _cashAllocationRequired;
	self.cashAlreadyAllocated   := _cashAlreadyAllocated;
	self.cashPaymentRequired    := _cashPaymentRequired;
	self.myVoyage 				:= _voyage;
	self.myAgent 				:= _agent;
	self.myWorkOrder 			:= _wo;
	self.myTerminal 			:= _terminal; 
end;
</source>
        <Parameter name="_cashId1" type="String"/>
        <Parameter name="_cashId2" type="String"/>
        <Parameter name="_cashId3" type="String"/>
        <Parameter name="_cashId4" type="String"/>
