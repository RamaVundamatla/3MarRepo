    <JadeMethod name="createToDoTask" id="7ea07491-62ec-41c6-b8f1-d0f3362c26de">
        <source>createToDoTask(taskDesc : Integer; _wod : CM_WorkOrderToDoDtl): CM_VoyageToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoTask : CM_VoyageToDoTask;
	toDoDesc : CM_ToDoTaskDesc;
	found	 : Boolean;
	passport : CM_Passport;
begin
	passport := app.myPassport;
	
	toDoDesc := app.myRoot.allToDoTaskDescriptions[taskDesc]; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then 
	*/
	if toDoDesc &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		create toDoTask persistent;
		toDoTask.setForCreate(STATUS_TODO,	toDoDesc, null, passport, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.updateObjectEdition(self);		
		
		return toDoTask;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="taskDesc" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CM_VoyageToDoTask"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="dc4e2da6-9a0a-4939-b6b6-a9f8c1581544">
        <source>createTransaction(_type : Integer; _time : TimeStamp; _resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask; _wod : CM_WorkOrderToDoDtl): CMEVT_VoyageEvent;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 March 2023	navcs2	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	trans : CMEVT_VoyageEvent;
	wod : CM_WorkOrderToDoDtl;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
	
begin
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	trans := app.createEvent(_type, _time, self.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	if trans  &lt;&gt; null then
		trans.setMyVoyage(self);
		trans.addResourcesFromProxys(_resourceUsageProxys); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		trans.setToDoTask(_task); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		wod := _wod; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		if wod = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			wod := trans.getWorkOrderDetail().CM_WorkOrderToDoDtl; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		if wod &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setFromWOD(wod);// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1 // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
			//trans.setContractId(wod.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;	
		//trans.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(trans,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _type;
	cmifEventCtrl.dateTime := _time;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := self;
	cmifEventCtrl.myToDoTask := _task;
	cmifEventCtrl.myWorkOrderDetail := _wod;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(cmifEventCtrl.allResourceUsages);
	endif;
	
	trans := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent; 
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	return trans;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CMEVT_VoyageEvent"/>
    </JadeMethod>
    <JadeMethod name="createVoyageInlandTerminals" id="86f88383-985a-4a76-87dd-6ec57ed0a85e">
        <source>createVoyageInlandTerminals();
// ---------------------------------------------------------------------------
// Created:     10 September 2007 by cnwrs2
//
// Purpose:     For multi-terminal / inland terminal need to
//				create matching voyage in other terminal.
// ---------------------------------------------------------------------------
vars
	thisTerminal,
	inlandTerminal	: CM_Terminal;
	newVoyInlandTerminal	: CM_VoyageInlandTerminal;
	tmpVoy		: CM_Voyage;
begin

	if (not process.isInTransactionState()) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process not in transaction state');
		return;
	endif;
	
	if (self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Voyage is transient');
		return;
	endif;
	
	thisTerminal := self.myTerminal;
	
	foreach inlandTerminal in thisTerminal.allTerminalsForVoyageInland do
	
		// need error checking
		// - voyage with code does not exist in terminal
		// - self does not already have an inland voyage for this terminal
		
		tmpVoy := inlandTerminal.lookupVoyage(self.code, null, true);
		if tmpVoy &lt;&gt; null then
			//epr par 30725 19/11/12 - will create inland if does not exist on update so remove exception just continue
			continue;
		endif;
		
		create newVoyInlandTerminal persistent;
		newVoyInlandTerminal.setFromVoyageForCreate(self, inlandTerminal);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="f470c2c5-6a68-47af-941a-ae624fa0c182">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
// ---------------------------------------------------------------------------
// cnwdad1 18/05/2010 - PAR #24275: Changed to clean up proxy Arrival/Departure
// Global Voyages, which need to be deleted along similar lines to the persistents
// later in the method, otherwise the transients are leaked.
//12 Mar 2012	cnwrs1		Par 29251 - Garbage Collection failing with 1310
vars
	
	tmpVGArrival	: CM_VoyageGlobal;
	tmpVGDeparture	: CM_VoyageGlobal;
	globalVoyage	: CM_VoyageGlobal;
	isInvalid		: Boolean;
	isSameGV		: Boolean;
	edition			: Integer;
begin
	if self.isTransient() then
		on Exception do app.handleDeletedObject(exception, self.myShipBlockStack, isInvalid);//cnwas3 par23535
		delete self.myShipBlockStack;
		isInvalid := false;
		
		//09 Sep 2011	NDL	Par 28173
		on Exception do app.handleDeletedObject(exception, self.myNotNotifiedStack, isInvalid);
		delete self.myNotNotifiedStack;
		isInvalid := false;
		
		delete self.myHMSVoyageData;
		delete self.myGeneralCargoVoyage;
		delete self.myLogVoyageStructure;
		delete self.myCellularVoyageStructure;
		delete self.myROROStructure;	//04 Sep 2014	NDL	Par 33670

		// 6/11/18 MAP TFS41143	check whether the global voyage has been deleted
		if self.myVoyageGlobalArrival &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, self.myVoyageGlobalArrival, isInvalid);
			edition := self.myVoyageGlobalArrival.edition();
			if isInvalid then
				self.myVoyageGlobalArrival := null;
				isInvalid := false;
			endif;
		endif;
		if self.myVoyageGlobalDeparture &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, self.myVoyageGlobalDeparture, isInvalid);
			edition := self.myVoyageGlobalDeparture.edition();
			if isInvalid then
				self.myVoyageGlobalDeparture := null;
				isInvalid := false;
			endif;
		endif;
		
// cnwdad1 18/05/2010 - PAR #24275.
		on Exception do app.handleDeletedObject(exception, globalVoyage, isInvalid);
		isSameGV	:=	false;
		if self.myVoyageGlobalDeparture &lt;&gt; null
		and self.myVoyageGlobalArrival &lt;&gt; null
		and self.myVoyageGlobalDeparture = self.myVoyageGlobalArrival
		then
			isSameGV	:=	true;
		endif;
		
		// need to remove this transient from the collection on global voyages
		if self.myVoyageGlobalDeparture &lt;&gt; null and self.myVoyageGlobalDeparture.isTransient() then
			globalVoyage	:=	self.myVoyageGlobalDeparture;	// cnwdad1 18/05/2010 - PAR #24275.
			self.myVoyageGlobalDeparture.allVoyages.removeObject(self);
			self.myVoyageGlobalDeparture	:=	null;
			//if self.myVoyageGlobalDeparture.allVoyages.includes(self) then
			//	self.myVoyageGlobalDeparture.allVoyages.remove(self);
			//endif;
			
// cnwdad1 18/05/2010 - PAR #24275.
			if globalVoyage.allVoyages.isEmpty() then
				delete globalVoyage;
			endif;
		endif;
	
		if (not isSameGV) and self.myVoyageGlobalArrival &lt;&gt; null and self.myVoyageGlobalArrival.isTransient() then
			globalVoyage	:=	self.myVoyageGlobalArrival;		// cnwdad1 18/05/2010 - PAR #24275.
			self.myVoyageGlobalArrival.allVoyages.removeObject(self);
			self.myVoyageGlobalArrival	:=	null;
			//if self.myVoyageGlobalArrival.allVoyages.includes(self) then
			//	self.myVoyageGlobalArrival.allVoyages.remove(self);
			//endif;
			
// cnwdad1 18/05/2010 - PAR #24275.
			if globalVoyage.allVoyages.isEmpty() then
				delete globalVoyage;
			endif;
		endif;
		
		return;
	endif;

	exclusiveLock(self);
	self.allVoyageKPIEntities.purge;	//12 Mar 2012	cnwrs1		Par 29251 - Garbage Collection failing with 1310

	if self.myTerminal &lt;&gt; null then
		// Do not give an error at this point
		self.myTerminal.removeVoyageFromDict(self, true);
	endif;
	
	// Lorcan explicitly remove the voyage from allVoyages - not just set them to null
	if self.myVoyageGlobalDeparture &lt;&gt; null then
		tmpVGDeparture := self.myVoyageGlobalDeparture;
		self.myVoyageGlobalDeparture := null;
		tmpVGDeparture.allVoyages.removeObject(self);
		
// cnwdad1 29/01/2008 - PAR #15783.
		if self.myVoyageGlobalArrival = tmpVGDeparture then
			self.myVoyageGlobalArrival := null;
		endif;
		
		if tmpVGDeparture.allVoyages.size = 0 then
			delete tmpVGDeparture;
		endif;
	endif;
	
	if self.myVoyageGlobalArrival &lt;&gt; null
	and self.myVoyageGlobalArrival &lt;&gt; tmpVGDeparture
	then
		tmpVGArrival := self.myVoyageGlobalArrival;
		self.myVoyageGlobalArrival := null;
		tmpVGArrival.allVoyages.removeObject(self);
		
		if tmpVGArrival.allVoyages.size = 0 then
			delete tmpVGArrival;
		endif;
	endif;
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152 
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteAccrualsCargo" id="e665818c-5498-4468-8be3-2afe894441ac">
        <source>deleteAccrualsCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2024	navra1	Initial creation for //navra1 - MTN-33087 - 23rd Oct 2024

*/

vars
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
begin
	create tiSet transient;
	
	foreach ti in self.allOnshipTIsByIdCargoType where ti.manifestNumber.pos("ACCRUALS", 1) &lt;&gt; 0 do
		tiSet.add(ti);
	endforeach;
	
	self.doActualDeleteAccrualsCargo(tiSet);

	tiSet.clear();
	
	foreach ti in self.allOnsiteTIsByIdCargoType where ti.manifestNumber.pos("ACCRUALS", 1) &lt;&gt; 0 do
		tiSet.add(ti);
	endforeach;
	
	self.doActualDeleteAccrualsCargo(tiSet);
	
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVoyageAllocationConfigs" id="126c1e2d-5943-4fdd-a6c1-5195cdc6ed46">
        <source>deleteVoyageAllocationConfigs();
// --------------------------------------------------------------------------------
// Created:		8 December 2009 by cnwjo3
//
// Purpose:		its dirty, its nasty.  Its what i wrote.
//
vars
	yaimexConfig	: CM_YAIMEXConfig;
	vaConfig		: CM_VoyageAllocationConfig;
begin
	foreach yaimexConfig in self.allVoyageAllocationConfigs do
		if yaimexConfig.isKindOf(CM_VoyageAllocationConfig) then
			vaConfig := yaimexConfig.CM_VoyageAllocationConfig;
			vaConfig.setNullVoyage();
			delete vaConfig;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="description" id="2e30ee26-962c-4af1-a741-3265f320f82b">
