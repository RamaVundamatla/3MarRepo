    <JadeMethod name="getAuditText" id="26415333-e508-4d30-a982-d18ec21529c1">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt			: String;
	tmpStr		: String;
	commod  	: CM_Commodity;
	recipe 		: CM_Recipe;
	terminal	: CM_Terminal; // ### TFS 53752 03June2022 NAVPW1
	sealType	: CM_SealType; // ### TFS 53752 03June2022 NAVPW1
	
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	if self.myDrawingAttribute &lt;&gt; null then
		txt := txt &amp; 'Font' &amp; AuditStringSeparator &amp; self.myDrawingAttribute.fontName.length.String &amp; AuditStringSeparator &amp; self.myDrawingAttribute.fontName.String&amp; AuditStringSeparator;
        txt := txt &amp; 'Draw Attribute' &amp; AuditStringSeparator &amp; self.myDrawingAttribute.code.length.String &amp; AuditStringSeparator &amp; self.myDrawingAttribute.code.String&amp; AuditStringSeparator;
	endif;	
	txt := txt &amp; app.getErrorString(Number_cargo_subtypes) &amp; AuditStringSeparator &amp; self.allProducts.size.String.length.String &amp; AuditStringSeparator &amp; self.allProducts.size.String&amp; AuditStringSeparator;
	if self.myDefaultHandlingType &lt;&gt; null then
		txt := txt &amp; 'Default Handling Type' &amp; AuditStringSeparator &amp; self.myDefaultHandlingType.description.length.String &amp; AuditStringSeparator &amp; self.myDefaultHandlingType.description.String&amp; AuditStringSeparator;
	endif;
	//31 Mar 2017	NDL	TFS 3414
	if self.myDefHandlingSubType &lt;&gt; null then
		txt := txt &amp; 'Default Handling Sub Type' &amp; AuditStringSeparator &amp; self.myDefHandlingSubType.description.length.String &amp; AuditStringSeparator &amp; self.myDefHandlingSubType.description.String&amp; AuditStringSeparator;
	endif;
	txt := txt &amp; app.getErrorString(Cargo_subtypes) &amp; AuditStringSeparator &amp; self.productType.String.length.String &amp; AuditStringSeparator &amp; self.productType.String&amp; AuditStringSeparator;
	
	//21 May 2021	NDL	TF S51243
	tmpStr := null;
	foreach recipe in self.allRecipes do
		tmpStr := tmpStr &amp; recipe.getTextForAuditStrOnCargoType();
	endforeach;
	if tmpStr &lt;&gt; null then
		txt := txt &amp; "Recipes" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	// ### TFS 53752 03June2022 NAVPW1
	tmpStr := null;
	foreach commod in self.allCommodities do
		tmpStr := tmpStr &amp; commod.getTextForAuditStrOnCargoType();
	endforeach;
	if tmpStr &lt;&gt; null then
		txt &amp;= "Commodities" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;

	tmpStr := null;
	foreach terminal in self.allTerminals do
		tmpStr := tmpStr &amp; terminal.getTextForAuditStrOnCargoType();
	endforeach;
	if tmpStr &lt;&gt; null then
		txt &amp;= "Terminals" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	foreach sealType in self.allSealTypes do
		tmpStr := tmpStr &amp; sealType.getTextForAuditStrOnCargoType();
	endforeach;
	if tmpStr &lt;&gt; null then
		txt &amp;= "Seal Types" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	// ### TFS 53752 03June2022 NAVPW1
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBulkTrackByDisplayForWeight" id="3da0b24e-8443-44cd-80dd-c075cb7480b2">
        <source>getBulkTrackByDisplayForWeight( _weight : Decimal; 
								_density : Decimal;
								_showUnit : Boolean) : String;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	volume  	: Decimal[14,4];
		amount, unit		: String;
begin
	if not self.isBulkMulti then
		return null;
	endif;
	
	if self.isTrackByWeight then
		
		if self.myWeightMeasurementType &lt;&gt; null then
			unit := self.myWeightMeasurementType.shortName;		
			amount:=app.convertMeasurementForDisplay(unit, _weight);
			if amount = null then
				amount:="0";
			endif;
			if _showUnit then
				return amount &amp; Space &amp; unit;
			else
				return amount;
			endif;
		endif;	
	else
			
		if _density &gt; 0 then
			volume:= _weight/_density;
		endif;
		if self.myVolumeMeasurementType &lt;&gt; null then
			unit :=  self.myVolumeMeasurementType.shortName;
			amount:=app.convertMeasurementForDisplay(unit, volume);
			if amount = null then
				amount:="0";
			endif;
			if _showUnit then
				return amount &amp; Space &amp; unit;
			else
				return amount;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_density" type="Decimal"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConvertedVolumeDisplay" id="ed227d6b-109e-47c0-9367-886058d29bfb">
        <source>getConvertedVolumeDisplay(  _volumeM3 : Decimal; 
							_showUnit : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2014	cnwndl1	Initial creation
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed

*/

vars

	amount : String;
	unit : String;

begin

	if not self.isBulkMulti then
		return null;
	endif;
	
	if self.myVolumeMeasurementType &lt;&gt; null then
		unit :=  self.myVolumeMeasurementType.shortName;
		amount := app.convertMeasurementForDisplay( unit, _volumeM3 );
		if _showUnit then
			return amount &amp; Space &amp; unit;
		else
			return amount;
		endif;
	endif;
	
	if _showUnit then
		//return _volumeM3.asStringMeasurementJMT &amp; "m3"; //13/09/2023 navmv20 Bug 60217
		return app.getVolumeForDefaultDisplay(_volumeM3); //13/09/2023 navmv20 Bug 60217
	else
		//return _volumeM3.asStringMeasurementJMT; //13/09/2023 navmv20 Bug 60217
		return app.getVolumeForDefault(_volumeM3); //13/09/2023 navmv20 Bug 60217
	endif;

epilog

end;</source>
        <Parameter name="_volumeM3" type="Decimal"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConvertedWeightDisplay" id="74b3d50b-8428-41d1-8449-708c3a1459a5">
        <source>getConvertedWeightDisplay(  _weightKgs : Decimal; 
							_showUnit : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2020	jlgndl1	Initial creation	TFS 49189
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed

*/

vars

	amount : String;
	unit : String;

begin

	if self.myWeightMeasurementType &lt;&gt; null then
		unit :=  self.myWeightMeasurementType.shortName;
		amount := app.convertMeasurementForDisplay( unit, _weightKgs );
		if _showUnit then
			return amount &amp; Space &amp; unit;
		else
			return amount;
		endif;
	endif;
	
	if _showUnit then
		//return _weightKgs.asStringMeasurementJMT &amp; "kg"; //13/09/2023 navmv20 Bug 60217
		return app.getWeightForDefaultDisplay(_weightKgs); //13/09/2023 navmv20 Bug 60217
	else
		//return _weightKgs.asStringMeasurementJMT; //13/09/2023 navmv20 Bug 60217
		return app.getWeightForDefault(_weightKgs); //13/09/2023 navmv20 Bug 60217
	endif;

epilog

end;</source>
        <Parameter name="_weightKgs" type="Decimal"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
