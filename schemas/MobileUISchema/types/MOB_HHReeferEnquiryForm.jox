    <Constant name="HELP_DESCRIPTION" id="5e568bed-10c7-45b4-9a78-5a40bd7e308f">
        <constantUsages>
            <GlobalConstant name="CrLf"/>
        </constantUsages>
        <source>"Type a partial container ID in the search box and click the search button to find a Container. This search will only find Reefer Containers." &amp; CrLf &amp; CrLf &amp;
"Use the context menu to navigate to other forms."&amp; CrLf &amp; CrLf &amp;
"White Background = Connected" &amp; CrLf &amp;
"Green Background = Not connected but has been previously" &amp; CrLf &amp; 
"Pink Background = Never Connected" &amp; CrLf &amp; CrLf &amp;
"If the Reefer has a controlled atmosphere then the 'O2' and 'CO2' rows will be highlighted Yellow."</source>
        <type name="String"/>
    </Constant>
