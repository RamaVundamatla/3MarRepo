    <JadeMethod name="btnAttachment_click" id="9d496e08-6f98-47e3-b511-5e9a0057ec32">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAttachment_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Mar 2022	navgm20	Initial creation  #52949
14 Mar 2022	navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
*/

vars
	obj 	  : Object;
	schema    : Schema;
	class     : Class;
	assistant : Object;
	cargoType : Object;
begin
	
	obj := self.btnAttachment.userObject;
	
	if obj.isKindOf(CM_CargoType) then
		cargoType := obj.CM_CargoType;
	else
		return;
	endif;
	
	schema := currentSchema.getSchema("UiCommonSchema");
	class  := schema.getClass("CMUI_Assistant");
	
	create assistant as class transient;
	assistant.sendMsgWithParams( "showFileAttachmentsForm", cargoType, self.myMasterMenuAction );
epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
