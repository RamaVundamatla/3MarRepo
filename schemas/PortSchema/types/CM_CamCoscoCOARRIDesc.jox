    <JadeMethod name="makeMessageHeader" id="84367fd1-7168-4708-95a2-a8c2f989eddc">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input;
					_unhSeqNumber : Integer io; _type : String; _fileType : String;
					_coll :HugeStringArray input) : String updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _cmaFile/_camTaskHistory parameter usage from io to input
// 16/05/2011	cnwcs5 	CCMS SCT 2058/par 27460 - replace literals with characters defined on protocol
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	protocol	:CM_CamProtocol;	// par 27460 cnwcs5
	strLine : String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol		:= _camTaskHistory.camProtocol;	// par 27460 cnwcs5
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "ANZ10", null, _camTaskHistory.runDateTime), _coll);

	// BGM segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, _unhSeqNumber, 9, null), _coll);
	
	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageNAD_CF" id="8fdcf404-020b-424a-99ca-497192ef22de">
        <source>makeMessageNAD_CF(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*
Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	value, msg	:String;
	foundMatch	:Boolean;
begin
	if _protocol.useContainerOperator_In_NAD_CF then
		value	:= app.myRoot.getXlationForeignOperatorCode( null, _ti.CM_Container.operatorCode.trimBlanks, foundMatch).trimRight;
	else
		value	:= _protocol.camGroup.recipient.trimRight;
	endif;
	
	msg := self.makeNADSegment (_protocol, _group, "CF", value, '172', '20');
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_ABT" id="78a9a8c7-ad67-4ad4-807f-2ba48b49afb0">
        <source>makeMessageRFF_ABT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	msg	:String;
begin
	if _ti.customExportEntryNumber.trimRight &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="261634dc-9735-4f0e-8c43-a471cfe85db6">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 10 May 2011	cnwcs5	CCMS SCT 2058/par 27460 - user defined special characters
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	theTI 					: CM_TrackedItem;
	contStatus, imExStatus	: String;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
// COSCO
	theTI := _transaction.myTrackedItem;

	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   theTI &lt;&gt; null and 
	   theTI.isWeightCertified and 
	   not theTI.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	imExStatus := self.imExStatusToString(theTI);

	// EQD segment
	//self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, theTI.CM_Container.isoType, '102', '5', null, imExStatus, contStatus); // par 27460 09/05/2011 cnwcs5 	 //23/08/2017 cnwma1 TFS #5834
	isoCode := theTI.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contStatus); //23/08/2017 cnwma1 TFS #5834 	
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	if _camMessage.activity = COARRI_SHIPDISCHARGE then
		// RFF+CV
		self.makeRFFSegment (_camProtocol, _camMessage.group3, "CV", "88888888");	// PAR 27460 CNWCS5
	else
		// RFF+BN
		self.makeMessageRFF_BN (_camProtocol, _camMessage.group3,  theTI);	// par 27460 cnwcs5
	endif;

	// RFF+CN
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group3, theTI);	// par 27460 cnwcs

	//CCMS 1251
	// RFF+ABT
	self.makeMessageRFF_ABT (_camProtocol, _camMessage.group3,  _camMessage.activity, theTI);	// par 27460 cnwcs5
	
	// DTM - transaction date/time
	self.makeDTMSegment (_camProtocol, _camMessage.group3, self.getDTMFormatQualifier(_camProtocol), _transaction.dateTime, "203"); // TFS 53754
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group3, theTI);					// TFS 4492
	endif;

	// LOC segments
	self.makeMessageLOC (_camProtocol, _camMessage.group3, _camMessage.activity, theTI);	// par 27460 cnwcs5

	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3,theTI,null); //epr par 37551 TFS 1429 16/2/16

	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group3, theTI);		// par 27460 09/05/2011 cnwcs5
	
	// TMP Segment
	self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, theTI.getTemperature, "CEL");	// par 27460 09/05/2011 cnwcs5 				

	//the SEL for the seal number
	self.makeMessageSealsData( theTI, _camMessage, _camMessage.group3, _camProtocol, contStatus);	//15 Sep 2010	NDL	Par 25608

	// ie Dangerous Goods
	self.makeMessageHazardsData (theTI, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
	
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group3, 'RG', theTI);	// par 27460 09/05/2011 cnwcs5

	// NDA+CF
	self.makeMessageNAD_CF (_camProtocol, _camMessage.group3, theTI);	// par 27460 cnwcs5	
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then		// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group3, theTI);								// TFS #2061
	endif;																								// TFS #2061
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="9a9d9590-82b8-4207-8c0e-2e2b7dc681a3">
        <updating/>
        <source>outputHeader_NAD(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	recipientCode, code, camISOPortDesc	:String;
	terminal							:CM_Terminal;
	strLine : String;
begin
	terminal		:= _protocol.terminal;
	recipientCode 	:= _protocol.camGroup.recipient.trimBlanks;
	code 			:= terminal.getConfig(PortDestCode).String;
	camISOPortDesc 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal).trimBlanks;

	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", recipientCode, "160", "143"), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "MS", camISOPortDesc, '160', '143'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_TDT" id="88fdcb50-4ef9-46fd-83ea-1d2e2e099e1a">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	voyage		:CM_Voyage;
	senderCode	:String;
	strLine : String;
begin
	voyage		:= _camVoyage.voyageOid;
	senderCode 	:= _protocol.camGroup.senderCode.trimBlanks;
	
	if _protocol.camGroup.useCallSign then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), null, 
													null, "COSCO", "160", senderCode, null, null, voyage.callSign.trimRight, '103', '87', voyage.vesselName.trimRight.toUpper), _coll);
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), null, 
													null, "COSCO", "160", senderCode, null, null, voyage.lloydsNumber, '146', '87', voyage.vesselName.trimRight.toUpper), _coll);
	endif;

	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="788f9e02-3665-4d94-8bd9-069bf6bb9ce0">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars

begin
	return self.outputFileMessage (_camTaskHistory, 
									self.makeUNBSegment (_protocol, "UNOA", 1, self.getSenderCode_UNB (_protocol), "ZZ", 
									_protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, false, _camTaskHistory.runDateTime),
									_coll);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="d9d7e91c-6746-44b3-9b9f-98a6cdf2e5e7">
        <updating/>
        <source>outputHeader_UNH_BGM(_camFile :CM_CamFile input; _camTaskHistory :CM_CamTaskHistory input; _activity :Integer; 
			_unhSeq, _segmentCount :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:	Refactored code	

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
constants
	COARRI = "COARRI";
	LOAD = "46";
	DISCHARGE = "44";
vars
	colon	:Character;
	strLine : String;
begin
	// it is not ideal to concatenate sub-elements here but I don't want to change the signature for makeMessageHeader
	// for the 7.8.2 hotfix (par 27460)
	colon := _camTaskHistory.camProtocol.subElementSeparator;
	
	if _activity = COARRI_SHIPLOAD then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, LOAD &amp; colon &amp; colon &amp; colon &amp; "LOD", COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
		
	elseif _activity = COARRI_SHIPDISCHARGE then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, DISCHARGE &amp; colon &amp; colon &amp; colon &amp; "DIS", COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_unhSeq" type="Integer" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="a9d3915b-60d2-4640-944b-ed146ce1614d">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/* special version for COSCO which creates one message per container */
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
// 12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 18 Dec 2012	cnwcs5	CCMS SFW 1294 /  par 30855
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage 			: CM_CamMessage;
	messageType 		: Integer;
	code, xlVoyage 		: String;
	vesselName 			: String;
	voyageOid			:CM_Voyage;
	pos3, pos4, pos5	: Integer;
	ti 					: CM_TrackedItem;
	terminal			: CM_Terminal;
begin
	_camAgent.writeDebugLog(class.name &amp; '::' &amp; method.name &amp; " process " &amp; _transaction.getCamsDisplayDetails);
	
	if _transaction.isCamsShipReceiveType() then
		messageType := COARRI_SHIPDISCHARGE;
	elseif _transaction.isCamsShipReleaseType() then
		messageType := COARRI_SHIPLOAD;
	else
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction not a ship receive/release.");
		endif;
		return;
	endif;
	
	//translate the voyage Code
	ti 			:= _transaction.myTrackedItem;
	code 		:= ti.myVoyage.code;
	terminal	:= _camProtocol.terminal;
	xlVoyage 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_VOYAGETERMINAL, terminal);
	camMessage 	:= self.setCamMessage(messageType, _camProtocol, _camFile, _transaction, xlVoyage, vesselName, voyageOid, terminal);

	if camMessage &lt;&gt; null then
		camMessage.camVoyage.voyageOid 	:= ti.myVoyage;
		camMessage.tiId 				:= ti.id.trimRight;
		pos3 							:= camMessage.group3.size;
		
		self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyage, terminal, null);
		
		camMessage.setupCAMSInfoDetails(_camProtocol, pos3, pos4, pos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
	else
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
		endif;
	endif;
epilog
	
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCamMessage" id="d5069d23-ede6-4f7b-b736-d5db4cf6a20a">
        <updating/>
        <source>setCamMessage(_messageType:Integer; _camProtocol: CM_CamProtocol; _camFile: CM_CamFile input; _transaction: CM_TITransaction; _voyageCode, _vesselName: String output; _voyageOid: CM_Voyage output; _terminal:CM_Terminal): CM_CamMessage updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
vars
	camMessage 	: CM_CamMessage;
	fCode 		: String;
	vesselName 	: String; //par18987 cnwrs1 mar 2009
begin

	//get the voyage code
	_voyageOid := null;
	
	if _voyageOid &lt;&gt; null then
		_voyageCode := "";
		_voyageOid 	:= null;
		
		if _transaction.myTrackedItem.myVoyage.code &lt;&gt; "" then
			_voyageOid := _terminal.lookupVoyage(_transaction.myTrackedItem.myVoyage.code, _transaction.myTrackedItem.myVoyage.arrivedDT, false);
			
			if _voyageOid &lt;&gt; null then
				if _voyageOid.inwardCode &lt;&gt; "" then
					_voyageCode := _voyageOid.inwardCode;
					_voyageOid 	:= _terminal.lookupVoyage(_voyageCode, null, false);
				endif;
			endif;
		endif;
	else
		fCode 		:= _transaction.myTrackedItem.myVoyage.code.trimRight;
		_voyageOid 	:= _transaction.myTrackedItem.myVoyage;
		
		//translate the voyage Code
		if fCode = "HOLD" then
			_voyageCode := fCode;
		elseif fCode = NULL_VOYAGE_CODE then
			_voyageCode := null;
		else
			_voyageCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, fCode, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
		endif;
	endif;

// setup the cam message for this transaction
	camMessage := self.getCamMessageById(_camFile, _voyageCode, vesselName, _messageType, _transaction.myTrackedItem.id);
	return camMessage;
end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
        <Parameter name="_vesselName" type="String" usage="output"/>
        <Parameter name="_voyageOid" type="CM_Voyage" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
</Class>
