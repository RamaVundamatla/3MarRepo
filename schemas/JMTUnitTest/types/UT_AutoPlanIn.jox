    <JadeMethod name="doATestAutoPlan" id="74a83d56-e2c9-480c-a7b6-aafed19efa5d">
        <source>doATestAutoPlan( _tiArray : CM_TIArray input; _expectedLocArray : CM_LCArray; _ta: CM_TerminalArea );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2013	cnwndl1	Initial creation	Par 32049

*/

vars

	tapRoot : CM_TestAutoPlanRoot;
	tapTI : CM_TrackedItem;
	result : CM_TestAutoPlanResult;
	index : Integer;
	pLoc : CM_LocationsController;
	pLocId : String;
	expectedPLoc : CM_LocationsController;
	expectedPLocId : String;

begin

	create tapRoot transient;
	tapRoot.doTestAutoPlan( null,	//_tblSelected : Table input;
							_tiArray,	//_alternateSelection : CM_TIArray input;
							self.getTerminal(),	//_terminal : CM_Terminal;
							_ta,	//_terminalArea : CM_TerminalArea
							true
							);
							
	foreach tapTI in _tiArray do
		index := index + 1;
		result := tapRoot.getResultFor( tapTI );
		expectedPLoc := _expectedLocArray[index];
		if expectedPLoc &lt;&gt; null then
			expectedPLocId := expectedPLoc.getFullId;
		else
			expectedPLocId := "null";
		endif;
		if result &lt;&gt; null and result.isPlanned then
			pLoc := result.CM_TestAutoPlanPlanned.myPlannedLocation;
			pLocId := pLoc.getFullId; 
		else
			pLoc := null;
			pLocId := "null";
		endif;
		self.assertTrueMsg( pLoc = expectedPLoc, tapTI.id &amp; " - Wrong Test auto plan location, expected '" &amp; expectedPLocId &amp; ", but got '" &amp; pLocId &amp; "");
	endforeach;

epilog

	delete tapRoot;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_expectedLocArray" type="CM_LCArray"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="tAutoPlanSplitBulk" id="e4123729-45e2-4572-8c1b-6288180eeed5">
        <source>tAutoPlanSplitBulk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2016	cnwndl1	Initial creation	TFS 2172

*/

constants

	BlockStackId1 : String = "UTYABS1";
	BlockStackId2 : String = "UTYABS2";
	BlockStackId3 : String = "UTYABS3";
	BlockStackId4 : String = "UTYABS4";
	CargoTypeDesc : String = "UTYAREBAR";
	ProductId : String = "UTYAPROD";
	YAId : String = "UTYASPLIT";
	CargoID1 : String = "UTSPLIT16";
	CargoID2 : String = "UTSPLIT7";
	CargoID3 : String = "UTSPLIT8";
	
vars

	
	defaultBS : CM_BlockStack;
	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	bs3 : CM_BlockStack;
	cargoType : CM_CargoType;
	product : CM_Product;
	operator : CM_Operator;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	agent : CM_YAAutoplanAgent;
	tiMoveArray	: CM_TIArray;

begin

	create tiMoveArray transient;
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;

	self.deleteCargoType(CargoTypeDesc);
	self.deleteYA(YAId);
	deleteTerminalArea(BlockStackId1);
	deleteTerminalArea(BlockStackId2);
	deleteTerminalArea(BlockStackId3);
	deleteTerminalArea(BlockStackId4);
	self.disableAllYA(true);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType(CargoTypeDesc, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CargoTypeDesc &amp; " not created during setup.");
	
	product := self.addProduct(ProductId, operator, cargoType);
	self.assertTrueMsg(product &lt;&gt; null, CargoTypeDesc &amp; "/" &amp; ProductId &amp; " not created during setup.");
	
	defaultBS := self.addBlockStack(BlockStackId4, 99, null);
	self.assertTrueMsg(defaultBS &lt;&gt; null, BlockStackId4 &amp; " not created during setup.");
	
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, BlockStackId1 &amp; " not created during setup.");
	
	self.addMinMaxToTerminalArea(	bs1,	//_tam : CM_TerminalAreaMaster input;
									cargoType,	//_cargoType : CM_CargoType;
									product,	//_cargoSubType : CM_Product;
									0,	//_minVol	: Decimal;
									0,	//_minWeight : Integer; 
									0,	//_maxVol		: Decimal;
									0,	//_maxWeight : Integer;
									5	//_maxQuantity : Integer
									);
									
	self.assertTrueMsg(bs1.allProductMinMax.size = 1, BlockStackId1 &amp; " Cargo Min Max not created during setup.");
	
	bs2 := self.addBlockStack(BlockStackId2, 99, null);
	self.assertTrueMsg(bs2 &lt;&gt; null, BlockStackId2 &amp; " not created during setup.");
	
	self.addMinMaxToTerminalArea(	bs2,	//_tam : CM_TerminalAreaMaster input;
									cargoType,	//_cargoType : CM_CargoType;
									product,	//_cargoSubType : CM_Product;
									0,	//_minVol	: Decimal;
									0,	//_minWeight : Integer; 
									0,	//_maxVol		: Decimal;
									0,	//_maxWeight : Integer;
									5	//_maxQuantity : Integer
									);
									
	self.assertTrueMsg(bs2.allProductMinMax.size = 1, BlockStackId2 &amp; " Cargo Min Max not created during setup.");
	
	bs3 := self.addBlockStack(BlockStackId3, 99, null);
	self.assertTrueMsg(bs3 &lt;&gt; null, BlockStackId3 &amp; " not created during setup.");
	
	self.addMinMaxToTerminalArea(	bs3,	//_tam : CM_TerminalAreaMaster input;
									cargoType,	//_cargoType : CM_CargoType;
									product,	//_cargoSubType : CM_Product;
									0,	//_minVol	: Decimal;
									0,	//_minWeight : Integer; 
									0,	//_maxVol		: Decimal;
									0,	//_maxWeight : Integer;
									5	//_maxQuantity : Integer
									);
									
	self.assertTrueMsg(bs3.allProductMinMax.size = 1, BlockStackId3 &amp; " Cargo Min Max not created during setup.");
	
	create locations transient;
	locations.add(bs1.allLocationsControllers.first);
	locations.add(bs2.allLocationsControllers.first);
	locations.add(bs3.allLocationsControllers.first);
	
	//create a normal YA NOT using multi range, ie. doesn't allow for splits
	self.opts.purge();
	ya := self.addYA(YAId, YACriteriaType_CargoType, cargoType, null, null, null, null, locations, null);
	self.assertTrueMsg(ya &lt;&gt; null, YAId &amp; " not created during setup.");
	
	self.opts.purge();
	self.opts.addAssoc("totalQuantity", 16);
	self.opts.addAssoc(ETRow_MyProduct, product.code);
	ti1 := self.addCargoOpts(CargoID1, "", "", operator, cargoType.id);
	self.assertTrueMsg(ti1 &lt;&gt; null, CargoID1 &amp; " not created during setup.");
	self.assertTrueMsg(ti1.totalQuantity = 16, CargoID1 &amp; " total quantity not 16 created during setup.");
	self.assertTrueMsg(ti1.myProduct = product, CargoID1 &amp; " product not created during setup.");
	self.move(ti1,defaultBS);
	
	self.opts.purge();
	self.opts.addAssoc("totalQuantity", 7);
	self.opts.addAssoc(ETRow_MyProduct, product.code);
	ti2 := self.addCargoOpts(CargoID2, "", "", operator, cargoType.id);
	self.assertTrueMsg(ti2 &lt;&gt; null, CargoID2 &amp; " not created during setup.");
	self.assertTrueMsg(ti2.totalQuantity = 7, CargoID2 &amp; " total quantity not 7 created during setup.");
	self.assertTrueMsg(ti2.myProduct = product, CargoID2 &amp; " product not created during setup.");
	self.move(ti2,defaultBS);
	
	self.opts.purge();
	self.opts.addAssoc("totalQuantity", 8);
	self.opts.addAssoc(ETRow_MyProduct, product.code);
	ti3 := self.addCargoOpts(CargoID3, "", "", operator, cargoType.id);
	self.assertTrueMsg(ti3 &lt;&gt; null, CargoID3 &amp; " not created during setup.");
	self.assertTrueMsg(ti3.totalQuantity = 8, CargoID3 &amp; " total quantity not 8 created during setup.");
	self.assertTrueMsg(ti3.myProduct = product, CargoID3 &amp; " product not created during setup.");
	self.move(ti3,defaultBS);
	
	//Auto plan of 16 should fail we only have space for 15 in total in the term, in 3 lots of 5.
	tiMoveArray.clear();
	tiMoveArray.add(ti1);
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.opts.addAssoc("IgnoreErrors", true);
	self.autoplanTIs(tiMoveArray);
	agent := app.myYAAgent;
	self.assertTrueMsg(agent &lt;&gt; null, "Auto Plan agent not found after setup.");
	self.assertTrueMsg(agent.myCurrentCMIFYAAutoPlan.allFoundLCs.isEmpty = true, "Should not have found any suitable locations - Test 1a");
	self.assertTrueMsg(ti1.allQueuedFutureMoves.isEmpty, "Should not have found any suitable locations - Test 1b");
	
	//Auto plan of 7 should fail we only have space for 5 in any one place.
	tiMoveArray.clear();
	tiMoveArray.add(ti2);
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.opts.addAssoc("IgnoreErrors", true);
	self.autoplanTIs(tiMoveArray);
	agent := app.myYAAgent;
	self.assertTrueMsg(agent.myCurrentCMIFYAAutoPlan.allFoundLCs.isEmpty = true, "Should not have found any suitable locations - Test 2a");
	self.assertTrueMsg(ti2.allQueuedFutureMoves.isEmpty, "Should not have found any suitable locations - Test 2b");
	
	
	//Now try with a YA using multi range, ie. Allow for splits
	self.deleteYA(YAId);
	
	self.opts.purge();
	self.opts.addAssoc("AllowMultiRangeSplit", true.Integer);
	ya := self.addYA(YAId, YACriteriaType_CargoType, cargoType, null, null, null, null, locations, null);
	self.assertTrueMsg(ya &lt;&gt; null, YAId &amp; " not created during setup.");
	self.assertTrueMsg(ya.allowMultiRangeSplit = true.Integer, YAId &amp; " not set as 'allowMultiRangeSplit' second during setup.");
	
	//Auto plan of 16 should fail we only have space for 15 in total in the term, in 3 lots of 5.
	tiMoveArray.clear();
	tiMoveArray.add(ti1);
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.opts.addAssoc("IgnoreErrors", true);
	self.autoplanTIs(tiMoveArray);
	agent := app.myYAAgent;
	self.assertTrueMsg(agent &lt;&gt; null, "Auto Plan agent not found after setup.");
	self.assertTrueMsg(agent.myCurrentCMIFYAAutoPlan.allFoundLCs.isEmpty = true, "Should not have found any suitable locations - Test 3a");
	self.assertTrueMsg(ti1.allQueuedFutureMoves.isEmpty, "Should not have found any suitable locations - Test 3b");
	
	
	//Auto plan of 7 should now queue splitting the amount and locations.
	tiMoveArray.clear();
	tiMoveArray.add(ti2);
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.autoplanTIs(tiMoveArray);
	self.assertTrueMsg(agent.myCurrentCMIFYAAutoPlan.allFoundLCs.isEmpty = true, "Should not have found any suitable locations (suitable on there own) - Test 4a");
	self.assertTrueMsg(ti2.allQueuedFutureMoves.size = 2, "Should have Queued to split locations - Test 4b");
	self.assertTrueMsg(ti2.allWorklistEntries.size = 2, "Should have Queued to split locations - Test 4c");
	self.assertTrueMsg(ti2.allWorklistEntries.first.locationTarget = BlockStackId1, "Should have Queued to " &amp; BlockStackId1 &amp; " - Test 4d");
	self.assertTrueMsg(ti2.allWorklistEntries.first.quantity = 5, "Should have Queued 5 to " &amp; BlockStackId1 &amp; " - Test 4e");
	self.assertTrueMsg(ti2.allWorklistEntries.last.locationTarget = BlockStackId2, "Should have Queued to " &amp; BlockStackId2 &amp; " - Test 4f");
	self.assertTrueMsg(ti2.allWorklistEntries.last.quantity = 2, "Should have Queued 2 to " &amp; BlockStackId1 &amp; " - Test 4g");
	
	//Auto plan of 8 should now queue splitting the amount and locations.
	tiMoveArray.clear();
	tiMoveArray.add(ti3);
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.autoplanTIs(tiMoveArray);
	self.assertTrueMsg(agent.myCurrentCMIFYAAutoPlan.allFoundLCs.isEmpty = true, "Should not have found any suitable locations (suitable on there own) - Test 5a");
	self.assertTrueMsg(ti3.allQueuedFutureMoves.size = 2, "Should have Queued to split locations - Test 5b");
	self.assertTrueMsg(ti3.allWorklistEntries.size = 2, "Should have Queued to split locations - Test 5c");
	self.assertTrueMsg(ti3.allWorklistEntries.first.locationTarget = BlockStackId2, "Should have Queued to " &amp; BlockStackId2 &amp; " - Test 5d");
	self.assertTrueMsg(ti3.allWorklistEntries.first.quantity = 3, "Should have Queued 3 to " &amp; BlockStackId2 &amp; " - Test 5e");
	self.assertTrueMsg(ti3.allWorklistEntries.last.locationTarget = BlockStackId3, "Should have Queued to " &amp; BlockStackId3 &amp; " - Test 5f");
	self.assertTrueMsg(ti3.allWorklistEntries.last.quantity = 5, "Should have Queued 5 to " &amp; BlockStackId3 &amp; " - Test 5g");
	
	
epilog

	self.disableAllYA(false);
	delete locations;
	delete tiMoveArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanOf40ToRightEdgeOfTA" id="1980d20c-4eef-4142-8907-8081b271c2f6">
        <source>tAutoplanOf40ToRightEdgeOfTA();
// cnwndl1
//20 November 2008	cnwdw1	
// Test that a 40 container can not planned to the last location of a TA row 
// (as the backend will NOT be in the TA)
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	ti20, ti40: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;
	
	tiTapArray : CM_TIArray;
	expectedLocArray : CM_LCArray;

begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	ti20 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti40 := self.addContainerOpts("TEST0000002", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	//Test Auto Plan testing
	create tiTapArray transient;
	create expectedLocArray transient;
	tiTapArray.add(ti20);
	expectedLocArray.add(locations.first);
	tiTapArray.add(ti40);
	expectedLocArray.add(null);
	self.doATestAutoPlan( tiTapArray, expectedLocArray, ta);
	
	// Plan and move a 20
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti20 to correct location");
	self.move(ti20, location);
	self.assertEqualMsg(ti20.myPrimaryActualLocation, location, "Did not move ti20 to correct location");

	// Try to plan a 40, should fail as no room for complete container
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertNullMsg(location, "Did not failed to autoplan ti40");

	// Delete the 20, then retry autoplan. Should succeed
	self.deleteContainer("TEST0000001");
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti40 to correct location");
	self.move(ti40, location);
	self.assertEqualMsg(ti40.myPrimaryActualLocation, location, "Did not move ti40 to correct location");
	
	
epilog

	delete locations;
	delete tiTapArray;
	delete expectedLocArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanOf40ToRightOfYA" id="b65e3e5c-67b0-4eaa-a364-b820fdeeb9f8">
        <source>tAutoplanOf40ToRightOfYA();
// cnwndl1
//20 November 2008	cnwdw1	
// Test that a 40 container can not planned to the right location of a YA 
// (as the backend will NOT be in the YA)
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	ti20, ti40: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;
	
	tiTapArray : CM_TIArray;
	expectedLocArray : CM_LCArray;

begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	ti20 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti40 := self.addContainerOpts("TEST0000002", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	//Test Auto Plan testing
	create tiTapArray transient;
	create expectedLocArray transient;
	tiTapArray.add(ti20);
	expectedLocArray.add(locations.first);
	tiTapArray.add(ti40);
	expectedLocArray.add(null);
	self.doATestAutoPlan( tiTapArray, expectedLocArray, ta);
	
	// Plan and move a 20
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti20 to correct location");
	self.move(ti20, location);
	self.assertEqualMsg(ti20.myPrimaryActualLocation, location, "Did not move ti20 to correct location");

	// Try to plan a 40, should fail as no room for complete container
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertNullMsg(location, "Did not failed to autoplan ti40");

	// Delete the 20, then retry autoplan. Should succeed
	self.deleteContainer("TEST0000001");
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti40 to correct location");
	
	
epilog

	delete locations;
	delete tiTapArray;
	delete expectedLocArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanToLOBArea" id="c1f5b270-7efd-4f0c-b790-5e8293c169a3">
        <source>tAutoplanToLOBArea();
// cnwndl1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2012	cnwrd1	Initial creation

*/


constants

	ForkLiftStackId			: String = "UTRJDGBS1";
	BlockStackId			: String = "UTRJDBS1";
	BlockStackId2			: String = "UTRJDBS2";
	LabourRestrictionId1	: String = "UTRJDLR1";
	AYardAllocation 		: String = "UTRJD";
	AContainer				: String = "RJDLOBAA01";
	
vars
	gbs						: CM_ForkLiftStack;
	pxyLabRestriction1		: CM_LabourRestriction;
	labourRestriction		: CM_LabourRestriction;
	lcArray					: CM_LCArray;
	ya						: CM_YardAllocation;
	ti1						: CM_TrackedItem;
	location: CM_LocationsController;
	bs1,
	bs2 			: CM_BlockStack;
	moveController				: CMIF_MoveController;	
	rttask			: CM_RTQueueTask;
begin

	self.disableAllYA(true);

	self.deleteTerminalArea(ForkLiftStackId);
	gbs := self.addForkLiftStack(ForkLiftStackId, 3, 4, 4);
	self.assertNotNull(gbs);
	
	deleteTerminalArea(BlockStackId);
	bs1:= self.addBlockStack(BlockStackId, 99, null);
	assertNotNullMsg(bs1, BlockStackId);
	
	deleteTerminalArea(BlockStackId2);
	bs2:= self.addBlockStack(BlockStackId2, 99, null);
	assertNotNullMsg(bs2, BlockStackId);
	
	create lcArray transient;

	lcArray.add(bs1.myLocationsController);
	
	// create a labour restriction
	create pxyLabRestriction1 transient;
	pxyLabRestriction1.setProxy(Red,					// Colour
							   app.getMyUserCode(),		// User code
							   null, 					// comment
							   null,					// hours
							   null, 					// days
							   null,					// reason
							   lcArray,					// location controllers
							   LabourRestrictionId1,	// labour Restriction id
							   false,					// ignore lights
							   self.getOrganisation,					// organisation
							   null,					// email entity
							   null,					//_emails : CM_EmailAddressByAddressDict;
							   bs1);					// terminal area
							   
	self.assertNotNull(pxyLabRestriction1);

	// create the labour restriction
	app.myTrxCA.trxCreateRestrictionLabour(pxyLabRestriction1, labourRestriction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(labourRestriction);
	

	
	
	self.deleteContainer(AContainer);
	ti1:= self.addContainerOpts(AContainer, "2210", "MALT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti1 ,gbs.allGridControllersByRowColumn[2, 3]);
	
	self.deleteYA(AYardAllocation);
	ya := self.addYA1(AYardAllocation, YACriteriaType_ISO, "2210", lcArray);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, 1);
	
	location := app.autoPlanTiYA(self.getTerminal, null, ti1);

	self.assertNotNull(location);
	self.assertTrue( lcArray.includes(location));

	self.opts.addAssoc('IsForcedMove', true);

	self.moveQueued(ti1, location);

	assertNotNull(ti1.getPrimaryLocation(QUEUE_MODE));
	assertEqual(ti1.getPrimaryLocation(QUEUE_MODE).myTerminalArea, bs1);
	assertNotNull(ti1.allQueuedFutureMoves.first);
	assertNotNull(ti1.allQueuedFutureMoves.first.CM_FutureMoveQueued.allRTQueueEntries.first);
	rttask := ti1.allQueuedFutureMoves.first.CM_FutureMoveQueued.allRTQueueEntries.first.getFirstUncompletedTask;
	assertNotNull(rttask);
	self.assertEqual (rttask.status , TASK_SYS_HELD);
	
	self.unqueueTI( ti1 );
	
	assertNull(ti1.getPrimaryLocation(QUEUE_MODE));
	
	lcArray.clear();
	
	lcArray.add(bs1.myLocationsController);
	lcArray.add(bs2.myLocationsController);
	
	
	self.deleteYA(AYardAllocation);
	ya := self.addYA1(AYardAllocation, YACriteriaType_ISO, '2210', lcArray);
	//self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, 2);
	
	location := app.autoPlanTiYA(self.getTerminal, null, ti1);
	self.assertNotNull(location);
	self.assertTrue( lcArray.includes(location));
	self.assertEqual(bs2.myLocationsController, location);
	
	self.deleteYA(AYardAllocation);
epilog
	self.disableAllYA(false);	
	ignoreTrxWarnings(false);
	delete lcArray;
	delete pxyLabRestriction1;
end;



</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanToROROAreaLane" id="7638b221-6e26-4cca-a7e5-69c5d27e309e">
        <source>tAutoplanToROROAreaLane();
// cnwndl1
//29 August 2008	cnwdw1	
// Test of Autoplan to RORO area by Lane
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2, ti3, ti4, ti5, ti6: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_TerminalArea;
begin
	deleteTerminalArea("UTRORO");
	ta:= addROROArea("UTRORO", 4, 15);
	assertNotNullMsg(ta, "roro area");

	self.deleteYA("UT");
	self.deleteContainer("TEST0000001");
	ti1:= self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000003");
	ti3:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000004");
	ti4:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000005");
	ti5:= self.addContainerOpts("TEST0000005", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000006");
	ti6:= self.addContainerOpts("TEST0000006", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first);
	locations.add(ta.allLocationsControllers.last);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, 4);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.first, "Did not autoplan to first location");
	
	// By Lane, Lane Decreasing
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByRow, 0, DeckingRule_Decreasing, 0, 0);
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.areaRule, DeckingRule_ByRow);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.rowRule, DeckingRule_Decreasing);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.last, "Did not autoplan to lane 4");
	self.move(ti1, location);
	self.assertTrueMsg(location.CM_RoRoController.usedLength &gt; 0, "Used length not updated");
	self.assertTrueMsg(location.CM_RoRoController.spareLength &lt; 15, "Spare length not updated");

	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.last, "Did not autoplan to lane 4");
	self.move(ti2, location);

	//AP of next cargo should go to next lane (previous lane is now full)
	location := app.autoPlanTiYA(self.getTerminal, ta, ti3);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, ta.CM_RoRoLaneArea.allLanesByLaneNumber[3], "Did not autoplan to lane 3");


epilog

	delete locations;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanToROROAreaPosition" id="0af2e610-9391-4131-8c35-b5432574568d">
        <source>tAutoplanToROROAreaPosition();
// cnwndl1
//29 August 2008	cnwdw1	
// Test of Autoplan to RORO area by Position
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2, ti3, ti4, ti5, ti6: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_TerminalArea;
	
	tiTapArray : CM_TIArray;
	expectedLocArray : CM_LCArray;
	
begin
	deleteTerminalArea("UTRORO");
	ta:= addROROArea("UTRORO", 3, 20);
	assertNotNullMsg(ta, "roro area");

	self.deleteYA("UT");
	self.deleteContainer("TEST0000001");
	ti1:= self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000003");
	ti3:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000004");
	ti4:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000005");
	ti5:= self.addContainerOpts("TEST0000005", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000006");
	ti6:= self.addContainerOpts("TEST0000006", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first);
	locations.add(ta.allLocationsControllers.last);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, 3);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.first, "Did not autoplan to first location");
	
	// By Position, 
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByStack, 0, DeckingRule_Increasing, 0, 0);
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.areaRule, DeckingRule_ByStack);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.rowRule, DeckingRule_Increasing);
	
	//Test Auto Plan testing
	create tiTapArray transient;
	create expectedLocArray transient;
	tiTapArray.add(ti1);
	expectedLocArray.add(ta.CM_RoRoLaneArea.allLanesByLaneNumber[1]);
	tiTapArray.add(ti2);
	expectedLocArray.add(ta.CM_RoRoLaneArea.allLanesByLaneNumber[2]);
	tiTapArray.add(ti3);
	expectedLocArray.add(ta.CM_RoRoLaneArea.allLanesByLaneNumber[3]);
	tiTapArray.add(ti4);
	expectedLocArray.add(ta.CM_RoRoLaneArea.allLanesByLaneNumber[1]);
	self.doATestAutoPlan( tiTapArray, expectedLocArray, ta); 
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, ta.CM_RoRoLaneArea.allLanesByLaneNumber[1], "Did not autoplan to lane 1");
	self.move(ti1, location);

	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, ta.CM_RoRoLaneArea.allLanesByLaneNumber[2], "Did not autoplan to lane 2");
	self.move(ti2, location);

	location := app.autoPlanTiYA(self.getTerminal, ta, ti3);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, ta.CM_RoRoLaneArea.allLanesByLaneNumber[3], "Did not autoplan to lane 3");
	self.move(ti3, location);

	location := app.autoPlanTiYA(self.getTerminal, ta, ti4);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, ta.CM_RoRoLaneArea.allLanesByLaneNumber[1], "Did not autoplan to lane 1");
	self.move(ti4, location);
	
epilog

	delete locations;
	delete tiTapArray;
	delete expectedLocArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanToROROQueued" id="5156422b-562c-4a6f-b3b2-9f45b8e5991e">
        <source>tAutoplanToROROQueued();
// cnwndl1
//29 August 2008	cnwdw1	
// Test of Autoplan to RORO area by Lane, when there is queued cars in lane
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2, ti3, ti4, ti5, ti6: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_TerminalArea;
	
	tiTapArray : CM_TIArray;
	expectedLocArray : CM_LCArray;
	
begin
	deleteTerminalArea("UTRORO");
	ta:= addROROArea("UTRORO", 4, 15);
	assertNotNullMsg(ta, "roro area");

	self.deleteYA("UT");
	self.deleteContainer("TEST0000001");
	ti1:= self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000003");
	ti3:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000004");
	ti4:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000005");
	ti5:= self.addContainerOpts("TEST0000005", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000006");
	ti6:= self.addContainerOpts("TEST0000006", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first);
	locations.add(ta.allLocationsControllers.last);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, 4);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.first, "Did not autoplan to first location");
	
	// By Lane, Lane Decreasing
	self.updateDeckingRulesTA("UTRORO", IN, DeckingRule_ByRow, 0, DeckingRule_Decreasing, 0, 0);
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.areaRule, DeckingRule_ByRow);
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allDeckingRulesIn.first.rowRule, DeckingRule_Decreasing);
	
	
	//Test Auto Plan testing
	create tiTapArray transient;
	create expectedLocArray transient;
	tiTapArray.add(ti1);
	expectedLocArray.add(locations.last);
	tiTapArray.add(ti2);
	expectedLocArray.add(locations.last);
	tiTapArray.add(ti3);
	expectedLocArray.add(ta.CM_RoRoLaneArea.allLanesByLaneNumber[3]);
	self.doATestAutoPlan( tiTapArray, expectedLocArray, ta); 
	
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.last, "Did not autoplan to lane 4");
	self.moveQueued(ti1, location);
	self.assertTrueMsg(location.CM_RoRoController.usedLength &gt; 0, "Used length not updated");
	self.assertTrueMsg(location.CM_RoRoController.spareLength &lt; 15, "Spare length not updated");

	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, locations.last, "Did not autoplan to lane 4");
	self.moveQueued(ti2, location);

	//AP of next cargo should go to next lane (previous lane is now full)
	location := app.autoPlanTiYA(self.getTerminal, ta, ti3);
	self.assertNotNullMsg(location, self.getYAAutoPlanMessages);
	self.assertEqualMsg(location, ta.CM_RoRoLaneArea.allLanesByLaneNumber[3], "Did not autoplan to lane 3");


epilog

	delete locations;
	delete tiTapArray;
	delete expectedLocArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoplanWithLabourOnBlock" id="e6dcb14a-4e37-4e0b-a98e-529f015eda42">
        <source>tAutoplanWithLabourOnBlock();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2015	cnwndl1	Initial creation	Par 35547

*/

constants

	FSName : String = "UT_APFS";
	SSName : String = "UT_APSS";
	BSName : String = "UT_APBS";
	YAName : String = "UT_YALOB";
	TiIDn : String = "UTLOB0102";
	LabourWorkAreaName : String = "LWA2";
	
vars

	term : CM_Terminal;
	fs : CM_ForkLiftStack;
	ss : CM_StraddleStack;
	bs : CM_BlockStack;
	locations: CM_LCArray;
	ya : CM_YardAllocation;
	operatorCode : String;
	operator : CM_Operator;
	index : Integer;
	ti : CM_TrackedItem;
	tiId : String;
	tiArray : CM_TIArray;
	agent : CM_YAAutoplanAgent;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	pxyLabourWorkArea : CM_LabourWorkArea;
	allSelectedObjects : ObjectSet;
	lobLocations : CM_LCArray;
	nonLobLocations : CM_LCArray;
	realLabourWorkArea : CM_LabourWorkArea;
	proxyLabourRestriction : CM_LabourRestriction;
	realLabourRestriction : CM_LabourRestriction;
	org : CM_Organisation;
	restrictOrg : CM_Organisation;
	expectedLc : CM_LocationsController;

begin

		//clean up from previous run / set references to pre-existing objects
	term := self.getTerminal();
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := app.myRoot.allOperators.getAtKey( operatorCode );
	
	self.deleteLabourWorkArea( LabourWorkAreaName );
	self.deleteYA(YAName);
	self.deleteTerminalArea(BSName);
	self.deleteTerminalArea(FSName);
	self.deleteTerminalArea(SSName);
	foreach index in 1 to 32 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	
	self.disableAllYA(true);	
			
		//create 1 x gridded block stacks.  4 x 4 single height, 1 x straddle stacks.  4 x 4 single height  i.e. room for 32
	fs := self.addForkLiftStack( FSName, 4, 4, 1);	
	self.assertTrueMsg( fs &lt;&gt; null, FSName &amp; " fork lift stack not created");
	ss := self.addStraddleStack( SSName, 4, 4, 1);
	self.assertTrueMsg( ss &lt;&gt; null, SSName &amp; " straddle stack not created");
			
		//set up a Yard allocation with ranges in a specific order
	create locations transient;
	fs.allLocationsControllers.copy(locations);
	ss.allLocationsControllers.copy(locations);
	ya := self.addYA1WithFill(YAName, YACriteriaType_OperatorItem, operatorCode, locations, YAFillOption_InOrder, YAFillOption_BestPick, true);
	self.assertTrueMsg( ya &lt;&gt; null, YAName &amp; " yard allocation not created");		
		
		//create a block stack with on-site cargo in it matching teh auto allocation that is targetting the gbs's  32 x 20 containers
	bs := self.addBlockStack( BSName, 32, null);	
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	
	create tiArray transient;
	foreach index in 1 to 32 do
		tiId := TiIDn &amp; index.padLeadingWith("0",2);
		ti := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs);
		self.assertTrueMsg( ti &lt;&gt; null, tiId &amp; " container not created");
		tiArray.add(ti);
	endforeach;
		
		//Auto plan all cargo from bs and check queued order matches range order in Allocation 
	index := 0;
	create agent transient;	
	create lobLocations transient;
	create nonLobLocations transient;
	foreach ti in tiArray do
		index := index + 1;
		lc := app.autoPlanTiYA(term, null, ti);
		self.assertTrueMsg( lc &lt;&gt; null, "Autoplan location not found for '" &amp; ti.id &amp; "'");
		ta := lc.myTerminalArea;
		if index &lt;= 16 then
			self.assertTrueMsg( ta = fs, "[Test 1] Expected '" &amp; ti.id &amp; "' to auto plan to " &amp; fs.id);
		else
			self.assertTrueMsg( ta = ss, "[Test 2] Expected '" &amp; ti.id &amp; "' to auto plan to " &amp; ss.id);
		endif;
		self.moveQueued(ti,lc);
		
		if index.isOdd then
			lobLocations.add(lc);
		else
			nonLobLocations.add(lc);
		endif;
	endforeach;	
	delete agent;
		
		//Unqueue all cargo
	foreach ti in tiArray do
		self.unqueueTI( ti );
	endforeach;	
			
		//set up LOB on half of locations - create a LOB work area of alternate locations and then add labour on block restriction
	create allSelectedObjects transient;
	lobLocations.copy(allSelectedObjects);

	create pxyLabourWorkArea transient;
	pxyLabourWorkArea.setProxy(	LabourWorkAreaName,	//_code : String;
								"Unit Test AP Labour Work Area",	//_description : String;
								false,	//_notAvailable : Boolean;
								allSelectedObjects,	//_allSelectedObjects : ObjectSet;
								term	//_myTerminal : CM_Terminal
								);
								
	app.myTrxCA.trxCreateLabourWorkArea(pxyLabourWorkArea, realLabourWorkArea, app.myPassport);
	self.assertTrueMsg( realLabourWorkArea &lt;&gt; null, "Labour Work Area not created. " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
	//create the labour restriction
	foreach org in app.myRoot.allOrganisations do
		if org.isAvailableForLabourRestiction then
			restrictOrg := org;
			break;
		endif;
	endforeach;
	self.assertTrueMsg( restrictOrg &lt;&gt; null, "No Organisation found.");
	
	locations.clear();
	locations.add( lobLocations.first.CM_LocationsController );
	create proxyLabourRestriction transient;
	proxyLabourRestriction.setProxy(	Red,	//_colour : Integer; 
										app.getMyUserCode,	//_userCode,
										"No comment",	//_comment : String; 
										null,	//_durationHrs : Time;
										1,	//_durationDays : Integer;
										CM_LabourRestrictionReasonCode.firstInstance,	//_reason : CM_LabourRestrictionReasonCode;
										locations,	//_allLocations : CM_LCArray;
										"UTLR1",	//_id : String;
										false,	//_ignoreLights : Boolean;
										restrictOrg,	//_organisation : CM_Organisation;
										null,	//_email : CM_EmailEntity;
										null,					//_emails : CM_EmailAddressByAddressDict;
										locations.first.myTerminalArea	//_theTerminal : CM_TerminalArea
										);
										
	app.myTrxCA.trxCreateRestrictionLabour(proxyLabourRestriction, realLabourRestriction, app.myPassport);
	self.assertTrueMsg( realLabourRestriction &lt;&gt; null, "Labour Restriction not created. " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
		
		//Now we have 16 available positions and 16 that are empty but have labour on block set
		//The second 16 should only be used after all the available ones have been used, AND should be used in teh same order as
		//declared in the Yard Allocation Range.
		
		//Auto plan all cargo from bs. 
		
		//Auto plan all cargo from bs and check queued order matches range order in Allocation 
	index := 0;
	create agent transient;	
	locations.clear();
	foreach ti in tiArray do
		index := index + 1;
		
		lc := app.autoPlanTiYA(term, null, ti);
		self.assertTrueMsg( lc &lt;&gt; null, "Autoplan location not found for '" &amp; ti.id &amp; "'");
	
		if index &lt;= 16 then
			expectedLc := nonLobLocations[ index ].CM_LocationsController;
		else
			expectedLc := lobLocations[ index - 16 ].CM_LocationsController;
		endif;
		self.assertTrueMsg( expectedLc = lc, "[Test 3, Index " &amp; index.String &amp; "] Expected '" &amp; ti.id &amp; "' to auto plan to '" &amp; expectedLc.getFullId &amp; "' but went to '" &amp; lc.getFullId &amp; "'" );
		
		self.moveQueued(ti,lc);
		
	endforeach;	
	delete agent;
	
	
	//If you got to here, all is good in teh world.
		//Unqueue all cargo
	foreach ti in tiArray do
		self.unqueueTI( ti );
	endforeach;	
		
epilog

	self.disableAllYA(false);
	
	delete locations;
	delete agent;
	delete tiArray;
	delete allSelectedObjects;
	delete pxyLabourWorkArea;
	delete proxyLabourRestriction;
	delete lobLocations;
	delete nonLobLocations;
	
	self.deleteLabourRestriction(realLabourRestriction);
	self.deleteLabourWorkArea( LabourWorkAreaName );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBOLCriteria" id="1dcc90cc-5c06-4e86-9d98-2d4e4bf503e4">
        <source>tBOLCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2, ti3: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
begin
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);

	self.deleteContainer("TEST0000001");
	self.opts.addAssoc("BOL", "BOL123");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.opts.purge();
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000003");
	self.opts.addAssoc("BOL", "123BOL123");
	ti3 := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_BOL, "BOL123", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);

	
		// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_BOL, "BOL*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);
	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_BOL, "!BOL", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertNull(location);
	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_BOL, "*BOL", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");
	location := app.autoPlanTiYA(self.getTerminal, bs, ti3);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);
	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_BOL, "*BOL*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");
	location := app.autoPlanTiYA(self.getTerminal, bs, ti3);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBlockStackActualMaxCap" id="dc97e105-899c-4b47-94b9-b256b102de9f">
        <source>tBlockStackActualMaxCap();
// cnwndl1
//30 September 2008	cnwdw1	
// Test that wjhen a Block stack is full, an autoplan to the stack will fail
vars
	ya: CM_YardAllocation;
	blockStack1: CM_BlockStack;
	container1, container2: CM_TrackedItem;
	locations : CM_LCArray;
	location: CM_LocationsController;
	
	tiTapArray : CM_TIArray;
	expectedLocArray : CM_LCArray;
	
begin
	deleteTerminalArea("UTBS1");
	blockStack1 := addBlockStack("UTBS1", 1, null);
	assertNotNullMsg(blockStack1, "blockStack1");
	
	self.deleteYA("UT");
	create locations transient;
	locations.add(blockStack1.allLocationsControllers.first);
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations);

	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	container2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	//Test Auto Plan testing
	create tiTapArray transient;
	create expectedLocArray transient;
	tiTapArray.add(container1);
	expectedLocArray.add(blockStack1.allLocationsControllers.first);
	tiTapArray.add(container2);
	expectedLocArray.add(null);
	self.doATestAutoPlan( tiTapArray, expectedLocArray, blockStack1); 
	
//	self.deleteContainer("TEST0000001");
//	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	location := app.autoPlanTiYA(self.getTerminal, blockStack1, container1);
	assertEqualMsg(location, blockStack1.allLocationsControllers.first, "autoplan failed:"&amp; CrLf &amp; getYAAutoPlanMessages());
	// Move first container - should be ok
	self.move(container1, location);
	assertEqualMsg(blockStack1.getNumTIs(REAL_MODE), 1, "Blockstack1 is not full");
	
//	self.deleteContainer("TEST0000002");
//	container2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	// Try to plan 2nd container should fail
	location := app.autoPlanTiYA(self.getTerminal, blockStack1, container2);
	assertTrueMsg(location = null, "autoplan should have failed:" &amp; CrLf &amp; getYAAutoPlanMessages());
	
epilog

	delete locations;
	delete tiTapArray;
	delete expectedLocArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBlockStackFIFOMaxCap" id="69ba6510-fffa-4ce4-8285-64b5036545c5">
