    <JadeMethod name="canUserAccessSelf" id="863c5cdc-e52f-4cb7-8643-121e42086714">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:		22 June 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
16/08/2018	jlgdap1	TFS 40030 	PEL1 Multiple Estimates and Invoices
20/02/2019	jlgka1	43316		AAT - Invoice List shows nothing if the user 
								has operator data access group assigned. 
								Because AAT is not using the feature where
								there is a default Debtor for each Operator
								then we need to reset the canAccess variable 
								to true when there is no Default matching Debtor.
============================================================================*/
vars
	op 		  : CM_Operator;
	ca 		  : CM_CustomsAgent;					// TFS 40030
	consignor : CM_ConsigneeConsignor;		// TFS 40030
	dac  	  : CM_DataAccessController;
	canAccess : Boolean;
	user 	  : CM_User;
	mustHaveDataAccess : Boolean;
begin
	// 02/09/2014 cnwar2 #34773 - users should always be able to access root debtor
	if self.isRDT() then
		return true;
	endif;
	
	user := _user;
	if user = null then
		user := app.myPassport.myUser;
	endif;
	//epr TFS 42219 29/11/18
	canAccess := true; //default to true
	dac 	  := user.allDataAccessControllers[CM_Operator.name];
	/*We need to do the code this way because if the code already got an existing canAccess 
	  in one of the Data Access everything will be accessible so no need to continue checking
	  for the other data access.
	  Hierarchy will be 
	  1. Operator Data Access
	  2. Customs Agent Data Access
	  3. Consignee Data Access
	*/
	
	//epr TFS 44670 14/6/19
	mustHaveDataAccess:=app.myRoot.getConfig(MustHaveDataAccessInv).Boolean;
	
	if dac &lt;&gt; null then
		canAccess := false;
		//if there is operator data access then check and if has one return true
		//check operators
		foreach op in self.operators discreteLock do
			if op.canUserAccessSelf(user, _failedDAC, _passport) then
				canAccess := true;
				return canAccess;
			endif;
		endforeach;
		
		//No Default Debtor for Operator will always have an access.
		//unless they have a config they says they must have data access
		if self.operators.size = 0  and not mustHaveDataAccess  then
			canAccess := true; //default to true
		endif;
	endif;
	
	dac := user.allDataAccessControllers[CM_CustomsAgent.name];
	if dac &lt;&gt; null then
		canAccess := false;
		// TFS 40030 check access for customs agents and consignors as well
		foreach ca in self.allCustomsAgents discreteLock do
			if ca.canUserAccessSelf(user, _failedDAC, _passport) then
				canAccess := true;
				return canAccess;
			endif;
		endforeach;
		
		//No Default Debtor for Custom Agent will always have an access.
		if self.allCustomsAgents.size = 0  and not mustHaveDataAccess   then
			canAccess := true; //default to true
		endif;
	endif;
	
	dac := user.allDataAccessControllers[CM_ConsigneeConsignor.name];
	if dac &lt;&gt; null then
		canAccess := false;
	
		
		
		foreach consignor in self.consignors discreteLock do
			if consignor.canUserAccessSelf(user, _failedDAC, _passport) then
				canAccess := true;
				return canAccess;
			endif;
		endforeach;
		
		//No Default Debtor for Consignee Consignor will always have an access.
		if self.consignors.size = 0  and not mustHaveDataAccess then
			canAccess := true; //default to true
		endif;
	endif;
	// TFS 40030 end
	
	return canAccess;
	//return inheritMethod(_user, _failedDAC, _passport);
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCashReceipt" id="7e06def0-ab3d-4447-b65f-b60c40348b8e">
        <updating/>
        <source>createCashReceipt(	_terminal : CM_Terminal;
					_cashValue : Decimal;
					_chequeBank : String;
					_chequeBranch : String;
					_chequeNumber : String;
					_chequeDate : Date;
					_myPaymentMethod : CM_PaymentMethod
					):CM_CashReceipt updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	drTerm : CM_DebtorTerminal;
	cashReceipt : CM_CashReceipt;

begin

	if _terminal = null or not _terminal.isCashOnlyEnabled then
		app.raiseCMException(Term_not_cash_enabled,null,self);
		return null;
	endif;

	drTerm := self.allDebtorTerminals.getAtKey( _terminal );
	if drTerm = null or not drTerm.isCashOnly then
		app.raiseCMException(Not_cash_only_no_receipt,null,self);
		return null;
	endif;
	
	cashReceipt := drTerm.createCashReceipt(	_cashValue,	//_cashValue : Decimal;
												_chequeBank,	//_chequeBank : String;
												_chequeBranch,	//_chequeBranch : String;
												_chequeNumber,	//_chequeNumber : String;
												_chequeDate,	//_chequeDate : Date;
												_myPaymentMethod	//_myPaymentMethod : CM_PaymentMethod
												);
	return cashReceipt;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cashValue" type="Decimal"/>
        <Parameter name="_chequeBank" type="String"/>
        <Parameter name="_chequeBranch" type="String"/>
        <Parameter name="_chequeNumber" type="String"/>
        <Parameter name="_chequeDate" type="Date"/>
        <Parameter name="_myPaymentMethod" type="CM_PaymentMethod"/>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="createDebtorTerminal" id="5bf90678-a39f-45ed-af57-1573d4fcfd21">
        <updating/>
        <source>createDebtorTerminal( _myTerminal : CM_Terminal; _isCashOnly : Boolean; _paymentType : Integer; _currencyType : CM_CurrencyType; _locale : CM_Locale; _defaultInvoiceJRW : String ; _orgCode : String; _interterminalCode : String):CM_DebtorTerminal updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2012	cnwndl1	Initial creation	Par 29968
17 Aug 2022		navpw1	TFS: 54564 (54374) - EUP - Inv Config - DB Changes
29 Apr 2023		navra1	TFS 57086 EUP - Customer Update - New Fields incl Debtor Details incl Financial ID

*/

vars
	
	drTerm : CM_DebtorTerminal;

begin
	
	if _myTerminal = null then
		return null;
	endif;

	create drTerm;
	drTerm.setDetails(	_myTerminal,			//_myTerminal 			: CM_Terminal;
						self,					//_myDebtor				: CM_Debtor;
						_isCashOnly,			//_isCashOnly 			: Boolean
						_paymentType,			//_paymentType			: Integer
						_currencyType,			//_currencyType			: CM_CurrencyType 	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						_locale,				//_locale				: CM_Locale			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						_defaultInvoiceJRW ,	//_defaultInvoiceJRW	: String			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
						_orgCode,				//orgCode 				: String			//navra1 - TFS 57086 - 28th Apr 2023
						_interterminalCode		//interterminalCode		: String			//navra1 - TFS 57086 - 28th Apr 2023			
						);
	return drTerm;

epilog

end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_isCashOnly" type="Boolean"/>
        <Parameter name="_paymentType" type="Integer"/>
        <Parameter name="_currencyType" type="CM_CurrencyType"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_defaultInvoiceJRW" type="String"/>
        <Parameter name="_orgCode" type="String"/>
        <Parameter name="_interterminalCode" type="String"/>
        <ReturnType type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="createEvent" id="439189d7-e3bf-48df-8f40-10bb29a7649b">
        <source>createEvent(_type : Integer; _time : TimeStamp; _resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask; _wod : CM_WorkOrderToDoDtl):CMEVT_NonOperationalEvent;

/*

Purpose:

Parameters:			

Return Value:		


Date			Who		Reason
08 March 2023	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	trans : CMEVT_NonOperationalEvent;
	wod : CM_WorkOrderDtl;
	cmifEventCtrl : CMIF_NonOperationalCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	/*//17/02/2025	navkc1 JIRA Bug MTN-33582
	trans := app.createEvent(_type, _time,app.myPassport.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_NonOperationalEvent; // ### TFS BUG 64545 11JUNE024 NAVAB1
	if trans  &lt;&gt; null then
		trans.setMyDebtor(self);
		 // ### TFS BUG 64545 11JUNE024 NAVAB1 trans.setMyTerminal(app.myPassport.myTerminal);
		trans.setToDoTask(_task); // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
		trans.addResourcesFromProxys(_resourceUsageProxys);
		wod := _wod; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		if wod = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			wod := trans.getWorkOrderDetail(); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		if wod &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setContractId(wod.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setNoCharge(wod.getNoCharge()); // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
		endif;	
		//trans.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(trans,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	endif;
	*/
	//17/02/2025	navkc1 JIRA Bug MTN-33582 Starts
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _type;
	cmifEventCtrl.dateTime := _time;
	cmifEventCtrl.myTerminal := app.myPassport.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myDebtor := self;
	cmifEventCtrl.myToDoTask := _task;
	cmifEventCtrl.myWorkOrderDetail := _wod;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(cmifEventCtrl.allResourceUsages);
	endif;
	
	trans := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_NonOperationalEvent; 
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
	return trans;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CMEVT_NonOperationalEvent"/>
    </JadeMethod>
    <JadeMethod name="createToDoTask" id="cb9a28c5-d9c4-4988-81c5-4f7ca140b9ad">
        <source>createToDoTask(taskDesc : Integer; _wod : CM_WorkOrderToDoDtl): CM_NonOpsToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoTask : CM_NonOpsToDoTask;
	toDoDesc : CM_ToDoTaskDesc;
	found	 : Boolean;
	passport : CM_Passport;
begin
	passport := app.myPassport;
	
	toDoDesc := app.myRoot.allToDoTaskDescriptions[taskDesc]; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then 
	*/
	if toDoDesc &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		create toDoTask persistent;
		toDoTask.setForCreate(STATUS_TODO,	toDoDesc, null, passport, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.updateObjectEdition(self);		
		
		return toDoTask;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="taskDesc" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CM_NonOpsToDoTask"/>
    </JadeMethod>
    <JadeMethod name="debtorMatches" id="23230ff3-3540-404a-bf6a-df6884beafa1">
        <source>debtorMatches(_strToMatch: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlgndl1	Initial creation	TFS 39254

*/

vars

	strToCheck : String;

begin

	strToCheck := self.name.toUpper;
	
	if self.myParentDebtorNode &lt;&gt; null and not self.myParentDebtorNode.isKindOf(CM_RootDebtorGroup) then
		strToCheck := strToCheck &amp; " " &amp; self.myParentDebtorNode.name.toUpper;
	endif;
	
	if self.decfinName.trimBlanks &lt;&gt; null then
		strToCheck := strToCheck &amp; " " &amp; self.decfinName.trimBlanks.toUpper;
	endif;
	
	return strToCheck.pos( _strToMatch, 1 ) &gt; 0;

epilog

end;</source>
        <Parameter name="_strToMatch" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
