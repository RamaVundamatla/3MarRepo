begin
	return self;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dataDumpHexToOidString" id="ba500ab6-a85a-4d36-a766-d80a08e87e2a">
        <source>dataDumpHexToOidString() : String;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwsb1
//
// Purpose:		Converts a data dump hex string representation of an oid
//				(eg. 0x094C00013211) into the oidString equivalent
//				(eg. 2380.78353).
// ---------------------------------------------------------------------------
vars
	classId : Integer;
	instanceId : Integer;

begin
	if self.length &lt;&gt; 14 or self[7] &lt;&gt; "0" then
		return null;
	endif;
	
	classId := self[3:4].cnEcHexValue;
	instanceId := self[8:7].cnEcHexValue;	// Skip first zero - cnEcHexValue limit of 7 digits

	return classId.String &amp; "." &amp; instanceId.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doInvalidCharacterSweep" id="fb1add15-5617-4bf8-b229-7a641bd95bd2">
        <source>doInvalidCharacterSweep() : String;
// -------------------------------------------
// Created 24 March 2004 by cnwdvb1
// -------------------------------------------
vars

	str : String;

begin

	str := self;
	str.cnReplaceChar('/', null);
	str.cnReplaceChar('\', null);
	str := str.cnEcRemoveSubstring(CrLf);
	str.cnReplaceChar(':', null);
	str.cnReplaceChar('+', null);
	//str.cnReplaceChar('-', null); This is a valid character for emails PAR11729
	str := str.cnEcRemoveSubstring(' ');
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dropLeading" id="5ab0331e-87e6-4bc6-b45d-464755417acd">
        <source>dropLeading(pChar : Character) : String;
// ---------------------------------------------------------------------------
// Created:     06 December 2000 by cnwrs2
//
// Purpose:     Drops multiple contiguous instances of a character from
//				the front of a string
//
// Parameters:  The character to check for
//
// Returns:     The modified string
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self = null then
		return null;
	endif;

	if self[1] = pChar then
		return self.trailingString(2).dropLeading(pChar);
	else
		return self;
	endif;
	
end;</source>
        <Parameter name="pChar" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="ediDateFormat" id="01e1b141-87fd-477c-9eb7-261b1e246a23">
        <source>ediDateFormat(_dateFormat, _delimiter : String) : Date;
/*
----------   ----------  --------------------------------------------------
Created:	08 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	date			: Date;
	len,
	day,
	month,
	year,
	pos				: Integer;
	
begin
	date := null;
	pos := 1;
	len := self.length;
	if len &lt; pos then
		return null;
	endif;
	
	if _dateFormat = EDIDateFormat_DDMMYYYY or 
	   _dateFormat = EDIDateFormat_DDMMYY then
		if _delimiter &lt;&gt; null then
			day 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			month 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			year 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
		else
			if len &lt; 6 then
				app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
				return null;
			endif;
			day 	:= self[1:2].Integer;
			month 	:= self[3:2].Integer;
			year 	:= self[5:end].Integer;
		endif;
		
	elseif _dateFormat = EDIDateFormat_MMDDYYYY or
	   _dateFormat = EDIDateFormat_MMDDYY then
		if _delimiter &lt;&gt; null then
			month 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			day 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			year 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
		else
			if len &lt; 6 then
				app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
				return null;
			endif;
			month 	:= self[1:2].Integer;
			day 	:= self[3:2].Integer;
			year 	:= self[5:end].Integer;
		endif;
		
	elseif _dateFormat = EDIDateFormat_YYYYMMDD then
		if _delimiter &lt;&gt; null then
			year 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			month 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			day 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
		else
			if len &lt; 8 then
				app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
				return null;
			endif;
			year 	:= self[1:4].Integer;
			month 	:= self[5:2].Integer;
			day 	:= self[7:end].Integer;
		endif;
		
	elseif _dateFormat = EDIDateFormat_YYMMDD then
		if _delimiter &lt;&gt; null then
			year 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			month 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
			pos := pos + 1;
			day 	:= self.scanUntil(_delimiter, pos).trimBlanks().Integer;
		else
			if len &lt; 6 then
				app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
				return null;
			endif;
			year 	:= self[1:2].Integer;
			month	:= self[3:2].Integer;
			day 	:= self[5:end].Integer;
		endif;
	endif;
	/*
	app.writeStatement(method.name &amp; '-day = ' &amp; day.String);
	app.writeStatement(method.name &amp; '-month = ' &amp; month.String);
	app.writeStatement(method.name &amp; '-year = ' &amp; year.String);
	*/
	date.setDate(day, month, year);
	return date;

end;


</source>
        <Parameter name="_dateFormat" type="String"/>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="ediTimeStampFormat" id="589a68d3-97c4-4fc4-affc-ae1672585bf7">
        <source>ediTimeStampFormat( _fileType : CM_EDIFileType; _dateFormat : String; _dateDelim : Character ) : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2017	cnwndl1	Initial creation	TFS 3886

*/

vars

	ts : TimeStamp;
	fileTypeUser : CM_EDIFileTypeUser;
	dateFormat : String;
	dateDelim : String;
	date : Date;
	day : Integer;
	month : Integer;
	year : Integer;
	rawTimeStr : String;
	timeStr : String;
	time : Time;
	pos : Integer;
	timeStartPos : Integer;
	tempStr : String;

begin

	if _fileType &lt;&gt; null then
		if _fileType.isKindOf(CM_EDIFileTypeUser) then
			//user defined format.
			fileTypeUser := _fileType.CM_EDIFileTypeUser;
			dateFormat := fileTypeUser.dateFormat;
			if fileTypeUser.dateDelimeter.Character &gt; #0.Character then
				dateDelim := fileTypeUser.dateDelimeter.String;
			endif;
		endif;
	else
		// to make available for other uses, such as testing.
		dateFormat := _dateFormat;
		if _dateDelim &lt;&gt; null and _dateDelim.Character &gt; #0.Character then
			dateDelim := _dateDelim.String;
		endif;
	endif;
	
	
	if dateFormat &lt;&gt; null then
		if self.length &lt; 11 then
			//string not long enough to include a time
			date := self.ediDateFormat( dateFormat, dateDelim );
			if date.isValid then
				ts.setDate(date);
				return ts;
			else
				return self.TimeStamp;
			endif;
			
		else // Includes a formatted date and a time
			pos := 1;
			if dateFormat.isOneOf( EDIDateFormat_DDMMYY, EDIDateFormat_MMDDYY, EDIDateFormat_YYMMDD,EDIDateFormat_DDMMYYYY, EDIDateFormat_MMDDYYYY, EDIDateFormat_YYYYMMDD ) then
				if dateDelim = null then
					//NO delimiter, must be exact length fileds
					if dateFormat = EDIDateFormat_DDMMYY then
						day 	:= self[1:2].Integer;
						month 	:= self[3:2].Integer;
						year 	:= self[5:2].Integer;
						timeStartPos := 7;
					elseif dateFormat = EDIDateFormat_MMDDYY then
						month 	:= self[1:2].Integer;
						day 	:= self[3:2].Integer;
						year 	:= self[5:2].Integer;
						timeStartPos := 7;
					elseif dateFormat = EDIDateFormat_YYMMDD then
						year 	:= self[1:2].Integer;
						month	:= self[3:2].Integer;
						day 	:= self[5:2].Integer;
						timeStartPos := 7;
					elseif dateFormat = EDIDateFormat_DDMMYYYY then
						day 	:= self[1:2].Integer;
						month 	:= self[3:2].Integer;
						year 	:= self[5:4].Integer;
						timeStartPos := 9;
					elseif dateFormat = EDIDateFormat_MMDDYYYY then
						month 	:= self[1:2].Integer;
						day 	:= self[3:2].Integer;
						year 	:= self[5:4].Integer;
						timeStartPos := 9;
					elseif dateFormat = EDIDateFormat_YYYYMMDD then
						year 	:= self[1:4].Integer;
						month	:= self[5:2].Integer;
						day 	:= self[7:2].Integer;
						timeStartPos := 9;
					endif;
					
					rawTimeStr := self[timeStartPos:end].trimBlanks;
				else
					//Allow for a delimiter
					if dateFormat = EDIDateFormat_DDMMYY or dateFormat = EDIDateFormat_DDMMYYYY then
						day := self.scanUntil(dateDelim, pos).trimBlanks().Integer;
						pos := pos + 1;
						month := self.scanUntil(dateDelim, pos).trimBlanks().Integer;
						pos := pos + 1;
						timeStartPos := self.findNextNonIntegerPos( pos );
						if timeStartPos &gt; pos then
							year := self[pos:timeStartPos - pos].Integer;
						else
							app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
							return null;
						endif;
					elseif dateFormat = EDIDateFormat_MMDDYY or dateFormat = EDIDateFormat_MMDDYYYY then
						month := self.scanUntil(dateDelim, pos).trimBlanks().Integer;
						pos := pos + 1;
						day := self.scanUntil(dateDelim, pos).trimBlanks().Integer;
						pos := pos + 1;
						timeStartPos := self.findNextNonIntegerPos( pos );
						if timeStartPos &gt; pos then
							year := self[pos:timeStartPos - pos].Integer;
						else
							app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
							return null;
						endif;
					elseif dateFormat = EDIDateFormat_YYMMDD or dateFormat = EDIDateFormat_YYYYMMDD then
						year := self.scanUntil(dateDelim, pos).trimBlanks().Integer;
						pos := pos + 1;
						month := self.scanUntil(dateDelim, pos).trimBlanks().Integer;
						pos := pos + 1;
						timeStartPos := self.findNextNonIntegerPos( pos );
						if timeStartPos &gt; pos then
							day := self[pos:timeStartPos - pos].Integer;
						else
							app.writeStatement(method.name &amp; '-unable to parse "' &amp; self &amp; '"');
							return null;
						endif;
					endif;
					rawTimeStr := self[timeStartPos:end].trimBlanks;
				endif;
				
				date.setDate(day, month, year);
				
			endif;
			
			if not date.isValid then
				return self.TimeStamp;
			else
				ts.setDate(date);
			endif;
			
			//strip off any lead chars that are just delimiters.
			while rawTimeStr &lt;&gt; null and not rawTimeStr[1:1].isInteger do
				if rawTimeStr.length = 1 then
					rawTimeStr := null;
				else
					rawTimeStr := rawTimeStr[2:end];
				endif;
			endwhile;
			
			if rawTimeStr &lt;&gt; null then
				time := rawTimeStr.Time;
			endif;
			ts.setTime(time);
			
			return ts;
			
		endif;
	
	else	// no known format, just do what we have always done.
	
		
		//29 Mar 2017	NDL	TFS 3862
		//This may be coming out of XSD generated XML.  
		if self.length = 25 then
			// format = YYYY-MM-DDTHH:MM:SS+HH:MM  I.e. 'Date' 'T' 'GMT Time' and 'Offset'
			// For these and only these we convert AND use the GMT offset to convert to local time
			tempStr := self;
			if self[11:1] = "T" then
				tempStr := self[1:10] &amp; " " &amp; self[12:end]; // replace the 'T' with a space (Jade doesn't recognise this T as a delimiter )
			endif;
			if tempStr[23:1] = ":" then
				tempStr := tempStr[1:22]&amp; tempStr[24:2]; // remove the ":" from the offset (Jade doesn't recognise this colon)
			endif;
			ts := tempStr.TimeStampOffset.asLocalTimeStamp;
			if ts.date.isValid then
				return ts;
			endif;
		elseif self.length = 19 then
			// format = YYYY-MM-DDTHH:MM:SS  I.e. 'Date' 'T' 'GMT Time'
			tempStr := self;
			if self[11:1] = "T" then
				tempStr := self[1:10] &amp; " " &amp; self[12:end]; // replace the 'T' with a space (Jade doesn't recognise this T as a delimiter )
			endif;
			ts := tempStr.TimeStamp;
			if ts.date.isValid then
				return ts;
			endif;
		endif;
		
		return self.TimeStamp;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <Parameter name="_dateFormat" type="String"/>
        <Parameter name="_dateDelim" type="Character"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="eliminateContiguous" id="afb8b446-a22a-40af-9819-86ef60a04252">
        <source>eliminateContiguous(pChar : Character) : String;
// ---------------------------------------------------------------------------
// Created:     06 December 2000 by cnwrs2
//
// Purpose:     Removes all contiguous instances of a character from a string
//				and replaces them with a single instance.
//
// Parameters:  The character to check
//
// Returns:     The modified string
//
// Changed On   Changed By  Reason
// 9Jan04-RJS	Rewritten to avoid a recursive call as this can cause a
//				kernel stack overflow with very long strings
// ---------------------------------------------------------------------------
vars
	i, j	: Integer;
	rtnStr	: String;

begin

	if self = null then 
		return null;
	endif;
	
	rtnStr := self;

	i := 1;
	while (true) do
		i := rtnStr.pos(pChar, i);
		if i &lt;= 0 then
			break;
		endif;
		
		j := i;
		rtnStr.scanWhile(pChar, j);
		if j &lt;= 0 then
			rtnStr := rtnStr[1 : i];
			break;
		endif;
		
		rtnStr := rtnStr[1 : i] &amp; rtnStr[j : end];
		
		i := i + 1;
		
	endwhile;
	
	return rtnStr;

end;</source>
        <Parameter name="pChar" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="eliminateContiguousSpaces" id="c7e026a1-edd0-4d8e-ae57-045eb929a723">
        <source>eliminateContiguousSpaces() : String;
// ---------------------------------------------------------------------------
// Created:     06 December 2000 by cnwrs2
//
// Purpose:     Removes all contiguous spaces from a string
//				and replaces them with a single space.
//
// 9Jan04-RJS	Rewritten to avoid a recursive call as this can cause a
//				kernel stack overflow with very long strings
// ---------------------------------------------------------------------------
constants
	Space	: Character = ' ';
vars
	i, j	: Integer;
	rtnStr	: String;
	
begin

	if self = null then 
		return null;
	endif;
	
	rtnStr := self.trimBlanks;
	
	if rtnStr = null then
		return null;
	endif;

	i := 1;
	while (true) do
		i := rtnStr.pos(Space, i);
		if i &lt;= 0 then
			break;
		endif;
		
		j := i;
		rtnStr.scanWhile(Space, j);
		if j &lt;= 0 then
			break;
		endif;
		
		rtnStr := rtnStr[1 : i] &amp; rtnStr[j : end];
		
		i := i + 1;
		
	endwhile;
	
	return rtnStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="encrypt" id="ea6af25a-aa43-4b48-99cf-0d3682eb6175">
        <source>encrypt() : Binary;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
// Purpose:			!     
// use digest() in pswdhash.dll to perform a hash (irreversible) 
// of the input string (self).	Rabbie, 16 Aug 2000.
// C Lib credits to Sky Williams &amp; Lorcan Bolster, CBT.
// Always returns a binary of length 20.
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	b : Binary[20];
begin

	// PAR 22678 - remove references to pswordhash.dll
	app.raiseUnexpectedProgramError(String.name, method.name, 'call to deimpemented encryption routine');

//	call digest(self.Binary, self.length, b);
	return b;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="encrypt2" id="9392daf3-9e0f-4633-b498-244cd6a159d8">
        <source>encrypt2(pKey:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		10 November 2005 by cnwdad1
//
// Purpose:		Encrypts the receiver - sourced from Jasper.
//
//				NOTE 1: This method will call the Cardschema cnEncryptV2 method and
//				pass in the key value.
//
//				NOTE 2: For the key parameter value, use the String::getEncryptionKey
//				method to get a key from a known string.  For example, when encrypting
//				a password, call getEncryptionKey on the userId to get a key.
//
// Parameters:	pKey - The encryption key.
//
// Returns:		The encrypted receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	encryptedStr	: String;
	charPos			: Integer;
	binEncrypted	: Binary;
	
begin
	encryptedStr	:=	cnEncryptV2(pKey);
	
	foreach charPos in 1 to encryptedStr.length do
		if encryptedStr[charPos] = null then
  			encryptedStr[charPos]	:=	1.Character;
		endif;	
	endforeach;
	
	binEncrypted	:=	encryptedStr.asANSI(0);	// 14/3/16 cnwmp6 PAR 36286 unicode version
	
	// 21/12/2007 cnwar2 - This should be looked at next time changes are made to
	// the encryption area.  The length does not need to be padded to 20 and this is 
	// causing problems (see PAR #15342)
	while binEncrypted.length &lt; 20 do
		binEncrypted	:=	binEncrypted &amp; binEncrypted;
	endwhile;
	
	return binEncrypted[1:20];
end;</source>
        <Parameter name="pKey" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="endsWith" id="a99417e6-7bca-4f6a-84fc-6d139fc52a2d">
        <source>endsWith(_end : String) : Boolean;
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	myLen,
	len : Integer;
begin
	myLen := self.length;
	
	len := _end.length;
	if len = 0 then
		return true;	//15 May 2013	NDL - Better than a crash...
	elseif len &gt; myLen then 
		return false;
	elseif len = myLen then
		return (self.toUpper = _end.toUpper);
	endif;
	
	return (self[myLen - len + 1 :len].toUpper = _end.toUpper);
end;</source>
        <Parameter name="_end" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="escapeEDIInvalidChars" id="28723b03-8ae8-46da-8e13-96ba7e8e361b">
        <source>escapeEDIInvalidChars(_elementSep, _subElementSep, _escape : Character) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2014	cnwmc5	Initial creation	PAR 33635

*/

vars

	str : String;
	
begin

	str := self;
	
	str := str.replaceString(_elementSep, _escape &amp; _elementSep);
	str := str.replaceString(_subElementSep, _escape &amp; _subElementSep);
	
	return str;
	
epilog

end;</source>
        <Parameter name="_elementSep" type="Character"/>
        <Parameter name="_subElementSep" type="Character"/>
        <Parameter name="_escape" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="expandCargoIDs" id="cb7cf575-9792-413d-993e-340e6bdd5f54">
        <source>expandCargoIDs(_cargoIDs : StringArray input);
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR

*/

constants
	RANGE_STRING 	= " - ";
	RANGE_CHARACTER = 01.Character.String;	// non printable character so won't have been entered by user
	COMMA			= ",";
vars

	len, idx, idy, num3,  num1, num2 		: Integer;
	rangeStr, tmpStr 						: String;
	part1, part2 							: String;
	tmpID,  cargoID, lett1, lett2 	: String;
	ed,  a, b , c, pos						: Integer;
begin
	tmpStr := self;
	tmpStr.replaceChar(CrLf.Character,COMMA);
	// treat '--' same as '-' (not sure why?)
	tmpStr := tmpStr.replace("--", " - ");
	tmpStr := tmpStr.replace("-", " - ");
	// no ranges so nothing to do
	if tmpStr.pos(RANGE_STRING, 1) = 0 then
		//return;
	endif;
	
	// it is easier if our range is a single character
	tmpStr := tmpStr.replace(RANGE_STRING, RANGE_CHARACTER);
	// get rid of any spaces in there
	tmpStr := tmpStr.replace(" ", null);	// 02/03/2011 cnwcs5

	idx := 1;
	ed 	:= tmpStr.length;
	a 	:= 1;
	
	foreach idx in 1 to ed do
		if tmpStr[idx:1] = COMMA then
			b := idx;
			if b &gt; a then
				tmpID :=  tmpStr[a:(b-a)];
				tmpID:=tmpID.replace(COMMA, null);
				tmpID:=tmpID.trimBlankCharacters();
				_cargoIDs.add(tmpID);
				//cargoIDS := cargoIDS &amp; tmpID;
				a := b + 1;
			endif;
		elseif tmpStr[idx:1] = RANGE_CHARACTER then
			c := tmpStr.pos(COMMA,idx);
			if c = 0 then
				rangeStr := tmpStr[b + 1 : end];
			else
				a := c + 1;
				rangeStr := tmpStr[b + 1 : (c - b - 1)];
			endif;
			
			pos		:= rangeStr.pos(RANGE_CHARACTER,1);	// 02/03/2011 cnwcs5
			part1 	:= rangeStr[1 : pos - 1];			// 02/03/2011 cnwcs5
			
			if pos &lt; rangeStr.length then				// 02/03/2011 cnwcs5
				part2 	:= rangeStr[pos + 1: end];		// 02/03/2011 cnwcs5
			else										// 02/03/2011 cnwcs5
				part2 	:= null;						// 02/03/2011 cnwcs5
			endif;										// 02/03/2011 cnwcs5
			
			part1	:= part1.trimBlankCharacters();
			part2 	:= part2.trimBlankCharacters();
			
			part1.splitIntoNumbersLetters(lett1, num1);
			part2.splitIntoNumbersLetters(lett2, num2);
			
			lett1 	:= lett1.trimBlankCharacters();
			lett2 	:= lett2.trimBlankCharacters();
			len 	:= part1.length() - lett1.length();
		
			
				if (lett1 &lt;&gt; null and lett2 &lt;&gt; null ) and lett1 &lt;&gt; lett2 then
					app.raiseCMException2(Your_range_must_begin_with_sam, lett1, lett2, null, null);	
				endif;
				if num2 &lt; num1 then
					num3 := num1;
					num1 := num2;
					num2 := num3;
				endif;
				
				if (num2 - num1) &gt; 1000 then
					app.raiseCMException(Your_range_will_creat_more_tha, null, null);	
				endif;
				if num2 = 0 or num1 = 0 then
					app.raiseCMException(Your_range_must_have_numbe_ran, null, null);	
				endif;
				
				if app.myPassport.hasErrorsOrWarnings() then
					return;
				endif;
				
			foreach idy in num1 to num2 do
				cargoID 	:= lett1.trimBlankCharacters() &amp; idy.padLeadingWith("0", len);
				
				_cargoIDs.add(cargoID);
				//cargoIDS 	:= cargoIDS &amp;   cargoID &amp; COMMA;
			endforeach;
			
			// no more commas
			if tmpStr.pos(COMMA,idx) = 0 then
				a := 0;
			endif;
		endif;
	endforeach;
	
	if a &gt; 0 and a &lt; ed then 
		tmpID 		:=  tmpStr[a:(ed-a + 1)];
		tmpID 		:= tmpID.trimBlankCharacters();
		_cargoIDs.add(tmpID);
		//cargoIDS 	:= cargoIDS &amp; tmpID;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_cargoIDs" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractFieldNameFromAuditText" id="7052ff46-8b7c-4201-ae3f-54b8614dd5df">
        <source>extractFieldNameFromAuditText() : String;
//-----------------------------------------------------------------------------------------
//	Created:	20 Feb 2007	by cnwvu1
//
//	Purpose:	Extracts field name from the auditText.
//				AuditText is built by CM_Object::getAuditTextForProperty()
//				For example, returns "myOperator" from "myOperator^15^Operator - TIOP^"
//-----------------------------------------------------------------------------------------

vars
	pos		: Integer;	
	value	: String;
	
begin

	value := self;
	if value = null then
		return null;
	endif;
	
	if value.length &lt; 1 then
		return null;
	endif;
	
	pos := 1;
	return value.scanUntil( AuditStringSeparator, pos );

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractInteger" id="a34d904c-78cf-4a51-a248-37058a2c8868">
        <source>extractInteger() : Integer;
//
//20 Aug 2012	cnwrs1	Par30198 get first integer out of string
//
vars
	input		: String;
	strLen,
	int,
	numLen		: Integer;
	char		: String;	
begin
	input := self;
	strLen := input.length;
	if strLen &lt; 1 then
		return null;
	endif;
	//find the first number in the string and return it
	foreach int in 1 to strLen do
		char := input[int:1];
		if char = "0" then
			continue;
		endif;
		
		if char.isInteger() or 
		   char = '-' or
		   char = '+' then
			//test for bogus +/-
			if (not char.isInteger())
			and (not input[int:2].isInteger()) then
				//we got a + or - but it's not in front of a number so...
				continue;
			endif;
			
			//found a number - return as many characters as possible while still being a number

			numLen := 1;
			while true do
				numLen  := numLen + 1;
				if (not input[int:numLen].isInteger()) then
					return input[int:numLen-1].Integer;
				endif;
				if (int + numLen) &gt;= (strLen+1) then
					return input[int:numLen].Integer;
				endif;
			endwhile;
		endif;
	endforeach;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractLastNumber" id="6ddc3fcc-aa7a-462d-84ab-f58d2bf852a8">
        <source>extractLastNumber() : Real;

vars
	input		: String;
	strLen,
	int,
	numLen		: Integer;
	char		: String;	
begin
	
	input := self;
	strLen := input.length;

	if strLen &lt; 1 then
		return null;
	endif;
	
	//find the last real number in the string and return it
	foreach int in 1 to strLen reversed do
		char := input[int:1];
		
		
		if char.isReal then
			numLen := 1;
			while true do
				numLen := numLen + 1;
				int := int - 1;				
				if (not input[int:numLen].isReal) or input[int].toUpper="E" then					
					return input[int+1:numLen-1].Real;
				endif;
				if (int + numLen) &gt; (strLen+1) then				
					return input[int+1:numLen].Real;
				endif;
				if int = 1 then						
					return input[int:numLen].Real;
				endif;
			endwhile;
		endif;
	endforeach;
	
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="extractNumber" id="24777b8d-864e-4549-a25e-61eaf69b129f">
        <source>extractNumber():Real;
//----------------------------------------------------------------
//	Created:	22 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	input		: String;
	strLen,
	int,
	numLen		: Integer;
	char		: String;	
begin
	
	input := self;
	strLen := input.length;

	if strLen &lt; 1 then
		return null;
	endif;
	
	//find the first number in the string and return it
	foreach int in 1 to strLen do
		char := input[int:1];
		if char = "0" then
			continue;
		endif;
		
		if char.isReal 
		or char = '-'
		or char = '+' then
			//test for bogus +/-
			if (not char.isReal)
			and (not input[int:2].isReal) then
				//we got a + or - but it's not in front of a number so...
				continue;
			endif;
			
			//found a number - return as many characters as possible while still being a number

			numLen := 1;
			while true do
				numLen  := numLen + 1;
				if (not input[int:numLen].isReal) then
					return input[int:numLen-1].Real;
				endif;
				if (int + numLen) &gt;= (strLen+1) then
					return input[int:numLen].Real;
				endif;
			endwhile;
		endif;
	endforeach;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="extractValueFromAuditText" id="59d7afc6-73e7-4888-be7f-15eca7c77a70">
        <source>extractValueFromAuditText() : String;
//-----------------------------------------------------------------------------------------
//	Created:	15 Feb 2007	by cnwvu1
//
//	Purpose:	Extracts value from the auditText.
//				AuditText is built by CM_Object::getAuditTextForProperty()
//				For example, returns "Operator - TIOP" from "myOperator^15^Operator - TIOP^"
//-----------------------------------------------------------------------------------------

vars
	pos		: Integer;	
	value	: String;
	
begin

	value := self;
	if value = null then
		return null;
	endif;
	
	if value.length &lt; 2 then
		return null;
	endif;
	
	pos := 2;
	return value.reverse.scanUntil( AuditStringSeparator, pos ).reverse;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractXML" id="37170441-722a-4ade-b420-519a9c8c347f">
        <source>extractXML(): String;
//----------------------------------------------------------------
//	Created:	02 August 2005	by Jason Chapman  (cnwjc2)
//
//	Has to be reasonably well formed XML
//
// Changed On	By			Reason
//----------------------------------------------------------------
// 14/10/2020	jlgdap1		TFS 50098 PRP EDI Not Loading Cargo Into Jade
//							When we originally load files, we decide whether they're XML based on the presence of the &lt;xml? heading,
//							or on the filename suffix being .xml - in the filename suffix case, we stick '&lt;?xml version="1.0" encoding="UTF-8"?&gt;'
//							on the front of the string so this method works.
//							When we're reloading data that came from a .xml suffix file, we've stripped the '&lt;?xml version="1.0" encoding="UTF-8"?&gt;'
//							off the front of it already, and only have the raw data. This method then fails, and reloading a JMT Internal format XML file
//							fails and deletes all the EDI TIs associated with the original file.
//							So if we don't have '&lt;?xml version="1.0" encoding="UTF-8"?&gt;' on the front here, but we do have 'xmlns:xsi',
// 							just return the whole string - this is the string we're attempting to get from this metohd anyway
vars
	str,
	endTag	: String;
	pos,
	posEnd	: Integer;
begin

	str := self;											//*rubbish*&lt;?xml &gt;&lt;tag&gt;&lt;/tag&gt;*rubbish*
	
	//find the start
	pos := str.pos("&lt;?xml",1);
	if pos = 0 then
		pos := str.pos("xmlns:xsi=",1);			// TFS 50098
		if pos &gt; 0 then							// TFS 50098
			return str;							// TFS 50098
		endif;									// TFS 50098
		return null;
	endif;
	str := str[pos:end];									//&lt;?xml &gt;&lt;tag&gt;&lt;/tag&gt;*rubbish*

	//now find the first a tag
	pos := str.pos("&lt;",2);
	if pos = 0 then
		return null;
	endif;

	posEnd := str.pos("&gt;",pos);
	
	if posEnd &lt; (pos + 2) then
		//must be at least one character in the tag
		return null;
	endif;
	
	endTag := "&lt;/" &amp; str[pos+1:posEnd-pos];					//&lt;/tag&gt;
	
	//find the end
	pos := str.pos(endTag, posEnd);
	
	if pos = 0 then
		//calling methods will have to allow for this
		return str;
	endif;	

	return str[1:pos+(endTag.length-1)];					//&lt;?xml &gt;&lt;tag&gt;&lt;/tag&gt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractXXXCode" id="525e0e0f-0bb1-48d9-8c9a-14b21e2d2294">
        <source>extractXXXCode() : String;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	code:		String;
	spacePos:	Integer;
	cnt:		Integer;
begin
	// extract a two letter code from code name eg.  shipname, customername etc
	// check for more than one word (check for a space)
	spacePos:=self.pos(" ",1);
	if spacePos&gt;0 then
		// A space exists ie. more than one word
		// CASE A: The name is more than one word eg. Hurdy Verdi
		// 		   code will be first letter of the first two words HV
		// Determine start position for next letter - ie may be more than one space between words
		cnt:=1;
		while cnt+spacePos&lt;=self.String.length do
			if self[(spacePos+cnt):1]&lt;&gt;" " then
				break;
			else
				cnt:=cnt+1;
			endif; 
		endwhile;
		code:=self[1:1] &amp; self[(spacePos+cnt):1];
	else
		// No space exists ie. only one word
		// CASE B: The name is only one word eg. Hurdy
		// 		   code will be first and last letters HY
           code:=self[1:1] &amp; self[(self.String.length):1];
    endif;
    return code;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fileBaseName" id="72d23d63-1082-4320-babc-6027e45e89f3">
        <source>fileBaseName() : String;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     Assumes that the string is a file in form
//					c:\temp\rjs.txt
//				and returns the file name without the path
//					rjs.txt
// ---------------------------------------------------------------------------
vars
	str : String;
	pos	: Integer;
begin

	pos := 1;
	str := self.reverse;
	str := str.scanUntil('\', pos);
	str := str.reverse;

	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findNextNonIntegerPos" id="f67409ed-ab1b-453d-bee3-faf40e066e57">
        <source>findNextNonIntegerPos( _startPos : Integer ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2017	cnwndl1	Initial creation	TFS 3886

*/

vars

	pos : Integer;
	char : String;

begin
	
	pos := _startPos;
	while pos &lt; self.length do
		pos := pos + 1;
		char := self[pos:1];
		if not char.isInteger then
			return pos;
		endif;
	endwhile;
	
	return 0;

epilog

end;</source>
        <Parameter name="_startPos" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatJSONForDisplay" id="aefdb77b-0e54-4910-bd07-5d85091e5327">
        <source>formatJSONForDisplay() : String;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
*/

vars
	display : String;
begin
	display := self;
	
	display := self.replace(',"', ',' &amp; CrLf &amp; Tab &amp; '"');
	display := display.replace('[{', ' [' &amp; CrLf &amp; Tab &amp; '{' &amp; CrLf &amp; Tab);
	display := display.replace('],', CrLf &amp; Tab &amp;'],' );
	display := display.replace('},{', CrLf &amp; Tab &amp;  '},' &amp; CrLf &amp; Tab &amp; '{' &amp; CrLf &amp; Tab);
	display := display.replace('{"', '{' &amp; CrLf &amp; Tab &amp; '"' );
	display := display.replace(',}',',' &amp; CrLf &amp; Tab &amp;  '}' );
	
	return display;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatWithEllipsis" id="4a7aac87-f2bf-4341-b0ed-332b87022654">
        <source>formatWithEllipsis(_start, _stop : Integer; _replaceLineBreaks : Boolean) : String;
/*

Purpose:			Formats a String with a Ellipsis for text that is longer than a specified length. Plus can replace line breaks with a space character

Parameters:			_start				Integer	Position to start at
					_stop				Integer	Position to stop at
					_replaceLineBreaks	Boolean	Whether or not we need to replace line breaks

Return Value:		A String that is either formatted, or could not be formatted as it is too short

Date		Who		Reason
09 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	if self.length &lt; _start + _stop then
		if _replaceLineBreaks then
			return self.replace(CrLf, " ");
		else
			return self;
		endif;
	endif;

	if _replaceLineBreaks then
		return self.replace(CrLf, " ")[_start:_stop] &amp; self.Ellipsis;
	else
		return self[_start:_stop] &amp; self.Ellipsis;
	endif;

end;</source>
        <Parameter name="_start" type="Integer"/>
        <Parameter name="_stop" type="Integer"/>
        <Parameter name="_replaceLineBreaks" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAddressValues" id="6be36dca-6a25-425e-b721-83f039d67f32">
        <source>getAddressValues(	_street : String output;
					_city : String output;
					_country : String output
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2017	jlgndl1	Initial creation	TFS 7779

*/

vars

	size : Integer;
	pos1 : Integer;
	int : Integer;
	workString : String;
	strArray : CnStringArray;
	seperatorArray : StringArray;
	seperator : String;

begin

	if self.trimBlanks = null then
		return;
	endif;

	workString := self;

	
	create seperatorArray transient;
	seperatorArray.add(CrLf);
	seperatorArray.add(Cr);
	seperatorArray.add(",");
	seperatorArray.add(" ");
	
	foreach seperator in seperatorArray do
		pos1 := workString.pos(seperator,1);
		if pos1 &gt; 0 then
			strArray := workString.cnGetTokens(seperator);
			if strArray &lt;&gt; null then
				if not strArray.isEmpty then
					break;
				endif;
			else
				delete strArray;
				strArray := null;
			endif;
		endif;	
	endforeach;
	
	if strArray &lt;&gt; null then
		size :=  strArray.size;
		_street := strArray[1];
		if size = 2 then
			_city := strArray[2];
		elseif size = 3 then
			_city := strArray[2];
			_country := strArray[3];
		elseif size &gt;= 4 then
			foreach int in 2 to size - 2 do
				_street := _street &amp; " " &amp; strArray[int];
			endforeach;
			_city := strArray[size - 1];
			_country := strArray[size];
		endif;
	endif;

epilog

	delete strArray;
	delete seperatorArray;

end;</source>
        <Parameter name="_street" type="String" usage="output"/>
        <Parameter name="_city" type="String" usage="output"/>
        <Parameter name="_country" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAlphaCharAfterPos" id="d85b0f99-940d-4fd9-abcf-bc57a755ee67">
        <source>getAlphaCharAfterPos(_pos : Integer io; _consinantsOnly : Boolean) : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	Returns the first valid character after the position passed in.
			Considers the _consinantsOnly abd skips to next character if necessary

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	Vowels = 'AEIOU';
vars
	char			: Character;
	len,
	idx				: Integer;
	
begin
	len := self.length;
	if _pos &gt; len then
		//cannot return anything as the position greater than the word length
		return null;
	endif;
	
	foreach idx in _pos to len do
		if self[idx].isAlpha then
			//if we've specified to return a consinant only and character is a vowel
			//then continue to the next position
			if _consinantsOnly and (Vowels.pos(self[idx], 1) &gt; 0) then
				continue;
			endif;
			_pos := idx + 1;
			return self[idx];
		endif;
	endforeach;
	
	return null;
end;


</source>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <Parameter name="_consinantsOnly" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextDetails" id="6c4b9398-370e-4eb7-811b-abfd6e0b7ec3">
        <source>getAuditTextDetails( _fieldDelimiter : String; _propertyDelimiter : String ) : String;

/*

Purpose:		This method will breakup self (ie a string) into 1 string with the fields separated by
				the supplied field delimiter string (a ": " if it is null) and
				using the property delimiter between different properties. (a ", " if it is null)
				
				The resulting string will be made up of each property with name and value in alphabetical order.
				
				The assumption here is that the self string has been formatted using the
				AuditStringSeparator (ie ^ character) delimiter.

Date				Who		Reason
19 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	tempStr				: String;
	fieldDelimiter		: String;
	propertyDelimiter	: String;
	returnStr			: String;
	length				: Integer;
	auditObjectImage	: CM_AuditObjectImage;
	auditPropertyImage	: CM_AuditPropertyImage;
	
begin
	// first do some basic validation of the input
	tempStr	:= self.trimBlanks;
	if tempStr = null then
		return returnStr;		// ie null
	endif;
	
	if _fieldDelimiter = null then
		fieldDelimiter	:= ColonAndSpace;
	else
		fieldDelimiter	:= _fieldDelimiter;
	endif;
	
	if _propertyDelimiter = null then
		propertyDelimiter	:= CNEC_COMMA &amp; Space;
	else
		propertyDelimiter	:= _propertyDelimiter;
	endif;
	
	// Now break up self (string) into CM_AuditPropertyImage instances.
	create auditObjectImage transient;
	auditObjectImage.createPropertyImages( tempStr );
	
	if auditObjectImage.allPropertyImages.isEmpty then
		return returnStr;		// ie null
	endif;
	
	// Finally build up the required output string using these CM_AuditPropertyImage instances
	// separated by the delimiter between each instance.
	foreach auditPropertyImage in auditObjectImage.allPropertyImages do
		returnStr		:=	returnStr &amp; auditPropertyImage.name &amp; fieldDelimiter &amp;
							auditPropertyImage.beforeValue &amp; propertyDelimiter;
	endforeach;
	
	// Strip the last propertyDelimiter ie comma and space off.
	length	:= propertyDelimiter.length;
	if returnStr[ returnStr.length - length + 1 : length ] = propertyDelimiter then
		returnStr	:= returnStr[ 1 : returnStr.length - length ];
	endif;
	
	return returnStr;
	
epilog
	delete auditObjectImage;
	
end;
</source>
        <text>cnwrl1 19/05/2009 PAR 19668 - CCMS 1814</text>
        <Parameter name="_fieldDelimiter" type="String"/>
        <Parameter name="_propertyDelimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCRC16" id="3627e2be-20f5-4955-933e-330ddbd25ea1">
        <source>getCRC16() : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 May 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	crc16	: Integer;
	n		: Integer;
	message	: String;
	char	: Character;
	poly	: Integer;
	i 		: Integer;
	checksum, shiftRight : String;

	length, messageLength 	: Integer;
begin

	crc16 := #FFFF;
	poly := #3C2C;
	//write poly.asBinaryNumber;
//	message := 1.Character &amp; 6.Character &amp;0.Character &amp;47.Character &amp;5.Character &amp;0.Character;
	message := self;
	
	messageLength := message.length;
	
	foreach i in 1 to messageLength  do 
		char  := message[i];
		crc16 := crc16.bitXor(char.Integer);
		foreach n in 0 to 8 do
			// right bit shift
			shiftRight := crc16.asBinaryNumber.String;
			length := shiftRight.length-1;
			shiftRight := '0' &amp; shiftRight[1:length];
			crc16 := shiftRight.binaryAsInteger();
			// if there is a carry we Xor CRC16 with the plynomial
			if crc16.bitAnd(1) &lt;&gt; 0 then
					crc16:=crc16.bitXor(poly);
			endif;
		endforeach;	
	endforeach;
	
	checksum :=  crc16.asHex(2).String;
	
	return checksum;
	
				//shift left
				/*shiftRight := crc16.asBinaryNumber.String;
				write 'before shift right ' &amp; crc16.asBinaryNumber.String ;
				length := shiftRight.length;
				shiftRight :=  shiftRight[2:length] &amp; '0';
				crc16 := shiftRight.binaryAsInteger();
				write 'after  shift right ' &amp; crc16.asBinaryNumber.String ;
				crc16.bitXor(poly);
				write 'after Xor with Poly ' &amp; crc16.asBinaryNumber.String ;*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCSVField" id="057bee82-0507-4096-89b7-5d5ff664bbeb">
        <source>getCSVField(_columnNo : Integer) : String;

/*

Purpose:	Return the field at column n
			Eg. if self := "mike,day,777, o5";
				getCSVField(2); //returns 'day'
				
				if _columnNo &gt; number of commas in self then no string is returned

Parameters:		_columnNo is the field number which is returned	

Return Value:		


Date		Who		Reason
11 August 2010	cnwmd1	Initial creation

*/

vars
	field : String;
	i, numFound : Integer;
begin
	foreach i in 1 to self.length do
		if self[i] = ',' then
			numFound := numFound + 1;
			if numFound = _columnNo then
				break;
			else
				field := '';
			endif;
		else
			field := field &amp; self[i];
		endif;
	endforeach;
	
	if i &gt; self.length then //end of the line counts as one
		numFound := numFound + 1;
	endif;
	if numFound = _columnNo then
		return field;
	endif;
epilog
	
end;</source>
        <Parameter name="_columnNo" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassNoForOidString" id="64a912a8-dae5-4374-8192-77b5bf8b5ebc">
        <source>getClassNoForOidString() : Integer;
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwsb1
//
// Purpose:		Returns the class number of the given OID.
// ---------------------------------------------------------------------------
vars
	classId : String;
	dotPos : Integer;

begin
	if self.length &lt; 3 then
		return null;
	endif;
	
	dotPos := self.pos(".", 1);
	if dotPos &lt; 2 then
		return null;
	endif;
	
	classId := self[1:dotPos-1];
	if classId.isInteger then
		return classId.Integer;
	endif;
	
	return null;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDelimitedToken" id="e35fd223-9763-4da6-93bd-5cf15275304c">
        <source>getDelimitedToken(startAt: Integer io; delimStr :String; delimiter:Character output): String;
// Retrieves the next token delimited by any character in delimStr

vars
	token:    String; 
	endAt,
	i,
	delimPos:  Integer; 
	ch:        Character;

begin
	delimiter := null;
	if startAt &lt;= 0  or startAt &gt; self.length then
		return '';
	endif;	
	if delimStr = "" then
		return '';
	endif;	

	//remove all leading delimiters
	ch := self[startAt];
	while delimStr.pos(ch.String, 1) &lt;&gt; 0 do
		startAt := startAt + 1;
		if startAt  &lt;= self.length then
			ch := self[startAt];
		else
			break;	
		endif;	
	endwhile;

	// find delimiter
	endAt := 0;
	i := startAt;
	while i &lt;= self.length do
		ch := self[i];
		delimPos := delimStr.pos(ch.String, 1);
		if delimPos = 0 then
			i := i + 1;
		else
			delimiter := delimStr[delimPos];
			endAt := i;
			break;  
		endif;      
	endwhile;

	//set up token
	if endAt = 0 then
		token := self[startAt: end]; //implicit -1 to ignore delimiter
		startAt := self.length + 1;
	else	
		token := self[startAt: (endAt -startAt)]; //implicit -1 to ignore delimiter
		startAt := endAt + 1;
	endif;

	//increment int to skip over delimiter and return token
	return token;

end;</source>
        <Parameter name="startAt" type="Integer" usage="io"/>
        <Parameter name="delimStr" type="String"/>
        <Parameter name="delimiter" type="Character" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDelimiterCount" id="a2d7106b-62eb-4482-ac97-86bdf97efeb3">
        <source>getDelimiterCount(delim : String) : Integer;
// ---------------------------------------------------------------------------
// Created:		18 June 2003 by cnwsgp1
//
// Purpose:		returns the number of times the specified delimiter occurs
//				in the string
// ---------------------------------------------------------------------------
vars
	position : Integer;
	strLength : Integer;
	count : Integer;

begin
	strLength := self.length;
	position := 1;
	
	while position &lt;&gt; 0 and position &lt;= strLength do
		position := self.pos(delim, position);	
		if position &lt;&gt; 0 then
			count := count + 1;
			position := position + 1;
		endif;
	endwhile;

	return count;
end;</source>
        <Parameter name="delim" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDirLevelUp" id="01127f69-2bb6-4fd8-9173-0b4354c3ae3f">
        <source>getDirLevelUp() : String;

vars
	levelUpDir		: String;
	theLen,
	idx 			: Integer;
 
begin

 	levelUpDir := self.stripTrailingSlashes;
 	theLen := levelUpDir.length;
 	
 	levelUpDir.replaceChar('/', '\');
	idx := levelUpDir.reversePos('\');
	
	if idx &lt;= 0 or idx &gt; theLen then
		return self;
	endif;
 	
 	levelUpDir := levelUpDir[1:idx].stripTrailingSlashes;
 	
	return levelUpDir;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDITimeStamp" id="c53b1d92-4eeb-4eda-80d8-e814ae3055c5">
        <source>getEDITimeStamp() : TimeStamp;

// cnwdvb1 28 February 2003 

vars

	dateStr,
	timeStr,
	yearStr			: String;
	dateResult		: Date;
	timeResult		: Time;
	timeStampResult	: TimeStamp;
	yearInt			: Integer;
	
begin

//	write self;
	dateResult := null;
	timeResult := null;
	if self.length &gt; 5 then
		dateStr := self[1:6];
	else
		return null;
	endif;

	if self.length &gt; 9 then	
		timeStr := self[7:4];
	endif;

	if dateStr.length = 6 then
		yearStr := dateStr[1:2];
		if yearStr.Integer &gt; 90 and yearStr.Integer &lt; 100 then
			yearInt := 1900 + yearStr.Integer;	
		elseif yearStr.Integer &lt; 90 then
			yearInt := 2000 + yearStr.Integer;
		else
			yearInt := yearStr.Integer;
		endif;
		
		dateResult.setDate(dateStr[5:2].Integer, dateStr[3:2].Integer, yearInt);
	endif;

	if timeStr.length = 4 then
		timeResult.setTime(timeStr[1:2].Integer, timeStr[3:2].Integer, 0, 0);
	endif;
	
	if dateResult.isValid then
		timeStampResult.setDate(dateResult);
	endif;
	
	if timeResult.isValid then
		timeStampResult.setTime(timeResult);
	endif;
	
	if timeStampResult.isValid then
		return timeStampResult;
	endif;
	return null;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEncryptionKey" id="5ed8e006-38bf-41ae-a3c0-48b95873bd73">
        <source>getEncryptionKey():Integer;
// --------------------------------------------------------------------------------
// Created:		14 November 2005 by cnwdad1
//
// Purpose:		Returns an encryption key for the receiver (sourced from Jasper).
//
//				Note: This uses the 1ast 5 characters of the receiver in reverse
//				order.  43 represents gap between hex for '0' = 48 and hex for
//				'Z' = 90.  1009 is a prime number. 
//
// Parameters:	None
//
// Returns:		The encryption key.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceLen	: Integer;
	charPos		: Integer;
	hashValue	: Integer;
	keyValue	: Integer;
	
begin
	sourceLen	:=	self.length();
	
	if sourceLen &gt; 5 then
		sourceLen	:=	5;
	endif;		
	
	foreach charPos in 1 to sourceLen reversed do
	 	hashValue	:=	hashValue * 43 + self[charPos].toUpper().Integer - 48;
	endforeach;	 	
	
	keyValue	:=	(hashValue / 1009).Integer;
	
	if keyValue &lt; 1009 or keyValue mod 256 = 0 then
		keyValue	:=	1009;
	endif;
	
	return keyValue;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFeetInchesFromMask" id="f4600cb2-afb0-4e1d-9b33-8978ae07bd98">
        <source>getFeetInchesFromMask() : String;
/*
Purpose:			Convert the return textUser value from an edit mask in to feet and inches,
					separated by a decimal place

Parameters:			

Return Value:		

Date		Who		Reason
28/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	decimalSep : String;
	newString : String;
	pos : Integer;
	inches, feet : String;

begin
	decimalSep := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	newString := self;
	newString := newString.trimLeft;
	pos := newString.pos(Space, 1);
	if pos = null then
		inches := newString[newString.length-1:end];
		feet := newString[1:4];
	else
		inches := newString[pos+1:end].trimBlanks;
		feet := newString[1:pos-1];
	endif;
	newString := feet &amp; decimalSep &amp; inches;
	return newString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldValueAsString" id="40cb4a07-abef-4f44-ab3a-31fe4e692833">
        <source>getFieldValueAsString(_fieldName : String; _value : String output) : Boolean;
//--------------------------------------------------------------
//Created: 03 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr	: String;
	valLen,
	pos		: Integer;
begin

	pos := self.pos(_fieldName &amp; ':', 1);
	if pos &gt; 1 and self[pos-1] &lt;&gt; ':' then
		// Have found incorrect tag so look further ...
		// (i.e. blahTAG:3:111:  instead of TAG:3:222:
		pos := self.pos(':' &amp; _fieldName &amp; ':', pos);
		if pos &gt; 0 then
			// move past initial ':'
			pos := pos+1;
		endif;
	endif;

	if pos = 0 then
		// tag not found so "no change" to tag value
		return false;
	endif;
	
	tmpStr := self.getNextToken(pos);	// move past the tag name
	valLen := self.getNextToken(pos).Integer;	// get the length of the value
	_value := self[pos : valLen];
	
	return true;

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_value" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFileName" id="d8a24def-598c-4b4a-93d9-281ce01de588">
        <source>getFileName(): String;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//
//	Assumes self is 'c:\path\fileName.ext' or something
//	Returns just the file name, no extension, no path
//----------------------------------------------------------------
vars
	fileNameRev		 		: String;
	dotPos,slashPos, start	: Integer;
	aFile					: File;
begin

	if self = null then
		return null;
	endif;

  	fileNameRev := self.reverse;
    dotPos		:= fileNameRev.pos(".", 1);
    slashPos	:= fileNameRev.pos("\", 1);
    start		:= dotPos + 1;
	
	if slashPos &gt; start then
		return fileNameRev[start:slashPos-start].reverse;
	else
		return fileNameRev[start:end].reverse;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileNameAndExtension" id="4ee10adf-7f1f-403d-89db-33e4c8620893">
        <source>getFileNameAndExtension() :String;

vars
	fileNameRev		 		: String;
	slashPos				: Integer;
	aFile					: File;
begin

	if self = null then
		return null;
	endif;

  	fileNameRev := self.reverse;

    slashPos	:= fileNameRev.pos("\", 1);
	if slashPos = 0 then
		return self;
	endif;
	return fileNameRev[1:slashPos - 1].reverse;	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHugeSAOfLengthForDelimeter" id="3234a004-7c1d-4346-aae1-845a54d7d860">
        <source>getHugeSAOfLengthForDelimeter(_lines : HugeStringArray input;_delimeter : Character; _lineLength : Integer);
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theString , line: String;
	theLines : HugeStringArray;
	pos, count  : Integer;
begin
	
	create  theLines transient;
	self.getHugeTokensForDelimiter(_delimeter,theLines); 
	
	foreach line in theLines do
		count:=line.length;
		if count &gt; _lineLength then
			while count &gt; _lineLength do
				count:=line.reversePosIndex(" ",count);
				count:= count - 1;
			endwhile;
			_lines.add(line[1:count]);
			_lines.add(line[count+1:line.length]);
		else
			_lines.add(line);
		endif;
		
	
	endforeach;

	


epilog
	delete theLines;

end;</source>
        <Parameter name="_lines" type="HugeStringArray" usage="input"/>
        <Parameter name="_delimeter" type="Character"/>
        <Parameter name="_lineLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHugeTokensForDelimiter" id="2f4c66d4-2c4f-41c6-ac3d-b54f369afac0">
        <source>getHugeTokensForDelimiter(_delimiter : String; _array : HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     01 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 18/03/2023	navmd1	TFS 57092 Bump string size to match new membership limit in JADE 2020
// 04/07/2023	navcs2	Bug 58947: FR | 54536 - 1035 UHE logs Occurring processing Damage CAMs Message
// 21/08/2023	navmd1	Handle single strings longer than the max length. 
//						We'll just have to deal with any issue this may cause with 'part lines' now appearing in places they didn't use to
vars
	theStr,
	theToken	: String;
	pos,
	theLen,
	delimPos	: Integer;
	
begin
	theStr := self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen := theStr.length;

	pos := 1;
	
	// 04/07/2023 navcs2 Bug 58947 Changes Start
	while (pos &gt; 0) do
		delimPos := theStr.pos(_delimiter, pos);
		
		if delimPos = 1 then
			// delim is at the first Pos
			theToken := "";
		elseif delimPos &gt; 1 then
			// Found it!
			theToken := theStr[pos:delimPos-pos] ;  // Outputs this
		else
			// delim doesn't exist
			theToken := theStr[pos:end];
		endif;
		
//		_array.add(theToken);	// cnwrl1 19/08/2009 PAR 20318 - MES 1011 Web EDI Link - what it was
//		_array.add( theToken[ 1 : 2047 ] );		// each individual string can only be up to 2047 bytes
		_array.add( theToken[ 1 : 15999 ] );	// JADE 2020 now allows 16k strings
		
		while theToken.length &gt; 15999 do
			theToken := theToken[16000:end];
			_array.add( theToken[ 1 : 15999 ] );
		endwhile;
		
		if delimPos = 0 then
			break;
		endif;
		
		pos := delimPos + _delimiter.length;
		if pos &gt; theLen then
			// last character must be a delimiter so
			// add null entry for the last item
			_array.add(null);
			break;
		endif;
	endwhile;	
	// 04/07/2023 navcs2 Bug 58947 Changes End
end;
</source>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getIntegerSortValue" id="751f4352-9ee6-42fb-80d1-b99ffa99a7f0">
        <source>getIntegerSortValue(_length: Integer): Integer;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int		: Integer;
	str		: String;
begin
	
	if self = null 
	or _length &lt; 1 then
		return 0;
	endif;
	
	foreach int in 1 to self.length do
		str := str &amp; self[int:1].Character.Integer.String;
		if int &gt;= _length then
			break;
		endif;
	endforeach;
	
	return str.Integer;

end;</source>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLHSandRHS" id="6c30a09b-24cf-4d96-828c-561c0255c27c">
        <source>getLHSandRHS(splittingStr: String; pos: Integer; lhs: String output; rhs: String output): Integer;

vars
	splitPos:   Integer;
	splitLen:   Integer;
	tmpPos:     Integer;
	tempStr:    String;
begin
	splitLen := splittingStr.length;
	if splitLen = 0 then
		return 0;
	endif;

	splitPos := self.pos(splittingStr, pos);
	if splitPos &gt; 0 then
		// exclude the splitting string from lhs
		lhs := self[pos: splitPos - pos];
		// exclude the splitting string from rhs
		rhs := self[splitPos + splitLen: end];
	else
		lhs := self;
	endif;

	return splitPos;

end;</source>
        <Parameter name="splittingStr" type="String"/>
        <Parameter name="pos" type="Integer"/>
        <Parameter name="lhs" type="String" usage="output"/>
        <Parameter name="rhs" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLeftAndRightTokens" id="fd2ebe6e-f222-488d-84b8-565331f25598">
        <source>getLeftAndRightTokens(splittingStr: String; pos: Integer; lhs: String output; rhs: String output): Integer;

vars
	splitPos:   Integer;
	splitLen:   Integer;
	tmpPos:     Integer;
	tempStr:    String;
begin
	splitPos := self.getLHSandRHS(splittingStr, pos, lhs, rhs);
	if splitPos &gt; 0 then
		// get token from lhs
		tmpPos := 1;
		lhs := lhs.getNextToken(tmpPos);
		// get token from rhs
		tmpPos := 1;
		rhs := rhs.getNextToken(tmpPos);
	endif;

	return splitPos;

end;</source>
        <Parameter name="splittingStr" type="String"/>
        <Parameter name="pos" type="Integer"/>
        <Parameter name="lhs" type="String" usage="output"/>
        <Parameter name="rhs" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextCSVToken" id="7655afd9-40ef-4958-938e-b47b058314d1">
        <source>getNextCSVToken(_pos : Integer io; _delimiter:Character) : String;

/*

Purpose:			Get the next token in the receiver starting from _pos using standard CSV decoding rules.
					Just a wrapper around getNextDelimitedToken with the standard CSV parameters
					See String::getNextTokenDelimitedQuoted for full details

Parameters:			Starting position in the string

Return Value:		Next token as a String, _pos updated (to zero at the end of the string)


Date		Who		Reason
13 Jun 2008	cnwkpd1	PAR #17040 - Correct EDI loading of CSV files with embedded commas and quotes in fields
25/11/2009	cnwdad1	PAR #21720 - Added delimiter parameter.
*/
begin
	//return self.getNextTokenDelimitedQuoted(",", '"', _pos);
	return self.getNextTokenDelimitedQuoted(_delimiter, '"', _pos);
end;</source>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <Parameter name="_delimiter" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextHttpValueOfName" id="ac8fae77-c3f6-4b92-aaca-4edcea27f609">
        <source>getNextHttpValueOfName(pName:String; pos : Integer io):String;
// Scans a string for the internet input string "name=value[&amp;]".
vars
	charIndex		: Integer;
	stringLength	: Integer;
	equalPos		: Integer;	// The position of the "=" sign.
	ampersandPos	: Integer;	// The position of the "&amp;" character.

begin
	stringLength	:=	self.length;

	if (stringLength &gt; 1) and (self[stringLength - 1:1] = #"0d") and (self[stringLength:1] = #"0a") then
		stringLength	:=	stringLength - 2;
	endif;

	charIndex	:=	self.pos("&amp;", pos);	// Skip the app name (at the start of the http string).

   	charIndex	:=	charIndex + 1;	

	while charIndex &lt;= stringLength do	: outerLoop
		// Find the next '=' and matching end '&amp;' positions for the next field.

		while true do
			// Get the position of the next '='.
			equalPos	:=	self.pos("=", charIndex);

			// If there are no more '=', then exit.
			if equalPos = 0 then
				return null;
			endif;

			// Get the position of the next '&amp;'.
			ampersandPos	:=	self.pos("&amp;", charIndex);

		  	if ampersandPos = 0 then
				ampersandPos	:=	stringLength + 1;
			endif;

			// If the position of the '&amp;' is less than the position of the
			// '=', then get the next start based on ampersandPos + 1.
			if ampersandPos &gt; equalPos then
				break;
			endif;

			charIndex	:=	ampersandPos + 1;

			if charIndex &gt; stringLength then
				break outerLoop;
			endif;
		endwhile;	

		if self[charIndex:(equalPos - charIndex)] = pName then
			if ampersandPos &gt; equalPos + 1 then
				pos := ampersandPos;
				return self[(equalPos + 1):(ampersandPos - equalPos - 1)];
			else
				return null;
			endif;
		endif;

		charIndex	:=	ampersandPos + 1;
	endwhile;	

	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextTagValueForName" id="22a0dabd-78cb-44f9-80da-b0feda10cd92">
        <source>getNextTagValueForName(pName:String; pStartPos : Integer io):String;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		copy of cqrd schema getNextTagValueOfName attempting to make faster
//
// ---------------------------------------------------------------------------

vars
	tagValue			: String;
	startTag			: String;
	endTag				: String;
	startTagPos			: Integer;
	endTagPos			: Integer;
	tagValueLength		: Integer;
	tagValueStartPos	: Integer;
	myLength			: Integer;
	fromFront 			: Boolean;
begin
	tagValue	:=	null;
	myLength := self.length;
	
	fromFront := pStartPos &lt; (myLength/ 2);
	
	startTag	:=	"&lt;" &amp; pName &amp; "&gt;";
	endTag		:=	"&lt;/" &amp; pName &amp; "&gt;";
	
	startTagPos	:=	self.pos(startTag, pStartPos);
	// Set pStartPos to 0.  If a tag found then this is reset below
	pStartPos := 0;
	
	if startTagPos &gt; 0 then
		endTagPos	:=	self.pos(endTag, startTagPos);

		if endTagPos &gt; startTagPos then
			tagValueStartPos	:=	startTagPos + startTag.length;
			tagValueLength		:=	endTagPos - tagValueStartPos;

			if tagValueStartPos &gt; 0 and tagValueStartPos &lt;= myLength and (tagValueStartPos + tagValueLength) &lt; myLength then
				tagValue	:=	self[tagValueStartPos:tagValueLength];
				
				// Set pStartPos to the endPosition found
				pStartPos	:= 	endTagPos + endTag.length;
				if pStartPos &gt;= myLength then
					pStartPos := 0;
				endif;
			else
				tagValue	:=	self[tagValueStartPos:end];
			endif;
		endif;
	endif;
epilog
	return tagValue;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pStartPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextTokenDelimitedQuoted" id="b844e24e-0258-465f-96ba-eec163fe0c8d">
        <source>getNextTokenDelimitedQuoted(_separator,
							_quote : Character;
							_pos : Integer io) : String;

/*

Purpose:			This returns a token from the receiver, starting from the specified position _pos.

					The receiver is assumed to be in the format defined as follows (usually CSV):

					The receiver consists of tokens separated by a separator (_separator, normally a comma or tab). If a token contains
					a separator as data, it is to be preceded and followed by a quote character (_quote, normally "). If the token contains
					any quote characters, it is to be preceded and followed by a quote character, and the embedded quotes are to be replaced
					by two quote characters.
					
					This is the way Excel outputs data in .CSV format.
	
					This method unravels the receiver, starting at _pos, as follows:
					
					If _pos is less than 1 or greater than the length of the receiver, a null is returned.
					
					If the character at _pos is not a quote character, the characters from _pos up to but not including the next separator
					or the end of the receiver are returned. _pos is updated.
					
					Otherwise, the leading quote is discarded, and the token is extracted as the characters up to but not including the next
					quote which is immediately followed by a separator. Double quote characters are replaced with a single character.

					
Return Value:		The token substring. _pos is updated to point beyond the next separator (or 0 if there are no more). If there is a trailing
					delimiter, _pos will point to the position beyond the length of the string.


Date		Who		Reason
???			cnwjub1	JSMS framework method
13 Jun 2008	cnwkpd1	PAR #17040 - Correct EDI parsing of standard CSV files with embedded Commas in fields

*/

vars
	token			: String;
	selfLength, 
	i				: Integer;
		
begin
	selfLength := self.length;
	if _pos &lt;= 0 or _pos &gt; selfLength then
		_pos:= 0;
		return null;
	endif;
	
	if self[_pos] = _quote then
		token := null;
		i := _pos + 1;
		while i &lt;= selfLength do
			token := token &amp; self.scanUntil(_quote, i);
			if i &lt;= 0 then					// No trailing quote
				_pos := 0;
				return token;
			endif;
			i := i + 1;
			if i &gt; selfLength then			// Trailing quote at end of receiver
				_pos := 0;
				return token;
			endif;
			// Got a quote, not at the end of the receiver, so check for a separator or a second quote
			if self[i] = _separator then	// This is the end of the token
				_pos := i + 1;
				return token;
			elseif self[i] = _quote then	// This is a second quote
				token := token &amp; _quote;
				i := i + 1;
				if i &gt; selfLength then
					_pos := 0;
					return token;
				endif;
			else
				token := token &amp; _quote;	// Quote followed by something else (shouldn't happen) - include the quote
			endif;
		endwhile;
		_pos := 0;
		return token;
	else
		i := _pos;
		token := self.scanUntil(_separator, i);
		if i &lt;= 0 then
			_pos := 0;
		else
			_pos := i + 1;		// Skip separator
		endif;
		return token;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_separator" type="Character"/>
        <Parameter name="_quote" type="Character"/>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumSubstituteParams" id="a4892fad-1e33-49e6-9567-8cd1e7d4fc63">
        <source>getNumSubstituteParams() : Integer;
/* ---------------------------------------------------------------------------
Created:			07 March 2001 by cnwdwq1
Purpose:			!
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------			----------  			--------------------------------------------------
---------------------------------------------------------------------------
*/
vars
	msgLen, i : Integer;
	currentChar, nextChar : Character;
	numSubs : Integer;	
begin
	msgLen := self.length;
	
	foreach i in 1 to msgLen do
		currentChar := self[i];
		if i + 1 &lt;= msgLen then
			nextChar := self[i + 1];
		else
			nextChar := null;
		endif;
		
		if currentChar = '%' and nextChar &gt;= '1' and nextChar &lt;= '9' then
			numSubs := numSubs + 1;
			i := i + 2;
		endif;
	endforeach;
	
	return numSubs;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfACharacter" id="c9a901dd-6c7f-4c47-8713-3ef972f73b36">
        <source>getNumberOfACharacter(pChar : String) : Integer;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lNum, lIndex : Integer;
begin
	
	foreach lIndex in 1 to self.length do
		if self[lIndex:pChar.length] = pChar then
			lNum := lNum + 1;
		endif;
	endforeach;
	
	return lNum;
end;</source>
        <Parameter name="pChar" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPreposition" id="9b914738-d4a3-4220-8c4c-0d78807058dc">
        <source>getPreposition() : String;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     Returns the preposition appropriate for self
//			 
// ----------   ----------  --------------------------------------------------
vars
	vowels,
	subStr			: String;
	startPos		: Integer;
begin
	vowels := 'AEIOU';
	subStr := self[1].toUpper;
	startPos := 1;
	if vowels.pos(subStr, startPos) &lt;&gt; 0 then
		return 'an';
	else
		return 'a';
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRealFromText" id="b47b744c-10cc-4e3e-bae7-701976fdb7f4">
        <source>getRealFromText():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	decimalSeperator : String;
	char : Character;
	workString : String;
	pos : Integer;
	isNegative : Boolean;
	outString : String;
	returnValue : Real;

begin
	if self = null then
		return 0;
	endif;
	workString := self.trimBlanks;

	decimalSeperator	:=	app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	foreach pos in 1 to workString.length do
		char := self[pos];
		if pos = 1 or pos = workString.length then
			if char = "-" then
				isNegative := true;
				continue;
			endif;
		endif;
		if char = decimalSeperator then
			outString := outString &amp; ".";
		elseif char.isNumeric then
			outString := outString &amp; char;
		endif;
	endforeach;
	
	if outString = null or outString = "." then
		return 0;
	endif;
	
	returnValue := outString.Real;
	
	if isNegative then
		returnValue := returnValue * -1;
	endif;
	
	return returnValue;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRowNameMeasureType" id="0238eb10-c411-44a8-b8a9-ba13d227b7ec">
        <source>getRowNameMeasureType(_rowName, _measureType : String output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321
*/
vars
	pos : Integer;

begin
	pos := self.reversePos("_");
	if pos &lt;&gt; null then
		_rowName := self[7:pos-7];
		_measureType := self[pos+1:end];
	endif;
epilog

end;</source>
        <Parameter name="_rowName" type="String" usage="output"/>
        <Parameter name="_measureType" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getStringValueAsInteger" id="2663e7d4-bd78-4816-91f1-423add8faa6d">
        <source>getStringValueAsInteger() :Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/07/2020 cnwma1 ChangeRequest 49632: MTN - Navis Smart Data Rest API

*/

vars
	i			: Integer;
	charInt     : Integer;
	length      : Integer;
begin
	length := self.length;
	
	if self = null or length &lt; 1 then
		return 0;
	endif;
	
	foreach i in 1 to self.length do
		charInt := charInt +  self[i:1].Character.Integer;
		
		if i &gt;= length then
			break;
		endif;
		
	endforeach;
	
	return charInt.Integer;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStringValueAsInteger64" id="679fbb9e-13b7-4afe-9133-e224a438e039">
        <source>getStringValueAsInteger64():Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	i			: Integer;
	charInt     : Integer64;
	length      : Integer;
begin
	length := self.length;
	
	if self = null or length &lt; 1 then
		return 0;
