    <JadeMethod name="pxyCreateUpdateProxy" id="6ad911f9-c133-4b1e-b52c-e16a4ef7e5eb">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	lWagon 				: CM_Wagon;
	pxyDamageInstance, 
	damageInstance 		: CM_DamageInstance;
	completedOK			: Boolean;
begin
	lWagon := inheritMethod();
	lWagon.myTerminal         := self.myTerminal;
	lWagon.myCarrier          := self.myCarrier;
	lWagon.myTrainInwards     := self.myTrainInwards;
	lWagon.myTrainOutwards    := self.myTrainOutwards;
	lWagon.myWagonClass       := self.myWagonClass; // PAR 21882
	lWagon.myStevedoreReceive := self.myStevedoreReceive;  //02.10.2020 cnwma1 TFS #50112
	lWagon.myStevedoreRelease := self.myStevedoreRelease;  //02.10.2020 cnwma1 TFS #50112
	
	foreach damageInstance in self.allDamageInstanceByPos  discreteLock do
		pxyDamageInstance := damageInstance.pxyGetProxyObject();
		if pxyDamageInstance = null then
			pxyDamageInstance := damageInstance.pxyCreateUpdateProxy().CM_DamageInstance;
		endif;
		pxyDamageInstance.setMySubject(lWagon);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return lWagon;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete lWagon;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetActualCargoLocations" id="93b4fbc9-8cc2-463d-bb56-216b78f2b911">
        <source>resetActualCargoLocations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2013	cnwndl1	Initial creation	Par 31171 - If the wagon moves the cargo's Yard position changes,
											need to reset it.

*/

vars

	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;

begin

	create tiArray transient;
	//foreach lc in self.allLocationsControllers discreteLock do
	foreach lc in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
		foreach ti in lc.allTrackedItems discreteLock do
			if (not tiArray.includes(ti)) then
				tiArray.add(ti);
			endif;
		endforeach;
	endforeach;
	
	foreach ti in tiArray do
		ti.resetLocationIdAfterWagonMove();
	endforeach;

epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="returnWagon" id="bb047bff-0e4a-4f15-b361-b2c3d83c35a1">
        <updating/>
        <source>returnWagon( _moveController : CMIF_WagonMoveController; _terminal : CM_Terminal; _pos : Integer; _passport : CM_Passport input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519
18 March 2024		navpw1	TFS: 62857 (62858) - Changed signature of createRailReceiveJob

*/

vars

	iter 	: Iterator;
	railJob : CM_RailJob;
	allTIs	: CM_TIArray;
	ti 		: CM_TrackedItem;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;
	
	if self.myTerminalDeparted &lt;&gt; null then
		self.myTerminalDeparted := null;
		self.myTerminal := _terminal;
	endif;
	
	self.allTIsReleased.clear();
	
	self.confirmedOutwards := false;
	
	self.createTransaction(effectiveDate, EVT_WagonReturned, self.myTrainOutwards, _pos, null, true, null, null, null);
	
	railJob := self.createRailReceiveJob(_passport, null);
	if not app.myPassport.checkValidation then
		return;
	endif;
	
	if railJob = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Railjob_null_contact_develop));	//+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	create allTIs transient;
	self.getAllTrackedItems(true, allTIs, false);
	if allTIs.isEmpty then
		return;
	endif;
	
	iter  := allTIs.createIterator;
	while iter.back(ti) do
		ti.doWagonReturn( self, _passport );
		//epr par 34466 7/7/14 new quantity/weight param
		railJob.addJobRequest(ti, true, null,null, _passport);
	endwhile;	
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.getTerminal.getTerminalEvent(Wagon_Create_Event), self);					
	railJob.causeTerminalEvent(railJob.Event_Mode_Create);
		
epilog

	delete allTIs;
	delete iter;

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAllWagonSeals" id="fafa5b5a-9f9e-4419-bc58-7e8c77edbafa">
        <updating/>
        <source>setAllWagonSeals(_pxySealObjs : CM_WagonSealBySealTypeDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	seal : CM_SealObject;
	realSeal : CM_WagonSeal;
	
begin

	self.raiseExceptionIfTransient(method);
	
	if _pxySealObjs = null or _pxySealObjs.isEmpty then
		return;
	endif;
	
	foreach seal in _pxySealObjs do
		if self.allWagonSeals.includesKey(seal.sealType) then
			self.allWagonSeals[seal.sealType].setForUpdate(seal);
		else
			create realSeal persistent;
			realSeal.setForCreate(seal);
			realSeal.setMyWagonVisit(self);
		endif;
	endforeach;
	
	self.updateObjectEdition(self);
	
epilog

end;</source>
        <Parameter name="_pxySealObjs" type="CM_WagonSealBySealTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setCargoRestrictionsFromMaster" id="c8949ab9-7f35-4fe6-aab6-55a29684db6d">
        <source>setCargoRestrictionsFromMaster() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

	matchCriteria : CM_CargoRestrictionCriteria;
	pxyRailAllocation : CM_RailAllocation;
	railAllocation : CM_RailAllocation;
	allTransientCriteriaObj	: CMIF_Array;
	criteria : CM_YACriteria;
	pxyCriteria : CM_YACriteria;
	pxyArray : CM_YACriteriaArray;

begin

	if self.myTerminal = null then
		return;
	endif;
	
	if self.myWagonMaster = null then
		return;
	endif;
	
	matchCriteria := self.myWagonMaster.getMyObjectMatchCriteriaFor( self.myTerminal );
	if matchCriteria = null then
		return;
	endif;
	
	// Ok we have some cargo restrictions, add teh colour coding.
	create pxyRailAllocation transient;
	create pxyArray transient;
	
	foreach criteria in matchCriteria.allCriteria do
		create pxyCriteria transient;
		pxyArray.add( pxyCriteria );
		pxyCriteria.setProxy(	criteria.myYACriteriaType,	//pCriteriaTypeObj:CM_YACriteriaType;
								criteria.getRawDescription,	//pDataValue:Any;
								criteria.code	//pCode:String
								);
		pxyCriteria.setYardAllocation(pxyRailAllocation);
	endforeach;
	
	pxyRailAllocation.setProxy(	self.id,
								app.getErrorString(Rail_colour_coding),
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								matchCriteria.colour, 	
								null,  
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								self.myTerminal
								);
								
	self.setRailAllocation( pxyRailAllocation, app.myPassport );
	
epilog

	if pxyArray &lt;&gt; null and not pxyArray.isEmpty then
		pxyArray.purge();
	endif;
	delete pxyArray;
	delete pxyRailAllocation;

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDateTime" id="f362ea0e-1155-4eea-a774-bac1500ea6da">
        <updating/>
        <source>setDateTime(_dateTime:TimeStamp) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2010 by cnwdad1
