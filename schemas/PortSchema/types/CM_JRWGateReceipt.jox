<Class name="CM_JRWGateReceipt" id="b7a3fa03-fad5-4fb2-b735-75d6691f3b9a">
    <superclass name="CM_JRWTrackedItems"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ImplicitInverseRef name="myVehicleVisit" id="8097cfc4-96d6-4559-93b5-b77e117a5b7e">
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
    </ImplicitInverseRef>
    <PrimAttribute name="vehicleVisitOid" id="e7c5e59d-98c8-41d6-97ca-341f7afd7464">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="bf728000-d8e2-49ef-a537-0aa6ac1e49f1">
        <source>delete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Aug 2022	navkc1	Initial creation	Bug 54342: PRP - VVR Report
15 May 2023 navma1	Bug 57048: EUP - TEST - Training. Error 4 on all reports after attempting to print Road Receipt report from Vehicle Visit
*/

vars
	tiClones	: CM_TISet;
	ti			: CM_TrackedItem;
	invalid     : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, ti, invalid); 		//17.05.2023 navma1 #57048
	
	create tiClones transient;
	
	foreach ti in self.allTrackedItems do
		invalid := false;													//17.05.2023 navma1 #57048
		ti.edition;
		if invalid then
			continue;
		endif;
		
		if ti.isTransient() then
			tiClones.add(ti);
		endif;
	endforeach;
	
	if not tiClones.isEmpty() then
		tiClones.purge();
	endif;
	
epilog

	delete tiClones;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="cbfbe355-3a51-4a7c-b899-fbdb93854ba8">
        <updating/>
        <source>setTerminal(_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2013	cnwndl1	Initial creation	Par 31562

*/

vars

begin

	self.allTerminals.clear;
	
	self.allTerminals.add (_terminal);
	
	self.setPortLogo();
	

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
