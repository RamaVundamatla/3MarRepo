<GUIClass name="CMUI_XTABDefinitionFormModal" id="ce4393da-25d6-4d2b-9807-ab3a61d66116">
    <superclass name="CMUI_XTABDefinitionForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
The only reason for this subclass is so the mdiChild setting (not able to be set at run time) can be set for the modal display.

The mdiChild property of the Form class specifies whether a form is displayed as an MDI child form inside an MDI frame form.
Use this property when creating a Multiple Document Interface (MDI) application.

At run time, forms with this property set to MdiChild_IsMdi (2) are displayed inside an MDI form.

An MDI child form can be maximized, minimized, and moved inside the parent MDI form
(if the minButton and maxButton property values are true).

Forms shown modally must have a resulting mdiChild property value of MdiChild_NotMdi (1)
The showModal method on a form declared as an MDI child form raises an exception.
</text>
    <JadeMethod name="displayOnSetupForm" id="5fb442ec-2beb-4283-aa0b-dab678e621a4">
        <updating/>
        <source>displayOnSetupForm() updating, protected;

/*

Purpose:		This method will display the form and details in the appropriate state for inital start up.
				This will usually be with a the selected definition and with full details showing.
Parameters:		
Return Value:	

Date				Who		Reason
29 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	index		: Integer;
	
begin
	// show the proxy details supplied (in a modal form)
	self.myQueryDefinition	:= null;			// force the property table to be refreshed.
	self.displayXTABDefinition( self.myProxyXTAB );
	
	// add proxy into tree (alphabetically) unless already there.
	lstSavedDisplays.listIndex	:= lstSavedDisplays.findStringExact( 1, self.myProxyXTAB.name );
	if lstSavedDisplays.listIndex &gt; null then
		// just ing case reset myCurrentXTAB
		self.myCurrentXTAB							:= lstSavedDisplays.listObject.CM_OutputFormat_XTAB;
	else
		index										:= self.lstSavedDisplays.addItem( self.myProxyXTAB.name );
		self.lstSavedDisplays.itemObject[ index ]	:= self.myProxyXTAB;
		self.lstSavedDisplays.listIndex				:= index;
	endif;
	
	if self.myCurrentXTAB = null then
		self.formMode := Mode_Add;
	else
		self.formMode := Mode_Update;
	endif;
	
	self.doBtnShowDetails;
	self.zSetControls;
	self.modalResult	:= MsgBox_Return_Cancel;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnRunDefn" id="a4a64729-d169-4e31-918f-0580ee53008b">
        <updating/>
        <source>doBtnRunDefn() updating, protected;
/* ---------------------------------------------------------------------------
Created:     29 January 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
03/12/2009	cnwcs5	par 21848 - remove workaround code
------------------------------------------------------------------------------*/
vars
	form		: CMUI_XTABDisplayForm;
	
begin
	// need to refresh the display form realFormatExpectedEdition in case the user has saved the query since last run.
	form	:= app.getForm( CMUI_XTABDisplayForm.name ).CMUI_XTABDisplayForm;
	
	if form &lt;&gt; null then

		form.setRealFormatExpectedEdition( self.currentXTABEdition );
		form.isVoyageCCMode := self.isVoyageCCMode; // PAR 21746
	endif;
	
	self.modalResult	:= MsgBox_Return_OK;
	self.unloadForm;
	
	// Do not do an inheritMethod.  As this is called from the CMUI_XTABDisplayForm via showModal it then
	// reruns the query in itself, and does not open a new form
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a2047bdf-3c02-479f-841c-ca5ddc984688">
        <updating/>
        <source>setupForm() updating;
/* ---------------------------------------------------------------------------
Created:     25 February 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod();
	
	self.centreOverParent( 250 );			// keeps the modal form on the same monitor as the display form.
	self.doBtnShowDetails;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d063a2ba-0a31-4056-9683-2625650ab85e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009321, locale);
end;</source>
    </JadeMethod>
</GUIClass>
