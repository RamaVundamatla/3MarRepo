    <JadeMethod name="getDefaultLayoutValues" id="292964e8-d9b1-432d-96e9-4a371851774e">
        <source>getDefaultLayoutValues(_width, _length : Integer output);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin

	_width := self.rows;	
	_length := self.cols;

end;</source>
        <Parameter name="_width" type="Integer" usage="output"/>
        <Parameter name="_length" type="Integer" usage="output"/>
    </JadeMethod>
