04 Aug 2023		navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 

*/

vars
	allResourceUsage : CM_ResourceTypeUsageSet;
begin
	create allResourceUsage transient;
	self.getResourceUsageSet(allResourceUsage);
	if allResourceUsage.isEmpty then
		return null;
	endif;
	return allResourceUsage.listStringNoDuplicate(Comma, CM_ResourceTypeUsage::remarks.name); // 04.08.2023 navlw1 tfs #59284:#59660
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
