    <JadeMethod name="cmbLineType_change" id="22121c5e-07cf-465e-81fd-b3b82f2935cc">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLineType_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2023	navmv20	Bug 58739: LNX - Invoice Line Type Combo Box

*/

vars
	lineType : CM_InvoiceLineDesc;
	descSet  : CM_InvoiceLineDescSet;
begin
	create descSet transient;
	if self.cmbLineType.listObject &lt;&gt; null then
		lineType :=  self.cmbLineType.listObject.CM_InvoiceLineDesc;
		descSet.add(lineType);
	endif;
	
	self.msgInvLineType.setSelected(descSet);
epilog
	delete descSet;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
