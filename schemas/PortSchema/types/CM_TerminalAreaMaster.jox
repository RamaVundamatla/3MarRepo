    <JadeMethod name="isProductWeightInRange" id="497837be-370e-4727-8608-ca71beb00b9f">
        <source>isProductWeightInRange(_productObj:CM_Product; _weight:Decimal; _isBelow:Boolean output; _limit:Integer output):Boolean;
// --------------------------------------------------------------------------------
// Created:		05 March 2008 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the weight of the specified
//				Product is within the minimum/maximum limits.
//
// Parameters:	_productObj - A reference to the Product who's weight to check.
//				_weight - The current known weight of the Product.
//				_isBelow - True if the minimum limit is exceeded, otherwise false.
//				_limit - The limit that has been exceeded, otherwise zero.
//
// Returns:		True if the Product weight is within the limits, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	minWeight	: Integer;
	maxWeight	: Integer;
	
begin
	self.getProductMinMaxWeight(_productObj, minWeight, maxWeight);
	
	if minWeight &gt; 0 and _weight &lt; minWeight then
		_isBelow	:=	true;
		_limit		:=	minWeight;
		return false;
		
	elseif maxWeight &gt; 0 and _weight &gt; maxWeight then
		_isBelow	:=	false;
		_limit		:=	maxWeight;
		return false;
		
	endif;
	
	return true;
end;</source>
        <Parameter name="_productObj" type="CM_Product"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_isBelow" type="Boolean" usage="output"/>
        <Parameter name="_limit" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
