    <JadeMethod name="getDisplayStringForAttribute" id="5a438c79-9922-4d7c-8bc0-06cec676c9eb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Aug 2009	cnwmd1	Initial creation
26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Apr 2023 navhl20 Bug 57458: EUP - Work Order Remarks
31 May 2023 navmv20 CR 54345 Task 57116: Jade - Contract Id Work Order Enquiry
05 July 2023 navmv20 CR 58416 Task 58417: UI - Work Order Enquiry
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability
*/

vars
	remarks : String;
	voyage	: CM_Voyage;
	vessel 	: CM_Vessel;	
begin
	if _attrName = ETRow_WorkOrderNum then
		return self.getMyParent.id.String;
	elseif _attrName = ETRow_Status then
		return self.getStatusString();
	elseif _attrName = ETRow_CustomerReference then
		return self.getMyParent.customerReference;
	elseif _attrName = ETRow_RequestedBy then
		return self.getMyParent.getEnteredByDisplay();
	elseif _attrName = ETRow_RequestedByTS then
		return self.systemToLocalTime(self.getMyParent.enteredByDT).asStringJMT;//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_ConfirmedBy then
		return self.getMyParent.approvedBy;
	elseif _attrName = ETRow_ConfirmedByTS 	then
		return self.systemToLocalTime(self.getMyParent.approvedByDT).asStringJMT();//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Progress then
		return self.getProgressString();
	elseif _attrName = ETRow_RequiredByWOTS then
		return self.systemToLocalTime(self.getMyParent.requiredByDT).asStringJMT();//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Task then
		return self.getDisplayString(true);
	elseif _attrName = ETRow_RequiredByTaskTS then
		return self.systemToLocalTime(self.requiredByDT).asStringJMT();//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Actioned then
		return self.getTotalActioned().asStringJMT();
	elseif _attrName = ETRow_Complete then
		return self.getTotalComplete.asStringJMT();
	elseif _attrName = ETRow_Required then
		return self.getMyParent.getTotalRequired().asStringJMT();
	elseif _attrName = ETRow_RemToAction then
		return self.getNumberRemainingToAction().asStringJMT();
	elseif _attrName = ETRow_RemToComplete then
		return self.getNumberRemainingToComplete().asStringJMT();	
	elseif _attrName = ETRow_TaskTotalRequired then
		return '';
	elseif _attrName = ETRow_AutoSchedule then
		return self.autoQueueTask.String;		
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_Remarks then								//06.4.2023 navhl20	#57458
		remarks := self.getRemarks();
		if remarks &lt;&gt; null then
			return remarks.formatWithEllipsis(1,100,true);
		endif;
		return null;
	elseif _attrName = ETRow_Priority then								//12.04.2023 navma1 #57458
		return null;
	elseif _attrName = ETRow_ContractId then   //31/05/2023 navmv20 CR 54345 Task 57116
		//return self.contractId;  //31/05/2023 navmv20 CR 54345 Task 57116
		return self.getContractID(); //26/11/2024	navkc1 JIRA Story MTN-19092
	//05/07/2023 navmv20 CR 58416 Task 58417 - start
	elseif _attrName = ETRow_ReleaseOperatorCode then
		return self.getReleaseOperatorCode();
	elseif _attrName = ETRow_ReleaseOprDesc then
		return  self.getReleaseOperatorDesc();
	elseif _attrName = ETRow_ReleaseCargoGrpId then
		return self.getReleaseCargoGroupId();
	//05/07/2023 navmv20 CR 58416 Task 58417 - end
	elseif _attrName = ETRow_NoCharge then  // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
		return self.getNoCharge().getYes();  // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
	elseif _attrName = ETRow_DebtorName then  // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
		return self.getDebtorName();
	elseif _attrName = ETRow_TransportMode then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getTransportModeStr();
	elseif _attrName = ETRow_VesselName then //26/11/2024	navkc1 JIRA Story MTN-19092
		voyage := self.getMyVoyageObject();
		if voyage &lt;&gt; null then
			vessel := voyage.getMyVessel();
			if vessel &lt;&gt; null then
				return vessel.name;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_VesselCode then //26/11/2024	navkc1 JIRA Story MTN-19092
		voyage := self.getMyVoyageObject();
		if voyage &lt;&gt; null then
			vessel := voyage.getMyVessel();
			if vessel &lt;&gt; null then
				return vessel.code;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_CargoGroupId then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCargoGroupID().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_BookingId then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getBookingID().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_ReleaseRequestNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getReleaseRequestID().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_BillOfLading then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getBOLID().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_CustomsEntryNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCustomEntryNumber().formatWithEllipsis(1, 100, true); 
	elseif _attrName = ETRow_TrainCode then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getTrainsCode();
	elseif _attrName = ETRow_VbsExternalReference then//26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getVBSExternalRef().formatWithEllipsis(1, 100, true); 
	elseif _attrName = ETRow_OperatorTI then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getTIOperatorStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_DebtorCode then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getDebtorCode();
	elseif _attrName = ETRow_ToDoTaskDesc then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getToDoTaskDescStr();
	elseif _attrName = ETRow_VehicleVisitNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getAllVehicleVisitsStr();
	elseif _attrName = ETRow_WagonNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getWagonsStr();
	elseif _attrName = ETRow_CargoType then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCargoTypeStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_CargoSubType then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCargoSubTypeStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_Commodity then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCommodity().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_Voyage then //26/11/2024	navkc1 JIRA Story MTN-19092
		voyage := self.getMyVoyageObject();
		
		if voyage &lt;&gt; null then
			return voyage.code;
		endif;
		
		return null;
	endif;
		
	return inheritMethod(_attrName, _short);
epilog
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDtlType" id="25c8873f-00d4-4a7e-83c1-1e2e8cd2454e">
        <source>getDtlType(): Integer abstract;
</source>
