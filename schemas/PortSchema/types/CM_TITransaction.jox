    <JadeMethod name="isChild" id="7d43b430-9dfc-4e80-9f0a-f0fdf78ee585">
        <source>isChild():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2010	cnwndl1	Initial creation	Par 23056

*/

vars

	stateData : Any;
	
begin

	stateData := self.getExtraData(TrnsExtraDataChild);
	
	if stateData &lt;&gt; null then
		return stateData.Integer.Boolean;
	else
		return false;
	endif;
	
