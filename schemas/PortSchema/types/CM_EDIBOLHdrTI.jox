end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6154293c-2b10-4b4f-bd14-7eba0d4789fc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/11/2013	cnwdap1		Initial creation PAR #33019 CCMS DPH 2285 New BOL Fields
// 09/09/2015   cnwma1      PAR #36797 Can't create BOL via EDI
// 01/12/2022   navma1	    ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//
vars

begin
	
	if _attrName = ETRow_ClientRef1 then
		return self.getServiceOrderNbr;
	elseif _attrName = ETRow_ClientRef2 then
		return self.getPONbr;
	elseif _attrName = ETRow_Vehicle then 				 //09/09/2015 cnwma1 PAR #36797
		return self.getVehicle;
	
	//02.12.2022 navma1 #55424
	elseif _attrName = ETRow_HasChanged then
		return false.String;
	elseif _attrName = ETRow_MessageMode then		
		return self.messageMode;
	elseif _attrName = ETRow_Id then
		return self.id;
	elseif _attrName = ETRow_CarrierCode then
		return self.carrierCode;
	elseif _attrName = ETRow_SubTerminalCode then
		return self.subTerminalCode;
	elseif _attrName = ETRow_DestinationPort then
		return self.destinationPort;
	elseif _attrName = ETRow_DischargePort then
		return self.dischargePort;
	elseif _attrName = ETRow_LoadPort then
		return self.loadPort;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_NotifyParty then
		return self.notifyParty;
	elseif _attrName = ETRow_TransportMode then
		return self.transportMode;
	elseif _attrName = ETRow_VoyageCode then
		return self.voyageCode;
	elseif _attrName = ETRow_OperatorCode then
		return self.operatorCode;
	endif;
	//02.12.2022 navma1 #55424
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
