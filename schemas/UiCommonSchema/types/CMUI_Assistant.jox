    <JadeMethod name="setLogGrade" id="0250a599-1d36-467a-8680-d5f559ab5936">
        <source>setLogGrade(_species : CM_LogSpecies;
			_grade : CM_LogGrade;
			_type : CM_LogType;
			_treatment : CM_LogTreatment;
			_length : CM_LogLength;
			_table : CM_EntryTable input; 
			_gradeCmb : ComboBox input; 
			_typeCmb : ComboBox input; 
			_treatmentCmb : ComboBox input; 
			_lengthCmb : ComboBox input			
			);
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
//--------------------------------------------------------------
//Created: 13 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpCodeGroup	: CM_CodesByCodeDict;

begin


	if _species &lt;&gt; null then
		tmpCodeGroup := _species.allLogGrades;
		if _grade &lt;&gt; null then
			_table.setValueByControlName(_gradeCmb.name, _grade.code);
		else
			_table.setValueByControlName(_gradeCmb.name, null);
		endif;
	else
		_table.setValueByControlName(_gradeCmb.name, null);
	endif;

	self.comboBoxAddCode(_gradeCmb, tmpCodeGroup, _grade, false);

	self.setLogType(_table, _typeCmb, _grade, _type);	
	self.setLogTreatment(_table, _treatmentCmb, _grade, _treatment);	
	self.setLogLength(_table, _lengthCmb, _grade, _length);	

end;</source>
        <Parameter name="_species" type="CM_LogSpecies"/>
        <Parameter name="_grade" type="CM_LogGrade"/>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_treatment" type="CM_LogTreatment"/>
        <Parameter name="_length" type="CM_LogLength"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_gradeCmb" type="ComboBox" usage="input"/>
        <Parameter name="_typeCmb" type="ComboBox" usage="input"/>
        <Parameter name="_treatmentCmb" type="ComboBox" usage="input"/>
        <Parameter name="_lengthCmb" type="ComboBox" usage="input"/>
    </JadeMethod>
