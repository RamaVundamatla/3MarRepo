    <JadeMethod name="doPrint4Weeks" id="910f8e56-4ebf-4bb5-bf48-0ac9ebcd1697">
        <source>doPrint4Weeks(_wk1,_wk2,_wk3,_wk4 : Integer; theDates : DateArray;_picNum : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	xPos, yPos : Integer;

	theWidth, theHeight : Integer;
begin
	
	theWidth := self.frmMain.clientWidth;
	theHeight := self.frmMain.clientHeight;

	if _picNum = 1 then
		self.picBack.picture := self.picture1.picture;
	elseif _picNum = 2 then
		self.picBack.picture := self.picture2.picture;
	elseif _picNum = 3 then
		self.picBack.picture := self.picture3.picture;
	elseif _picNum = 4 then
		self.picBack.picture := self.picture4.picture;
	endif;
		
	// ### TOP LEFT
	yPos := 5;
	xPos := 5;
	self.doPrintFrame(xPos,yPos,theDates[_wk1]);

	// ### TOP RIGHT
	yPos := 5;
	xPos := theWidth + 40;
	self.doPrintFrame(xPos,yPos,theDates[_wk2]);


	// ### BOTTOM LEFT
	yPos := theHeight + 70;
	xPos := 5;
	self.doPrintFrame(xPos,yPos,theDates[_wk3]);


	// ### BOTTOM RIGHT
	yPos := theHeight + 70;
	xPos := theWidth + 40;
	self.doPrintFrame(xPos,yPos,theDates[_wk4]);

	app.printer.newPage();
end;</source>
        <Parameter name="_wk1" type="Integer"/>
        <Parameter name="_wk2" type="Integer"/>
        <Parameter name="_wk3" type="Integer"/>
        <Parameter name="_wk4" type="Integer"/>
        <Parameter name="theDates" type="DateArray"/>
        <Parameter name="_picNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrintDiary" id="95f9b34c-4f18-409e-8ec2-233f099f5f02">
        <source>doPrintDiary();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	stDate : Date;
	theDates : DateArray;
	xPos, yPos : Integer;
	theWidth, theHeight : Integer;
begin
	self.setHolidays();
	
	theWidth := self.frmMain.clientWidth;
	theHeight := self.frmMain.clientHeight;

	create theDates transient;
	stDate.setDate(4,4,2011); //  FIRST MONDAY
	
	self.getWeeks(stDate, theDates, 56);
	app.printer.setMargins(Print_Portrait,1,1,1,1);
	app.printer.printPreview := self.chkPreview.value;
	app.printer.duplex := 2; //app.printer.Duplex_Vertical;
	
	self.doPrint4Weeks(56, 1, 42, 15,theDates,1);
	self.doPrint4Weeks(2, 55, 16, 41,theDates,2);
	self.doPrint4Weeks(54, 3, 40, 17,theDates,3);
	self.doPrint4Weeks(4, 53, 18, 39,theDates,4);
	self.doPrint4Weeks(52, 5, 38, 19,theDates,1);
	self.doPrint4Weeks(6, 51, 20, 37,theDates,2);
	self.doPrint4Weeks(50, 7, 36, 21,theDates,3);
	self.doPrint4Weeks(8, 49, 22, 35,theDates,4);
	self.doPrint4Weeks(48, 9, 34, 23,theDates,1);
	self.doPrint4Weeks(10, 47,24, 33,theDates,2);
	self.doPrint4Weeks(46, 11, 32, 25,theDates,3);
	self.doPrint4Weeks(12, 45, 26, 31,theDates,4);
	self.doPrint4Weeks(44, 13, 30, 27,theDates,1);
	self.doPrint4Weeks(14, 43, 28, 29,theDates,2);
	

epilog
	app.printer.close;

	delete theDates;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintFrame" id="1570112f-aa1c-4b35-b02b-9dc25ea75830">
        <source>doPrintFrame(_xPos : Integer;  _yPos : Integer; _stDate : Date);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theWidth, theHeight : Integer;
begin
	
	theWidth := self.frmMain.clientWidth;
	theHeight := self.frmMain.clientHeight;
	
	
	self.lblTop.caption := "  " &amp; _stDate.day.String &amp; " " &amp; _stDate.monthName &amp; " to " &amp; (_stDate + 6).String;
	self.lblName.caption := self.getDateCaption(_stDate);
	self.lblName_1.caption := self.getDateCaption(_stDate + 1);
	self.lblName_1_1.caption := self.getDateCaption(_stDate + 2);
	self.lblName_1_2.caption := self.getDateCaption(_stDate + 3);
	self.lblName_1_3.caption := self.getDateCaption(_stDate + 4);
	self.lblName_1_4.caption := self.getDateCaption(_stDate + 5);
	self.lblName_1_5.caption := self.getDateCaption(_stDate + 6);

	self.lblHoliday.caption := self.getHolidayCaption(_stDate);
	self.lblHoliday_1.caption := self.getHolidayCaption(_stDate + 1);
	self.lblHoliday_2.caption := self.getHolidayCaption(_stDate + 2);
	self.lblHoliday_3.caption := self.getHolidayCaption(_stDate + 3);
	self.lblHoliday_4.caption := self.getHolidayCaption(_stDate + 4);
	self.lblHoliday_5.caption := self.getHolidayCaption(_stDate + 5);
	self.lblHoliday_6.caption := self.getHolidayCaption(_stDate + 6);

	
	self.frmMain.move(_xPos,_yPos,theWidth, theHeight);
	app.printer.setPrintPosition(_yPos);				
	
	
	app.printer.print(self.frmMain);

epilog
end;</source>
        <Parameter name="_xPos" type="Integer"/>
        <Parameter name="_yPos" type="Integer"/>
        <Parameter name="_stDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doPrintRoster" id="7ee235b1-5009-4f5e-8ab9-89bcd8597877">
        <source>doPrintRoster();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lastDate, stDate, endDate, holDate : Date;
	theDates : DateArray;
	idx : Integer;
	theWidth, theHeight : Integer;
	sth : String;
begin
	self.setHolidays();
	self.setDevs();

	create theDates transient;
	stDate.setDate(19,6,2017); //  FIRST MONDAY
	
	self.getWeeks(stDate, theDates, 30); 
	
	lastDate := stDate;
	endDate := stDate;

	foreach stDate in theDates do
		
		if lastDate &lt;= stDate then
			if self.holidaysDates.includes(stDate) then
				endDate := stDate;
			else
				endDate := stDate - 1;
			endif;
			holDate := null;
			sth := null;
			sth := self.getHolidayCaptionWeek(lastDate, endDate, holDate);
			
			if holDate &gt; endDate then
				endDate := holDate;
			endif;
			idx := idx + 1;
			if idx &gt; self.devNames.size then
				idx := 1;
			endif;
			
			write lastDate.String &amp; " to " &amp; endDate.String &amp; sth &amp; " " &amp; self.devNames[idx];
		endif;
		
		lastDate := endDate + 1;
	endforeach;

epilog


	delete theDates;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDateCaption" id="84509495-fd1e-4aa2-9a7e-a4c61ca61a50">
        <source>getDateCaption(_date : Date) : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return "  " &amp;  _date.dayName() &amp; ", " &amp; _date.day.String &amp; " " &amp; _date.monthName;

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHolidayCaption" id="4fc50052-f0eb-49bc-90ea-92bdb9bedddc">
        <source>getHolidayCaption(_date : Date) : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	if self.holidaysDates.includes(_date) then
		idx := self.holidaysDates.indexOf(_date);
		return self.holidayNames[idx];
	else
		return null;
	endif;

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHolidayCaptionWeek" id="7a7c1806-887c-48df-85ac-90f2bd3ba8ba">
        <source>getHolidayCaptionWeek(_stDate, _endDate : Date; _holDate : Date io) : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	st, en, idx : Integer;
	holDate : Date;
begin
	st := 1;
	en := self.holidaysDates.size;
	
	foreach idx in st to en do
		holDate := self.holidaysDates[idx];
		
		if (holDate &gt; _stDate and holDate &lt;= _endDate)
		or (holDate = _endDate + 1) then
			_holDate := holDate;
			return " (" &amp; self.holidayNames[idx] &amp; ")";
		endif;
	
	endforeach;

	return null;

end;</source>
        <Parameter name="_stDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_holDate" type="Date" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeeks" id="685380cf-5cc8-4965-8211-c36bb4f819f3">
        <source>getWeeks(_stDate : Date input; _theDates : DateArray input; _numWeeks : Integer) ;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	tmpDate : Date;
begin
	tmpDate := _stDate;
	_theDates.clear;
	
	foreach idx in 1 to _numWeeks do
		_theDates.add(tmpDate);
		
		tmpDate := tmpDate + 7;
	endforeach;
	

end;</source>
        <Parameter name="_stDate" type="Date" usage="input"/>
        <Parameter name="_theDates" type="DateArray" usage="input"/>
        <Parameter name="_numWeeks" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDevs" id="0a966e2f-0744-4929-b718-356eaeadcccd">
