<Class name="CM_QRefLocActTypeProperty" id="f72cb4d4-5fca-47b1-82d7-155e3dbbd4cc">
    <superclass name="CM_QRefEventTypeProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="setComboValues" id="05f6e16f-c726-4cd4-8e97-4e0ba55797c8">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2021	navndl1	Initial creation	TFS 50906

*/

vars
	qrl				: CM_QReferenceLookup;
	eventType		: CM_EventType;
	eventTypeDict	: CM_EventTypeByTypeDict;
	obj				: Object;
	nameDict		: CM_ObjectByStringDict;
begin
	_combo.clear();
	eventTypeDict := app.myRoot.allEventTypesByType;	
	create nameDict transient;

	foreach eventType in eventTypeDict where eventType.isLocationActivity do
		nameDict.putAtKey(eventType.name, eventType);
	endforeach;
	foreach obj in nameDict do
		eventType := obj.CM_EventType;
		_combo.itemObject[_combo.addItem(eventType.name)] := eventType;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
epilog
	delete nameDict;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="4b7ede61-000f-4976-9a84-45c8bb5d338d">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2021	navndl1	Initial creation	TFS 50906

*/

vars
	selectionValue, idx		: Integer;
	eventType		: CM_EventType;
	eventTypeDict	: CM_EventTypeByTypeDict;
	obj				: Object;
	nameDict		: CM_ObjectByStringDict;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; //

	eventTypeDict := app.myRoot.allEventTypesByType;
	create nameDict transient;

	foreach eventType in eventTypeDict where eventType.isLocationActivity do
		nameDict.putAtKey(eventType.name, eventType);
	endforeach;
	foreach obj in nameDict do
		eventType := obj.CM_EventType;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(eventType) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; eventType.name);
		_tbl.accessRow(idx).itemObject := eventType;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
epilog
	delete nameDict;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
