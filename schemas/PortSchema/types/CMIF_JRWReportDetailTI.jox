<Class name="CMIF_JRWReportDetailTI" id="ccea4ee3-6eae-4ece-b58c-e1c055675de6">
    <superclass name="CMIF_JRWReportDetail"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ImplicitInverseRef name="allReportTIs" id="5d3bd57a-07bf-4c6b-ad1f-b3a6dc2c15b5">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneReferences" id="f013a301-da82-4855-a971-7891ac7b6897">
        <updating/>
        <source>cloneReferences(_proxyDetail : SelfType; _isTransient : Boolean) updating;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_proxyDetail, _isTransient);
	_proxyDetail.allReportTIs.copy(self.allReportTIs);
	
end;</source>
        <Parameter name="_proxyDetail" type="SelfType"/>
        <Parameter name="_isTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReportName" id="92b7878b-4aca-476b-b18c-33d8d9c6c9d5">
        <source>getReportName(): String;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
		if self.allReportTIs.size = 1 then
			return self.allReportTIs.first.id;
		else
			return inheritMethod();
		endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setTI" id="f5eb9c28-5f58-4619-bb31-2e66d04eb2c5">
        <source>setTI(_ti: CM_TrackedItem);
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allReportTIs.clear;
	self.allReportTIs.add(_ti);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTIs" id="fe3a9de3-13ac-42b7-a2b9-e57c252e3cc4">
        <source>setTIs(_tiSet: CM_TISet);
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allReportTIs.clear;
	_tiSet.copy(self.allReportTIs);

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setupReport" id="936654df-ac31-4d50-a479-b8254d9518ea">
        <source>setupReport(): JadeReportWriterReport;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 02/06/2020	jlgdap1		TFS 49477 PNL Carters Note Report Broken
vars
	jrwr			: JadeReportWriterReport;
	ti				: CM_TrackedItem;
	isPoweredItem,
	isReefer,
	showVentilation,
	showHumidity	: Boolean;
	tmpISOType		: CM_ISOType;
	tmpOperator		: CM_Operator;
	co				: CM_Bank;
	addressLine,
	strAddress		: String;
	jrwTransient	: CM_JRWTrackedItems;		// TFS 49477
begin
	jrwr :=  inheritMethod();
	
	if jrwr = null then
		return jrwr;
	endif;
	
	//if self.jrwDesignName = 'CM_CarterNote' then										// TFS 49477
	ti := self.allReportTIs.first;
	app.allReportTIs.clear;
	app.allReportTIs.add(ti);
	
	isPoweredItem := false;
	isReefer := false;
	showVentilation := false;
	showHumidity := false;
	tmpISOType := ti.getISOTypeObject();
	tmpOperator := ti.myOperator;
	if (tmpISOType &lt;&gt; null) and ( tmpOperator &lt;&gt; null) then
		isPoweredItem := (tmpISOType.isReefer or tmpISOType.isFantainer);
		isReefer := tmpISOType.isReefer;
		if isPoweredItem and tmpOperator.requiresHumidity then
			showHumidity := true;
		endif;		
		if isPoweredItem and tmpOperator.requiresVentilation then
			showVentilation := true;
		endif;	
	endif;
	
	// TFS 49477
	if self.jrwDesignName = DefRep_GateCarterNoteReport then
		foreach co in self.terminal.companies do
			if co.isBusinessUnit and not co.isSuspended and co.mailingAddress.size &lt;&gt; 0 then
				jrwr.setParameter('portName', co.mailingName);
				foreach addressLine in co.mailingAddress do
					if strAddress = null then
						strAddress := addressLine;
					else
						strAddress := strAddress &amp; CrLf &amp; addressLine;
					endif;
				endforeach;
				jrwr.setParameter('portLine01', strAddress);
				break;
			endif;
		endforeach;
	else
		jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
		jrwTransient.allTerminals.clear;
		jrwTransient.allTerminals.add(ti.myTerminal);
		jrwTransient.allTrackedItems.clear;
		jrwTransient.allTrackedItems.add(ti);
	endif;
	jrwr.setParameter('showHumidity', showHumidity);
	jrwr.setParameter('showVentilation', showVentilation);
	
	return jrwr;
end;</source>
        <ReturnType type="JadeReportWriterReport"/>
    </JadeMethod>
</Class>
