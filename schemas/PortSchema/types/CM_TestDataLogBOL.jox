    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <ImplicitInverseRef name="myOperator" id="e630cca5-fee0-483e-9e58-e349f2d6a620">
        <embedded/>
        <type name="CM_Operator"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTestDataRoot" id="98c74cc4-310b-4663-85ac-3884aa521040">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
