    <JadeMethod name="getDebtorFromConsignee" id="3b3571c5-7e1f-4265-a9e1-d1511cbb1ff6">
        <source>getDebtorFromConsignee(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	debtor : CM_Debtor;
	tmpConsignee : CM_ConsigneeConsignor;

begin

	tmpConsignee := app.myRoot.allConsigneeConsignors.getAtKey( self.consignee );
	if tmpConsignee &lt;&gt; null then
		debtor := tmpConsignee.debtor;
	endif;
	
	return debtor;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="052f7077-af4d-4910-ba98-a79f6b21d6f3">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return self.getDisplayString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="b2ee77ad-f6a2-470a-ac35-059a1889058b">
        <source>getDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	str : String;

begin

	if self.myTrackedItem &lt;&gt; null then
		str := self.myTrackedItem.id &amp; " - ";
	endif;

	if self.isTransferIn then
		str := str &amp; app.getErrorString1( Transfered_from,  self.fromBolNumber );
	elseif self.isTransferOut  &lt;&gt; null then
		str := str &amp; app.getErrorString1( Transfered_to,  self.toBolNumber );
	else
		if self.myBOL &lt;&gt; null then
			if self.isUnassignTrn and self.fromBolNumber = self.myBOL.number then
				str := str &amp; app.getErrorString1( Unassigned_from, self.fromBolNumber );
			elseif self.isAssignTrn and self.toBolNumber = self.myBOL.number then
				str := str &amp; app.getErrorString1( Assigned_to, self.toBolNumber );
			elseif self.isUnassignTrn then
				str := str &amp; app.getErrorString1( Unassigned_from, "(" &amp; self.fromBolNumber &amp; ")  " &amp; self.myBOL.number );
			elseif self.isAssignTrn then
				str := str &amp; app.getErrorString1( Assigned_to, "(" &amp; self.toBolNumber &amp; ")  " &amp; self.myBOL.number );
			endif;
		else
			str := str &amp; app.getErrorString(No_BOL_object);
		endif;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f11cdef2-1217-4afd-b0d3-eea7f135d05c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation		TFS 1903

*/

vars

begin
	
	if _attrName = ETRow_Details then
		return self.getDisplayString;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingTfrTrx" id="01c969b6-bff9-4001-a916-1132b2eef206">
        <source>getMatchingTfrTrx():CM_BOLTransferTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	if self.myFromTfrTransaction &lt;&gt; null then
		return self.myFromTfrTransaction;
	elseif self.myToTfrTransaction &lt;&gt; null then
		return self.myToTfrTransaction;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="CM_BOLTransferTransaction"/>
    </JadeMethod>
    <JadeMethod name="getRelatedBOL" id="2f939a76-0723-4cce-b408-1a03b9959b39">
        <source>getRelatedBOL():CM_BOLIn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	if self.myFromTfrTransaction &lt;&gt; null then
		return self.myFromTfrTransaction.myBOL.CM_BOLIn;
	elseif self.myToTfrTransaction &lt;&gt; null then
		return self.myToTfrTransaction.myBOL.CM_BOLIn;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getSourceBolString" id="66071620-5585-4c9a-9b57-c24351392170">
        <source>getSourceBolString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	if self.isAssignTrn then
		return "None";
	elseif self.isTransferIn then
		return self.fromBolNumber;
	elseif self.isTransferOut or self.isUnassignTrn then
		return self.myBOL.number;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetBolString" id="158e21d0-1b86-4e85-b9f6-e9e5a799fe53">
        <source>getTargetBolString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	if self.isAssignTrn then
		return self.myBOL.number;
	elseif self.isTransferIn or self.isTransferOut then
		return self.toBolNumber;
	elseif self.isUnassignTrn then
		return "None";
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemId" id="fd76f768-a73c-49b5-bcef-d6652b3eadf1">
