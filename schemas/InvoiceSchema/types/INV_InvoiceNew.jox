    <JadeMethod name="initEntTable" id="48892371-1ae2-4f63-90c5-bd77a2f1b8d3">
        <updating/>
        <source>initEntTable(_table : CM_EntryTable; _entTableDef, _entTableView : String) protected, updating;
/*

Purpose:			Initializes an Ent Table from a definition and a view

Parameters:			_table			CM_EntryTable	The Ent Table to set the view for
					_entTableDef	String			The Ent Table Def to use
					_entTableView	String			The Ent Table View to use

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	theTable		: CM_EntryTable;
	entTableDef		: EntTableDef;
	entTableView	: EntTableView;
	
begin
	theTable := _table;
	theTable.clearValues();
	
	entTableDef := app.myController.getEntTableDef(_entTableDef);
	
	entTableView := entTableDef.allEntTableViews[_entTableView];
	theTable.setEntTableFromView(entTableDef, entTableView, null, null);
	
	theTable.accessColumn(1).width := 150;
	theTable.accessColumn(2).width := (theTable.width - 150).Integer;
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	theTable.warningMethod := 'entTableWarning';
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable"/>
        <Parameter name="_entTableDef" type="String"/>
        <Parameter name="_entTableView" type="String"/>
    </JadeMethod>
    <JadeMethod name="initEntTables" id="288db39d-1b88-4912-bb04-7a5781a80159">
        <updating/>
        <source>initEntTables() protected, updating;
/*

Purpose:			Initializes all the Ent Tables on the form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed
*/

begin
	// 10/11/2023	navkc1 Bug 61004
	//Initialize General Tab CM_EntryTable
	//self.initEntTable(self.tblInvProperties, ETDef_InvListInvProperties, ETView_InvListInvPropCreate);
	self.initEntTable(self.tblInvProperties, ETDef_InvListInvProperties, null);
	self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddInvDef, CM_EntryTable.ShowHideRows, true); // 10/11/2023	navkc1 Bug 61004 Reset to default
	
	/* // 10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed
	//20/07/2023	navkc1	Bug 58995 - Hide this by default, display when user select Category Credit NOte
	self.tblInvProperties.hideRowByName(ETRow_CreditNoteStartDate, false);
	self.tblInvProperties.hideRowByName(ETRow_CreditNoteStartTime, false);
	self.tblInvProperties.hideRowByName(ETRow_CreditNoteEndDate, false);
	*/
	self.tblInvProperties.setFocus();
	self.tblInvProperties.moveFirst();
	
	//Initialize Other CM_EntryTables
	self.initEntTable(self.tblBOL, ETDef_InvListInvProperties, ETView_InvListInvPropBOL);
	self.initEntTable(self.tblBooking, ETDef_InvListInvProperties, ETView_InvListInvPropBooking);
	self.initEntTable(self.tblCargo, ETDef_InvListInvProperties, ETView_InvListInvPropCargo);
	self.initEntTable(self.tblCargoGroup, ETDef_InvListInvProperties, ETView_InvListInvPropCG);
	self.initEntTable(self.tblRelease, ETDef_InvListInvProperties, ETView_InvListInvPropRelease);
	self.initEntTable(self.tblVoyage, ETDef_InvListInvProperties, ETView_InvListInvPropVoyage);
	
	self.displayInvoice();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initLinkedInvoiceSheet" id="50581c85-1b1f-4c75-95e9-3777a30d432a">
        <source>initLinkedInvoiceSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	entTableDef			: EntTableDef;
	debtor				: CM_Debtor;
	root				: CM_Root;
	rootBank			: CM_Bank;
	cmbInvDebtor		: CMUI_ComboBox;
	invType 			: CM_InvoiceDesc;
	bank				: CM_Bank;
	allInvTypes 		: CM_InvoiceTypeByNumber;
	cmbInvType			: CMUI_ComboBox;
begin
	// Set EntTable
	entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTable);
	
	if entTableDef &lt;&gt; null then
		self.tblInvoiceResult.selectMode := CM_EntryTable.SelectMode_FixedRow;
		self.tblInvoiceResult.selectionType := CM_EntryTable.SelectionType_Row;
		self.tblInvoiceResult.rows := tblInvoiceResult.fixedRows;
		self.tblInvoiceResult.setTblDataEntRowsFromDef(entTableDef);
		self.tblInvoiceResult.multiSelect := CM_BaseTable.MultiSelect_Simple;
		self.tblInvoiceResult.userInputEnabled := false;
		
		self.tblInvoiceLink.selectMode := CM_EntryTable.SelectMode_FixedRow;
		self.tblInvoiceLink.selectionType := CM_EntryTable.SelectionType_Row;
		self.tblInvoiceLink.rows := tblInvoiceLink.fixedRows;
		self.tblInvoiceLink.setTblDataEntRowsFromDef(entTableDef);
		self.tblInvoiceLink.multiSelect := CM_BaseTable.MultiSelect_Simple;
		self.tblInvoiceLink.userInputEnabled := false;
	endif;
	
	// Populate Debtor combobox
	root := app.myRoot;
	
	if root = null then
		return;
	endif;
	
	rootBank := root.myRootCompany;
	
	if rootBank = null then
		return;
	endif;
	
	// Populate Invoice Type
	cmbInvType		 := self.cmbInvoiceType;
	
	bank := self.myCurrentBank;
	
	if bank = null then
		return;
	endif;
	
	allInvTypes := bank.invoiceTypes;
	
	foreach invType in allInvTypes discreteLock where not invType.isNotAvailableForEntry do
		cmbInvType.addItemObject(invType.description, invType);		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="invTypeClick" id="a1caf818-ff7c-4418-ae44-793e46f4420f">
        <updating/>
        <source>invTypeClick(combobox: ComboBox input) protected, updating;
/*

Purpose:			Modifies the form to show entry tables for invoice separation criteria

Parameters:			combobox	ComboBox	The combo box that was clicked

Return Value:		NONE

Date		Who		Reason
29 September 2022	navpw1	Initial creation TFS: 54565 (54384)
21 December 2022	navkc1	Bug 55879: PNL - Invoicing - Creating a Manual Invoice takes 30 seconds to load
09/02/2023			navkc1	TFS CR 55305 Task 55537 UI - Invoice Credit Note UI
16 March 2023  		navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
26 April 2023		navmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
20/07/2023			navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023			navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
21 Aug 2023 		navhl20 Bug 59906: FR | 54086 - Drop down menu for 'Cargo Group Specific' for Invoice/Credit note - Creation/update screens
23 Aug 2023 		navhl20 Bug 59978: MTN - Error 14011 When creating New Invoice
11 Sep 2023 		navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
10/11/2023			navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed
*/

vars
	invoiceDesc		: CM_InvoiceDesc;
	theTable		: CM_EntryTable;
	invoiceProcess	: CM_InvoiceProcess;
	cargoTypeCol	: CM_CargoTypeSet;
	selIndex		: Integer;
	debtor			: CM_Debtor;
	debtorSep 		: CM_InvTypeDebtorSeparation;
begin
	theTable := self.tblInvProperties;
	
	theTable.setValueByControlName(combobox.name, combobox.text);
	
	//16/03/2023  navmv20 TFS 56128 Task 56129 - START
	/*self.shtBOL.visible := false;
	self.shtBooking.visible := false;
	self.shtCargo.visible := false;
	self.shtCargoGroup.visible := false;
	self.shtRelease.visible := false;
	self.shtVoyage.visible := false;
	self.shtPONumber.visible := false;  // ### BUG 56925 07MAR2023 NAVAB1 */
	//16/03/2023  navmv20 TFS 56128 Task 56129 - END
	
	invoiceDesc := combobox.listObject.CM_InvoiceDesc;
	
	if invoiceDesc = null then
		app.msgBox("Please select a valid invoice type,","Invoice Type Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		combobox.listIndex := -1;
		theTable.setValueByControlName(combobox.name, combobox.text);
		return;
		
	endif;
	
	invoiceProcess := app.getInvoiceProcess(self.myTerminal, null);
	
	//self.cmbStatusInvProp.listIndex := 1; // 26.4.2023 navmk20 TFS 57663
//20/07/2023	navkc1	Bug 58995 - Do we need to set the status to pending everytime we change the invoice type?
//	self.cmbStatusInvProp.listIndex	:= self.cmbStatusInvProp.findStringExact(1, app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING)); // 26.4.2023 navmk20 TFS 57663
//	theTable.setValueByControlName(self.cmbStatusInvProp.name, app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING));
	
	//theTable.showRowByName(ETRow_StatusInvoiceManual, false); // 10/11/2023	navkc1 Bug 61004 - It's always visible now
	
	self.cmbVoyageInvProp.listIndex := -1;
	
	selIndex	:= self.cmbDebtorInvProp.listIndex;
	
	/*  // ### TFS BUG 58919 28JUN2023 NAVAB1
	// 09/02/2023	navkc1	TFS CR 55305 TASK 55537
	if selIndex &lt; 0 then
		app.raiseCMException(Input_required_field_debtor, ETRow_Debtor, null);
	endif;
*/
	// 10/11/2023	navkc1 Bug 61004
	self.isUsingGeneralTab := false;
	
	//16/03/2023  navmv20 TFS 56128 Task 56129 - START
	if self.myTerminal.getConfig(InvShowAllSeparation).Boolean then
		return; 
	endif;
	
	self.shtBOL.visible := false;
	self.shtBooking.visible := false;
	self.shtCargo.visible := false;
	self.shtCargoGroup.visible := false;
	self.shtRelease.visible := false;
	self.shtVoyage.visible := false;
	self.shtPONumber.visible := false;
	//16/03/2023  navmv20 TFS 56128 Task 56129 - END
	
	if selIndex &gt; 0 then 									  //23.8.2023 navhl20 #59978
		debtor		:= self.cmbDebtorInvProp.itemObject[selIndex].CM_Debtor;
		debtorSep := invoiceDesc.getDebtorSeparation(debtor); // ### BUG 56925 07MAR2023 NAVAB1
	endif;													  //23.8.2023 navhl20 #59978
	
	// 10/11/2023	navkc1 Bug 61004
	if self.isCreditNote then
		if self.isUpdate() then
			self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdCNDef, CM_EntryTable.ShowHideRows, true);
		elseif self.isPosted() then // 28/11/2023	navkc1 Bug 61567
			// Don't change the enttable when posting
		else
			self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddCNDef, CM_EntryTable.ShowHideRows, true);
		endif;
		
	else
		if self.isUpdate() then
			self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdInvDef, CM_EntryTable.ShowHideRows, true);
		elseif self.isPosted() then // 28/11/2023	navkc1 Bug 61567
			// Don't change the enttable when posting
		else
			self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddInvDef, CM_EntryTable.ShowHideRows, true);
		endif;
	endif;
	
	if invoiceDesc.isVoyageSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
		// 10/11/2023	navkc1 Bug 61004
		if debtorSep = null then // If we don't have debtor seperation set up, display in one tab
			self.isUsingGeneralTab := true;
			if self.isCreditNote then
				if self.isUpdate then
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdCNVoy, CM_EntryTable.ShowHideRows, true);
				elseif self.isPosted() then // 28/11/2023	navkc1 Bug 61567
					// Don't change the enttable when posting
				else
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddCNVoy, CM_EntryTable.ShowHideRows, true);
				endif;
			else
				if self.isUpdate then
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdInvVoy, CM_EntryTable.ShowHideRows, true);
				elseif self.isPosted() then // 28/11/2023	navkc1 Bug 61567
					// Don't change the enttable when posting
				else
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddInvVoy, CM_EntryTable.ShowHideRows, true);
				endif;
			endif;
			
			if self.cmbVoyageGen.listCount() &lt;= 1 then
				self.doCmbVoyageBuild(self.cmbVoyageGen, self.includeArchivedVoyages);	//11.9.2023 navhl20 #59376
			endif;
			self.tblInvProperties.disableRowByName(ETRow_ArrivalTSGeneral);
			self.tblInvProperties.disableRowByName(ETRow_DepartureTSGeneral);
			self.tblInvProperties.disableRowByName(ETRow_VoyageDescGeneral);
		else
		 // ### BUG 56925 07MAR2023 NAVAB1 if invoiceDesc.isVoyageSpecificDebtor(debtor) then
			if self.cmbVoyageInvProp.listCount &lt;= 1 then
				//self.doCmbVoyageBuild(self.cmbVoyageInvProp,true); // PAR 10715			//11.9.2023 navhl20 #59376
				self.doCmbVoyageBuild(self.cmbVoyageInvProp, self.includeArchivedVoyages);	//11.9.2023 navhl20 #59376
			endif;
			
			self.tblVoyage.disableRowByName(ETRow_ArrivalTS);
			self.tblVoyage.disableRowByName(ETRow_DepartureTS);
			self.tblVoyage.disableRowByName(ETRow_VoyageDesc);
			self.shtVoyage.visible := true;
		endif;
	endif;
	
	if invoiceDesc.isCargoSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1 	if invoiceDesc.isCargoItemSpecificDebtor(debtor) then
		if self.cmbCargoTypeInvP.listCount &lt;= 1 then
			create cargoTypeCol transient;
			self.myTerminal.getAllCargoTypes(cargoTypeCol,true);
			self.cmbCargoTypeInvP.listCollection( cargoTypeCol, false, 0); 
		endif;
		self.populateCargoOperLocns();
		// ### JIRA 33006 15OCT2024 NAVAB1
		self.populateCargoSubTypes(null);
		self.populateCargoCommodities(null);
		
		self.tblCargo.disableRowByName(ETRow_ReceivedDT);
		self.tblCargo.disableRowByName(ETRow_ReleaseDT);
		
		self.shtCargo.visible := true;
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1if invoiceDesc.isBOLSpecificDebtor(debtor) then
	if invoiceDesc.isBOLSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
		// 10/11/2023	navkc1 Bug 61004
		if debtorSep = null then // If we don't have debtor seperation set up, display in one tab
			self.isUsingGeneralTab := true;
			if self.isCreditNote then
				if self.isUpdate() then
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdCNBol, CM_EntryTable.ShowHideRows, true);	
				elseif self.isPosted() then // 28/11/2023	navkc1 Bug 61567
					// Don't change the enttable when posting
				else
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddCNBol, CM_EntryTable.ShowHideRows, true);	
				endif;
			else
				if self.isUpdate() then
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdInvBol, CM_EntryTable.ShowHideRows, true);
				elseif self.isPosted() then // 28/11/2023	navkc1 Bug 61567
					// Don't change the enttable when posting
				else
					self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddInvBol, CM_EntryTable.ShowHideRows, true);
				endif;
			endif;
		else
			self.shtBOL.visible := true;
		endif;
		
		if self.cmbBillOfLading.listCount() &lt; 1 then
			self.doCmbBolBuild();
		endif;
	endif;
	
	if invoiceDesc.isBookingSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1 	if invoiceDesc.isBookingSpecificDebtor(debtor) then
		if self.cmbBooking.listCount() &lt; 1 then
			self.doCmbBookingBuild(); // 21/12/2022	navkc1	#55879
		endif;
		self.shtBooking.visible := true;
	endif;
	
	if invoiceDesc.isCargoGroupSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceDesc.isCargoGroupSpecificDebtor(debtor) then
		if self.cmbCGType.listCount() &lt; 1 then
			self.doCmbCargoGroupTypeBuild(); // 21/12/2022	navkc1	#55879
			self.doCmbCargoGroupIdBuild(null);				//21.8.2023 navhl20 #59906
		endif;
		self.shtCargoGroup.visible := true;
	endif;
	
	if invoiceDesc.isReleaseSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceDesc.isReleaseSpecificDebtor(debtor) then
		if self.cmbReleaseRequest.listCount() &lt; 1 then
			self.doCmbReleaseRequestBuild(); // 21/12/2022	navkc1	#55879
		endif;
		self.shtRelease.visible := true;
	endif;
	
	//14/08/2023	navkc1	Bug 59803 - Dont need this as we are now always displaying PO in General sheet
	 // ### BUG 56925 07MAR2023 NAVAB1
	/*if invoiceDesc.isPONumberSpecificSeparation(debtorSep) then
		self.shtPONumber.visible := true;
		self.txtPONumber.text := "";
	endif;
	*/
	self.doResize();
	
epilog
	delete cargoTypeCol;
	
end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
