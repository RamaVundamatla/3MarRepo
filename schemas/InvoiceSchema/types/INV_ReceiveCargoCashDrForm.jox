    <JadeMethod name="setupForm" id="51522a2e-6ea6-446b-a97d-430ff6283a64">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.setColumnsAndControlWidth(2, 200);

	inheritMethod();
	
	self.initFieldsForEntDefName(ETDef_ContainerFull, true);
	self.setupFormEmpty;
	
	self.enableAllControls(true);
	self.setFieldsFromTi();
	
	if self.initialId &lt;&gt; null and self.myTI = null then
		self.txtCargoID.setValue( self.initialId );
	endif;
	
	// no Next button
	btnNext.visible := false;
	btnSave.left := btnNext.left;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="af140c4e-2e77-47f6-bd0a-8ee3baf01511">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018423, locale);
end;</source>
    </JadeMethod>
</GUIClass>
