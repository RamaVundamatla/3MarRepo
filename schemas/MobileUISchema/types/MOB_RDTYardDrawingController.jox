    <JadeMethod name="calcGridDrawRowsUnflipped" id="067fec0d-0801-477c-8b54-7f87c88df230">
        <updating/>
        <source>calcGridDrawRowsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars

begin
	// Calculate how many rows we want to draw. This may be 1 more than fits,
	// to allow drawing of items which don't quite fit, rather than leaving a blank space
	// at the bottom of  the viewport
	if self.numGridRowsFit &lt; self.maxGridRow  and  self.bottomGridRow &lt; self.maxGridRow then
		self.bottomGridRowDraw := self.bottomGridRow + 1;
	else
		self.bottomGridRowDraw := self.bottomGridRow;
	endif;
	self.topGridRowDraw := self.topGridRow;	

	// Adjust for partial scroll, where TOP row should be partially drawn
	self.yDrawOffset := 0;
	if self.vScrollOffset &gt; 0 then
		if self.topGridRowDraw &gt; 1 then
			self.topGridRowDraw := self.topGridRowDraw - 1;
			self.yDrawOffset := (self.vScrollOffset - self.getGridHeight()).Integer;
		endif;
	elseif self.vScrollOffset &lt; 0 then
		self.yDrawOffset := self.vScrollOffset;
	endif;
	
	self.numGridRowsToDraw := self.bottomGridRowDraw - self.topGridRowDraw + 1;
epilog

end;</source>
