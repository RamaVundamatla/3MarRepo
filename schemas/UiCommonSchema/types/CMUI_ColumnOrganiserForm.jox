    <JadeMethod name="doBtnAscDescClick" id="aae5baa5-950a-4530-aac7-948619169631">
        <source>doBtnAscDescClick()protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	idx : Integer;
	str : String;
	lstBox : CM_MultiSelectListBox;
	entRow : EntTableRow;
begin

	lstBox := self.mulColumnSorter.mySelectedListBox;
	
	idx := lstBox.listIndex;
	if idx &lt; 1 then
		return;
	endif;
	lstCnt := lstBox.listCount;

	idx := 1;
	while idx &lt;= lstCnt do
		if lstBox.itemSelected[idx] then
			str := lstBox.itemText[idx];
			if str &lt;&gt; null then
				if str.cnContains(Ascending) or str.cnContains(Descending) then
					if str.cnContains(Ascending) then
						str := str.replaceWord(Ascending, Descending);
					else 
						str := str.replaceWord(Descending, Ascending);
					
					endif;
				else
					entRow := lstBox.listObject.EntTableRow;
					if entRow.inputType = CM_BaseTable.InputType_TimeStamp or entRow.inputType = CM_BaseTable.InputType_Date then
						str := str &amp; ' - ' &amp; Descending;
					else
						str := str &amp; ' - ' &amp; Ascending;
					endif;
				endif;
				lstBox.itemText[idx] := str;
			endif;
		endif;
		idx := idx+1;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
