epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateData" id="3dadf6f0-aebe-410a-99af-53a92aed334e">
        <source>populateData(_obj : CM_InstructionsIssued);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	self.txtInternalInstructions.text := _obj.internalInstructions;
	self.txtExternalReference.text := _obj.externalInstruction;
	self.cmbInstructions.listIndex		:= self.cmbInstructions.findObject(_obj.myInstructionType);
epilog

end;</source>
        <Parameter name="_obj" type="CM_InstructionsIssued"/>
    </JadeMethod>
    <JadeMethod name="populateInstruction" id="3a2f163d-7398-4a14-b15a-84536a357dac">
        <source>populateInstruction(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
16 Dec 2022 navmv20  TFS ChangeRequest 55858 Task 55867 : EUP - Instruction code refactor
14 Mar 2023 navhl20  ChangeRequest 56844:[56845] EUP - VAS Work Order Remarks
21 Aug 2023 navhl20  ChangeRequest 58717: EUP - Additional Operational Instructions on the Order - Enhancement 1
24 Aug 2023 navhl20  Bug 60029: MTN - Able to delete the instructions even after the booking is fully received.
06 Mar 2025	navah1	 Bug 34283: EUP | Additional Operational Instructions - further issues
*/

vars
	instructions : CM_InstructionsIssued; //16/12/2022 navmv20 TFS CR 55858 Task 55867
	count		 : Integer;
	showInst	 : Boolean; 
	release		 : CM_BulkRelease;		  //11.03.2025 navah1 #34283
begin
	self.btnClear.enabled := false;
	if self.myObject &lt;&gt; null then
	    //16/12/2022 navmv20 TFS CR 55858 Task 55867 - START
		/*if self.myObject.isKindOf(CM_PreNote) and self.myObject.CM_PreNote.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_PreNote.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_BookingRefItem) and self.myObject.CM_BookingRefItem.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_BookingRefItem.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_BulkRelease) and self.myObject.CM_BulkRelease.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_BulkRelease.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_ReserveDetail) and self.myObject.CM_ReserveDetail.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_ReserveDetail.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_BOL) and self.myObject.CM_BOL.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_BOL.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_BOLDtl) and self.myObject.CM_BOLDtl.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_BOLDtl.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_WorkOrder) and self.myObject.CM_WorkOrder.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_WorkOrder.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_WorkOrderDtl) and self.myObject.CM_WorkOrderDtl.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_WorkOrderDtl.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_ToDoTask) and self.myObject.CM_ToDoTask.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_ToDoTask.myInstructions);
			self.btnClear.enabled := true;
			return true;
		elseif self.myObject.isKindOf(CM_TrackedItem) and self.myObject.CM_TrackedItem.myInstructions &lt;&gt; null then
			self.populateData(self.myObject.CM_TrackedItem.myInstructions);
			self.btnClear.enabled := true;
			return true;
		endif;*/
		instructions := self.myObject.getInstructions();								//24.8.2023 navhl20 #60029
		if  instructions &lt;&gt; null then
			self.populateData(instructions);
			self.btnClear.enabled := true;
			showInst := true;
		endif;
		if self.myObject.isKindOf(CM_WorkOrder) then									//14.3.2023 navhl20 #56844:[56845]
			if self.myObject.CM_WorkOrder.taskStatus = WO_STATUS_COMPLETE then
				self.disableControls();													//24.8.2023 navhl20 #60029
			endif;
		elseif self.myObject.isKindOf(CM_WorkOrderDtl) then
			if self.myObject.CM_WorkOrderDtl.getStatus() = WO_STATUS_COMPLETE then
				self.disableControls();													//24.8.2023 navhl20 #60029
			endif;
		endif;
		if self.myObject.isKindOf(CM_BookingRef) then									//21.8.2023 navhl20 #58717
			count := self.myObject.CM_BookingRef.getTotalQuantity();
			if count = 0 then
				count := 1;
			endif;
			if count = self.myObject.CM_BookingRef.getRecievedCount() or
			self.myObject.CM_BookingRef.status = BOOKING_REF_CLOSED then
				self.disableControls();														//24.8.2023 navhl20 #60029
			endif;
		elseif self.myObject.isKindOf(CM_BOL) then
			if self.myObject.CM_BOL.getTotalQuantity() = self.myObject.CM_BOL.getNumReceived() then
				self.disableControls();														//24.8.2023 navhl20 #60029
			endif;
		elseif self.myObject.isKindOf(CM_BulkRelease) then 									//07.03.2025 navah1 #34283
			release := self.myObject.CM_BulkRelease;
			if release.status = BR_COMPLETE then
				self.disableControls();	
			endif;
		elseif self.myObject.isKindOf(CM_ReserveDetail) then 								//07.03.2025 navah1 #34283
			release := self.myObject.CM_ReserveDetail.myReserveHeader;
			if release.status = BR_COMPLETE then	 
				self.disableControls();	
			endif;
		endif;
		//16/12/2022 navmv20 TFS CR 55858 Task 55867 - END
		if showInst then
			return true;
		endif;
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
