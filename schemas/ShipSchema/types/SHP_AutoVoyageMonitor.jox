	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_VoyageStageCreate), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_VoyageStageUpdate), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_VoyageStageDelete), Response_Continuous, null);
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, null);					//navra1 - MTN-34347/MTN-34395 - 19th Mar 2025

epilog

