				&lt;generatorID/&gt;
				&lt;generatorType/&gt;
				&lt;heatTreated/&gt;
				&lt;heightString/&gt;
&lt;id&gt;JMTU1112340&lt;/id&gt;
				&lt;imexStatus/&gt;
				&lt;invoiceNumber/&gt;
				&lt;isoType&gt;2200&lt;/isoType&gt;
				&lt;isoTypeGroup/&gt;
				&lt;lengthString/&gt;
				&lt;loadPort/&gt;
&lt;locationId&gt;D4299O&lt;/locationId&gt;
				&lt;make/&gt;
				&lt;mark/&gt;
				&lt;markNumber/&gt;
				&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;model/&gt;
				&lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
				&lt;orderNumber/&gt;
				&lt;palletType/&gt;
				&lt;parentCargoID/&gt;
				&lt;parentCargoType/&gt;
				&lt;product/&gt;
				&lt;purchaseOrder/&gt;
				&lt;registration/&gt;
				&lt;remarks/&gt;
				&lt;sealCustoms/&gt;
