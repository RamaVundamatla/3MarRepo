    <JadeMethod name="spawnInputForVehicle" id="44046d3e-5713-47f8-aafd-b2fb5c0c1f3f">
        <updating/>
        <source>spawnInputForVehicle(_numToSpawn : Integer) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	Builds cloned buttons and DTO_ContainerInfo transients (to hold and pass back input to Mobile schema)

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
*/
constants
	MaxButtonHeight = 50;
	AvailableWidth 	= 140;
	Gap				= 2;
vars
	newButtonTop,
	buttonHeight			: Real;
	buttonIdx,
	availableWidth			: Integer;
	clonedButton			: Button;
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
	startTabIdx				: Integer;
begin
	if _numToSpawn = null then
		return;
	endif;
		
	buttonHeight := (AvailableWidth / _numToSpawn).min(MaxButtonHeight);
	newButtonTop := self.btnCloneMaster.top;
	startTabIdx := self.btnCloneMaster.tabIndex;
	
	foreach buttonIdx in 1 to _numToSpawn do
		self.maxCloneButtons := self.maxCloneButtons + 1;
		clonedButton := self.btnCloneMaster.getControl(self.maxCloneButtons);
		if clonedButton = null then
			clonedButton := self.btnCloneMaster.loadControl(self.maxCloneButtons).Button;
			clonedButton.tag := buttonIdx.String;
		endif;
		
		self.allClonedControls.add(clonedButton);
		clonedButton.tabIndex := startTabIdx + buttonIdx;
		clonedButton.height := buttonHeight;
		clonedButton.top := newButtonTop;
		clonedButton.visible := true;
		newButtonTop := newButtonTop + buttonHeight + Gap;
		
		create containerInfo transient;
		containerInfo.idx := buttonIdx;
		containerInfo.myButton := clonedButton;
		containerInfo.setButtonCaption();
		self.allContainerInfo.add(containerInfo);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_numToSpawn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtId_change" id="1ab4e5d2-f468-44cd-a4eb-84be5992585d">
        <controlMethod name="TextBox::change"/>
