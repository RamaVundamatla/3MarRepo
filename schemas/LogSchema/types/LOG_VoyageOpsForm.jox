        <updating/>
        <source>cmbVoyOperator_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	assist : LOG_Assistant;
	voyOper: CM_VoyageOperator;
	comboText	: String;
	
begin
	comboText	:=	combobox.text;
	comboText.replaceChar(Tab, " ");	// 14/12/2007 cnwar2 #15339
	self.tblLotDetails.setValueByControlName(combobox.name, comboText);
	if self.origValueStr &lt;&gt; combobox.text then
		voyOper := combobox.listObject.CM_VoyageOperator;	
		assist := self.myAssistant.LOG_Assistant;
		if voyOper &lt;&gt; null then
//			assist.setLogSpecies(voyOper.myOperator, null, null, null, null, null, tblLotDetails, 
//								cmbSpecies, cmbGrade, cmbType, cmbTreatment, cmbLength);
			assist.setLogSpeciesComboObjects(voyOper.myOperator, null, null, null, null, null, tblLotDetails, 
								cmbSpecies, cmbGrade, cmbType, cmbTreatment, cmbLength);

		else
//			assist.setLogSpecies(null, null, null, null, null, null, tblLotDetails, 
//								cmbSpecies, cmbGrade, cmbType, cmbTreatment, cmbLength);
			assist.setLogSpeciesComboObjects(null, null, null, null, null, null, tblLotDetails, 
								cmbSpecies, cmbGrade, cmbType, cmbTreatment, cmbLength);

		endif;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
