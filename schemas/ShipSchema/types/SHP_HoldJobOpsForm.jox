    <JadeMethod name="doAssignToDirectRelease" id="d222ca89-7b99-41fb-b4a4-e2252ed722ee">
        <updating/>
        <source>doAssignToDirectRelease() updating;
/*

Purpose:			Assigns the currently selected load WLE as a Direct Release if possible

Parameters:			

Return Value:		

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars
	result			: Integer;
	wlesWithWarnings,
	wleSet 			: CM_WLESet;
	
begin
	create wleSet transient;
	create wlesWithWarnings transient;
	self.tblJobDetails.allSelectedObjects.copy(wleSet);
	
	while true do
		app.myTrxUA.trxUpdateWLEsSetDirectRelease(wleSet, wlesWithWarnings, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleSet.clear;
				wlesWithWarnings.copy(wleSet);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	delete wleSet;
	delete wlesWithWarnings;
end;</source>
    </JadeMethod>
