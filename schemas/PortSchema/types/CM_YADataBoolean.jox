/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 August 2008	consw1	Initial creation

*/

vars

begin
	return self.doDataComparison(_yaData.CM_YADataBoolean);

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YAData"/>
