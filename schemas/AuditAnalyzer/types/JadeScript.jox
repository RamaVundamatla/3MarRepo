<Class name="JadeScript">
    <JadeMethod name="dumpJournals" id="04cd7c2e-4e24-475f-b3da-850ba11ec18b">
        <source>dumpJournals();
vars
	control			: AAControl;
	path			: String;
	startJournal	: Integer;
	endJournal		: Integer;
	startTime		: TimeStamp;
	endTime			: TimeStamp;
	fileName 		: String;
begin
	create control transient;
	
	fileName := "C:\temp\OtagoLogs\test.csv";
	path := "C:\temp\OtagoLogs";

	startJournal := 321251;
	endJournal := 321257;
	
	control.dumpJournals(fileName, path, startJournal, endJournal, startTime, endTime);
	
epilog
	delete control;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getRoot" id="c476db8c-01ff-493a-bc1f-1acfefa7185f">
        <source>getRoot() : AARoot;

vars

begin
	return AARoot.firstInstance();
end;
</source>
        <ReturnType type="AARoot"/>
    </JadeMethod>
    <JadeMethod name="loadUsers" id="358f67a7-370e-4218-a6e1-bcf0dbee62e8">
        <source>loadUsers();
vars
	root			: AARoot;
	file			: File;
	fileName 		: String;
begin
	create file	   transient;
	file.kind := File.Kind_Unknown_Text; // 4/3/16  cnwns1 PAR 36286 unicode version
	fileName := "D:\Transfer\TWL\twl-SignOn.csv";
	file.openInput(fileName);
	
	root := getRoot();
	root.loadUsers(file, 0);
	file.close();
	file.kind := File.Kind_Unknown_Text; // 4/3/16  cnwns1 PAR 36286 unicode version
	fileName := "D:\Transfer\TWL\twl-reports.csv";
	file.openInput(fileName);
	root := getRoot();
	root.loadUsers(file, 1);
	
epilog

	file.close();
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="makeRoot" id="5267e109-a20f-43b2-9dd6-c17c0e8883bd">
        <source>makeRoot();

vars
	root : AARoot;
begin
	root := getRoot();
	if root = null then
		beginTransaction;
		create root;
		commitTransaction;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="purgeUsers" id="3b7339d0-1d86-4cc2-9690-a166b006413b">
        <source>purgeUsers();

vars
	root : AARoot;
begin
	root := getRoot();
	
	beginTransaction;
	root.purgeUsers();
	delete root;
	commitTransaction;

end;
</source>
    </JadeMethod>
    <JadeMethod name="theWarehouseProcessSignOn" id="d8dee6a3-eaed-4c6f-9fd1-6c7c941557f5">
        <source>theWarehouseProcessSignOn();

/*
         1         2         3         4         5         6         7         8         9
123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890
2007/09/06 09:43:52.486 03fe8-1fec Jom: Local process sign-on 0xecc6a18: no=21, id=8172, oid=[187.51583], type=2 (non-prodn), scm=TWHTUI, app=TWHTUI2, 6.1.10.51
2007/09/06 09:43:52.517 03fe8-1fec JadApp: Thin Client connected and signed on: SP111468A (10.11.87.130) schema=TWHTUI app=TWHTUI2 tcp threadId=370c
*/

constants
	OutputFile		= 'D:\Transfer\TWL\twl_signon.csv';
	
vars
	fileNames		: StringArray;
	fileName		: String;
	input			: File;
	output			: File;
	details			: DynaDictionary;
	processDetails	: DynaDictionary;
	threadDetails	: JadeDynamicObject;
	line			: String;
	dateTime		: String;
	i, j			: Integer;
	processId		: String;
	threadId		: String;
	processOid		: String;
	name			: String;
	string			: String;
	processObject	: Object;
	threadObject	: Object;

begin
	create fileNames transient;
//	fileNames.add('c:\temp\jommsg190.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg190.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg191.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg192.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg193.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg205.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg206.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg207.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg208.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg209.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg210.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\jommsg\jommsg211.log');
	create input;
	create output;
	output.openOutput(OutputFile);
	output.writeLine('DateTime,ProcessOid,Name');
	// details are stored in a 2-dimensional array of Dynamic Dictionaries indexed by operating system process Id and thread Id
	create details transient;
	details.setMembership(DynaDictionary);
	details.addExternalKey(String, 30, false, false);	// key: Process Id
	details.endKeys(false);
	foreach fileName in fileNames do
		input.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
		input.openInput(fileName);
		while not input.endOfFile() do
			line := input.readLine();
			// locate process sign on record: "local process sign-on"
			if line.pos('Local process sign-on', 1) &lt;&gt; 0 then
				dateTime := line[ 1 : 23 ];
				// locate Process Id
				i := line.pos('-', 25);
				processId := line[ 25 : i - 25 ];
				// locate Thread Id
				j := line.pos(' ', i);
				threadId := line[ i + 1 : j - i - 1 ].toLower();
				// locate Process oid 
				i := line.pos('oid=[', j) + 5;
				j := line.pos(']', i);
				processOid := line[ i : j - i ];
write 's: '&amp;dateTime&amp;' '&amp;processId&amp;' '&amp;threadId&amp;' '&amp;processOid;
				// get or create a detail line for this process
				processDetails := details.getAtKey(processId).DynaDictionary;
				if processDetails = null then
					create processDetails transient;
					processDetails.setMembership(JadeDynamicObject);
					processDetails.addExternalKey(String, 30, false, false);	// key: Thread Id
					processDetails.endKeys(false);
					details.putAtKey(processId, processDetails);
				endif;
				threadDetails := processDetails.getAtKey(threadId).JadeDynamicObject;
				if threadDetails = null then
					// create a detail entry for this thread
					create threadDetails transient;
					threadDetails.addProperty('details', String);
					processDetails.putAtKey(threadId, threadDetails);
				endif;
				threadDetails.setPropertyValue('details', dateTime &amp; ',' &amp; processOid);
			endif;
			// locate thin client connect record: "Thin Client connected" 
			if line.pos('Thin Client connected', 1) &lt;&gt; 0 then
				// locate Process Id
				i := line.pos('-', 25);
				processId := line[ 25 : i - 25 ];
				// locate Thread Id
				j := line.pos(' ', i);
				threadId := line[ i + 1 : j - i - 1 ].toLower();
				// locate machine name (or usercode?)
				i := line.pos('signed on: ', 25) + 11;
				j := line.pos(' ', i);
				name := line[ i : j - i ];
write 'c: '&amp;processId&amp;' '&amp;threadId&amp;' '&amp;name.String;
				// get the detail line for this process
				processDetails := details.getAtKey(processId).DynaDictionary;
				if processDetails = null then
					// ignore this entry if there was no prior process sign-on
					continue;
				endif;
				// update the detail line entry for this thread
				threadDetails := processDetails.getAtKey(threadId).JadeDynamicObject;
				string := threadDetails.getPropertyValue('details').String;
				output.writeLine(string &amp; ',' &amp; name);
				threadDetails.setPropertyValue('details', null.String);
			endif;
		endwhile;
		input.close();
		write 'done - ' &amp; fileName;
	endforeach;
	foreach processObject in details do
		foreach threadObject in processObject.DynaDictionary do
			string := threadObject.getPropertyValue('details').String;
			if string &lt;&gt; null then
				output.writeLine(string);
			endif;
		endforeach;
	endforeach;
	write 'all done!';
epilog
	delete fileNames;
	delete input;
	delete output;
	foreach processObject in details do
		foreach threadObject in processObject.DynaDictionary do
			delete threadObject;
		endforeach;
		delete processObject;
	endforeach;
	delete details;
end;
</source>
    </JadeMethod>
    <JadeMethod name="theWarehouseReportStart" id="546a6440-89d4-458d-87bb-1d10c17b179d">
        <source>theWarehouseReportStart();

/*
         1         2         3         4         5         6         7         8         9
123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890
2007/09/06 10:53:05.656 ReportServer100_1/79: FAXSTATUS Deadlock Priority now 0
*/

constants
	OutputFile		= 'c:\temp\twl-reports.csv';
	
vars
	fileNames		: StringArray;
	fileName		: String;
	input			: File;
	output			: File;
	line			: String;
	dateTime		: String;
	i, j			: Integer;
	serverName		: String;
	reportName		: String;
	name			: String;
	instanceId		: String;
	string			: String;

begin
	create fileNames transient;
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg195.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg196.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg197.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg210.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg211.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg212.log');
	fileNames.add('\\cnwrwm1a\Transfer\TWL\ApplicationMessageLogs\msg213.log');
	create input;
	create output;
	output.openOutput(OutputFile);
	output.writeLine('DateTime,ProcessOid,Name,Server');
	foreach fileName in fileNames do
		input.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
		input.openInput(fileName);
		while not input.endOfFile() do
			line := input.readLine();
			// locate report start record: "Deadlock Priority now"
			if line.pos('Deadlock Priority now', 1) &lt;&gt; 0 then
				dateTime := line[ 1 : 23 ];
				// locate report server name
				i := line.pos('/', 25);
				serverName := line[ 25 : i - 25 ];
				// locate Process Instance Id
				i := i + 1;
				j := line.pos(':', i);
				instanceId := line[ i : j - i ];
				// locate report name
				i := j + 2;
				j := line.pos(' ', i);
				reportName := line[ i : j - i ];
				output.writeLine(dateTime&amp;',187.'&amp;instanceId&amp;','&amp;reportName&amp;','&amp;serverName);
write 'r: '&amp;dateTime&amp;' '&amp;serverName&amp;' '&amp;instanceId&amp;' '&amp;reportName;
			endif;
		endwhile;
		input.close();
		write 'done - ' &amp; fileName;
	endforeach;
	write 'all done!';
epilog
	delete fileNames;
	delete input;
	delete output;
end;
</source>
    </JadeMethod>
</Class>
