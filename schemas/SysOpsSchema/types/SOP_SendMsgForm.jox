<GUIClass name="SOP_SendMsgForm" id="5095a5f5-6aaa-41b7-8457-2f956dd7621f">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <Constant name="TOKEN" id="c38636cc-fb9a-49da-8a0a-d907b77d31ce">
        <source>'&amp;&amp;'</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="multiNames" id="7ee77d09-729a-401f-94d2-65e92b46a658">
        <embedded/>
        <type name="CMUI_MultiSelectGroupBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="objArray" id="e7be2ca7-b06c-4a28-8316-e69c32cf42d9">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="addToolbarControls" id="fa1bc7f4-3503-4bea-b7aa-d021110f533d">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="767f2c9b-4231-4950-ab25-69edf43d0746">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.permissionView		:= PmBkGrndProcessMaint;
	self.permissionMaint	:= PmBkGrndProcessView; // TFS 2101
	
	self.helpFileName := HelpFile_Admin;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDetail" id="5e3ee347-bdb3-49e9-9c84-1ba0fb9ad36a">
        <source>displayDetail(_obj : CM_User) : String;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
begin

	return _obj.code;


end;</source>
        <Parameter name="_obj" type="CM_User"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="e3d389e0-4d09-4624-a9b6-d3d529ed456b">
        <updating/>
        <source>doBaseFormCancel() protected, updating;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.unloadForm;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="14ba613e-b7c5-459f-84a1-c996b0abd7ea">
        <updating/>
        <source>doBaseFormSave() protected, updating;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars

	obj			: Object;
	str			: String;

begin

	// Clear out previous.
	self.objArray.clear();
	// Get selected users.
	self.multiNames.getSelected(self.objArray);	
	// Delimit str to be used by send message functionality.
	foreach obj in self.objArray do
		str := str &amp; TOKEN &amp; obj.CM_User.code;
	endforeach;
	// Nice little hack to set config
	beginTransaction;
		app.myRoot.setConfig(BGPUsersForMsg, str, true);
	commitTransaction;
	self.unloadForm();


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="3207224a-89ec-4eb9-84d8-fdfb1db04b64">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.multiNames.visible then
		self.multiNames.top	:= self.frmToolbar.height;
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="getUsersFromConstant" id="1cba7528-127b-4494-bf86-75c2ba9812bd">
        <source>getUsersFromConstant() protected;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars

	userStr,
	usersStr	: String;
	strArray	: StringArray;
	user		: CM_User;
	pos,
	strLength	: Integer;
	ch			: Character;
begin

	// Clear previous info.
	self.objArray.clear();
	// Get config message string.
	usersStr := app.myRoot.getConfig(BGPUsersForMsg).String;
	if usersStr = null then
		return;
	endif;
	// Pars string into user ids.
	create strArray transient;
	strLength := usersStr.length;
	pos := 1;
	while pos &lt;= strLength do
		strArray.add(usersStr.getDelimitedToken(pos, TOKEN, ch));
	endwhile;
	if strArray.isEmpty then
		return;
	endif;
	// Look up user and add to selected group box.
	foreach userStr in strArray do
		user := app.myRoot.allUsers[userStr];
		if user &lt;&gt; null then
			self.objArray.add(user);
		endif;
	endforeach;
	self.multiNames.setSelected(self.objArray);

epilog
	delete strArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="340d5267-6eb0-4ad5-adb1-1e5e7b5c85b6">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// -------------------------------------------
// Created 26 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	self.setColorsForMultiSelectGrpBox(self.multiNames);


end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bcc1441a-65c6-4e80-a5d1-211ed5cf51db">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars

	users : String;
	
begin
	
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	inheritMethod();
	self.multiNames.formDisplayEntryMethodName := SOP_SendMsgForm::displayDetail.name; 
	self.multiNames.availableHeading := app.getErrorString(Available_Users);
	self.multiNames.selectedHeading := app.getErrorString(Selected_Users);
	self.multiNames.myBaseForm	:= self;
	self.multiNames.mySelectedListBox.sorted := false;
	self.multiNames.displayOrderBtns(true, true);
	self.multiNames.multiSelect	:= ListBox.MultiSelect_Extended;
	// This is a fix to stop cancel button disappearing.
	self.multiNames.setAvailable(app.myRoot.allUsers, true);
	self.getUsersFromConstant();
//	self.multiNames.setSelected(app.myRoot.allBGPSelectedUsers, true);
	self.doResize();

		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
		self.multiNames.readOnly := true;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4113d266-d70a-4cb5-af5e-dde57db40718">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007069, locale);
end;</source>
    </JadeMethod>
</GUIClass>
