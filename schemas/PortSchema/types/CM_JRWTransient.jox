end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteria" id="feed07e2-0cd8-475a-998d-ca17a108346d">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteria(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	04 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	if set then
		return;
	endif;
	
	if self.myOperator &lt;&gt; null then
		str := "Operator:";
	endif;
	
	if self.consignor &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Consignor:";
		else
			str :=              "Consignor:";
		endif;
	endif;
	
	if self.myCarrier &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Carrier:";
		else
			str :=              "Carrier:";
		endif;
	endif;	
	
	
epilog
	_value := str;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteriaValues" id="6a41104c-8a73-4582-a2e4-f37b1808b25a">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteriaValues(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	05 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	if set then
		return;
	endif;
	
	if self.myOperator &lt;&gt; null then
		str := self.myOperator.code ;
	endif;

	if self.consignor &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.consignor;
		else
			str :=              self.consignor;
		endif;
	endif;

	if self.myCarrier &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myCarrier.code;
		else
			str :=              self.myCarrier.code;
		endif;
	endif;

	
epilog
	_value := str;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAllTerminals" id="d41e0af3-c30b-4f86-98b9-14f774f7d782">
        <updating/>
        <source>setAllTerminals(_allTerms : CM_TerminalByCodeDict input) updating;
// -------------------------------------------
// Created 08 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	self.allTerminals.clear();
	_allTerms.copy(self.allTerminals);
	self.setPortLogo();
end;</source>
        <Parameter name="_allTerms" type="CM_TerminalByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPortLogo" id="1be834c3-9910-4651-86fc-b2d8043aaee6">
        <updating/>
        <source>setPortLogo() protected, updating;
// -------------------------------------------
// Created 08 September 2004 by cnwdvb1
//09/02/2016 cnwma1 PAR #36654 Reports run through the web interface missing port logo
// -------------------------------------------
vars

	binary : Binary;

begin
	/*if app.isWebApp then   //09/02/2016 cnwma1 PAR #36654 
		return;
	endif;*/
	
	app.writeLog('Setting Port Logo', LogINFO);
	//if self.allTerminals.size = 0 then
	//	return;
	//elseif self.allTerminals.size = 1 then
	if self.allTerminals.size = 1 then
		binary := self.allTerminals.first.getConfig(PortLogoPic).Binary;
	else
		binary :=  app.myRoot.getConfig(PortLogoPic).Binary;
	endif;
	create self.portLogo transient;
	self.portLogo.picture := binary;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="terminalDescr" id="ca230e1d-9740-4b69-97b2-ac4607551ab3">
        <source>terminalDescr() : String;
// ---------------------------------------------------------------------------
// Created:     22 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	terminal 			: CM_Terminal;
	str					: String;
begin
	//process.debug;
	if self.allTerminals.size = 1 then
		terminal := self.allTerminals.first;
		return terminal.code &amp; ' - ' &amp; terminal.name;
	else
		foreach terminal in self.allTerminals do
			str := str &amp; terminal.code &amp; ', ';
		endforeach;
	endif;
	
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="terminalName" id="2a7d847b-184e-4c6e-9d62-20fa4a176b46">
        <source>terminalName() : String;
// ---------------------------------------------------------------------------
// Created:     22 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	terminal 			: CM_Terminal;
	str					: String;
begin

	if self.allTerminals.size = 1 then
		terminal := self.allTerminals.first;
		return terminal.name;
	else
		foreach terminal in self.allTerminals do
			str := str &amp; terminal.name &amp; ', ';
		endforeach;
	endif;
	
	return str[1:(str.length-2)];

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="thisPort" id="e5defe9a-4505-45f7-a5bf-15ecfa5c5cc9">
        <methodInvocation>mapping</methodInvocation>
        <source>thisPort(set: Boolean; _value: CM_Port io) mapping;
// ---------------------------------------------------------------------------
// Created:     22 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	portCode		:	String;
	terminal		: CM_Terminal;
begin
	if set then
		return;
	endif;
	
	if self.allTerminals.size = 1 then
		terminal := self.allTerminals.first;
		portCode := terminal.getConfig(PortDestCode).String.trimBlanks;
		//_value := app.myRoot.allPorts[portCode];
		_value := app.myRoot.allPorts[portCode];
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Port" usage="io"/>
    </JadeMethod>
</Class>
