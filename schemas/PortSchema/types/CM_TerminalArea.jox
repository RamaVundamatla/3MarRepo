    <JadeMethod name="removeInvalidCharactersFromId" id="8f8621c8-cb69-4662-98aa-941405277d7c">
        <updating/>
        <source>removeInvalidCharactersFromId()updating;
// ---------------------------------------------------------------------------
// Created:     19 October 2009 by cnwcs5:1
// Purpose:     Par 21404 - gate conversion issues  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	old_ID, new_ID,
	str				:String;
	lc				:CM_LocationsController;
	ti				:CM_TrackedItem;
	int				:Integer;
	chr				:Character;
begin
	// temporary code - in first instance we only want to call this method for VTA
	if not self.isKindOf (CM_VehicleTransferArea) then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for unexpected terminal area type');
	endif;
	
	old_ID	:= self.id;
	
	if not old_ID.hasInvalidChars then
		return;	// nothing to do
	endif;
	
	// replace any invalid character with an underScore (_)
	new_ID := old_ID;
	
	foreach int in 1 to String.InvalidCharSet.length do
		chr := String.InvalidCharSet[int];
		
		new_ID.replaceChar (chr, '_');
	endforeach;
	
	// now check for duplicate terminal area id's - just incase they had 'VTA-A' and VTA A' for example
	// we will just keep appending a number till we get a unique value
	str := new_ID;
	int	:= 0;
	
	while self.myTerminal.allTerminalAreas[new_ID] &lt;&gt; null do
		// at least one duplicate terminal area id
		if int &gt; 9999 then
			// it is very unlikely we will get to this point with VTA (in the first instance)
			// review when method used for other terminal area types
			break;
		endif;
		
		int		:= int + 1;
		new_ID 	:= str &amp; int.String;
	endwhile;
	
	if int &gt; 9999 then
		// we are stuffed - write error to the log
		// it is VERY unlikely there would be &gt; 10000 terminal areas
		app.writeLog ('Unable to find unique replacement terminal area id for ' &amp; old_ID, LogINFO);
		return;
	endif;

	// call method that will fixup all associated data
	self.updateId (new_ID);
epilog

end;</source>
    </JadeMethod>
