*/

vars

begin
	self.causeEvent(self.getMyTerminal.getTerminalEvent(Object_Delete_Event), true, self);
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Delete);
	
	inheritMethod(_eraseLevel);

	
	
epilog

end;</source>
