    <JadeMethod name="containsIncompleteRailRelease" id="53a13e1a-f8e6-4c58-8c2c-31d5e744bce3">
        <source>containsIncompleteRailRelease()	:	Boolean;
//Returns TRUE if this job contains a release of a TI that is NOT in a position
//on a wagon (ie, in an RTA). 
//[actually returns TRUE if TI is on RTA.]
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	lc	:	CM_LocationsController;	
	blockStack	:	CM_BlockStack;
	alert	:	CM_SystemAlert;

begin
	foreach wle in workListEntries do
		//----------------
		//We are only interested in releases
		//----------------
		if wle.myRequest.CM_YardRequest.isReceipt = false then

			//PAR 3527 AJA 11/05/00: Add extra protection from 1090 errors
			if wle.myTrackedItem = null then
				return false;
			endif;

			//Where is this TI?
			lc := wle.myTrackedItem.getPrimaryLocation(REAL_MODE);
			if lc = null then
				return false; //must be offsite
			endif;
			
			if lc.isKindOf(CM_BlockController) then
				if lc.getParent.isKindOf(CM_BlockStack) then
					blockStack := lc.getParent.CM_BlockStack;
					if blockStack.type = TA_TYPE_RAIL_TRANS then
						create alert transient;
						alert.details := "Item " &amp; wle.myTrackedItem.id.trimRight &amp; " is located in the " &amp; blockStack.id &amp; " it needs to be on a wagon";
						alert.setSeverity(SEVERE_INFO);
						//-----------
						//Tell alert to add itself to system
						//-----------
						alert.add;
						// DVB this should not stop completion of job !! 2/12/03
						return true;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="containsIncompleteReceipt" id="bbcfacbf-d222-4ae0-b4df-b8173ed7f807">
        <source>containsIncompleteReceipt()	:	Boolean;
//Returns TRUE if this job contains a receipt of a TI that is STILL in a position
//on a wagon
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	lc	:	CM_LocationsController;	
begin
	foreach wle in workListEntries do
		//----------------
		//We are only interested in releases
		//----------------
		if wle.myRequest.CM_YardRequest.isReceipt = true then
			//PAR 3527 AJA 11/05/00: Add extra protection from 1090 errors
			if wle.myTrackedItem = null then
				return false;
			endif;
			//---------------
			//Where is this TI?
			//---------------
			lc := wle.myTrackedItem.getPrimaryLocation(REAL_MODE);
			if lc = null then
				return false; //must be offsite
			endif;
			
			if lc.isKindOf(CM_WagonController) then
				return true;
			endif;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
