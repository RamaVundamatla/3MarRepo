    <JadeMethod name="delete" id="2e2736d8-5d83-42ed-928b-04e943eacd33">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2025	navkc1 JIRA Story MTN-34232: MTN | Prenote Voyage Cut Offs - System Admin

*/

vars

begin
	self.allReceivalCutoffs.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromConfig" id="54c4e187-0267-44a4-8e12-4b157231b7ac">
        <updating/>
        <source>setFromConfig() updating;
/*

Date		Who		Reason
06 March 2017	cnwer1	Initial creation TFS 3581

*/

vars
	opTerm	: CM_OperatorTerminal;
	recCutoffs		: CM_RecCutoffOpTermByDefDict;
	recCutoff		: CM_ReceivalCutoffOpTerm;
	recCutoffTermDef: CM_ReceivalCutoffTermDef;
	hasRecCutoffOpTerm, 
	invalidObj		: Boolean;
	edition 		: Integer;
	recCutoffCmif	: CM_ReceivalCutoffOpTerm;
	recCutOffTermBySortKey : CM_RecCutoffDefsBySortKey; //20/03/2025	navkc1 JIRA Story MTN-34232
	
begin
	if self.myOperator = null  or self.myTerminal = null then
		return;
	endif;
	
	
	opTerm := self.myOperator.allOperatorTerminals[self.myTerminal];
	if opTerm = null then
		return;
	endif;
	
	//20/03/2025	navkc1 JIRA Story MTN-34232
	create recCutOffTermBySortKey transient;
	self.myTerminal.allReceivalCutoffDefs.copy(recCutOffTermBySortKey);
	
	self.weighExports			:= opTerm.getConfig(WeighExports).Boolean;
	self.weighImports			:= opTerm.getConfig(WeighImports).Boolean;
	self.weighMTExports 		:= opTerm.getConfig(WeighMTExports).Boolean;
	self.weighMTImports			:= opTerm.getConfig(WeighMTImports).Boolean;
	//th2 PAR 14641
//	self.freeStorageDays		:=  opTerm.freeStorageDays;
//	self.fullFreeStorageDays	:=  opTerm.fullFreeStorageDays;
//	self.emptyFreeStorageDays	:= opTerm.emptyFreeStorageDays;
			
	// CCMS 1489
	self.weighTranships		:= opTerm.getConfig(WeighTranships).Boolean;
			
	//cnwjo3 ccms 1039 par 22315
	self.restrictCargoBookingEdits := opTerm.getConfig(ETRow_RestrictCargoBookEdits).Boolean;
			
	// 25/05/2009 cnwar2 CCMS1040
	recCutoffs := opTerm.getConfig(AllReceivalRestrictions).CM_RecCutoffOpTermByDefDict;
	
	on Exception do app.handleDeletedObject(exception,recCutoffTermDef,invalidObj);
	
	//20/03/2025	navkc1 JIRA Story MTN-34232 - We want to display all Default Terminal Receival Cutoff. i.e. if the operator doesn't have any of the default receival cutoff, we populate them instead of displaying blank
	foreach recCutoffTermDef in recCutOffTermBySortKey do
		// Reset
		hasRecCutoffOpTerm := false;
		// Go through the Operator receival cutoff
		if recCutoffs &lt;&gt; null then
			foreach recCutoff in recCutoffs do
				invalidObj:=false;
				edition:=recCutoffTermDef.edition;
				
				if invalidObj then
					continue;
				endif;
				
				// We have a operator receival cutoff
				if recCutoff.myReceivalCutoffTermDef = recCutoffTermDef then
					hasRecCutoffOpTerm := true;
					break;
				endif;
			endforeach;
			
			// If we have one, clone it
			if hasRecCutoffOpTerm then
				recCutoffCmif := recCutoff.cloneSelf(true);
				
				recCutoffCmif.setRecCutoffTermDef(recCutoffTermDef);
				self.allReceivalCutoffs.add(recCutoffCmif);
			// If we don't have one, create a proxy
			else
				create recCutoffCmif transient;
				
				recCutoffCmif.setPxyFromTermDef(recCutoffTermDef, opTerm);
				self.allReceivalCutoffs.add(recCutoffCmif);
			endif;
		else
		// We don't have operator receival cutoff, create a proxy
			create recCutoffCmif transient;
			recCutoffCmif.setPxyFromTermDef(recCutoffTermDef, opTerm);
			self.allReceivalCutoffs.add(recCutoffCmif);
		endif;
	endforeach;
	// PAR #28223 "record extra edit info" config options
	self.recordExtraEditInfoExports		:= opTerm.getConfig(RecordExtraEditInfoExports).Boolean;
	self.recordExtraEditInfoImports		:= opTerm.getConfig(RecordExtraEditInfoImports).Boolean;
	self.recordExtraEditInfoStorage		:= opTerm.getConfig(RecordExtraEditInfoStorage).Boolean;
	self.recordExtraEditInfoTranships	:=opTerm.getConfig(RecordExtraEditInfoTranships).Boolean;
	// PAR #28223 end
	
	self.myMTPoolParty := opTerm.getConfig(ETRow_PoolParty).CM_MTPoolingParty;		// TFS 3039
	self.isExternallyMonitored := opTerm.getConfig(ETRow_IsExternallyMonitored).Boolean; //epr TFS 3581 6/3/17
	
epilog
	delete recCutOffTermBySortKey; //20/03/2025	navkc1 JIRA Story MTN-34232
end;</source>
    </JadeMethod>
</Class>
