    <JadeMethod name="getOccursDT" id="c05fbe07-961d-4597-8632-e2b2a4599e24">
        <source>getOccursDT(): TimeStamp;
/*

Purpose:			// TFS 40747 

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlgab1	Initial creation

*/

vars
	occursdt : TimeStamp;
	wod : CM_WorkOrderDtl;
	voyage : CM_Voyage;
begin
	
	wod := self.allWoDtls.first;
	
	if wod &lt;&gt; null then
		occursdt :=  wod.getOccursDT();
	endif;

	if occursdt.isValid() then
		return occursdt;
	endif;
	
	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		return voyage.arrivedDT;
	endif;
	
	return self.createdTime;



epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
