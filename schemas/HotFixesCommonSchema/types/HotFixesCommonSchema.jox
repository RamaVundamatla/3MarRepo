        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="appStartHotFixKarma" id="9987c845-c04d-481b-a7d4-7d98df116495">
        <source>appStartHotFixKarma();

vars

begin

	app.initialiseKarma();
	
	app.myRootHotFix := RootHotFixes.firstInstance();
	app.setApplicationSkinByName('Jmaster2006');
//	app.setApplicationSkinByName('JMTxpx2006');

end;
</source>
    </JadeMethod>
    <JadeMethod name="copyAFile" id="df213feb-184c-4be7-9d51-921153e22682">
        <source>copyAFile(_sourceFileName : String;
		  _sourceIsPresentation : Boolean;
		  _targetFileName : String;
		  _targetIsPresentation : Boolean) : Boolean;

/*

Purpose:			Copy the file named _sourceFileName as a file named _targetFileName, allowing
					for either source and/or target files to use the PresentationClient file system

Parameters:			

Return Value:		True if the copy is successful, false otherwise


Date		Who		Reason
22 Mar 2010	cnwkpd1	Allow for Thin client patch creation

*/

constants
	FileChunkSize	= 100000;
	
vars
	inFile,
	outFile			: File;
	sourceType,
	targetType		: String;
	bin				: Binary;
	
begin
	if _sourceIsPresentation then
		sourceType := "Local";
	else
		sourceType := "App Server";
	endif;
	if _targetIsPresentation then
		targetType := "Local";
	else
		targetType := "App Server";
	endif;
		
	self.writeLogMessage("Copying " &amp; _sourceFileName &amp; " (" &amp; sourceType &amp; ") as " &amp;
						 _targetFileName &amp; " (" &amp; targetType &amp; ")");
						 
	create inFile transient;
	inFile.kind := File.Kind_Binary;
	inFile.usePresentationFileSystem := _sourceIsPresentation;
	inFile.fileName := _sourceFileName;
	
	if not inFile.isAvailable() then
		self.writeLogMessage("Cannot find " &amp; _sourceFileName &amp; " (" &amp; sourceType &amp; ")");
		return false;
	endif;
	
	inFile.openInput(_sourceFileName);
	
	create outFile transient;
	outFile.kind := File.Kind_Binary;
	outFile.usePresentationFileSystem := _targetIsPresentation;
	
	outFile.openOutput(_targetFileName);
	
	while not inFile.endOfFile() do
		bin := inFile.readBinary(FileChunkSize);
		outFile.writeBinary(bin);
	endwhile;
	
	inFile.close();
	outFile.close();
	
	self.writeLogMessage("Copied " &amp; _sourceFileName &amp; " (" &amp; sourceType &amp; ") as " &amp;
						 _targetFileName &amp; " (" &amp; targetType &amp; ")");

	return outFile.isAvailable();
	
	
epilog
	delete inFile;
	delete outFile;
	
end;</source>
        <Parameter name="_sourceFileName" type="String"/>
        <Parameter name="_sourceIsPresentation" type="Boolean"/>
        <Parameter name="_targetFileName" type="String"/>
        <Parameter name="_targetIsPresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyAFolder" id="a1b6d57d-0980-40e1-b135-b19b4059fea8">
        <source>copyAFolder(_sourceFolderName : String;
		  _sourceIsPresentation : Boolean;
		  _targetFolderName : String;
		  _targetIsPresentation : Boolean) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwdw1	Initial creation
*/
vars
	agent: DEV_ReleaseExtractAgent;
begin
	create agent transient;
	
	return agent.copyDirectory(_sourceFolderName, _sourceIsPresentation, _targetFolderName, _targetIsPresentation, null);
	
epilog
	delete agent;
end;</source>
        <Parameter name="_sourceFolderName" type="String"/>
        <Parameter name="_sourceIsPresentation" type="Boolean"/>
        <Parameter name="_targetFolderName" type="String"/>
        <Parameter name="_targetIsPresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteAFile" id="f42f046f-d491-4c8b-8cf5-ce770625d182">
        <source>deleteAFile(_fileName : String;
			_usePresenation : Boolean) : Boolean;

/*

Purpose:			Delete the file passed in, either locally or on the App Server

Parameters:			File name, whether it is local or not

Return Value:		None


Date		Who		Reason
23 Mar 2010	cnwkpd1	Allow for Thin client patch creation


*/

vars
	file			: File;
	type			: String;
	returnValue		: Boolean;
	
begin
	if _usePresenation then
		type := "Local";
	else
		type := "App Server";
	endif;
	
	self.writeLogMessage("Deleting " &amp; _fileName &amp; " (" &amp; type &amp; ")");
	
	create file transient;
	file.fileName := _fileName;
	file.usePresentationFileSystem := _usePresenation;
	
	if file.isAvailable() then
		file.purge();
		if file.isAvailable() then
			self.writeLogMessage("Delete of " &amp; _fileName &amp; " (" &amp; type &amp; ") failed, please remove manually");
		else
			self.writeLogMessage("File " &amp; _fileName &amp; " (" &amp; type &amp; ") deleted");
			returnValue := true;
		endif;
	else
		self.writeLogMessage("File " &amp; _fileName &amp; " (" &amp; type &amp; ") not found, could not delete");
	endif;
	
	return returnValue;

	
epilog
	delete file;
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresenation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteAFolder" id="62eb9ed3-3905-4c25-9eab-837027d40d4d">
        <source>deleteAFolder(_folderName : String; _isPresentation : Boolean) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwdw1	Initial creation
*/
vars
	agent: DEV_ReleaseExtractAgent;
begin
	create agent transient;
	
	return agent.clearDirectory(_folderName, _isPresentation, true);
	
epilog
	delete agent;
end;</source>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_isPresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fileExists" id="58e4887f-35c2-4359-b87f-82fd3e21ed78">
        <source>fileExists(_fileName: String; _usePresentation: Boolean) : Boolean;
/*
Purpose: Does the file exist?			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwdw1	Initial creation
*/
vars
	file			: File;
	
begin
	create file transient;
	file.fileName := _fileName;
	file.usePresentationFileSystem := _usePresentation;
	return file.isAvailable;

epilog
	delete file;
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="folderExists" id="fad777f0-a50a-47f0-b09b-7c130647e798">
        <source>folderExists(_folderName: String; _usePresentation: Boolean) : Boolean;
/*
Purpose: Does the folder exist?			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwdw1	Initial creation
*/
vars
	folder: FileFolder;
	
begin
	create folder transient;
	folder.fileName := _folderName;
	folder.usePresentationFileSystem := _usePresentation;
	return folder.isAvailable;

epilog
	delete folder;
end;</source>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_usePresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getUserCode" id="8cfa95d8-3b32-42ef-be08-4ca9505dd729">
        <source>getUserCode() : String;
// created by cnwvu1 on 13/02/2007
vars
	iPos	: Integer;
	uCode	: String;
begin

	uCode := process.userCode;
	iPos := uCode.pos( '_', 1 );
	if iPos &gt; 0 then
		return uCode[1:iPos-1];
	else
		return uCode;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseKarma" id="1f1413e4-2243-4eaa-adaa-60d9d6628336">
        <updating/>
        <source>initialiseKarma() updating;

vars

begin

	if app.myCnCntrl = null then
		self.cnActivateKarmaControl(Cn_JADE_Thin_Client, null, null /*'143.96.130.37', 'cnwvu1a'*/);
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="pathExists" id="56f29895-d0f1-472a-a3bf-11e4656b8789">
        <source>pathExists(_pathName: String; _usePresentation: Boolean) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
*/
vars

begin
	if self.fileExists(_pathName, _usePresentation) then
		return true;
	endif;

	if self.folderExists(_pathName, _usePresentation) then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_pathName" type="String"/>
        <Parameter name="_usePresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="raiseHotFixException" id="e7a51c81-0419-4e3f-8d89-2257d55c726c">
        <updating/>
        <source>raiseHotFixException(errNo : Integer;
				  pAttrNameString : String; pGuiObject : Object) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 07 December 2006
//
//----------------------------------------------------------------------

vars
	exObj	: HF_Exception;

begin

	create exObj transient;
	exObj.set(errNo, self.getErrorString(errNo), false, pAttrNameString, pGuiObject);
	
	raise exObj;

end;</source>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="writeLogMessage" id="16825ff9-3431-4037-abea-6bc8a3cbcf4e">
        <source>writeLogMessage(_msg : String);

/*

Purpose:			Write the passed in message to the application log and the interpreter 

Parameters:			message to be written

Return Value:		None


Date		Who		Reason
22 Mar 2010	cnwkpd1	Enable Patch creation from a thin client

*/

vars
	
begin
	if self.myCnCntrl &lt;&gt; null then 
		self.myCnCntrl.cnWriteLog(CnCntrl.CnLogComment, _msg, null);
	endif;

	if self.myCnCntrl = null or not self.myCnCntrl.logToScreen then
		write Space &amp; _msg;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
</Class>
