    <JadeMethod name="load" id="28145b5e-7f18-4038-a25c-f18c8a51aacf">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// self.isModal := true;
	inheritMethod();
	//epr par 26986 default to cancel when form closes
	self.modalResult := IDCANCEL;
	self.centreWindow;
	self.resize();	
end;</source>
    </JadeMethod>
