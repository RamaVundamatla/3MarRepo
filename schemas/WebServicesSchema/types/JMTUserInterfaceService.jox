    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReportsForReportHeaderReq" id="89091445-1176-42f8-81bd-784e671a12a9">
        <usesRPC>default</usesRPC>
        <source>getReportsForReportHeaderReq(reportsReq : WS_ReportsRequest) : WS_ReportsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Sep 2008	cnwkao1	Initial creation
09 Mar 2009	cnwkpd1	PAR #19048 - Allow for reports that are not under a group heading
26 Mar 2009	cnwkpd1	PAR #19263 - Prevent 1035 exceptions for very long Terminal names

*/

vars
	userTerminal	: CM_UserTerminal;
	response		: WS_ReportsResponse;
	theMenuEntity,
	menuEntity		: CM_MenuEntity;
	menuHdr			: CM_MenuUserHdr;
	theMenuHdr		: CM_MenuUserHdr;
	menuEntities	: CM_MenuEntitySet;
	pxyReport		: WS_Report;
	completedOK		: Boolean;
	userItem		: CM_MenuUserItem;
	terminal		: CM_Terminal;
	terminalHeader	: String;
	topLevelOnly	: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.getMyTerminalDO_NOT_USE();
	userTerminal := app.getMyUser().getUserTerminal(terminal);
	
	if userTerminal = null then
		app.raiseCMException1(Repor_menu_root_objec_been_fou, 
							  app.getMyUser().userName,
							  null, 
							  null);
		completedOK := true;
		return response;
	endif;
	
	create menuEntities transient;
	
	// Terminal header name means all reports at the highest level only
	terminalHeader := app.getTerminalReportHeading();		// PAR #19263
	if reportsReq.headerName = terminalHeader then
	
		menuEntities.add(userTerminal.myReportMenuRoot);
		topLevelOnly := true;
	
	else
	
		foreach menuEntity in userTerminal.myReportMenuRoot.allChildren do //only those reports accessible to the current user
			if menuEntity.isKindOf(CM_MenuUserHdr) then
				menuHdr := menuEntity.CM_MenuUserHdr;
				if menuHdr.heading = reportsReq.headerName then
					theMenuHdr := menuHdr;
					break;
				endif;			
			endif;
		endforeach;
	
		if theMenuHdr = null then
			app.raiseCMException1(Repor_menu_heade_objec_been_fo,reportsReq.headerName,
								  null, 
								  null);
			completedOK := true;
			return response;
		endif;
		
		menuEntities.add(theMenuHdr);
	endif;
	
	// Only allowing one level of grouping - collate the reports
	while not menuEntities.isEmpty() do
		theMenuEntity := menuEntities.first();
		foreach menuEntity in theMenuEntity.allChildren discreteLock do
			if not menuEntity.isKindOf(CM_MenuUserItem) then
				continue;
			endif;
			userItem := menuEntity.CM_MenuUserItem;
			if userItem.myMenuItem.isKindOf(CM_QryReport) and
			 (userItem.myMenuItem.CM_QryReport.reportAvailability = CM_QryReport.ReportAvailability_WebAndJMT or
			  userItem.myMenuItem.CM_QryReport.reportAvailability = CM_QryReport.ReportAvailability_Web) then
				create pxyReport transient;
				pxyReport.setProxyFromObject(userItem.myMenuItem.CM_QryReport);
				response.allReports.add(pxyReport);
			
			elseif not topLevelOnly and userItem.isKindOf(CM_MenuUserHdr) then
				menuEntities.add(userItem.CM_MenuUserHdr);				
			else
				//not interested in anything else
			endif;		
		endforeach;
		
		menuEntities.remove(theMenuEntity);		
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
	
epilog
	delete menuEntities;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
		
end;</source>
        <wsdlName>getReportsForReportHeaderReq</wsdlName>
        <Parameter name="reportsReq" type="WS_ReportsRequest"/>
        <ReturnType type="WS_ReportsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getResourceTypesForTask" id="be8b95e3-7563-46a0-b11d-529042f6c2d6">
        <source>getResourceTypesForTask(_taskCode : Integer) : WS_ResourceTypesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2016	cnwmc5	Initial creation

*/

vars

	response		: WS_ResourceTypesResponse;
	completedOK		: Boolean;
	
	toDoTask		: CM_ToDoTaskDesc;
	obj				: CM_Object;
	resource		: CM_ResourceType;
	wsResource		: WS_ResourceType;
	
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmTaskResourceView);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	toDoTask := app.myRoot.allToDoTaskDescriptions[_taskCode];
	
	if toDoTask = null then
		app.raiseCMException(ERR_INVALID_TODOTASKDESCR,null,null);
		completedOK := true;
		return response;
	endif;
	
	foreach obj in toDoTask.allResourceTypes do
		if obj.isKindOf(CM_ResourceType) then
			resource := obj.CM_ResourceType;
			if not resource.isAvailable then
				continue;
			endif;
			
			create wsResource transient;
			wsResource.setProxyFromObject(resource);
			response.allResourceTypes.add(wsResource);
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_taskCode" type="Integer"/>
        <ReturnType type="WS_ResourceTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRoroCountDetails" id="276aac4a-5aea-4dfa-ac18-f6e8f6c9fa62">
        <source>getRoroCountDetails(request : WS_RoroCountRequest): WS_RoroCountResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
01 Aug 2017		jlgam15		Polling webservice to know the area/sub area count of items scanned
31 Aug 2017		jlghl1		TFS 6771
08 Jan 2026 	navma1 		MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	completedOK : Boolean;
	response : WS_RoroCountResponse;
	terminal : CM_Terminal;
	terminalArea : CM_TerminalArea;
	voyage : CM_Voyage;
	genCargoArea : CM_IrregularBlockArea;
	roroArea : CM_RoRoLaneArea;
	roroLane : CM_RoRoController;
	locController : CM_LocationsController;
	shelf : CM_RackShelfController;
	shelfIter : Iterator;
	iter : Iterator;
	cargoIter : Iterator;
	ti : CM_TrackedItem;
	onShipCount : Integer;
	transhipCount, importsCount : Integer;
	areaScannedCount : Integer;
	subAreaScannedCount : Integer;
	voyageId : String;
	failedDAC 	: CM_DataAccessController;
	lc : CM_LocationsController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmHHRoRoLandConf);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	voyageId := request.voyageCode.trimBlanks.toUpper;
	
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	terminal := app.myPassport.myTerminal;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;	
	endif;

	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	if voyage &lt;&gt; null then
		
		iter := voyage.allImportTIs.createIterator;
	
		while iter.next(ti) do
			if ti.isCar() then
	
				if ti.isOnSite and ti.myVoyage.code = voyage.code then
					importsCount := importsCount + 1;				
				endif;
				
				lc := ti.myPrimaryActualLocation;		//08.01.2026 navma1 #MTN-36897
				if (ti.isOnSite and ti.myVoyage.code &lt;&gt; voyage.code) or (lc.isKindOf(CM_VoyageController) and  lc.CM_VoyageController.myVoyage &lt;&gt; voyage) then		//08.01.2026 navma1 #MTN-36897
					transhipCount := transhipCount + 1;
				endif;
				
				if lc.isKindOf(CM_VoyageController) and lc.CM_VoyageController.myVoyage = voyage then		//08.01.2026 navma1 #MTN-36897
					onShipCount := onShipCount + 1;
				endif;
					
			endif;
		endwhile;
		delete iter;

		response.totalOnShip := onShipCount;
		response.totalOnSite := importsCount + transhipCount;
	endif;

	terminalArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[request.terminalAreaTypeId, request.areaId];
		
	if terminalArea &lt;&gt; null then 
			
		if request.terminalAreaTypeId = TA_TYPE_RORO_LANE_AREA then
		
			if request.areaId &lt;&gt; null or request.areaId &lt;&gt; "" then
				roroArea := terminalArea.CM_RoRoLaneArea;				
				
				//get all lane number tracked items
				foreach roroLane in roroArea.allLanesByLaneNumber do
					foreach ti in roroLane.allTrackedItems do
						if not ti.isCar then
							continue;
						endif;
						
						if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then
							areaScannedCount := areaScannedCount + 1;					
						endif;
					endforeach;
				endforeach;
				
				// sent as string, only can be 0 if no roro lane selected
				if request.subAreaId &lt;&gt; "0" then 
					roroLane := roroArea.allLanesByLaneNumber[request.subAreaId.Integer];					
					//get the specified lane number tracked item
					if roroLane &lt;&gt; null then						//08.01.2026 navma1 #MTN-36897
						foreach ti in roroLane.allTrackedItems do
							if not ti.isCar then
								continue;
							endif;
							
							if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then	
								subAreaScannedCount := subAreaScannedCount + 1;					
							endif;
						endforeach;
					endif;
				endif;
			endif;
			
			response.totalScannedSubArea := subAreaScannedCount;
			response.totalScannedArea := areaScannedCount;
			
		elseif terminalArea.type = TA_TYPE_BLOCK_STACK then
			locController := terminalArea.CM_BlockStack.getLocationsController();			
			iter := locController.allTrackedItems.createIterator();
			while iter.next(ti) do
				if not ti.isCar then
					continue;
				endif;
				
				if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then	
					areaScannedCount := areaScannedCount + 1;					
				endif;
			endwhile;
			delete iter;
			
			response.totalScannedArea := areaScannedCount;
		else
			genCargoArea := terminalArea.CM_IrregularBlockArea;
			iter := genCargoArea.allLocationsControllers.createIterator();
			
			while iter.next(locController)do					
				if locController.isRack then 
					foreach shelf in locController.CM_IrregularBlockController.allSubLocations do					
						shelfIter := shelf.allTrackedItemsById.createIterator();
						while shelfIter.next(ti) do
							if not ti.isCar then
								continue;
							endif;
							
							if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then		
								areaScannedCount := areaScannedCount + 1;
							endif;
						endwhile;
						delete shelfIter;
					endforeach;			
				else
					cargoIter := locController.allTrackedItemsById.createIterator();			
					while cargoIter.next(ti) do
						if not ti.isCar then
							continue;
						endif;
						
						if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then		
							areaScannedCount := areaScannedCount + 1;
						endif;
					endwhile;
					delete cargoIter;
				endif;
				
				
			endwhile;
			delete iter;
			
			//bay count
			genCargoArea.findLocationFromString(request.subAreaId,locController);
			if locController &lt;&gt; null then 
				iter := locController.allTrackedItems.createIterator();
				while iter.next(ti) do
					if not ti.isCar then
						continue;
					endif;
					
					if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then
						subAreaScannedCount := subAreaScannedCount + 1;
					endif;
				endwhile;
				delete iter;
			endif;
			
			response.totalScannedSubArea := subAreaScannedCount;
			response.totalScannedArea := areaScannedCount;
		endif;
	endif;
		
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RoroCountRequest"/>
        <ReturnType type="WS_RoroCountResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRoroVehicleDetailsFromId" id="1e619168-a856-40e5-ae8e-88b1b24cb7af">
        <source>getRoroVehicleDetailsFromId(request : WS_RoroVehicleDetailsRequest) : WS_RoroVehicleDetailsResponse webService;
/*

Purpose:			
	to check the validity of an ID field, then return a condensed set of details about a specific RORO tracked item
Parameters:			
	
Return Value:		

Date		Who		Reason
28 July 2017	jlghl1	Initial creation
31 Aug 2017		jlghl1	TFS 6771

*/

vars
	response : WS_RoroVehicleDetailsResponse;
	completedOK 	: Boolean;
	terminal : CM_Terminal;
	cargoId, cargoIdReversed : String;
	cargoIdLength : Integer;
	voyage : CM_Voyage;
	obj : Object;
	firstTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	proxyTi : WS_RoroVehicleDetails;
	tiArray : CM_TIArray;
	cmif : CMIF_IDConversion;
	processedText : String;
	errorMsg : WS_ErrorMessage;
	failedDAC 	: CM_DataAccessController;
	localAltIdDict : CM_TIByAlternativeID;
	rawUserStr : String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmHHRoRoLandConf);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.vehicleId.trimBlanks = "" then
		completedOK := true;
		return response;	
	endif;
	
	cargoId := request.vehicleId.trimBlanks.toUpper;
	
	terminal := app.myPassport.myTerminal;
	
	// find voyage
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(request.voyageCode,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(request.voyageCode, null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; request.voyageCode then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	
	// find cargo by id
	cargoIdLength := cargoId.length;
	cargoIdReversed := cargoId.reverse;
	create tiArray transient;
	
	// SEARCH ON SHIP
	//Exact match only for whole id
	firstTi := voyage.allOnshipTIsByIdCargoType.getAtKey(cargoId,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
		iter := voyage.allOnshipTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
				break;
			endif;
			if ti.id &lt;&gt; cargoId then
				//to select, must be an exact match
				continue;
			endif;
			tiArray.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
	//10 Aug 2016	NDL Allow for partial searches matching on the last 'n' chars TFS 2511
	//Try reverse 'cargoId' as any piece of the id
	if tiArray.isEmpty then
		firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
		
	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	//Still nothing try an exact match on the alternate id
	if tiArray.isEmpty then
		create localAltIdDict transient;
		voyage.allOnshipTIsByIdCargoType.copy( localAltIdDict );
		firstTi := localAltIdDict.getAtKey(cargoId);
		if firstTi &lt;&gt; null and firstTi.alternativeId = cargoId then	
			iter := localAltIdDict.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;	
	
	
	// NOTHING ON SHIP, TRY ON SITE
	
	if tiArray.isEmpty then
		firstTi := terminal.allOnsiteTIsByIdCargoType.getAtKey(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
			iter := terminal.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if ti.id &lt;&gt; cargoId then
					//to select, must be an exact match
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	//10 Aug 2016	NDL Allow for partial searches matching on the last 'n' chars TFS 2511
	//Try reverse 'cargoId' as any piece of the id
	if tiArray.isEmpty then
		firstTi := terminal.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := terminal.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	//Still nothing try an exact match on the alternate id
	if tiArray.isEmpty then
		firstTi := terminal.allOnsiteTIsByAlternativeId.getAtKey(cargoId);
		if firstTi &lt;&gt; null and firstTi.alternativeId = cargoId then	
			iter := terminal.allOnsiteTIsByAlternativeId.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	// STILL NOTHING, TRY HOOK CODE
	rawUserStr := cargoId;	
	//epr TFS 7956 22/11/17 make sure tiArray still empty
	if tiArray.isEmpty  and cargoIdLength &gt;= 6 then
	
		cargoIdReversed := rawUserStr.reverse[1:6].trimBlanks; // first 6 chars of the reversed scanned value
		cargoIdLength := cargoIdReversed.length; // Not necessarily 6, because we might have trimmed a space
												// that was previously embedded but was on the end after
												// the truncation
		firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;		
	endif;
	
	if tiArray.isEmpty then
		//Still nothing
	
		create cmif transient;
		cmif.myTerminal := terminal;
		cmif.myVoyage := voyage;
		cmif.scannedValue := rawUserStr;
		cmif.isAlternateId := false;
		cmif.callerName := self.class.name;
	
		processedText := app.convertScannedCargoId( null,  null, false, cmif );
		
		if processedText &lt;&gt; rawUserStr then	// because no point in trying it if its not different
		
			//OK we have something that has potentially had some suffix crap taken off the end
			cargoId := processedText;
			cargoIdLength := cargoId.length;	
			cargoIdReversed := cargoId.reverse;
			//try an exact match against the hook code processed text.
			if voyage &lt;&gt; null then
				firstTi := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
				if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
					iter := voyage.allOnshipTIsByIdCargoType.createIterator;
					iter.startAtObject(firstTi);
					while iter.next( ti ) do
						if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
							break;
						endif;
						tiArray.addExclusive(ti);
					endwhile;
					delete iter;
				endif;
			
				//Try a reverse id match against the hook code processed text.
				if tiArray.isEmpty then
					firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
					if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
						iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
						iter.startAtObject(firstTi);
						while iter.next( ti ) do
							if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
								break;
							endif;
							tiArray.addExclusive(ti);
						endwhile;
						delete iter;
					endif;
					
				endif;
			
			else	// No voyage selected
				firstTi := terminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
				if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
					iter := terminal.allOnsiteTIsByIdCargoType.createIterator;
					iter.startAtObject(firstTi);
					while iter.next( ti ) do
						if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
							break;
						endif;
						tiArray.addExclusive(ti);
					endwhile;
					delete iter;
				endif;
			endif;			
		endif;	
	endif;	
	
		
	if tiArray.size = 1 then
	
		create proxyTi transient;
		proxyTi.setProxyFromObject(tiArray.first);
		response.myVehicleDetails := proxyTi;	
				
	elseif tiArray.size &gt; 1 then
		
		create errorMsg transient;
		errorMsg.errorCode := UniqueIdRequired;
		errorMsg.text := app.getErrorString1(UniqueIdRequired, cargoId);
		response.allErrors.add(errorMsg);
		
	else
		
		create errorMsg transient;
		
		if voyage &lt;&gt; null then
			errorMsg.errorCode := Cargo_item_not_found_voyag_sit;
			errorMsg.text := app.getErrorString2(Cargo_item_not_found_voyag_sit, cargoId, voyage.code);
		else
			errorMsg.errorCode := Cargo_item_not_found_site;
			errorMsg.text := app.getErrorString1(Cargo_item_not_found_site, cargoId.trimBlanks);
		endif;
		
		errorMsg.errorCode := Cargo_item_not_found_site;
		errorMsg.text := app.getErrorString1(Cargo_item_not_found, cargoId);
		response.allErrors.add(errorMsg);
		
	endif;	
	
	
	
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	// ...
	delete tiArray;
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RoroVehicleDetailsRequest"/>
        <ReturnType type="WS_RoroVehicleDetailsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRoroVoyageDetailsByCode" id="9372e063-9745-4d9b-a666-e0e799a4e675">
        <source>getRoroVoyageDetailsByCode(request : WS_VoyageDefinitionRequest) : WS_VoyageDetailsResponse webService;
/*

Purpose:			
	return a set of condensed details about a voyage that can be worked for RORO
Parameters:			

Return Value:		

Date		Who		Reason
27 July 2017	jlghl1	Initial creation

*/

vars
	response : WS_VoyageDetailsResponse;
	completedOK 	: Boolean;
	proxyVoyage		: WS_VoyageDetails;
	voyageId : String;
	obj : Object;
	voyage : CM_Voyage;
	terminal : CM_Terminal;
	failedDAC 	: CM_DataAccessController;	
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmHHRoRoLandConf);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	voyageId := request.voyageCode;
	
	if voyageId.trimBlanks = "" then
		completedOK := true;
		return response;
	
	endif;	
		
	// ### BY OID
		//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;

	if voyage = null then
		completedOK := true;
		return response;

	endif;
	
	if voyage &lt;&gt; null then
		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(voyage);
		response.myVoyageDetails := proxyVoyage;
	endif;
	
	completedOK := true;
	return response;
epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_VoyageDefinitionRequest"/>
        <ReturnType type="WS_VoyageDetailsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRowControllersForTermArea" id="12869547-92dd-49cd-9d0c-6866f75cfaa3">
        <usesRPC>default</usesRPC>
        <source>getRowControllersForTermArea(terminalAreaId : String) : WS_RowControllerResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars
	response	: WS_RowControllerResponse;
	obj			: Object;
	rowArea		: CM_RowArea;	
	rowCont		: CM_RowController;
	pxyRowCont	: WS_RowController;
	user		: CM_User;
	failedDAC	: CM_DataAccessController;
	completedOK	: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	user := app.myPassport.myUser;
	//epr TFS 5535 4/8/17
	rowArea := app.myPassport.getObjectOfTypeFromOid(terminalAreaId,CM_RowArea).CM_RowArea;
	
	if rowArea &lt;&gt; null then
		foreach rowCont in rowArea.allRowControllersById do
			if not rowCont.canUserAccessSelf(user, failedDAC, app.myPassport) then
				continue;
			endif;
			create pxyRowCont transient;
			pxyRowCont.setProxyFromObject(rowCont);
			response.allRowControllers.add(pxyRowCont);			
		endforeach;
	endif;
	
		// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getRowControllersForTermArea</wsdlName>
        <Parameter name="terminalAreaId" type="String"/>
        <ReturnType type="WS_RowControllerResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getSAPStatuses" id="14b3b58d-93e6-42ad-8561-a6c840ea9efc">
        <source>getSAPStatuses() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 10/2/2020	jlger1		8.6.2 pushed differences to dmast
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	wsCode : WS_Code;

begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	create wsCode transient;
	wsCode.setProxyDetails(null, app.getErrorString(SAP_Hold), app.getErrorString(SAP_Hold));
	wsCode.setOidDetailsForNonObject("1");
	response.allCodes.add(wsCode);
	create wsCode transient;
	wsCode.setProxyDetails(null,  app.getErrorString(Debit), app.getErrorString(Debit));
	wsCode.setOidDetailsForNonObject("2");
	response.allCodes.add(wsCode);
	create wsCode transient;
	wsCode.setProxyDetails(null,  app.getErrorString(Cancelled), app.getErrorString(Cancelled));
	wsCode.setOidDetailsForNonObject("3");
	response.allCodes.add(wsCode);
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getSAPTransactionTypes" id="16ed05c5-8807-4fcf-aae1-ef3549611a88">
        <source>getSAPTransactionTypes() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars
	response : WS_CodeResponse;
