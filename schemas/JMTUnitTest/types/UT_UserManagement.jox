    <JadeMethod name="toggleRowsReadOnly" id="ef65b212-556e-41b0-a269-d74b5d8d6c3c">
        <updating/>
        <source>toggleRowsReadOnly(_isReadOnly : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation

*/

vars
	row 	: Integer;
	
	cell 	: JadeTableCell;
	
begin
	foreach row in 2 to self.tblUserData.rows do
		self.tblUserData.accessRow(row).enabled := (not _isReadOnly);
		self.tblUserData.selected := null;
		
		if not self.isNew then
			self.tblUserData.accessCell(row, 2).enabled := false;
		endif;
		
		if self.tblUserData.accessCell(row, 1).text.Integer.Boolean and not _isReadOnly then
			cell := self.tblUserData.accessCell(row, 4);
			cell.enabled := true;
			cell := self.tblUserData.accessCell(row, 5);
			cell.enabled := true;
			cell := self.tblUserData.accessCell(row, 6);
			cell.enabled := true;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_isReadOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="txtUser_gotFocus" id="dcfa2119-5130-4b31-8a43-1ad0e97d9512">
