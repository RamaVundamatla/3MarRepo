    <JadeMethod name="doResize" id="e9243fac-1aef-458f-a859-808bedcdafcb">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.txtNarr.top := self.tblEntNarr.height + 1;
	self.txtNarr.height := self.shtEntDetail.height - (self.tblEntNarr.height + 5);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f2f54f2d-a954-45c9-ae90-f3e8cdcac88c">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	
// Date			Changed By		Reason
// 15/06/2023	navcs2			ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration
// ---------------------------------------------------------------------------

vars
	pxyInvoiceDesc		: CM_InvoiceDesc;
	rtnValue	, isStorage, print1LineDay		: Boolean;
	errObj				: CM_Error;
	navObject			: CMUI_NavigatorObject;
	colour,
	id					: Integer;
	table				: CM_EntryTable;
	arrNarrationDesc : HugeStringArray;
	isAllowManEditExtRef, //08/12/2025	navkc1 JIRA 36262
	notAvailable,
	isApiInvType,
	isApiCnType		: Boolean;
	invoiceType : Integer;
	triggerOnAction	: Integer;
	theReturn : Integer;
	realInvoiceDesc,
	loopInvoice		: CM_InvoiceDesc;
	expectedEdition	: Integer;
	invGenerationDateFrom,
	invGenerationDateTo	: Date;
	invGenerationStatus	: Integer;
	externalReference : String;
begin


	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyInvoiceDesc transient;
	elseif self.mode = Mode_Update then
		pxyInvoiceDesc := self.myProxyObject.CM_InvoiceDesc;
	else
		return false;
	endif;
	
	arrNarrationDesc := self.getNarration();
	isStorage := self.tblEntDetail.getValueByName(ETRow_IsStorageInvoiceChk).Boolean;
	if isStorage then
		invoiceType := InvoiceTypeStorage;
	else
		invoiceType := InvoiceTypeGeneral;
	endif;
	
	print1LineDay := self.tblEntDetail.getValueByName(ETRow_Print1LineDayChk).Boolean;
	notAvailable := self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean;
	isApiInvType := self.tblEntDetail.getValueByName(ETRow_IsApiInvType).Boolean;					// 15.06.2023	navcs2	#58434:[58452]
	isApiCnType  := self.tblEntDetail.getValueByName(ETRow_IsApiCreditNote).Boolean;				// 15.06.2023	navcs2	#58434:[58452]
	isAllowManEditExtRef := self.tblEntDetail.getValueByName(ETRow_AllowManEditExtRefChk).Boolean; 	//08/12/2025	navkc1 JIRA 36262
	
	if self.cmbTriggerAction.listIndex &gt; 0 then
		triggerOnAction := self.cmbTriggerAction.itemData[self.cmbTriggerAction.listIndex];
	else
		triggerOnAction := null;
	endif;
	
	externalReference := self.tblEntDetail.getValueByName(ETRow_ExternalReference).String;  //ccms 1970 par 25387
	
	if self.mode = Mode_Update then
		pxyInvoiceDesc.pxyGetRealObjectAndEdition(realInvoiceDesc, expectedEdition);
		invGenerationDateFrom	:= realInvoiceDesc.invoiceGenerationDateFrom;
		invGenerationDateTo		:= realInvoiceDesc.invoiceGenerationDateTo;
		invGenerationStatus		:= realInvoiceDesc.invoiceGenerationStatus;
	endif;
	
	pxyInvoiceDesc.setProxy(self.cmbAccuralType.itemData[self.cmbAccuralType.listIndex],
							arrNarrationDesc,
							self.tblEntDetail.getValueByName(ETRow_Description30).String, // PAR 21146
							self.cmbSepInvoices.itemData[self.cmbSepInvoices.listIndex],
							invoiceType,
							self.cmbAccuralType.listObject.CM_FinancialPeriodEnd, // _myFinancialPeriodEnd
							self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade,
							print1LineDay, 
							triggerOnAction,
							invGenerationDateFrom,
							invGenerationDateTo,
							invGenerationStatus,
							externalReference,
							notAvailable,
							isApiInvType,
							isApiCnType,
							isAllowManEditExtRef //08/12/2025	navkc1 JIRA 36262
							);
	pxyInvoiceDesc.setCompany(self.myCurrentBank);		// 35872 set from local business unit
							
	while true do
 
	 	if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceDesc(pxyInvoiceDesc,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceDesc(pxyInvoiceDesc, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvoiceDesc;
	endif;
	delete arrNarrationDesc;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNarration" id="d94292e1-5885-42fa-926b-9924c76a8acb">
        <source>getNarration() : HugeStringArray;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	FIELD = "___field = ";
vars
	theTable : CM_EntryTable;
	theNarr : HugeStringArray;
begin
	theTable := self.tblEntNarr;
	create theNarr transient;
	
	theNarr.add(theTable.getValueByName(ETRow_FreeText1).String);
	theNarr.add(FIELD &amp; self.cmbField1.itemData[self.cmbField1.listIndex].String);
	
	theNarr.add(theTable.getValueByName(ETRow_FreeText2).String);
	theNarr.add(FIELD &amp; self.cmbField2.itemData[self.cmbField2.listIndex].String);
	
	theNarr.add(theTable.getValueByName(ETRow_FreeText3).String);
	theNarr.add(FIELD &amp; self.cmbField3.itemData[self.cmbField3.listIndex].String);
	
	theNarr.add(theTable.getValueByName(ETRow_FreeText4).String);
	theNarr.add(FIELD &amp; self.cmbField4.itemData[self.cmbField4.listIndex].String);
	
	theNarr.add(theTable.getValueByName(ETRow_FreeText5).String);
	theNarr.add(FIELD &amp; self.cmbField5.itemData[self.cmbField5.listIndex].String);
	
	return theNarr;
	
end;</source>
        <ReturnType type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="getNarrationEx" id="4ece739a-901a-42d8-bd53-68a26ee1f9c9">
        <source>getNarrationEx() : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	FIELD = "___field = ";
vars
	theTable : CM_EntryTable;
	theNarr : String;
begin
	theTable := self.tblEntNarr;
	
	theNarr := theNarr &amp; theTable.getValueByName(ETRow_FreeText1).String;
	theNarr := theNarr &amp; self.getNarrationExample(self.cmbField1.itemData[self.cmbField1.listIndex]);
	
	theNarr := theNarr &amp; theTable.getValueByName(ETRow_FreeText2).String;
	theNarr := theNarr &amp; self.getNarrationExample(self.cmbField2.itemData[self.cmbField2.listIndex]);
	
	theNarr := theNarr &amp; theTable.getValueByName(ETRow_FreeText3).String;
	theNarr := theNarr &amp; self.getNarrationExample(self.cmbField3.itemData[self.cmbField3.listIndex]);
	
	theNarr := theNarr &amp; theTable.getValueByName(ETRow_FreeText4).String;
	theNarr := theNarr &amp; self.getNarrationExample(self.cmbField4.itemData[self.cmbField4.listIndex]);
	
	theNarr := theNarr &amp; theTable.getValueByName(ETRow_FreeText5).String;
	theNarr := theNarr &amp; self.getNarrationExample(self.cmbField5.itemData[self.cmbField5.listIndex]);
	
	return theNarr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNarrationExample" id="18bceb1f-0cab-4bdd-9d0f-06460d0f5147">
        <source>getNarrationExample(fieldNo : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/01/2013	cnwdap1		PAR #30860 CCMS QNS 2236 New narrative types
constants
	None            = "";
	Debtor_Name     = "CAR";
	Voyage_Code     = "3822SWB";
	Vessel_Name     = "Southern Wandering Belle";
	Operator_Code	= "OPER";							// PAR #30860
	Operator_Desc	= "Southern Operators";				// PAR #30860
	
vars
	str : String;
begin
	if fieldNo = CM_InvoiceDesc.Field_None then
		str := None;
	elseif fieldNo = CM_InvoiceDesc.Field_Debtor_Name then
		str := Debtor_Name.trimBlanks;
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Code then
		str := Voyage_Code.trimBlanks;
	elseif fieldNo = CM_InvoiceDesc.Field_Vessel_Name then
		str := Vessel_Name.trimBlanks;
	elseif fieldNo = CM_InvoiceDesc.Field_Business_Unit then
		str := app.getProductName() &amp; " Technologies".trimBlanks;
		
		
	elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date then
		str := app.actualTimeServer.date.String;
	elseif fieldNo = CM_InvoiceDesc.Field_Closing_Date_And_Time then
		str := app.actualTimeServer.String;
		
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Code then		// PAR #30860
		str := Operator_Code.trimBlanks;								// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Operator_Desc then		// PAR #30860
		str := Operator_Desc.trimBlanks;								// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Arrival_Date then		// PAR #30860
		str := app.actualTimeServer.date.String;						// PAR #30860
	elseif fieldNo = CM_InvoiceDesc.Field_Voyage_Departure_Date then	// PAR #30860
		str := app.actualTimeServer.date.String;						// PAR #30860
	endif;

	return str;
end;</source>
        <Parameter name="fieldNo" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="5f40e1a7-2b71-4631-a5cc-ae9e388c98ab">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		10 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _obj.CM_InvoiceDesc.company &lt;&gt; self.myCurrentBank then
		return false;
	endif;
	return inheritMethod(_obj, _passport);

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
