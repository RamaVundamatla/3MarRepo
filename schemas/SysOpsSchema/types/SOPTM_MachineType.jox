    <JadeMethod name="initShtMultiSelect" id="31679ee0-b122-438f-8feb-72d942ca8768">
        <source>initShtMultiSelect();

vars
	theForm	: SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	inheritMethod;

	theForm.btnSetDefault1.visible := true;

	theForm.mulSelect1.visible	:= true;
	theForm.mulSelect2.visible	:= true;
	theForm.mulSelect3.visible	:= true;// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	theForm.mulSelect6.visible	:= true;// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	theForm.shtMultiSelect1.visible := true;
	theForm.shtMultiSelect2.visible := true;
	//theForm.shtMultiSelect3.visible := true;// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//theForm.shtMultiSelect6.visible := true;
	
	
	theForm.shtSingleSelect1.visible := true;
	theForm.shtSingleSelect1.caption := 'Fault Questions';
	theForm.lstSingleSelect1.visible :=true;	
	
	theForm.btnSingle1Up.visible:=true;
	theForm.btnSingle1Down.visible:=true;
	theForm.frmTBSingle.setToolbarControlsEnabled(true);
	theForm.chkAnyTriggField.visible := false;
	
	self.setupMultiSelect1(app.getErrorString(TerminalAreasTypeAccess), app.myRoot.allTerminalAreaTypes,SOP_TableMaintForm::displayEntryTAType.name);	
	self.setupMultiSelect2(app.getErrorString(Cargo_Types_Access) ,app.myRoot.allCargoTypesById,SOP_TableMaintForm::displayEntryCargoType.name);
	// 30/07/2009 cnwsh3 CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	self.setupMultiSelect3(app.getErrorString(Damage_positions), app.myRoot.allDamagePositionsByCode, SOP_TableMaintForm::displayEntryDamagePosition.name);
	self.setupMultiSelect6(app.getErrorString(Damage_Codes), app.myRoot.allDamageDefinitionCodes, SOP_TableMaintForm::displayEntryDamageDefCodes.name);
	
end;</source>
    </JadeMethod>
