        <source>isCommodity_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	commodity	: Object;
	str			: String;

begin

	str := self.myTrackedItem.commodity.trimBlanks();
	
	// Only priorities will be empty.
