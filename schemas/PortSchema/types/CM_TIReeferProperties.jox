    <JadeMethod name="pxyCreateUpdateProxy" id="b9c47684-a4dd-4ae0-9ee1-cfeed2e60066">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2009	cnwdap1	CCMS 1007 Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
*/
vars
	proxyProperties	: CM_TIReeferProperties;
	proxyCOU		: CM_ClipOnUnit;
	proxyGenerator	: CM_Generator;
	completedOK		: Boolean;
	pxyReading 		: CM_PackTempReading;
begin
	proxyProperties := inheritMethod();
	
	if self.packTempDetails &lt;&gt; null then
		pxyReading := self.packTempDetails.pxyCreateUpdateProxy();
		proxyProperties.setPackTempDetails(pxyReading);
	endif;
			
	if self.cou &lt;&gt; null then
		if app.isUnitTestGarbageCollect then
			proxyCOU := self.cou.pxyGetProxyObject();
		endif;
		if proxyCOU = null then
			proxyCOU := self.cou.pxyCreateUpdateProxy();
			proxyProperties.setCou(proxyCOU);
		endif;
	endif;

	if self.generator &lt;&gt; null then
		if app.isUnitTestGarbageCollect then
			proxyGenerator := self.generator.pxyGetProxyObject();
		endif;
		if proxyGenerator = null then
			proxyGenerator := self.generator.pxyCreateUpdateProxy();
			proxyProperties.setGenerator(proxyGenerator);
		endif;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyProperties;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyProperties;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresPower" id="83405c78-19ab-442a-8a78-06831e652946">
        <methodInvocation>mapping</methodInvocation>
        <source>requiresPower(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container
					Returns true if (the ti is powered and the commodity requires power)
					or (the ti is an (integral or porthole wit cou) and the commodity requires temperature).
Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
11/03/2010	cnwdap1	PAR #22938 Correct reefer checking
31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/
vars
	comm	: CM_Commodity;
	ti		: CM_TrackedItem;

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := false;
	
	//epr par 32291 8/1/14
	if self.myParent = null then
		return;
	endif;
	
	ti := self.myParent.CM_TrackedItem;
	if not (ti.typeAttributes.bitAnd(ISO_POWERED) &lt;&gt; 0) and 
		 not (ti.typeAttributes.bitAnd(ISO_INTEGRAL) &lt;&gt; 0) and
		 not (ti.typeAttributes.bitAnd(ISO_PORTHOLE) &lt;&gt; 0) and
		 not (ti.isReefer) then		// PAR #22938
		return;
	endif;
	//---------------
	// Check to see if we are empty - in which case we don't need power...
	//---------------
	if ti.isKindOf(CM_Container) and (ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY or ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_NULL) then
		return;
	endif;

	//---------------
	// Now determine if the container/commodity combination requires power...
	//
	// Checking for powered and not porthole because users may do silly thing and check
	// powered attribute for portholes even though they are not powered.
	//---------------
	comm := app.myRoot.allCommodities[ti.commodity];							//31.10.2023 navma1 #60920
	if (ti.typeAttributes.bitAnd(ISO_POWERED) &lt;&gt; 0) and 
		 not (ti.typeAttributes.bitAnd(ISO_PORTHOLE) &lt;&gt; 0) then
		// Does the commodity require power?
		if comm = null then
			return;
		endif;
	endif;

	if (ti.typeAttributes.bitAnd(ISO_PORTHOLE) &lt;&gt; 0) then
		// Do we have an attached cou??? If not we cannot be "powered" ...
		if self.cou = null then
			// If a porthole does not have a cou then it cannot require power! (it may
			// require temperature which is a seperate map instvar)...
			return;
		endif;
	endif;
	// If get here we an integral or a cou with a porthole...
	// Does the commodity require a temperature?
	
	if comm = null then // PAR 35158 Cargo type is break bulk and Is Reefer.  Cargo is in a container. Added temp reading on hand held Reefer Reading app. In cargo Enq click the Reefer tab and get a 1090.
		_value := false; // PAR 35158
	else
		_value := comm.hasTemp or comm.requiresPower; // AKB 15Mar2001 NOW
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="requiresTemperature" id="e5238e7b-2286-4338-95b3-769b44709934">
        <methodInvocation>mapping</methodInvocation>
        <source>requiresTemperature(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
11/03/2010	cnwdap1	PAR #22938 Correct reefer checking
*/
vars
	comm	: CM_Commodity;
	ti		: CM_TrackedItem;

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;	
	_value := false;
	ti := self.myParent.CM_TrackedItem;
	
	if ti = null then
		return;
	endif;
	//------------
	//If NOT an integral AND NOT a porthole, quit now.
	//------------
	if not (ti.typeAttributes.bitAnd(ISO_INTEGRAL) &lt;&gt; 0) and not (ti.typeAttributes.bitAnd(ISO_PORTHOLE) &lt;&gt; 0) 
				and not (ti.typeAttributes.bitAnd(ISO_REEFER) &lt;&gt; 0) and not (ti.isReefer) then		// PAR #22938
		return;
	endif;
	//------------
	// Check to see if we are empty - in which case we don't need power...
	//------------
	if ti.isKindOf(CM_Container) and (ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY or ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_NULL) then
		return;
	endif;
	//------------
	// Now determine if the commodity requires refridgeration...
	//------------
	comm := app.myRoot.allCommodities[ti.commodity];
	if comm = null then
		return;
	endif;
	_value := comm.hasTemp;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
