    <JadeMethod name="getMachineRuleTerminalArea" id="e21da925-b0d1-4b82-a6c1-9619fb0d7ead">
        <source>getMachineRuleTerminalArea(): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	workPoint :  CM_WorkPoint;
begin

	
	if self.myRORORequestDischarge &lt;&gt; null and not self.myRORORequestDischarge.isComplete and self.myRORORequestDischarge.myJob &lt;&gt; null then //cnwrd1 par 30576 19.10.2012 
		workPoint:=	self.myRORORequestDischarge.getMyWorkPoint;
		if workPoint &lt;&gt; null then
			return workPoint.myWorkPointInterchangeArea;
		endif;
	endif;
	
	
	if self.myRORORequestLoad &lt;&gt; null and  self.myRORORequestLoad.myJob &lt;&gt; null then //cnwrd1 par 30576 19.10.2012 
		workPoint:=	self.myRORORequestLoad.getMyWorkPoint;
		if workPoint &lt;&gt; null then
			return workPoint.myWorkPointInterchangeArea;
		endif;
	endif;
	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
