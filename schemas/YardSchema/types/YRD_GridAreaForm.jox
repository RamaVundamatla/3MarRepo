    <JadeMethod name="getXMLSettingsForExit" id="82aa7b43-64b1-4229-bccd-f4126a1b2b03">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpStr,
	xml		: String;
	tmpObj	: Object;
begin
	xml := inheritMethod();
	
	foreach tmpObj in self.allTerminalAreas do
		tmpStr := tmpStr &amp; global.formatAsXML(XML_TA, tmpObj.CM_TerminalArea.id);
	endforeach;
	
	xml := xml &amp; tmpStr;
	
	return xml;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="b5bde9b3-4679-411d-a717-26a52204c549">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	hideL,hideT,hideM : Boolean;
	aGridArea : CMUI_GridArea;
	theFrame : CMUI_GridAreaFrame;
begin
	inheritMethod();
	
	if self.areaType = self.Area_Type_Log then
		self.xmlToolbar := false;
	else
		theFrame := self.frmGridArea.getControl(1).CMUI_GridAreaFrame;
		if theFrame &lt;&gt; null then
			 if theFrame.myGridArea &lt;&gt; null then
				theFrame.myGridArea.setFlips(self.xmlFlipH,self.xmlFlipV);
				self.doSetCaption(theFrame.myGridArea);
			endif;
		endif;
		theFrame := self.frmGridArea.getControl(2).CMUI_GridAreaFrame;
		 if theFrame &lt;&gt; null then
			if theFrame.myGridArea &lt;&gt; null then
			   theFrame.myGridArea.setFlips(self.xmlFlipH,self.xmlFlipV);
				self.doSetCaption(theFrame.myGridArea);
			endif;
		endif;
		theFrame := self.frmGridArea.getControl(3).CMUI_GridAreaFrame;
		 if theFrame &lt;&gt; null then
			 if theFrame.myGridArea &lt;&gt; null then
				theFrame.myGridArea.setFlips(self.xmlFlipH, self.xmlFlipV);
				self.doSetCaption(theFrame.myGridArea);
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="dfabbdb0-ac92-4a47-be93-bcb3fdcb586e">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	tmpTA	: CM_TerminalArea;
	
begin

	inheritMethod(_userWindow);
	
	pos := 1;
	
	while true do
		str := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XML_TA, pos);
		if pos &lt;= 0 then
			break;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA = null then
			continue;
		endif;

		self.myCurrentTerminalArea := tmpTA;
		self.allTerminalAreas.add(tmpTA);

	endwhile;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initSelectAreasCollection" id="d6376e41-7fc6-4160-8bcc-42727fc2e808">
        <source>initSelectAreasCollection();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	terminalArea	: CM_TerminalArea;
	iter01 : Iterator;
	ls, haveStarted : Boolean;
	theTAs : CM_TAByTypeIdDict;
begin
	self.allAvailableGridAreas.clear;
	
	app.cmsBeginLoad(ls);
	theTAs := self.myTerminal.allTerminalAreasByTypeId;
	iter01 := theTAs.createIterator();

	// ###################################
	// ### LOG AREAS
	if self.areaType = self.Area_Type_Log  then	
		theTAs.startKeyGeq(TA_TYPE_LOGAREA, null, iter01);
		while iter01.next(terminalArea) do
			if iter01.getCurrentKey(1).Integer = TA_TYPE_LOGAREA then
				self.allAvailableGridAreas.add(terminalArea);
			else
				break;
			endif;
		endwhile;
	// ###################################
	// ### SHED AREAS
	elseif self.areaType = self.Area_Type_Shed then	
	// ###################################
	// ### GRID AREAS
	else
		theTAs.startKeyGeq(TA_TYPE_STRADDLE_STACK, null, iter01);
		while iter01.next(terminalArea) do
			if iter01.getCurrentKey(1).Integer = TA_TYPE_STRADDLE_STACK then
				self.allAvailableGridAreas.add(terminalArea);
			else
				break;
			endif;
		endwhile;
	
		theTAs.startKeyGeq(TA_TYPE_FORK_LIFT_STACK, null, iter01);
		while iter01.next(terminalArea) do
			if iter01.getCurrentKey(1).Integer = TA_TYPE_FORK_LIFT_STACK then
				self.allAvailableGridAreas.add(terminalArea);
			else
				break;
			endif;
		endwhile;
	endif;
	self.msgSelectAreas.setAvailable(self.allAvailableGridAreas,true);

epilog
	delete iter01;
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="initSelectAreasGroupBox" id="e9d0ae10-c0c6-4242-af0e-fe3520b4b4a1">
        <source>initSelectAreasGroupBox();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := self.msgSelectAreas;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displaySelectAreas";
	theGroupBox.availableHeading := app.getErrorString(Available_areas);
	theGroupBox.selectedHeading := app.getErrorString(Selected_areas);

	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="12eaad09-d4a7-4e89-989d-0f45bc6c5507">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelectorForm();
		else
			if self.frmSelectAreas.visible then
				self.showAreaSelectorEnable(false);
			else
				self.showAreaSelector();
			endif;
			return;
		endif;
		
	elseif keyCode = CMUI_Key_F5 then
		// as the F5 key will be processed by the CMUI_GridAreaForm::mnuWorkDisplayRedraw_click 
		// which is fired as it has this assigned to it in the Painter
		return;

	elseif keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		self.sdf01.clearUpDragDrop();
		self.sdf02.clearUpDragDrop();
		self.sdf03.clearUpDragDrop();
		return;
		
	endif;

	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="2b870c6d-8c06-4f2d-bb95-14a30a82f4db">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	aGridPoint : CMUI_GridPoint;
	aGridArea : CMUI_GridArea;
	regKeys : IntegerArray;

begin

	inheritMethod();

	if self.sdf01.viewMode = VIEW_OPERATOR then
	   	self.btnViewOperator.value := true;
	else
	   	self.btnViewVoyage.value := true;
	endif;
	
	if self.allTerminalAreas.size &gt; 0 then
		// have setup in initFromUserWindow
		self.setupFormFromAreaSelector();

	elseif self.areaType = self.Area_Type_Log then
	
		if self.myInitializeObject &lt;&gt; null then
			if self.myInitializeObject.isKindOf(CM_LogArea) then
			self.areaType := self.Area_Type_Log;
			self.myCurrentTerminalArea := self.myInitializeObject;
			self.allTerminalAreas.add(self.myCurrentTerminalArea);
			self.setupFormFromAreaSelector();
		
				if self.myInitializeLocation &lt;&gt; null then
					aGridPoint := self.sdf01.getPointFromLC(self.myInitializeLocation);
					aGridArea := aGridPoint.myGridArea;
				
					aGridArea.allSelectedPoints.add(aGridPoint);
					if self.myInitializeTI &lt;&gt; null then
	//						aGridArea.allSelectedTrackedItems.add(self.myInitializeTI);
					aGridArea.addTIToSelected(self.myInitializeTI);
					self.picCargo.picture := self.showCargoPicture(self.myInitializeTI);
					self.showExtraInfoForObject(self.myInitializeTI);
					endif;
					self.sdf01.doCentreOnSelectedPoint();
				endif;
			endif;
		else
		self.showAreaSelector(); 
		self.btnSelectTAs.caption := "Logs &amp;Areas";
		self.btnSelectTAs.bubbleHelp := "Select Logs Areas";
		endif;
	else
		if self.myInitializeObject &lt;&gt; null then
			if self.myInitializeObject.isKindOf(CM_GridArea) then
				self.areaType := self.Area_Type_Straddle;
				self.myCurrentTerminalArea := self.myInitializeObject;
				self.allTerminalAreas.add(self.myCurrentTerminalArea);
				self.setupFormFromAreaSelector();
				
				if self.myInitializeLocation &lt;&gt; null then
					aGridPoint := self.sdf01.getPointFromLC(self.myInitializeLocation);
					aGridArea := aGridPoint.myGridArea;
					
					aGridArea.allSelectedPoints.add(aGridPoint);
					if self.myInitializeTI &lt;&gt; null then
//						aGridArea.allSelectedTrackedItems.add(self.myInitializeTI);
						aGridArea.addTIToSelected(self.myInitializeTI);
						self.picCargo.picture := self.showCargoPicture(self.myInitializeTI);
						self.showExtraInfoForObject(self.myInitializeTI);
					endif;
					self.sdf01.doCentreOnSelectedPoint();
				endif;
			endif;			
		else
			self.showAreaSelector(); 
		endif;
	endif;

	self.initSelectAreasGroupBox();
	self.initSelectAreasCollection();

	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);

epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
