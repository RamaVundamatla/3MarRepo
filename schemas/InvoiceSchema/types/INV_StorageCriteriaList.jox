    <JadeMethod name="doQuery" id="d33ba5a2-a13a-4125-bf3e-d7076b5117f4">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
*/

vars
	storageDetail : CM_StorageDetail;
begin
	//if self.myStorageConfig = null then																	//-TFS7228
	self.myStorageConfig := self.myTerminal.myStorageConfig;					//+TFS7228
	if self.myStorageConfig = null then
		self.btnConfig.enabled := true;
		self.btnNew.enabled := false;
		self.btnEditItem.enabled := false;
		self.btnDelete.enabled := false;
		self.btnRefresh.enabled := false;
		//return;			//-TFS7228
	else
		if self.myStorageConfig.allStorageDetails.size  &lt;&gt; 0 then
				self.btnEditItem.enabled := true;
				self.btnDelete.enabled := true;
				self.btnRefresh.enabled := true;
		else
				self.btnEditItem.enabled := false;
				self.btnDelete.enabled := false;
				self.btnRefresh.enabled := false;
		endif;
		self.btnConfig.enabled := true;
		self.btnNew.enabled := true;
	endif;

	self.populateDataTable(); // TFS 5225
	// TFS 5225 self.populateTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="5c459a8a-64bc-416f-a94b-5082b74ee53c">
        <updating/>
        <source>doQueryAddItem(_detail : CM_StorageDetail) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2017		CNWAB1		Initial creation
*/
vars
	theDataLine : String;
	idx, colNumber : Integer;
begin
	theDataLine := _detail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

	idx := self.tblData.addItem(theDataLine);
	self.tblData.accessRow(idx).itemObject := _detail;

end;</source>
