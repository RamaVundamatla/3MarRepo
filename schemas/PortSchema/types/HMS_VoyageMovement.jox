    <JadeMethod name="getPilotLaunchForPilot" id="464025f5-dd7e-4e35-b9bf-2ab2e74da96a">
        <source>getPilotLaunchForPilot(_pilotCode : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
begin
	foreach movementPilotDetails in self.allMovementPilotDetails where movementPilotDetails.myPilot.code = _pilotCode do
		if movementPilotDetails.myPilotLaunch &lt;&gt; null then
			return movementPilotDetails.myPilotLaunch.description;
		endif;
	endforeach;
	return null; // no movement found with pilot having code _pilotCode, or pilot launch null
epilog

end;</source>
        <Parameter name="_pilotCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPilotLaunchString" id="285654ef-88e2-4862-b172-bff6dd68f1d8">
        <source>getPilotLaunchString( _desc : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
22 May 2019	jlgsl4	TFS 44844 - PEL1 - for Report Writer, need to output complete pilot launch list
*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
	str, launchDesc, launchCode : String; // TFS 44844
	pilotLaunch : HMS_PilotLaunch; // TFS 44844
begin
	foreach movementPilotDetails in self.allMovementPilotDetails do //where movementPilotDetails.myPilotLaunch &lt;&gt; null do // --&gt; TFS 44844
		pilotLaunch := movementPilotDetails.myPilotLaunch;
		if pilotLaunch &lt;&gt; null then
			launchDesc := pilotLaunch.description;
			launchCode := pilotLaunch.code;
		else
			launchDesc := null; // means there'll be ,, for pilot without a launch
			launchCode := null;
		endif; // &lt;-- TFS 44844
		if str &lt;&gt; null then
			if _desc then
				str := str &amp; "," &amp; launchDesc; //movementPilotDetails.myPilotLaunch.description; // TFS 44844
			else
				str := str &amp; "," &amp; launchCode; //movementPilotDetails.myPilotLaunch.code; // TFS 44844
			endif;
		else
			if _desc then
				str := launchDesc; //movementPilotDetails.myPilotLaunch.description; // TFS 44844
			else
				str := launchCode; //movementPilotDetails.myPilotLaunch.code; // TFS 44844
			endif;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <Parameter name="_desc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPilotLaunchTime" id="f1f3910f-039b-4524-8377-a9a1668d99d1">
        <source>getPilotLaunchTime() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlger1	Initial creation 39322

*/

vars
	pilotLaunchTime : TimeStamp;
	
begin
	if self.relativeOrderTimePlaunch  &lt; 0 then
		pilotLaunchTime:=self.occursOnDT.addMinutes(self.relativeOrderTimePlaunch.Integer*-1);
	else
		pilotLaunchTime:=self.occursOnDT.addMinutes(self.relativeOrderTimePlaunch.Integer);
	endif;
	
	return pilotLaunchTime;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPilotsString" id="faec7ca3-43b2-42b4-ae18-df9ca37324ec">
        <source>getPilotsString( _desc : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41662
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
22 May 2019	jlgsl4	TFS 44844 - PEL1 - for Report Writer, need to output complete pilot launch list
*/

vars

	pilot : HMS_Pilot;
	str : String;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin
	
	//if not self.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
	foreach movementPilotDetails in self.allMovementPilotDetails where movementPilotDetails.myPilot &lt;&gt; null do //pilot in self.allPilots do // TFS 44438
		if str &lt;&gt; null then
			if _desc then
				str := str &amp; "," &amp; movementPilotDetails.myPilot.description; //pilot.description; // TFS 44438
			else
				str := str &amp; "," &amp; movementPilotDetails.myPilot.code; //pilot.code; // TFS 44438
			endif;
		else
			if _desc then
				str := movementPilotDetails.myPilot.description; //pilot.description; // TFS 44438
			else
				str := movementPilotDetails.myPilot.code; //pilot.code; // TFS 44438
			endif;
		endif;
	endforeach;
	/*else // TFS 44438 - during upgrade script run, myPilotRef will be set to null...
		pilot := self.getUnConvertedMyPilotRef;
		if pilot &lt;&gt; null then
			if _desc then
				str := pilot.description;
			else
				str := pilot.code;
			endif;
		endif;
	endif;*/
	
	return str;

epilog

end;</source>
        <Parameter name="_desc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPilotsSummary" id="e0930833-21fa-4d0e-b294-739b9bb1be98">
        <source>getPilotsSummary(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41662
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars
	tmpPilot : HMS_Pilot;
	tmpStr : String;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin

	/*tmpPilot := self.getUnConvertedMyPilotRef; // --&gt; TFS 44438
	if tmpPilot &lt;&gt; null and ( self.allPilots.isEmpty or not self.allPilots.includes( tmpPilot ) ) then
		tmpStr := tmpStr &amp; "; " &amp; tmpPilot.description;
	endif;*/ // &lt;-- TFS 44438
	
	foreach movementPilotDetails in self.allMovementPilotDetails where movementPilotDetails.myPilot &lt;&gt; null do //tmpPilot in self.allPilots do // TFS 44438
		tmpStr := tmpStr &amp; "; " &amp; movementPilotDetails.myPilot.description; //tmpPilot.description; // TFS 44438
	endforeach;
 	
 	if tmpStr.length &gt; 2 then
	 	return tmpStr[3:end];
 	else
 		return tmpStr;
 	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="ba8f5a47-eb54-40e2-a7b4-8c6551dc3390">
        <source>getRemarks() : String;
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myHMSVoyageData &lt;&gt; null then
		return 'Movement Remarks: ' &amp; self.remarks &amp; ' ' &amp; self.myHMSVoyageData.getRemarks();
	else
		return 'Movement Remarks: ' &amp; self.remarks;
	endif;

	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResUsedDescription" id="d7ea66e1-e56e-44ee-9ecb-f9bc0b2fef16">
        <source>getResUsedDescription() : String;
// ---------------------------------------------------------------------------
// Created:		29 March 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpString, tmpTimeStr, tmpDec : String;
	nextMove, prevMove : HMS_VoyageMovement;
	timeDiff : Time;
	posNeg, numOfDays, tmpPos: Integer;
begin
	tmpString :=  self.moveType &amp; " " &amp; self.systemToLocalTime(self.occursOnDT).String;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support

	if app.isSpecial() then
		if self.moveType =  HMSMovementTypeDeparture then
			tmpString := tmpString &amp; " N";
		else
			nextMove := self.getVoyageMovementNext();
			prevMove := self.getVoyageMovementPrevious();
			if self.isMovementChargeable(self) then
				if nextMove &lt;&gt; null then
					tmpTimeStr := self.occursOnDT.differenceInHoursReal(nextMove.occursOnDT).String;
					tmpPos := tmpTimeStr.pos(".",1);
					if tmpPos &gt; 0 then
						tmpDec := tmpTimeStr[tmpPos:end];
						if tmpDec.length &gt; 3 then
							tmpDec := tmpDec[1:3];
							tmpTimeStr := tmpTimeStr[1:tmpPos - 1] &amp; tmpDec;
						endif;
						
					endif;
					tmpTimeStr := tmpTimeStr &amp;  " Hrs";
				endif;
				tmpString := tmpString &amp; " Y";
				tmpString := tmpString &amp; " " &amp; tmpTimeStr;
			else
				tmpString := tmpString &amp; " N";
			endif;
		endif;
	endif;
	
	return tmpString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourceUsedString" id="33a3a236-e0d3-48ea-942a-8b72839ace4f">
        <source>getResourceUsedString() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	res, lstRes : HMS_ResourceUsed;
	str : String;
	idx : Integer;
begin

	if self.allResourceUsed.isEmpty then
		return null;
	endif;
	
	lstRes := self.allResourceUsed.last;
	
	foreach res in self.allResourceUsed do
		idx := idx + 1;
		str := str  &amp; res.description;
		
		if res &lt;&gt; lstRes then
			str := str  &amp; ',';
			if idx mod 2 = 0  then
				str := str  &amp; Cr;
			endif;
		else
			str := str  &amp; '.';
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourcesUsedCancelled" id="b5fcd26c-351f-4574-a2f3-49ea54bde2b1">
        <source>getResourcesUsedCancelled():HMS_ResourceUsedSet;

/*

Purpose:			
				For use in Reportwriter
Parameters:			

Return Value:		


Date		Who		Reason
14 December 2018	jlgndl1	Initial creation	TFS 

*/

vars

	set : HMS_ResourceUsedSet;
	cancelledMovements : HMS_VoyageMovementArray;
	cancelledMovement : HMS_VoyageMovement;
	resourceUsed : HMS_ResourceUsed;

begin

	create set transient;
	create cancelledMovements transient;
	
	self.getMyCancelledMovements( cancelledMovements );
	
	foreach cancelledMovement in cancelledMovements do
		foreach resourceUsed in cancelledMovement.allResourceUsed do
			set.add( resourceUsed );
		endforeach;
	endforeach;

	return set;

epilog

	delete cancelledMovements;

end;</source>
        <ReturnType type="HMS_ResourceUsedSet"/>
    </JadeMethod>
    <JadeMethod name="getSecondPilot" id="8fae20d2-22a1-4404-a3bb-ae5dfe1a3c67">
        <source>getSecondPilot():HMS_Pilot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2018	jlgndl1	Initial creation	TFS 41826
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars

	size : Integer;
	index : Integer;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438	
begin

	if not self.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
		size := self.allMovementPilotDetails.size; //allPilots.size; // TFS 44438
		if size &gt; 1 then
			foreach movementPilotDetails in self.allMovementPilotDetails where movementPilotDetails.myPilot &lt;&gt; null do //pilot in self.allPilots do
				index := index + 1;
				if index = 2 then
					return movementPilotDetails.myPilot; //pilot; // TFS 44438
				endif;
			endforeach;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="HMS_Pilot"/>
    </JadeMethod>
    <JadeMethod name="getSecondPilotLaunch" id="2f8a960a-7c23-4844-9043-e5ee1710fa0c">
        <source>getSecondPilotLaunch() : HMS_PilotLaunch;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2019	jlgsl4	TFS 44918 - PEL1 - multiple pilot names being truncated; need 2nd pilot launch

*/

vars
	index : Integer;
	movementPilotDetails : HMS_MovementPilotDetails;
begin
	if not self.allMovementPilotDetails.isEmpty then
		if self.allMovementPilotDetails.size &gt; 1 then
			foreach movementPilotDetails in self.allMovementPilotDetails do
				index := index + 1;
				if index = 2 then
					return movementPilotDetails.myPilotLaunch;
				endif;
			endforeach;
		endif;
	endif;	
	return null;
epilog

end;</source>
        <ReturnType type="HMS_PilotLaunch"/>
    </JadeMethod>
    <JadeMethod name="getShipEnterLeaveDescJRW" id="ab8c73c1-8cd2-46f9-be79-d5802371ae80">
        <source>getShipEnterLeaveDescJRW() : String;

/*

Purpose:			Get tge description of the receiver as required for the Report Writer


Return Value:		String description


Date		Who		Reason
01 May 2008	cnwkpd1	PAR #16639 - Short Term Movements Pilots report

*/

vars
	descr			: String;
	
begin
	descr := self.getShipEnterLeaveDescr();
	if descr = HMSMovementTypeEntering then
		return "Enter";
	elseif descr = HMSMovementTypeLeaving then
		return "Depart";
	else
		return "Shift";
	endif;
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipEnterLeaveDescr" id="51983f75-d5a6-4021-8dd2-e12dee2e9684">
        <source>getShipEnterLeaveDescr() : String;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
// This method determines whether a ship is entering or leaving the 
// harbour on this movement 
vars
 	fromBerth,
 	toBerth:		HMS_Berth;
 	movementType: 	String;

begin
	
	fromBerth := self.getMyBerthPrevious();
	toBerth := self.getMyBerth();

	// Determine whether a ship is entering the harbour
	// ie. moving from a logical wharf to a nonlogical wharf
	if fromBerth &lt;&gt; null and toBerth &lt;&gt; null then
		if fromBerth.isLogicalBerth and 
		   (not toBerth.isLogicalBerth) then
			// Ship is entering the harbour
			movementType := HMSMovementTypeEntering;
		elseif (not fromBerth.isLogicalBerth)
		and toBerth.isLogicalBerth then
				// Ship is leaving the harbour
			movementType := HMSMovementTypeLeaving;
		endif;

	elseif fromBerth &lt;&gt; null and toBerth = null then
		if (not fromBerth.isLogicalBerth) then
			// Ship is leaving the harbour
			movementType := HMSMovementTypeLeaving;
		else
			movementType := HMSMovementTypeEntering;								
		endif;

	elseif fromBerth = null and toBerth &lt;&gt; null then
		if (not toBerth.isLogicalBerth) then
			// Ship is entering the harbour
			movementType := HMSMovementTypeEntering;
		else
			movementType := HMSMovementTypeLeaving;			
		endif;
	endif;

	return movementType;		

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipEnterLeaveStatus" id="d13dda66-e7df-4a4c-8907-22a83d9109ee">
        <source>getShipEnterLeaveStatus(regionFrom, regionTo : HMS_HarbourRegion io;
						 _movePrev : HMS_Movement) : String protected;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
// This method determines whether a ship is entering or leaving the 
// harbour on this movement and which regions it is travelling to/from
vars
 	fromBerth,
 	toBerth:		HMS_Berth;
 	movementType: 	String;
 	harbour:		HMS_Harbour;
 	fromWharf,
 	toWharf :		HMS_Wharf;
begin
	
	harbour := self.myHarbour;
	
	if _movePrev &lt;&gt; null then
		// either a shift or a departure movement
		fromBerth := _movePrev.getMyBerth();
		toBerth := self.getMyBerth();
	else
		// arrival movement
		fromBerth := null;
		toBerth := self.getMyBerth();
	endif;
	
	if fromBerth &lt;&gt; null then
		fromWharf := fromBerth.myWharf;
	endif;

	if toBerth &lt;&gt; null then
		toWharf := toBerth.myWharf;
	endif;	

	// Determine whether a ship is entering the harbour
	// ie. moving from a logical wharf to a nonlogical wharf
	if fromBerth &lt;&gt; null and toBerth &lt;&gt; null then
		if fromWharf &lt;&gt; null 
		and toWharf &lt;&gt; null then
			if fromWharf.isLogicalWharf
			and (not toWharf.isLogicalWharf) then
				// Ship is entering the harbour
				movementType := HMSMovementTypeEntering;
			elseif (not fromWharf.isLogicalWharf)
			and toWharf.isLogicalWharf then
				// Ship is leaving the harbour
				movementType := HMSMovementTypeLeaving;
			endif;
		else
			movementType := HMSMovementTypeEntering;					
		endif;
		regionFrom := fromBerth.myHarbourRegion;
		regionTo := toBerth.myHarbourRegion;
	elseif fromBerth &lt;&gt; null and toBerth = null then
		if fromWharf &lt;&gt; null
		and (not fromWharf.isLogicalWharf) then
			// Ship is leaving the harbour
			movementType := HMSMovementTypeLeaving;
		else
			movementType := HMSMovementTypeEntering;								
		endif;
		regionFrom := fromBerth.myHarbourRegion;
		if harbour.defaultDepartBerth &lt;&gt; null then
			regionTo := harbour.defaultDepartBerth.myHarbourRegion;
		endif;
	elseif fromBerth = null and toBerth &lt;&gt; null then
		if toWharf &lt;&gt; null
		and (not toWharf.isLogicalWharf) then
			// Ship is entering the harbour
			movementType := HMSMovementTypeEntering;
		else
			movementType := HMSMovementTypeLeaving;			
		endif;
		if harbour.defaultDepartBerth &lt;&gt; null then
			regionFrom := harbour.defaultDepartBerth.myHarbourRegion;
		endif;
		regionTo := toBerth.myHarbourRegion;
	endif;

	return movementType;		

end;</source>
        <access>protected</access>
        <Parameter name="regionFrom" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="regionTo" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="_movePrev" type="HMS_Movement"/>
        <ReturnType type="String"/>
    </JadeMethod>
