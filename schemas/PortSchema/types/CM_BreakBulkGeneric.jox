    <JadeMethod name="addToJobTotalsMove" id="b9874d2e-1389-4582-a197-1beb6f23f014">
        <source>addToJobTotalsMove(_theTotals: CMIF_JobTITotals input; _moveType: Integer);
/*
Purpose:			
Date		Who		Reason
20 June 2013	cnwab1	Initial creation
*/

vars

begin
	if _moveType =  DISCHARGE_MOVETYPE or _moveType =  LOAD_MOVETYPE then
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotals);
	elseif _moveType = DLR_MOVETYPE then
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsRH);
	elseif _moveType = SOB_MOVETYPE then
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsSOB);
  	endif;

epilog

end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="aggregate" id="72b48cfc-c484-436d-bf1e-de8cf7038f52">
        <updating/>
        <source>aggregate(	_aggregateToTI : CM_Bulk input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/04/2014	cnwndl1	Initial creation
24/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
*/

vars

	oldQuantity : Integer;
	oldVolume : Real; 
	oldWeight : Decimal[14,4];
	storageConfig	: CM_StorageConfig;
	oldCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	
begin

	oldQuantity := self.totalQuantity;
	oldVolume	:= self.totalVolume;
	oldWeight := self.totalWeight;	
	
	// PAR 36472
	storageConfig := self.myTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null and storageConfig.includesTriggerType(CargoSplitMerge) then
		self.createStorageTransaction(null,_passport);
		if not _passport.noErrors() then
			return;
		endif;
	endif;

	self.setTotalQuantity(0);
	self.setMyTotalVolume(0);
	self.setTotalWeightWithoutTrans(0);
	
	self.createMergeTransactons(	_aggregateToTI,
									oldQuantity, oldVolume, oldWeight, 0, 0,
									0 ,0, 0, 0, 0,
									true, null,
									_passport);
									
	//self.mergeNullRefs( _aggregateToTI ,null);				// TFS 3489
	self.mergeNullRefs( _aggregateToTI ,null, null);			// TFS 3489
		
epilog

end;</source>
        <Parameter name="_aggregateToTI" type="CM_Bulk" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="allowDirectDelivery" id="b26ad120-087d-462f-af51-4ef0ad02afc3">
        <source>allowDirectDelivery(): Boolean;
/*
Purpose: BreakBulk and Bulk cannot be direct delivery			

Parameters:			

Return Value:		

Date		Who		Reason
22 Dec 2014	cnwdw1	Initial creation
15 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/
vars
	cargoType : CM_CargoType;
begin
	cargoType := self.myCargoType;											//31.10.2023 navma1 #60920
	
	if cargoType = null then
		return false;
	endif;
	if self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then		// TFS 51935
		return true;														// TFS 51935
	endif;																	// TFS 51935
	
	return not cargoType.allowDuplicates;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMergeBreakBulk" id="b4a3860e-48df-4f9c-affc-383d6ec58c24">
        <source>canMergeBreakBulk(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2013	cnwndl1	Initial creation	CCMS 2274 Break-bulk
31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/

vars
	cargoType : CM_CargoType;
begin

	cargoType := self.myCargoType;					//31.10.2023 navma1 #60920
	
	if cargoType = null then
		return false;
	endif;
	
	if not  cargoType.allowDuplicates then		   //31.10.2023 navma1 #60920
		return false;
	endif;

	return  self.totalQuantity &gt; 0;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSplitTotalQuantity" id="a8ce0f9e-17ec-4cf2-8180-6e718b1761fc">
        <source>canSplitTotalQuantity(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwer1	Initial creation CCMS DPH 2274
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/

vars
	cargoType : CM_CargoType;
begin
	
	cargoType := self.myCargoType;							//31.10.2023 navma1 #60920
	
	if cargoType = null then
		return false;
	endif;
	
	if not  cargoType.allowDuplicates then
		return false;
	endif;
	
	return  self.totalQuantity &gt; 1;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferencesInternal" id="c2700017-9fd8-40ea-9fec-f4241174cfee">
        <updating/>
        <source>cloneReferencesInternal(_ti: CM_TrackedItem; _cloneTrans: Boolean; _isSplitTI: Boolean; _isFutureMoveTI: Boolean; _moveController: CMIF_MoveController input; _toLocation: CM_LocationsController; _voyage: CM_Voyage; _passport: CM_Passport input) updating, protected;
/*
Purpose:	// ### TFS BUG 57440 03APR2023 NAVAB1 - virtual attributes are not cloned

Date		Who		Reason
03 April 2023	navab1	 // ### TFS BUG 57440 03APR2023 NAVAB1
*/

vars

begin
	inheritMethod(_ti.CM_TrackedItem, _cloneTrans, _isSplitTI, _isFutureMoveTI, _moveController, _toLocation, _voyage, _passport);
	
	self.diameter := _ti.getDiameter();
	self.grade := _ti.getGrade();
	self.grammage := _ti.getGrammage();
	self.rollingLength := _ti.getRollingLength();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cloneTrans" type="Boolean"/>
        <Parameter name="_isSplitTI" type="Boolean"/>
        <Parameter name="_isFutureMoveTI" type="Boolean"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNewBreakBulkNewId" id="117aa287-8a53-40f3-ae19-3e71ea9a770a">
        <updating/>
        <source>createNewBreakBulkNewId(_control : CMIF_MoveController input; _newId : String;_includeStops ,_includeToDo,_includeDamage,_includeHaz: Boolean;_passport : CM_Passport input): CM_Cargo updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
22 Oct 2015	cnwma1	PAR #36678 When splitting a cargo with Stops the new cargoes don't have theirs
24 Feb 2017	cnwdap1	TFS 3489 LNX DLR/SOB
*/

vars

	retVal : CM_Cargo;

begin

	retVal :=  self.splitBreakBulkGeneric(_control, _newId );
	
	if not _control.myPassport.hasErrors then
		if self.totalQuantity = 0 then
			//self.mergeNullRefs( null,null);				// TFS 3489
			self.mergeNullRefs(null, null, null);			// TFS 3489
		endif;
	endif;
	
	retVal.updateDetailsFromCargoMulti(false,self,_includeStops,_includeToDo,_includeDamage,_includeHaz,_control.myPassport); //22/10/2015 cnwma1 PAR #36678  // ### JIRA 35283 30JUN2025 NAVAB1

	
	return retVal;
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_includeStops" type="Boolean"/>
        <Parameter name="_includeToDo" type="Boolean"/>
        <Parameter name="_includeDamage" type="Boolean"/>
        <Parameter name="_includeHaz" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="diameter" id="654bc8ea-c11e-401c-91c0-1dbd9a81d45e">
        <methodInvocation>mapping</methodInvocation>
        <source>diameter(set: Boolean; _value: Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2022	navpw1	Initial creation TFS: 54021

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, ExtraDiameter, _value);
	else
		global.getExtraData(self.allExtraData, ExtraDiameter, _value);
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="83da5eb8-b883-4067-893f-b76ead1833d5">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2020	jlgndl1	Initial creation	TFS 48249

*/

vars
	propName : String;
	palletType : CM_PalletType;

begin

	propName := _property.name;

	if propName = CM_PalletDetailsTI::heatTreated.name then
		if self.myPalletDetailsTI &lt;&gt; null then
			return self.myPalletDetailsTI.heatTreated.getYesNo;
		endif;
		return null;
	elseif propName = CM_PalletDetailsTI::myPalletType.name then
		if self.myPalletDetailsTI&lt;&gt; null then
			palletType := self.myPalletDetailsTI.getPalletTypeObj;
		endif;
		if palletType &lt;&gt; null then
			return palletType.code;
		endif;
		return null;
	elseif propName = CM_PalletDetailsTI::storeOnPallets.name then
		if self.myPalletDetailsTI &lt;&gt; null then
			return self.myPalletDetailsTI.storeOnPallets.getYesNo;
		endif;
		return null;
	else
	
		return inheritMethod(_property);
	
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBBDiscrepancyOverage" id="2cd3e64f-e397-4b7f-9e7f-24a944fd6bbf">
        <source>getBBDiscrepancyOverage():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwma1	Initial creation Used by BreakBulk Reports

*/

vars
	trans : CM_TITransaction;
	qty :Integer;
	total : Integer;
begin

	foreach trans in self.allTransactions reversed where trans.type = TRANS_TYPE_BREAKBULK_OVERAGE  do
		if trans &lt;&gt; null then
			if trans.CM_BBDiscrepancy.quantityChange &gt; 0 then
				qty :=trans.CM_BBDiscrepancy.quantityChange;
				total := total+qty;
			endif;
		endif;
	endforeach;
		
	return total;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBBDiscrepancyShortage" id="e095bca5-328f-4758-91af-31891f74ea20">
        <source>getBBDiscrepancyShortage():Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwma1	Initial creation 
Used by  BreakBulk Reporting

*/

vars
	trans : CM_TITransaction;
	qty :Integer;
	total : Integer;
begin

	foreach trans in self.allTransactions reversed where trans.type =TRANS_TYPE_BREAKBULK_OVERAGE  do
		if trans &lt;&gt; null then
			if trans.CM_BBDiscrepancy.quantityChange &lt; 0 then
				qty :=trans.CM_BBDiscrepancy.quantityChange *-1;
				total := total+qty;
				total := total *-1;
			endif;
		endif;
	endforeach;
	
return total;


end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBBManifestQuantity" id="420771ed-2631-4f8c-9cd2-7dca649c583c">
        <source>getBBManifestQuantity(_term,_bol,_cargoType : String):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2015	cnwma1	Initial creation    Used by Break Bulk Reports
*/

vars
	ti 				: CM_TrackedItem;
	qty,
	totalManifestQty	:Integer;
	cargoType 		: CM_CargoType;
	iter			: Iterator;
	idKey			: String;
	objSet			: ObjectSet;
	obj				: Object;
	term        	: CM_Terminal;
	dyna			: DynaDictionary;
begin
	
	create dyna transient;
	dyna.setMembership(CM_TrackedItem);
	dyna.addMemberKey(CM_TrackedItem::id.name, false, true);
	dyna.endKeys(false);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(_cargoType);
	idKey :=_bol;

	term := app.myRoot.allTerminals[_term].CM_Terminal;
	create objSet transient;

	iter := term.allOnsiteTIsByIdCargoType.createIterator;
	term.allOnsiteTIsByIdCargoType.startKeyGeq(null, cargoType.id,iter);
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; cargoType.id then
			continue;
		endif;
		
		if ti.billOfLading &lt;&gt; idKey then
			continue;
		endif;
		
		objSet.add(ti);

	endwhile;
	
	foreach obj in objSet do
		if dyna[obj.CM_BreakBulkGeneric.id] = null then
			dyna.add(obj.CM_BreakBulkGeneric);
			qty := obj.CM_BreakBulkGeneric.unsplitQuantity;
			totalManifestQty := totalManifestQty +qty;
		else
			continue;
		endif;
	
	endforeach;

	return  totalManifestQty;

epilog
	delete objSet;
	delete dyna;
end;</source>
        <Parameter name="_term" type="String"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBBOffsiteQuantity" id="59d06a64-46f0-4e70-a591-90c0dbf967ba">
        <source>getBBOffsiteQuantity(_term,_id,_cargoType : String):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2015	cnwma1	Initial creation BreakBulk Reports

*/

vars
	ti 				: CM_TrackedItem;
	qty,totalQtyOffsite	:Integer;
	cargoType 		: CM_CargoType;
	iter			: Iterator;
	idKey			: String;
	objSet			: ObjectSet;
	obj				: Object;
	term        	: CM_Terminal;	
begin
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(_cargoType);
	idKey :=_id;
	term := app.myRoot.allTerminals[_term].CM_Terminal;
	create objSet transient;

	iter := term.allOffsiteTIsByIdCargoType.createIterator;
	term.allOffsiteTIsByIdCargoType.startKeyGeq(idKey, cargoType.id,null,iter);
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; cargoType.id then
			continue;
		endif;
		
		if ti.id &lt;&gt; idKey then
			break;
		endif;
		objSet.add(ti);
	endwhile;
	
	foreach obj in objSet do
		if obj.CM_BreakBulkGeneric &lt;&gt; null then
			qty :=obj.CM_BreakBulkGeneric.totalQuantity;
			totalQtyOffsite := totalQtyOffsite+qty;
		endif;
	endforeach;

	return  totalQtyOffsite;

epilog
	delete objSet;
end;</source>
        <Parameter name="_term" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
