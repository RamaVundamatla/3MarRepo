        <source>"alias"</source>
        <type name="String"/>
    </Constant>
    <Constant name="DOC_MODEL_CLASS" id="c2c2d126-746c-4195-ad8c-0988c279e28f">
        <source>"class"</source>
        <type name="String"/>
    </Constant>
    <Constant name="DOC_MODEL_METHOD" id="cacc1085-6365-4539-9531-55176ef6276b">
        <source>"method"</source>
        <type name="String"/>
    </Constant>
    <Constant name="DOC_MODEL_NAME" id="0979e502-5f96-4653-b7bf-88b36d579bb9">
