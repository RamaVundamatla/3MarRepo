    <JadeMethod name="setBinaryValue" id="5472ba70-52c9-4c83-82ce-fa21eba2535b">
        <updating/>
        <source>setBinaryValue(value: Binary) updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if binaryValue &lt;&gt; value then 
		binaryValue := value;
	endif;
end;</source>
        <Parameter name="value" type="Binary"/>
    </JadeMethod>
