    <JadeMethod name="setForUpdate" id="1b7d9afe-e09e-4b72-8215-ee9965dac9e9">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 12/02/2019	jlgdap1		TFS 43062 PEL1 Container Services - Changes in Web Portal
// 20/02/2019	jlgdap1		TFS 43431 PEL1 Container Services - Release Request Expiry Date
// 1/04/2019	JLGNS1		Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
// 28/12/2022   navdp20  	ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
// 03 Feb 2023	navcs2		ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
// 31/03/2023	navcs2		ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
// 06 Jul 2023 	navhl20 	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
// 07 July 2023 navmv20     CR Task 58418 Task 58419: UI - Work Order Maintenance
// 31 November 2023 navmv20 Bug 61502: FR | EUP - Release Request by Type - Cargo Group Change Defaults
// 05 Feb 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
vars

begin
	inheritMethod(_pxyWoDDtl);
	
	self.myReleaseRequest 		:= _pxyWoDDtl.CM_WodRelease.getMyReleaseRequest();			// Bug 44134
	// 07/07/2023 navmv20 CR Task 58418 Task 58419 - start
	if app.myPassport.isVASEnabled then
		if self.myReleaseRequest &lt;&gt; null and self.myReleaseRequest.context = null then
			self.myReleaseRequest.setContext(RelReqContext_CargoGroupReview);
		endif;
	endif;
	// 07/07/2023 navmv20 CR Task 58418 Task 58419 - end
	self.customsClearanceNumber := _pxyWoDDtl.CM_WodRelease.customsClearanceNumber;			// TFS 43062
	self.transport				:= _pxyWoDDtl.CM_WodRelease.transport; 						// 28.12.2022 navdp20 TFS TFS 56661[56012] 
	self.myVoyage 				:= _pxyWoDDtl.CM_WodRelease.myVoyage;						// 03.02.2023	navcs2	ChangeRequest 55440 (54990)
	self.myTrain 				:= _pxyWoDDtl.CM_WodRelease.myTrain;						// 03.02.2023	navcs2	ChangeRequest 55440 (54990)
	self.myBookingRef			:= _pxyWoDDtl.CM_WodRelease.myBookingRef;			// 03.02.2023	navcs2	ChangeRequest 55440 (54990)			//06.7.2023 navhl20 #58952
	self.myBookingRefItem		:= _pxyWoDDtl.CM_WodRelease.myBookingRefItem;				//06.7.2023 navhl20 #58952
	self.myReserveDetail		:= _pxyWoDDtl.CM_WodRelease.myReserveDetail;				//31.03.2023	navcs2  #55440:[54990]
	
	if self.myReleaseRequest &lt;&gt; null 
	and not self.myReleaseRequest.expiryTimeStamp.isValid() // ### TFS CR 60424 TASK 60549 04OCT2023 NAVAB1 - only set this is necessary, this was overriding what was entered on the  screen
	and self.myReleaseRequest.context &lt;&gt; RelReqContext_CargoGroupReview //31/11/2023 navmv20 Bug 61502
	and self.requiredByDT.isValid and			// TFS 43431
	   self.myReleaseRequest.type = BR_TYPE_ROAD then		// 05 Feb 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
		self.myReleaseRequest.setExpiryTimeStampDate(self.requiredByDT.date);	// TFS 43431
		self.myReleaseRequest.setExpiryTimeStampTime(self.requiredByDT.time);	// TFS 43431
	endif;																		// TFS 43431
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodRelease" id="24233c63-5238-4e07-8758-07399164f3e6">
        <updating/>
        <source>setProxyWodRelease(_release		  : CM_BulkRelease;
				   _transport	  : Integer; 
				   _voyage 		  : CM_Voyage; 
				   _train 		  : CM_Train; 
				   _bookingRef 	  : CM_BookingRef;
				   _bookingItem   : CM_BookingRefItem;
				   _reserveDetail : CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018 jlgdap1	Initial creation TFS 38501 PEL1 Work Order Changes
28 Dec 2022 navdp20 ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
03 Feb 2023 navcs2	ChangeRequest 55440:[54990] EUP - Cargo Work Order Enhancements
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars

begin
	self.myReleaseRequest    := _release;
	self.transport 		     := _transport; 				//28.12.2022 navdp20 #56661:[56012]
	self.myVoyage 			 := _voyage; 			 		// 03.02.2023 navcs2 #355440:54990]
	self.myTrain 			 := _train;						// 03.02.2023 navcs2 #355440:54990]
	self.myReserveDetail	 := _reserveDetail;
	self.myBookingRef        := _bookingRef;				//04.07.2023 navma1 #58952
	self.myBookingRefItem	 := _bookingItem;				//04.07.2023 navma1 #58952

epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_transport" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setTransportMode" id="4eb314a6-abbd-47b9-b6a7-0d1a34f37447">
        <updating/>
        <source>setTransportMode(_transport : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Dec 2022	navdp20	ChangeRequest 56661:[56013] - Add Transport Mode to Receive and Release work orders

*/

vars

begin
	self.transport := _transport;
epilog

end;</source>
        <Parameter name="_transport" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="66f93882-638c-41c5-9b74-f494b54faed2">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navhl20	ChangeRequest 57301: EUP - [Framework] - Improve Audits on Work orders

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_WodReceive::transport.name
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="skipTiValidation" id="1dfdb55d-1f9d-4354-b0ef-9b6c6d7a7ffb">
        <source>skipTiValidation(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/03/2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement

*/

vars
	bulkRelease : CM_BulkRelease;
begin
	
	bulkRelease := self.myReleaseRequest;
	
	if bulkRelease &lt;&gt; null then
		if self.myReleaseRequest.releaseByType then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="ac5ba6b6-4c1e-4f19-92ef-1cbbd794b609">
        <source> validate() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May2018	jlgdap1	Initial creation TFS 38501 PEl1 Work Order Changes
11 Mar 2019	jlgdap1	TFS 43563 PEL1 Container Services - Cargo Business Unit
01 Apr 2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
30 Jul 2019	jlgmp6	TFS45870 Requirement of Customs Clearance Number on international cargo does not apply to empty containers
15 Oct 2021	jlier1	TFS 51963 - removed reference to isPELInternational
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
20 Apr 2023	navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
19 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Type / Data Load
19 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/
vars
	bulkRelease 	: CM_BulkRelease;
	wodRelease  	: CM_WorkOrderDtl;
	realRelease 	: CM_WorkOrderDtl;
	reserveDetail	: CM_ReserveDetail;
begin
	inheritMethod();
	
	bulkRelease 	:= self.getMyReleaseRequest();
	reserveDetail	:= self.myReserveDetail;
	
	//17.04.2023 navma1 #57324:[57325]
	if bulkRelease &lt;&gt; null and bulkRelease.releaseByType then
		if reserveDetail = null then
			app.raiseCMException(Please_select_release_detail,null,null);
		endif;
	endif;
	
	if app.myPassport.isVASEnabled then																//06.06.2023 navma1 #58339
		if reserveDetail &lt;&gt; null then
			wodRelease := reserveDetail.allWodReleases.first;
			if wodRelease &lt;&gt; null then
				realRelease := self.pxyGetRealObject();														// TFS 58923
				//if wodRelease &lt;&gt; self.pxyGetRealObject() then												// TFS 58923
				if not wodRelease.isTransient and realRelease &lt;&gt; null and wodRelease &lt;&gt; realRelease then	// TFS 58923
					app.raiseCMException1(ERR_ReleaseItem_AlreadyUsed,wodRelease.myParent.id,null,null);
				endif;
			endif;
		endif;
	endif;

	if self.transport = TI_TRANSMODE_SHIP then			//19.01.2024 navhl20 #62066
		if self.myVoyage = null then
			app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(Voyage), null, null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateAddTI" id="3c52864f-6826-4a7d-b28c-2a1ac73f9dc4">
        <source>validateAddTI( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2019	jlgndl1	Initial creation	TFS 43282

*/

vars

	wod : CM_WorkOrderDtl;

begin

	if not self.isTransient then	
		wod := _ti.getWorkOrderDetailOfType( self.detailType );
		if wod &lt;&gt; null and wod &lt;&gt; self then
			app.raiseCMException2(Alrea_assig_not_work_order_thi, _ti.id, self.getDisplayString(true) &amp; " " &amp; self.getMyParent.id, null, null);
		endif;	
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForApproval" id="4cbf6146-c79f-4536-929d-e50ab82a51e1">
        <source>validateForApproval();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEl1 Work Order Changes
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
//
vars

begin
	inheritMethod();
	
	if self.myParent.hasBeenApproved() then
		if self.getMyReleaseRequest() = null and self.myBookingRef = null then	//Bug 44134
			app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(Release), null, null);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
