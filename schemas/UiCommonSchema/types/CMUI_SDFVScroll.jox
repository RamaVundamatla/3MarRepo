    <JadeMethod name="isSelectable" id="5fc1954f-9b7f-4829-aee7-d6ece00d34d2">
        <source>isSelectable(): Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
