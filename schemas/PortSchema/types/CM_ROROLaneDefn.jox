    <JadeMethod name="setProxy" id="f01713c6-11b4-4f18-b6d9-94a154d16657">
        <updating/>
        <source>setProxy(_structure: CM_Object; _code: String; _desc: String; _remarks: String; _deckItemLayout: CM_DeckItemLayout; _deck: CM_Deck; _width: Decimal; _len: Decimal; _gap: Decimal; _ordinal: Integer; _deckLayerLayout: CM_DeckLayerLayout) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.setCode( _code, false );
	self.ordinal := _ordinal;
	self.description := _desc;
	self.remarks := _remarks;
	self.width := _width;
	self.length := _len;
	self.standardGap := _gap;
	
	self.myDeck := _deck;
	self.myDeckLayerLayout := _deckLayerLayout;
	self.myLayout := _deckItemLayout;
epilog

end;</source>
        <Parameter name="_structure" type="CM_Object"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_len" type="Decimal"/>
        <Parameter name="_gap" type="Decimal"/>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_deckLayerLayout" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreateDefaults" id="56fc6c9a-f935-4298-8c49-8631023deb45">
        <updating/>
        <source>setProxyForCreateDefaults(_deckItemLayout: CM_DeckItemLayout; _gapInMetre: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpDeck, realDeck : CM_Deck;
	tmpLayer : CM_DeckLayerLayout;
	ord, numT : Integer;
	actualW, actualL : Real;
begin
	tmpLayer := _deckItemLayout.myDeckLayer;
	tmpDeck := tmpLayer.myDeckLayout.myDeck;
	realDeck := tmpDeck.pxyGetRealObject();
	
	actualW := _deckItemLayout.getWidthInMetres();
	actualL := _deckItemLayout.getLengthInMetres();	

	ord := tmpDeck.allROROLaneDefnByOrdinal.size + realDeck.allROROLaneDefnByOrdinal.size + 1;
	
	self.setProxy(null, _deckItemLayout.code &amp; ord.String, _deckItemLayout.description, null, _deckItemLayout,tmpDeck , 
					actualW, //width : Decimal;
					actualL, //length : Decimal;
					_gapInMetre, //gap : Decimal;
					ord, // _ordinal : Integer;
					tmpLayer);

epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_gapInMetre" type="Decimal"/>
    </JadeMethod>
