        <source>getLaycanDifference() : Integer;
//-----------------------------------------------------------------------
//	Created:	06 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	diff	: Integer;
begin
	
	if self.laycanDateFrom &gt;=  self.arrivalDT then
		return 0;
	endif;
	diff := self.laycanDateFrom.getDifferenceInMinutes (self.arrivalDT);
	return diff;

	
epilog

end;</source>
