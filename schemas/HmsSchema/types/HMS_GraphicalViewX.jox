    <JadeMethod name="unload" id="054c1603-0e88-4241-a6cb-258bdbe569e1">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------
// Created:	27 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.allProxyObjects.purge();
	if global.isValidObject(self.myAdditionalInfoForm) then
		self.myAdditionalInfoForm.unloadForm();
	endif;
	
	inheritMethod();
end;</source>
