	realCustomsActionTt := null;
	
	//Delete Customs Action 2
	realCustomsAction2 := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_2];
	if realCustomsAction2 &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_2, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction2, "realCustomsAction2");
	endif;
	
	realCustomsAction2 := null;
	
	//Delete Customs Action 3
	realCustomsAction3 := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_3];
	if realCustomsAction3 &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_3, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction3, "realCustomsAction3");
	endif;
	
	realCustomsAction3 := null;
	
	//Delete Customs Action 6
	realCustomsAction6 := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_6];
	if realCustomsAction6 &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_6, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction6, "realCustomsAction6");
	endif;
	
	realCustomsAction6 := null;
	
	//Delete TSW DTR HOLD
	stopsTableDtrHold := self.getRoot.getStopTableForId(STOP_ID_DTR_HOLD);
	if stopsTableDtrHold &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_DTR_HOLD);
		self.assertIsDeletedMsg(stopsTableDtrHold, "stopsTableDtrHold");
	endif;
	
	delete systemUTHelper;
	delete pxyStopsTableSeaHold;
	delete pxyCustomsActionGc;
	delete pxyCustomsActionTt;
	delete pxyCustomsAction2;
	delete pxyCustomsAction3;
	delete pxyCustomsAction6;
	delete setAreasArr;
	delete checkAreasArr;
	delete processAreasArr;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRMOTSea_1" id="06118f68-49c8-4c31-acf0-d2eafeecd1bf">
        <source>tTSWDTRMOTSea_1();
/*

Purpose:			Tests an allow Mode of Transport by sea using Stops
					1O
					1C

Parameters:			

Return Value:		

Date			Who		Reason
26 June 2023	navpw1	Initial creation TFS: 58834

*/

constants
	STATEMENT_CODE_1O				: String	= '1O';
	STATEMENT_CODE_1C				: String	= '1C';
	BLOCKSTACK						: String	= 'UTB' &amp; self.TFS58834;
	MASTERBOL						: String	= "PMWLQ6952";		// Master BOL
	HOUSEBOL						: String	= "TLL014121";		// House BOL
	VESSEL							: String	= 'UTBOLSEA' &amp; self.TFS58834;
	VOYAGE							: String	= 'UT' &amp; self.TFS58834 &amp; "_Sea";
	OPERATOR						: String	= 'UTOP';
	USER_DEF_NAME					: String	= 'TSW';
	
	CONTAINERTEST1					: String	= self.TFS58834 &amp; "-SEA1";
	CONTAINERTEST2					: String	= self.TFS58834 &amp; "-SEA2";
	CONTAINERTEST3					: String	= self.TFS58834 &amp; "-SEA3";
	CONTAINERTEST4					: String	= self.TFS58834 &amp; "-SEA4";
	CONTAINERTEST5					: String	= self.TFS58834 &amp; "-SEA5";
	CONTAINERTEST6					: String	= self.TFS58834 &amp; "-SEA6";
	CONTAINERTEST7					: String	= self.TFS58834 &amp; "-SEA7";
	CONTAINERTEST8					: String	= self.TFS58834 &amp; "-SEA8";
	CONTAINERTEST9					: String	= self.TFS58834 &amp; "-SEA9";
	CONTAINERTEST10					: String	= self.TFS58834 &amp; "-SEA10";
	BOL1							: String	= "BOL120N28100-1";
	
	STOP_CODE_LAND_HOLD				: String	= "TSWLN";
	STOP_ID_LAND_HOLD				: Integer	= 883;
	STOP_HEADING_LAND_HOLD			: String	= "TSW LAND HOLD";
	
	CUSTOMS_ACTION_NAME_1O			: String	= "TSW LAND 1O";
	CUSTOMS_ACTION_KEYWORD_1O		: String	= "1O";
	
	CUSTOMS_ACTION_NAME_1C			: String	= "TSW LAND 1C";
	CUSTOMS_ACTION_KEYWORD_1C		: String	= "1C";
	
vars
	blockStack						: CM_BlockStack;
	pxyStopsTableLandHold,
	realStopsTableLandHold,
	stopsTableMAF,
	stopsTableLandHold				: CM_StopsTable;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	tiSet							: CM_TISet;
	ti1,
	ti2								: CM_TrackedItem;
	ediText, tempStr				: String;
	ediFile							: CM_EDIFile;
	ediTI							: CM_EDITrackedItem;
	ediStop							: CM_EDICustomStopTI;
	found1							: Boolean;
	pxyCustomsAction1O,
	realCustomsAction1O,
	pxyCustomsAction1C,
	realCustomsAction1C				: CM_EDIAction;
	
	pxyStopsTableTemplateLH			: CM_StopTableTemplate;
	checkAreasArr,
	setAreasArr,
	processAreasArr					: IntegerArray;
	noImportStops,
	completedOk						: Boolean;
	systemUTHelper					: UT_HelperAdmSys;
	
begin
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	create systemUTHelper transient;
	systemUTHelper.setActiveProfile;
	systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRMOTSea_1;
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW LAND HOLD
	stopsTableLandHold := self.getRoot.getStopTableForId(STOP_ID_LAND_HOLD);
	if stopsTableLandHold &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_LAND_HOLD);
		self.assertIsDeletedMsg(stopsTableLandHold, "stopsTableLandHold");
	endif;
	
	//Get Stops Table MAF
	stopsTableMAF := self.getRoot.getStopTableForId(TI_Stop_MAF);
	
	//Create TSW LAND HOLD
	create setAreasArr transient;
	//setAreasArr.add(StopApplyExport);
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventImport);
	//checkAreasArr.add(StopPreventExport);
	
	create processAreasArr transient;
	
	systemUTHelper.opts.purge();
	systemUTHelper.opts.addAssoc(UT_OPTS_IsFull, true);
	systemUTHelper.opts.addAssoc(UT_OPTS_CheckAreas, checkAreasArr);
	systemUTHelper.opts.addAssoc(UT_OPTS_SetAreas, setAreasArr);
	systemUTHelper.opts.addAssoc(UT_OPTS_ProcessAreas, processAreasArr);
	systemUTHelper.opts.addAssoc(UT_OPTS_HoldVoyages, null);
	
	realStopsTableLandHold := systemUTHelper.xCreateStop(STOP_ID_LAND_HOLD, STOP_CODE_LAND_HOLD, STOP_HEADING_LAND_HOLD, STOP_CODE_LAND_HOLD, false, null, false, false);
	
	systemUTHelper.opts.purge();
	
	//Delete Customs Action 1O
	realCustomsAction1O := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_1O];
	if realCustomsAction1O &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_1O, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction1O, "realCustomsAction1O");
	endif;
	
	realCustomsAction1O := null;
	
	//Delete Customs Action 1C
	realCustomsAction1C := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_1C];
	if realCustomsAction1C &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_1C, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction1C, "realCustomsAction1C");
	endif;
	
	realCustomsAction1C := null;
	
	//Create Customs Action TT
	create pxyCustomsAction1O transient;
	pxyCustomsAction1O.setProxy(CUSTOMS_ACTION_NAME_1O, CUSTOMS_ACTION_KEYWORD_1O, EDIKeySegment_MOT, EDIAction_Add, realStopsTableLandHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction1O, realCustomsAction1O, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction1O, "realCustomsAction1O");
	
	//Create Customs Action GC
	create pxyCustomsAction1C transient;
	pxyCustomsAction1C.setProxy(CUSTOMS_ACTION_NAME_1C, CUSTOMS_ACTION_KEYWORD_1C, EDIKeySegment_MOT, EDIAction_Add, realStopsTableLandHold, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction1C, realCustomsAction1C, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction1C, "realCustomsAction1C");
	
	/*
	**	Test 1 Start - Test Statement Code is 1O and Multiple Additional Items. Should add the TSW LAND HOLD stop with stopId as 883
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 2, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20230214160658&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;569&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="dcc9d96c-0834-49c6-a241-dc3c0610e85d-lodgement" filename="PDF7-13739579-2023-02-14-1602296006.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;MB MB987654331 - MOVEMENT APPROVED. All movements approved under a DTR for uncleared goods must be moved by way of an enclosed, secure, leak-proof conveyance, being either within an enclosed vehicle, or within an enclosed air container.&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;13739579&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20230214160658&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;NSN_FCL_SEA&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;OfficerSubmissionClientCode&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20221116&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZNSN&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;	  
		  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementDescription&gt;MPI APPROVAL TO MOVE TO ATF&lt;/StatementDescription&gt;
            &lt;StatementTypeCode&gt;MCS&lt;/StatementTypeCode&gt;
            &lt;Pointer&gt;
              &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;DocumentSectionCode&gt;28A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementCode&gt;' &amp; STATEMENT_CODE_1O &amp; '&lt;/StatementCode&gt;
            &lt;StatementTypeCode&gt;MTT&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementDescription&gt;seq:1,takenTo:TSW GROOT LOCATION, 15 Brigade Road, Manukau,for:MPI APPROVAL TO MOVE TO ATF,by:ACCREDITED PERSON,instructions:.Container(s) to be checked by Nominated Accredited Person,issuedDate:Tuesday, 14 February 2023 4:18:52 PM,issuedBy:MPI SYSTEMS,transportEquipment:BMOU8708209&lt;/StatementDescription&gt;
            &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AssociatedTransportDocument&gt;
            &lt;ID&gt;MB987654331&lt;/ID&gt;
            &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
          &lt;/AssociatedTransportDocument&gt;
          &lt;Consignee&gt;
            &lt;Name&gt;NZ Chemicals&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
              &lt;GrossMassMeasure unitCode="KGM"&gt;1234&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;10&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;DR&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
            &lt;Name&gt;CN Chemicals&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;GoodsLocation&gt;
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/GoodsLocation&gt;
          &lt;TransitDestination&gt;
            &lt;Name&gt;PORTNZWLG&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST1 &amp; '&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
		  &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST2 &amp; '&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
            &lt;ID&gt;NZNSN&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20230214160658&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;B07&lt;/NameCode&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		tempStr	:= 'Test 1 - Stop ' &amp; STOP_ID_LAND_HOLD.display &amp; Space &amp; realStopsTableLandHold.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_LAND_HOLD), true, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 1 End - Test Statement Code is 1O and Multiple Additional Items. Should add the TSW LAND HOLD stop with stopId as 883
	*/
	
	/*
	**	Test 2 Start - Test Statement Code is 1O. Should add the TSW LAND HOLD stop with stopId as 883
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST3, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST4, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 4, "Test 2 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20230214160658&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;569&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="dcc9d96c-0834-49c6-a241-dc3c0610e85d-lodgement" filename="PDF7-13739579-2023-02-14-1602296006.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;MB MB987654331 - MOVEMENT APPROVED. All movements approved under a DTR for uncleared goods must be moved by way of an enclosed, secure, leak-proof conveyance, being either within an enclosed vehicle, or within an enclosed air container.&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;13739579&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20230214160658&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;NSN_FCL_SEA&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;OfficerSubmissionClientCode&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20221116&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZNSN&lt;/FirstArrivalLocationID&gt;
