18 Apr 2018	jlgkpd1	TFS #37190 - refactor to CM_XmlHelperAgent

*/

vars
	xml 			: JadeXMLDocument;
	parseError		: Boolean;
	documentChanged	: Boolean;
	xmlHelper 		: CM_XmlHelperAgent;
	
begin
	// Start by parsing the message so that it can be more easily analysed
	on JadeXMLException do self.handleXMLException(exception, parseError);
		
	create xml transient;
	xml.parseString(self.incomingMessage);
		
	if parseError then
		// No nothing
		return;
	endif;

	create xmlHelper transient;
	
	// Firstly convert INAPORTNET names to JMT names
	xmlHelper.translateElementNames(xml,"urn:JadeWebServices/JMTExternalInterfaceService/", "RequestEntryRKBM", "requestEntryRKBM", documentChanged);
	xmlHelper.translateElementNames(xml,"urn:JadeWebServices/JMTExternalInterfaceService/", "DetailRKBM", WS_DetailRKBM.name, documentChanged);
	
	// Ensure any WS_DetailRKBM are correctly parented
	xmlHelper.reparentElements(xml, WS_DetailRKBM.name, WS_EntryRKBMRequest::allDetailRKBM.name, documentChanged);
	
	if documentChanged then
		app.writeLog(method.qualifiedName &amp; " modified input before preProcess", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.logIncomingMessage();
		app.writeLog(method.qualifiedName &amp; " modified input", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.incomingMessage := xml.writeToString();
		self.logIncomingMessage();
	endif;
	
epilog
	delete xml;
	delete xmlHelper;
	
end;
</source>
