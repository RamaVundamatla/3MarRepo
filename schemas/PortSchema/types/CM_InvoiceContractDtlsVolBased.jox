    <JadeMethod name="setProxyVolBased" id="d9ae7916-728b-4d1b-a3af-ebd3fb294bb1">
        <updating/>
        <source>setProxyVolBased(_rail, _road, _ship : Boolean; _type : Integer) updating;
/*
Purpose:			

Date		Who		Reason
23 January 2023	navab1	TFS CR 55624 TASK 55698 
*/

vars

begin
	self.accumulateForRailReceival := _rail;
	self.accumulateForRoadReceival := _road;
	self.accumulateForShipReceival := _ship;
	self.accumulationType := _type;
	

epilog

