    <JadeMethod name="populateTableBackup" id="f5ffd117-1970-4588-8e3d-7d80253d2757">
        <source>populateTableBackup() protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// 03 Oct 2019	jlgrs1	TFS 46810 - include Journal Number in backup deatils
// ---------------------------------------------------------------------------
vars

begin
	if self.myBackup = null then
		return;
	endif;
//	self.tblBackup.setValueByName(ETRow_BinaryPath, self.myBackup.binaryBackupPath);
//	self.tblBackup.setValueByName(ETRow_BinaryRemotePath, self.myBackup.binaryRemoteBackupPath);
	self.tblBackup.setValueByName(ETRow_BackupPath, self.myBackup.dbBackupPath);
	self.tblBackup.setValueByName(ETRow_DBCompress, self.myBackup.dbCompress);
//	self.tblBackup.setValueByName(ETRow_DBOverwrite, self.myBackup.dbOverwrite);
//	self.tblBackup.setValueByName(ETRow_DBBackupRemotePath, self.myBackup.dbRemoteBackupPath);	// 15 May NDL	Par 29574
//	self.tblBackup.setValueByName(ETRow_DBVerify, self.myBackup.dbVerify);
//	self.tblBackup.setValueByName(ETRow_Debug, self.myBackup.debug);
	self.tblBackup.setValueByName(ETRow_JournalCompress, self.myBackup.journalCompress);
	self.tblBackup.setValueByName(ETRow_JournalPath, self.myBackup.journalLocalBackupPath);
	self.tblBackup.setValueByName(ETRow_JournalRemotePath, self.myBackup.journalRemoteBackupPath);
	self.tblBackup.setValueByName(ETRow_JournalVerify, self.myBackup.journalVerify);
	self.tblBackup.setValueByName(ETRow_PurgeJournals, self.myBackup.purgeDBJournals);
	self.tblBackup.setValueByName(ETRow_PurgeJournalDays, self.myBackup.purgeJournalDays);
	self.tblBackup.setValueByName(ETRow_PurgeJournalsLocal, self.myBackup.purgeLocalJournal);
	self.tblBackup.setValueByName(ETRow_PurgeJournalsRemote, self.myBackup.purgeRemoteJournals);
	self.tblBackup.setValueByName(ETRow_PurgeSDSJournals, self.myBackup.purgeSDSJournals);
	self.tblBackup.setValueByName(ETRow_DatabaseWorkers, self.myBackup.databaseWorkers);	// CCMS1150 cnwrs1 04 July 2011
	self.tblBackup.setValueByName(ETRow_SDSSecondaryBackup, self.myBackup.sdsSecondaryBackup);	// CCMS1150 cnwrs1 04 July 2011
	self.tblBackup.setValueByName(ETRow_JournalNumber, self.myBackup.journalNumber);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="3feb1435-c534-405d-9982-69df1ec11261">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
