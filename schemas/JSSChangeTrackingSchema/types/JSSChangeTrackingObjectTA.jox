    <JadeMethod name="doCreate" id="bc800ef3-ba1e-4ba3-9e6d-b5c8f2118689">
        <updating/>
        <source>doCreate(): Boolean updating, protected;
/*
*/
begin
	on Exception do handleException(exception, self);

	create self.myChangeObject persistent;
	self.myChangeObject.createEntity(self);

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="53d3ff6b-61eb-4c0b-919d-3ece9a97a1db">
        <updating/>
        <source>doDelete(): Boolean updating, protected;
/*
*/
begin
	self.myChangeObject.deleteEntity(self);
	delete self.myChangeObject;

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="32f14f5f-27bf-4208-82d0-bb1aa4185054">
        <updating/>
        <source>doUpdate(): Boolean updating, protected;
/*
*/
begin
	self.myChangeObject.updateEntity(self);

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="b80c9acb-adcc-4d2b-8be8-d09de4d0b890">
        <updating/>
        <source>handleException(pException: Exception; pObject: JSSChangeTrackingObjectTA): Integer updating;

vars

begin
	write pObject.changeAction.String;
	write pObject.changeObjectID.String;
	write pObject.changeTimestamp.String;
	write pObject.className.String;
	write pObject.myChangeClass.String;
	write pObject.myDeleteClass.String;

	errorCode := pException.errorCode;

	return(Ex_Pass_Back);
end;</source>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pObject" type="JSSChangeTrackingObjectTA"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lockEntity" id="777d2637-b9a2-4528-b9b1-460bb31bd0ef">
        <source>lockEntity(): Boolean protected;

vars
	rtn: Boolean;
begin
	if self.myChangeTrackingRoot &lt;&gt; null then
		if not self.tryLockingObject(self.myChangeTrackingRoot.allUpdatesByTransactionIdDict) then
			return (false);
		endif;
	endif;
	if self.myChangeClass &lt;&gt; null then
		rtn := self.tryLockingObject(myChangeClass);
		if rtn then
			if not self.tryLockingObject(myChangeClass.allChangesByOid) then
				return (false);
			endif;
		endif;
	endif;
	if self.myDeleteClass &lt;&gt; null then
		rtn := self.tryLockingObject(myDeleteClass);
		if rtn then
			if not self.tryLockingObject(myDeleteClass.allChangesByOid) then
				return (false);
			endif;
		endif;
	endif;
	rtn := self.tryLockingObject(myChangeObject);

	return(rtn);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockEntityCreate" id="7411e0cb-9c01-48c9-92e5-dedec35c2350">
        <source>lockEntityCreate(): Boolean protected;

vars
	rtn: Boolean;
begin
	if self.myChangeTrackingRoot &lt;&gt; null then
		if not self.tryLockingObject(self.myChangeTrackingRoot.allUpdatesByTransactionIdDict) then
			return (false);
		endif;
	endif;
	if self.myChangeClass &lt;&gt; null then
		rtn := self.tryLockingObject(self.myChangeClass);
		if rtn then
			rtn := self.tryLockingObject(myChangeClass.allChangesByOid);
		endif;
	elseif self.myDeleteClass &lt;&gt; null then
		rtn := self.tryLockingObject(self.myDeleteClass);
		if rtn then
			rtn := self.tryLockingObject(myDeleteClass.allChangesByOid);
		endif;
	endif;
	return (rtn);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="monitor" id="8ad8dc00-11aa-480c-a1a9-213ef1192351">
        <source>monitor(_msg: String);

vars

begin
	self.myServiceManager.monitor(_msg);
end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
</Class>
