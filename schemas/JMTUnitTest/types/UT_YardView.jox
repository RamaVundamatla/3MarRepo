    <JadeMethod name="tDwellDaysRange" id="6e6789e3-fa62-4709-a0c9-98dbfcda9cbc">
        <source>tDwellDaysRange();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	allDwellRanges : CM_DwellDayRangeByLowerDict;
	objectArray : ObjectArray;
	
	firstDwellDayRange : CM_DwellDayRange;
	pxyFirstDwellDayRange : CM_DwellDayRange;
	
	secondDwellDayRange : CM_DwellDayRange;
	pxySecondDwellDayRange : CM_DwellDayRange;
	
	dwellDayRange : CM_DwellDayRange;
	pxyDwellDayRange1 : CM_DwellDayRange;
	dwellDayRange1 : CM_DwellDayRange;
	pxyDwellDayRange2 : CM_DwellDayRange;
	dwellDayRange2 : CM_DwellDayRange;
	
	error : CM_Error;
	loadState : Boolean;

begin

	create allDwellRanges transient;
	create objectArray transient;
	app.myRoot.allDwellDayRanges.copy( allDwellRanges );
	foreach dwellDayRange in allDwellRanges do
		objectArray.add(dwellDayRange);
	endforeach;

	if allDwellRanges.isEmpty then
	elseif allDwellRanges.size = 1 then
		firstDwellDayRange := allDwellRanges.first;
		secondDwellDayRange := null;
	elseif allDwellRanges.size = 2 then
		firstDwellDayRange := allDwellRanges.first;
		secondDwellDayRange := objectArray[2].CM_DwellDayRange;
	else
		if objectArray[3].CM_DwellDayRange.lower &lt; 7 then
			self.assertTrueMsg(false, "Can't run Dwell Days Range test see code." );
			return;
			// We want to delete teh first two and then add them back in creating overlaps etc.
			// not enough room with the range of numbers set up to allow testing all options
			// If there are existing ranges, the third object must start with 7 or higher.
		endif;
		firstDwellDayRange := allDwellRanges.first;
		secondDwellDayRange := objectArray[2].CM_DwellDayRange;
	endif;

	//Save off or create our first Dwell Days Range object.
	create pxyFirstDwellDayRange transient;
	if firstDwellDayRange = null then
		pxyFirstDwellDayRange.setProxy(	Green,	//_colour : Integer;
										0,	//_lower : Integer;
										5	//_upper : Integer
										);
	else
		pxyFirstDwellDayRange.setProxy(	firstDwellDayRange.colour,	//_colour : Integer;
										firstDwellDayRange.lower,	//_lower : Integer;
										firstDwellDayRange.upper	//_upper : Integer
										);
	endif;
	
	if firstDwellDayRange &lt;&gt; null then
		app.myTrxDA.trxDeleteDwellDayRange( firstDwellDayRange, app.myPassport );
		self.assertTrueMsg(not app.myPassport.hasErrors, "Delete of First Dwell Days Range gives : " &amp; app.myPassport.getErrorsAsString );
	endif;
	
	//Save off or create our first Dwell Days Range object.
	create pxySecondDwellDayRange transient;
	if secondDwellDayRange = null then
		pxySecondDwellDayRange.setProxy(	Red,	//_colour : Integer;
											6,	//_lower : Integer;
											14	//_upper : Integer
											);
	else
		pxySecondDwellDayRange.setProxy(	secondDwellDayRange.colour,	//_colour : Integer;
											secondDwellDayRange.lower,	//_lower : Integer;
											secondDwellDayRange.upper	//_upper : Integer
											);
	endif;
	
	if secondDwellDayRange &lt;&gt; null then
		app.myTrxDA.trxDeleteDwellDayRange( secondDwellDayRange, app.myPassport );
		self.assertTrueMsg(not app.myPassport.hasErrors, "Delete of Second Dwell Days Range gives : " &amp; app.myPassport.getErrorsAsString );
	endif;
	
	create pxyDwellDayRange1 transient;
	pxyDwellDayRange1.setProxy(	Green,	//_colour : Integer;
								-3,	//_lower : Integer;
								0	//_upper : Integer
								);
								
	app.myPassport.clearErrorsWarnings();
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange1, dwellDayRange1, app.myPassport );
	self.assertTrueMsg(app.myPassport.hasErrors, "Should have errored, lower less than zero" );
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = 87057, "Should have errored, lower less than zero" );
	
	pxyDwellDayRange1.setProxy(	Green,	//_colour : Integer;
								5,	//_lower : Integer;
								0	//_upper : Integer
								);
	
	app.myPassport.clearErrorsWarnings();
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange1, dwellDayRange1, app.myPassport );
	self.assertTrueMsg(app.myPassport.hasErrors, "Should have errored, lower greater than upper" );
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = 87058, "Should have errored, lower greater than upper" );
	
	pxyDwellDayRange1.setProxy(	Green,	//_colour : Integer;
								1,	//_lower : Integer;
								4	//_upper : Integer
								);
	
	app.myPassport.clearErrorsWarnings();
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange1, dwellDayRange1, app.myPassport );
	
	self.assertTrueMsg(not app.myPassport.hasErrors, "Create of Dwell Days Range[1] gives : " &amp; app.myPassport.getErrorsAsString );
	delete pxyDwellDayRange1;
	
	create pxyDwellDayRange2 transient;
	pxyDwellDayRange2.setProxy(	Red,	//_colour : Integer;
								2,	//_lower : Integer;
								3	//_upper : Integer
								);
	app.myPassport.clearErrorsWarnings();							
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange2, dwellDayRange2, app.myPassport );
	self.assertTrueMsg(app.myPassport.hasErrors, "Should have errored, overlaps" );
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = 87059, "Should have errored, overlaps internal" );
	
	pxyDwellDayRange2.setProxy(	Red,	//_colour : Integer;
								0,	//_lower : Integer;
								5	//_upper : Integer
								);
	app.myPassport.clearErrorsWarnings();							
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange2, dwellDayRange2, app.myPassport );
	self.assertTrueMsg(app.myPassport.hasErrors, "Should have errored, overlaps" );
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = 87059, "Should have errored, overlaps start and end" );
	
	pxyDwellDayRange2.setProxy(	Red,	//_colour : Integer;
								0,	//_lower : Integer;
								3	//_upper : Integer
								);
	app.myPassport.clearErrorsWarnings();							
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange2, dwellDayRange2, app.myPassport );
	self.assertTrueMsg(app.myPassport.hasErrors, "Should have errored, overlaps" );
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = 87059, "Should have errored, overlaps start" );
	
	pxyDwellDayRange2.setProxy(	Red,	//_colour : Integer;
								3,	//_lower : Integer;
								6	//_upper : Integer
								);
	app.myPassport.clearErrorsWarnings();							
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange2, dwellDayRange2, app.myPassport );
	self.assertTrueMsg(app.myPassport.hasErrors, "Should have errored, overlaps" );
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = 87059, "Should have errored, overlaps end" );
	
	pxyDwellDayRange2.setProxy(	Red,	//_colour : Integer;
								5,	//_lower : Integer;
								6	//_upper : Integer
								);
	
	app.myPassport.clearErrorsWarnings();
	app.myTrxCA.trxCreateDwellDayRange( pxyDwellDayRange2, dwellDayRange2, app.myPassport );
	self.assertTrueMsg(not app.myPassport.hasErrors, "Create of Dwell Days Range[2] gives : " &amp; app.myPassport.getErrorsAsString );
	delete pxyDwellDayRange2;
	
	app.cmsBeginLoad(loadState);
	pxyDwellDayRange2 := dwellDayRange2.pxyCreateUpdateProxy().CM_DwellDayRange;
	app.cmsEndLoad(loadState);
	pxyDwellDayRange2.setProxy(	pxySecondDwellDayRange.colour,	//_colour : Integer;
								pxySecondDwellDayRange.lower,	//_lower : Integer;
								pxySecondDwellDayRange.upper	//_upper : Integer
								);
	
	app.myPassport.clearErrorsWarnings();
	app.myTrxUA.trxUpdateDwellDayRange( pxyDwellDayRange2, app.myPassport );
	self.assertTrueMsg(not app.myPassport.hasErrors, "Update of Dwell Days Range[2] gives : " &amp; app.myPassport.getErrorsAsString );
	
	app.cmsBeginLoad(loadState);
	pxyDwellDayRange1 := dwellDayRange1.pxyCreateUpdateProxy().CM_DwellDayRange;
	app.cmsEndLoad(loadState);
	pxyDwellDayRange1.setProxy(	pxyFirstDwellDayRange.colour,	//_colour : Integer;
								pxyFirstDwellDayRange.lower,	//_lower : Integer;
								pxyFirstDwellDayRange.upper	//_upper : Integer
								);
	
	app.myPassport.clearErrorsWarnings();
	app.myTrxUA.trxUpdateDwellDayRange( pxyDwellDayRange1, app.myPassport );
	self.assertTrueMsg(not app.myPassport.hasErrors, "Update of Dwell Days Range[1] gives : " &amp; app.myPassport.getErrorsAsString );

epilog

	app.cmsEndLoad(loadState);
	delete pxyFirstDwellDayRange;
	delete pxySecondDwellDayRange;
	delete pxyDwellDayRange1;
	delete pxyDwellDayRange2;
	delete allDwellRanges;
	delete objectArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tLaborRestriction" id="1c7dd0bd-51c9-4a54-901b-91347cd1ac1c">
        <source>tLaborRestriction();
/*

Purpose:			

Date		Who		Reason
31/03/2014	cnwma1	Initial creation

*/

constants
	BlockStack  = "UTLRBS1";
	LabourRestrictionId	: String = "UTLR1";
vars
	bs					: CM_BlockStack;
	labourRestriction	: CM_LabourRestriction;
	pxyLabRestriction	: CM_LabourRestriction;
	lcArray				: CM_LCArray;
	restricationReason  : CM_LabourRestrictionReasonCode;
	organisation		: CM_Organisation;

begin

   
	// Add Block Stack
	bs := self.addBlockStack(BlockStack,500,null);
	self.assertNotNull(bs);
	
	// Restrication Reason
	restricationReason := self.getRoot.allLabourRestictionsCodes.first;
	self.assertNotNull(restricationReason);
	
	// Organisation
	organisation := self.getRoot.allOrganisations[UT_DSL.MasterTermOrg];
	self.assertNotNull(organisation);
	 
	create lcArray transient;
	lcArray.add(bs.myLocationsController);
	
	create pxyLabRestriction transient;
	pxyLabRestriction.setProxy(Green,								// Colour
							   app.getMyUserCode(),					// User code
							   "UnitTest Labour Restrication", 		// comment
							   null,								// hours
							   2, 									// days
							   restricationReason,					// reason
							   lcArray,					// location controllers
							   LabourRestrictionId,	// labour Restriction id
							   false,					// ignore lights
							   organisation,					// organisation
							   null,					// email entity
							   null,					//_emails : CM_EmailAddressByAddressDict;
							   bs);					// terminal area
							   
	self.assertNotNull(pxyLabRestriction);
	// create the labour restriction
	app.myTrxCA.trxCreateRestrictionLabour(pxyLabRestriction, labourRestriction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(labourRestriction);
	
	
	// Update Labour Restrication 
	updateLabourRestriction(labourRestriction);
	


epilog
	delete lcArray;
	delete pxyLabRestriction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPlanningOversize" id="4fdcf8dd-5ead-4e53-9c19-ab06d13e529a">
        <source>tPlanningOversize();

/*

Purpose:		Plan / Queue oversize to yard area.

Date			Who		Reason
14/04/2014		cnwmh5	Initial creation

*/

vars

	gbs						: CM_ForkLiftStack;
	bs						: CM_BlockStack;
	container				: CM_Container;
	container2				: CM_Container;
	container3				: CM_Container;
	ti						: CM_TrackedItem;
	
	tiArray					: CM_TIArray;
	

begin


	self.deleteTerminalArea("UTMHGBZ");
	gbs := self.addForkLiftStack("UTMHGBZ", 3, 5, 4);
	self.assertNotNull(gbs);
	
	self.deleteTerminalArea("UTMHBSZ");
	bs := self.addBlockStack("UTMHBSZ", 50, null);
	self.assertNotNull(bs);
	
	create tiArray transient;
	
	
	ti := self.getTrackedItem("UTMHZZ00001");
	self.deleteTrackedItem(ti, false);
	container := self.addContainerAtLocation("UTMHZZ00001", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()], 
		"2200", "GENL", TI_IMEX_STATUS_STORAGE, bs.myLocationsController);
	self.assertNotNull(container);
	tiArray.add(container);
	
	
	ti := self.getTrackedItem("UTMHZZ00002");
	self.deleteTrackedItem(ti, false);
	container := self.addContainerAtLocation("UTMHZZ00002", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()], 
		"2200", "GENL", TI_IMEX_STATUS_STORAGE, bs.myLocationsController);
	self.assertNotNull(container);
	tiArray.add(container);
	
	
	ti :=self.getTrackedItem("UTMHZZOV001");
	self.deleteTrackedItem(ti, false);
	container2 := self.addContainerAtLocation("UTMHZZOV001", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()], 
		"2490", "GENL", TI_IMEX_STATUS_STORAGE, gbs.allGridControllersByRowColumn[1, 1]);
	self.assertNotNull(container2);
	ti := container2;
	self.updateTIDimensions(ti, 15, 15, 15, 15, 15, 0, false);
	self.opts.purge();
	self.opts.addAssoc("OverDimension", true);
	self.updateTI(container2);
	
	
	ti :=self.getTrackedItem("UTMHZZOV002");
	self.deleteTrackedItem(ti, false);
	container3 := self.addContainerAtLocation("UTMHZZOV002", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()], 
		"2490", "GENL", TI_IMEX_STATUS_STORAGE, gbs.allGridControllersByRowColumn[1, 3]);
	self.assertNotNull(container3);
	ti := container3;
	self.updateTIDimensions(ti, 15, 15, 15, 15, 15, 0, false);
	self.opts.purge();
	self.opts.addAssoc("OverDimension", true);
	self.updateTI(container3);
	
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Cannot_contain_underne_overhei);
	self.move(tiArray[1], gbs.allGridControllersByRowColumn[1, 1]);
	
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Cannot_contain_underne_overhei);
	self.movePlanned(tiArray[1], gbs.allGridControllersByRowColumn[1, 1]);
	
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Cannot_contain_underne_overhei);
	self.moveQueued(tiArray[1], gbs.allGridControllersByRowColumn[1, 1]);
	
	self.clearExpectedTrxErrors();
	
	ti := container2;
	self.updateTIDimensions(ti, 0, 0, 0, 0, 0, 0, false);
	self.move(tiArray[1], gbs.allGridControllersByRowColumn[1, 1]);
		
	
	self.move(tiArray[1], bs.myLocationsController);
	self.movePlanned(tiArray[1], gbs.allGridControllersByRowColumn[1, 1]);
		
	
	self.unplanTI(tiArray[1]);
	//self.move(tiArray[1], bs.myLocationsController);
	self.moveQueued(tiArray[1], gbs.allGridControllersByRowColumn[1, 1]);
	
epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tROROLaneReOrdering" id="9f55cc5f-2f7b-4202-99cb-feda506760df">
        <source>tROROLaneReOrdering();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2020	jlgndl1	Initial creation	TFS 48270 - Speed up RORO Lane re0rdering by removing
									the multiple updates that lock the tis in big re-orders

*/
constants

	BlockStack = "UTBSCAR";
	RoroArea = "UTROROCAR";
	CarPrefix = "UTCOBRA";
	
vars

	right : String;
	left : String;
	direction : String;
	roroLane : CM_RoRoController;
	roroArea : CM_RoRoLaneArea;
	ti : CM_TrackedItem;
	bs : CM_BlockStack;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	index : Integer;
	lc : CM_LocationsController;
	tiId : String;
	ti19 : CM_TrackedItem;
	ti20 : CM_TrackedItem;

begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "Operator is null in setup");
	
	cargoType := self.getCargoType("CAR");
	self.assertNotNullMsg(cargoType, "Cargo type is null in setup");

	//clean-up
	foreach index in 1 to 20 do 
		tiId := CarPrefix &amp; index.padLeadingWith('0',3);
		deleteCargo( tiId, cargoType );
	endforeach;
	deleteTerminalArea(BlockStack);
	deleteTerminalArea(RoroArea);
	
	//create block stack with 2 cars in it (to test the move against)
	//Create a roro area with 2 lanes in it and 9 cars in each ( to check the shuffling against)
	
	bs := self.addBlockStack(BlockStack, 100, null);
	self.assertTrueMsg( bs &lt;&gt; null, BlockStack &amp; " block stack not created in setup");
	roroArea := self.addROROArea(RoroArea, 2, 100);
	self.assertTrueMsg( roroArea &lt;&gt; null, RoroArea &amp; " RoRo Lanes not created in setup");
	
	foreach index in 1 to 20 do 
		tiId := CarPrefix &amp; index.padLeadingWith('0',3);
		if index.isOneOf(19,20) then
			lc := bs.allLocationsControllers.first;
		elseif index &lt;= 9 then
			lc := roroArea.allLanesById.first;
		else
			lc := roroArea.allLanesById.last;
		endif;
		ti := self.addCargoAtLocation( tiId, cargoType, operator, lc);
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " Car not created in setup");
		if index = 19 then
			ti19 := ti; //1st ti in the block stack
		elseif index = 20 then
			ti20 := ti;	//2nd ti in the block stack
		endif;
		beginTransaction;
			ti.setTotalQuantity(1);
			ti.setTotalWeightWithoutTrans(1800);
			ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
		commitTransaction;
	endforeach;
	
	right := roroArea.rightLabel;
	left := roroArea.leftLabel;
	
	//use trxRoroVehicleConfirm to move one of the bs cars to the 1st roro lane using left to right i.e. walking/confirming the same way as the cars are stored
	roroLane := roroArea.allLanesById.first;
	direction := left &amp; " to " &amp; right;
	
	app.myTrxUA.trxRoroVehicleConfirm(ti19,roroLane,null,direction,false,false,null,null,null,null);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "'NON Shuffle' Vehicle Confirm to RORO lane failed with - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	//check the order - should add to the LAST position in the allTrackedItems array
	self.assertTrueMsg( roroLane.allTrackedItems.last = ti19, ti19.id &amp; " should have been added to the last position in the roro lane");
	
	
	//use trxRoroVehicleConfirm to move the second of the bs cars to the 2nd roro lane using right to left i.e. walking/confirming the OPPPOSITE direction to the way as the cars are stored
	roroLane := roroArea.allLanesById.last;
	direction := right &amp; " to " &amp; left; //causes the shuffle


//process.profiler.start();
	app.myTrxUA.trxRoroVehicleConfirm(ti20,roroLane,null,direction,false,false,null,null,null,null);
//process.profiler.stop();
//process.profiler.report();
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "'Shuffle version' of Vehicle Confirm to RORO lane failed with - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	//check the order - should add to the FIRST position in the allTrackedItems array
	self.assertTrueMsg( roroLane.allTrackedItems.first = ti20, ti20.id &amp; " should have been added to the first position in the roro lane");
	
	
	app.myTrxUA.trxRoroVehicleConfirm(ti19,roroLane,null,direction,false,false,null,null,null,null);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "2nd 'Shuffle version' of Vehicle Confirm to RORO lane failed with - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( roroLane.allTrackedItems[1] = ti19, ti19.id &amp; " should have been added to the first position in the roro lane(2nd shuffle)");
	self.assertTrueMsg( roroLane.allTrackedItems[2] = ti20, ti20.id &amp; " should have been moved to the second position in the roro lane(2nd shuffle)");
	
	//We were successfull, so clean-up
	foreach index in 1 to 20 do 
		tiId := CarPrefix &amp; index.padLeadingWith('0',3);
		deleteCargo( tiId, cargoType );
	endforeach;
	deleteTerminalArea(BlockStack);
	deleteTerminalArea(RoroArea);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tRtgWorkZone" id="947c525c-7b0c-450d-ab4e-12e323463d47">
        <source>tRtgWorkZone();
/*

Purpose: Update RTG Work Zone 	

Date		Who		Reason
02/04/2014	cnwma1	Initial creation

*/

vars
	 rtgArea	: CM_RTGArea;
	 rtg		: CM_Machine;
	 startCol	: CM_RTGColumn;
	 endCol		: CM_RTGColumn;
	 tas: StringArray;
	 	rtgAreaQueue		: CM_RadioTelemetryQueue;
	 

begin

	deleteTerminalArea("950");
	rtgArea := self.addRTGArea("950",6,40,5);
	self.assertNotNull(rtgArea);
	
	self.deleteQueue("MAQueue");
	rtgAreaQueue := self.addQueueToTA("MAQueue", rtgArea);
		
	
	create tas transient;
	tas.add("950"); 
	
	deleteMachine("125");
	rtg:=self.addMachine(MACHINETYPE_RTG, "125", 91, tas, "MAQueue");
	self.assertNotNull(rtg);
	
	beginTransaction;
	rtg.setPropertyValue(CM_Machine::myPrimaryMachineQueue.name,rtgAreaQueue);
	commitTransaction;
	startCol := rtgArea.allGridColumns[10].CM_RTGColumn;
	endCol := rtgArea.allGridColumns[35].CM_RTGColumn;
	
	

	app.myTrxUA.trxUpdateRTGMachineWorkzones(rtg,startCol,endCol,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.assertEqual(rtg.allWorkzoneLocations.last.column, 35);
	
	
 epilog
    
  delete tas;


 
end;</source>
    </JadeMethod>
    <JadeMethod name="tSatViewYAPopup" id="51827015-507e-4490-a10b-c7cd909242c2">
        <source>tSatViewYAPopup();
// cnwndl1
/*
Purpose: Test the free space displayed by the Satellite View YA Popup pane

Date		Who		Reason
14 April 2011	cnwdw1	// CCMS CPL 2059
*/
vars
	frame: Frame;
	yardSchema: Schema;
	klass: Class;
	ya: CM_YardAllocation;
	locations: CM_LCArray;
	yaBlockLocations: CM_LCArray;
	ta: CM_StraddleStack;
	cmifYABlock: CMIF_YABlock;
	bs: CM_BlockStack;
	is30IncludedForReports : Integer;
	is45IncludedForReports : Integer;
	is53IncludedForReports : Integer;
begin
	write PointArray.lastInstance;
	yardSchema := rootSchema.getSchema("YardSchema");
	klass := yardSchema.getClass("YRD_ContainerOverDrawingFrame");
	create frame as klass;
	assertNotNull(frame);
	
	self.setTerminalConfig(Is30IncludedForReports, 1);
	self.setTerminalConfig(Is45IncludedForReports, 1);
	self.setTerminalConfig(Is53IncludedForReports, 1);

	ta := self.addStraddleStack("USTA", 8, 10, 4);
	bs := self.addBlockStack("UBS1", 10, null);
	
	create locations transient;
	locations.add(ta.allGridControllersByName["020002"]);
	locations.add(ta.allGridControllersByName["040003"]);
	locations.add(ta.allGridControllersByName["060002"]);
	locations.add(ta.allGridControllersByName["080003"]);
	locations.add(bs.getLocationsController);

	ya := self.addYA1("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	assertEqual(ya.allYABlocksIn.size, 3);
	
	create cmifYABlock transient;
	create yaBlockLocations transient;
	ya.allYABlocksIn.first.allYardControllers.copy(yaBlockLocations);
	frame.sendMsgWithParams("updateFreeStats", cmifYABlock, yaBlockLocations);
	assertEqual(cmifYABlock.myStatistics.c20Free, 24);
	assertEqual(cmifYABlock.myStatistics.c40Free, 12);
	assertEqual(cmifYABlock.myStatistics.c30Free, 12);
	assertEqual(cmifYABlock.myStatistics.c45Free, 0);
	assertEqual(cmifYABlock.myStatistics.c53Free, 0);
	
	yaBlockLocations.clear();
	delete cmifYABlock;
	create cmifYABlock transient;
	ya.allYABlocksIn.last.allYardControllers.copy(yaBlockLocations);
	frame.sendMsgWithParams("updateFreeStats", cmifYABlock, yaBlockLocations);
	// Non gridded areas (ie blockstack) do not have feree space calculated doe container lengths
	assertEqual(cmifYABlock.myStatistics.c20Free, 0);
	assertEqual(cmifYABlock.myStatistics.c40Free, 0);
	assertEqual(cmifYABlock.myStatistics.c30Free, 0);
	assertEqual(cmifYABlock.myStatistics.c45Free, 0);
	assertEqual(cmifYABlock.myStatistics.c53Free, 0);

epilog

	delete locations;
	delete frame;
	delete cmifYABlock;
	delete yaBlockLocations;
	write PointArray.lastInstance;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateBlockStack" id="69a71160-d4da-4587-a0ce-8cc8af26f0ad">
        <source>tUpdateBlockStack();
/*

Purpose: Update Block Stack [Mark Area is Full] option			

Date		Who		Reason
07/04/2014	cnwma1	Initial creation
08/04/2010  cnwma1	Set Terminal Area Flag  Suitable to Load Into
08/04/2014	cnwma1	Update Terminal Area FIFO Date
*/
constants
	BlockStack = "UTBS005";
	CNTR = "CRXU800900";
	ProductCargo = "UT Product";
vars
	
	bs,bs2 : CM_BlockStack;
	fullArea : Boolean;
	ti		 : CM_Cargo;
	product	 : CM_Product;
	cargoId  : String;
begin

	// Delete Block Stack
	//self.deleteContainer(CNTR );
	cargoId := CNTR;							// 16/04/2015 cnwmh5
	self.deleteTrackedItem(cargoId, false);
	self.deleteTerminalArea(BlockStack);
	self.deleteProduct(ProductCargo,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

								
	
	//Create Bloack Stack
	bs := self.addBlockStack(BlockStack,888,null);
	self.assertNotNull(bs);
	

	
	product := addProduct(ProductCargo, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

		ti := self.addCargoAtLocation(CNTR, product, product.myOperator, bs.myLocationsController).CM_Cargo;
	assertLocationHasTI(bs.myLocationsController, 	ti);
	
	
	// Update BlockStack Mark Area a full
	
	fullArea := true;
	
	app.myTrxUA.trxUpdateBlockstackFull(bs,fullArea,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(bs.isFull,true);
	
	// Update Terminal Area Flag
	
	app.myTrxUA.trxUpdateTerminalAreaFlag(bs,true,false,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrue(bs.isSuitableForLoadFrom);
	
	//  Update Terminal Area FIFO Date

	app.myTrxUA.trxUpdateBlockstackFIFODate(bs,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog

end;</source>
    </JadeMethod>
