    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isIgnoreState" id="647e930e-4889-4d84-81a1-4b36a154261f">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
        <text>On the gotFocus event, this flag is set in order that the "text" mapping
method won't overwrite the formatting of the currency value back to a
numeric value for editing.  The flag is unset after formatting.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="myCurrencyFormat" id="dfc8e30b-877c-4191-8731-105faa7863a1">
