    <JadeMethod name="doAddAction" id="4202b5f0-f9e1-447f-8fa5-32ff71eb7fee">
        <source>doAddAction(_table :CM_DataTable input) protected;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
15/10/2012	cnwcs5	par 30483 - tab key does not work when table has no data
03/07/2013	cnwcs5	par 31942 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	rows		:Integer;
begin
	// add a rows to the table and create a proxy for it
	rows		:= _table.rows + 1;
	_table.rows 	:= rows;
	
		
	_table.clearAllSelected;
	
	_table.selectRow (rows, true);
	if _table.accessCell(rows, 1).cellControl = null then		// TFS 2566
		_table.accessCell(rows, 1).comboIndex	:= 1;
	endif;														// TFS 2566
	_table.column							:= 1;			// so they can select value
	_table.tabKey							:= J_key_Tab;	// par 30483 oct 2012						
	_table.setFocus;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="414e1e6e-cf62-4e28-a10f-69a5a91fadc1">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	inheritMethod();

	self.unloadForm;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="0ac400bc-105f-4384-9bab-b57726aa4b8c">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	party, proxy	:CM_EDIParty;
	result			:Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	party 	:= self.myCurrentEDIParty;
	
	if party &lt;&gt; null then	
		beginTransaction;
		proxy := party.pxyCreateUpdateProxy;
		commitTransaction;
	else
		create proxy transient;
	endif;
	
	self.setProxyFromForm (proxy);
	
	while true do		
		if party = null then
			app.myTrxCA.trxCreateEDIParty(proxy, party, app.myPassport);
		else
			// updating
			app.myTrxUA.trxUpdateEDIParty(proxy, app.myPassport);
		endif;
		
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog	
	delete proxy;
	
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteAction" id="9f013f8e-0358-43df-b6eb-5467db679665">
        <source>doDeleteAction(_table :CM_DataTable input) protected;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
15/10/2012	cnwcs5	par 30483 - tab key does not work when _table has no data
03/07/2013	cnwcs5	par 31942
*/
vars
	row		:Integer;
	proxy	:CM_EDIEDIFactRule;
begin
	// delete _table row 
	row	:= _table.row;

	if row &lt;= _table.fixedRows or not _table.accessRow (row).selected then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;
	endif;
	
	_table.clearAllSelected;
	_table.deleteRow (row);
	
	// par 30483 Oct 2012 - tab key only works when _table has non-fixed rows
	if _table.rows = _table.fixedRows then
		_table.tabKey := null;
	else
		_table.tabKey := J_key_Tab;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteActionMulti" id="6efe39d6-da08-4d38-9a6c-b0447950ee04">
        <source>doDeleteActionMulti(_table :CM_DataTable input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2024	navsp1	Initial creation MTN-33228

*/
vars
	row				: Integer;
	obj				: Object;
	invalidObject 	: Boolean;
	size 			: Integer;
	deleteCount		: Integer;
begin

	size := _table.rows;
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	foreach row in size to (_table.fixedRows + 1)step-1 do		
		if _table.accessRow(row).selected then
			_table.deleteRow(row);
			deleteCount+=1;							//MTN-33537
		endif;
	endforeach; 
	
	if _table.rows = _table.fixedRows then
		_table.tabKey := null;
	else
		_table.tabKey := J_key_Tab;
	endif;
	
	if deleteCount &gt; 0 then							//MTN-33537
		self.btnShowLoadFile.enabled	:= false;	//MTN-33537
	endif;											//MTN-33537
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadNewFile" id="48b8bad9-b7c8-4ed2-9fca-da2f5cc4bf6e">
        <updating/>
        <source>doLoadNewFile(_copyToServer :Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2024	navsp1	Initial creation MTN-33228

*/

vars
	errorMsg	: String;
begin
	on FileException do self.xHandlerFileOpen(exception, errorMsg);

	errorMsg	:=	null;
	self.processHSCodeFile(_copyToServer);
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_copyToServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectItem" id="e291a481-9bb2-4aac-815b-0752df41e0dd">
        <source>doSelectItem(_table :Table input; _row, _type :Integer) protected;
/*
Date		Who		Reason
07 Dec 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
04 Jul 2013	cnwcs5	par 31942
*/
vars
	item, list, text	:String;
begin
	item 	:= _table.getCellText (_row, 1);
	list	:= self.getComboListForItem (item, _type);
	
	_table.accessCell (_row, 3).comboList := list;
	
	text := _table.accessedCell.text;
	
	if text &lt;&gt; null and list.pos (text, 1) = 0 then
		_table.accessedCell.text := null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSelectItem315" id="9b7ad647-b0ab-4428-b6d0-c1265552aa79">
        <source>doSelectItem315(_table :Table input; _row, _type :Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation

*/

vars
	item, 
	list, 
	stop,
	text	:String;
	stopsTable : CM_StopsTable;
begin
	item 	:= _table.getCellText (_row, 1);
	list	:= self.getComboListForItem (item, _type);
	stop 	:= _table.getCellText (_row, 4);
	_table.accessCell (_row, 3).comboList := list;
	
	text := _table.accessedCell.text;
	
	//list := self.getToDoTaskComboList();
	
	stopsTable := self.getStopsTableFromHeading(stop);
	

	self.cmbStopTable.listObject := stopsTable;
	
	if text &lt;&gt; null and list.pos (text, 1) = 0 then
		_table.accessedCell.text := null;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSelectItemCuscar" id="6b27b5af-a594-4240-a17f-db893366dda5">
        <source>doSelectItemCuscar(_table :Table input; _row, _type :Integer) protected;
/*
Date		Who		Reason
07 Dec 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
04 Jul 2013	cnwcs5	par 31942
*/
vars
	item, 
	list, 
	todo,
	text	:String;
	todoTaskDesc : CM_ToDoTaskDesc;
begin
	item 	:= _table.getCellText (_row, 1);
	list	:= self.getComboListForItem (item, _type);
	todo 	:= _table.getCellText (_row, 5);
	_table.accessCell (_row, 3).comboList := list;
	
	text := _table.accessedCell.text;
	
	//list := self.getToDoTaskComboList();
	
	todoTaskDesc := self.getToDoTaskDescFromDesc(todo);
	

	self.cmbToDoTask.listObject := todoTaskDesc;
	
	if text &lt;&gt; null and list.pos (text, 1) = 0 then
		_table.accessedCell.text := null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSysNotify" id="bda8fac9-0d1c-498c-82c1-bdc6642c3168">
        <updating/>
        <source>doSysNotify(_event :Integer; _party :CM_EDIParty; _tag :Integer)updating, protected;
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	if _event = Object_Delete_Event then
		app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, app.getErrorString (EDI_Party)), 
					app.getErrorString (Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
		
		self.doBaseFormCancel;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_party" type="CM_EDIParty"/>
        <Parameter name="_tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="e7442395-9a22-4d80-a132-de66e15451cb">
        <updating/>
        <source>doUserNotify(_event :Integer; _party :CM_EDIParty; _tag :Integer)updating, protected;
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	if _event = EDI_PARTY_UPDATE_EVENT then
		if self.canUpdate then
			if app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, app.getErrorString (EDI_Party)), 
								app.getErrorString (Warning), 
								MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
				// reload data
				self.loadData (_party);
			else
				self.doBaseFormCancel;
			endif;
		else
			// they can't change anything so re-load silently
			self.loadData (_party);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_party" type="CM_EDIParty"/>
        <Parameter name="_tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getComboListForItem" id="b5b31b1f-18bc-4875-964b-3ee16afa7a87">
        <source>getComboListForItem(_item :String; _type :Integer):String protected;
/****Changes

Date		Name	TFS#			Description
============================================================================
07 Dec 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
13/09/2012	cnwcs5	CCMS POL 2216 - changes for functional spec
24/09/2012	cnwcs5	ccms pol 2097 - changes for functional spec
12/12/2012  cnwgb1  CCMS POL 2216 - Implement
28/02/2013	cnwcs5	CCMS POL 2220 - Changes for functional spec
25/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - 
03/07/2013	cnwcs5	par 31942 - 	FTX segment processing for Coparn/IFTMCS bookings
11 Sep 2014	cnwma1	PAR#34855 		CCMS 2351: Hapag-Lloyd Release Request Enhancements
14 Jun 2016 cnwma1	TFS #2048		POL - HSD EDI Empty Release Request
21 Aug 2017	jlgrs1	TFS 6564 		add Coparn and Coreor RFF and NAD translation
31 Aug 2017	jlgrs1	TFS 6797 		SNO SpecialStow
30 May 2018	jlgrs1	TFS 38357 		SNO Fix Xlations from TFS 6797
08 Jun 2018	jlgrs1	TFS 39018		SNO Cargo Operator in COPRAR
06 Nov 2018	jlgka1	39185, 39187	Add IFCSUM Action rule for FTX+AAA.
14 Feb 2019	jlggb1	43427 			Missing COPARN REL_1_1 rules. Reformat so we we can see what's going on
22/05/2019	jlgka1	TFS 42732		PNL - CUSCAR Bayplan Style.
============================================================================*/
vars
	str	:String;
begin
	str := str &amp; Tab;	// empty first entry
	
	if _item = CM_EDIEDIFactRule.Item_UNH_1_1 then  	//cnwma1 TFS #2048 14/06/2016 
		str := str  &amp; CM_EDIEDIFactRule.Function_UNH_1_1_Booking_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_UNH_1_1_Release_Desc;
		
	elseif _item = CM_EDIEDIFactRule.Item_BGM_1_1 then
		str := str  &amp; CM_EDIEDIFactRule.Function_BGM_1_1_Booking_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_BGM_1_1_Release_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_BGM_1_1_Prenote_Desc; //epr TFS 2744 13/2/17
		
	elseif _item = CM_EDIEDIFactRule.Item_DTM_1_1 then
		str := str 	&amp; CM_EDIEDIFactRule.Function_DTM_1_1_ReqDT_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_DTM_1_1_EstReqDT_Desc;
	
	elseif _item = CM_EDIEDIFactRule.Item_RFF_1_1 then //11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
		if _type = EDIFileType_Coparn then
			str := str	&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_Release_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_BOL_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_CarrierRef_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_CustomerRef_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_Sequence_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Function_RFF_1_1_RELNo_Desc;
		elseif _type = EDIFileType_Coreor then
			str := str 	&amp; CM_EDIEDIFactRule.Fnct_RFF_1_1_EntryNumber_Desc;
		endif;
		
	elseif _item = CM_EDIEDIFactRule.Item_NAD_1_1 then 
		if _type = EDIFileType_Coparn then
			str := str	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam_Desc &amp; Tab 
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef_Desc;
		elseif _type = EDIFileType_Coreor then
			str := str	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc;
		elseif _type = EDIFileType_Coprar then
			str := str 	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef_Desc;
		elseif _type = EDIFileType_CusCar then									// jlgka1 TFS 42732 --&gt;
			str := str &amp; CM_EDICUSCARRule.Function_NAD_1_1_ConsigneeDesc;
		endif;																	// jlgka1 TFS 42732 &lt;--		
	elseif _item = CM_EDIEDIFactRule.Item_NAD_2_1 then 
		if _type = EDIFileType_Coparn then
			str := str 	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef_Desc;
		elseif _type = EDIFileType_Coprar then
			str := str 	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef_Desc;
		endif;
		
	elseif _item = CM_EDIEDIFactRule.Item_NAD_3_1 then 
		if _type = EDIFileType_Coparn then
			str := str 	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef_Desc;
		elseif _type = EDIFileType_Coprar then
			str := str 	&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam_Desc &amp; Tab
						&amp; CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef_Desc;
		endif;
		
	elseif _item = CM_EDIEDIFactRule.Item_MEA_3_2 then         //CCMS 2216 30902 cnwgb1
		str := CM_EDIEDIFactRule.Function_MEA_3_2_Heavy_Desc;
		
	elseif _item = CM_EDIEDIFactRule.Item_FTX_1_1 then         //CCMS 2220 cnwcs5 Feb 2013   
		if _type = EDIFileType_CusCar then 							// jlgka1 TFS 42732 --&gt;
			str := CM_EDICUSCARRule.Function_FTX_1_1_RemarksDesc
				&amp; Tab &amp; CM_EDICUSCARRule.Function_FTX_1_1_DescriptDesc;	//29 Jan 2020	NDL	TFS 48360
		else							  							// jlgka1 TFS 42732 &lt;--
			str := CM_EDIEDIFactRule.Function_FTX_1_1_BkRemark_Desc; 
		endif;							
 	elseif _item = CM_EDIEDIFactRule.Item_FTX_3_1 then	//07 Jun 2017	NDL	TFS 4454
		if _type = EDIFileType_Coparn then
			str := CM_EDIEDIFactRule.Function_FTX_3_1_Stowage_Desc;
		elseif _type = EDIFileType_Coprar then
			str := CM_EDIEDIFactRule.Function_FTX_3_1_Stowage_Desc;
		endif;
		
	elseif _item = CM_EDIEDIFactRule.Item_FTX_21_1 then		//jlgka1 TFS 39187, 39185 --&gt;
		if _type = EDIFileType_IFCSUM94B then					
			str := 	  CM_EDIEDIFactRule.Function_FTX_21_1_Mafis_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_FTX_21_1_IgnoreSegDsc;	
		endif;//jlgka1 TFS 39187, 39185 &lt;--
		
	elseif _item = CM_EDIEDIFactRule.Item_FTX_4_1 then         //CCMS 2216 30902 cnwgb1 
		if _type = EDIFileType_Coparn then
			str := 	  CM_EDIEDIFactRule.Function_FTX_4_1_Heavy_Desc &amp; Tab  
					&amp; CM_EDIEDIFactRule.Function_FTX_4_1_MTGText_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_FTX_4_1_BkIgnore_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_FTX_4_1_EstReqDT_Desc &amp; Tab   //cnwma1 TFS #2048 14/06/2016 
					&amp; CM_EDIEDIFactRule.Function_FTX_4_1_BookVent_Desc ;
		elseif _type = EDIFileType_IFTMCS03A then
			str :=    CM_EDIEDIFactRule.Function_FTX_4_1_BkIgnore_Desc &amp; Tab 
					&amp; CM_EDIEDIFactRule.Function_FTX_4_1_BookVent_Desc;		
		endif;
				
	elseif _item = CM_EDIEDIFactRule.Item_TMP_1_1 then        // ccms pol 2097 par 31259
		str :=    CM_EDIEDIFactRule.Function_TMP_1_1_MTGTemp_Desc;  
		
	elseif _item = CM_EDICUSCARRule.Item_LOC_1_1 then //cnwrd1 par 34193
		str :=    CM_EDICUSCARRule.Function_LOC_1_1_TODO_Desc;
		
	elseif _item = CM_EDI315Rule.Item_B403 then
		str := 	  CM_EDI315Rule.Function_B403_StopAdd_Desc &amp; Tab
				&amp; CM_EDI315Rule.Function_B403_StopRemove_Desc;
				
	elseif _item = CM_EDI315Rule.Item_N903 then
		str := 	  CM_EDI315Rule.Function_N903_CreateRelease_D;
		
	elseif _item = CM_QatarRule.Item_Qatar then	//29 Jun 2015	NDL	Par 36543
		str := 	  CM_QatarRule.Function_ImportReleaseStopDesc &amp; Tab
				&amp; CM_QatarRule.Function_ExportReleaseStopDesc &amp; Tab
				&amp; CM_QatarRule.Function_ImportBayanStopDesc &amp; Tab
				&amp; CM_QatarRule.Function_ExportBayanStopDesc;
	endif;
		
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNewHSCodeFile" id="e2abedbe-b408-4d67-9f6b-5d36d5e71c4b">
        <source>getNewHSCodeFile():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2024	navsp1	Initial creation MTN-33228

*/

vars
	fileGet		 		: CMDFileOpen;
begin
	create fileGet;
	fileGet.cnEcSetFilters( true, 1, CNEC_FILE_FILTER_DATA, CNEC_FILE_FILTER_TEXT);
	fileGet.fileName := '';
	fileGet.initDir := self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	if fileGet.open = CMDialog.Return_OK then
		self.txtFileName.text := fileGet.fileName;
		return true;			//MTN-33537
	else
		self.txtFileName.text := null;
		return false;			//MTN-33537
	endif;
epilog
	delete fileGet;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProxyEDIPartyRules" id="b37b5ad1-61ca-4d41-890c-563a240c51a3">
        <source>getProxyEDIPartyRules(_proxy : CM_EDIParty; _type : Integer) : CM_EDIPartyRules protected;
/*
Date		Who		Reason
22 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
04 Jul 2013	cnwcs5	par 31942
03 Jun 2015 cnwma1  PAR #36337  CCMS 2502 TFS 375  DPH - Consignor in the N1*SH
06 Jul 2015 cnwma1 PAR# 36526 Patch for Baplie File MEA segment
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 31 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/
vars
	rules	:CM_EDIPartyRules;
begin
	rules	:= _proxy.getRulesForFileType (_type);
	
	if rules = null then
		if _type = EDIFileType_Coparn then
			create rules as CM_EDIPartyCoparnRules transient;
		elseif _type = EDIFileType_IFTMCS03A then
			create rules as CM_EDIPartyIFTMCSRules transient;
		elseif _type = EDIFileTypeX12_315_4010 then
			create rules as CM_EDIPartyX12315Rules transient;		
		elseif _type = EDIFileType_Coprar then
			create rules as CM_EDIPartyCoprarRules transient;
		elseif _type = EDIFileType_Coreor then
			create rules as CM_EDIPartyCoreorRules transient;
		elseif _type = EDIFileType_CusCar then
			create rules as CM_EDIPartyCuscarRules transient;
		elseif _type = EDIFileTypeX12_301_4010 then    //27/05/2015 cnwma1 PAR #36337
			create rules as CM_EDIPartyX12301Rules transient;
		elseif _type = EDIFileType_Baplie20 then       //6/07/2015 cnwma1 PAR #36526
			create rules as CM_EDIPartyBaplieRules transient;
		elseif _type = EDIFileType_XML_Milaha_Customs then	//29 Jun 2015	NDL	Par 36543
			create rules as CM_EDIPartyQatarRules transient;
		elseif _type = EDIFileType_IFCSUM94B then					// TFS 2566
			create rules as CM_EDIPartyIFCSUMRules transient;		// TFS 2566
		elseif _type = EDIFileTypeCAMIR_CustomsStatus then	//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
			create rules as CM_EDIPartyCAMIRRules transient;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid type');
		endif;
		
		rules.setMyEDIParty (_proxy);
		rules.setMyEDIConfig (self.myTerminal.myEdiConfig);
	endif;
	
	return rules;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_EDIParty"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getStopsTableFromHeading" id="fc56f750-566e-4e53-ade5-92f6b9038e9e">
        <source>getStopsTableFromHeading( _desc : String) : CM_StopsTable;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation

*/

vars
	aStopsTable : CM_StopsTable;
	found : Boolean;
begin

	foreach aStopsTable in app.myRoot.allStopsTable
		where aStopsTable.heading.trimBlanks = _desc do
			return aStopsTable;
		break;
	endforeach;

	return null;
	
epilog

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskDescFromDesc" id="71e08ac7-bc7e-4435-8fc3-32e764f5ac03">
        <source>getToDoTaskDescFromDesc(_desc : String) : CM_ToDoTaskDesc ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2014	cnwrd1	Initial creation

*/

vars
	toDoDesc : CM_ToDoTaskDesc;
	found : Boolean;
begin

	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions	where toDoDesc.type = TODO_TYPE_GROUP_TI and // ### TFS  #56634[54259] 22NOV2022 NAVAB1 
		toDoDesc.description.trimBlanks = _desc do
			return toDoDesc;
		break;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskDescFromShrtDesc" id="f49d2a0c-6126-49e4-bd41-bf186dc46eb8">
