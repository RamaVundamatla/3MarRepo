<GUIClass name="Label">
    <JadeMethod name="jssDate" id="ec7f2353-a666-421e-bf31-7f995a14cb2f">
        <source>jssDate():Date;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Date value.
//
// Parameters:	None
//
// Returns:		Date - the trimmed caption cast to a Date value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().Date;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="669660cd-e7d3-48d8-8125-e02af5b67343">
        <source>jssDecimal():Decimal;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Decimal value.
//
// Parameters:	None
//
// Returns:		Decimal - the trimmed caption cast to a Decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().jssRemoveSubstring(",").Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssInteger" id="22abee68-43b4-49a0-b5c3-bbcba112a23f">
        <source>jssInteger():Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Integer value.
//
// Parameters:	None
//
// Returns:		Integer - the trimmed caption cast to a Integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks().jssRemoveSubstring(",").Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssReal" id="1445c8ca-546b-463f-a27a-019201ecd86b">
