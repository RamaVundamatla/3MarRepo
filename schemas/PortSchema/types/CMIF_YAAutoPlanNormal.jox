    <JadeMethod name="getVoyage" id="5e546a90-4ec2-407e-9f99-e9b4410fa6f6">
        <source>getVoyage(): CM_Voyage;
// -------------------------------------------
// Created 14 September 2005 by cnwdvb1
// -------------------------------------------
/* Changed On	By			Reason
   ----------	--------	----------------------------------------
   12/05/2010	cnwdap1		CCMS 1116 Tranship changes  
*/
vars

begin

	//if self.myTrackedItem.myTranshipExport &lt;&gt; null then		// PAR #23645 CCMS 1116
	//	return self.myTrackedItem.myTranshipExport.myVoyage;	// PAR #23645 CCMS 1116
	if self.myTrackedItem.isTranshipExport then					// PAR #23645 CCMS 1116
		return self.myTrackedItem.myExportVoyage;				// PAR #23645 CCMS 1116
	endif;
	
	return self.myTrackedItem.myVoyage;


end;</source>
        <ReturnType type="CM_Voyage"/>
