    <JadeMethod name="tPostVoyageWithVesselHarbour" id="cf766400-b153-49aa-9c6e-7dce1b621c0b">
        <source>tPostVoyageWithVesselHarbour();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2024	navsaa30	Initial creation
24 July 2024 navsaa30 Task 64795: 64372 New Unit Test
*/


constants
OperatorCode = "LAUR";
VoyCode = "TEST64372";
VessCode = "VESS64372";
VoyageJson = '[{
"id": "'&amp;VoyCode&amp;'",
"arrivalDT" : "2023-04-05T16:02:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : "2023-04-10T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "'&amp;OperatorCode&amp;'",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
},
{
    "id": "AUPKL",
    "tranship": true
},
{
    "id": "KRINC",
    "tranship": true
},
{
    "id": "CNRZH",
    "tranship": false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"tradeId" : "Unit Test Trade",
"vessel" :{
"id" : "'&amp;VessCode&amp;'",
"imo" : "",
"name" : "Test Vessel for 64372",
"callSign" : "", 
"operatorId" : "'&amp;OperatorCode&amp;'",
"loa" : 100
}
}]';						// navsaa30
LoginJson = '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "REPLACE" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
vars
	root 					: CM_Root;
	terminalCode,
	loginJson,
	incomingJsonString		: String;
	expectFailure 			: Boolean;
	terminal 				: CM_Terminal;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;
	operator 				: CM_Operator;
	harbourData				: HMS_VesselDataHarbour;
	tidalClassArr,
	tidalClassDep			: HMS_TidalClass;
	harbour					: HMS_Harbour;
    pxyBerthPref,
    realBerthPref 			: HMS_BerthPreferenceVesselData;
    berth, preferredBerth	: HMS_Berth;
	arrivalMovement			: HMS_VoyageMovement;
begin
	root := self.getRoot();
	operator := root.allOperators[OperatorCode];
	self.assertNotNullMsg(operator, "Operator LAUR");
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := root.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "Terminal " &amp; terminalCode);
	harbour := terminal.myHarbour;
	self.assertNotNullMsg(harbour, "Harbour for Terminal " &amp; terminalCode);
	
	// Delete things first
	self.deleteVoyage(VoyCode);
	self.deleteVessel(VessCode);
	self.opts.purge();
	
	// Create a known vessel
	vessel := self.addVesselLOLOholdsRORO(VessCode, operator);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VessCode);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VessCode &amp; " HMS Data");
	
	// Check the vessel has tidal classes
	harbour := terminal.myHarbour;
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["B"];
	tidalClassDep := root.allTidalClasses["E"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	// Now give the vessel / harbour combination a berthing preference
	// Get a preferred berth that isn't the harbour's default arrival berth
	foreach berth in harbour.allBerths where berth &lt;&gt; harbour.defaultArrvBerth do
		preferredBerth := berth;
		break;
	endforeach;
	self.assertNotNullMsg(preferredBerth, "A berth that isn't the harbour's default arrival berth");
	
	create pxyBerthPref transient;
	pxyBerthPref.setProxy(20.0, 20.0, 120.0, OrientPortSideTo, preferredBerth, app.myPassport);
	beginTransaction;
	create realBerthPref persistent;
	realBerthPref.setForCreate(pxyBerthPref, app.myPassport); 
	harbourData.addBerthPreference(realBerthPref);
	commitTransaction;
	self.assertNotNullMsg(harbourData.allBerthPrefByName[preferredBerth.code], "Berth preference by name for berth " &amp; preferredBerth.code);
	self.assertNotNullMsg(harbourData.allBerthPrefByOrder.first, "Berth preference by order");
	self.assertEqualMsg(vessel.myHMSVesselData.allVesselDataForHarbour[harbour].allBerthPrefByName.size, 1, "Vessel HMS Data has wrong number of berth preferences");
	
	// POST /voyage with vessel having harbour details
	loginJson := LoginJson.replaceString("REPLACE", terminal.code);
	incomingJsonString := VoyageJson;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
	// Check results - voyage created successfully
	voyage := terminal.lookupVoyage(VoyCode, null, true);
	self.assertNotNullMsg(voyage, "Voyage " &amp; VoyCode);
	// Voyage has HMS Data
	self.assertNotNullMsg(voyage.myHMSVoyageData, "Voyage " &amp; voyage.code &amp; " HMS Data");
	// HMS Data has tidal classes
	self.assertNotNullMsg(voyage.myHMSVoyageData.myTidalClass, "Voyage Tidal Class Arrival");
	self.assertNotNullMsg(voyage.myHMSVoyageData.myTidalClassDept, "Voyage Tidal Class Departure");
	// Arrival berth is the default from the vessel
	arrivalMovement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.assertNotNullMsg(arrivalMovement, "Arrival Movement");
	self.assertEqualMsg(arrivalMovement.getMyBerth, preferredBerth, "Arrival Movement does not have berth preference berth " &amp; preferredBerth.code);
	
epilog
	delete hms_VesselDataHarbour;
	delete pxyBerthPref;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostWorkPointJobSheet" id="1ca1ac49-fced-4f35-8314-288a0852763d">
        <source>tPostWorkPointJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 Jul 2023		navlw1	ChangeRequest 58336: [58935] EUP | LMS Gang API - Endpoint Unit Tests
14 Mar 2024		naviv1  Bug 62922 - Bug 62922 - Bug 62922 - EUP | FR - LMS to MTN Interface 
*/
constants
WPJS = "DUB-A01J";
JsonBody = '{
  "id": "DUB-A01N",
  "shift": {
    "startDT": "2023-07-17T08:00:00Z",
    "endDT": "2023-07-17T16:00:00Z",
    "code": "Shift-A",
    "description": "Shift-A"
  },
  "workPointId": "CFS1",
  "reference1": "EXT1",
  "reference2": "EXT2",
  "reference3": "EXT3"
}';

vars
	terminal 			: CM_Terminal;
	expectFailure 		: Boolean;
	incomingJsonString,
 	loginJson,
	terminalCode,
	params,				
	startDT,
	endDT,
	jsonString 			: String;
	jobSheet			: CM_WorkPointJobSheet;
begin

	// set up
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	// date stuff
	startDT := app.actualTimeServer().utcToLocalTime().asJSONFormat;
	endDT := app.actualTimeServer().addDays(1).utcToLocalTime().asJSONFormat;
	
	jsonString := '{
  "id": "'&amp;WPJS&amp;'",
  "shift": {
    "startDT": "'&amp;startDT&amp;'",
    "endDT": "'&amp;endDT&amp;'",
    "code": "Shift-A",
    "description": "Shift-A"
  },
  "workPointId": "CFS1",
  "reference1": "EXT1",
  "reference2": "EXT2",
  "reference3": "EXT3"
}';
	
	jobSheet := terminal.getWorkPointJobSheet(WPJS);
	if jobSheet &lt;&gt; null then // only want to delete it if we find one
		app.myTrxDA.trxDeleteWorkPointJobSheet(jobSheet, app.myPassport);
	endif;
	self.deleteWorkPoint(WPJS);
	self.addWorkPoint("CFS1",false);
	
	self.opts.purge();
	
	// Test One create Work Point Job Sheet
	incomingJsonString := jsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostWorkPointJobSheet.name, loginJson, incomingJsonString, params, expectFailure);
	jobSheet := terminal.getWorkPointJobSheet(WPJS);
	self.assertNotNullMsg(jobSheet, "Jobsheet not created!");
	
	// Test Two shift checks expect an error  --- 14.03.2024 naviv1 #62922 -- Removing this test case, since the update of start/end datetime in the past date in allowed.
	/*self.opts.purge();
	incomingJsonString := JsonBody;
	expectFailure := true;
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; ERR_Shift_StartDT.String &amp; ". " &amp; app.getErrorString1(ERR_Shift_StartDT, "Shift"));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostWorkPointJobSheet.name, loginJson, incomingJsonString, params, expectFailure);*/
	
	// Test Three job sheet already exists expect error
	incomingJsonString := jsonString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; Exter_name_shoul_uniqu_work_po.String &amp; ". " &amp; app.getErrorString1(Exter_name_shoul_uniqu_work_po, "External Name"));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostWorkPointJobSheet.name, loginJson, incomingJsonString, params, expectFailure);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPutBarrierConfirmation" id="df9dfd3e-32f6-428b-bddf-7b18f800f7fd">
        <source>tPutBarrierConfirmation();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2024	navsp1	Initial creation TFS 61975
25 March 2024	navmd1	TFS 61975 Tweaks after spec'ing API. Rename from putProceedTruck to putBarrierConfirmation

*/
constants
	VEHICLEID 	= "REG75";
	DRIVERID 	= "DR75";
	REF 		= "61975";
	CONTAINERID = "CNTU6197501";
vars
	loginJson 			: String;
	terminalCode 		: String;
	queryString		 	: String;
	expectFailure 		: Boolean;
	regNumber 			: String;
	truck 				: CM_Vehicle;
	carrier 			: CM_Carrier;
	carrierCode 		: String;
	allCarriers 		: CM_CarrierByCodeDict;
	allVehicleMachines 	: CM_VehicleSet; 
	driver 				: CM_DriverDetails;
	dualGate 			: CM_Gate;
	vvr 				: CM_VehicleVisitRecord;
	bs1 				: CM_BlockStack;
	ct 					: CM_CargoType;
	pin, pout			: CM_GateArea;
begin
	
	terminalCode := self.getProfileStr(UT_Profile.P_TERMINAL).String;
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "unittest",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	//Initial setup
	self.deleteVehicle(VEHICLEID);
	self.deleteDriverDetails(DRIVERID);
	
	//Carrier
	carrierCode := self.getProfileStr(UT_Profile.P_CARRIER);
	carrier := app.myRoot.allCarriers[carrierCode];
	self.assertNotNull(carrier);
	
	//Add location
	bs1:=self.addBlockStack("BS"&amp;REF,999,null);
	
	//add cargo type
	app.myPassport.ignoreErrors();
	self.opts.purge;
	self.opts.addAssoc("AllowDuplicateId", true);
	ct:=self.addCargoType(REF, false);
	self.assertNotNull(ct);
	
	//API Call - Scenario 1 :	Raise exception if vehicle not found
	regNumber := "";
	queryString := 'MasterTerminalAPI&amp;direction=IN';	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :90371. Truck not found");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	

	
	//API Call - Scenario 2 :	Raise exception if direction is not specified
	regNumber := "";	
	queryString := 'MasterTerminalAPI';
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :96671. An input is required for the Direction field.");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	
	//API Call - Scenario 3 : Call API with an unknown registration number	
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=in';
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :90371. Truck not found");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	regNumber := "";	
	queryString := 'MasterTerminalAPI&amp;direction=Other';
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :96671. An input is required for the Direction field.");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	
	//Create Truck
	truck := self.addVehicle(VEHICLEID, carrier, self.getTerminal());
	self.assertNotNull(truck);	
	
	//Create driver details
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(truck);
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	
	//Gate
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);	
	
	//Truck
	truck:=self.getTerminal.vehicles[VEHICLEID,null];
	self.assertNotNull(truck);
	
	//In Gate
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);	
	self.assertNotNull(pin);
	
	//Out Gate
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	self.assertNotNull(pout);
	
	//******* API Call- Scenario : //Raise an exception if no vehicle visit found
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=IN';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :85925. Truck does not have a visit record.  Unable to be processed.");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	self.deleteContainer(CONTAINERID);
	//Create VVR
	self.opts.purge;
	self.opts.addAssoc("Location", bs1.myLocationsController.getFullId);
	vvr:=self.gateInContainer(VEHICLEID,CONTAINERID, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString,"MT",dualGate);
	self.assertNotNull(vvr);
	
	self.assertEqual(vvr.myRoadJob.status, JOB_UNACTIONED);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	
	//Delete the job entry
	self.deleteJob(vvr.myRoadJob);
	
	//API Call- Scenario : 	//Raise an exception if no road job found
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=IN';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :90008. The Truck REG75 does not have a Road Job");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	//Delete VVR
	self.deleteVVR(vvr);	
	
	//Create VVR
	self.opts.purge;
	self.opts.addAssoc("Location", bs1.myLocationsController.getFullId);
	vvr:=self.gateInContainer(VEHICLEID,CONTAINERID, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString,"MT",dualGate);
	self.assertNotNull(vvr);
	
	self.assertEqual(vvr.myRoadJob.status, JOB_UNACTIONED);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	
	//Move vehicle to lane
	self.moveVehicleToLane(vvr.vehicle, pin, 1);	
	
	//API Call - Scenario : Move vehicle to yard
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=IN';	
	self.opts.purge();
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
		
	//API Call- Scenario : 	Raise an exceptio if the request is for proceedToYard and the vehicle is inside the yard
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=IN';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :96647. Truck REG75 is already in the yard");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	//API Call - Scenario ; Raise an exception if the request is for the roadExit and the vehicle is not in the gate area
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=OUT';	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :84327. Vehicle must proceed to an outward gate lane prior to road exit'");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
	//Work Vehicle
	self.workVehicle(vvr);
	
	//Move vehicle to OUT gate
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
	
	//API Call - Road exit
	regNumber := VEHICLEID;	
	queryString := 'MasterTerminalAPI&amp;direction=OUT';	
	self.opts.purge();
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBarrierConfirmation.name, loginJson, regNumber, queryString, expectFailure);	
	
epilog
	delete allCarriers;
	delete allVehicleMachines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPutBooking" id="76344ff1-b741-4e4f-a6c1-3ebb6bfe1769">
        <source>tPutBooking();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2023	navpw1	Initial creation TFS: 57616 (57435)
08 March 2024 	naviv1	TFS: 62796 - CR - CUX | EDBIC - Modify Booking API to be independent of Prenotes
20 March 2024   navsp1  TFS ChangeRequest 63028: CUX | TK 62942 | EDBIC BOOKING APIs - Add field GoLiveCrit 01
*/

constants
	UTBookingRefOrig			: String = self.TFS57264 &amp; "OrigPUT";
	UTOperatorIdOrig			: String = "ABC";
	UTVoyageCodeOrig			: String = "********************";
	UTDestinationPortOrig		: String = "NZPOE";
	UTDischargePortOrig			: String = "NZAKL";
	UTConsignorCodeOrig			: String = "ACDG";
	UTConsigneeCodeOrig			: String = "PW";
	UTStevedoreCodeOrig			: String = "PW";
	UTFreightForwarderCodeOrig	: String = "FF1";
	UTRemarksOrig				: String = "Test Remarks";
	UTShippingReferenceOrig		: String = "EDBICSH";
	UTPackAsOrig				: String = "FCL";
	UTCustomsAgentOrig			: String = "PERT";
	
	UTBookingRef				: String = self.TFS57264 &amp; "PUT";
	UTOperatorId				: String = "UTOP";
	UTConsignorCode				: String = "UTCC1";
	UTConsigneeCode				: String = "UTCC2";
	UTDestinationPort			: String = "DEPOG";
	UTDischargePort				: String = "NZBLU";
	UTRemarks					: String = "Test Remarks 2";
	UTShippingReference			: String = "EDBICSH1";
	UTNoEmptiesOut				: Boolean = false;
	UTStatus					: Integer = 0;
	UTTransVoyageCode			: String = "********************";
	UTReceiveAsTranship			: Boolean = true;
	UTPackAs					: String = "FCL";
	UTCustomsAgent				: String = "TEST";
	UTDirectDelivery			: Boolean = false;
	UTFreightForwarderCode		: String = "UTCC1";
	UTCarrierCode				: String = "ACE";
	UTStevedoreCode				: String = self.TFS57264;
	UTStevedoreDescription		: String = self.TFS57264;
	UTVoyageCode				: String = self.TFS57264 &amp; "PUT";
	UTVesselCode				: String = self.TFS57264 &amp; "PUT";
	
	UTCargoType1				: String = "CONT";
	UTCargoIsoType1				: String = "22R1";
	UTCargoCommodityCode1		: String = "APA";
	UTCargoWeight1				: Integer = 2500;
	UTCargoDescription1			: String = "Test Description Reefer";
	UTCargoCurtains1			: Boolean = true;
	UTCargoCarbonDioxide1		: Decimal = 20;
	UTCargoHumidity1			: Decimal = 20;
	UTCargoOxygen1				: Decimal = 20;
	UTCargoVentilation1			: Decimal = 12;
	UTCargoVentUnits1			: Integer = 1;
	UTCargoPurchaseOrder1		: String = "EDBIC1";
	UTCargoRemarks1				: String = "Test Remarks field";
	UTCargoServiceOrder1		: String = "EDBICS1";
	UTCargoTemperature1			: Decimal = 0.5;
	UTCargoSpecialStow1			: String = "DIRR";
	UTCargoQuantity1			: Integer   = 2;	//TFS 63028
	
	UTCargoType2				: String = "CONT";
	UTCargoIsoType2				: String = "2200";
	UTCargoCommodityCode2		: String = "GENL";
	UTCargoWeight2				: Integer = 2500;
	UTCargoDescription2			: String = "Test Description 2";
	UTCargoPurchaseOrder2		: String = "EDBIC2";
	UTCargoRemarks2				: String = "Test Remarks field";
	UTCargoServiceOrder2		: String = "EDBICS2";
	UTCargoHazardCode2			: String = "2.2";
	UTCargoSpecialStow2			: String = "DIRR";
	UTCargoQuantity2			: Integer   = 3;	//TFS 63028
	
	UTCargoHazardCode			: String = "2.2";
	
	//Error Scenarios
	UTErrBookingRef				: String = self.TFS57264 &amp; "PUTErr";
	UTErrBookingRefNotFound		: String = self.TFS57264 &amp; "PUTNF";
	UTErrOperatorId				: String = "ABC";
	UTErrOperatorIdNotFound		: String = "ABCN";
	UTErrVoyageCode				: String = self.TFS57264 &amp; "PUT";
	UTErrVoyageCodeNotFound		: String = "RandomVoyage1";
	UTErrCargoType1				: String = "CONT";
	UTErrCargoTypeNotFound1		: String = "CONT12";
	UTErrHazardCode1			: String = "2.2";
	UTErrHazardCode1NotFound1	: String = "2.2223";
	UTErrSpecialStow1			: String = "DIRR";
	UTErrSpecialStowNotFound1	: String = "DIRR12";
	UTErrCargoType2				: String = "ALUM";
	UTErrCargoSubType2			: String = "SLAB";
	UTErrCargoSubTypeNotFound2	: String = "SLAB12";
	
	HappyDayScenarioPutMultiJson : String = '[
    {
        "id": "' &amp; UTBookingRef &amp; '",
        "cargo": [
            {
                "cargoTypeId": "' &amp; UTCargoType1 &amp; '",
                "cargoSubTypeId": null,
                "commodityId": "' &amp; UTCargoCommodityCode1 &amp; '",
                "isoTypeId": "' &amp; UTCargoIsoType1 &amp; '",
                "density": 0,
                "volume": 0,
                "weights": {
                    "gross": ' &amp; UTCargoWeight1.String &amp; ',
                    "net": 0,
                    "tare": 0
                },
                "dimensions": {
                    "height": 0,
                    "length": 0,
                    "width": 0
                },
                "colour": null,
                "curtains": false,
                "description": "' &amp; UTCargoDescription1 &amp; '",
                "generatorTypeId": null,
                "isoGroupId": null,
                "markNumber": null,
                "marks": null,
				"quantity": '&amp;UTCargoQuantity1.String&amp;',
                "onsiteCount": 0,
                "prenoteCount": 0,
                "purchaseOrder": "' &amp; UTCargoPurchaseOrder1 &amp; '",
                "remarks": "' &amp; UTCargoRemarks1 &amp; '",
                "serviceOrder": "' &amp; UTCargoServiceOrder1 &amp; '",
                "specialStow": "' &amp; UTCargoSpecialStow1 &amp; '",
                "trailerTypeId": null,
				"curtains": ' &amp; UTCargoCurtains1.String &amp; ',
				"reeferProperties": {
                    "carbonDioxide": ' &amp; UTCargoCarbonDioxide1.String &amp; ',
                    "humidity": ' &amp; UTCargoHumidity1.String &amp; ',
                    "oxygen": ' &amp; UTCargoOxygen1.String &amp; ',
                    "vent": ' &amp; UTCargoVentilation1.String &amp; ',
                    "ventUnits": ' &amp; UTCargoVentUnits1.String &amp; ',
					"temperature": ' &amp; UTCargoTemperature1.String &amp; '
                },
                "hazards": [
                    {
                        "id": "2.3",
                        "undgNumber": "0326, 0333",
                        "limitedQuantity": true,
                        "packingGroupId": "I",
                        "marinePollutant": 1,
                        "acidBase": "ACID",
                        "flashpointTemperature": 2
                    }
                ]
            },
        ],
        "carrierId": "' &amp; UTCarrierCode &amp; '",
        "consigneeId": "' &amp; UTConsigneeCode &amp; '",
        "consignorId": "' &amp; UTConsignorCode &amp; '",
        "customsAgentId": "' &amp; UTCustomsAgent &amp; '",
        "destinationPortId": "' &amp; UTDestinationPort &amp; '",
        "directDelivery": false,
        "dischargePortId": "' &amp; UTDischargePort &amp; '",
        "freightForwarderId": "' &amp; UTFreightForwarderCode &amp; '",
        "stockBooking": false,
        "operatorId": "' &amp; UTOperatorId &amp; '",
        "packAsType": null,
        "receiveAsTranship": ' &amp; UTReceiveAsTranship.String &amp; ',
        "releaseRequestId": null,
        "remarks": "' &amp; UTRemarks &amp; '",
        "shippingReference": "' &amp; UTShippingReference &amp; '",
        "status": 0,
        "stevedoreId": "' &amp; UTStevedoreCode &amp; '",
        "transhipOriginalVoyageId": "' &amp; UTTransVoyageCode &amp; '",
        "voyageArrivalDT": null,
        "voyageId": "' &amp; UTVoyageCode &amp; '"
    }
]';

	BadLogin : String = '{
	"userId": "baduser",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "LWT",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';

vars
	utHelperTerminal		: UT_HelperAdmTerm;
	incomingJsonString,
	terminalCode,
	loginJson,
	params,
	shippingLineCode		: String;
	isoType					: CM_ISOType;
	terminal				: CM_Terminal;
	expectFailure			: Boolean;
	root					: CM_Root;
	booking					: CM_BookingRef;
	bookingItem				: CM_BookingRefItem;
	contCargoType			: CM_CargoType;
	contCargoTypeId			: Integer;
	
	errOperator,
	operator,
	operatorNew				: CM_Operator;
	vesselNew				: CM_Vessel;
	errVoyage,
	voyageOrig,
	voyageNew				: CM_Voyage;
	consignorOrig,
	consigneeOrig,
	freightForwarderOrig	: CM_ConsigneeConsignor;
	carrier					: CM_Carrier;
	stevedore,
	stevedoreOrig			: CM_Stevedore;
	
	pxyBooking				: CM_BookingRef;
	pxyBookingItem			: CM_BookingRefItem;
	pxyHazardsArr			: CM_HazardByCodeDict;
	pxyTiHazardsArr			: CM_TIHazardByCodeDict;
	pxyTiHazard				: CM_TIHazard;
	hazardClass				: CM_HazardClass;
	reason					: String; //05/04/2024	navkc1 Bug 63509
begin
	create utHelperTerminal transient;
	root := app.myRoot;
	
	//Get terminal
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	app.writeLog("Changing MaxLiftWeightWarnOnly Terminal Config to true", LogINFO);
	app.writeLog("Changing IsSubTerminalsOn Terminal Config to false", LogINFO);
	self.setTerminalConfig(MaxLiftWeightWarnOnly, true);
	self.setTerminalConfig(IsSubTerminalsOn, false);
	
	//Get operator
	operator := root.allOperators[UTOperatorIdOrig];
	self.assertTrueMsg(operator &lt;&gt; null, method.name &amp; " | Setup: operator is null/could not be found | Operator Code: " &amp; UTOperatorIdOrig);
	
	//Get voyage orig
	voyageOrig := terminal.lookupVoyage(UTVoyageCodeOrig, null, true);
	self.assertTrueMsg(voyageOrig &lt;&gt; null, method.name &amp; " | Setup: voyage is null/could not be found | Voyage Code: " &amp; UTVoyageCodeOrig);
	
	//Get consignor
	consignorOrig := root.allConsigneeConsignors[UTConsignorCodeOrig];
	self.assertTrueMsg(consignorOrig &lt;&gt; null, method.name &amp; " | Setup: consignorOrig is null/could not be found | Consignor Code: " &amp; UTConsignorCodeOrig);
	
	//Get consignee
	consigneeOrig := root.allConsigneeConsignors[UTConsigneeCodeOrig];
	self.assertTrueMsg(consigneeOrig &lt;&gt; null, method.name &amp; " | Setup: consigneeOrig is null/could not be found | Consignee Code: " &amp; UTConsigneeCodeOrig);
	
	//Get freightForwarder
	freightForwarderOrig := root.allConsigneeConsignors[UTFreightForwarderCodeOrig];
	self.assertTrueMsg(freightForwarderOrig &lt;&gt; null, method.name &amp; " | Setup: freightForwarderOrig is null/could not be found | Freight Forwarder Code: " &amp; UTFreightForwarderCodeOrig);
	
	//Get carrier
	carrier := root.allCarriers[UTCarrierCode];
	self.assertTrueMsg(carrier &lt;&gt; null, method.name &amp; " | Setup: carrier is null/could not be found | Carrier Code: " &amp; UTCarrierCode);
	
	//Get stevedore
	stevedoreOrig := root.allStevedores[UTStevedoreCodeOrig];
	self.assertTrueMsg(stevedoreOrig &lt;&gt; null, method.name &amp; " | Setup: stevedoreOrig is null/could not be found | Stevedore Code: " &amp; UTStevedoreCodeOrig);
	
	//Get operatorNew
	operatorNew := root.allOperators[UTOperatorId];
	self.assertTrueMsg(operatorNew &lt;&gt; null, method.name &amp; " | Setup: operator is null/could not be found | Operator Code: " &amp; UTOperatorId);
	
	//Get/Create voyage new
	voyageNew := terminal.lookupVoyage(UTVoyageCode, null, true);
	if voyageNew &lt;&gt; null then
		//delete
		self.deleteVoyage(UTVoyageCode);
	endif;
	
	vesselNew := self.getVessel(UTVesselCode);
	if vesselNew &lt;&gt; null then
		//delete
		self.deleteVessel(UTVesselCode);
	endif;
	
	//Create Vessel
	vesselNew := self.addVesselCellular(UTVesselCode, operatorNew);
	self.assertTrueMsg(vesselNew &lt;&gt; null, method.name &amp; " | Setup: vesselNew is null/could not be found | Vessel Code: " &amp; UTVesselCode);
	
	//Create voyage
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyageNew := self.addVoyageWithContainerStructur(UTVoyageCode, UTVesselCode, operatorNew.code, shippingLineCode);
	self.assertTrueMsg(voyageNew &lt;&gt; null, method.name &amp; " | Setup: voyageNew is null/could not be found | Voyage Code: " &amp; UTVoyageCode);
	
	//Delete Booking
	self.deleteBooking(UTBookingRefOrig);
	self.deleteBooking(UTBookingRef);
	self.deleteBooking(UTErrBookingRef);
	
	//Create stevedore
	stevedore := utHelperTerminal.xCreateStevedore(UTStevedoreCode, UTStevedoreDescription);
	self.assertTrueMsg(stevedore &lt;&gt; null, method.name &amp; " | Setup: stevedore is null/could not be found | Stevedore Code: " &amp; UTStevedoreCode);
	
	create pxyTiHazardsArr transient;
	create pxyTiHazard transient;
	hazardClass := root.allHazardClasses[UTCargoHazardCode2];
