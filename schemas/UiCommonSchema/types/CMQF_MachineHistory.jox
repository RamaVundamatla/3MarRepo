<Class name="CMQF_MachineHistory">
    <JadeMethod name="setFromAgent" id="5f5b4d48-8203-44f8-84db-cb87624d2faa">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     10 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	time	:Time;
begin
	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_MachineType) then
		self.setMyMachineType( _agent.getSelectedMachineType );
	endif;
	if _agent.isRowIncluded(ETRow_Machine) then
		self.setMyMachine( _agent.getSelectedMachine );
	endif;
	if _agent.isRowIncluded(ETRow_DelayType) then
		_agent.getSelectedDelayType(self.allDelayTypes);
		self.allDelayTypes.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	endif;
	if _agent.isRowIncluded(ETRow_DelayTypeGroup) then
		_agent.getSelectedDelayTypeGrp(self.allDelayTypeGroups);
		self.allDelayTypeGroups.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	endif;
	if _agent.isRowIncluded(ETRow_MachineOperator) then
		self.myUser := _agent.getSelectedMachineOperator;
	endif;
	if _agent.isRowIncluded (ETRow_StartTime) then
		self.startTime  := _agent.getValueByNameIfVisible(ETRow_StartTime).Time;
	endif;
	if _agent.isRowIncluded (ETRow_EndTime) then
		self.endTime  := _agent.getValueByNameIfVisible(ETRow_EndTime).Time; 
	else
		self.endTime := '23:59:59:999'.Time;
	endif;
epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
