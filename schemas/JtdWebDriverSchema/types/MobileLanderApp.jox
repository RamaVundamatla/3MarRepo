    <JadeMethod name="stop2" id="fb8a7de9-2dd2-4cd6-9b19-f177c061fbd3">
        <updating/>
        <source>stop2() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2019	jlger1	Initial creation

*/

vars

begin
	inheritMethod();
	if self.myWebServiceTestForm &lt;&gt; null then
		// do Logoff
		self.logout;
		
		//close form
		self.myWebServiceTestForm.unloadForm;
		self.myWebServiceTestForm:=null;
	endif;
epilog

end;</source>
