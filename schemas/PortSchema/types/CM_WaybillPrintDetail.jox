    <JadeMethod name="titleStr" id="7789aa9f-0719-449b-8d25-62beaa0f015d">
        <methodInvocation>mapping</methodInvocation>
        <source>titleStr(set : Boolean; _value : String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

begin

	if not set then
		if app &lt;&gt; null then
			if self.isProForma then
				_value := app.getErrorString(PROFORMA_WAYBILL);
			else
				_value := app.getErrorString(WAYBILL);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
