end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="20086dcc-c5a7-4cfb-a5e6-736001187359">
        <source>setProxyFromObject(_helper : CMIF_KPIVoyageHelper; _includeDetail, _includeshifts : Boolean; _bayCodes, _craneCodes, _deckCodes, _wpCodes : StringArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
	voyage 		: CM_Voyage;
	kpiArray	: WS_KPIVoyageArray;
begin
	create kpiArray transient;
	
	voyage := _helper.myVoyage;
	
	if voyage = null then
		return;
	endif;
	
	kpiArray := _helper.getVoyageKPIs(_includeshifts, _includeDetail, _bayCodes, _craneCodes, _deckCodes, _wpCodes);
	
	kpiArray.copy(self.allVoyageKPIs);
epilog
	
end;</source>
        <Parameter name="_helper" type="CMIF_KPIVoyageHelper"/>
        <Parameter name="_includeDetail" type="Boolean"/>
        <Parameter name="_includeshifts" type="Boolean"/>
        <Parameter name="_bayCodes" type="StringArray"/>
        <Parameter name="_craneCodes" type="StringArray"/>
        <Parameter name="_deckCodes" type="StringArray"/>
        <Parameter name="_wpCodes" type="StringArray"/>
    </JadeMethod>
</Class>
