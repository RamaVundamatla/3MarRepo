<Class name="CMQF_DiscrepancySeals" id="20b34f08-a3a9-4532-a84a-b5beae3827b3">
    <superclass name="CMQF_Discrepancy"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="ad018493-8234-480d-94f3-debd9aae937d">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 19 November 2008
//
// Implemented version: 7.7.1
// CCMS1765 GDANSK - Maersk reporting requirements. 
// 3/19/2019	JLGNS1	ChangeRequest 45790: JMT - Refactor - Seal Transactions
//----------------------------------------------------------------------
vars
	i			: Integer;
	tmpCol  	: CM_TITransactionSet;
	txn			: CM_TITransaction;
	oldField,
	newField,
	field		: String;
begin
	create tmpCol transient;

	self.initiateFilterObjects(tmpCol);
	foreach txn in tmpCol do
		if self.checkCommonFilters(txn) then
			
			foreach i in 1 to txn.CM_Edit.fieldsValues.size  do
				txn.CM_Edit.getFieldValues(i, field, oldField, newField);
				
				//17 Sep 2010	NDL	Par 25608	- allow for when the old attributes are removed
				if field = null then
					txn.CM_Edit.getFieldValuesForSystemSeals(i, field, oldField, newField);
				endif;
				
				if field = SealNum or
				   field = SealNumShippers or
				   field = SealNumCustoms or
				   field = AllCustomsSealNumbers or 
				   field = SealNumTerminalOperator or	//ChangeRequest 45790 
				   field = SealNumUnknown or 			//ChangeRequest 45790
				   field = SealNumVent then
				
		/*		if field = CM_Container::sealNum.name or 
					field = CM_Container::sealNumCustoms.name or 
					field = CM_Container::sealNumShippers.name or 
					field = CM_Container::allCustomsSealNumbers.name or
					field = CM_Container::sealNumVent.name then //CCMS1909 - PAR22160 18/01/2010 cnwsh3 */
						_collection.add(txn);
						break;
				endif;
			endforeach;
		endif;
	endforeach;

epilog
	delete tmpCol;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="a9e90e6b-95cb-48df-b71c-216b0edc17fa">
        <updating/>
        <source>initFields() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 19 November 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars

begin
	inheritMethod();
	//Set the transaction types we want to search.
	//We'll use this during the self.filterObjects
	self.allTxnTypes.add(TRANS_TYPE_EDIT);
epilog
end;</source>
    </JadeMethod>
</Class>
