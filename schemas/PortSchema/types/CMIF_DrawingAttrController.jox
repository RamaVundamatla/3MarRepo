    <JadeMethod name="handleDwellDayRange" id="2720687a-732e-4a49-ac0d-9310a03d99ef">
        <source>handleDwellDayRange( _ti : CM_TrackedItem; _theColour : Integer output );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	dwellDayRange : CM_DwellDayRange;

begin

	dwellDayRange := _ti.getMyDwellDayRange;
	if dwellDayRange &lt;&gt; null then
		_theColour := dwellDayRange.colour;
	else
		_theColour := White;
	endif;
	
	if dwellDayRange &lt;&gt; null then
		if not self.allDwellRanges.includes(dwellDayRange) then
			self.allDwellRanges.add(dwellDayRange);
			self.beginNotification(dwellDayRange, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_theColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleDwellDayRangeObj" id="77f834bd-b17b-49ba-af4d-041aeb9c42a7">
        <source>handleDwellDayRangeObj(_dwellDayRange : CM_DwellDayRange; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	theCode : String;
	theColor : Integer;

begin
	
	if _dwellDayRange = null then
		_codesArray.atPut(TI_ColourMode_DwellDays, null);
		_colorArray.atPut(TI_ColourMode_DwellDays, NullColour);
		return;
	endif;

	theCode		:= _dwellDayRange.getDisplayValue;
	theColor	:= _dwellDayRange.colour;
	
	if not self.allDwellRanges.includes(_dwellDayRange) then
		self.allDwellRanges.add(_dwellDayRange);
		self.beginNotification(_dwellDayRange, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
	endif;

	_codesArray.atPut(TI_ColourMode_DwellDays, theCode);
	_colorArray.atPut(TI_ColourMode_DwellDays, theColor);
	_objArray.atPut(TI_ColourMode_DwellDays, _dwellDayRange);

end;</source>
        <Parameter name="_dwellDayRange" type="CM_DwellDayRange"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleHazards" id="335dd27a-e524-41e2-a6fa-2f9961511c77">
        <source>handleHazards(_hazCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpHaz		: CM_HazardClass;
	theObject : Object;
begin



	trimCode := _hazCode.trimBlanks;
	
	if trimCode = null then
		_code	:= null;
		_color	:= White;
		return;
	endif;

	iter := self.myIterHazards;
	self.allHazards.startKeyGeq(trimCode, 0, iter);
	self.allHazards.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= _hazCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		tmpHaz := self.myRoot.allHazardClasses[trimCode];
		if tmpHaz &lt;&gt; null then
			self.allHazards.add(tmpHaz);
			self.beginNotification(tmpHaz, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= tmpHaz.colour;
			theObject := tmpHaz;
		else
			theCode		:= null;
			theColor	:= NullColour;
			theObject := null;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;
end;</source>
        <access>protected</access>
        <Parameter name="_hazCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleISOType" id="a56fbabc-1885-4603-ab6b-8f7f344a5207">
        <source>handleISOType(_isoTypeCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpISOType	: CM_ISOType;
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey,groupCodeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
begin

	trimCode := _isoTypeCode.trimBlanks;

	if trimCode = null then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;
	tmpISOType := self.myRoot.allISOTypes[trimCode];
	
	if tmpISOType &lt;&gt; null and tmpISOType.myISOTypeGroup &lt;&gt; null then
//		groupCodeKey := tmpISOType.myISOTypeGroup.code;
	endif;

	iter := self.myIterISOType;
	self.allISOTypes.startKeyGeq(trimCode, null, iter);
	self.allISOTypes.getIteratorKeys(codeKey, groupCodeKey, iter);
	
	theCode		:= null;
	theColor	:= NullColour;
	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= tmpISOType.colour;
		iter.next(theObject);
	else
		if tmpISOType &lt;&gt; null then
			self.allISOTypes.addNoDuplicates(tmpISOType,false);
			self.beginNotification(tmpISOType, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= tmpISOType.colour;
			theObject := tmpISOType;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleISOTypeGroup" id="224ee0d1-e45b-4793-b966-728e4852aa41">
        <source>handleISOTypeGroup(_isoTypeCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	theCode,
	trimCode,
	codeCodeKey,
	groupCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpGroup	: CM_ISOTypeGroup;
	tmpISOType	: CM_ISOType;
	theObject : Object;
begin
	trimCode := _isoTypeCode.trimBlanks;
	
	if trimCode = null then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;
	
	iter := self.myIterISOType;
	self.allISOTypes.startKeyGeq(trimCode, null, iter);
	self.allISOTypes.getIteratorKeys(codeCodeKey, groupCode, iter);

	theCode		:= null;
	theColor	:= NullColour;
	
	if codeCodeKey = trimCode then
		// found the iso type so get the group out of the group key
		
		iter := self.myIterISOTypeGroup;
		self.allISOTypeGroups.startKeyGeq(groupCode, 0, iter);
		self.allISOTypeGroups.getIteratorKeys(codeKey, colorKey, iter);
	
		if codeKey = groupCode then
			// found the right one
			theCode		:= groupCode;
			theColor	:= colorKey;
			iter.next(theObject);

		else
			// this should not be necessary as should have been
			// added below but done for belts and braces
			tmpGroup := self.myRoot.allISOTypeGroups[groupCode];
			if tmpGroup &lt;&gt; null then
				self.allISOTypeGroups.add(tmpGroup);
				self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				theCode		:= groupCode;
				theColor	:= tmpGroup.colour;
				theObject := tmpGroup;
			endif;
		endif;

	else
		tmpISOType := self.myRoot.allISOTypes[trimCode];
		if tmpISOType &lt;&gt; null then
			self.allISOTypes.add(tmpISOType);
			tmpGroup := tmpISOType.myISOTypeGroup;
			if tmpGroup &lt;&gt; null then
				if (not self.allISOTypeGroups.includes(tmpGroup)) then
					self.allISOTypeGroups.add(tmpGroup);
					self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				endif;
				theCode		:= tmpGroup.code;
				theColor	:= tmpGroup.colour;
				theObject := tmpGroup;
			endif;
		else
			// TFS 37556
			tmpGroup := self.myRoot.allISOTypeGroups[_isoTypeCode];
			if tmpGroup &lt;&gt; null then
				self.allISOTypeGroups.addNoDuplicates(tmpGroup, false);
				self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				theCode		:= groupCode;
				theColor	:= tmpGroup.colour;
				theObject := tmpGroup;
			endif;
		endif;

	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleISOTypeGroup2" id="23ef2742-b141-4148-9ff3-d433bff7add0">
        <source>handleISOTypeGroup2(_isoTypeCode : String; _codesStr, _colourStr, _objStr : String io);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColour	: Integer;
	theObject : Object;

begin

	self.handleISOTypeGroup(_isoTypeCode, theCode, theColour,theObject);

	_codesStr := _codesStr &amp; theCode &amp; GridData_SubDelimiter;
	_colourStr	:= _colourStr &amp; theColour.String &amp; GridData_SubDelimiter;
//	_objStr := _objStr &amp; GridData_SubDelimiter;
	_objStr	:= _objStr &amp; self.getOidStringForObject(theObject) &amp; GridData_SubDelimiter;

end;</source>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_codesStr" type="String" usage="io"/>
        <Parameter name="_colourStr" type="String" usage="io"/>
        <Parameter name="_objStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleISOTypeGroupObj" id="d623f7dc-f51b-464c-a61f-6ab89bc8ad76">
        <source>handleISOTypeGroupObj(_isoTypeCode : String; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	theCode,
	trimCode,
	codeCodeKey,
	groupCode,
	groupCodeKey	: String;
	theColor,
	colorKey	: Integer;
	tmpGroup	: CM_ISOTypeGroup;
	tmpISOType	: CM_ISOType;
	
begin

	trimCode  := _isoTypeCode.trimBlanks;
	
	if trimCode = null then
		_codesArray.atPut(TI_ColourMode_ISOTypeGroup, null);
		_colorArray.atPut(TI_ColourMode_ISOTypeGroup, NullColour);
		return;
	endif;
	
	iter := self.myIterISOType;
	self.allISOTypes.startKeyGeq(trimCode, null, iter);
	self.allISOTypes.getIteratorKeys(codeCodeKey, groupCode, iter);

	theCode		:= null;
	theColor	:= NullColour;
	
	if codeCodeKey = trimCode then
		// found the iso type so get the group out of the group key
		
		iter := self.myIterISOTypeGroup;
		self.allISOTypeGroups.startKeyGeq(groupCode, 0, iter);
		self.allISOTypeGroups.getIteratorKeys(groupCodeKey, colorKey, iter);
	
		if groupCodeKey = groupCode then
			// found the right one
			theCode		:= groupCodeKey;
			theColor	:= colorKey;
		else
			// this should not be necessary as should have been
			// added below but done for belts and braces
			tmpGroup := self.myRoot.allISOTypeGroups[groupCode];
			if tmpGroup &lt;&gt; null then
				self.allISOTypeGroups.add(tmpGroup);
				self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				theCode		:= groupCode;
				theColor	:= tmpGroup.colour;
			endif;
		endif;

	else
		tmpISOType := self.myRoot.allISOTypes[trimCode];
		if tmpISOType &lt;&gt; null then
			self.allISOTypes.add(tmpISOType);
			tmpGroup := tmpISOType.myISOTypeGroup;
			if tmpGroup &lt;&gt; null then
				if (not self.allISOTypeGroups.includes(tmpGroup)) then
					self.allISOTypeGroups.add(tmpGroup);
					self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				endif;
				theCode		:= tmpGroup.code;
				theColor	:= tmpGroup.colour;
			endif;
		endif;

	endif;

	_codesArray.atPut(TI_ColourMode_ISOTypeGroup, theCode);
	_colorArray.atPut(TI_ColourMode_ISOTypeGroup, theColor);
	_objArray.atPut(TI_ColourMode_ISOTypeGroup, tmpGroup);

end;</source>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleISOTypeGroupXML" id="eaf2a941-82ef-4ce1-a0ab-ed8e041be7f6">
        <source>handleISOTypeGroupXML(_isoTypeCode : String) : String;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColour	: Integer;
	theObject : Object;

begin
	self.handleISOTypeGroup(_isoTypeCode, theCode, theColour,theObject);

	return self.formatForXML(TI_ColourMode_ISOTypeGroup, theCode, theColour,theObject);

