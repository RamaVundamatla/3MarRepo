		 _runAsKey,
		 _callBackUrl : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2018	jlgmp6	Initial creation	TFS41999
10 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value    
*/

vars

begin
	inheritMethod(_active,_name, _baseEndpoint, _password, _userCode, _maxRetries, _timeBetweenRetries, _timeoutSeconds, _restAPIAuthEndpoint, _restAPIBaseEndpoint, _authProviderUrl, _clientId, _clientSecret, _runAsKey,_callBackUrl);
	self.authProviderUrl := _authProviderUrl;
	self.clientID 		 := _clientId;
	self.clientSecret 	 := _clientSecret;
	self.runAsKey 		 := _runAsKey;		 // 3/7/19 MAP TFS45230
	self.callBackUrl     := _callBackUrl;    // 10.07.2020 cnwma1 #49243  
epilog

end;</source>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_baseEndpoint" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_maxRetries" type="Integer"/>
        <Parameter name="_timeBetweenRetries" type="Integer"/>
        <Parameter name="_timeoutSeconds" type="Integer"/>
        <Parameter name="_restAPIAuthEndpoint" type="String"/>
        <Parameter name="_restAPIBaseEndpoint" type="String"/>
        <Parameter name="_authProviderUrl" type="String"/>
        <Parameter name="_clientId" type="String"/>
