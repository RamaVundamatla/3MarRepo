    </JadeMethod>
    <JadeMethod name="trxLoadXLATsFromGlbConstants" id="4c9a6d23-9b07-43d4-8183-bbe6e9c57aca">
        <updating/>
        <source>trxLoadXLATsFromGlbConstants(_justThisCategory : String) updating;
// ---------------------------------------------------------------------------
// Created:     9 August 2006 by RBarr
//
// Purpose:     Single entry point to load all CM_TranslatableText intances
//				from global constants. Used by Deployment process
// 				Includes: error messages, literals, form labels and captions, report names, EntTable text)
// 				Create new items, update existing default locale (NZ) text, remove old items
//				See XLAT_TranslatableText text for XML format
// ---------------------------------------------------------------------------

vars
	constantCategory		: Constant;
	constant				: Constant;
	locale					: CM_Locale;
	existingTranslations	: XLAT_TranslatableTextByCatNmbr;
	translatableText		: XLAT_TranslatableText;
	category				: XLAT_Category;
	tmpCategoryDict,
	tmpConstantDict			: ConstantNDict;
begin

	// Load existing translations into a collection, any remaining at the end can be removed
	create existingTranslations transient;
	
	beginTransaction;

	// do this to ensure we have at least one locale
	self.subTrxCreateDefaultLocale();

	if _justThisCategory = null or _justThisCategory = XLAT_Exceptions then
		self.myRoot.resetBaseErrorNumber;	// set to MaxInteger
	endif;
	
	tmpCategoryDict := self.myCategory.getConstants;

	foreach constantCategory in tmpCategoryDict do
		if _justThisCategory &lt;&gt; null and _justThisCategory &lt;&gt; constantCategory.name then
			continue;
		endif;
		if constantCategory.name = XLAT_Menus then
			self.zLoadMenuTranslations();
			continue;
		endif;

		if constantCategory.name = XLAT_ReportNames then	// par 17779
			self.zLoadReportTranslations();					// par 17779
			continue;										// par 17779
		endif;												// par 17779
		
		existingTranslations.clear;

		category := myRoot.allXLAT_Categories[constantCategory.name];

		if constantCategory.name = EntTableRows then
			// these are maintained elsewhere
			existingTranslations.clear;
		else
			category.allTranslatableText.copy(existingTranslations);
		endif;

		// for each translatable text item ...
		tmpConstantDict := self.mySchema.getCategory(constantCategory.name).getConstants();
		foreach constant in tmpConstantDict where constant.text &lt;&gt; null do
			translatableText := self.subTrxLoadFromGlobalConstant(category, constant.GlobalConstant);
			
			// remove from the existing collection as we go ..
			if translatableText &lt;&gt; null and
			   existingTranslations[translatableText.myConstantCategoryName,translatableText.number] &lt;&gt; null then
				existingTranslations.removeKey(translatableText.myConstantCategoryName,translatableText.number);
			endif;
		endforeach;	// constant

		// any remaining in existingTranslations can be purged
		existingTranslations.purge;

	endforeach; // category

	commitTransaction;

//	root.inspectModal;
epilog
	delete existingTranslations;
end;</source>
        <Parameter name="_justThisCategory" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxRemoveSpecificTranslations" id="e630fb81-6f75-4fd0-a04d-a01208cd9aa4">
        <source>trxRemoveSpecificTranslations(_strArray : StringArray input; _category : String);
/*

Purpose:			Fixup crap permissions
					Intended for DEV use only!

Parameters:			

Return Value:		

Date		Who		Reason
02 Sep 2022	navmd1	Initial creation

*/
vars

	translatableText		: XLAT_TranslatableText;
	tmpContStr				: String;
	const					: Constant;
	category				: XLAT_Category;

begin

	category := self.myRoot.allXLAT_Categories[_category];
	if category = null then
		write "Category [" &amp; _category &amp; "] not found. Nothing to do";
		return;
	endif;

	beginTransaction;
	
	foreach tmpContStr in _strArray do
		
		const := currentSchema.getConstant(tmpContStr);
		if const = null then
			write "Constant [" &amp; tmpContStr &amp; "] not found, skipping";
			continue;
		endif;

		translatableText := category.allTranslatableText[const.valueAsInteger];
		delete translatableText;
	endforeach;	
	
	commitTransaction;
//	abortTransaction;

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <Parameter name="_category" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxRemoveXLATPermissions" id="1a91040e-c74d-4721-b2cd-bcb36c3198bd">
        <source>trxRemoveXLATPermissions(_permissions : IntegerArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Sep 2012	cnwpjs1	Initial creation Par #30391 

*/

vars

	translatableText		: XLAT_TranslatableText;
	category				: XLAT_Category;
	permission				: Integer;

begin

	category := self.myRoot.allXLAT_Categories[XLAT_Permissions];

	beginTransaction;
	
	foreach permission in _permissions do
		translatableText := category.allTranslatableText[permission];
		
		if translatableText &lt;&gt; null then
			delete translatableText;
		endif;
		
	endforeach;	
	
	commitTransaction;
	
end;</source>
        <Parameter name="_permissions" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="trxSetAsReviewed" id="b04fe5d7-5cdb-44bb-a1b4-a519cd9188f4">
        <source>trxSetAsReviewed(_scope : Integer; _selection : XLAT_TranslatableTextByNumber; _category : XLAT_Category);

vars
	translatableText : XLAT_TranslatableText;
	category		 : XLAT_Category;
	results			 : XLAT_SearchResults;
begin

	// validation


	// locks
	if _selection &lt;&gt; null and _selection.size &gt; 0 then
		foreach translatableText in _selection do
			exclusiveLock(translatableText);
		endforeach;
	elseif _category &lt;&gt; null then
		exclusiveLock(_category);
	else
		exclusiveLock(self.myRoot);
	endif;


	beginTransaction;

	if _scope = Scope_SingleTranslation or _scope = Scope_Multiple_Translations then
		foreach translatableText in _selection do
			translatableText.setToBeReviewedFlag(false);
		endforeach;
		
	elseif _scope = Scope_Results_For_Category then
		results := self.allSearchResults[_category.constantCategoryName];
		if results &lt;&gt; null then
			foreach translatableText in results.allTranslatableText do
				translatableText.setToBeReviewedFlag(false);
			endforeach;
		endif;

	elseif _scope = Scope_Results_All_Categories then
		foreach results in allSearchResults do
			foreach translatableText in results.allTranslatableText do
				translatableText.setToBeReviewedFlag(false);
			endforeach;
		endforeach;

	elseif _scope = Scope_Global_All_Translations then
		foreach category in myRoot.allXLAT_Categories do
			foreach translatableText in category.allTranslatableText do
				translatableText.setToBeReviewedFlag(false);
			endforeach;
		endforeach;

	else
	
	endif;
	
	commitTransaction;
end;</source>
        <Parameter name="_scope" type="Integer"/>
        <Parameter name="_selection" type="XLAT_TranslatableTextByNumber"/>
        <Parameter name="_category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="trxSetDefaultLocale" id="c36af584-d81d-4fe0-8e8d-8c8c4bf034a8">
        <source>trxSetDefaultLocale(_locale : CM_Locale);

// set the default locale for the deployed system (note the development system locale is defined by StandardTextLocale

vars
	root : CM_Root;
begin
	// validation
	if _locale = null then
		return;
	endif;

	root := app.myRoot;
	
	exclusiveLock(root);
	exclusiveLock(_locale);
	
	beginTransaction;
	root.setDefaultLocale(_locale);
	commitTransaction;
epilog
	unlock(root);
	unlock(_locale);
end;
</source>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTranslatableText" id="1a05752f-8510-458d-bcfc-f5a8be8c1f4b">
        <updating/>
        <source>/*
Date		Who		Reason
25 Nov 2008	cnwjk3	PAR 18461 - Need to be able to exclude parameters from the translation

*/

trxUpdateTranslatableText(_translatableText				: XLAT_TranslatableText io; 
						  _edition 						: Integer; 
						  _proxy 						: XLAT_TranslationsAndGCProxy; 
						  _passport 					: CM_Passport) updating;

// update the XLAT_TranslatableText object
// the proxy has arrays of each locale to be updated, and corresponding translated text and shortText for each locale

vars
	locale			: CM_Locale;
	newText			: String;
	newShortText	: String;
	translation		: XLAT_Translation;
	indx			: Integer;
	localeName		: String;
	// cnwjk3 PAR 18461 25/11/08
	warnLocales 	: String;
	errHint 		: String;
	// 22/02/2011 cnwcs5 par 27084
	permission		: CM_PermissionObject;
	newXML			: String;
begin	
	// validation
	if _translatableText = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'translatable text', null, null);
		app.raiseCMException(Input_required_field_transText, null, null); // cnwdb2	PAR 35364
	endif;
	if _edition &lt;&gt; 0 and _translatableText.edition &lt;&gt; _edition then
		app.raiseCMException2(ExpectedEditionInvalid, edition.String, _translatableText.vConstantName, null, null);
	endif;
	// cnwjk3 PAR 18461 25/11/08
	if _proxy.validateSubstitutionRanges(localeName, errHint) = false then
		app.raiseCMException2(ERR_FIELD_RANGE , localeName, errHint, _translatableText.vConstantName, null);	
	endif;
	
	//if _proxy.validateSubstitutionCount(localeName) = false then
	// cnwjk3 PAR 18461 25/11/08
	if _proxy.validateSubstitutionCount(localeName, warnLocales) = false then
		app.raiseCMException1(ERR_NUMBER_OF_FIELDS, localeName, _translatableText.vConstantName, null);
	elseif warnLocales &lt;&gt; null then
		if app.msgBox(app.getErrorString1(WARN_TOO_FEW_FIELDS, warnLocales), 
		              "Warning", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon ) = MsgBox_Return_Cancel then
			return;
		endif;
		
	endif;
	
	exclusiveLock(_translatableText);

	beginTransaction;	

	// iterate translations for each locale
	foreach locale in _proxy.allLocales do
		indx 		:= indx + 1;
		translation := 	_translatableText.getTranslation(locale);
		newText 	:= _proxy.allText[indx];
		
		if _translatableText.usesShortText then
			newShortText := _proxy.allShortText[indx];
		endif;
		
		_translatableText.updateLocaleTranslation(self.myRoot, locale, newText, newShortText, _proxy, false);
		
// 22/02/2011 cnwcs5 par 27084 - start		
		// only update global constant xml text if the developer has updated the system default locale text
		if app.isDevelopmentSystemMain() and app.isSpecial() then
			// can only update meta data if in main development system
			if _translatableText.hasGlobalConstant and locale.localeId = StandardTextLocaleStr then
				// only update if we are updating the standard text
				if _translatableText.isKindOf (XLAT_Permission) then
					// we need to use a permission object to build the global constant text
					create permission transient;
					permission.setFromXML (_translatableText.myGlobalConstant);
					// permission now has the OLD global constant text
					permission.description := newText; 
					// permission now has NEW constant details
					newXML := permission.outputAsXML; 
					// now update using translation object
					_translatableText.myGlobalConstant.setText(newXML);
				else
					_translatableText.myGlobalConstant.setText(_proxy.buildXml);
				endif;
			endif;
		endif;
// 22/02/2011 cnwcs5 par 27084 - end		
	endforeach;
	commitTransaction;
epilog
	delete permission;
end;</source>
        <Parameter name="_translatableText" type="XLAT_TranslatableText" usage="io"/>
        <Parameter name="_edition" type="Integer"/>
        <Parameter name="_proxy" type="XLAT_TranslationsAndGCProxy"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTranslation" id="147e9811-dfe1-4236-a730-530b70eb8cff">
        <updating/>
        <source>trxUpdateTranslation(_fields : HugeStringArray; _partsDone : Integer) : Boolean updating;

// Purpose: This is a callback method:
//          doImportCSV calls the method String::csvDecode to decode a whole file;
//          csvDecode parses the file record by record, passing the contents of
//          each record to this method as a huge string array called fields.
// adm 060509 Par 19230 display warnings
vars
	locale : CM_Locale;
	category : XLAT_Category;
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
	text : String;
	shortText : String;
	field6 : String;
	errStr : String;
	localeId : String;
begin
	setLineCount(lineCount + 1);
	//locale := app.myRoot.getLocale(_fields[1].Integer.padLeadingWith("0", 4), false);  //- cnwmd1, Par 23998
	//+ cnwmd1, Par 23998 - Replacement for the above
	localeId := _fields[1];
	if localeId = '0000' then //Should never import and replace the standard translation!
		app.msgBox("The locale specified in the file is the standard locale.  This locale cannot be modified.  Please change the file and try again.", "Information", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	locale := app.myRoot.getLocale(localeId, false);
	if locale = null then
		app.msgBox("Please create the locale first", "Information", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	category := app.myRoot.allXLAT_Categories[_fields[2]];
	if category = null then
		// this needs to report back
		errStr	:= 'Line ' &amp; lineCount.String &amp; ': category not found for (' &amp; _fields[2].trimBlanks &amp; ')';
		app.writeLog(errStr, LogINFO);
		allWarnings.add(errStr);
		return true;
	endif;
	translatableText := category.allTranslatableText[_fields[3].Integer];
	if translatableText = null then
		// this is ok
		errStr	:= 'Line ' &amp; lineCount.String &amp; ': translatableText not found for (' &amp; _fields[2].trimBlanks &amp; '::' &amp; _fields[3].trimBlanks &amp; ')';
		app.writeLog(errStr, LogINFO);
		allWarnings.add(errStr);
		// PAR 19230 - this should not cause the load to fail 
		return true;
		//return false;
	endif;
	translation := translatableText.allTextByLocale[_fields[1]];
	if translation &lt;&gt; null then
		text := translation.text;
		shortText := translation.shortText;
	endif;
	
	// Each record should have 6 fields, but Excel sometimes removes the sixth field if it is empty.
	// The variable field6 is used to avoid an exception in this case.
	if _fields.size &gt; 5 then
		field6 := _fields[6];
	endif;

	// The record is either updating the text or the shortText property.
	if XLAT_Translation::text.name = _fields[4] then
		text := field6;
	elseif XLAT_Translation::shortText.name = _fields[4] then
		shortText := field6;
	endif;

	// Updates or adds a translation for the translatable text and adjusts the global constant xml text.
	beginTransaction;
	translatableText.updateLocaleTranslation(app.myRoot, locale, text, shortText, null, true);
	commitTransaction;

	// Update the progress monitor
	self.progressCallBackObject.sendMsgWithParams(self.progressUpdateCallback, _partsDone);
	
	
	return true;
end;</source>
        <Parameter name="_fields" type="HugeStringArray"/>
        <Parameter name="_partsDone" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zGetRuntimeClassForCategory" id="50a88e4c-5c56-41a9-b18b-e568f74e76ac">
        <source>zGetRuntimeClassForCategory(_category : ConstantCategory):Class protected;

// Runtime class is stored on GC as XML in text property
// OBSOLETE
vars
	xmlDoc		: CM_XMLDocument;
	xmlElement	: JadeXMLElement;
	xmlArray	: JadeXMLElementArray;
	xmlElem		: JadeXMLElement;
begin
	if _category.text = null then
		return null;
	endif;
	
	create xmlDoc transient;
	create xmlArray transient;

	xmlDoc.parseString(_category.text);
	xmlDoc.getElementsByTagName(XMLTag_TranslationClass, xmlArray);

	if xmlArray.size &lt;&gt; 1 then
		return null;
	endif;

	xmlElem := xmlArray.first;

	if xmlElem.attributes.size &lt;&gt; 1 then
		return null;
	endif;

	return self.mySchema.getClass(xmlElem.attributes[1].value);
	
epilog
	delete xmlDoc;
	delete xmlArray;
end;</source>
        <access>protected</access>
        <Parameter name="_category" type="ConstantCategory"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="zInitSearchResults" id="ebdb0e82-c46d-4009-a039-45fb46a46d77">
        <source>zInitSearchResults(_refineExisting : Boolean);

vars
	searchResults : XLAT_SearchResults;
begin

	if not _refineExisting then
		foreach searchResults in self.allSearchResults do
			searchResults.clear;
		endforeach;
	endif;

end;</source>
        <Parameter name="_refineExisting" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zLoadMenuTranslations" id="cb701f53-652f-4a0f-9f8c-d71867c1f1fb">
        <source>zLoadMenuTranslations() protected;

vars
	menuRoot	: CM_MenuRootForRoot;
	menuItem	: CM_MenuItem;
	xlatMenu	: XLAT_Menu;
	xlatText	: XLAT_TranslatableText;
	delSet		: ObjectSet;

begin

	create delSet transient;
	
	foreach xlatText in app.myRoot.allXLAT_TranslatableText
			where xlatText.myConstantCategoryName = XLAT_Menus do
		delSet.add(xlatText);
	endforeach;
	
	menuRoot := app.myRoot.myMenuRoot;

	foreach menuItem in menuRoot.allMenuItems do

		xlatMenu := app.myRoot.allXLAT_TranslatableText[XLAT_Menus, menuItem.getMenuTranslationNumber()].XLAT_Menu;
		if xlatMenu = null then
			create xlatMenu persistent;
		else
			delSet.removeIfPresent(xlatMenu);
		endif;
			
		// default locale
		xlatMenu.initialiseMenu(myRoot, menuItem);
	endforeach;

	menuRoot := app.myRoot.myMenuRootForSysEntities;

	foreach menuItem in menuRoot.allMenuItems do

		xlatMenu := app.myRoot.allXLAT_TranslatableText[XLAT_Menus, menuItem.getMenuTranslationNumber()].XLAT_Menu;
		if xlatMenu = null then
			create xlatMenu persistent;
		else
			delSet.removeIfPresent(xlatMenu);
		endif;
			
		// default locale
		xlatMenu.initialiseMenu(myRoot, menuItem);
	endforeach;
	
	// remove any xlats no longer valid
	delSet.purge();

epilog
	delete delSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zLoadReportTranslations" id="ae6f71bd-ca98-4a34-b5ff-45ce37a5866d">
        <source>zLoadReportTranslations()protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
21 August 2008	concms1	Par 17779 Initial creation
*/
vars
	menuRoot	: CM_MenuRootReportForRoot;
	menuItem	: CM_MenuItem;
	xlatReport	: XLAT_ReportName;
	xlatText	: XLAT_TranslatableText;
	delSet		: ObjectSet;

begin

	create delSet transient;
	
	foreach xlatText in app.myRoot.allXLAT_TranslatableText
			where xlatText.myConstantCategoryName = XLAT_ReportNames do
		delSet.add(xlatText);
	endforeach;
	
	menuRoot := app.myRoot.myReportMenuRoot;

	foreach menuItem in menuRoot.allMenuItems do

		xlatReport := app.myRoot.allXLAT_TranslatableText[XLAT_ReportNames, menuItem.getMenuTranslationNumber()].XLAT_ReportName;
		
		if xlatReport = null then
			create xlatReport persistent;
		else
			delSet.removeIfPresent(xlatReport);
		endif;
			
		// default locale
		xlatReport.initialiseReport(myRoot, menuItem);
	endforeach;

	// remove any xlats no longer valid
	delSet.purge();

epilog
	delete delSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
