    <JadeMethod name="doSave" id="40e457ca-eb77-465d-b51c-1cc45e5c4708">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwndl1	Initial creation	CCMS MES 1006
31 October  2022	navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23 December 2022    navds21 ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
04 Sept 2024 		navah1  Bug 65972: DQM - Unable to Save To Do Task Resources
*/

vars
	theForm 					: SOP_TableMaintForm;
	lCode 						: String;
	lDescription 				: String;
	lNumDecimals 				: Integer;
	lUnitDescription 			: String;
	lHasBeenUsed 				: Boolean;
	lIsAvailable 				: Boolean;
	toDoColl 					: CM_ToDoTaskDescBySortKey;
	transTypeSet				: CM_TransactionTypeSet;
	transResourceBrokers 		: CM_TransSBByTransTypeType;//CM_TransResourceBrokerDict;
	iter 						: Iterator;
	obj 						: Object;
	eventTypes 					: CM_EventTypeByTypeDict;
	proxyResourceType 			: CM_ResourceType;
	realResourceType 			: CM_ResourceType;
	rtnValue 					: Boolean;
	lIsFromToDateTimeRequired 	: Boolean;			 	//cnwmc5 - 23 Sep 2015 - PAR 36920	
	tmpJadeCode					: String;			 	//cnwmc5 - 23 Sep 2015 - PAR 36920
	addInfo 					: String;			 	//13 Apr 2017	NDL	TFS 3414
	type 						: Integer;			 	//31/10/2022 navds20 TFS #56635[54261]
	mandatory 					: Boolean; 			 	//23.12.2022 navds21 TFS #54349[54262]
	tbl						    : CM_EntryTable;
	resourceTypeGroup			: CM_ResourceTypeGroup;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	autoApplyResourceType		: CM_ResourceType;		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	resourceTypeGroupCode,
	autoApplyResourceTypeCode	: String;				// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	root						: CM_Root;				// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
begin
	
	theForm  				  := self.myForm; 
	tbl      				  := theForm.tblInput1;
	root					  := app.myRoot;
	lCode 					  := tbl.getValueByName(ETRow_Code).String[1:10];
	lDescription 			  := tbl.getValueByName(ETRow_Description).String[1:40];
	lNumDecimals 			  := tbl.getValueByName(ETRow_NumDecimals).Integer;
	lUnitDescription 		  := tbl.getValueByName(ETRow_UnitDescription).String[1:10];
	lIsAvailable 			  := tbl.getValueByName(ETRow_IsAvailable).Boolean;
	lHasBeenUsed 		      := false;																	//default value
	lIsFromToDateTimeRequired := tbl.getValueByName(ETRow_IsFromToDateTimeRequired).Boolean;			//cnwmc5 - 22 Sep 2015 - PAR 36920
	addInfo					  := theForm.cmbExtraInfo.text;												//13 Apr 2017	NDL	TFS 3414
	type 					  := app.getToDoTaskStringToInt(tbl.getValueByName(ETRow_Type).String);		//31/10/2022 navds20 TFS #56635[54261]
	mandatory   			  := tbl.getValueByName(ETRow_IsMandatory).Boolean;         				//23.12.2022 navds21 TFS #54349[54262]
	resourceTypeGroupCode 	  := tbl.getValueByName(ETRow_ResourceGroup).String;						// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
	if app.myPassport.isVASEnabled then																	//04.09.2024 navah1 #65972
		
		autoApplyResourceTypeCode := tbl.getValueByName(ETRow_AutoApply).String;						// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		resourceTypeGroup 		  := root.allResourceTypeGroups[resourceTypeGroupCode];					// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		if autoApplyResourceTypeCode &lt;&gt; null then														//04.09.2024 navah1 #65972	
			autoApplyResourceType := root.allTaskResourceTypes[autoApplyResourceTypeCode];				// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		endif; 
	endif;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ResourceType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create toDoColl transient;
	theForm.mulSelect1.getSelected(toDoColl);
	
	create eventTypes transient;
	create transTypeSet transient;
	create transResourceBrokers transient;
	if theForm.myCurrentObject &lt;&gt; null then
		realResourceType := theForm.myCurrentObject.CM_ResourceType;
		lHasBeenUsed 	 := realResourceType.hasBeenUsed;
		iter 			 := realResourceType.allUsageContexts.createIterator;
		
		while iter.next( obj ) do
			if obj.isKindOf(CM_EventType) then
				eventTypes.add( obj.CM_EventType );
			elseif obj.isKindOf(CM_TransactionType) then
				transTypeSet.add(obj.CM_TransactionType);
			elseif obj.isKindOf(CM_TransResourceServiceBroker) then
				transResourceBrokers.add(obj.CM_TransResourceServiceBroker);
			endif;
		endwhile;
	endif;
	
	tmpJadeCode := self.jadeCode;
	
	proxyResourceType := theForm.myProxyObject.CM_ResourceType;
	proxyResourceType.setProxy(	lCode, 
								lDescription, 
								lNumDecimals, 
								lUnitDescription, 
								lHasBeenUsed, 
								lIsAvailable, 
								toDoColl, 
								eventTypes, 
								transTypeSet, 
								transResourceBrokers, 
								lIsFromToDateTimeRequired,		//cnwmc5 - 22 Sep 2015 - PAR 36920
								tmpJadeCode,					//cnwmc5 - 22 Sep 2015 - PAR 36920
								addInfo,
								app.myPassport.userCode,		//cnwmc5 - 22 Sep 2015 - PAR 36920
								type,                           //02/11/2022 navds20 TFS #56635[54261]	
								mandatory,						//23.12.2022 navds21 TFS #54349[54262]
								resourceTypeGroup,				// ### TFS 58761 (60739) 16Nov2023 NAVPW1
								autoApplyResourceType);			// ### TFS 58761 (60739) 16Nov2023 NAVPW1

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateResourceType(proxyResourceType, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateResourceType(proxyResourceType, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
		
	endif;
	return rtnValue;
epilog
	delete toDoColl;
	delete eventTypes;
	delete transTypeSet;
	delete transResourceBrokers;
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterAutoApplyList" id="bae5faed-35ea-4bc0-9e4b-416c547dfb9c">
        <source>filterAutoApplyList(_theForm : SOP_TableMaintForm; _resourceType : CM_ResourceType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	comboAutoApply			: ComboBox;
	realResourceType,
	resourceTypeLinked,
	resourceType			: CM_ResourceType;
	allResourceTypes		: CM_ResourceTypeDict;
	
begin
	comboAutoApply := _theForm.cmbAutoApply;
	comboAutoApply.clear();
	allResourceTypes := app.myRoot.allTaskResourceTypes;
	comboAutoApply.addItem("");
	
	if _resourceType = null or not _resourceType.isTransient then
		foreach resourceType in allResourceTypes do	//Add all
			comboAutoApply.addItem(resourceType.code);
		endforeach;
		return;
	endif;
	
	realResourceType := _resourceType.pxyGetRealObject();
	
	resourceTypeLinked := realResourceType.myResourceTypeLinked;
	foreach resourceType in allResourceTypes do
		
		/*
		16.09.2024 navma1 58761
		Exclude resources already used before to be auto applied
		*/ 
		
		if resourceType.myResourceTypeLinked &lt;&gt; null then
			continue;
		endif;
		
		if realResourceType = null or
			resourceType.code = realResourceType.code or 
			(resourceType.type &lt;&gt; realResourceType.type or not resourceType.isAvailable) or 
			resourceType.isFromToDateTimeRequired &lt;&gt; realResourceType.isFromToDateTimeRequired or
			(resourceTypeLinked &lt;&gt; null and resourceTypeLinked = resourceType)
		then
			continue;
		endif;
		
		comboAutoApply.addItem(resourceType.code);
	endforeach;
	
end;</source>
        <Parameter name="_theForm" type="SOP_TableMaintForm"/>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
    </JadeMethod>
