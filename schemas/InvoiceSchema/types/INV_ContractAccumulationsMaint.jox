    <JadeMethod name="setCaption" id="eca9f375-7d3f-4820-8bf2-14e47b218293">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	myCaption : String;
begin
	
	myCaption := self.caption &amp; " - ";
	
	if self.myInvoiceContractDtlsVolBased &lt;&gt; null then
		myCaption &amp;= self.myInvoiceContractDtlsVolBased.auditId();
	endif;
	
	if self.myBusinessUnit &lt;&gt; null then
		myCaption := myCaption &amp; " " &amp;  self.myBusinessUnit.code;
	endif;
	
	inheritMethod(myCaption);
	
epilog

end;</source>
