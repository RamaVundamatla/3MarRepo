    <JadeMethod name="getDisplayStringForAttribute" id="49a7e305-ae34-4286-9812-d2056b7ff262">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _attrName = ETRow_Description  then
		return self.description;
	endif;	
	return inheritMethod(_attrName, _short);


end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ffaacb01-7e6a-4f97-9979-b837176047cc">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created by cnwdvb1 on 30 March 2007
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	delayGroup : SelfType;
	completedOK		: Boolean;

begin
	
	delayGroup := inheritMethod();
	
	self.allDelayTypes.copy(delayGroup.allDelayTypes);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return delayGroup;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete delayGroup;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="136d5c2b-b4e0-4462-a1ce-d1a4f4488a5e">
        <updating/>
        <source>setForCreate(pProxyDelayTypeGroup : CM_DelayTypeGroup) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	pProxyDelayTypeGroup.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(pProxyDelayTypeGroup);
	self.myRoot := app.myRoot;

end;
</source>
        <Parameter name="pProxyDelayTypeGroup" type="CM_DelayTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b3cf31f1-b82c-46c2-9d5e-468cecbb1cc3">
        <updating/>
        <source>setForUpdate(pProxyDelayTypeGroup : CM_DelayTypeGroup ) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.description := pProxyDelayTypeGroup.description.trimBlanks;
	self.allDelayTypes.clear();
	pProxyDelayTypeGroup.allDelayTypes.copy(self.allDelayTypes);
end;
</source>
        <Parameter name="pProxyDelayTypeGroup" type="CM_DelayTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e8c2744c-0f65-4efd-b675-e64db437666c">
        <updating/>
        <source>setProxy(_root : CM_Root; _description : String; _allDelayTypes : CM_DelayTypeSet) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.description := _description;
	self.myRoot := _root;
	self.allDelayTypes.clear;
	_allDelayTypes.copy(self.allDelayTypes);
end;
</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_allDelayTypes" type="CM_DelayTypeSet"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="02b3301a-9cc1-420d-b004-ee1832ad37ad">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable	
----------   ----------  --------------------------------------------------
*/
vars
	tmpDelayTypeGroup : CM_DelayTypeGroup;
begin
	// ************ do i need to check for duplicates? ******************
	tmpDelayTypeGroup := self.myRoot.allDelayTypeGroups.getAtKey(self.description);
	if tmpDelayTypeGroup &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, 'Delay Type Group', self.description, ETRow_Description, null); //13.06.2022 navds20 53760
		//Delay Type Group already exists for %1 : Delay_type_group_alread_exists
		app.raiseCMException1(Delay_type_group_alread_exists, self.description, ETRow_Description, null); //13.06.2022 navds20 53760
	endif;
	
	self.validateMe();

end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="8bc0988b-88ce-4602-b5e3-85377b6800b2">
        <source>validateForDelete();
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	whereUsed : String;

begin

	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.description, whereUsed, null, self);
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c72b0171-9acf-470a-8650-a07385649832">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.validateMe();
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="a596bd47-d543-4f75-877d-71f6f61f2638">
        <source>validateMe() protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Description), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
	//. need to add to translations
		app.raiseCMException1(Error, app.getErrorString(ERROR_Root), null, null);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
