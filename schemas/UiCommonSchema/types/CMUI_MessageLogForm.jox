    </JadeMethod>
    <JadeMethod name="doShowUnformatted" id="5d569b74-bc5a-40cf-9be6-c608b8a8d0d0">
        <updating/>
        <source>doShowUnformatted() protected, updating;
/*

Purpose:			Moved from btnUnformatted_click

Parameters:			

Return Value:		

Date				Who		Reason
21 August 2023		navmd1	Initial creation TFS 59024 Handle JSON messages

*/

vars
	message : String;
begin
	self.unformatted := not self.unformatted;
	self.allMessages.clear();
	
	if self.clearFormattingOnly then
		self.jtxtMessages.configureFor_Text();
		self.jtxtMessages.viewLinenumbers := false;
		
		if self.myObject &lt;&gt; null then
			self.jtxtMessages.text := null;
			self.setMyObject(self.myObject);
		endif;
		
		self.btnUnformatted.enabled := false;	// Can't go back to formatted (for now)
	else		
		self.showJsonData(); //jlier1 TFS 56856 12/4/23		
	endif;
	
	self.jtxtMessages.readOnly:=false;
		
	self.jtxtMessages.selectAll();
	self.jtxtMessages.cutToClipboard();
	self.jtxtMessages.emptyUndoBuffer();

	foreach message in self.allMessages do
		self.jtxtMessages.addText(JadeTextEdit.ADDTXT_APPEND,message &amp; CrLf);
	endforeach;

	self.jtxtMessages.readOnly:=true;
	
	self.jtxtMessages.selStart := 0;
	self.jtxtMessages.selLength := 0;
	self.jtxtMessages.moveCaret(JadeTextEdit.MVCRT_VIEWCARET, 0, 0);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handle1StopVBS" id="44bf3bb8-ff15-468f-9b25-52e6f148eccc">
        <source>handle1StopVBS(_formatted : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2023	navsp1	Initial creation - Bug 55822: AAT - External Web Service Monitor for 1Stop VBS Response Data

*/

vars

begin
	if _formatted then		
		self.myObject.CM_EWSActivity1Stop.description.formatJSONForDisplay().asStringHugeArrayByDelimiter(self.allMessages,CrLf);
	else	
		self.myObject.CM_EWSActivity1Stop.description.asStringHugeArrayByDelimiter(self.allMessages,CrLf);
	endif;
epilog

end;</source>
        <Parameter name="_formatted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCMHugeString" id="696c3574-e1b8-4628-8556-4b16b590f485">
        <updating/>
        <source>setCMHugeString(_caption : String; _hugeString : CM_HugeString) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2024	navra1	Initial creation for DEFECT 62578 - Make the API Activity screen more user friendly

*/

vars

begin
	
	self.caption := _caption;
	if _hugeString.hugeString &lt;&gt; null then
		_hugeString.hugeString.getHugeTokensForDelimiter(CrLf, self.allMessages);
	endif;

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_hugeString" type="CM_HugeString"/>
    </JadeMethod>
    <JadeMethod name="setMyObject" id="d1eec548-7920-4292-81e8-4f9b623bc263">
        <updating/>
        <source>setMyObject( _object : CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Sep 2018	jlger1	Initial creation
07 APR 2022	navhl20 TFS 52777 EUP - INT - Generic API: record-scan
10 JAN 2022	navsp1	Bug 55822: AAT - External Web Service Monitor for 1Stop VBS Response Data
13 Jan 2023	navdap1	TFS 55159 MTN Export CAMS to JSON API Endpoint
05 Apr 2023	navpw1	Defect 57382 - Added support for EDBIC Activity History, plus refactored code
12 Apr 2023 jlier1 TFS 56856 - finance one also changed so generic to handle any External Web Service Activity
18 AUg 2023	navmd1	TFS 59024 Handle JSON POST /SendEDI requests
02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
17 December 2024    navsp1 MTN-33438 MTN - EWS monitor form - Messages not formatted
21 February 2025	NAVRV30	JIRA 34032 EUP | FR - 54090 - Invoice API activity - Message truncation
*/

vars
	extWebServiceActivity		: CM_ExternalWebServiceActivity;	// ### TFS 57382 29Mar2023 NAVPW1
	activityHistoryExtInterface : CM_ActivityHistoryExtInterface;	// ### TFS 57382 29Mar2023 NAVPW1
	taskHistory					: CM_CamTaskHistory;
begin
	self.myObject:=_object;
	
	if self.myObject.isKindOf(	CM_ActivityHistoryExtInterface) then
		activityHistoryExtInterface := self.myObject.CM_ActivityHistoryExtInterface;
		self.allMessages.add("REQUEST");
		activityHistoryExtInterface.request.asStringHugeArrayByDelimiter(self.allMessages,CrLf); // ### TFS 50669 23AUG2021 NAVAB1
		self.allMessages.add("");
		self.allMessages.add("RESPONSE");
			
		activityHistoryExtInterface.response.asStringHugeArrayByDelimiter(self.allMessages,CrLf); // ### TFS 50669 23AUG2021 NAVAB1
		if activityHistoryExtInterface.errors &lt;&gt; null then
			self.allMessages.add("");
			self.allMessages.add("ERRORS");
			activityHistoryExtInterface.errors.asStringHugeArrayByDelimiter(self.allMessages,CrLf); // ### TFS 50669 23AUG2021 NAVAB1
		endif;
			
		self.caption:= activityHistoryExtInterface.description;
		
	elseif self.myObject.isKindOf(CM_ExternalWebServiceActivity) then
		extWebServiceActivity := self.myObject.CM_ExternalWebServiceActivity;
		if extWebServiceActivity.isOneStop then  //10Jan2022 navsp1 TFS 55822
			self.handle1StopVBS(true);
			self.caption := extWebServiceActivity.CM_EWSActivity1Stop.dataType;
		elseif extWebServiceActivity.isKindOf(CM_EWSActivityQships) then
			if extWebServiceActivity.myExtWebserviceDef &lt;&gt; null and extWebServiceActivity.myExtWebserviceDef.isNSWOnePortDef() then 	//MTN-33438
				self.unformatted := true;																								//MTN-33438
				self.showJsonData();																									//MTN-33438
			else
				if extWebServiceActivity.request &lt;&gt; null then
					self.myXMLString := "REQUEST" &amp; CrLf &amp; extWebServiceActivity.request &amp; CrLf;
				endif;
				if extWebServiceActivity.response &lt;&gt; null then
					self.myXMLString := self.myXMLString &amp; "RESPONSE" &amp; CrLf &amp; extWebServiceActivity.response;
				endif;
			endif;
			self.caption := extWebServiceActivity.description;
		//02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
		elseif extWebServiceActivity.isKindOf(CM_EWSActivityAPILog) then    
			if extWebServiceActivity.request &lt;&gt; null then
				self.myXMLString := "REQUEST" &amp; CrLf &amp; extWebServiceActivity.request &amp; CrLf;
			endif;
			if extWebServiceActivity.response &lt;&gt; null then
				self.myXMLString := self.myXMLString &amp; "RESPONSE" &amp; CrLf &amp; extWebServiceActivity.response;
			endif;	
			self.caption := extWebServiceActivity.description;
		elseif extWebServiceActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then    //21 February 2025	NAVRV30	JIRA 34032
			self.showJsonDataInvoicing();
			self.caption := extWebServiceActivity.description;
		//navra1 - MTN-34782 - 15th July 2025 - start
		elseif extWebServiceActivity.isKindOf(CM_EWSActivityAgGateway) then
			self.showXMLDataAgGateway();
			self.caption := extWebServiceActivity.createdTime.asStringJMT() &amp; " - " &amp; extWebServiceActivity.description;
		//navra1 - MTN-34782 - 15th July 2025 - end
		else 
			//jlier1 TFS 56856 3/4/22
			self.unformatted:=self.myObject.isKindOf(CM_EWSActivityFinanceOne); //jlier1 TFS 56856 3/4/22
			self.showJsonData();		// ### TFS 57382 04Apr2023 NAVPW1
			self.caption := extWebServiceActivity.description;
		endif;
	elseif self.myObject.isKindOf(CM_CamTaskHistory) then
		taskHistory := self.myObject.CM_CamTaskHistory;
		self.showCAMSJsonData(taskHistory);
		self.caption := taskHistory.camProtocol.code &amp; " - " &amp; taskHistory.camProtocol.description;
		self.clearFormattingOnly := true;
	elseif self.myObject.isKindOf(CM_EDIFile) then
		self.showEDIJsonData(self.myObject.CM_EDIFile);
		if self.caption = self.class.name then
			self.caption := "EDI Data";
		endif;
		self.clearFormattingOnly := true;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyString" id="fd5b25bd-d87c-4377-8009-bef00e2b5067">
        <updating/>
        <source>setMyString(_caption, _str : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navhl20	ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars

begin
	self.caption:= _caption;
	_str.asStringHugeArrayByDelimiter(self.allMessages,CrLf);
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTxtLanguage" id="726f34de-134b-4b5d-9753-b6dc06d6b944">
        <source>setTxtLanguage() protected;
/*

Purpose:			Sets  the language styling the jadeTextEdit Control "jtxtMesssages" should be using

Parameters:			

Return Value:		

Date				Who		Reason
26 November 2019	jlgzm1	Initial creation TFS 47653 Changing how EDI Webservice Monitor displays XML
21 Nov 2022			jlika1	TFS 54892 POB - Vessel, Voyage and Movement EDI Messages
18 August 2023		navmd1	TFS 59024 Handle JSON EDI Messages (as well as CAMS)
*/

vars
	
begin
	if (self.myObject &lt;&gt; null and (self.myObject.isKindOf(CM_ActivityHistoryExtInterface) or self.myObject.isKindOf(CM_EWSActivityQships)))
	or self.myXMLString &lt;&gt; null then
		self.jtxtMessages.language := JadeTextEdit.SCLEX_XML;
		self.jtxtMessages.applySettings();
		return;	
	endif;
	
	// Testing - This could do with being made a little more generic for general JSON messages
	if self.myObject &lt;&gt; null and 
		(self.myObject.isKindOf(CM_CamTaskHistory) or self.myObject.isKindOf(CM_EDIFile)) then
		self.jtxtMessages.language := JadeTextEdit.SCLEX_JAVASCRIPT;
		self.jtxtMessages.viewLinenumbers := true;
		self.jtxtMessages.applySettings();
		return;
	endif;
	
	// Default to python, don't applySetting to maintain appearance for
	// YRD_QueueForm - query machine assignment
	self.jtxtMessages.language :=  JadeTextEdit.SCLEX_PYTHON;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8eae7f1f-e521-48e6-b4a5-1f3c0cf709f1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
08 September 2009	cnwer1	Initial creation
25 November 2019	jlgzm1	TFS 47653 Changing how EDI Webservice Monitor displays XML
14 September 2023	navmd1	TFS 60086 Avoid making calls to JadeTextEdit::addText as its a (relatively) slow external method!
11 November 2024	navlw1	Jira-32978: MTN - Ctrl-Shift-G on column has count of 0
*/

vars
	message : String;
	count : Integer;
begin
	inheritMethod();
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	self.btnClose.visible:=false;
	self.jtxtMessages.backColor:=White; //jlier1 TFS 56856 - this is only an issue in Jade 2022
	self.jtxtMessages.top:=self.frmToolbar.height;
	self.jtxtMessages.height:=self.clientHeight - self.jtxtMessages.top - 20;
	//self.jtxtMessages.language := JadeTextEdit.SCLEX_PYTHON; // TFS 47653
	self.jtxtMessages.fontSize:=10;
	self.jtxtMessages.clearAllStyles();
	self.jtxtMessages.setStyleAttributes(JadeTextEdit.STYLE_DEFAULT, self.jtxtMessages.fontName,
	self.jtxtMessages.fontSize.Integer, self.jtxtMessages.foreColor, self.jtxtMessages.backColor,
	self.jtxtMessages.fontBold.Integer, self.jtxtMessages.fontItalic.Integer,
	self.jtxtMessages.fontUnderline.Integer, JadeTextEdit.ATTRIB_FALSE);
	
	
	self.jtxtMessages.copyDefaultToAllStyles();
	self.jtxtMessages.changeKeywords(JadeTextEdit.KEYWORDS_TOLANGDEF, 0, "");
	
	self.jtxtMessages.markerMargin := true;
	self.jtxtMessages.setLinemarkAttributes(JadeTextEdit.MARKER_JAD_LINEMARK, JadeTextEdit.SC_MARK_ARROW,// SC_MARK_ROUNDRECT, 
                      Black, LightGreen);
	//bindKeyToCommand(J_key_F7+KEYMOD_CTRL, SCI_TOGGLE_JADE_LINEMARK);
	
	self.setTxtLanguage(); // TFS 47653
	self.jtxtMessages.folding:=true;
	self.jtxtMessages.foldSymbols:=JadeTextEdit.SC_FOLDSYM_TREESQUARE ;//SC_FOLDSYM_PLUSMINUS;
	self.jtxtMessages.readOnly:=false;
	self.jtxtMessages.wrapMode:=JadeTextEdit.SC_WRAP_WORD;
	self.jtxtMessages.wrapIndent:=0;

	message := self.allMessages.concatenate(CrLf);
	self.jtxtMessages.addText(JadeTextEdit.ADDTXT_APPEND, message &amp; CrLf);
	
	// Don't do this, this is slow!
	/*foreach message in self.allMessages do
		self.jtxtMessages.addText(JadeTextEdit.ADDTXT_APPEND,message &amp; CrLf);
	endforeach;*/
	
	if self.myXMLString &lt;&gt; null then												// TFS 47653									
		self.jtxtMessages.addText(JadeTextEdit.ADDTXT_APPEND, self.myXMLString);	// TFS 47653
	endif;

	self.jtxtMessages.readOnly:=true;
	
	self.jtxtMessages.firstVisibleLine := 1; // ### TFS 51855 08FEB2022 NAVAB1 Scroll to the top
	
	// navlw1 Start #Jira-32978
	count := self.jtxtMessages.lineCount - 3; // minus three is the the two white spaces and heading
	self.statusLine.caption := app.getErrorString(Total) &amp; Space &amp; count.String;
	// navlw1 End #Jira-32978
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="show" id="2450c012-eea9-4af3-8f7e-860cae565aaf">
        <updating/>
        <source>show() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 September 2023	navmd1	TFS 60086 Loading large messages might take a while so display the spinning wheel of doom

*/

vars

begin
	app.mousePointer := Window.MousePointer_HourGlass;

	inheritMethod();

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showCAMSJsonData" id="f1dc2226-ea54-44c4-b474-8be49aa9a89a">
        <source>showCAMSJsonData(_taskHistory : CM_CamTaskHistory) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2023	navmd1	Initial creation TFS 58947
26 April2024    navsp1  Bug 61182: EUP - Damage &amp; Repair message is not formatted correctly in Display when large
30 August 2024	navhn30	Bug 65667: MTN - Reverse Changes made for 61182 for handling large JSON messages
*/

vars
	allMsgs,
	msg,
	jsonString	: String;
	pos,
	curPos		: Integer;
	agent		: CMIF_JsonHelper;
	maxLength	: Integer;
	//jsonSubStr, 					//TFS 61182
	//formattedSubStr  : String;		//TFS 61182
	//crPos, 							//TFS 61182
	//splitPos 	: Integer;			//TFS 61182
	//cam 		: CM_CamProtocol;	//TFS 61182
	//cntr 		: Integer;			//TFS 61182
begin
	
	create agent transient;
//	create cam transient;			//TFS 61182	//30.08.24	navhn30	TFS 65521
	allMsgs := _taskHistory.getRawDataString();
	maxLength := self.allMessages.getMaxLength();

	// Return early if there is nothing to show
	if allMsgs = null then
		return;
	endif;
	while true do
		pos += 1;
		//30.08.24	navhn30		TFS 65521  start
		//This will handle the large message string (message length &gt; maxLength,-					//TFS 61182
		//or the message contains 'split delimeter') 												//TFS 61182
		/*splitPos 	:= allMsgs.pos(CM_CamProtocol.JSON_Split_Delimeter.String, pos);				//TFS 61182
		crPos 		:= allMsgs.pos(Cr, pos);														//TFS 61182
		if splitPos &gt; 0 or (splitPos = 0 and crPos &gt; maxLength) then								//TFS 61182
			app.writeLog(method.qualifiedName &amp; "JSON split message", LogDEBUG);					//TFS 61182
			//Handle multiple messages																//TFS 61182
			//Split JSON by 'split delimeter'														//TFS 61182		
			cntr := 0;																				//TFS 61182
			while true do																			//TFS 61182
				if pos &gt; 1 then																		//TFS 61182
					pos  +=1;																		//TFS 61182
				endif;																				//TFS 61182
				cntr +=1;																			//TFS 61182
				jsonSubStr := cam.splitJsonMessage(allMsgs, pos);									//TFS 61182
				formattedSubStr := agent.formatJsonString(jsonSubStr);								//TFS 61182
				if formattedSubStr &lt;&gt; null then														//TFS 61182
					jsonSubStr := formattedSubStr;													//TFS 61182
				endif;																				//TFS 61182
				jsonSubStr.getHugeTokensForDelimiter(CrLf, self.allMessages);						//TFS 61182
				self.allMessages.add(null);															//TFS 61182
				if pos &gt;= allMsgs.length then														//TFS 61182
					pos := 0;																		//TFS 61182
					break;																			//TFS 61182
				endif;																				//TFS 61182
				if cntr &gt; 20 then																	//TFS 61182
					pos := 0;																		//TFS 61182
					app.writeLog( method.qualifiedName &amp; "Infinite loop", LogERROR);				//TFS 61182
					break;																			//TFS 61182
				endif;																				//TFS 61182
			endwhile;																				//TFS 61182			
		else	*/																					//TFS 61182
		//30.08.24	navhn30		TFS 65521  end
			msg := allMsgs.scanUntil(Cr, pos);
			
			jsonString := agent.formatJsonString(msg);	// Pretty-Print all the things
			if jsonString &lt;&gt; null then
				jsonString.getHugeTokensForDelimiter(CrLf, self.allMessages);
			else
				// Something went wrong with the transform, ok, lets show at least some of the raw data
				curPos := 1;
			while curPos &lt; msg.length do
					self.allMessages.add(msg[curPos:maxLength]);		//30.08.24	navhn30	TFS 65521
					curPos += maxLength;
				endwhile;
			endif;
		//endif;
		if pos = 0 then
			break;
		endif;
		
		// It doesn't make all that much difference, but lets attempt to add a separator
		self.allMessages.add(null);
	endwhile;
	
epilog
	delete agent;
	//delete cam;		//TFS 61182
end;</source>
        <access>protected</access>
        <Parameter name="_taskHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="showEDIJsonData" id="8884ebbb-ee0e-4531-bbc2-e0e7b34c73db">
        <source>showEDIJsonData(_file: CM_EDIFile) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		navmd1	Initial creation TFS 59024
21 August 2023		navmd1 	TFS 59451 - MTN - Not displaying EDI Raw Data greater than 16k characters correctly

*/

vars
	agent			: CMIF_JsonHelper;
	jsonString		: String;
	resString		: String;
	pos				: Integer;
	notJson			: Boolean;
begin	
	create agent transient;
	
	if self.isXMLRequest then
		// No file data for some reason, so just return early ?
		if _file.getWebReqStrLength() = 0 then
			return;
		endif;
		
		if self.unformatted then
			jsonString := _file.getWebReqString();
		else
			jsonString := agent.formatJsonString(_file.getWebReqString());
		endif;
	
	elseif self.isXMLResponse then
		// No file data for some reason, so just return early ?
		if _file.getWebResStrLength() = 0 then
			return;
		endif;
		
		// The Response will include the Content-Type and Response-Code
		resString := _file.getWebResString();
		pos := 1;
		
		//self.allMessages.add(resString.scanUntil(CrLf, pos));	// Content-Type
		resString.scanUntil(CrLf, pos);	// skip the Content-Type, its always JSON, so who cares
		resString.scanWhile(CrLf, pos);
		
		if not self.unformatted then
			self.allMessages.add(resString.scanUntil(CrLf, pos));	// Status-Code
			self.allMessages.add(null);	// Add an empty line as a separator
		else
			resString.scanUntil(CrLf, pos);	// skip the Status-Code if show unformatted responses
		endif;
		resString.scanWhile(CrLf, pos);
	
		if self.unformatted then
			jsonString := resString[pos:end];
		else
			jsonString := agent.formatJsonString(resString[pos:end]);
		endif;
	else
		if self.isEDIPostTransform then
			if _file.getRawDataLength() = 0 then
				return;
			endif;

			resString := _file.getRawDataString();
			if _file.myEDIFileType &lt;&gt; null and not _file.myEDIFileType.isJSON() then
				notJson := true;
			endif;
		else
			if _file.getOriginalFileDataString().length = 0 then
				// The only way to get in here is if we are an XML message, and haven't specified request or response for some reason
				// So - just grab and display the raw string
				resString := _file.getRawDataString();
				notJson := true;
			else
				resString := _file.getOriginalFileDataString();
			endif;
		endif;
		
		if self.unformatted or notJson then
			jsonString := resString;
		else
			jsonString := agent.formatJsonString(resString);
		endif;

	endif;
	
	jsonString.getHugeTokensForDelimiter(CrLf, self.allMessages);
	
epilog
	delete agent;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="showJsonData" id="95778ba9-3f94-4e2b-bcb0-aba3a02c3877">
        <source>showJsonData() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2023	navpw1	Initial creation TFS: 57382
12 Apr 2023 jlier1 TFS 56856 - finance one also changed so generic to handle any External Web Service Activity
*/

vars
	responseHeader : String;
	activity : CM_ExternalWebServiceActivity;
begin
	activity:=self.myObject.CM_ExternalWebServiceActivity;
	responseHeader := "RESPONSE";
	
	if activity.responseCode &gt; 0 then
		responseHeader &amp;= Space &amp; "-" &amp; Space &amp; activity.responseCode.asStringJMT &amp; Space &amp; app.httpStatusCodeEnumToString(activity.responseCode);
	endif;
	
	if self.unformatted then
		self.allMessages.add("REQUEST");
		self.allMessages.add("");
		activity.request.formatJSONForDisplay().asStringHugeArrayByDelimiter(self.allMessages,CrLf); 
		
		self.allMessages.add("");
		self.allMessages.add(responseHeader);
		activity.response.formatJSONForDisplay().asStringHugeArrayByDelimiter(self.allMessages,CrLf); 
	else
		self.allMessages.add("REQUEST");
		self.allMessages.add("");
		activity.request.asStringHugeArrayByDelimiter(self.allMessages,CrLf);
		
		self.allMessages.add("");
		self.allMessages.add(responseHeader);
		activity.response.asStringHugeArrayByDelimiter(self.allMessages,CrLf);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showJsonDataInvoicing" id="fa004101-9911-4e78-8fb4-872830b0ef60">
        <source>showJsonDataInvoicing() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2025	NAVRV30	JIRA 34032 EUP | FR - 54090 - Invoice API activity - Message truncation
*/


vars
	responseHeader : String;
	activity : CM_ExternalWebServiceActivity;
	jsonHelper	: CMIF_JsonHelper;
	formattedVal : String;
begin
	create jsonHelper transient;
	activity:=self.myObject.CM_ExternalWebServiceActivity;
	responseHeader := "RESPONSE";
	
	if activity.responseCode &gt; 0 then
		responseHeader &amp;= Space &amp; "-" &amp; Space &amp; activity.responseCode.asStringJMT &amp; Space &amp; app.httpStatusCodeEnumToString(activity.responseCode);
	endif;
	
	self.allMessages.add("REQUEST");
	self.allMessages.add("");
	formattedVal := jsonHelper.formatJsonString(activity.request);
	if formattedVal &lt;&gt; null then
		formattedVal.asStringHugeArrayByDelimiter(self.allMessages,CrLf);
	elseif activity.request &lt;&gt; null then
		activity.request.formatJSONForDisplay().asStringHugeArrayByDelimiter(self.allMessages,CrLf);
	endif;
	
	
	self.allMessages.add("");
	self.allMessages.add(responseHeader);
	activity.response.formatJSONForDisplay().asStringHugeArrayByDelimiter(self.allMessages,CrLf); 	
epilog
	delete jsonHelper;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showXMLDataAgGateway" id="f93da770-7f96-42b8-ae3e-2af64a475a55">
        <source>showXMLDataAgGateway();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars	
	activity : CM_EWSActivityAgGateway;	
	formattedVal : String;
begin
	
	
	if self.myObject.isKindOf(CM_EWSActivityAgGateway) then
		activity:=self.myObject.CM_EWSActivityAgGateway;
	else		
		return;
	endif;
	
	self.myObject.CM_EWSActivityAgGateway.sendRecvMessage.asStringHugeArrayByDelimiter(self.allMessages,CrLf);	
epilog
	
end;</source>
    </JadeMethod>
