    <JadeMethod name="changeToDoTasksStatus" id="e2808a60-3017-4250-b3c8-806de87186fb">
        <updating/>
        <source>changeToDoTasksStatus(_newStatus : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//	Date				Who		Reason
//  28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
//--------------------------------------------------------------
vars
	task : CM_ToDoTask;
	newTrans : CM_TITransaction;
begin
	if _newStatus &lt;&gt; STATUS_COMPLETE then
		return;
	endif;
	foreach task in self.allToDoTasks do
		if task.status &lt;&gt; _newStatus then
			task.setTaskComplete(_passport, true, newTrans);
		endif;
	endforeach;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createWLE" id="b0d55bbb-d4f3-43ef-b1b6-6813c25506ad">
        <source>createWLE(): CM_WorkListEntry;
// ---------------------------------------------------------------------------//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date			Who		Reason
// 28 Sep 2022 navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// 19 Apr 2023 navma1   ChangeRequest 57326:[57327] EUP - VAS Task linked with Pack or Unpack Work Order
// ---------------------------------------------------------------------------
vars
	wle	: CM_WOToDoWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);
	return wle;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="7bd10869-eb12-4eda-bcf7-381a10ebf903">
        <source>createWLEs();
// ---------------------------------------------------------------------------
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date				Who		Reason
// 28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// ---------------------------------------------------------------------------
vars

begin

	if (self.allWorkListEntries.size &gt; 0) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_HAS_WL_ENTRIES, null, null);
		return;
	endif;

	self.createWLE();

end;</source>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="3adcd1a8-df9e-4343-9fc7-dd1fb7c20fc1">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
//
// Date				Who		Reason
// 28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_To_Do_Task), DC_Label, 1, null);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getWORequestByType" id="0c4d0c4c-fa0d-4527-99d8-c3b510a175f1">
