        <updating/>
        <source>showVoyageJobPriorityForm(_obj : CM_Object; _menuAction : CMUI_MenuAction; _class : Class ) updating;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	voyJobForm : SHP_JobPriority;
	menuAction : CMUI_MenuAction;
begin
	if _obj = null then
		return;
	endif;

	menuAction := app.myController.createMenuAction(PmShpJobPriorityView, null, _menuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;

	voyJobForm := menuAction.goToObject(null, null, false, null).SHP_JobPriority;

	if voyJobForm = null then
		return;
	endif;
	
	voyJobForm.priorityObject := _obj;
	voyJobForm.priorityClass := _class;
	voyJobForm.show();

end;</source>
