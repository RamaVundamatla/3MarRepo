<Class name="Object">
    <JadeMethod name="jssGetInstanceId" id="3582ac15-e23a-459b-a031-d54a0829a3f0">
        <source>jssGetInstanceId():Integer;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns the instance ID number of the receiver.
//
// Parameters:	None
//
// Returns:		The instance ID number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oidString	: String;
	startPos	: Integer;
	
begin
	startPos	:=	1;
	oidString	:=	self.getOidStringForObject(self);
	startPos	:=	oidString.reversePos(".") + 1;
	
	return oidString[startPos:end].Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
