    <JadeMethod name="doResize" id="45d23571-d815-4531-8086-d6a53738e814">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.msgLines.move(0,0,self.msgLines.parent.width,self.msgLines.parent.height);
	self.msgDebtors.move(0,0,self.msgLines.parent.width,self.msgLines.parent.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="675b7d6f-9379-4d66-b746-efa4a3e6ea05">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 14/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge Changes
// 31/01/2023	navvt20		TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

vars
	pxyInvoiceLineDesc	: CM_DebtorInvoiceLineDesc;
	table				: CM_EntryTable;
	theReturn : Integer;
	theController : CMIF_InvoiceLineDescDebtor;
begin


	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyInvoiceLineDesc transient;
	elseif self.mode = Mode_Update then
		pxyInvoiceLineDesc := self.myProxyObject.CM_DebtorInvoiceLineDesc;
	else
		return false;
	endif;
	create theController transient;
	self.msgLines.getSelected(theController.allInvoiceLineDescriptions);
	self.msgDebtors.getSelected(theController.allConsolidatingDebtor);
	pxyInvoiceLineDesc.setProxyBank(self.myCurrentBank);
	
	pxyInvoiceLineDesc.setProxy(false,false,null,null,null,null,//CP CCMS 1047 PAR 16666 cnwgb1 16 April 2008
								self.tblEntDetail.getValueByName(ETRow_Narration).String,
								null,self.tblEntDetail.getValueByName(ETRow_Remarks).String,
								//null,null, false);						// PAR #36909
								null,null, false, null, null, null, false, false,null,null	// PAR #36909 // 31 Jan 2023 navvt20 TFS 56134
								);		
	// 35872 use selected business unit
	pxyInvoiceLineDesc.setProxyBank(self.myCurrentBank);
	theController.myBank := self.myCurrentBank;
	theController.myProxyInvoiceLineDebtor := pxyInvoiceLineDesc;
	
	while true do
 
	 	if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceLineDescDebtor(theController,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceLineDescDebtor(theController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Consolidation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvoiceLineDesc;
	endif;
	delete theController;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="0304fcb4-e861-4d60-85ac-fdebfb1ea88e">
