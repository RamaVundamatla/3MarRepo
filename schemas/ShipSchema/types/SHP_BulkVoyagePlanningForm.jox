    <JadeMethod name="displayHolds" id="2d1eeaef-5deb-418c-9732-ce3178102d39">
        <source>displayHolds(_theObject : Object) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	hold : CM_GeneralCargoController;
	string : String;
	first : Boolean;

begin
	if _theObject &lt;&gt; null then
		if self.selectMode = self.SelectModeHold then
			if _theObject.isKindOf(CM_ShipBlockController) then
				string := "Ship Block Stack";		// 20/7/16 cnwmp6 TFS 1601
			else
				hold := _theObject.CM_GeneralCargoController;
				first := true;
				string := "Hold " &amp; hold.getID;
			endif;
			return string;
		else
			return null;
		endif;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayModeActual" id="aed60cb1-3185-4602-bec5-89e55d63c1bd">
        <updating/>
        <source>displayModeActual(_doClick : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.btnActual.value := true;
	self.btnViewOps.value := false;
	self.btnViewByWeight.value := false;
	self.btnViewByVolume.value := false;
	self.btnViewByWeight.enabled := false;
	self.btnViewByVolume.enabled := false;

	self.frmToolbar.visible:= not self.xmlToolbar; //epr par 36003 29/4/15
	
	self.enableDisableImexBtns(true, true);

	self.btnSaveBase.visible		:= false;
	self.btnImportTasks.enabled		:= true;
	self.btnCustomsEDI.enabled		:= true;
	self.btnSummariseAll.enabled	:= true;	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.btnSummariseAll.bubbleHelp := app.getErrorString(Summar_onship_cargo_enquir_pur);
	
	self.frmStatusLine.myFrameDisplayMode.enabled := true;
	self.frmStatusLine.myFrameMoveMode.enabled := true;
	self.frmStatusLine.enabled := true;

	if self.displayMode = ShpDisplayMode_Actual and _doClick then // not EDI
		self.frmStatusLine.setDisplayMode(DISPLAY_MODE_ACTUAL);
	endif;
	
	self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_INSTANT);
	self.frmStatusLine.myFrameDisplayMode.enabled := true; 
	self.frmStatusLine.myFrameMoveMode.enabled := true;
	self.frmStatusLine.displayMode := DISPLAY_MODE_ACTUAL;
epilog

end;</source>
        <Parameter name="_doClick" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayModeDefn" id="497adff4-8f42-4cc9-ae49-c2771be11b0f">
