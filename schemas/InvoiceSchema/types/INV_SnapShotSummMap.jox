    <JadeMethod name="doControlEvent" id="c6c932bd-1e60-49bb-9240-232f5f0b2eb4">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
// this is called after list box population
vars
	bool : Boolean;
begin
	if _control.isKindOf(Button) then
		if _control = self.msgbAttr.myAddSelectedBtn or
		   _control = self.msgbAttr.myRemoveSelectedBtn then
			self.populateDebtorCombo();
		endif;
	endif;
end;
</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="366429d1-193f-48e2-899b-9be06dadaabf">
        <updating/>
        <source>doSave() : Boolean updating;
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	ls : Boolean;
	pxySB, realSB : CM_ServiceBroker;
	debtorProp	: CM_QueryProperty;
	debtorType	: CM_DebtorType;
	defaultQtyType	: CM_XTABField;
	obj			: Object;
	yaCriteria	: IntegerArray;
	selected	: ObjectArray;
	theReturn	: Integer;
begin
	if not self.validateInput then
		return false;
	endif;

	if self.mode = Mode_Add then
		create pxySB as CM_SnapShotServiceBroker transient;
	else
		app.cmsBeginLoad(ls);
		pxySB := app.createUpdateProxy(self.mySnapShotBroker).CM_SnapShotServiceBroker;
		app.cmsEndLoad(ls);
	endif;
	
	create selected transient;
	create yaCriteria transient;
	self.msgbAttr.getSelected(selected);
	foreach obj in selected do
		yaCriteria.add(obj.CM_QueryProperty.allocationAttribute);
	endforeach;
	if self.cmbDebtor.listIndex &gt; 0 then
		debtorProp := self.cmbDebtor.itemObject[self.cmbDebtor.listIndex].CM_QueryProperty;
		debtorType := self.getDebtorType(debtorProp);
	endif;
	
	pxySB.CM_SnapShotServiceBroker.setProxySSB(yaCriteria, debtorType, defaultQtyType, self.myOutputFormat, self.myCurrentTranMapSS);

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceTMTransaction(pxySB, realSB, app.myPassport);
		else
			app.myTrxUA.trxUpdateInvoiceSSBroker(pxySB.CM_SnapShotServiceBroker, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.mode = Mode_Add then
				self.mySnapShotBroker := realSB.CM_SnapShotServiceBroker;
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog("SnapShot Summary Invoice Mapping", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

	return true;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxySB;
	delete selected;
	delete yaCriteria;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDebtorType" id="8f00f026-6c61-48e6-ae73-09573e0613b0">
        <source>getDebtorType(_qp : CM_QueryProperty) : CM_DebtorType protected;

vars
	code	: String;
	dt	: CM_DebtorType;
begin
	if _qp.allocationAttribute = YACriteriaType_Carrier then
		code := "SDT9";
	elseif _qp.allocationAttribute = YACriteriaType_Consignee then
		code := "SDT2";
	elseif _qp.allocationAttribute = YACriteriaType_Consignor then
		code := "SDT3";
	elseif _qp.allocationAttribute = YACriteriaType_FreightForward then
		code := "SDT7";
	elseif _qp.allocationAttribute = YACriteriaType_OperatorItem then
		code := "SDT1";
	elseif _qp.allocationAttribute = YACriteriaType_MTPoolParty then // TFS 3509
		code := "SDT0";
	elseif _qp.isKindOf(CM_QRefDebtorType) then
		code := _qp.propertyName[6:end];		// 'DT - &lt;code&gt;'
	endif;
	
	if code &lt;&gt; null then
		dt := app.myRoot.allDebtorTypes[code];
	endif;
	
	return dt;
end;
</source>
        <access>protected</access>
        <Parameter name="_qp" type="CM_QueryProperty"/>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeQueryProperty" id="3f8a9332-f729-41fe-984c-3451cc5200d5">
        <source>getDebtorTypeQueryProperty(_dt : CM_DebtorType) : CM_QueryProperty protected;

vars
	index	: Integer;
	code	: String;
	attr	: Integer;
	qp		: CM_QueryProperty;
	obj		: Object;
	selected	: ObjectArray;
begin
	code := _dt.code;
	if code = "SDT9" then
		attr := YACriteriaType_Carrier;
	elseif code = "SDT2" then
		attr := YACriteriaType_Consignee;
	elseif code = "SDT3" then
		attr := YACriteriaType_Consignor;
	elseif code = "SDT7" then
		attr := YACriteriaType_FreightForward;
	elseif code = "SDT1" then
		attr := YACriteriaType_OperatorItem;
	elseif code = "SDT0" then // TFS 3509
		attr := YACriteriaType_MTPoolParty;
	endif;
	
	if attr &gt; 0 then
		create selected transient;
		self.msgbAttr.getSelected(selected);
		foreach obj in selected do
			if obj.CM_QueryProperty.allocationAttribute = attr then
				qp := obj.CM_QueryProperty;
				break;
			endif;
		endforeach;
	endif;
	
	if qp = null then
		// debtor types
		foreach index in 1 to self.cmbDebtor.listCount do
			obj := self.cmbDebtor.itemObject[index];
			if obj.isKindOf(CM_QRefDebtorType) then
				if obj.CM_QRefDebtorType.propertyName = "DT - " &amp; _dt.code then
					qp := obj.CM_QueryProperty;
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	return qp;
epilog
	delete selected;
end;
</source>
        <access>protected</access>
        <Parameter name="_dt" type="CM_DebtorType"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="init" id="fb7cdc0f-6127-4ed7-bd27-702721cec5d1">
        <source>init();
vars

begin
	self.msgbAttr.caption := "";
	self.msgbAttr.distanceFromBottom 	:= 50;
	self.msgbAttr.distanceFromRight 	:= 30;
	self.msgbAttr.lockBottom 			:= false;
	self.msgbAttr.lockRight				:= false;
	self.msgbAttr.stretchHeight 		:= true;
	self.msgbAttr.stretchWidth 			:= true;
	self.msgbAttr.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.msgbAttr.formDisplayEntryMethodName := "displayAttributeName";
	self.msgbAttr.availableHeading := app.getErrorString(Available_attributes);
	self.msgbAttr.selectedHeading := app.getErrorString(Selected_attributes);
	self.msgbAttr.displayOrderBtns(true, true);
	self.msgbAttr.myBaseForm	:= self;
	self.msgbAttr.mySelectedListBox.sorted := false;
	self.msgbAttr.cnEcResizeContents();
	self.msgbAttr.readOnly := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateAttributes" id="4136e73b-8929-4fde-8d12-b58a2001a4f9">
        <updating/>
        <source>populateAttributes() updating;

vars
	attr,
	indx	: Integer;
	allGroupProps : CM_QueryPropertyArray;
	queryProp	: CM_QueryProperty;
	obj			: Object;
	avail,
	selected,
 	selectedSorted	: ObjectArray;
begin
	if self.myOutputFormat &lt;&gt; null then
		create allGroupProps transient;
		self.myOutputFormat.getGroupingProperties( allGroupProps );
		// only show usable query properties
		create avail transient;
		create selected transient;
		foreach queryProp in allGroupProps where queryProp.allocationAttribute &lt;&gt; 0 do
			avail.add(queryProp);
			if self.mySnapShotBroker &lt;&gt; null and
			   self.mySnapShotBroker.allYACriteriaTypes.includes(queryProp.allocationAttribute) then
				selected.add(queryProp);
			endif;
		endforeach;
		self.msgbAttr.setAvailable(avail, true);
		// for an existing broker sort selected into the correct sequence
		if self.mySnapShotBroker = null then
			self.msgbAttr.setSelected(selected);
		else
			create selectedSorted transient;
			foreach attr in self.mySnapShotBroker.allYACriteriaTypes do
				foreach obj in selected do
					queryProp := obj.CM_QueryProperty;
					if queryProp.allocationAttribute = attr then
						selectedSorted.add(obj);
						break;
					endif;
				endforeach;
			endforeach;
			self.msgbAttr.setSelected(selectedSorted);
		endif;
	endif;
	
	self.populateDebtorCombo();
	// show current debtor type
	if self.mySnapShotBroker &lt;&gt; null and
	   self.mySnapShotBroker.myDebtorType &lt;&gt; null then
		queryProp := self.getDebtorTypeQueryProperty(self.mySnapShotBroker.myDebtorType);
		indx := self.cmbDebtor.findObject(queryProp);
		if indx &gt; 0 then
			self.cmbDebtor.listIndex := indx;
		endif;
	endif;
	
epilog
	delete allGroupProps;
	delete avail;
	delete selected;
	delete selectedSorted;
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateDebtorCombo" id="7d39830a-bb72-4b86-9c0c-5cd59f08ea68">
        <updating/>
        <source>populateDebtorCombo() updating;

vars
	indx	: Integer;
	oa		: ObjectArray;
	obj		: Object;
	savedQp,
	qp		: CM_QueryProperty;
	allGroupProps : CM_QueryPropertyArray;

begin
	create oa transient;
	self.msgbAttr.getSelected( oa );
	if oa.size = 0 then
		self.msgbAttr.getAvailable( oa );
	endif;
	
	if self.cmbDebtor.listIndex &gt; 0 then
		savedQp := self.cmbDebtor.itemObject[self.cmbDebtor.listIndex].CM_QueryProperty;
	endif;
	self.cmbDebtor.clear();
	
	
	foreach obj in oa do
		qp := obj.CM_QueryProperty;
		if qp.isKindOf(CM_QRefDebtorType) or
		   qp.allocationAttribute = YACriteriaType_OperatorItem or
		   qp.allocationAttribute = YACriteriaType_Consignee or
		   qp.allocationAttribute = YACriteriaType_Consignor or
		   qp.allocationAttribute = YACriteriaType_FreightForward or
		   qp.allocationAttribute = YACriteriaType_MTPoolParty or  // TFS 3509
		   qp.allocationAttribute = YACriteriaType_Carrier then
			indx := self.cmbDebtor.addItem(qp.niceName);
			self.cmbDebtor.itemObject[indx] := qp;
		endif;
	endforeach;
	if self.myOutputFormat &lt;&gt; null then
		create allGroupProps transient;
		self.myOutputFormat.getGroupingProperties( allGroupProps );
		foreach qp in allGroupProps where qp.isKindOf(CM_QRefDebtorType) do
			indx := self.cmbDebtor.addItem(qp.niceName);
			self.cmbDebtor.itemObject[indx] := qp;
		endforeach;
	endif;

	// restore any previous selection, if still present
	if savedQp &lt;&gt; null then
		indx := self.cmbDebtor.findObject(savedQp);
		if indx &gt; 0 then
			self.cmbDebtor.listIndex := indx;
		endif;
	endif;
	// if only one entry, select it
	if self.cmbDebtor.listCount = 1 then
		self.cmbDebtor.listIndex := 1;
	endif;
epilog
	delete oa;
	delete allGroupProps;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDefn" id="573cfc21-9b6f-46f5-935d-767a659466a0">
        <source>populateDefn();

vars
	indx	: Integer;
	ofss	: CM_OutputFormat_SS;
begin
	self.cmbDefn.clear;
	foreach ofss in app.myRoot.allOutputFormats_SS where ofss.hasSnapShotProperties() do
		indx := self.cmbDefn.addItem(ofss.name);
		self.cmbDefn.itemObject[indx] := ofss;
	endforeach;
	
	indx := self.cmbDefn.findObject(self.myOutputFormat);
	if indx &gt; 0 then
		self.cmbDefn.listIndex := indx;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="008a3704-27c1-4a34-9408-ecfd068b151b">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	self.createMyAssistant(INV_Assistant);
	self.init();
	self.populateDefn();
	self.populateAttributes();
	
	self.minimumHeight := 500; // TFS 3509
	self.minimumWidth := 430; // TFS 3509
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c07a1f7e-7d66-4f26-8b27-3c2c13d9d362">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015160, locale);
	btnCancel.translateCaption(Xlat_0015161, locale);
	btnNewDefn.translateCaption(Xlat_0015162, locale);
	btnSave.translateCaption(Xlat_0015163, locale);
	lblAttributes.translateCaption(Xlat_0015164, locale);
	lblDebtor.translateCaption(Xlat_0015165, locale);
	lblDefn.translateCaption(Xlat_0015166, locale);
	msgbAttr.translateCaption(Xlat_0015167, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateInput" id="15a194ab-02d9-4374-add4-b0048fee2a8b">
        <updating/>
        <source>validateInput() : Boolean updating;

vars

begin
	// no attribute selection
	if self.msgbAttr.mySelectedListBox.listCount = 0 then
		app.msgBox('Please select an item from the list.', 'Selected Attributes', MsgBox_OK_Only+MsgBox_Information_Icon);	
		return false;
	endif;
	
	// no debtor type present
	if self.cmbDebtor.listCount = 0 then
		app.msgBox('There must be at least one attribute from which a Debtor can be derived.' &amp; CrLf &amp;
					'These are Carrier, Consignee, Consignor, Debtor Types, ' &amp; CrLf &amp;
					'Freight Forwarder and Operator.', 'Derive Debtor from', MsgBox_OK_Only+MsgBox_Information_Icon);	
		return false;
	endif;
	
	// no debtor type selection
	if self.cmbDebtor.listCount &gt; 0 and
	   self.cmbDebtor.listIndex &lt; 1 then
		app.msgBox('Please select an item from the list.', 'Derive Debtor from', MsgBox_OK_Only+MsgBox_Information_Icon);	
		return false;
	endif;

	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
