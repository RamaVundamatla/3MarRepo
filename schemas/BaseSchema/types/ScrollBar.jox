<GUIClass name="ScrollBar">
    <JadeMethod name="cnEcSet" id="4c4776fd-cb63-4a8b-8c4d-62b3700d13d6">
        <updating/>
        <source>cnEcSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's current position with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.value &lt;&gt; pValue then
		self.value	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
</GUIClass>
