    <JadeMethod name="tblExtra_cellInputReady" id="a93f0e20-fe4b-41f8-b325-3636b9c5ed61">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_cellInputReady(table: CM_EntryTable ; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     29 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/08/2008	cnwdad1		PAR #13863 - Moved the pre-setting of numerous comboboxes
//							from the "gotFocus" method to here.
// 20/05/2013	cnwdap1		PAR #31574 Allowable time off power editing
// ---------------------------------------------------------------------------
vars
	assistantObj	: GTE_Assistant;
	topSheetObj		: GTE_Sheet;
	tableObj		: CM_EntryTable;
	
begin
	assistantObj	:=	self.myAssistant.GTE_Assistant;
	topSheetObj		:=	self.topSheet;
	
	assistantObj.mainExtraCellInputReady(	table,
											inputControl,
											cleft,
											ctop,
											cwidth,
											cheight,
											self.saveRowHeight,
											GTE_InOutForm::getTopSheetControl.name);
	
	if inputControl.name = cmbSubTerminal.name then
		if app.isSubTerminalsOn(self.myTerminal) then
			tableObj	:=	table;
			self.setSubTerminalDefault(topSheetObj.isReceival, false, tableObj);
		endif;
	endif;
	
	if inputControl = self.txtTimeOffPower then														// PAR #31574
		tableObj := table;																			// PAR #31574
		self.txtTimeOffPower.text := tableObj.getValueByName(ETRow_AllowableTimeOffPower).String;	// PAR #31574
	endif;																							// PAR #31574
	
/*	
	if inputControl = topSheetObj.getControlByName(Cntrl_cmbLogSpecies) then
		self.doInputReadyLogSpecies(assistantObj, inputControl.GTE_ComboBox);
		
	elseif inputControl = topSheetObj.getControlByName(Cntrl_cmbLogGrade) then
		self.doInputReadyLogGrade(assistantObj, inputControl.GTE_ComboBox);
		
	elseif inputControl = topSheetObj.getControlByName(Cntrl_cmbLogType) then
		self.doInputReadyLogType(assistantObj, inputControl.GTE_ComboBox);
		
	endif;
*/
end;</source>
        <Parameter name="table" type="CM_EntryTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblExtra_change" id="721e752f-93ef-47b7-a419-26ea2f790792">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_change(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sheet		: GTE_Sheet;
	mainTbl,
	extraTbl	: CM_EntryTable;
	cmb			: GTE_ComboBox;
	code		: String;
	tmpRow		: Integer;
	cargoType	: CM_CargoBOLType;	
begin

	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	mainTbl := sheet.myTblMain;
	extraTbl := table;
	code := sheet.myMenuAction.code;
	cmb := sheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;	
	cargoType := cmb.listObject.CM_CargoBOLType;	

	if code = NavObj_GTE_In then
		self.myAssistant.GTE_Assistant.receival_tblMainExtraChange(extraTbl, mainTbl, extraTbl, cargoType, sheet.getISOType, self.myTerminal);
	endif;
	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblExtra_dblClick" id="ddb4d6a6-2fce-4582-bcea-9b57bf1e11e0">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_dblClick(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mainTable		: CM_EntryTable;
	cargoDocketId,
	imexCode		: Integer;
	imexStatusString : String;
	bookingRef		: CM_BookingRef;
	brItem			: CM_BookingRefItem;
	sheet			: GTE_Sheet;
	cmb				: ComboBox;
begin

	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	bookingRef := sheet.getBookingRefFromMenuAction();
	cmb := sheet.getControlByName(self.cmbBRItem.name).ComboBox;
	if cmb &lt;&gt; null then
		brItem := cmb.listObject.CM_BookingRefItem;
	endif;
	
	cargoDocketId	:=	sheet.getCargoBOLTypeId();
	mainTable		:=	sheet.myTblMain;
	imexStatusString:=mainTable.getValueByNameIfVisible(ETRow_StatusString).String;
	imexCode:= app.myRoot.getImexCodeFromDesc(imexStatusString);
	self.myAssistant.receival_tblDblClick(	table,
											mainTable, 
											sheet.allAttachments,
											bookingRef,
											brItem,
											cargoDocketId, 
											sheet.allTicketSequences,
											sheet.getControlByName(Cntrl_cmbSupplier).ComboBox.listObject.CM_Operator,
											null, null, null, null, imexCode, null, null, null);
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
