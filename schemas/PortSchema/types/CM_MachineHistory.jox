    <JadeMethod name="getDisplayDetails" id="0f5c4f53-dea7-4884-b3d6-f25b819e3bad">
        <source>getDisplayDetails(_short: Boolean): String;

/*
Date			Who		Reason
18 July 2016	cnwns1 	TFS2333 Multi-timezone issues
*/
vars

begin
	if _short then
		return self.getDateTimeLocalTZ.String;
	else
		return self.getDateTimeLocalTZ.String&amp;' '&amp;self.userId&amp;' '&amp;self.typeString;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="89c14c29-c2a3-4fb7-bbad-c3d094628e9b">
        <source>getDisplayString() : String;
// -------------------------------------------
// Created 02 October 2003 by cnwdvb1
// -------------------------------------------
// 24/11/2010	cnwcs5	par 23714/ccms 1132 - correct date format
// 18 July 2016	cnwns1 	TFS2333 Multi-timezone issues
vars

begin
	return 	self.getDateTimeLocalTZ.asStringJMT &amp; Tab &amp; self.userId &amp; Tab &amp; self.typeString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="ceb43be3-b13a-42e0-a3d3-d08f014d7334">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2016		cnwns1	Initial creation
18 July 2016		cnwns1 	TFS2333 Multi-timezone issues
01 November 2023	navmd1	TFS 61063 - Unit Test - Handle transients without machines yet (not a real thing, why is this class not abstract!)
*/

vars
	
begin
	if self.machine &lt;&gt; null then
		return self.machine.getMyTerminal();
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getName" id="d752286b-2bd1-416a-a81f-b196135fb0b4">
        <source>getName() : String;

vars
	returnStr		: String;
	
begin
	returnStr	:=	inheritMethod();
	/*
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					self.userId.padBlanks( 10 ) &amp; Tab &amp;
					self.dateTime.cnEcShortFullFormat &amp; Tab &amp;
					self.type.display &amp; Tab &amp;
					self.typeString.padBlanks( 30 ) &amp; Tab &amp;
					self.creationTime.cnEcShortFullFormat;
	
	if self.machine &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; 'machine ' &amp; self.machine.id;
		if self.machine.myTerminal &lt;&gt; null then
			returnStr	:= returnStr &amp; Tab &amp; 'terminal ' &amp; self.machine.myTerminal.code;
		endif;
	endif;
	*/
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShift" id="6fd5ea05-5a27-4dfc-a1b4-6c6bdd443d52">
        <source>getShift():CM_ShiftEntity;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.getShiftForTimeStamp (self.dateTime);
epilog

end;</source>
        <ReturnType type="CM_ShiftEntity"/>
    </JadeMethod>
    <JadeMethod name="getShiftForTimeStamp" id="f447c4ae-d952-4644-a41f-921d54da5944">
        <source>getShiftForTimeStamp(_ts :TimeStamp) :CM_ShiftEntity protected;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	machine		:CM_Machine;
	terminal	:CM_Terminal;
	shift		:CM_ShiftEntity;
begin
	if _ts &lt;&gt; null then
		machine :=  self.machine;
		
		if machine &lt;&gt; null then
			terminal := machine.myTerminal;
			
			if terminal &lt;&gt; null then
				shift :=  terminal.getShiftForTimeStampReal (_ts);
			endif;
		endif;
	endif;
epilog
	return shift;
end;</source>
        <access>protected</access>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_ShiftEntity"/>
    </JadeMethod>
