    <JadeMethod name="isCMIFDataMatch" id="9b96c76d-a5bf-47cf-b7a0-ada5e0e353dd">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return _cmifAutoPlan.isCurtainsIn_Match(_yaData);
end;</source>
