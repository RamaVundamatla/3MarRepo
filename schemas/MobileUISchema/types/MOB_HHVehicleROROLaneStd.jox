    <JadeMethod name="searchOnShip" id="e6a83566-834a-4971-91d1-10d5261c4736">
        <source>searchOnShip( _cargoId : String; _voyage : CM_Voyage; _tiArray : CM_TIArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)
*/

vars

	firstTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	localAltIdDict : CM_TIByAlternativeID;

begin

	cargoIdLength := _cargoId.length;
	cargoIdReversed := _cargoId.reverse;
	
	//Exact match only for whole id
	firstTi := _voyage.allOnshipTIsByIdCargoType.getAtKey(_cargoId,null);
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = _cargoId then
		iter := _voyage.allOnshipTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; _cargoId then
				break;
			endif;
			if ti.id &lt;&gt; _cargoId then
				//to select, must be an exact match
				continue;
			endif;
			_tiArray.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
	//10 Aug 2016	NDL Allow for partial searches matching on the last 'n' chars TFS 2511
	//Try reverse 'cargoId' as any piece of the id
	if _tiArray.isEmpty then
		firstTi := _voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := _voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				_tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
		
	//10 Aug 2016	NDL Allow for partial searches TFS 2511
	//Still nothing try an exact match on the alternate id
	if _tiArray.isEmpty then
		create localAltIdDict transient;
		_voyage.allOnshipTIsByIdCargoType.copy( localAltIdDict );
		firstTi := localAltIdDict.getAtKey(_cargoId);
		if firstTi &lt;&gt; null and firstTi.alternativeId = _cargoId then	
			iter := localAltIdDict.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; _cargoId then
					break;
				endif;
				_tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;

epilog

	delete localAltIdDict;
	delete iter;

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="e43e1a04-7b27-4906-99f8-62b4ab86406f">
        <updating/>
        <source>selectCargoItem( manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;	
	cargoIdLength : Integer;	
	location: CM_LocationsController;
	msg : String;
	cargoIdReversed : String;	
	
begin

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;

	self.setMyTrackedItem(	null, null );	
	
	term := self.myMobileDataAgent.myTerminal;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;
		cargoIdReversed := cargoId.reverse;	//10 Aug 2016	NDL Allow for partial searches
		
		if self.myVoyage &lt;&gt; null then
			// We have come from the "MOB_HHVehicleLanderConfirm" form and voyage has been chosen
			// look on the voyage first, there is a probability that the cargo is not yet discharged.
			self.searchOnShip( cargoId, self.myVoyage, tiArray );
			
		endif;
		
		//Exact match only for whole id
		if tiArray.isEmpty then
			firstTi := term.allOnsiteTIsByIdCargoType.getAtKey(cargoId,null);
			if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
				iter := term.allOnsiteTIsByIdCargoType.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
						break;
					endif;
					if ti.id &lt;&gt; cargoId then
						//to select, must be an exact match
						continue;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
		endif;
		
		//10 Aug 2016	NDL Allow for partial searches matching on the last 'n' chars TFS 2511
		//Try reverse 'cargoId' as any piece of the id
		if tiArray.isEmpty then
			firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
			if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
				iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
		endif;
		
		//10 Aug 2016	NDL Allow for partial searches TFS 2511
		//Still nothing try an exact match on the alternate id
		if tiArray.isEmpty then
			firstTi := term.allOnsiteTIsByAlternativeId.getAtKey(cargoId);
			if firstTi &lt;&gt; null and firstTi.alternativeId = cargoId then	
				iter := term.allOnsiteTIsByAlternativeId.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.alternativeId &lt;&gt; cargoId then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
		endif;
		
	endif;
	
	if tiArray.isEmpty then
		//try the hook code here if we have failed so far...
		self.doTryTrunacteAndHookCode( tiArray, cargoId );
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem(	tiArray.first, cargoId );
		return;
		
	elseif tiArray.size &gt; 1 then
		msg := app.getErrorString1( UniqueIdRequired, cargoId.trimBlanks);
		app.beep();
		self.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only, true);	
	else
		if self.myVoyage &lt;&gt; null then
			msg := app.getErrorString2(Cargo_item_not_found_voyag_sit, cargoId, self.myVoyage.code);
		else
			msg := app.getErrorString1(Cargo_item_not_found_site, cargoId.trimBlanks);
		endif;
		app.beep();
		self.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only, true);
	endif;
	

epilog

	delete tiArray;
	delete iter;
	
end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="65646307-b898-4be9-8ff3-60a9ada1f863">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem; _passedCargoId : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)


*/

vars

	desc1 : String;
	desc2 : String;
	index : Integer;
	existingIndex : Integer;
	existingTi : CM_TrackedItem;
	passedLength : Integer;
	passedReversed : String;
	updateAltId : Boolean;

begin

	self.myTrackedItem := _ti;
	
	self.setUpTblVehicles();

	if _ti = null then
		self.txtCargoId.text := lblCargoId.caption.toUpper;
		self.txtCargoId.setFocus();
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;
		
		self.btnDamage.enabled := false;
		self.btnLabel.enabled := false;
		self.btnReset.enabled := false;
		self.btnConfirm.enabled := false;
		
		self.lblNoDamage.visible := false;
		self.tblDamage.visible := false;
		
	else
	
		//Update the alternate id if appropriate
		if _passedCargoId &lt;&gt; null and _ti.alternativeId.trimBlanks = null then
			updateAltId := false;
			if _ti.id &lt;&gt; _passedCargoId then
				passedLength := _passedCargoId.length;
				if passedLength &lt;= _ti.id.length then
					passedReversed := _passedCargoId.reverse;
					if _ti.id[1:passedLength] &lt;&gt; _passedCargoId and  _ti.id[1:passedLength] &lt;&gt; passedReversed then
						//we have a raw entered id that is not our cargo id, that found this cargo, add it as an alternate Id
						updateAltId := true;
					endif;
				else
					//too long to be teh existing cargo id
					updateAltId := true;
				endif;
			endif;
			if updateAltId then
				if _passedCargoId.length &lt;= 30 then
					if not self.doUpdateAlternateId( _ti, _passedCargoId ) then
						//need to reset the local variable.
						self.myTrackedItem := _ti;
					endif;
				endif;
			endif;
		endif;
		
		self.txtCargoId.text := self.myTrackedItem.id;
		self.myTrackedItem.getShortDescriptions( desc1, desc2 );
		self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;
		
		if self.myTrackedItem.allDamageInstances.isEmpty then
			self.lblNoDamage.visible := true;
			self.tblDamage.visible := false;
		else
			self.lblNoDamage.visible := false;
			self.tblDamage.visible := true;
			self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
			self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
			
			self.doDisableDamageTable();
			
		endif;
		
		//High light the ti if its already in the list
		if self.allConfirmedArray.includes(self.myTrackedItem) then
			foreach index in 1 to self.tblVehicles.rows do
				existingTi := self.tblVehicles.accessRow(index).itemObject.CM_TrackedItem;
				if existingTi &lt;&gt; null and existingTi = self.myTrackedItem then
					self.tblVehicles.accessCell(index,1).backColor := Red;
					break;
				endif;
			endforeach;
		endif;
		
		//self.tblVehicles.accessCell(self.nextPosition,1).text := ("&lt;" &amp; app.getErrorString(Position) &amp; " " &amp; (self.nextPosition - 1).String &amp; "&gt; " &amp; self.myTrackedItem.id);	//25 May 2016	NDL	TFS 1593
		self.tblVehicles.accessCell(self.nextPosition,1).text := ((self.nextPosition - 1).String &amp; Tab &amp; self.myTrackedItem.id &amp; Tab &amp; self.myTrackedItem.alternativeId );
		self.tblVehicles.accessRow(self.nextPosition).itemObject := self.myTrackedItem;
	//	self.tblVehicles.accessCell(self.nextPosition,1).fontBold := true;	//08 Aug 2016	NDL	TFS 2505
		self.tblVehicles.accessRow(self.nextPosition).fontBold := true;	//08 May 2017	NDL	TFS 4238
		
		self.btnDamage.enabled := true;
		self.btnLabel.enabled := true;
		self.btnReset.enabled := true;
		self.btnConfirm.enabled := true;
		
		self.btnLabel.caption := app.getErrorString(Heading_Label);
		self.btnDamage.caption := app.getErrorString(Damage);
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passedCargoId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setUpTblVehicles" id="80375593-9921-470c-985c-259f72a824ec">
        <updating/>
        <source>setUpTblVehicles() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)
*/

vars

	index : Integer;
	ti : CM_TrackedItem;
	pos : Integer;	

begin

	self.tblVehicles.clear();
	self.tblVehicles.fixedColumns := 0;
	self.tblVehicles.columns := 3;
	self.tblVehicles.fixedRows := 0;
	self.tblVehicles.rows := 1;
	
	if self.myMobileGenericAgent.forward then		
		self.tblVehicles.accessCell(1,1).text := self.myMobileGenericAgent.myTerminalArea.leftLabel;
	else
		self.tblVehicles.accessCell(1,1).text := self.myMobileGenericAgent.myTerminalArea.rightLabel;	
	endif;
	self.tblVehicles.accessCell(1,2).text := app.getErrorString(CM_Vehicle_ID) &amp; Tab &amp; app.getErrorString(AlternativeID);
	self.tblVehicles.accessRow(1).backColor := LightGray;
	self.tblVehicles.accessCell(1,1).enabled := false;
	
	foreach ti in self.allConfirmedArray do
		pos := pos + 1;
		index := self.tblVehicles.addItem(pos.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.alternativeId );
		self.tblVehicles.accessRow(index).itemObject := ti;
		self.tblVehicles.accessRow(index).backColor := Gray;
	endforeach;
	

	pos := pos + 1;
	index := self.tblVehicles.addItem( pos.String );	
	self.tblVehicles.accessRow(index).backColor := White;
	self.nextPosition := index;
	
	if self.myMobileGenericAgent.forward then
		index := self.tblVehicles.addItem(self.myMobileGenericAgent.myTerminalArea.rightLabel);
	else
		index := self.tblVehicles.addItem(self.myMobileGenericAgent.myTerminalArea.leftLabel);	
	endif;
	
	self.tblVehicles.accessRow(index).backColor := LightGray;
	self.tblVehicles.accessCell(index,1).enabled := false;
	
	self.tblVehicles.topRow := self.nextPosition;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setVoyageCounts" id="0c5fa0b3-dc26-4009-880b-5bc76e8e12e0">
        <source>setVoyageCounts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)

*/

vars

	rowIndex : Integer;
	ti : CM_TrackedItem;
	pendingCount : Integer;
	onShipStr : String;
	onSiteStr : String;
	pendingArray : CM_TIArray;

begin

	if self.myVoyage = null then
		self.lblShipCounts.visible := false;
		
	else
		onShipStr := self.myVoyage.allOnshipTIsByCargoTypeId.size.String;
		onSiteStr := self.myVoyage.allOnsiteTIsByCargoTypeId.size.String;
	
		create pendingArray transient;
		foreach rowIndex in 1 to self.tblVehicles.rows do
			ti := self.tblVehicles.accessRow(rowIndex).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null then
				if ti.isOnShip then
					pendingArray.addExclusive(ti);
				endif;
			endif;
		endforeach;
		
		self.lblShipCounts.visible := true;
		if pendingArray.isEmpty then
			self.lblShipCounts.caption := app.getErrorString2(Ship_Site, onShipStr, onSiteStr);
		else
			self.lblShipCounts.caption := app.getErrorString3(Ship_Site_Pending, onShipStr, onSiteStr, pendingArray.size.String);
		endif;
		
	endif;
	
epilog

	delete pendingArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="a1696dc2-14a5-4256-802c-a1255194e93b">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwndl1	Initial creation	TFS 4160 / 4238 (Loose copy and modification  of MOB_HHVehicleROROLane)
*/

vars

begin

	self.doResizeControls( true );
	
	self.setMyTrackedItem(	null, null );
	self.txtCargoId_lostFocus(self.txtCargoId);
	self.myVoyage := self.myMobileGenericAgent.myVoyage; 
	self.setVoyageCounts();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="daae4da3-1312-441f-9952-040566a63f22">
