        <type name="CM_Root"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="0f209f8d-90b1-48e7-aff3-a774d07d2c75">
        <updating/>
        <source>create() updating;

vars

begin
	root := CM_Root.firstInstance;
	
	create self.myLog transient;
	self.myLog.fileName := self.class.name &amp; "_" &amp; app.actualTimeServer.fileNameFormat;
	self.myLog.versionFile := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createLSchema" id="a3d44f32-1793-4230-9e49-9e1195e2b210">
        <source>createLSchema(schemaName:String) protected;

vars
	lsscm : LSschema;
begin
	create lsscm transient;
	lsscm.mySchema := rootSchema.getSchema(schemaName);
	lsscm.name := lsscm.mySchema.name;	// this way round gets 1090 if name is mis-spelled
	self.allSchemas.add(lsscm);
end;</source>
        <access>protected</access>
        <Parameter name="schemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6ed31e96-38fa-49c2-bdc1-4cc0c6329f4f">
        <updating/>
        <source>delete() updating;
// 16/03/2015	cnwmh5	Transient Leak issue

vars

begin
	delete self.myLog;
	
	self.allGlobalConstants.purge();
	self.allSchemas.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fillSchemas" id="3a139569-920c-470f-b760-6ba56f1cca15">
        <source>fillSchemas();

vars

begin
	self.createLSchema(PortSchemaName);
	self.createLSchema(UiCommonSchemaName);
	self.createLSchema(GateSchemaName);
	self.createLSchema(GeneralCargoSchemaName);
	self.createLSchema(HmsSchemaName);
	self.createLSchema(InvoiceSchemaName);
	self.createLSchema(LogSchemaName);
	self.createLSchema(ShipSchemaName);
	self.createLSchema(SysOpsSchemaName);
	self.createLSchema(YardSchemaName);
	
	self.createLSchema(MobileUISchemaName);
end;</source>
    </JadeMethod>
    <JadeMethod name="findClassInSchemas" id="0ba544fa-549b-44b3-a782-5c7da16358ee">
        <source>findClassInSchemas(className : String):Class protected;

vars
	lsscm 	: LSschema;
	cls		: Class;
begin
	foreach lsscm in allSchemas do
		cls := lsscm.mySchema.getClass(className);
		if cls &lt;&gt; null then
			return cls;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="className" type="String"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getJmtSchemas" id="f0f19811-afbe-4314-8ecc-4f538cbbe613">
        <source>getJmtSchemas(appSchemas : SchemaColl input) protected;

// populate a collection of schemas below PortSchema
// REPLACED BY fillSchemas

begin
	rootSchema.getSchema(PortSchemaName).allSubschemas(appSchemas);
	appSchemas.add(rootSchema.getSchema(PortSchemaName));
end;</source>
        <access>protected</access>
        <Parameter name="appSchemas" type="SchemaColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNextExceptionGlobConstValue" id="8d9d649e-2957-4e65-b8d6-5c7305ac0af3">
        <source>getNextExceptionGlobConstValue():Integer protected;

// derive next exception Global Constant value (category = exception)

vars
	constant : Constant;
	category : ConstantCategory;
	maxValue : Integer;
begin
	
	foreach constant in currentSchema.getCategory(XLAT_Exceptions).getConstants where constant.valueAsInteger &gt; maxValue do
		maxValue := constant.valueAsInteger;
	endforeach;
	return maxValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="log" id="73b46a93-62ba-473d-ba2d-ac65173c9572">
        <source>log(text:String; andWrite : Boolean) ;

vars

begin
	if andWrite then
		write text;
	endif;
	self.myLog.logServer(text);
	
end;</source>
        <Parameter name="text" type="String"/>
        <Parameter name="andWrite" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zCountForms" id="9396d73f-8e36-49ce-b0c0-d0748afdb2e5">
        <source>zCountForms():Integer protected;

vars
	lsSchema 	: LSschema;
	formCount	: Integer;
begin
	// count forms
	foreach lsSchema in allSchemas do
		formCount := formCount + lsSchema.allClasses.size;
	endforeach;
	return formCount;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zFindAllGlobalConstants" id="5925b7b8-ff31-4790-bddc-f2e8d835f935">
        <source>zFindAllGlobalConstants() protected;

vars
	gc : GlobalConstant;
begin
	self.log("Getting list of all global constants (for conflict checking) ...", true);
	
	foreach gc in GlobalConstant.instances where allGlobalConstants[gc.name] = null do
		allGlobalConstants.add(gc);
	endforeach;
	
	self.log("	Global constants: " &amp; allGlobalConstants.size.String, true);
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
