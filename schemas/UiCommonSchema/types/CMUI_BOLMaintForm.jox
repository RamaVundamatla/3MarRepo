    <JadeMethod name="setMyCurrentBOL" id="486710d5-0d40-4a5e-b824-cc54a80fe9d2">
        <updating/>
        <source>setMyCurrentBOL(_value : CM_BOL) updating;
//06 January 2010	cnwml2
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
//							Replace not process.isInLoadState with app.cmsBeginLoad

vars
	localLoad : Boolean;
begin
	if _value &lt;&gt; null then
		self.myCurrentBOL := _value;
		app.cmsBeginLoad(localLoad);	
		self.myProxyBOL := app.createUpdateProxy(self.myCurrentBOL).CM_BOLIn;
		app.cmsEndLoad(localLoad);
	else
		self.myCurrentBOL := null;
		create self.myProxyBOL transient;		
	endif;

epilog
	app.cmsEndLoad(localLoad);					// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_value" type="CM_BOL"/>
    </JadeMethod>
