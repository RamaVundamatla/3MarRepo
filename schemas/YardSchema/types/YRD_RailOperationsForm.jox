//--------------------------------------------------
// Created:	03 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	// clear out any objects created in the wagon menus
	self.doClearTransientObjects();
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateJobRake" id="e1d0fe0a-6bc3-4df6-b8c4-9a880cecb1b7">
        <updating/>
        <source>updateJobRake(pTargetType : Integer;pJob : CM_RailJob input;pRake : CM_RailJSInOutRake) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars
	result : Integer;
begin
	app.mousePointer := MousePointer_HourGlass;

	while true do
		app.myTrxUA.trxUpdateJobRailOps(pJob,pRake,true,pTargetType, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			//result := app.showErrorWarningDialog('Load to Operations', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);//- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Load_to_operations), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);//+ cnwmd1, CCMS 1067, Par 19710
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
			
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="pTargetType" type="Integer"/>
        <Parameter name="pJob" type="CM_RailJob" usage="input"/>
        <Parameter name="pRake" type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="updateRailRakeArea" id="9a02e063-3e01-46f4-ade7-f936fad14549">
        <updating/>
        <source>updateRailRakeArea(_rail : CM_Rail)updating;
//--------------------------------------------------------------
//Created: 24 February 2004 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
begin
	
	if _rail &lt;&gt; self.myCurrentRailArea then
		return;
	endif;
	
	self.doRefreshGraphicView();
	
	self.myCurrentRailArea := null;
	self.myCurrentRailJSIO := null;
	self.myCurrentRailJob := null;
	self.myCurrentRailLine := null;
	self.myCurrentJSIORake := null;
	self.myCurrentWagon := null;
	//self.myCurrentTrain := null;
	self.setMyTrain( null );	//14 May 2021	NDL	TFS 51199
	
	self.mnuRebuildWLEStatus.visible := false;
	self.mnuRebuildJobStatusWLE.visible := false;
	self.mnuShowRelReqForm.visible := false;
	self.mnuJobReturnRelReq.visible := false;
	
	self.tblInfo.rows := 0;
	self.tblInfoSmall.rows := 0;
	self.tblWorkEntries.rows := self.tblWorkEntries.fixedRows;

	self.showAreaSelector();
	self.lstSelectAreas_click(self.lstSelectAreas); // PAR 21257
end;</source>
        <Parameter name="_rail" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="updateWagonArea" id="5eddff5c-f049-4a75-b853-401459d8b6ba">
        <updating/>
        <source>updateWagonArea(_wagon : CM_Wagon; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 09 April 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 25/06/2009	consw1		PAR 20117 - The Rail Planning graphic is not redisplay correctly in some circumstances.
// 27 Oct 2022 	navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// 02/06/2023	navkc1		Bug 58384: FR 53740 | EUP - Wagon Track Planning (part II)
// ---------------------------------------------------------------------------
vars
	wagonArea : YRD_WagonArea;
	
begin
	if _wagon = null then
		return;
	endif;		

	if _event = Wagon_Update_Event then
		wagonArea := self.getWagonAreaFromWagonObject(_wagon);
		if wagonArea &lt;&gt; null and (wagonArea.myRailLine = null or _wagon.confirmed) then
			// Wagon already displayed and position has not changed - refresh the wagon
			wagonArea.setDisabledAppearance(_wagon.myTrainInwards, _wagon); // PAR 21740

			wagonArea.redrawGridArea();
			return; // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; RETURN
		endif;	
	endif;

	if _event = Wagon_Create_Event or _event = Wagon_Update_Event then
		// we have to re-display the current selected train/rake if the wagon has been
		// added to it or its position has changed
		if self.myCurrentTrain &lt;&gt; null then
			if self.optDirOutTB.value then
				if _wagon.myTrainOutwards = self.myCurrentTrain then
					self.doRefreshGraphicView();
					return;
				endif;
			else
				if _wagon.myTrainInwards = self.myCurrentTrain then
					self.doRefreshGraphicView();
					return;
				endif;
			endif;
		elseif _wagon.myRailLine &lt;&gt; null and _wagon.myRailLine = self.myCurrentRailLine then
			self.doRefreshGraphicView();
			return;
		elseif _wagon.myRailLine &lt;&gt; null and self.myCurrentRailArea = _wagon.myRailLine.myRailArea then


			self.doRefreshGraphicView();
			return;
		//Start 27.10.2022 navhl20 TFS 54281
		elseif _wagon.allPlannedFutureMoves.isNotEmpty then
			self.doRefreshGraphicView();
			return;
		//End 27.10.2022 navhl20 TFS 54281
		endif;
	endif;

	if _event = Wagon_Delete_Event or _event = Wagon_Update_Event then
		wagonArea := self.getWagonAreaFromWagonObjectWas(_wagon);
		if wagonArea &lt;&gt; null then
			self.doRefreshGraphicView();
		//Start 27.10.2022 navhl20 TFS 54281
		elseif not app.isValidObject(_wagon) or // 02/06/2023	navkc1	Bug 58384
				_wagon.allPlannedFutureMoves.isEmpty then
			self.doRefreshGraphicView();
		//End 27.10.2022 navhl20 TFS 54281
		endif;
	endif;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a07b37c3-c745-4639-9043-bcbf17a2e626">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Apr 2025 navnk30	JIRA 34157: MTN | Rail Operations - Handle Notifications

*/

vars

begin
	
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(theObject, self.myTerminal.getEventFromTerminalEvent(eventType), eventTag, userInfo);
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateRetrospectiveTS" id="73b3cd2e-9a48-4f91-89c0-d0b220a69203">
        <source>validateRetrospectiveTS( _control : CMIF_WagonMoveController input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2021	navndl1	Initial creation	TFS 50837

*/

vars

	msg : String;

begin

	if self.chkRetrospect.value and self.retrospectiveDate.isValid then
	
		if self.retrospectiveDate.time.isValid
		and self.retrospectiveDate &gt; app.actualTimeAppServer
		then
			if process.isInLoadState or process.isInTransactionState then
				app.raiseCMException( Retrosp_datetim_not_future, null, null );
			else
				msg := app.getErrorString( Retrosp_datetim_not_future );
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			endif;
			return false;
		
		else
			if _control &lt;&gt; null then
				_control.setEffectiveTimeStampOverride( self.retrospectiveDate );
			endif;
		endif;
		
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_control" type="CMIF_WagonMoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wagonAreaReceiveDrop" id="9e650f09-83dc-4dcb-9b0b-adffbee0722a">
        <updating/>
        <source>wagonAreaReceiveDrop( _wagonArea : YRD_WagonArea ) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	consw1	Initial creation
24 Jun 2009	consw1	PAR 19913 - SFW1067 Rail Simplifications
30 Sep 2022 navhl20 ChangeRequest 54281: EUP - Wagon Track Planning
*/

vars
	moveController : CMIF_WagonMoveController;
	result : Integer;
	tmpStr : String;
	wagon : CM_Wagon;
	msg : String;
	
begin
	if app.myMoveController &lt;&gt; null then
		//  The presence of a 'move controller' means that the current 'wagon move controller' is left
		//  over from a wagon move that was not completed.  The 'wagon move controller' is no longer valid.
		return false;
	endif;

	moveController := app.myWagonMoveController;
	
	if self.myCurrentRailArea &lt;&gt; null then
		if _wagonArea = null then
			return false;
		endif;
		if moveController.isFromTrain then
			foreach wagon in moveController.allWagons do
				if tmpStr &lt;&gt; null then
					tmpStr := tmpStr &amp; ", ";
				endif;
				tmpStr := tmpStr &amp; wagon.id;
			endforeach;
			if moveController.moveMode = REAL_MODE then	// 16.11.2022	navhl20 TFS 54281
				if app.msgBox(	app.getErrorString2(Pleas_confi_that_want_confi_ra, tmpStr,
								_wagonArea.myRailLine.getDisplayDetails(false)), app.getErrorString(Move_rail), 
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
					return false;
				endif;
			// Start-16.11.2022	navhl20 TFS 54281
			else
				if app.msgBox(	app.getErrorString2(Pleas_confi_that_want_plan_rai, tmpStr,
								_wagonArea.myRailLine.getDisplayDetails(false)), app.getErrorString(Plan_rail), 
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
					return false;
				endif;
			endif;
			// End-16.11.2022	navhl20 TFS 54281
		endif;
	endif;
	
	moveController.myTargetTrain := null;
	moveController.myTargetRailLine := null;
	if self.myCurrentTrain &lt;&gt; null then
		moveController.myTargetTrain := self.myCurrentTrain;
	elseif self.myCurrentRailArea &lt;&gt; null then
		moveController.myTargetRailLine := _wagonArea.myRailLine;
	endif;

	moveController.isInwardTarget := self.optDirInTB.value;
	
	if _wagonArea = null then
		if self.flipHorizontal then
			moveController.targetPosition := 1;		// start of train
		else
			moveController.targetPosition := 0;  	// end of train
		endif;
	else
		if self.flipHorizontal then
			moveController.targetPosition := self.getMaximumColumn() - _wagonArea.column + 1;
		else
			moveController.targetPosition := _wagonArea.column;
		endif;
	endif;
	
	//23 Feb 2021	NDL	TFS 50837
	if not validateRetrospectiveTS(moveController) then
		return false;
	endif;
	
	app.myPassport.setWarningsIgnored(false);	//18 Dec 2009	NDL Par 22035
	
	while true do
		//if moveController.isFromTrain and self.myCurrentRailArea &lt;&gt; null then  //30.09.2022 navhl20 TFS 54281
		if moveController.isFromTrain and self.myCurrentRailArea &lt;&gt; null and moveController.moveMode = REAL_MODE then	//30.09.2022 navhl20 TFS 54281
			app.myTrxUA.trxUpdateWagonConfirmToRail(moveController, app.myPassport);
		else
			app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ...
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

	return true;
epilog
	if app.myWagonMoveController &lt;&gt; null then
		delete app.myWagonMoveController;
	endif;		
end;</source>
        <Parameter name="_wagonArea" type="YRD_WagonArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zSetXMLStrForTblColumns" id="dfdc8af1-7d41-4b72-b607-1ed8d09c6a76">
        <updating/>
        <source>zSetXMLStrForTblColumns(_theTable: CM_DataTable input; _includeColumnWidths : Boolean) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/03/2011	cnwdap1	Initial creation PAR #27166 CCMS POL 2001 Separate column organisers for inwards/outwards
						This is a copy of a framework method that exists on CM_TabelViewForm superclass, but not on this form's superclass
						so we reimplement it here just for this purpose
*/
vars
	tagPrefix,
	tagSuffix,
	tmpStr,	
	defName,
	replaceStr,
	tmpDefStr,
	tmpXMLStr 	: String;
	startPos	: Integer;
	
begin
	tmpXMLStr := _theTable.getXmlStrForColumns(_includeColumnWidths);
	
	if self.xmlStrTblData = null then
		self.xmlStrTblData := tmpXMLStr;
		return;
	endif;
	
	defName := _theTable.myEntTableDef.name;
	tagPrefix := J_key_LessThan.Character &amp; _theTable.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
	tagSuffix := global.formatAsXMLSuffix(_theTable.XMLTag_EntTblDef &amp; defName).trimBlanks;

	startPos := 1;
	tmpDefStr := self.xmlStrTblData.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then
		// there is already xml for the table/entTableDef combination
		startPos := 1;
		tmpStr := tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;
		replaceStr := tagPrefix &amp; tmpStr &amp; tagSuffix;
		startPos := 1;
		tmpDefStr := tagPrefix &amp; self.xmlStrTblData.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		self.xmlStrTblData := self.xmlStrTblData.replaceString(tmpDefStr, replaceStr);
	else
		// adding a new table/entTableDef combination - find the value to put between the prefix 7 suffix tage
		startPos := 1;
		tmpDefStr := tagPrefix &amp; tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		// we want to insert it before the &lt;/table name = &lt;name&gt;&gt; tag
		startPos := 1;
		//self.xmlStrTblData.scanWhile('&lt;'&amp; _theTable.XMLTag_Table &amp; _theTable.name &amp; '&gt;', startPos);
		startPos := self.xmlStrTblData.pos('&lt;/'&amp; _theTable.XMLTag_Table &amp; _theTable.name &amp; '&gt;', startPos);
		
		if startPos &lt;&gt; 0 then
			self.xmlStrTblData := self.xmlStrTblData.cnEcInsertInto(tmpDefStr, startPos, startPos);
		else
			// should not happen but if it does we will append at the end
			self.xmlStrTblData := tmpDefStr;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_includeColumnWidths" type="Boolean"/>
    </JadeMethod>
</GUIClass>
