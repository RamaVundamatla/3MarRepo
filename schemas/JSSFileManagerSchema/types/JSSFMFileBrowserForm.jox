    <JadeMethod name="contextMenu" id="7955365a-a51d-467f-99b4-1bece4803b7b">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Passes this event on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyFormInterface &lt;&gt; null then
		return self.aMyFormInterface.sendMsgWithParams(method.name, conwin, mouse, x, y).Boolean;
	endif;
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
