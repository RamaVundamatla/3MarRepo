<Class name="UT_EDI_DotNET" id="3c36fb3c-e8d5-4647-a1ea-72b0016209cf">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Unit Test class for driving any .NET EDI transformations</text>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="iBayPlan" id="16e7ffad-8c5a-499a-9f3a-23c0b6da374c">
        <source>iBayPlan();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars

begin
	self.uLoadEDIFile("UT_EDIDotNET_tBayPlan", System_EDIFileType, self.zTestBAPLIEForPlugin(), null, true, true);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="iConsignee" id="2b94d10f-e65f-4ac7-8324-67166aad5b7a">
        <source>iConsignee();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	consignee			: CM_ConsigneeConsignor;
	
begin
	self.deleteConsigneeConsignor("KEVIN");
	
	self.uLoadEDIFile("UT_EDIDotNET_tConsignee", System_EDIFileType, "Create a dummy Consignee", null, true, true);
	
	consignee := app.myRoot.allConsigneeConsignors["KEVIN"];
	assertNotNull(consignee);
	
	assertEqual(consignee.description, "Kevin Douglas");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tDriverDetails" id="65c26444-212a-48c4-91c5-f1c69a41c2bb">
        <source>tDriverDetails();
// jlgmd1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	driverDetails 		: CM_DriverDetails;
	terminal			: CM_Terminal;
	
begin
	self.deleteDriverDetails("KEVIN");
	
	self.uLoadEDIFile("UT_EDIDotNET_tDriverDetails", System_EDIFileType, "Create a dummy Driver", null, true, true);

	terminal := self.getTerminal();
	if terminal = null then
		return;
	endif;
	
	driverDetails := terminal.allDriversByCode["KEVIN"];
	assertNotNull(driverDetails);
	
	assertEqual(driverDetails.name, "Kevin Douglas");
	
epilog

end;</source>
    </JadeMethod>
