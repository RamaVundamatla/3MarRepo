    <JadeMethod name="doAddControl" id="b15f2a98-e6d3-46de-9f64-fa0d9f179387">
        <source>doAddControl(_form :Form input; _control:Control input)protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
29 August 2008	concms1	Initial creation
*/
constants
	// use constants to avoid the inevitable typo
	DBLCLICK	= 'dblClick';
	MOUSEDOWN 	= 'mouseDown';
	MOUSEMOVE	= 'mouseMove';
	DRAGDROP 	= 'dragDrop';
	DRAGOVER 	= 'dragOver';
vars

begin
	// add control to our form - parent will already be set
	_form.addControl (_control);
	
	if _control.isKindOf (Label) or
		 _control.isKindOf (Button) or
		 _control.isKindOf(TextBox) or
		 _control.isKindOf (ComboBox)then
		self.doEventMapping (_control, DBLCLICK);
		self.doEventMapping (_control, MOUSEDOWN);
		self.doEventMapping (_control, MOUSEMOVE);
		
		self.allCustomisableControls.add (_control);
	elseif _control.isKindOf (GroupBox) or 
		_control.isKindOf(Table) then
		// we'll add events for these later
	else
		return;
	endif;

	_control.enabled			:= true;	// so we get events;
	
	if _control.isKindOf(TextBox) then 
		// make all text boxes readonly
		_control.TextBox.readOnly 	:= true;
		_control.mousePointer		:= _control.MousePointer_Arrow;
	endif;	
	
	// these events apply to all control
	self.doEventMapping (_control, DRAGDROP);
	self.doEventMapping (_control, DRAGOVER);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_form" type="Form" usage="input"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEventMapping" id="cd692b7b-d958-4a76-b134-d51a7144246c">
        <source>doEventMapping(_control :Control input; _event :String)protected;
/*
	Purpose:		Map control events to method on the customisation form		
	Parameters:			
	Return Value:		

Date			Who		Reason
29 August 2008	concms1	Initial creation
*/

vars
	cls			:Class;
	strMethod,
	strEvent	:String;
begin
	if _event = 'click' or _event = 'mouseDown' or _event = 'mouseMove' then
		if self.getDisplayNameForControl (_control) = null then
			return;
		endif;
	endif;
	// the method name uses the jade superclass name so this next bit is
	// just so we handle all control suclasses
	if _control.isKindOf (Label) then
		cls := Label;
	elseif _control.isKindOf (TextBox) then
		cls := TextBox;
	elseif _control.isKindOf (GroupBox) then
		cls := GroupBox;
	elseif _control.isKindOf (ComboBox) then
		cls := ComboBox;
	elseif _control.isKindOf (Button) then
		cls := Button;
	else
		// not someting we handle
		return;
	endif;
	
	strEvent 	:= _event;
	
	strEvent.firstCharToUpper;
	
	strMethod 	:= 'do' &amp;  strEvent &amp; '_' &amp; cls.name; 

	_control.setEventMapping (_event, strMethod);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_event" type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfigItemForControl" id="90cae831-1bc2-44c1-bc47-50dc61441c1a">
        <source>getConfigItemForControl(_control :Control input):CM_FormConfigItem;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	config	:CM_FormConfigControl;
begin
	config := _control.userObject.CM_FormConfigControl;
	
	if config &lt;&gt; null then
		return config;	// we already have it
	endif;
	
	if _control.isKindOf (Label) then
		self.createConfigItemForLabel (_control.Label, config);
	elseif _control.isKindOf (TextBox) then
		self.createConfigItemForTextBox (_control.TextBox, config);
	elseif _control.isKindOf (ComboBox) then
		self.createConfigItemForComboBox (_control.ComboBox, config);
	elseif _control.isKindOf (Button) then
		self.createConfigItemForButton (_control.Button, config);
	endif;
	
	// now set all the common properties
	config.setVisible (_control.visible);
	config.setPosition (_control.left, _control.top);
	config.setControlName (_control.name);
	config.setMyConfigForm (self.myPxyFormConfiguration);
	
	_control.userObject := config;
	
	return config;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <ReturnType type="CM_FormConfigItem"/>
    </JadeMethod>
    <JadeMethod name="getDisplayNameForControl" id="6e4c0d05-776e-440d-9f2b-84e9fa533cd0">
        <source>getDisplayNameForControl(_control	:Control):String;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
03 September 2008	concms1	Initial creation
*/

vars
	strName, strDisplay, strType		:String;
begin
	strName := _control.name;
	
	if strName = 'lblCarrier' then strDisplay :=  'Carrier'; endif;
	if strName = 'lblDriverID' then strDisplay :=  'Driver' ;endif;
	if strName = 'lblGateLane' then strDisplay :=  'Gate Lane'; endif;
	if strName = 'lblOutGate' then strDisplay :=  'Out Gate'; endif;
	if strName = 'lblRegno' then strDisplay :=  'Registration'; endif;
	if strName = 'lblTrans' then strDisplay :=  'Transaction'; endif;
	
	if strName = 'txtDriverID' then strDisplay :=  'Driver'; endif;
	if strName = 'txtDriverName' then strDisplay :=  'Driver Name'; endif;
	if strName = 'txtTrans' then strDisplay :=  'Transaction'; endif;
	
	if strName = 'cmbCarrier' then strDisplay :=  'Carrier'; endif;
	if strName = 'cmbGateLanes' then strDisplay :=  'Gate Lanes'; endif;
	if strName = 'cmbRegno' then strDisplay :=  'Registration'; endif;
	if strName = 'cmbPrinter' then strDisplay :=  'Printer'; endif;
	
	if _control.isKindOf (Button) then
		strDisplay := _control.Button.caption;
	endif;
	
	if strDisplay = null then
		return null;
	endif;
	
	if _control.isKindOf (Label) then
		strType := Label.name;
	elseif _control.isKindOf (TextBox) then
		strType := TextBox.name;
	elseif _control.isKindOf (ComboBox) then
		strType := ComboBox.name;
	elseif _control.isKindOf (Button) then
		strType := Button.name;
	endif;
	
	return strDisplay &amp; ' (' &amp; strType &amp; ')';
epilog

end;</source>
        <Parameter name="_control" type="Control"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFormConfiguration" id="f241a503-642d-4a56-b958-3483312d1536">
        <source>getFormConfiguration(): CM_FormConfigForm protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
