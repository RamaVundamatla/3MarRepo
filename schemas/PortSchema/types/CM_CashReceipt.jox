    <JadeMethod name="setShipReleaseDateCONV" id="97421df6-4899-4e4a-a48a-1cad9f99b737">
        <updating/>
        <source>setShipReleaseDateCONV(_releaseDate : Date) updating;

/*

Purpose:			Store the ship release date, for conversion only.
					Will only be called for null date to clear the value.
Parameters:			

Return Value:		


Date		Who		Reason
June 2015	cnwjre1	36457 save this for the query
*/

vars
	size	: Integer;
begin
	if _releaseDate = null then
		size := self.allExtraData.size;
		global.setExtraData (self.allExtraData, self, "shipReleaseDate", _releaseDate);
		// this just updates the existing entry with a null value, if there is nothing else there (is some duty-doc stuff also in extraData) then zap it
		if size = 1 then
			self.allExtraData.purge;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_releaseDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setTaxValues" id="90be41f3-286c-4e41-a3f2-9a675bca0b84">
        <updating/>
        <source>setTaxValues(_value1, _value2, _value3 : Decimal; _code1, _code2, _code3: String) updating;
// GPHA 2368 tax held against the receipt overall


vars

begin
	self.taxValue1 := _value1;
	self.taxValue2 := _value2;
	self.taxValue3 := _value3;

	if _value1 = null then		// 8/2/18 MAP TFS8065
		self.taxCode1 := null;
	else
		self.taxCode1 := _code1;
	endif;
	if _value2 = null then		// 8/2/18 MAP TFS8065
		self.taxCode2 := null;
	else
		self.taxCode2 := _code2;
	endif;
	if _value3 = null then		// 8/2/18 MAP TFS8065
		self.taxCode3 := null;
	else
		self.taxCode3 := _code3;
	endif;
end;
</source>
        <Parameter name="_value1" type="Decimal"/>
        <Parameter name="_value2" type="Decimal"/>
        <Parameter name="_value3" type="Decimal"/>
        <Parameter name="_code1" type="String"/>
        <Parameter name="_code2" type="String"/>
        <Parameter name="_code3" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="b5d45cf2-25dd-4720-a9cf-ce3ebfc02e0f">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/02/2018  cnwma1	Bug 43452: PEL1 - SAP Web Service (1081 Deadlock) issue

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_CashReceipt::paymentStatus.name 
	or	propName = CM_CashReceipt::myDebtorTerminal.name then // TFS 46032
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldRound" id="e65620b9-d996-4a22-bcfa-2aa1c9906134">
        <source>shouldRound() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2015	cnwmc5	Initial creation		PAR 36895

*/

vars

begin
	//return self.myTerminal.getConfig(CashRoundingType).Integer &gt; 0;
	return self.myTerminal.getCashRoundingType( self.getBank ) &gt; 0;	//08 Jan 2018	NDL	TFS 40010
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
