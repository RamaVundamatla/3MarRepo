    <JadeMethod name="btnBack_click" id="d5310f78-108d-42b7-b875-17b0c52a636e">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBack_click(juice: JadeMask input) updating;
/*
// Author:	cnwsmc1
// Created:	06 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
*/
begin
	self.aSequence	:=	self.aSequence - 2;
	self.getNextActivity();
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCross_click" id="41357dff-9c09-4e2f-af94-fa734bfb29b6">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCross_click(juice: JadeMask input) updating;

begin
	self.doClearGraphics();
	unloadForm();
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDoIt1_click" id="f0578b7c-e24d-4858-bc72-7769a8305b16">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDoIt1_click(juice: JadeMask input) updating;

vars
	endForm	: Boolean;

begin
	if lstLessons.visible then
		if lstLessons.listIndex &gt; 0 then
			self.aMyLesson := lstLessons.listObject.CnEcTLesson;
			btnEndIt1.enabled := true;
			self.displayLesson();
		endif;
		return;
	endif;	

	if self.aIsAbortLesson then
		self.closeForm();
		return;
	endif;

	if juice.caption = self.DO_IT then
		self.doAction(self.aMyControl, true);
	elseif juice.caption = self.NEXT then
		self.getNextActivity();
	elseif juice.caption = self.START then
		self.getNextActivity();
	elseif juice.caption = self.FINISH then
		self.getNextActivity();
	else
		self.aIsAbortLesson := true;
	endif;

	if self.aSequence &gt; self.aMyLesson.allActivities.size() then
		self.closeForm();
	endif;
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEndIt1_click" id="28e57884-7caf-445f-97bd-72f5e1c9272e">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEndIt1_click(juice: JadeMask input) updating;

begin
	self.doClearGraphics();
	
	if self.aMyLesson &lt;&gt; null then
		self.aSequence := self.aMyLesson.allActivities.size() + 1;
		self.getNextActivity();
	endif;
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="closeForm" id="e67fa81a-b5f5-45ad-bf16-d0a85055b6ab">
        <updating/>
        <source>closeForm() updating;

vars
	lessonName	: String;
	theClass	: Class;
	
begin
	self.doClearGraphics();

	if self.aIsAbortLesson then
		self.writeScriptFileServer("&lt;&lt;&lt; Lesson terminated due to trapped error: " &amp; self.aMyLesson.name);
	else
		self.writeScriptFileServer("&lt;&lt;&lt; Lesson end: " &amp; self.aMyLesson.name);
	endif;

	if self.aIsAbortLesson or self.aMyLesson.nextLessonName.length = 0 then
		unloadForm();
		return;
	endif;

	lessonName := self.aMyLesson.nextLessonName;
	self.aMyLesson := self.getLessonByName(lessonName);

	if self.aMyLesson = null then
		self.writeScriptFileServer("### Next lesson undefined: '" &amp; lessonName &amp; "'");
		unloadForm();
		return;
	endif;

	if self.aMyLesson.formName.length = 0 then
		self.writeScriptFileServer("### Lesson form undefined for: " &amp; self.aMyLesson.name);
		unloadForm();
		return;
	endif;

	if not app.isValidObject(self.aMyForm) or self.aMyLesson.formName &lt;&gt; self.aMyForm.name then
		self.aMyForm := getForm(self.aMyLesson.formName, true);
		if self.aMyForm = null then
			theClass := currentSchema.getClass(self.aMyLesson.formName);
			
			if theClass &lt;&gt; null then
				create self.aMyForm as theClass;
				self.aMyForm.show();
			endif;	
		endif;	
	endif;

	if self.aMyForm = null or self.aMyLesson.formName &lt;&gt; self.aMyForm.name then
		if self.aMyForm = null then
			self.writeScriptFileServer("### Form '" &amp; self.aMyLesson.formName &amp; "' not found (not active)");
		else
			self.writeScriptFileServer("### Lesson form '" &amp; self.aMyLesson.formName &amp; "' does not match form '" &amp; self.aMyForm.name &amp; "'");
		endif;
		
		unloadForm();
		return;
	endif;

	self.aMyForm.setFocus();
	self.displayLesson();
end;</source>
    </JadeMethod>
    <JadeMethod name="displayLesson" id="bf192b40-551f-4bc0-a540-6f0233cb372c">
        <updating/>
        <source>displayLesson() updating;

vars
	theControl	: Control;
	
begin
	lblCaption.caption	:= self.aMyLesson.name;
	self.aSequence		:= 0;

	self.toggleMode(self.MODE_TEXT);

	picRight.visible := false;

	if self.aMyLesson.checkControlEnabled or self.aMyLesson.checkControlValue or self.aMyLesson.checkControlVisible then
		theControl := self.getControl(self.aMyLesson.controlName);

		if theControl = null then
			self.writeScriptFileServer("### Lesson error: " &amp; self.aMyLesson.name &amp; " check startup control not found on form (" &amp; self.aMyLesson.controlName &amp; ")");
			txtText.text := "I cannot start this lesson as an important control is not on this form.";
			self.aIsAbortLesson := true;

		elseif self.aMyLesson.checkControlVisible and theControl.visible = self.aMyLesson.controlIsVisible then
			if theControl.visible then
				txtText.text := "I cannot start this lesson as this control is visible.";
			else
				txtText.text := "I cannot start this lesson as an important control is not visible.";
				theControl := null;
			endif;
			
			self.aIsAbortLesson := true;

		elseif self.aMyLesson.checkControlEnabled and theControl.enabled = self.aMyLesson.controlIsEnabled then
			if theControl.visible then
				if theControl.enabled then
					txtText.text := "I cannot start this lesson as this control is enabled.";
				else
					txtText.text := "I cannot start this lesson as this control is not enabled.";
				endif;
			else
				if theControl.enabled then
					txtText.text := "I cannot start this lesson as an important control is enabled.";
				else
					txtText.text := "I cannot start this lesson as an important control is not enabled.";
				endif;
				
				theControl := null;
			endif;
			
			self.aIsAbortLesson := true;

		elseif self.aMyLesson.checkControlValue and self.aMyLesson.controlHasAValue = doAction(theControl, false) then

			if theControl.visible then
				if self.aMyLesson.controlHasAValue then
					txtText.text := "I cannot start this lesson as this control has a value.";
				else
					txtText.text := "I cannot start this lesson as this control does not have a value.";
				endif;
			else
				if self.aMyLesson.controlHasAValue then
					txtText.text := "I cannot start this lesson as an important control has a value.";
				else
					txtText.text := "I cannot start this lesson as an important control does not have a value.";
				endif;
				
				theControl := null;
			endif;
			
			self.aIsAbortLesson := true;
		else	// everything is ok!
			theControl := null;
		endif;
	endif;

	if self.aIsAbortLesson then
		btnDoIt1.caption := self.FINISH;
		txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to end.";
	elseif theControl = null then
		txtText.text := self.aMyLesson.text;
		btnDoIt1.caption := self.START;
		txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to start.";
	endif;

	btnDoIt1.setFocus();
	self.positionWizard(theControl);
	self.setupHelp();
	self.writeScriptFileServer("&gt;&gt;&gt; Lesson: " &amp; self.aMyLesson.name &amp; " (activities: " &amp; self.aMyLesson.allActivities.size().String &amp; ")");

	if self.aIsNoUserInput then
		while (not self.aIsAbortLesson) and self.aSequence &lt;= self.aMyLesson.allActivities.size() do
			if btnDoIt1.caption = self.DO_IT then
				self.doAction(self.aMyControl, true);
			elseif btnDoIt1.caption = self.NEXT then
				self.getNextActivity();
			elseif btnDoIt1.caption = self.START then
				self.getNextActivity();
			endif;
		endwhile;	
		
		self.closeForm();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayResult" id="5cfe2869-5c86-4c26-9db7-52b3814a81ed">
        <updating/>
        <source>displayResult() updating;

vars
	endForm	: Boolean;

begin
	if aMyActivity.afterText.length = 0 then
		getNextActivity;

	elseif aMyControlAfter = null or aMyControlAfter.visible then		// don't care if not enabled
		if aMyActivity.text.length &gt; 0 then
			lblCaption.caption := lblCaption.caption &amp; " - result";
		endif;
		
		txtText.text := aMyActivity.afterText;
		setDoItCaption(true);
		positionWizard(aMyControlAfter);

	else
		handleMissingControlOrForm(aMyActivity, aMyControlAfter, aMyActivity.afterControlName);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAction" id="26b8db31-d66e-4e81-97d9-4759063064bd">
        <updating/>
        <source>doAction(ctrl : Control io; performAction : Boolean) : Boolean updating;
//	If performAction is TRUE then do the action on the ctrl
//	Otherwise return TRUE or the ctrl has a value (or checkbox/optionbutton is set), else FALSE
//
//	If you change the action, be sure to reflect the change in CnEcTTeachMaintForm::doDisplayRules
//
//	Actions:
//
//	ListBox						: integer	- selects the nth item in the list (or last one if greater)
//								: string	- finds the first match for the string
//	ComboBox					: integer	- selects the nth item in the list (or last one if greater)
//								: "string	- enters the string (may or may not match)
//								: string	- finds the first match for the string
//	TextBox						: any		- sets textbox to the value if non-blank
//	OptionButton				: any		- sets the optionbutton if non-blank
//	CheckBox					: "true"	- sets the checkbox
//								: "false"	- unsets the checkbox
//								: else		- changes the checkbox setting if non-blank
//	Button, JadeJuiceControl	: any		- clicks the button if non-blank
//	Table						: integer	- clicks row in table
//
//	With every action there is a click on the control. An addition for a TextBox, there is a change
vars
	button			: Button;
	juice			: JadeMask;	// Juice button
	combo			: ComboBox;
	checkbox		: CheckBox;
	listbox			: ListBox;
	optionButton	: OptionButton;
	table			: Table;
	textbox			: TextBox;
	index			: Integer;
	comboString		: String;
	activityAction	: String;
	
begin
	activityAction := aMyActivity.action;

	if ctrl.isKindOf(ComboBox) then
		combo := ctrl.ComboBox;

		if combo &lt;&gt; null then
			if not performAction then
				return (combo.listIndex &gt; 0);
			endif;

			if activityAction.isInteger then
				index := activityAction.Integer;
				if index &gt; combo.listCount then
					index := combo.listCount;
				endif;
			else
				comboString := activityAction;
				if comboString[1] = '"' then
					if comboString.length &gt; 1 then
						combo.text := comboString[2:end];
					else
						combo.text := "";
					endif;
				else
					index := combo.findString(1, activityAction);
				endif;
			endif;

			if index &gt; 0 then
				combo.listIndex := index;
				combo.click(combo);
			endif;
		endif;

	elseif ctrl.isKindOf(ListBox) then
		listbox := ctrl.ListBox;

		if listbox &lt;&gt; null then
			if not performAction then
				return (listbox.listIndex &gt; 0);
			endif;

			if activityAction.isInteger then
				index := activityAction.Integer;
				if index &gt; listbox.listCount then
					index := listbox.listCount;
				endif;
			else
				index := listbox.findString(1, activityAction);
			endif;

			if index &gt; 0 then
				listbox.listIndex := index;
			endif;
			listbox.click(listbox);
		endif;

	elseif ctrl.isKindOf(CheckBox) then
		checkbox := ctrl.CheckBox;

		if checkbox &lt;&gt; null then
			if not performAction then
				return checkbox.value;
			endif;

			if activityAction = "true" then
				checkbox.value := true;
			elseif activityAction = "false" then
				checkbox.value := false;
			elseif activityAction.length &gt; 0 then
				checkbox.value := not checkbox.value;
			endif;

			if activityAction.length &gt; 0 then
				checkbox.click(checkbox);
			endif;
		endif;

	elseif ctrl.isKindOf(OptionButton) then
		optionButton := ctrl.OptionButton;

		if optionButton &lt;&gt; null then
			if not performAction then
				return optionButton.value;
			endif;

			if activityAction.length &gt; 0 then
				optionButton.value := true;
				optionButton.click(optionButton);
			endif;
		endif;

	elseif ctrl.isKindOf(Button) then
		button := ctrl.Button;

		if button &lt;&gt; null then
			if not performAction then
				return false;
			endif;
			if activityAction.length &gt; 0 then
				button.click(button);
			endif;
		endif;

	elseif ctrl.isKindOf(JadeMask) then
		juice := ctrl.JadeMask;

		if juice &lt;&gt; null then
			if not performAction then
				return false;
			endif;
			if activityAction.length &gt; 0 then
				juice.click(juice);
				juice.value := true;
			endif;
		endif;		

	elseif ctrl.isKindOf(Table) then
		table := ctrl.Table;

		if table &lt;&gt; null then
			if not performAction then
				return (table.rows &gt; 0);
			endif;
			if activityAction.isInteger then
				table.row := activityAction.Integer;
				table.column := 1;
				table.click(table);		// do you need this?
			endif;
		endif;

	elseif ctrl.isKindOf(TextBox) then
		textbox := ctrl.TextBox;

		if textbox &lt;&gt; null then
			if not performAction then
				return (textbox.text.length &gt; 0);
			endif;
			textbox.click(textbox);		// do you need this?
			activityAction := getActivityAction(false);
			if activityAction.length &gt; 0 then
				textbox.text := activityAction;
				textbox.change(textbox);
			endif;
		endif;
	endif;

	if performAction then
		displayResult;
	endif;

	return false;
end;</source>
        <Parameter name="ctrl" type="Control" usage="io"/>
        <Parameter name="performAction" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClearGraphics" id="e7e2e391-961a-439d-8b8a-c7df03719be5">
        <updating/>
        <source>doClearGraphics() updating;

begin
	if self.aMyPreviousControl &lt;&gt; null then
		self.aMyPreviousControl.backColor := self.aPreviousBackColor;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveWindow" id="c84b2747-8fcb-4925-8e25-fb18520380da">
        <updating/>
        <source>doMoveWindow() updating;

begin
