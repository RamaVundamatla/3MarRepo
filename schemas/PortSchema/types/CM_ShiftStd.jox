<Class name="CM_ShiftStd" id="ecdea0c2-6d3c-42a2-9258-b6ada0183861">
    <superclass name="CM_ShiftEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="endTime" id="fe21f960-c426-4a0d-a169-1db70162e84c">
        <embedded/>
        <type name="Time"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="10d45052-dd07-45bb-baf4-4cbdb7db98d9">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allShiftsStandard"/>
    </ExplicitInverseRef>
    <PrimAttribute name="shiftDay" id="346a863e-725d-4352-a0d7-bded48c68a3d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="startTime" id="48475913-56c1-4480-97e7-9a566a8781c2">
        <embedded/>
        <type name="Time"/>
    </PrimAttribute>
    <JadeMethod name="getDisplay" id="85bd7d2e-84c6-49c6-8c37-7352e1642df8">
        <source>getDisplay() : String;

vars

begin
	return self.getShiftDay() &amp; Tab &amp; 
			self.startTime.String &amp; Tab &amp; 
			self.endTime.String &amp; Tab &amp;
			self.code &amp; Tab &amp;
			self.description;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndTime" id="c2b0132d-3c95-4f71-bae1-157d2c338302">
        <source>getEndTime() : String;

vars

begin
	return self.endTime.String;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="1b6353a9-c00e-4f8f-bcc8-cc3a50ce1a7f">
        <source>getMyTerminal() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:		21 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.myTerminal;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getShiftDay" id="da1cf932-4a17-461c-85ab-f34606245089">
        <source>getShiftDay() : String;

vars

begin
	if self.shiftDay = 1 then
		return "Monday";
	elseif self.shiftDay = 2 then
		return "Tuesday";
	elseif self.shiftDay = 3 then
		return "Wednesday";
	elseif self.shiftDay = 4 then
		return "Thursday";
	elseif self.shiftDay = 5 then
		return "Friday";
	elseif self.shiftDay = 6 then
		return "Saturday";
	elseif self.shiftDay = 7 then
		return "Sunday";
	endif;
	return null;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStartTime" id="b11b1cab-eeec-4d39-beec-b254a96b3118">
        <source>getStartTime() : String;

vars

begin
	return self.startTime.String;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="95753f34-bb96-4699-9dcf-4e42a7c5f8cc">
        <updating/>
        <source>setForCreate(pProxyShiftStd: CM_ShiftStd) updating;

vars
messStr : String;
begin
	pProxyShiftStd.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	inheritMethod(pProxyShiftStd);
	
	self.shiftDay 		:= pProxyShiftStd.shiftDay;
	self.startTime 		:= pProxyShiftStd.startTime;
	self.endTime 		:= pProxyShiftStd.endTime;
	self.myTerminal		:= pProxyShiftStd.myTerminal;
	
	messStr := self.myTerminal.validateForShiftGaps().trimBlanks(); // PAR 21305
	if messStr &lt;&gt; null then
		app.raiseCMWarning1(Termina_shifts_weeks_gaps, messStr, null, null, self); // PAR 21305
	endif;
	
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_Shift_Add), false, null);
end;
</source>
        <Parameter name="pProxyShiftStd" type="CM_ShiftStd"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e7d47382-b7ee-433c-a94a-666b998e04b8">
        <updating/>
        <source>setForUpdate(pProxyShiftStd : CM_ShiftStd) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

begin
	pProxyShiftStd.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.shiftDay 		:= pProxyShiftStd.shiftDay;
	self.startTime 		:= pProxyShiftStd.startTime;
	self.endTime 		:= pProxyShiftStd.endTime;
	self.code 			:= pProxyShiftStd.code;
	self.description 	:= pProxyShiftStd.description;
	self.myTerminal		:= pProxyShiftStd.myTerminal;
	
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_Shift_Update), false, null);	


end;
</source>
        <Parameter name="pProxyShiftStd" type="CM_ShiftStd"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="50bf1846-6633-4df7-b792-a2ae15c4f7c3">
        <updating/>
        <source>setProxy(pShiftDay : Integer; pStartTime : Time; pEndTime : Time; pCode : String; pDesc : String; pTerminal : CM_Terminal; _ignore : Boolean) updating;

vars

begin
	self.shiftDay  		:= pShiftDay;
	self.startTime  	:= pStartTime;
	self.endTime		:= pEndTime;
	self.code			:= pCode;
	self.description	:= pDesc;
	self.myTerminal		:= pTerminal;
end;
</source>
        <Parameter name="pShiftDay" type="Integer"/>
        <Parameter name="pStartTime" type="Time"/>
        <Parameter name="pEndTime" type="Time"/>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDesc" type="String"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="_ignore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="6445858b-d093-47fb-8544-4f6dc48cb877">
        <updating/>
        <source>validate(_passport : CM_Passport) updating;

vars

begin
	self.raiseExceptionIfNotTransient(method);
	if self.shiftDay = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Day',null, null);
		app.raiseCMException(Input_required_field_day,null, null); // cnwdb2	PAR 35364
	endif;
	
	if not self.startTime.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'Start',null, null);
	endif;

	if not self.endTime.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'End',null, null);
	endif;
	
	if self.endTime &lt; self.startTime then
//		app.raiseCMException1(ERR_SHIFT_WRONG_TIME, null,null, null); CAN have end before start
	endif;

	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code',null, null);
		app.raiseCMException(Input_required_field_code,null, null); // cnwdb2	PAR 35364
	endif;

end;
</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="796385f7-91de-4efc-b435-d3acd3f61670">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport) updating;
// 09/12/2014   cnwdb2	PAR #35364
vars
	existingShift : CM_ShiftStd;

begin
	
	self.raiseExceptionIfNotTransient(method);
	
	self.validate(_passport);
	
	existingShift := self.myTerminal.allShiftsStandard[self.shiftDay, self.startTime];
	if existingShift &lt;&gt; null then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'Worker Shift ', self.code &amp; " at " &amp; self.getShiftDay() &amp; ' ' &amp; self.startTime.String, null,'Worker Shift', null);
		app.raiseCMException2(Already_exists_worker_shift,self.code, self.getShiftDay() &amp; ' ' &amp; self.startTime.String,'Worker Shift', null); // cnwdb2 PAR 35364
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="033becf0-bb44-49de-b7b4-2f948da52732">
        <updating/>
        <source>validateForUpdate( _passport : CM_Passport ) updating;

// 09/12/2014   cnwdb2	PAR #35364
vars
	existingShift,
	realFromPxyShift	: CM_ShiftStd;
	expectedEdition		: Integer;
	
begin
	
	inheritMethod( _passport );
	
	// Extra validation added.	Par 17324, 02 of July, 2008	cnwvu1
	self.validate( _passport );	
	
	// Extra validation for possible duplicates.	Par 17324, 02 of July, 2008	cnwvu1
	// getting real from proxy
	self.pxyGetRealObjectAndEdition(realFromPxyShift, expectedEdition);
	// getting existing shift
	existingShift := self.myTerminal.allShiftsStandard[self.shiftDay, self.startTime];
	if existingShift &lt;&gt; null
	and existingShift &lt;&gt; realFromPxyShift // there is another real shift different from updated one
	then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'Worker Shift ', self.code &amp; " at " &amp; self.getShiftDay() &amp; ' ' &amp; self.startTime.String, null,'Worker Shift', null);
		app.raiseCMException2(Already_exists_worker_shift,self.code, self.getShiftDay() &amp; ' ' &amp; self.startTime.String,'Worker Shift', null); // cnwdb2 PAR 35364

	endif;
	
	
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
