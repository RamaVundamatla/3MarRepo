    <JadeMethod name="checkMultiSelect" id="e7680953-9632-47cf-89a2-9f73e9e66f1d">
        <updating/>
        <source>checkMultiSelect( _lastIndex : Integer ):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2015	cnwndl1	Initial creation	Par 36846

*/

vars

	index : Integer;
	entity : CM_MenuEntity;
	pickupEntityClass : Class;
	oldParent : CM_MenuEntity;

begin

	self.allMultiSelectObjects.clear();

	self.lastMultiIndex := _lastIndex;
	if self.lastMultiIndex &lt; 1 or self.lastMultiIndex &gt; lstBox.listCount then
		self.lastMultiIndex := 0;
		return false;
	endif;
	
	if self.myPickupEntity = null or self.origIndex = 0 then
		self.lastMultiIndex := 0;
		return false;
	endif;
	
	pickupEntityClass := self.myPickupEntity.class;
	oldParent := self.myPickupEntity.myParent;
	
	if self.origIndex &lt; self.lastMultiIndex then
		//forwards
		foreach index in self.origIndex to self.lastMultiIndex do
			entity := lstBox.itemObject[index].CM_MenuEntity;
			if entity = null then
				//huh?
				self.lastMultiIndex := 0;
				return false;
			elseif entity = self.myPickupEntity then
				continue;
			elseif entity.class &lt;&gt; pickupEntityClass or entity.myParent &lt;&gt; oldParent then
				//one of the selection doesn't match, must be all the same type
				self.lastMultiIndex := 0;
				return false;
			endif;
			self.allMultiSelectObjects.add(entity);
		endforeach;
	else
		//backwards
		foreach index in self.lastMultiIndex to self.origIndex do
			entity := lstBox.itemObject[index].CM_MenuEntity;
			if entity = null then
				//huh?
				self.lastMultiIndex := 0;
				return false;
			elseif entity = self.myPickupEntity then
				continue;
			elseif entity.class &lt;&gt; pickupEntityClass or entity.myParent &lt;&gt; oldParent then
				//one of the selection doesn't match, must be all the same type
				self.lastMultiIndex := 0;
				return false;
			endif;
			self.allMultiSelectObjects.add(entity);
		endforeach;
	endif;
	
	return true;

epilog

	

end;</source>
        <access>protected</access>
        <Parameter name="_lastIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
