    <JadeMethod name="deckHasJobs" id="17ca3aa5-f88d-43bf-b85c-55998b56f582">
        <source>deckHasJobs(_deck: CM_DeckVoyage; _workPoint: CM_WorkPoint) : Boolean protected;
/*
Purpose:			
	Return true if this deck has jobs for the work point
*/
vars
	allJobs: CM_VoyageJobSet;
	job: CM_VoyageJob;
begin

	create allJobs transient;
	_deck.getAllDeckJobs(allJobs);
	foreach job in allJobs do
		if not job.isLoadedToOperations then
			continue;
		endif;
		if job.getMyWorkPointObject = _workPoint then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog
	delete allJobs;
end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f7afb039-53d8-4b67-9128-862f50b62ed1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.allDecks.purge;
	self.allWorkPoints.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setJobsForWorkPoint" id="b0453856-072e-4499-90b5-5d61d0a4da2a">
        <updating/>
        <source>setJobsForWorkPoint(_workPoint : CM_Object;
					_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2011	cnwer1	Initial creation CCMS MES 1033
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1 

*/

vars
	wsWorkPoint : WS_WorkPoint;
	job 		: CM_Job;
	wsJob 		: WS_Job;
	jobSheet,
	workPointJobSheet : CM_VoyageJobSheet;
begin
	
	create wsWorkPoint transient;
	wsWorkPoint.setProxyFromObject(_workPoint);
	self.allWorkPoints.add(wsWorkPoint);
	
	workPointJobSheet:=_voyage.allJobSheets[_workPoint.IF_VoyageWorkPoint.getID];

	if workPointJobSheet = null then
		return;
	endif;
	
	foreach job in workPointJobSheet.allJobsByOrder do
		if not job.CM_VoyageJob.isLoadedToOperations then
			continue;
		endif;
		
		create wsJob transient;
		wsJob.setProxyFromObject(job);
		wsWorkPoint.allJobs.add(wsJob);
	endforeach;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_Object"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setLOLOStructureForRequest" id="e290395f-13d2-459b-a99c-351a36a57510">
        <source>setLOLOStructureForRequest(	_request : CM_Request;
							_holdSlots : WS_SlotArray input;
							_crane : IF_VoyageWorkPoint;
							_slotId,
							_points: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwer1	Initial creation CCMS MES 1026 par 29962

*/

vars
	wsSlot: WS_Slot;
begin
	if _request = null then
		return;
	endif;
	if  _request.hasJobLoadToOps(_crane) then
		create wsSlot transient;
		wsSlot.name := _slotId;
		if _request.getIsDischarge then
			wsSlot.visibility := "Discharge";
		else
			wsSlot.visibility := "Load";
		endif;
		wsSlot.tierHeight := 1;
		wsSlot.isGeneralCargo := false;
		create wsSlot.myStructure transient;
		wsSlot.myStructure.setDetails(_slotId,White,Black,_points);

		wsSlot.setDetailsFromRequest(_request);
		_holdSlots.add(wsSlot);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_holdSlots" type="WS_SlotArray" usage="input"/>
        <Parameter name="_crane" type="IF_VoyageWorkPoint"/>
        <Parameter name="_slotId" type="String"/>
        <Parameter name="_points" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLOLOStructureForTiers" id="198572e9-7c12-4118-8957-5a305d16aab3">
        <source>setLOLOStructureForTiers(	_tiers  : CM_TierDefnByOrdinalDict; 
							_wsHold : WS_Deck input;
							_crane  : IF_VoyageWorkPoint;
							y1, x1  : Integer io;
							bayX1   : Integer io) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2012	cnwer1	Initial creation CCMS MES 1026 par 29962 LOLO changes
28 Apr 2021 cnwma1  ChangeRequest 51024: MTN - Add Cell and Tier numbers to Tallyman
*/
constants
	SlotHeight = 20;
	SlotWidth  = 20;
	Gap  	   = 1;
vars
	wsSlotRoB	: WS_Slot;
	slot 		: CM_SlotDefn;
	voyageSlot  : CM_SlotDefnVoyage;
	tier		: CM_TierDefn;
	x2,
	y2 			: Integer;
	points, 
	slotId 		: String;
	request 	: CM_Request;
begin
	foreach tier in _tiers  reversed, discreteLock do
		foreach slot in tier.allSlotDefinitions discreteLock do 
			voyageSlot:=slot.CM_SlotDefnVoyage;		
			if voyageSlot.unavailable then
				continue;
			endif;
			x1     := (bayX1 + ((slot.myCellDefinition.alignment-1)*(SlotWidth + Gap))).Integer;
			slotId := voyageSlot.mySlotController.getStowageId(null);
			create wsSlotRoB transient;
			wsSlotRoB.name		 := slotId;
			wsSlotRoB.visibility := "Both";
			
			if voyageSlot.myAftSlot &lt;&gt; null then
				wsSlotRoB.linked40Slot:=voyageSlot.myAftSlot.CM_SlotDefnVoyage.mySlotController.getStowageId(null).String &amp; "LOLO";
			endif;
			
			create wsSlotRoB.myStructure transient;
			
			y2:=y1 + SlotHeight;
			x2:=x1 + SlotWidth;
			points:= x1.String &amp; "," &amp; y1.String &amp; " " &amp; 
					 x1.String &amp; "," &amp; y2.String &amp; " " &amp;
					 x2.String &amp; "," &amp; y2.String &amp; " " &amp;
					 x2.String &amp; "," &amp; y1.String &amp; " " &amp;
					 x1.String &amp; "," &amp; y1.String;
			wsSlotRoB.myStructure.setDetails(slotId,White,Black,points);
			
			//28.04.2021 cnwma1 #51024
			wsSlotRoB.myStructure.setStructureLabels(tier,_tiers,voyageSlot);
			//28.04.2021 cnwma1 #51024
			
			_wsHold.allRemainOnBoardSlots.add(wsSlotRoB);	
			wsSlotRoB.setDetailsFromLOLOController(voyageSlot.mySlotController);
			
			request:=voyageSlot.mySlotController.mySlotRequestLoad;
			self.setLOLOStructureForRequest(request,_wsHold.allLoadSlots,_crane,slotId,points);
			
			request:=voyageSlot.mySlotController.mySlotRequestDischarge;
			self.setLOLOStructureForRequest(request,_wsHold.allDischargeSlots,_crane,slotId,points);
			
			x1:=x1+ SlotWidth + Gap;
		endforeach;
		y1:=y1 + SlotHeight + Gap;

	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiers" type="CM_TierDefnByOrdinalDict"/>
        <Parameter name="_wsHold" type="WS_Deck" usage="input"/>
        <Parameter name="_crane" type="IF_VoyageWorkPoint"/>
        <Parameter name="y1" type="Integer" usage="io"/>
        <Parameter name="x1" type="Integer" usage="io"/>
        <Parameter name="bayX1" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setLOLOStructureFromObject" id="09516d4a-c304-4148-83e0-13e8b1219e48">
        <source>setLOLOStructureFromObject(_voyage : CM_Voyage; _crane : CM_Crane);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwer1	Initial creation CCMS MES 1026 par 29962 LOLO changes

*/
constants
	Gap  = 1;
vars
	hold : CM_Hold;
	voyageHold : CM_VoyageHold;
	wsHold	 	: WS_Deck;
	bay  : CM_Bay;
	voyageBay : CM_BayVoyage;
	bayX1, maxX1,
	x1, y1 : Integer;
begin
	if _voyage.myCellularVoyageStructure = null then
		return;
	endif;

	//add all the roro structural decks
	foreach hold in _voyage.myCellularVoyageStructure.allHolds discreteLock do
		wsHold:=null;
		voyageHold:=hold.CM_VoyageHold;
		
		if not voyageHold.hasJobsLoadedToOps( _crane) then
			continue;
		endif;
		
		// create the wsDeck to represent the hold
		create wsHold transient;
		//wsHold.name:=voyageHold.ordinalHold.String;
		self.allDecks.add(wsHold);	
		bayX1:=100;
		maxX1 := 0;
		foreach bay in voyageHold.allBays discreteLock do
			voyageBay:=bay.CM_BayVoyage;
			//epr par 30099 25/7/12
			if wsHold.name = null then
				wsHold.name:= bay.id;
			else
				wsHold.name:=wsHold.name &amp; "-" &amp; bay.id;
			endif;
			//lets start a bit down the screen for each bay
			y1 := 100;
			self.setLOLOStructureForTiers(voyageBay.allTiersOnDeck,wsHold,_crane,y1,x1,bayX1);
			maxX1:=maxX1.max(x1);
			// gap for under deck 
			y1:=y1 + 10 + Gap;
			self.setLOLOStructureForTiers(voyageBay.allTiersUnderDeck,wsHold,_crane,y1,x1,bayX1);
			maxX1:=maxX1.max(x1);
			bayX1:=maxX1+ 20; 
		endforeach;
	endforeach;
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="37dbbb65-637f-4916-81e6-577813a89b1c">
        <updating/>
        <source>setProxyFromObject(_object: CM_Voyage) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2008	cnwkao1	Initial creation

*/

vars
	voyageData: HMS_VoyageData;
	berth: HMS_Berth;
begin
	inheritMethod(_object);
	self.code			:= _object.code;
	self.description	:= _object.description;
	self.comboboxDescription := self.code &amp; " " &amp; self.description;
	self.arrivalDT:=_object.arrivedDT.asStringForWebInterface;			//cnwmc5 - 13 Jan 2016 - PAR 37326
	self.planningVersion := _object.planningVersion;
	self.departedDT := _object.departedDT.asStringForWebInterface();	// 21/6/18 MAP TFS38046
	self.estimatedArrivalDT := _object.estimatedArrivalDT.asStringForWebInterface();
	self.estimatedDepartureDT := _object.estimatedDepartureDT.asStringForWebInterface();
	self.lloydsNumber := _object.lloydsNumber;
	self.voyageCodeExternal := _object.voyageCodeExternal;
	
	voyageData := _object.myHMSVoyageData;		// 26/6/18 MAP TFS38046
	if voyageData &lt;&gt; null then
		berth := voyageData.getMyBerth();
		if berth &lt;&gt; null then
			self.berthCode := berth.code;
		endif;
	endif;
	
	
	

epilog

end;</source>
        <Parameter name="_object" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setROROStructureFromObject" id="9fafc932-a270-4c44-a62a-ae7153fffa0d">
        <updating/>
        <source>setROROStructureFromObject(_voyage : CM_Voyage; _workPoint : CM_WorkPoint) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2011	cnwer1	Initial creation CCMS MES 1116
04 July 2012	cnwer1	PAR 29948
11 July 2012	cnwer1	PAR 29962
*/

vars
	wsDeck	 	: WS_Deck;
	wsStructure : WS_Structure;
	wsSlotRoB,
	wsLoadSlot, wsDischargeSlot: WS_Slot;
	deck 		: CM_Deck;
	deckItem 	: CM_DeckItem;
	deckLayout	 : CM_DeckLayout;
	deckLayerLayout : CM_DeckLayerLayout;
	deckItemLayout , coveringDeckItemLayout: CM_DeckItemLayout;
	allControllers 	: CM_VoyageROROControllerArray;
	controller		: CM_VoyageROROController;
	request			: CM_VoyageRequest;
	dischargeVisible,
	loadVisible : Boolean;
	addedToLoadSlot,
	addedToDischSlot	: Boolean;
	requestLayout : CM_RORORequestLayout;
	requestSlotLC : CM_ROROSlotController;
begin

	//self.setProxyFromObject(_voyage);
	
	if _voyage.myROROStructure = null then
		return;
	endif;
	
	create allControllers transient;
	//add all the roro structural decks
	foreach deck in _voyage.myROROStructure.allDecks discreteLock do
		wsDeck:=null;
		if deck.myDeckLayout = null then
			continue;
		endif;
		
		if not deck.CM_DeckVoyage.hasJobsLoadedToOps( _workPoint) then
			continue;
		endif;
		deckLayout:=deck.myDeckLayout;
		foreach deckLayerLayout in deckLayout.allDeckLayerLayouts  discreteLock where  deckLayerLayout.isVisible  do  
			foreach deckItemLayout in deckLayerLayout.allDeckItemLayouts discreteLock  do
				dischargeVisible:=true;
				loadVisible:=true;
				if not deckItemLayout.getVisibilityTallyman(dischargeVisible,loadVisible) then
					continue;
				endif;

				if wsDeck = null then
					create wsDeck transient;
					wsDeck.setProxyFromObject(deck);
					self.allDecks.add(wsDeck);
				endif;	
				wsSlotRoB:=null;
				if deckLayerLayout.type = ROROLayerType_Structure then					
					create wsStructure transient;
					wsStructure.setProxyFromObject(deckItemLayout);
					wsDeck.allStructureSlots.add(wsStructure);
				else
				
					deckItem:=deckItemLayout.myDeckItem;
			
					if deckItem = null then
						continue;
					endif;
			
					if (dischargeVisible or loadVisible) then
						create wsSlotRoB transient;
						wsSlotRoB.name:=deckItem.code;
						if dischargeVisible and loadVisible then
							wsSlotRoB.visibility :="Both";
						else
							if dischargeVisible then
								wsSlotRoB.visibility :="Discharge";
							elseif loadVisible then
								wsSlotRoB.visibility :="Load";
							else
								wsSlotRoB.visibility :="None";
							endif;
						endif;
						
						create wsSlotRoB.myStructure transient;
						wsSlotRoB.myStructure.setProxyFromObject(deckItemLayout);
						wsDeck.allRemainOnBoardSlots.add(wsSlotRoB);	
					endif;
					
					addedToLoadSlot := false;
					addedToDischSlot := false;
					wsLoadSlot := null;
					wsDischargeSlot := null;
					
					allControllers.clear;
					deckItem.getAllVoyageControllers(allControllers);					
				
					foreach controller in allControllers do
						if wsSlotRoB &lt;&gt; null then
							wsSlotRoB.setDetailsFromController(controller);
						endif;
						
						//Get Load
						//epr par 29948 4/7/12 
						request := controller.myRORORequestLoad;
						if request &lt;&gt; null then //and loadVisible then
							if self.setSlotFromRequest(request, _workPoint.IF_VoyageWorkPoint, deckItem, deckItemLayout, wsLoadSlot) then
								wsLoadSlot.visibility := "Load";
								if not addedToLoadSlot then
									wsDeck.allLoadSlots.add(wsLoadSlot);
									addedToLoadSlot := true;
								endif;
								if wsSlotRoB = null then
									create wsSlotRoB transient;
									wsSlotRoB.name:=deckItem.code;
									wsSlotRoB.visibility := "Load";
									wsSlotRoB.setDetailsFromController(controller);
									create wsSlotRoB.myStructure transient;
									wsSlotRoB.myStructure.setProxyFromObject(deckItemLayout);
									wsDeck.allRemainOnBoardSlots.add(wsSlotRoB);	
								endif;
							endif;
						endif;
						
						//Get Discharge
						request:=controller.myRORORequestDischarge;
						if request &lt;&gt; null then // and dischargeVisible then
							if self.setSlotFromRequest(request, _workPoint.IF_VoyageWorkPoint, deckItem, deckItemLayout, wsDischargeSlot) then
								wsDischargeSlot.visibility := "Discharge";
								if not addedToDischSlot then
									wsDeck.allDischargeSlots.add(wsDischargeSlot);
									addedToDischSlot := true;
								endif;
								if wsSlotRoB = null then
									create wsSlotRoB transient;
									wsSlotRoB.name:=deckItem.code;
									wsSlotRoB.visibility := "Discharge";
									wsSlotRoB.setDetailsFromController(controller);
									create wsSlotRoB.myStructure transient;
									wsSlotRoB.myStructure.setProxyFromObject(deckItemLayout);
									wsDeck.allRemainOnBoardSlots.add(wsSlotRoB);	
								endif;
							endif;
						endif;
						
					endforeach;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
epilog
	delete allControllers;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="setSlotFromRequest" id="e8318815-69e8-43a7-8086-cc7b7274dd09">
        <source>setSlotFromRequest(_request: CM_Request; _workPoint: IF_VoyageWorkPoint; _deckItem: CM_DeckItem; _deckItemLayout: CM_DeckItemLayout; _wsSlot: WS_Slot io) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2012	cnwdw1	Initial creation
*/
vars
	job: CM_VoyageJob;
	request : CM_Request;
begin

	if not _request.hasJobLoadToOps(_workPoint) then
		return false;
	endif;
	
	if _wsSlot = null then
		
		create _wsSlot transient;
		_wsSlot.name := _deckItem.code;
		if _deckItem.isKindOf(CM_ROROLocnDefn) then
			_wsSlot.tierHeight := _deckItem.CM_ROROLocnDefn.allROROSlotDefnByOrdinal.size;
		elseif _deckItem.isKindOf(CM_ROROGCDefn) then
			_wsSlot.isGeneralCargo := true;
		endif;

		create _wsSlot.myStructure transient;
		_wsSlot.myStructure.setProxyFromObject(_deckItemLayout);
	endif;
	_wsSlot.setDetailsFromRequest(_request);
	return true;
	
epilog

end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_workPoint" type="IF_VoyageWorkPoint"/>
        <Parameter name="_deckItem" type="CM_DeckItem"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_wsSlot" type="WS_Slot" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
