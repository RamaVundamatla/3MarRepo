vars

begin
	self.modalResult := ModalResultCancel;
	unloadForm();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGenerate" id="52a5a247-4dac-413b-be0b-2b4b2c76421d">
        <updating/>
        <source>doGenerate() updating, protected;
// DATE           WHO           REASON
// 01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
// 08/01/2026	navcs2	MTN-36895 MTN  - Improve Auto-Generation Performance for Cargo
vars
	i,
	max	: Integer;
	nextId	: String;
	abbr : String; //1 Sept 2022 navmv20 TFS 54610
	idString	: String;		// 08/01/2026	navcs2	MTN-36895
begin
	max := self.txtNumber.text.Integer;
	if max &lt; 1 then
		return;
	endif;
	//Start 1 Sept 2022 navmv20 TFS 54610
	if myCargoType&lt;&gt; null then 
		abbr:= myCargoType.abbreviation;
	else
		abbr:=null;
	endif;
    // End 1 Sept 2022 navmv20 TFS 54610
	if self.chkSystem.value then
		idString := "";					// 08/01/2026	navcs2	MTN-36895
		foreach i in 1 to max do
			//self.txtIds.text := self.txtIds.text &amp; self.myTerminal.generateNextCargoId(false,true) &amp; CrLf; //1 Sept 2022 navmv20 TFS 54610
			idString := idString &amp; self.myTerminal.generateNextCargoId(false,true,abbr) &amp; CrLf; //1 Sept 2022 navmv20 TFS 54610				// 08/01/2026	navcs2	MTN-36895
		endforeach;
		
		self.txtIds.text := idString;		// 08/01/2026	navcs2	MTN-36895
	else
		nextId := self.txtFirstId.text.trimBlanks();
		if nextId = "" then
			return;
		endif;
		
		idString := nextId &amp; CrLf;										// 08/01/2026	navcs2	MTN-36895
		foreach i in 1 to max - 1 do
			idString := idString &amp; nextId.incrementID(i) &amp; CrLf;		// 08/01/2026	navcs2	MTN-36895
		endforeach;
		
		self.txtIds.text := idString;									// 08/01/2026	navcs2	MTN-36895
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="8218a2de-2acc-4089-a7ca-d131e524cc4b">
        <updating/>
        <source>doOK() updating, protected;

vars

begin
	self.getIds();
	
	if self.checkLength then				//07/03/18 jlgmd1 TFS 37320
		self.modalResult := ModalResultOK;
		unloadForm();
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getIds" id="071a1598-5b0a-43c3-ac03-c7e037e06239">
        <updating/>
        <source>getIds() protected, updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 05/05/2017	cnwdap1		TFS 4266 AAT Cargo IDs being saved with Tab at the end
vars
	delim	: String;
begin
	self.ids.clear();
	delim := CrLf;
	self.txtIds.text := self.txtIds.text.removeString(Tab);					// TFS 4266
	self.txtIds.text := self.txtIds.text.removeString(" ");	//14 Jul 2017	NDL	TFS 5407
	self.txtIds.text.asStringArrayByDelimiter(self.ids, delim);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="39ac1883-85da-4797-b79a-177f72a44874">
        <updating/>
        <source>setupForm() updating;
// show any existing ids passed from the cargo form
// 08/01/2026	navcs2	MTN-36895 MTN  - Improve Auto-Generation Performance for Cargo

vars
	str	: String;
	textStr	: String;		// 08/01/2026	navcs2	MTN-36895
begin
	inheritMethod();
	
	foreach str in self.ids do
		textStr := textStr &amp; str &amp; CrLf;		// 08/01/2026	navcs2	MTN-36895
	endforeach;	
	
	txtIds.text := textStr;						// 08/01/2026	navcs2	MTN-36895
	
	self.chkSystem.click( self.chkSystem );	//16 Oct 2012	NDL par 30526
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ba2510d1-e603-42b3-a82e-a35bec30538c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014113, locale);
	btnCancel.translateCaption(Xlat_0014114, locale);
	btnGenerate.translateCaption(Xlat_0014115, locale);
	btnOK.translateCaption(Xlat_0014116, locale);
	chkSystem.translateCaption(Xlat_0014117, locale);
	grpGenerateIds.translateCaption(Xlat_0014118, locale);
	lblCargoIds.translateCaption(Xlat_0014119, locale);
	lblFirstId.translateCaption(Xlat_0014120, locale);
	lblNumber.translateCaption(Xlat_0014121, locale);
end;</source>
    </JadeMethod>
</GUIClass>
