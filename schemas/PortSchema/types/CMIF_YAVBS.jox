    <JadeMethod name="populateCriteriaForVbs" id="ca1632fc-59d6-428f-a05b-605146b56bd4">
        <updating/>
        <source>populateCriteriaForVbs(_checkObject 	: Object;
						_hasCarrier,
						_hasOperator,
						_hasCargoType,
						_hasProduct,
						_hasCommodity 	: Boolean io)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
*/

vars
	criteria 			: CM_YACriteria;
	objSet   			: ObjectSet;
	root				: CM_Root;
begin

	root := app.myRoot;
	
	if _hasCarrier then
		create objSet transient;
		objSet.clear();
		self.getMatchingCarrier(_checkObject,objSet);
		if objSet.isNotEmpty then
			/*
			create criteria transient;
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Carrier], objSet, null);
			self.allScenarioCriteria.add( criteria );
			*/
			self.myCarrier := objSet.first.CM_Carrier;
		endif;
	endif;
	
	if _hasOperator then
		create objSet transient;
		objSet.clear();
		self.getMatchingOperators(_checkObject,objSet);
		if objSet.isNotEmpty then
			/*
			create criteria transient;
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet, null);
			self.allScenarioCriteria.add( criteria );
			*/
			self.myOperator := objSet.first.CM_Operator;
		endif;
	endif;
	
	if _hasCargoType then
		create objSet transient;
		objSet.clear();
		self.getMatchingCargoTypes(_checkObject,objSet);
		if objSet.isNotEmpty then
			/*
			create criteria transient;
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_CargoType], objSet, null);
			self.allScenarioCriteria.add( criteria );
			*/
			self.myCargoType := objSet.first.CM_CargoType;
		endif;
	endif;
	
	
	if _hasProduct then
		create objSet transient;
		objSet.clear();
		self.getMatchingProducts(_checkObject,objSet);
		if objSet.isNotEmpty then
			/*
			create criteria transient;
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Product], objSet, null);
			self.allScenarioCriteria.add( criteria );
			*/
			self.myProduct := objSet.first.CM_Product;
		endif;
	endif;
	
	if _hasCommodity then
		create objSet transient;
		objSet.clear();
		self.getMatchingCommodities(_checkObject,objSet);
		if objSet.isNotEmpty then
			/*
			create criteria transient;
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Commodity], objSet, null);
			self.allScenarioCriteria.add( criteria );
			*/
			self.myCommodity := objSet.first.CM_Commodity;
		endif;
	endif;
epilog
	delete objSet;
end;</source>
        <Parameter name="_checkObject" type="Object"/>
        <Parameter name="_hasCarrier" type="Boolean" usage="io"/>
        <Parameter name="_hasOperator" type="Boolean" usage="io"/>
        <Parameter name="_hasCargoType" type="Boolean" usage="io"/>
        <Parameter name="_hasProduct" type="Boolean" usage="io"/>
        <Parameter name="_hasCommodity" type="Boolean" usage="io"/>
    </JadeMethod>
</Class>
