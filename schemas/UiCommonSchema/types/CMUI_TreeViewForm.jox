    <JadeMethod name="lstTree_mouseDown" id="c8607778-4eab-41a0-8651-837c08fe3eee">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTree_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mySelectedObject = listbox.listObject.CM_Object then
		return;//clicked on same entity - nothing to do
	endif;
	
	if self.mode &lt;&gt; self.Mode_View and self.mySelectedObject &lt;&gt; null then
		self.saveUserEntry();
	endif;
	
	self.mySelectedObject := listbox.listObject.CM_Object;
	self.doTreeClick();
	
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;


</source>
