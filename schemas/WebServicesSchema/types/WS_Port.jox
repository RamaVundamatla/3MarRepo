<Class name="WS_Port" id="e8302a0f-c1f3-4376-b0dd-f1a1b35f66e0">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to return all ports defined in the system or ports for a specific voyage.  </text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="ca41ddff-d341-42b7-9bc5-2f746377d7a0">
        <type name="String"/>
        <text>The Port Code. </text>
    </PrimAttribute>
    <PrimAttribute name="countryCode" id="3842383b-237b-4406-a2cb-02d3d0a36173">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <text>The Country code.</text>
    </PrimAttribute>
    <PrimAttribute name="countryDescription" id="68482bd7-b373-47db-95a0-cd3b15f5859d">
        <length>26</length>
        <embedded/>
        <type name="String"/>
        <text>The Country description.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="312c1f73-70ba-4409-b9c2-f281185f6dc6">
        <type name="String"/>
        <text>The Port description.</text>
    </PrimAttribute>
    <PrimAttribute name="portCode" id="3ceaaf92-d5f0-42d3-b9a7-6a808b0c24aa">
        <length>4</length>
        <embedded/>
        <type name="String"/>
        <text>The 3 character Port Code.</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="593b40b5-32de-4a4b-b9be-46e692913d24">
        <updating/>
        <source>setProxyFromObject(_object: CM_Port) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	country			: CM_Country;
	desc			: String;
begin
	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	self.portCode := _object.portCode;
	country := _object.myCountry;
	if country &lt;&gt; null then
		self.countryCode := country.code;
		//self.description := country.description;
	endif;
	
	desc := " ";
	if self.countryCode &lt;&gt; null then
		desc := " (" &amp; self.countryCode &amp; ") ";
	endif;
	
	self.description := self.portCode &amp; desc &amp; self.description;
	
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Port"/>
    </JadeMethod>
</Class>
