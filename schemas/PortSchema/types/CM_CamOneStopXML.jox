    <JadeMethod name="makeArrCarrTruckSubSectXML" id="d9b1fc10-0992-43d0-a1c5-fa0ce74b3f17">
        <source>makeArrCarrTruckSubSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	carrier : CM_Carrier;
	vvr : CM_VehicleVisitRecord;
	workStr : String;

begin

	rootElem := _parentElem.addElement('ArrivalCarrierTruck');
	
	if _ti = null then
		return;
	endif;
	carrier := _ti.getCarrierReceive();
	if carrier = null then
		return;
	endif;
	
	xmlElem := rootElem.addElement('CarrierCode');
	xmlElem.setText( carrier.code );
/*	
	xmlElem := rootElem.addElement('CarrierName');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CTO_ReferenceNumber');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CTO_CarrierName');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CTO_CarrierCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Carrier_ABN');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('VBS_Booking');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('BatNumber');
	xmlElem.setText( null );
*/	
	workStr := null;
	vvr := _ti.getVehicleVisitReceival();
	if vvr &lt;&gt; null then
		workStr := vvr.regNumber;
	endif;
	xmlElem := rootElem.addElement('RegoNumber');
	xmlElem.setText( workStr );
/*	
	xmlElem := rootElem.addElement('DestinationCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('BillingAccount');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Slot');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('DoorFacing');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ScheduledDeparture');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('SheduledArrival');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('StackRunID');
	xmlElem.setText( null );
*/	
epilog

end;</source>
        <access>protected</access>
