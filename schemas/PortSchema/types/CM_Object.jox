    <JadeMethod name="canUserAccessSelf" id="f296848c-68cb-404d-b65f-75ec2098cc6b">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport : CM_Passport) : Boolean;
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			Does passed in user have access to this object     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 6 Jun 2003	sgp			
// Passport is passed in instead of user for performance reasons.  The data
// data access controllers for the current user are set on passport on startup.
// ---------------------------------------------------------------------------
vars
	dac :  CM_DataAccessController;
	tmpClass	: Class;
	clsName	: String;

begin

	if app.isSpecial() then
		return true;
	endif;

	tmpClass := self.class;
	if tmpClass = CM_ExternalOrganisation or
	   tmpClass = CM_InternalOrganisation then
		clsName := CM_Organisation.name;
	else
		clsName := self.class.name;
	endif;

	// Par 14106
	// Have brought into line with existing functionality which
	// uses user data access if the user is not null. This is because
	// some data access checking is based on the passed in user rather
	// than the logged on user.
	
	if _user &lt;&gt; null then
		dac := _user.allDataAccessControllers[clsName];
	else
		dac := _passport.allDataAccessControllers[clsName];
	endif;

	if dac &lt;&gt; null and (not dac.canAccess(self)) then
		_failedDAC := dac;
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
