<JadeWebServiceProviderClass name="JMTUnitTestService" id="d4f63a79-c037-4ce4-a461-1af702ea5d7d">
    <superclass name="JadeWebServiceProvider"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="buildTestTree" id="3de90617-33c0-4a75-92a4-2d90d28d3d80">
        <source>buildTestTree(_schema: Schema; _class: Class; _xml: String io);
//24 April 2010	cnwdw1	
//
vars
	subclass: Class;
	allSubclasses: ClassColl;
	meth: Method;
	allMethods: MethodSet;

begin
	create allSubclasses transient;
	_class.getSubclasses(allSubclasses);
	foreach subclass in allSubclasses do
		_xml := _xml &amp; "&lt;folder&gt;&lt;name&gt;" &amp; subclass.name &amp; "&lt;/name&gt;";
		self.buildTestTree(_schema, subclass, _xml);
		_xml := _xml &amp; "&lt;/folder&gt;";
	endforeach;
	
	create allMethods transient;
	_class.allMethods(allMethods);
	foreach meth in allMethods do
		if app.isUnitTestMethod(meth) then
			_xml := _xml &amp; "&lt;test&gt;&lt;name&gt;" &amp; meth.name &amp; "&lt;/name&gt;&lt;/test&gt;";
		endif;
	endforeach;
epilog
	delete allSubclasses;
	delete allMethods;
end;</source>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_xml" type="String" usage="io"/>
    </JadeMethod>
    <JadeWebServicesMethod name="echo" id="c10a98d9-5cb5-4ac1-9471-8b2afc786628">
        <source>echo(_message: String) :String webService;
//23 September 2010	cnwdw1	
//
vars

begin
	return _message.toUpper;
end;</source>
        <Parameter name="_message" type="String"/>
        <ReturnType type="String"/>
    </JadeWebServicesMethod>
    <JadeMethod name="getRootFolder" id="9c66a985-e922-4b0c-b74e-787973c3ae71">
        <source>getRootFolder() : String;
//11 February 2010	cnwdw1	
//
vars
	schema: Schema;
	rootClass: Class;
	xml: String;
begin

	schema := rootSchema.getSchema("JMTUnitTest");
	rootClass := schema.getClass("UT_UnitTest");
	xml := "&lt;folders&gt;";
	self.buildTestTree(schema, rootClass, xml);
	xml := xml &amp; "&lt;/folders&gt;";
	return xml;
	
/*
	return "
&lt;folders&gt;
	&lt;folder&gt;
		&lt;name&gt;Folder XXX&lt;/name&gt;
		&lt;folder&gt;
			&lt;name&gt;Folder ZZZ&lt;/name&gt;
			&lt;test&gt;
				&lt;name&gt;Test 4&lt;/name&gt;
			&lt;/test&gt;
		&lt;/folder&gt;
		&lt;test&gt;
			&lt;name&gt;Test 1&lt;/name&gt;
		&lt;/test&gt;
	&lt;/folder&gt;
	&lt;folder&gt;
		&lt;name&gt;Folder AAA&lt;/name&gt;
		&lt;test&gt;
			&lt;name&gt;Test 2&lt;/name&gt;
		&lt;/test&gt;
		&lt;test&gt;
			&lt;name&gt;Test 3&lt;/name&gt;
		&lt;/test&gt;
	&lt;/folder&gt;
&lt;/folders&gt;";
*/

end;</source>
        <wsdlName>getRootFolder</wsdlName>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubFolders" id="7ee6e7e1-2323-48a4-bd69-5993228c40fd">
        <source>getSubFolders(name: String): StringArray;
//11 February 2010	cnwdw1	
//
vars
	schema: Schema;
	class, subclass: Class;
	subFolders: StringArray;
	allSubclasses: ClassColl;
begin
	create subFolders transient;
	schema := rootSchema.getSchema("JMTUnitTest");
	class := schema.getClass(name);
	create allSubclasses transient;
	class.getSubclasses(allSubclasses);
	foreach subclass in allSubclasses do
		subFolders.add(subclass.name);
	endforeach;
	
	return subFolders;
epilog
	delete allSubclasses;
end;</source>
        <wsdlName>getSubFolders</wsdlName>
        <Parameter name="name" type="String"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getTests" id="27780c1b-1ee5-4f10-9e7d-9b4f43af2cd9">
        <source>getTests(name: String): StringArray;
//11 February 2010	cnwdw1	
//
vars
	schema: Schema;
	class, subclass: Class;
	tests: StringArray;
	meth: Method;
	allMethods: MethodSet;
begin
	create tests transient;
	schema := rootSchema.getSchema("JMTUnitTest");
	class := schema.getClass(name);
	create allMethods transient;
	class.allMethods(allMethods);
	foreach meth in allMethods do
		if app.isUnitTestMethod(meth) then
			tests.add(meth.name);
		endif;
	endforeach;
	
	return tests;
epilog
	delete allMethods;
end;</source>
        <wsdlName>getTests</wsdlName>
        <Parameter name="name" type="String"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeWebServicesMethod name="getVoyages" id="2a47128e-8b31-4fd6-8c4e-eaab1fcee59c">
        <source>getVoyages(_terminalCode: String): String webService;
//12 October 2010	cnwdw1	
//
vars
	terminal: CM_Terminal;
	startTs: TimeStamp;
	iterVoy: Iterator;
	voyage: CM_Voyage;
	xml: String;
begin
	app.initialize();
	terminal := app.myRoot.allTerminals[_terminalCode];
	if terminal = null then
		return "&lt;Error&gt;Terminal "&amp;_terminalCode&amp;" not found&lt;/Error&gt;";
	endif;
	
	iterVoy := terminal.allVoyagesByDepartDTCode.createIterator();
	terminal.allVoyagesByDepartDTCode.startKeyGeq(app.actualTimeServer(), null, iterVoy);
	xml := "&lt;Voyages&gt;";
	while iterVoy.next(voyage) do
		xml := xml &amp; "&lt;Voyage&gt;" &amp; 
					    "&lt;VoyCode&gt;" &amp; voyage.code &amp; "&lt;/VoyCode&gt;" &amp;
						"&lt;VoyDesc&gt;" &amp; voyage.description &amp; "&lt;/VoyDesc&gt;" &amp;
					  "&lt;/Voyage&gt;";
	endwhile;
	xml := xml &amp; "&lt;/Voyages&gt;";
	
	return xml;
epilog
	delete iterVoy;
	app.finalize;
end;</source>
        <Parameter name="_terminalCode" type="String"/>
        <ReturnType type="String"/>
    </JadeWebServicesMethod>
    <JadeMethod name="runTest" id="724959b9-ae37-4242-bce7-637ae2ee3841">
        <source>runTest(_class: String; _test: String; _profile: String) : String;
//24 April 2010	cnwdw1	
//
vars
	testController	: JMTTestController;
	class: Class;
	meth: Method;
	profileClass: UT_Profile;
	schema: Schema;
	xml: String;
	result: UT_TestResult;
begin
	schema := rootSchema.getSchema("JMTUnitTest");
	class := schema.getClass(_class);
	meth := class.getMethod(_test);
	
	create testController transient;
	testController.getProfile(_profile, profileClass);
	testController.runMethodTest(null, class, meth, profileClass);

	xml := "&lt;TestResults&gt;";
	foreach result in testController.getTestResults do
		xml := xml &amp; "&lt;TestResult&gt;";
		xml := xml &amp; "&lt;Folder&gt;"&amp;result.getClassName&amp;"&lt;/Folder&gt;";
		xml := xml &amp; "&lt;Test&gt;"&amp;result.getMethodName&amp;"&lt;/Test&gt;";
		xml := xml &amp; "&lt;Owner&gt;"&amp;result.getOwnerName&amp;"&lt;/Owner&gt;";
		xml := xml &amp; "&lt;ElapsedTime&gt;"&amp;result.getTimeString&amp;"&lt;/ElapsedTime&gt;";
		if result.hasPassed then
			xml := xml &amp; "&lt;Passed&gt;"&amp;"Yes"&amp;"&lt;/Passed&gt;";
		else
			xml := xml &amp; "&lt;Passed&gt;"&amp;"No"&amp;"&lt;/Passed&gt;";
		endif;
		xml := xml &amp; "&lt;Details&gt;"&amp;result.fullDetails&amp;"&lt;/Details&gt;";
		xml := xml &amp; "&lt;/TestResult&gt;";
	endforeach;
	xml := xml &amp; "&lt;/TestResults&gt;";
	return xml;
	
end;</source>
        <Parameter name="_class" type="String"/>
        <Parameter name="_test" type="String"/>
        <Parameter name="_profile" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</JadeWebServiceProviderClass>
