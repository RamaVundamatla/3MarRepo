    <JadeMethod name="addPorts" id="d1a7429a-89c8-40c0-96f8-e55d1fb708b9">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_PortCodeSelector::addPorts"/>
        </interfaceImplements>
        <source>addPorts(_objectArray : ObjectArray; _areTranshipPorts : Boolean);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by concms1
// Purpose:     Par 19013
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	if _objectArray.isEmpty then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveRail(_objectArray, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Make_code_active), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
        <Parameter name="_areTranshipPorts" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="8b65fda0-48e3-4c4b-bf5b-cb33ee47ed6d">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
18 Aug 2022  navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
----------   ----------  --------------------------------------------------
*/
vars

	toolbar		: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left); //+ 21/05/2009, cnwmd1, CCMS 1067, Par 19710
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);	// 28 Aug 2009	NDL	CCMS 1094
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnNewTrain, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditTrain, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveNext, CMUI_Toolbar.Control_Alignment_Left);	// 28 Aug 2009	NDL	CCMS 1094
	toolbar.addButton(self.btnCopyTrain, CMUI_Toolbar.Control_Alignment_Left);	// 28 Aug 2009	NDL	CCMS 1094
	toolbar.addButton(self.btnDeleteTrain, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnMoveToRail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnConfirmTrainI, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnConfirmTrainO, CMUI_Toolbar.Control_Alignment_Left); // PAR 19710
	toolbar.addButton(self.btnOutOrder, CMUI_Toolbar.Control_Alignment_Left);	//12 Aug 2009	NDL	CCMS 1094
	toolbar.addButton(self.btnDeparture, CMUI_Toolbar.Control_Alignment_Left);
		
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnRailPlan, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRailOps, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnWarnings, CMUI_Toolbar.Control_Alignment_Left);	// 18 Feb 2010 RJS Par 21951
	toolbar.addButton(self.btnNewEvent, CMUI_Toolbar.Control_Alignment_Left);	// 29 Oct 2009	NDL	Par 21519
	toolbar.addButton(self.btnLoadList, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEnquiryRec, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEnquiryRel, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCargoForecast,CMUI_Toolbar.Control_Alignment_Left);	//25-Apr-2022	TFS 53142

	//27 Nov 2009	NDL Par 21677
//	self.frmTrainCmb.borderStyle := Frame.BorderStyle_None;
//	toolbar.addFrame(self.frmTrainCmb, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	//27 Nov 2009	NDL Par 21677
	self.frmTrainCmb.top := toolbar.height + 1;
	self.frmTrainCmb.left := toolbar.left;
	
	
	// ############### WAGON TOOLBAR
	toolbar := self.frmWagonToolbar;
	toolbar.addButton(self.btnNewWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteWagon, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCCWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRailAllocRem, CMUI_Toolbar.Control_Alignment_Left); //+ cnwmd1, Par 20211
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.addButton(self.btnWagonUp, CMUI_Toolbar.Control_Alignment_Left); // PAR 19710
	toolbar.addButton(self.btnWagonDown, CMUI_Toolbar.Control_Alignment_Left); // PAR 19710
	toolbar.addButton(self.btnConfirmIn, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnConfirmOut, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnIntransit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnIntransitNO, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTrainDir, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	//Start 18.8.2022 navhl20 TFS 54281
	toolbar.addButton(self.btnMoveWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnWagonUnplan, CMUI_Toolbar.Control_Alignment_Left);
	//End 18.8.2022 navhl20 TFS 54281
	
	toolbar.positionToolbarControls();
	self.frmWagonToolbar.top := 19;
	self.frmWagonToolbar.left := 1;	// cnwmp6 PAR 36875 4/4/16
	self.frmWagonToolbar.distanceFromRight := 2;	// cnwmp6 PAR 36875 5/4/16
	toolbar.visible := true;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addWagonRow" id="b9fbfe4d-9fa8-49fb-8d0e-3d10f6ddfda5">
        <source>addWagonRow(_wagon : CM_Wagon) protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rowStr			: String;
	entRow			: EntTableRow;
	idx				: Integer;
begin
	if _wagon = null then
		return;
	endif;
	
	//entDef := app.myController.getEntTableDef(ETDef_WagonData);			//- cnwmd1, CCMS 1067, Par 19710 &lt;- TableDef no longer req'd
	
	//foreach entRow in entDef.allEntTableRows do							//- cnwmd1, CCMS 1067, Par 19710
	foreach entRow in self.tblWagons.allTblDataEntRows do					//+ cnwmd1, CCMS 1067, Par 19710
		rowStr := rowStr &amp; _wagon.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
	endforeach;
	
	idx := self.tblWagons.addItem(rowStr);
	self.tblWagons.accessRow(idx).itemObject := _wagon;
	
	/* 			//- cnwmd1, CCMS 1067, Par 19710
	col := _wagon.getCCAllocationColor();
	if col &lt;&gt; NULL_COLOURCODE then
		self.tblWagons.accessedRow.backColor := col;
		self.tblWagons.accessedRow.foreColor := col.getInverseColour();
	endif;*/
	
end;


</source>
