        <source>setMyCaption() updating;
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars
	modeView : Integer;
begin
	self.setCaption(  self.myROROPlanningForm.setCaptionForModesGetView(self.myROROLocnDrawingController.modeView));
