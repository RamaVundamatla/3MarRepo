    <JadeMethod name="changeAutoVoyageStatus" id="f270d2ee-d44b-4d21-8849-c9f088b89ef2">
        <source>changeAutoVoyageStatus(_voyStatus : CM_VoyageStatus);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2024	navra1	Initial creation for //navra1 - MTN-33086 - 21st Oct 2024

*/

vars

begin
	if _voyStatus = null then
		app.writeLog("Voyage Status passed is null, cannot proceed", LogERROR);
		return;
	endif;
	
	if process.isInTransactionState() then
		app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myCurrentVoyage, _voyStatus.id,false,app.myPassport);
	else
		app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myCurrentVoyage, _voyStatus.id,false,app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_voyStatus" type="CM_VoyageStatus"/>
