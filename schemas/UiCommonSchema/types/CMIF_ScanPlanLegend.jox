<Class name="CMIF_ScanPlanLegend" id="ee0935e9-48a7-465e-b7b2-ea5f50d31ce6">
    <superclass name="CMIF_ScanPlanReport"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="attributeIndex" id="76116826-f9a1-4841-876c-5791c60bd8cf">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="colour" id="50c2f52d-8e28-415f-ae39-d736437246d7">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="header" id="7a437a2d-d193-4c9b-ac10-0282c693699a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myAgent" id="bf70c3a1-836c-4786-ae3b-eb3bbde91990">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_ScanPlanReportAgent"/>
        <Inverse name="CMIF_ScanPlanReportAgent::allScanPlanLegends"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myObject" id="e56fc953-1038-4d11-b72b-ca3505ca0f9e">
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="picture" id="d2e93f49-6ef1-411a-9f2b-41b779807da3">
        <type name="Binary"/>
    </PrimAttribute>
    <PrimAttribute name="title" id="82cdc436-8e46-4e56-865d-f2af6a2194fa">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setAttributeDetails" id="d6d1ab69-ce8f-46c9-8465-141be184474e">
        <updating/>
        <source>setAttributeDetails( _index : Integer; _agent : CMIF_ScanPlanReportAgent ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	self.attributeIndex := _index;
	
	self.colour := White;
	
	if _index = 1 then
		title := app.getErrorString(Longer_than_forty);
	elseif _index = 2 then
		title := app.getErrorString(High_cube);
	elseif _index = 3 then
		title := app.getErrorString(CM_Over_height);
	elseif _index = 4 then
		title := app.getErrorString(Over_length);
	elseif _index = 5 then
		title := app.getErrorString(CM_Over_width_right);
	elseif _index = 6 then
		title := app.getErrorString(CM_Over_width_left);
	elseif _index = 7 then
		title := app.getErrorString(Flat_rack);
	elseif _index = 8 then
		title := app.getErrorString(Reefer);
	elseif _index = 9 then
		title := app.getErrorString(Empty);
	elseif _index = 10 then
		title := app.getErrorString(CM_Hazardous);
	elseif _index = 11 then
		title := app.getErrorString(Sobdlr);
	elseif _index = 12 then
		title := app.getErrorString(Remain_board);
		if _agent.remainOnBoard = _agent.RobGrey then
			self.colour := WindowsGrey;
		endif;
	elseif _index = 13 then
		title := app.getErrorString(Tranship);
	elseif _index = 14 then
		title := app.getErrorString(BackEnd);
	endif;
	
	self.myAgent := _agent;

epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_agent" type="CMIF_ScanPlanReportAgent"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="8f954d0d-e10c-4d21-82e6-e6dea482980d">
        <updating/>
        <source>setDetails( _colourObject : CM_Object; _agent : CMIF_ScanPlanReportAgent ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	if _agent.allScanPlanLegends.isEmpty then
		//create the sub header legend
		_agent.addLegendSubHeading( null, true, false );
	endif;

	if _colourObject.isKindOf( CM_Port ) then
		self.colour := _colourObject.CM_Port.colour;
		self.title := " " &amp; _colourObject.CM_Port.code;
		
	elseif _colourObject.isKindOf( CM_Operator ) then
		self.colour := _colourObject.CM_Operator.colour;
		self.title := " " &amp; _colourObject.CM_Operator.code;
		
	elseif _colourObject.isKindOf( CM_CommodityGroup ) then
		self.colour := _colourObject.CM_CommodityGroup.colour;
		self.title := " " &amp; _colourObject.CM_CommodityGroup.code;
		
	elseif _colourObject.isKindOf( CM_ISOTypeGroup ) then
		self.colour := _colourObject.CM_ISOTypeGroup.colour;
		self.title := " " &amp; _colourObject.CM_ISOTypeGroup.code;
		
	elseif _colourObject.isKindOf( CM_ISOType ) then
		self.colour := _colourObject.CM_ISOType.colour;
		self.title := " " &amp; _colourObject.CM_ISOType.code;
		
	endif;
	
	self.myObject := _colourObject;
	self.myAgent := _agent;

epilog

end;</source>
        <Parameter name="_colourObject" type="CM_Object"/>
        <Parameter name="_agent" type="CMIF_ScanPlanReportAgent"/>
    </JadeMethod>
</Class>
