    <JadeMethod name="acceptedWarning" id="f2a35450-3691-4f29-a126-37b570a3beae">
        <source>acceptedWarning(	_mess : String;
					_ignoreAllFuture : Boolean io
					):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2016	cnwndl1	Initial creation	TFS 1936

*/

vars

	returnValue : Integer;

begin

	returnValue := self.optBox( app.getErrorString(No), app.getErrorString(Yes_For_One), app.getErrorString(Dont_warn), null, 1, _mess );
	if returnValue = 1 then
		return false;
	elseif returnValue = 2 then
		return true;
	elseif returnValue = 3 then
		_ignoreAllFuture := true;
		return true;
	endif;

epilog

end;</source>
        <Parameter name="_mess" type="String"/>
        <Parameter name="_ignoreAllFuture" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
