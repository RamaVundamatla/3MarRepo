    <JadeMethod name="setForCreate" id="44fd2339-934a-45d3-8e94-3b91ed328415">
        <updating/>
        <source>setForCreate(_proxyDeckItem : SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	_proxyDeckItem.raiseExceptionIfNotTransient(method);
	
	if  _proxyDeckItem.myDeck &lt;&gt; null then
		if _proxyDeckItem.myDeck.isTransient() then
			self.myDeck := _proxyDeckItem.myDeck.pxyGetRealObject();
		else
			self.myDeck := _proxyDeckItem.myDeck;
		endif;
	endif;
	
	self.setForUpdate(_proxyDeckItem,_passport);
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="f2329f8e-6dfb-4645-adc1-2c3615436a2d">
        <updating/>
        <source>setForCreateImport(_proxyDeckItem : SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.setForUpdate(_proxyDeckItem,_passport);
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2362dcdc-d0ed-4c25-a6e1-4ae4e19e624a">
        <updating/>
        <source>setForUpdate(_proxyDeckItem : SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	realLayout : CM_DeckItemLayout;
begin
	
	self.setCode( _proxyDeckItem.code, false );
	self.description 	:= _proxyDeckItem.description;
	self.remarks 		:= _proxyDeckItem.remarks;
	if _proxyDeckItem.myLayout &lt;&gt; null then
		if _proxyDeckItem.myLayout.isTransient() then
			realLayout:=_proxyDeckItem.myLayout.pxyGetRealObject();
			if realLayout &lt;&gt; null then
				self.myLayout := realLayout;
			endif;
		else
			self.myLayout := _proxyDeckItem.myLayout;
		endif;
	else
		self.myLayout := null; // PAR 27501
	endif;
	

epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
