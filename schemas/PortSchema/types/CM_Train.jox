    <JadeMethod name="getCargoManifestStr" id="671ae72a-c100-4e9d-9aa4-4bf9c8504557">
        <source>getCargoManifestStr() : String;
/*

Purpose:			Gets the cargo manifest information as a CSV String

Parameters:			NONE

Return Value:		String: Containing a CSV format

Date		Who		Reason
06 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	ti						: CM_TrackedItem;
	cargoManifest			: CMIF_CargoManifest;
	cargoManifests			: CMIF_CargoManifests;
	measureType				: CM_MeasurementType;
	cargoManifestCsv,
 	mode,
	totalWeight,
	measureTypeShortName	: String;
	
begin
	create cargoManifests transient;
	
	foreach ti in self.allTIsReceived do
		if ti.getImExStatusObject().code = TI_IMEX_STATUS_EXPORT then
			mode := CM_CargoForecast.Mode_Load;
		elseif ti.getImExStatusObject().code = TI_IMEX_STATUS_IMPORT then
			mode := CM_CargoForecast.Mode_Discharge;
		endif;
		
		cargoManifest := cargoManifests[mode, ti.myCargoType.id.String];
		if  cargoManifest &lt;&gt; null then
			cargoManifest.setTotalWeight(ti.totalWeight);
		else
			create cargoManifest transient;
			cargoManifest.setProxyForCreate(ti.myCargoType.id.String, ti.myCargoType, null, ti.totalWeight, mode);
			cargoManifests.add(cargoManifest);
		endif;
	endforeach;
	
	foreach ti in self.allTIsReleased do
		if ti.getImExStatusObject().code = TI_IMEX_STATUS_EXPORT then
			mode := CM_CargoForecast.Mode_Load;
		elseif ti.getImExStatusObject().code = TI_IMEX_STATUS_IMPORT then
			mode := CM_CargoForecast.Mode_Discharge;
		endif;
		
		cargoManifest := cargoManifests[mode, ti.myCargoType.id.String];
		if  cargoManifest &lt;&gt; null then
			cargoManifest.setTotalWeight(ti.totalWeight);
		else
			create cargoManifest transient;
			cargoManifest.setProxyForCreate(ti.myCargoType.id.String, ti.myCargoType, null, ti.totalWeight, mode);
			cargoManifests.add(cargoManifest);
		endif;
	endforeach;
	
	//Build String from data
	//measureType := app.getDefaultMeasurementForType(Type_Weight);
	
	foreach cargoManifest in cargoManifests do
		if cargoManifest.myCargoType = null or cargoManifest.mode = null then
			continue;
		endif;
		
		if cargoManifest.myCargoType &lt;&gt; null then
			measureType := cargoManifest.myCargoType.getMeasurementTypeFor(Type_Weight, true);
		else
			measureType := app.getDefaultMeasurementForType(Type_Weight);
		endif;
		
		if measureType = null then
			totalWeight := cargoManifest.totalWeight.asStringJMT();
			measureTypeShortName := "kg";
		else
			measureTypeShortName := measureType.shortName;
			totalWeight := app.convertMeasurementForDisplay(measureTypeShortName, cargoManifest.totalWeight);
		endif;
		
		//cargoManifestCsv &amp;= cargoManifest.myCargoType.description &amp; " - " &amp; cargoManifest.getDefaultMeasureTotalWeight() &amp; measureType.shortName &amp; " - " &amp; cargoManifest.mode;
		cargoManifestCsv &amp;= cargoManifest.myCargoType.description &amp; " - " &amp; totalWeight &amp; measureTypeShortName &amp; " - " &amp; cargoManifest.mode;
		cargoManifestCsv &amp;= ", ";
	endforeach;
	
	cargoManifestCsv := cargoManifestCsv.stripTrailingChar(",");
	
	return cargoManifestCsv;

epilog
	delete cargoManifests;
	delete cargoManifest;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTotals" id="a99bc76f-6fdf-45f4-8963-d6d603acad21">
        <source>getCargoTotals(_attrName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars	
	inward : Boolean;	
	tot : Integer;
	wag : CM_Wagon;
begin
	if _attrName = ETRow_NumCargoRec  then
		inward := true;
	elseif _attrName = ETRow_NumCargoRel  then
		inward := false;
	elseif _attrName = ETRow_TotalCargoIntransit  then
		inward := true;
	elseif _attrName = ETRow_TotalCargoIn  then
		inward := true;
	elseif _attrName = ETRow_TotalCargoLoaded  then
		inward := false;
	elseif _attrName = ETRow_TotalCargoDischarged then
		inward := true;
	endif;

	if inward then
		foreach wag in self.allWagonsByOrderInward discreteLock do
			tot := tot + wag.getCargoTotals(_attrName);
		endforeach;
	else
		foreach wag in self.allWagonsByOrderOutward discreteLock do
			tot := tot + wag.getCargoTotals(_attrName);
		endforeach;
	endif;
	
	return tot;

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoWeight" id="90d42305-5563-4008-acf5-eaad53c01e69">
        <source>getCargoWeight(_isInward : Boolean) : Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	weight : Decimal[12,2];
	ti : CM_TrackedItem;
	tis : CM_TIArray;
begin
	create tis transient;
	
	self.getAllTrackedItems(_isInward, tis);
	
	foreach ti in tis do
		//weight := weight + ti.weight;
		weight := weight + ti.totalWeight;	//02 Nov 2009	NDL Par 21519
	endforeach;
	
	return weight;
epilog
	delete tis;
end;</source>
        <Parameter name="_isInward" type="Boolean"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCargoWeightProposed" id="352b7ee2-8d50-4f13-ab75-5380e5919e72">
        <source>getCargoWeightProposed() : Integer;
// ---------------------------------------------------------------------------
// Created:     March 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 21977
// ---------------------------------------------------------------------------

vars
	weight : Decimal[12,2];
