<CollClass name="CM_MenuUserReportByNameDict" id="803f62bf-5cb2-422e-9460-5888a56004fe">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_MenuUserReport"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <MemberKey>
        <property name="CM_MenuUserReport::name"/>
    </MemberKey>
    <JadeMethod name="getNames" id="46d399db-dca7-4a66-a308-d211f018b3fb">
        <source>getNames() : String;
// -------------------------------------------
// Created 09 September 2004 by cnwdvb1
// -------------------------------------------
vars

	report	: CM_MenuUserReport;
	str		: String;

begin

	foreach report in self do
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; report.name.trimBlanks();
	endforeach;
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
