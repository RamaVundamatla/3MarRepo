<Class name="WS_InvoiceAPIAsyncPartUpdRes" id="9ba4430f-013b-4aa8-bec8-53e0d998107e">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="responseCode" id="8f681f62-b261-4fb8-a42f-0c9c1abc814f">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="responseMessage" id="8284af4a-cd8d-4f8b-abea-d0ae84d6a6c0">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFailure" id="2e8e4bb9-5f2f-468c-a9a1-407e0e891c14">
        <updating/>
        <source>setFailure(_errorNumber : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	navra1	Initial creation for  TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61411/Task - 61413)

*/


vars

begin
	if _errorNumber = 404 then
		self.responseCode := 404;
		self.responseMessage := "The passed in invoiceMessageUniqueIdentifier was invalid, no message with id found";
	elseif _errorNumber = 403 then
		self.responseCode := 403;
		self.responseMessage := "Forbidden Access";
	elseif _errorNumber = 512 then
		self.responseCode := 512;
		self.responseMessage := "Error in updating the EWSActivityInvoiceAPI status";
	elseif _errorNumber = 513 then
		self.responseCode := 500;
		self.responseMessage := "Error in updating the Invoice status";
	endif;
epilog

end;</source>
        <Parameter name="_errorNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSuccess" id="9a186df5-6ff2-4da1-b3c6-cfcd4631aabf">
        <updating/>
        <source>setSuccess() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	navra1	Initial creation for  TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61411/Task - 61413)

*/

vars

begin
	self.responseCode := 200;
	self.responseMessage := "The status of the message that the invoiceMessageUniqueIdentifier pointed to was updated";
epilog

end;</source>
    </JadeMethod>
</Class>
