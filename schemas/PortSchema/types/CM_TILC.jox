    <JadeMethod name="getCargoBreakdown" id="e69440ac-2faf-4ac0-b1ac-9a5a5d85c57f">
        <source>getCargoBreakdown() : String;
/*
Purpose:			

Date		Who		Reason
01 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tmpStr, subType : String;
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
			subType := ti.getCargoSubTypeCode();
			
			/*
			if tmpStr = null then
				tmpStr := subType;
			elseif tmpStr.pos(subType, 1) = 0 then
				tmpStr := tmpStr &amp; ', ' &amp; subType;
			endif;
			*/
			
			tmpStr.addStringToList(subType, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				subType := ti.getDisplayStringForAttribute( ETRow_CargoOnboard, true );
				if subType &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; subType;
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
