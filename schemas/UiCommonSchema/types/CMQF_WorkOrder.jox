<Class name="CMQF_WorkOrder">
    <JadeMethod name="setFromAgent" id="787a3236-13dd-4b2e-8bcc-f8b81094e171">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
*/
vars

begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_WorkOrderId) then
		self.workOrderId := _agent.getValueByName(ETRow_WorkOrderId).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_RequiredByDateFrom) then
		self.fromReqDT := _agent.getValueByName(ETRow_RequiredByDateFrom).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_RequiredByDateTo) then
		self.toReqDT := _agent.getValueByName(ETRow_RequiredByDateTo).Date;
	endif;
	
	self.allWOStatus.clear;
	if _agent.isRowIncluded(ETRow_WorkOrderStatus) then
		_agent.getSelectedWOStatus(self.allWOStatus);
	endif;
	
	self.allWODetailTypes.clear;
	if _agent.isRowIncluded(ETRow_WorkOrderType) then
		_agent.getSelectedWOType(self.allWODetailTypes);
	endif;
	
	self.allUsers.clear;
	if _agent.isRowIncluded(ETRow_AllUsers) then
		_agent.getSelectedUsers(self.allUsers);
	endif;
	
end;


</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
