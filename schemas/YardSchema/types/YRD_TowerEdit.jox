    <JadeMethod name="btnClose_click" id="1e7ecb63-7539-4508-a69c-68a4ada3a677">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theReturn : Integer;
begin
	if self.tblContainer1.hasChanged then
		theReturn := app.msgBox("You have changed data on the First container data entry table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_No then
			return;
		endif;
	endif;
	if self.tblContainer2.hasChanged then
		theReturn := app.msgBox("You have changed data on the Second container data entry table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_No then
			return;
		endif;
	endif;
	if self.tblTowerDetails.hasChanged then
		theReturn := app.msgBox("You have changed data on the Tower details data entry table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_No then
			return;
		endif;
	endif;

	self.unloadForm();

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
