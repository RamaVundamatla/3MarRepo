    <JadeMethod name="getNewDepartureTS" id="8e2a2d80-f860-4f26-b962-6cbf70fea14c">
        <source>getNewDepartureTS() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlger1	Initial creation

*/

vars
	lengthOfTime : Decimal[16,4];
	newDepartureTS : TimeStamp;
begin
	lengthOfTime:=self.getCurrentLengthOfTime;
	newDepartureTS:=null;
	if lengthOfTime &gt; 0 then
		// set the ETMAL tfs 41310 18/10/18
		//arrival time  + new Departure = shift occurs on  + workOrder lenght of Time
		if self.berthArrival.date.isValid then	//26 Oct 2018	NDL	TFS 41413
			newDepartureTS:=  self.berthArrival.addDecimalDays(lengthOfTime);
		else
			newDepartureTS:= self.getOccursDT().addDecimalDays(lengthOfTime);
		endif;
				
	elseif self.berthArrival.date.isValid then
		newDepartureTS:=self.berthArrival;
	endif;
	
	return newDepartureTS;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
