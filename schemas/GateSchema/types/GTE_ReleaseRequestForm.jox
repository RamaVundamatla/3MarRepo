    <JadeMethod name="doQueueMoves" id="220ba690-e8b9-4bcc-9f6d-1cff5427a15a">
        <source>doQueueMoves();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2014	cnwndl1	Initial creation

*/

vars

	br : CM_BulkRelease;
	tiArray : CM_TIArray;
	
begin

	if self.tblData.allSelectedObjects.isEmpty then
		app.msgBox("Nothing Selected", app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	elseif self.tblData.allSelectedObjects.size = 1 then
		br := self.tblData.allSelectedObjects.first.CM_BulkRelease;
	else
		app.msgBox("Only available for individual releases", app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if br.releaseByType then
		//release by type
		self.myAssistant.showQueueDirectorMovesFor( br );
		
	else
		//release by id
		create tiArray transient;
		br.allTrackedItemsAssigned.copy(tiArray);
		if tiArray.isEmpty then
			app.msgBox("Selected Release 'by ID' has no assigned Cargo", app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		self.myAssistant.showMoveItForm( tiArray, QUEUE_MODE );
		
	endif;

epilog
	
	delete tiArray;
end;</source>
    </JadeMethod>
