    <JadeMethod name="btnDeleteAll_click" id="6804eb88-ca32-4840-9a81-34c74a6bcdce">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteAll_click(btn: Button input) updating;

vars
	intReturn : Integer;
	queueItem : CnEcIspecToHost;

begin
	intReturn := app.msgBox ( ("You  want to delete  ALL queued items? "), "Delete Confirmation" , MsgBox_OK_Cancel);

	if intReturn = MsgBox_Return_Cancel	 then 
		abortTransaction;
		return;
	endif;	

	beginTransaction;
		foreach queueItem in myLincSystemDef.allIspecsToHost do
			delete queueItem;
		endforeach; 
  	commitTransaction;

	// Refresh the table contents
	initQueueTable();
	updateQueueTable();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="b6cd06ae-cda8-4abe-851d-cc8277787cb5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;

vars
    selRow 		: Integer;
	selColumn	: Integer;
    countRow	: Integer;

    queueItem 	: CnEcIspecToHost;

begin
	// Handle database enquiry exceptions
	on SystemException do deleteExceptionHandler(exception);
	on LockException   do deleteExceptionHandler(exception);

	// Do nothing if a row isn't selected, or the header row is selected
	if ( tableQueueItems.selected = false or tableQueueItems.row = 1 ) then
		return;
	endif;

	beginTransaction;


		if app.isValidObject(tableQueueItems.itemObject) then
			delete tableQueueItems.itemObject;
		endif;

	commitTransaction;

	// Refresh the table contents
	initQueueTable();
	updateQueueTable();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
