    <JadeMethod name="setupForm" id="ed96d8b2-9179-4e4c-b679-603c11143c1b">
        <updating/>
        <source>setupForm() updating;

// Created by cnwdvb1 on 01 May 2006

vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	

	//self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_AutoPlannedDischarge));
	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_ShipOperations));
	self.tblData.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblData.autoSize := Table.AutoSize_Column;
	
	self.caption := self.caption &amp; "  Voyage: " &amp; self.myVoyage.code;

	// Want to keep the table in the job sheet order.
	//self.tblData.disallowColumnSorter := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAutoDetail" id="14da5518-467f-4742-84b0-8cd9f1131c69">
        <source>showAutoDetail() protected;

// Created by cnwdvb1 on 02 May 2006

vars

	wle 	: CM_WorkListEntry;
	ti		: CM_TrackedItem;

begin

	// This method shows transactions or alerts depending on what is appropriate.
	
	wle := self.tblData.accessRow(self.tblData.row).itemObject.CM_WorkListEntry;
	
	if wle = null then
		return;
	endif;
	
	ti := wle.myTrackedItem;
	
	if ti = null then
		return;
	endif;	
	
	if wle.isQueued() or wle.myFutureMove &lt;&gt; null or wle.status = WLE_COMPLETED then
		self.myAssistant.showCargoTransactionsForm(ti, self.myMasterMenuAction);
		return;
	endif;
	
	if ti.mySystemAlerts.isEmpty() then
		return;
	endif;

	self.allAlertsArray.clear();	
	ti.mySystemAlerts.copy(self.allAlertsArray);
	
	app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, self.allAlertsArray);
	
	return;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="0b299042-5db4-4ba5-a124-9552981d5114">
        <source>showColumnOrganiser();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	// Update the navigator
	self.setNavigatorHeading('Column Organizer'); 
	self.tblData.showColumnOrganiserFrm(self.myTerminal, null);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblDataChange" id="fe02cc57-f78e-44b9-9f6e-18ebe2a7924e">
        <updating/>
        <source>tblDataChange(_table : CM_DataTable input; _newRow : Integer) updating, protected;

vars
	obj : CM_Object;
	rtCol : Integer;
begin
	if _newRow &lt;= _table.fixedRows then
		return;
	endif;

	obj := _table.accessRow(_newRow).itemObject.CM_Object;
	
	if not global.isValidObject(obj) then
		return;
	endif;
	
	
	self.displayExtraInfoForObj(obj);

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="c990d026-6a27-4323-b30d-07f315924584">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

// Created by cnwdvb1 on 02 May 2006

vars

	xLeft 	: Real;
	yTop	: Real;
	
begin

	xLeft := x;
	yTop := y;

	self.mnuInspectObj.visible := app.isAllowedToInspect();
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuContextTbl, xLeft.Integer, yTop.Integer);

	return false;

	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="03a9b953-5125-4aaa-aff6-e99bd023f180">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: CM_DataTable input) updating;

// Created by cnwdvb1 on 02 May 2006

vars

begin

	if table.row = table.fixedRows then
		table.resortTableByColumn(table.column);
	else
		self.showAutoDetail();
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="3224d450-c459-4d6c-a5cf-22bfff1dfbac">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;

// Created by cnwdvb1 on 02 May 2006

vars

begin

