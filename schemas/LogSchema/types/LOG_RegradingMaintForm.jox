    <JadeMethod name="translateForm" id="dfa5c2a3-ebb0-49e0-b77d-1df37311a6fb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006334, locale);
	btnFind.translateBubbleHelp(Xlat_0002432, locale);
	btnFind.translateCaption(Xlat_0002433, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForSave" id="0cde036b-3cba-49bf-89fc-000473c46855">
        <source>validateForSave(_logRegrade: CMIF_LogRegrade; _passport : CM_Passport io) protected;
/* ---------------------------------------------------------------------------
Created:	09 December 2009	by cnwvu1

Purpose:	PAR 21688
			There are some errors in GUI phase, not in trx level. It is because we need to manage 
			some required fields before trx starts eihter in GUI or BGP mode.
			In this case, errors are populated in self.allErrorsWarnings and the ErrorsWarning dialog to be displayed later.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin

	// when ID entered and no tabbing done (or log not found). PAR 21688 Dec 2009
	if self.selection = LOGID then
	
		if self.myLog = null then
			app.addErrorFullPassport(LogNotFound, app.getErrorString1(LogNotFound,null), null, null, _passport);
			return;
		endif;
		
		if self.myLog.id &lt;&gt; self.tblSelection.getValueByName(ETRow_LogId).String then
			//app.msgBox("Please refresh log details data", null, MsgBox_OK_Only + MsgBox_Information_Icon);
			app.addErrorFullPassport(RefreshLogdata, app.getErrorString(RefreshLogdata), null, null, _passport);
		endif;
		
		// an average sclaed log is not editable. PAR 21688 Dec 2009
		if self.selection = LOGID and self.myLog.isAverageScaled then	// perform check only at log level. PAR 21688
			app.addErrorFullPassport(AverageScaledLogNotEditable, app.getErrorString1(AverageScaledLogNotEditable, self.myLog.CM_Log.id), null, null, _passport);
		endif;
		
	endif;
	
	
	if _logRegrade.myOperator = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, self.terminologyForOperatorLog), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_Required, app.getErrorString1(Input_required_field_Required, self.terminologyForOperatorLog), null, null, app.myPassport);
	elseif _logRegrade.species = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, "Species"/*app.getErrorString(CM_Species)*/), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_specisFld, app.getErrorString(Input_required_field_specisFld), null, null, app.myPassport); // cnwdb2	PAR 35364

	elseif	_logRegrade.gradeCode = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, "Grade"), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_grade, app.getErrorString(Input_required_field_grade), null, null, app.myPassport);
		
	elseif	_logRegrade.length = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, "Length"), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field, app.getErrorString(Input_required_field), null, null, app.myPassport);

	elseif _logRegrade.myRegradeCode = null then
	//	app.addErrorFullPassport(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, "Regrade Reason"), null, null, app.myPassport);
		app.addErrorFullPassport(Input_required_field_regrdeRen, app.getErrorString(Input_required_field_regrdeRen), null, null, app.myPassport);
		
		
		
	endif;
	
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_logRegrade" type="CMIF_LogRegrade"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
    </JadeMethod>
</GUIClass>
