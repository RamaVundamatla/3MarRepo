 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating event map (' &amp; _mapName &amp; '), row ' &amp; rowCount.String);
 			return false;
 		endif;
		createCount := createCount + 1;
	endif;
	
	_eventMap := eventMap;
	return true;
epilog
	delete proxyMap;
end;</source>
