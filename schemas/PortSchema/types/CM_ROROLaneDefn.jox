    <JadeMethod name="cloneMySelf" id="b49a615c-d600-4245-9a4e-b5532431aeba">
        <source>cloneMySelf(_newLayer : CM_DeckLayerLayout; _copy : Boolean; _nextOrd : Boolean) : CM_ROROLaneDefn;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : SelfType;
	ord : Integer;
	deck : CM_Deck;
begin
	deck:= _newLayer.myDeckLayout.myDeck;

	if deck.isKindOf(CM_DeckVessel) then
		newMe := self.cloneSelf(_copy);
	elseif deck.isKindOf(CM_DeckVoyage) then
		newMe := self.cloneSelfAs(CM_ROROLaneDefnVoyage,_copy).CM_ROROLaneDefnVoyage;
	endif;

	// PAR 27528 
	// TEMP CODE &amp; ORDINAL
	if  _nextOrd then
		ord := _newLayer.myDeckLayout.myDeck.allROROLaneDefnByOrdinal.size;
		while true do : ordLoop
			ord := ord + 1;
			if _newLayer.myDeckLayout.myDeck.allROROLaneDefnByCode[ord.String] = null then
				newMe.ordinal := ord;
				newMe.setCode( ord.String, false );
				break ordLoop;
			endif;
		endwhile;
	endif;

	newMe.myDeckLayerLayout := _newLayer;
	newMe.myDeck :=deck;
	newMe.myLayout := self.myLayout.cloneMySelf(newMe, _newLayer, _copy);
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_nextOrd" type="Boolean"/>
        <ReturnType type="CM_ROROLaneDefn"/>
    </JadeMethod>
    <JadeMethod name="getItemLength" id="aa59b8fa-9f45-4b41-b52d-bfc484dc5344">
        <source>getItemLength(_ti : CM_TrackedItem): Decimal;
/*
Purpose:			
Date		Who		Reason
30 November 2011	cnwab1	Initial creation
*/

vars
	lengthMetres : Decimal[12,2];
begin
	if _ti = null then
		return inheritMethod(_ti);
	endif;
	
	lengthMetres := _ti.getLengthInMetres();
	
	if lengthMetres &lt;= 0 then
		return 12; // metres
	endif;

	return lengthMetres;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
