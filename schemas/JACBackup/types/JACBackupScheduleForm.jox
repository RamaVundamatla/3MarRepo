    <JadeMethod name="doBackupOrAbort" id="433e7253-bd2a-405f-88a2-7a66a31a8290">
        <source>doBackupOrAbort();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
begin
	sched := app.myServerAppObject.jacBackupScheduleObjects.getAtKeyGeq(JACBackupRunning, null);
	if sched = null or 
	   sched.status &lt;&gt; JACBackupRunning then
		sched := app.myServerAppObject.jacBackupScheduleObjects.getAtKeyGeq(JACBackupScheduled, null);
		if sched = null then
			self.statusLine.caption := "Unable to find a schedule to do backup.";		
		else
			beginTransaction;
			sched.setStatus(JACBackupActivated);
			sched.setActualStartTS(app.actualTimeServer);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			commitTransaction;
			if app.isSDSSecondaryBackup then
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyBackupControlApp='&amp;NotifyBackupControlApp.String, LogDebug);
				beginTransaction;
				app.myServerAppObject.sdsCauseEvent(NotifyBackupControlApp, false, sched);
				commitTransaction;
				app.myDBA.closeCurrentJournal();
			else
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupControlApp='&amp;NotifyBackupControlApp.String, LogDebug);
				app.myServerAppObject.causeEvent(NotifyBackupControlApp, true, sched);
			endif;
		endif;
	else
		app.myServerAppObject.doAbortBackup;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoad" id="bba55cd5-1f97-44a5-b862-dee5852bef25">
