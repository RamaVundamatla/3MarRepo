    <JadeMethod name="comboTerminals_closeup" id="d981f8a4-1818-4867-8be2-3891f64b2419">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>comboTerminals_closeup(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwns1	Initial creation

*/

vars
	terminal : CM_Terminal;
	shortID : String;
	timeZone : CMIF_TimeZoneInfo;
	foundTZ : Boolean;
	timeZones : CMIF_TimeZoneInfoArray;
	terminalTimeString : String;
	ind : Integer;
	adj : TimeStampInterval;
begin
	if comboTerminals.myObject = null then
		return;
	endif;
	ind := 3;
	terminal := comboTerminals.myObject.CM_Terminal;

	if terminal.timeZoneShortID &lt;&gt; "" then
		shortID := terminal.timeZoneShortID;
	else
		shortID := "&lt;null&gt;";
	endif;
	
	if app.actualTimeServer = 	terminal.systemToLocalTime(app.actualTimeServer ) then
		terminalTimeString := "Server time";
	elseif	app.actualTimeServer &lt; 	terminal.systemToLocalTime(app.actualTimeServer )then

		terminalTimeString :=	"Server time + " &amp;	(terminal.systemToLocalTime(app.actualTimeServer ) - app.actualTimeServer).asStringJMT;
	else
	
		terminalTimeString :=	"Server time - " &amp;	(app.actualTimeServer - 	terminal.systemToLocalTime(app.actualTimeServer )).asStringJMT;
	
	endif;
	
	labelTermTZ.caption :=  "Term Code "  &amp; terminal.code &amp; CrLf &amp;
							"TZ ID           " &amp; terminal.timeZoneID &amp; CrLf &amp;
							"TZ Short     "  &amp; shortID &amp; CrLf &amp;
							terminalTimeString;
	
	textBoxTZshort.text := terminal.timeZoneShortID;
	
	self.setSelectedTZ(terminal);

epilog
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboTerminals_displayEntry" id="77857f91-81f9-46af-8c41-19a14bd35d50">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
