<Class name="CM_CamSuzanoDesc" id="d6bf0f2a-7492-451f-9a3e-c3ecf7727444">
    <superclass name="CM_CamProtocolDesc"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cams"/>
    <JadeMethod name="addMessage" id="22093977-0cb9-4f59-be02-a0012062c846">
        <source>addMessage( _anArray : HugeStringArray input; _aString : String);
/*
Purpose: processTransaction methods use this to add 
         the xml message into the Cam Message for later output
         The key thing is this version doesn't add any special characters 
Parameters:This uses no object data - could go anywhere			
Return Value:		
Date		Who		Reason
18 Jul 2014 cnwgb1	Initial creation (copied from X12_322) PAR 34561 CCMS 2346
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//02 Jun 2015	cnwrs1	Par 36365 - Change to support strings longer than 512 bytes
vars
	msgLength :Integer;	
	theString : String;
begin

	theString := _aString;
	msgLength := theString.length;
	
	while msgLength &gt; 2047 do
		_anArray.add(theString[1:2047]);	
		theString := theString[2048:msgLength];
		msgLength := theString.length;
	endwhile;
	
	_anArray.add(theString);
	
	
epilog
end;</source>
        <Parameter name="_anArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_aString" type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="ecf6af64-817c-49eb-ba1a-e2c2304b368e">
