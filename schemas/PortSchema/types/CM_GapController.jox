    <JadeMethod name="getSpannedToLCs" id="a28830f7-bd9f-4c39-884b-7e2cc1921d02">
        <source>getSpannedToLCs(control: CMIF_MoveController input): Boolean;
/*
 ------------------------------------------------------------------------
Created:			28 February 2002 by cnwdwq1
Purpose:			We are a gap, return false
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	control.setMyToSecondaryLocations(null);
	return false;
end;</source>
