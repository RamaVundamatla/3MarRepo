    <JadeMethod name="removeDummyListEntry" id="ebf24468-3078-4bf4-94e6-5946bb34264b">
        <updating/>
        <source>removeDummyListEntry() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	
begin
	idx := lstSavedDisplays.findObject( self.myProxyXTAB );
	if idx &gt; 0 then
		lstSavedDisplays.removeItem( idx );
	endif;
	
epilog
	self.zSetControls;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetButtonValues" id="840db1ff-73be-4b63-97aa-7a6dbc1d91b3">
        <source>resetButtonValues(_coll :ObjectArray; _btn :Button)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	:Object;
begin
	foreach obj in _coll do 
		if obj = _btn then
			continue;
		endif;
		obj.Button.value 	:= false;
		obj.Button.foreColor:= Black;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_btn" type="Button"/>
    </JadeMethod>
    <JadeMethod name="saveDefn" id="87d484c6-6712-487a-9de0-036878dbd629">
        <updating/>
        <source>saveDefn() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	
begin
	app.mousePointer	:= Busy;

	
	if not self.doSaveXTAB() then
		// must have had errors during save
		return false;
	endif;
	
	self.zClearProxyDetails();
	self.zSetControls;
	self.clearErrorWarnings();
	
	if self.formMode = Mode_Add then
		// remove dummy entry from list
		self.removeDummyListEntry;
	endif;
	
	// refresh list and select the appropriate object (caters especially for renaming etc).
	self.loadSavedDisplays;
	lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );
	self.displayXTABDefinition( self.myCurrentXTAB );
	// now setup this definiton in update mode
	self.doLstSavedDisplays();
	
	return true;
	
epilog
	app.mousePointer	:= Idle;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtonProperties" id="a3bbd9d6-ea8e-4ea3-a237-4198aac31f39">
        <source>setButtonProperties(_btn :Button input)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _btn - new button being cloned
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwcs5		do not use skins for tab/row/col/cell work area
// ---------------------------------------------------------------------------
vars

begin
	_btn.ignoreSkin	:= true;					// cnwcs5 16/12/2009
	_btn.width 		:= self.btnField.width;		// cnwcs5 16/12/2009
	_btn.height		:= self.btnField.height;	// cnwcs5 16/12/2009
	_btn.style		:= Button.Style_2State;
	_btn.tabStop	:= false;
	_btn.fontBold	:= false;
	_btn.value		:= false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
