	self.allQueryProperties.add(tmpProp);
	
	//is 53
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is 53', CM_CashPayment::getTrackedItemIs53.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//is direct delivery
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Direct Delivery', CM_CashPayment::getTrackedItemIsDD.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//is storage
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Invoice is Storage', CM_CashPayment::isStorage.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
