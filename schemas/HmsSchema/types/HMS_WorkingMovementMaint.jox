    <JadeMethod name="updateMovement" id="411d2855-a89c-49dc-909e-c98cd83e1c1b">
        <updating/>
        <source>updateMovement():Boolean updating, protected;

/*

Date		Who		Reason
19 Mar 2008	cnwkpd1	Corrected before/after error messages to include date/time information.
24/01/2014	cnwdap1	PAR #33337 CCMS PTR 2214 HMS Enhancements			
// 10/12/2014  cnwdb2	PAR 35364
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
17 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
05 Oct 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

*/

vars
	raiseWarningMsg		: Boolean;
	moveDTChanged		: Boolean;
	nextMove			: CMIF_HMS_WorkingMovement;
	clonedMovement		: CMIF_HMS_WorkingMovement;
	newWorkingMove		: CMIF_HMS_WorkingMovement;
	prevMoveObj			: CMIF_HMS_WorkingMovement;
	newTime				: TimeStamp;
	harbour				: HMS_Harbour;
	departureTime		: TimeStamp;
	//allPilots 			: HMS_PilotByCodeDict;	//30 Oct 2018	NDL	TFS 41662 // TFS 44438
begin
 	// Set harbour and terminal references
 	harbour	:=	self.myTerminal.myHarbour;
	
 	if harbour = null then
 		return false;
 	endif;
	
	if self.aMySelectedMovement = null then
		return false;
	endif;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	// Set cloneHasChanged property to true
	self.aMySelectedMovement.cloneHasChanged := true;
	
	// Update 'To Berth'
	self.aMySelectedMovement.myBerth := self.myCmbBerthTo.listObject.HMS_Berth;

	if self.aMySelectedMovement.myBerth = null then
		app.raiseCMException(Input_required_field_toBerth, null, null); // cnwdb2	PAR 35364
		app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_Add);
		self.setAllErrorWarnings(app.myPassport);
		return false;
	endif;
	
	prevMoveObj	:=	self.aMySelectedMovement.getMovementPrevious();

	// Set move type
	self.aMySelectedMovement.moveType := self.txtMoveType.text;
	
	// Set movement date/time
	//newTime := (self.txtMoveOnDate.text &amp; "," &amp; self.txtMoveOnTime.text).TimeStamp;
	newTime.setDate(self.myTxtMoveOnDate.getDate());
	newTime.setTime(self.myTxtMoveOnTime.getTime());
	
	self.aMySelectedMovement.remarks := self.txtRemarks.text.trimBlanks;			// PAR #33337
	
	if newTime.isValid then
		if newTime &lt;&gt; self.aMySelectedMovement.occursOnDT then
			// move Date/Time has changed
			moveDTChanged := true;
			self.aMySelectedMovement.occursOnDT := newTime;
		endif;
	endif;

 	// Validate movement date/time
 	if self.aMySelectedMovement.moveType &lt;&gt; HMSMovementTypeDeparture then

		nextMove := self.aMySelectedMovement.getMovementNext();
		
		if nextMove = null then
		 	if self.aMySelectedMovement.moveType = HMSMovementTypeArrival then
		 		// Arrival Movement - must occur before all other movements
		       	// Error - arrival movement must occur before all other movements
				app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeArrival, 'before', null, null);
		 	
		 	elseif self.aMySelectedMovement.moveType = HMSMovementTypeShift then
				// Error - The shift movement cannot occur after the departure movement
//				app.raiseCMException2(HMSMovementShiftDT, 'before' , 'Departure', null, null);													// PAR #16176
				departureTime := null;
				if self.aMySelectedMovement.myClonedVoyage &lt;&gt; null then
					departureTime := self.aMySelectedMovement.myClonedVoyage.departedDT ;
				endif;
				app.raiseCMException3(HMSMovementShiftDT, 'before', HMSMovementTypeDeparture, departureTime.asStringJMT, null, null);			// PAR #16176
			endif;
		else
			//Shift can't be before and Arrival
			//Error - Shift can't occur before an Arrival.
			if self.aMySelectedMovement.moveType = HMSMovementTypeShift then
				if nextMove.moveType = HMSMovementTypeArrival then
//					app.raiseCMException2(HMSMovementShiftDT, 'after', HMSMovementTypeArrival,  null, null);									// PAR #16176
					app.raiseCMException3(HMSMovementShiftDT, 'after', HMSMovementTypeArrival, nextMove.occursOnDT.asStringJMT, null, null);	// PAR #16176
				endif;
			endif;
		endif;
		if app.myPassport.hasErrors() then
			app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;

	if self.aMySelectedMovement.moveType = HMSMovementTypeShift then
		// skip this bit
	else
		// if is an arrival or departure, update arrival and departure DT on voyage
		if self.aMySelectedMovement.moveType = HMSMovementTypeArrival then
			self.aMySelectedMovement.myClonedVoyage.arrivedDT := self.aMySelectedMovement.occursOnDT;
		
		elseif self.aMySelectedMovement.moveType = HMSMovementTypeDeparture then
			self.aMySelectedMovement.myClonedVoyage.departedDT := self.aMySelectedMovement.occursOnDT;
		endif;
		// check for same ship in port
		if (not self.aMySelectedMovement.myClonedVoyage.checkForSameShipInPort(self.aMySelectedMovement.myClonedVoyage.arrivedDT, self.aMySelectedMovement.myClonedVoyage.departedDT)) then
			app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	
	// START 16 Sep 2022	navsj20	TFS 54739
	self.aMySelectedMovement.setMyBollards(self.cmbBowMarkBollard.listObject.HMS_Resource, self.cmbSternMarkBollard.listObject.HMS_Resource, self.cmbBridgeMarkBollard.listObject.HMS_Resource);
	self.aMySelectedMovement.bowToBollard	:= self.txtBowMarkMeter.text.asDecimalJMT();
	self.aMySelectedMovement.bridgeToBollard:= self.txtBridgeMarkMeter.text.asDecimalJMT();
	self.aMySelectedMovement.sternToBollard	:= self.txtSternMarkMeter.text.asDecimalJMT();
	// END 16 Sep 2022	navsj20	TFS 54739
	
	self.aMySelectedMovement.clonedMove_SetActOrPlanAsReqd(self.aMySelectedMovement.occursOnDT);
	//self.aMySelectedMovement.vesselDraft	:=	txtGDraft.cnEcDecimal();
	//par 16295 cnwjo3
	//self.aMySelectedMovement.vesselDraft	:=	txtGDraft.text.asDecimalJMT();
	self.aMySelectedMovement.numLineCrewRequired := self.txtLineCrewReqd.text.Integer;
	self.aMySelectedMovement.pilotExempt := self.chkPilotExempt.value;
	self.aMySelectedMovement.chargeForMove := (not self.chkChargeMove.value);
	self.aMySelectedMovement.shipsMaster := self.txtShipsMaster.text;

    //self.aMySelectedMovement.draftAft := self.txtDraftAft.text.Decimal; 	//4.1.1 Draft enhancements
    //self.aMySelectedMovement.draftFwd := self.txtDraftFwd.text.Decimal; 	//4.1.1 Draft enhancements
    self.aMySelectedMovement.draftAft := self.txtDraftAft.text.asDecimalJMT(); 	//par 16295
    self.aMySelectedMovement.draftFwd := self.txtDraftFwd.text.asDecimalJMT();	//par 16295

	
    // Update Fore &amp; Aft 'From Berth' Clearances
	if txtAftClearFrom.text = app.getErrorString(Unlimited) then
		self.aMySelectedMovement.aftClearanceFrom := ClearanceUnbounded;
	else
		self.aMySelectedMovement.aftClearanceFrom := self.txtAftClearFrom.text.Integer;
	endif;
	if self.txtForeClearFrom.text = app.getErrorString(Unlimited) then
		self.aMySelectedMovement.foreClearanceFrom := ClearanceUnbounded;
	else
		self.aMySelectedMovement.foreClearanceFrom := self.txtForeClearFrom.text.Integer;
	endif;

    // Update bow,stern marks and fore &amp; aft clearaneces for the 'to berth'
	if (not self.aMySelectedMovement.isLogicalBerth()) then
		self.aMySelectedMovement.aftClearanceTo := self.aLastValidAftClearance; //tbxAftClearTo.text.Integer;
		self.aMySelectedMovement.foreClearanceTo := self.aLastValidForeClearance; //tbxForeClearTo.text.Integer;
		//self.aMySelectedMovement.bowMarkTo := self.txtBowMarkTo.text.Decimal;
		//self.aMySelectedMovement.sternMarkTo := self.txtSternMarkTo.text.Decimal;
		self.aMySelectedMovement.bowMarkTo := self.txtBowMarkTo.text.asDecimalJMT(); 	//par 16295
		self.aMySelectedMovement.sternMarkTo := self.txtSternMarkTo.text.asDecimalJMT(); 	//par 16295

	endif;

	// Update Work Order Times
	self.aMySelectedMovement.relativeOrderTimeLines := self.txtLineRelative.text.Integer;
	self.aMySelectedMovement.relativeOrderTimePlaunch := self.txtLaunchRel.text.Integer;
	self.aMySelectedMovement.relativeOrderTimeTugs := self.txtTugRelative.text.Integer;

	// Update 'side to'
	if self.cmbOrientTo.listIndex &gt; 0 then
		if self.cmbOrientTo.itemText[cmbOrientTo.listIndex] = app.getErrorString(PortSideTo) then
			self.aMySelectedMovement.sideTo := OrientPortSideTo;
		else
	 		self.aMySelectedMovement.sideTo := OrientStarboardSideTo;
 		endif;
 	endif;
 	
 	// Update Master
	self.aMySelectedMovement.myMaster := self.cmbMaster.listObject.HMS_Master;

 	// Update Pilot
//	self.aMySelectedMovement.myPilot := self.cmbPilot.listObject.HMS_Pilot;
	//30 Oct 2018	NDL	TFS 41662
	/*create allPilots transient; // --&gt; TFS 44438
	self.lstPilots.allSelectedObjects.copy(allPilots);
	self.aMySelectedMovement.allPilots.clear();
	if not allPilots.isEmpty then
		allPilots.copy( self.aMySelectedMovement.allPilots );
	endif;*/ // --&gt; TFS 44438

 	// Update PilotLaunch
	//self.aMySelectedMovement.myPilotLaunch := self.cmbPilotLaunch.listObject.HMS_PilotLaunch; // TFS 44438

 	// Update LineCompany
	self.aMySelectedMovement.myLineCompany := self.cmbLineCo.listObject.HMS_LineCompany;

 	// Update LocationPilotLaunch
	if cmbLaunchPosn.listIndex&gt;0 then
		self.aMySelectedMovement.locationPilotLaunch := self.cmbLaunchPosn.listIndex;
 	endif;
 	// Update TugLaunch
	if cmbTugPosn.listIndex&gt;0 then
		self.aMySelectedMovement.locationTug:=cmbTugPosn.listIndex;
 	endif;

	//update allTugsUsed
	self.aMySelectedMovement.allTugsUsed.clear;
	self.lstTugsReq.allSelectedObjects.copy( self.aMySelectedMovement.allTugsUsed );
	
 	// Update agent 
 	if self.optAgent.value then
 		if self.cmbShippingAgent.listIndex &gt; 0 then
 			self.aMySelectedMovement.myShippingAgent := self.cmbShippingAgent.listObject.CM_ShippingAgent;
 			self.aMySelectedMovement.isAgentDefault := true;
 		else
 			self.aMySelectedMovement.myShippingAgent := null;
 			self.aMySelectedMovement.isAgentDefault := false;
 		endif;
 	else
 		self.aMySelectedMovement.isAgentDefault := false;
 	endif;

 	// Update shippingline
 	self.aMySelectedMovement.myShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine;

 	// Update contact
	self.aMySelectedMovement.myContact := self.cmbContact.listObject.CM_EmailAddress2;

	// Update movement tidal class
	self.aMySelectedMovement.myMoveTidalClass := self.cmbMoveTidalClas.listObject.HMS_TidalClass;

	raiseWarningMsg := self.aMySelectedMovement.raiseClearanceWarnings();
	
	if (not self.aMySelectedMovement.check_Clearances(false, raiseWarningMsg)) then
		return false;
	endif;
	
	// Update resources used
  	self.updateResourcesUsed();
	self.aMySelectedMovement.validateResourcesUsed(app.myPassport);
	
	self.updateMvmntPilotDetails(); // TFS 44438
	self.aMySelectedMovement.validateMvmntPilotDetails(app.myPassport); // TFS 44438
	
	if app.myPassport.hasErrorsOrWarnings then
		if app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
	endif;	
	
	self.clearErrorWarnings();

 	if raiseWarningMsg then
		//Within the validation period
	 	self.aMySelectedMovement.validateMovement();
	else
		//Don't validate movements occuring after warning period
	endif;

	if app.myPassport.hasErrorsOrWarnings() then
		if app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	
	self.clearErrorWarnings();
	// disarm the validation ex handler	
	on CM_Exception do null;

	// Update views following the result of the validation
	// Adjust next movement if needed
	self.updateNextMovement();

	self.aHasSavedChanges := true;
	newWorkingMove := self.aMySelectedMovement.createWorkingMovement(null, false, false, false);
	// Delete clonedVoyage, resources and movements
	
	foreach clonedMovement in self.aMySelectedVoyage.allClonedMovements do
		clonedMovement.allWorkingResUsed.purge();
		clonedMovement.allMovementPilotDetails.purge(); // TFS 44438
	endforeach;

	self.aMySelectedVoyage.allClonedMovements.purge();
	delete self.aMySelectedVoyage;

	self.aMySelectedMovement := newWorkingMove;
	self.aMySelectedVoyage := self.aMySelectedMovement.myWorkingVoyage;
	
	self.aHasSavedChanges := true;
	self.aMyViewController.view_BuildEntireForeground();

	return true;
	
epilog

	//delete allPilots; // TFS 44438
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMvmntPilotDetails" id="13c30797-ccb0-49a0-9534-cba3e687420b">
        <source>updateMvmntPilotDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	rowIdx,
	row,
	numRows : Integer;
	tmpTable : CM_DataTable;
	tempMvmntPilotDetails : HMS_MovementPilotDetails;
	delMvmntPilotDetails : HMS_MovementPilotDetailsSet;
begin
	if self.aMySelectedMovement = null then
		return;
	endif;
	if (not self.shtMarineService.visible) then
		return;
	endif;
	tmpTable := self.tblPilotLaunch;
	row := tmpTable.fixedRows+1;
	numRows := tmpTable.rows;	
	
	foreach rowIdx in row to numRows do
		tempMvmntPilotDetails := tmpTable.accessRow(rowIdx).itemObject.HMS_MovementPilotDetails;
		tempMvmntPilotDetails.setMyPilot(tmpTable.accessCell(rowIdx, self.aColPilot).cellControl.CMUI_ComboBox.listObject.HMS_Pilot);
		tempMvmntPilotDetails.setMyPilotLaunch(tmpTable.accessCell(rowIdx, self.aColPilotLaunch).cellControl.CMUI_ComboBox.listObject.HMS_PilotLaunch);
	endforeach;
	
	create delMvmntPilotDetails transient;
	foreach tempMvmntPilotDetails in self.aMySelectedMovement.allMovementPilotDetails do
		rowIdx := 0;
		if not tmpTable.findObjectInRow(tempMvmntPilotDetails, rowIdx) then
			delMvmntPilotDetails.add(tempMvmntPilotDetails);
		endif;
	endforeach;
	
	delMvmntPilotDetails.purge;
epilog
	delete delMvmntPilotDetails;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateNextMovement" id="ad950aff-48d3-4f5c-a2dc-88aa5903b99d">
        <source>updateNextMovement() protected;
/*
This function updates the movement after the selected movement to ensure
that it reflects the revised nature of the selected movement with regard
to marine services
*/
vars
	nextMove, newWorkingMove : CMIF_HMS_WorkingMovement;
	vessel : CM_Vessel;
begin
	if aMySelectedMovement = null then
		return;
	endif;
	if aMySelectedMovement.moveType&lt;&gt;HMSMovementTypeDeparture then
		nextMove:=aMySelectedMovement.getMovementNext;

		if nextMove = null then
			return;
		endif;
		// Make sure that we are working with the clone
		if nextMove.myClonedMovement=null then
			nextMove:=nextMove.myClone;
		endif;

		//See if the next move requires marine services
		if aAddMode or aMyOriginalBerth.noMarineServices &lt;&gt; aMySelectedMovement.myBerth.noMarineServices then
			nextMove.checkAndSetInitialValues;
			/*
			  From non piloted to port =  arrival type
              From port to non piloted = departure type
              else shift
			*/        	
            if aMySelectedMovement.myBerth.noMarineServices = true and nextMove.myBerth.noMarineServices = false then
 			 	nextMove.updateForMoveType(HMSMovementTypeArrival);
			elseif aMySelectedMovement.myBerth.noMarineServices = false and nextMove.myBerth.noMarineServices = true then
			 	nextMove.updateForMoveType(HMSMovementTypeDeparture);
			else
 			 	nextMove.updateForMoveType(HMSMovementTypeShift);
			endif;
            //Make a new movement and update the parent of this clone
			newWorkingMove:=nextMove.createWorkingMovement(null,false,false, false);
			nextMove.myClonedMovement:=newWorkingMove;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateResourcesUsed" id="70ec39bb-96a8-448d-83dd-8bb84f48dc93">
        <updating/>
        <source>updateResourcesUsed()updating, protected;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.shtResources.visible then
		self.updateResourcesUsedFromTable();
	elseif self.shtWharfServices.visible then
		self.updateResourcesUsedFromList();		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateResourcesUsedFromList" id="2eeb598d-fa96-4712-b4f8-aba74342e8f6">
        <source>updateResourcesUsedFromList() protected;

vars
	tmpLstCount,
  	count:				Integer;
  	workResourceUsed,
  	workResUsed:		CMIF_HMS_ResourceUsed;
  	resource:			HMS_Resource;
  	resForDelColl:		CMIF_HMS_ResourceUsedSet;
  	posn:				Integer;
begin
	if self.aMySelectedMovement = null then
		return;
	endif;

	if self.shtWharfServices.visible = false then
		return;
	endif;
  				
  	// This method updates resources used on a movement
  	tmpLstCount := self.lstResourceList.listCount;  	
  	count := 1;
  	while count &lt;= tmpLstCount do
  		// Add selected resources to workingMovement.allWorkingResUsed
  		if lstResourceList.itemSelected[count]=true 
  		and HMS_Resource.hasInstance(lstResourceList.itemObject[count]) then
  			// Update collection of workingResourceUsed
  			resource := lstResourceList.itemObject[count].HMS_Resource;
  			// Check to see if workResourceUsed already exists
  			//workResourceUsed:=selectedMovement.allWorkingResUsed.getAtKey(resource.name);
  			// Reset workResourceUsed;
  			workResourceUsed:=null;
  			foreach workResUsed in aMySelectedMovement.allWorkingResUsed do
  				if workResUsed.myResource=resource then
  					workResourceUsed:=workResUsed;
  				endif;
  			endforeach;
  			if workResourceUsed&lt;&gt;null then
  				// this resource has already been included in the list of used resources for the movement
			else
  				// create a new resourceUsed object for this resource
  				create workResourceUsed transient;
  				workResourceUsed.myResource := resource;
  				workResourceUsed.myResourceType := resource.myResourceType;  				
  				workResourceUsed.myWorkingMovement := self.aMySelectedMovement;
  				workResourceUsed.notYetSaved := true;
			endif;
  		endif;
  		count:=count+1;
  	endwhile;

  	// Remove deselected resources
  	create resForDelColl transient;
  	foreach workResourceUsed in aMySelectedMovement.allWorkingResUsed do
  		// See if workResourceUsed is selected in current list
  		posn:=lstResourceList.findObject(workResourceUsed.myResource);
  		if posn&gt;0 then
  			if lstResourceList.itemSelected[posn]=false then
  				// Add workResourceUsed to delete collection
  				resForDelColl.add(workResourceUsed);
  			endif;
  		else
  			// Add workResourceUsed to delete collection
  			resForDelColl.add(workResourceUsed);
  		endif;
  	endforeach;
  	// Delete resourceUsed objects for resources that are no longer selected for use
  	resForDelColl.purge;


epilog
	delete resForDelColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateResourcesUsedFromTable" id="a589bb28-1940-4bc8-a906-248c66459818">
        <updating/>
        <source>updateResourcesUsedFromTable()updating, protected;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------
// 23/08/2017	jlgdap1		TFS 6633 STWO Correct date handling for mm/dd/yyyy date formats
// 04/10/2017	jlgdap1		TFS 7204 STWR Correct real handling for non-standard locales
// 11 Aug 2025	navhn30		MTN-35592: 14050 Error when adding Resources on the Movement Maintenance form in Harbour Management
vars
	rowIdx,
	row,
	numRows : Integer;
	tmpTable : CM_DataTable;
	workResourceUsed : CMIF_HMS_ResourceUsed;
  	resForDelColl :	CMIF_HMS_ResourceUsedSet;	
	dateStr : String;								// TFS 6633
	timeStr : String;								// TFS 6633
	timeStamp : TimeStamp;							// TFS 6633
begin
	if self.aMySelectedMovement = null then
		return;
	endif;

	if (not self.shtResources.visible) then
		return;
	endif;
	
	if (not app.myCurrentUserCan(self.myTerminal, Mod_Invoicing)) then
		return;
	endif;
	tmpTable := self.tblResources;

	row := tmpTable.fixedRows+1;
	numRows := tmpTable.rows;	
	
	foreach rowIdx in row to numRows do
		
		if tmpTable.accessRow(rowIdx).enabled then
			//Update 
			workResourceUsed := tmpTable.accessRow(rowIdx).itemObject.CMIF_HMS_ResourceUsed;
	 		if self.aColResource &lt;&gt; null then
				workResourceUsed.myResource := tmpTable.accessCell(rowIdx, self.aColResource).cellControl.CMUI_ComboBox.listObject.HMS_Resource;
			endif;
			if self.aColResourceType &lt;&gt; null then
				workResourceUsed.myResourceType := tmpTable.accessCell(rowIdx, self.aColResourceType).cellControl.CMUI_ComboBox.listObject.HMS_ResourceType;
			endif;
			//workResourceUsed.fromDateTime.setDate(tmpTable.accessCell(rowIdx, self.aColDateFrom).text.Date); //.cellControl.CMUI_DateMask.getDate());	// TFS 6633
			//workResourceUsed.fromDateTime.setTime(tmpTable.accessCell(rowIdx, self.aColTimeFrom).text.Time); //cellControl.CMUI_TimeMask.getTime());	// TFS 6633
			//workResourceUsed.toDateTime.setDate(tmpTable.accessCell(rowIdx, self.aColDateTo).text.Date); //.cellControl.CMUI_DateMask.getDate());		// TFS 6633
			//workResourceUsed.toDateTime.setTime(tmpTable.accessCell(rowIdx, self.aColTimeTo).text.Time); //cellControl.CMUI_TimeMask.getTime());		// TFS 6633
			dateStr := tmpTable.getCellValue(rowIdx,self.aColDateFrom);			//11.08.2025	navhn30 	MTN-35592
			timeStr := tmpTable.getCellValue(rowIdx, self.aColTimeFrom);		//11.08.2025	navhn30 	MTN-35592
			timeStamp.setDate(dateStr.asDateJMT);																										// TFS 6633
			timeStamp.setTime(timeStr.Time);																											// TFS 6633
			workResourceUsed.fromDateTime := timeStamp;																									// TFS 6633
			dateStr := tmpTable.getCellValue(rowIdx,self.aColDateTo);			//11.08.2025	navhn30 	MTN-35592
			timeStr := tmpTable.getCellValue(rowIdx, self.aColDateTo);			//11.08.2025	navhn30 	MTN-35592
			timeStamp.setDate(dateStr.asDateJMT);																										// TFS 6633
			timeStamp.setTime(timeStr.Time);																											// TFS 6633
			workResourceUsed.toDateTime := timeStamp;																									// TFS 6633
			if self.aColUnitsUsed &lt;&gt; null then		//11.08.2025	navhn30		MTN-35592
				workResourceUsed.unitsUsed := tmpTable.accessCell(rowIdx, self.aColUnitsUsed).cellControl.CMUI_TextBox.text.asRealJMT;		// TFS 7204
			endif;
			workResourceUsed.isCharged := tmpTable.getCellValue(rowIdx, self.aColCreateCharge) = '1';			//11.08.2025	navhn30 	MTN-35592
			workResourceUsed.isPartOfContract := tmpTable.getCellValue(rowIdx, self.aColPartOfContract) = '1';	//11.08.2025	navhn30 	MTN-35592

			workResourceUsed.notYetSaved := true; 				

		endif;
			
	endforeach;

  	// Remove deselected resources
  	create resForDelColl transient;
  	
  	foreach workResourceUsed in self.aMySelectedMovement.allWorkingResUsed do
		// ### We do not show teh marine services, so do not delete them CCMS 1350
 		if workResourceUsed.myResourceType &lt;&gt; null then
			if workResourceUsed.myResourceType.isMarineService then
				continue;
			endif;
		endif;
		
  		rowIdx := 0;
  		// See if workResourceUsed is selected in current list
  		if tmpTable.findObjectInRow(workResourceUsed, rowIdx) then
			//Still there
  		else
  			// workResourceUsed deleted, add to delete collection
  			resForDelColl.add(workResourceUsed);
  		endif;
  	endforeach;

  	// Delete resourceUsed objects for resources that are no longer selected for use
  	resForDelColl.purge;

epilog
	delete resForDelColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
