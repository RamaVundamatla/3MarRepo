    <JadeMethod name="setForCreate" id="e5c535a4-1b05-4ad2-921c-a4c62bac863c">
        <updating/>
        <source>setForCreate(pProxyInterTermVehicleJob : CM_InterTermVehicleJob) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 February 2010	conkc1	Initial creation
*/
vars

begin
	self.vehicleID := pProxyInterTermVehicleJob.vehicleID;
	self.state     := pProxyInterTermVehicleJob.state;
	self.driverID  := pProxyInterTermVehicleJob.driverID;
	self.myRoot    := app.myRoot;
epilog

end;</source>
