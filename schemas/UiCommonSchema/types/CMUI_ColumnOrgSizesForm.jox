    <JadeMethod name="displayMultiSelectAvailable" id="4713ca10-a697-492b-84ab-d0b86da3bce5">
        <source>displayMultiSelectAvailable(_obj : Object) : String protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
//call back method used by multi select sheet
vars
	entRowObj	: EntTableRow;
	rtnString	: String;
	
begin
	if self.myDataTable = null then
		return null;
	endif;
	
	if EntTableRow.hasInstance(_obj) then
		entRowObj := _obj.EntTableRow;
		
		rtnString	:=	entRowObj.getHeading(	self.myDataTable.myTerminologyCargoBOLType,
												self.myDataTable.myTerminologyTerminal,
												app.myCurrentLocale);
	endif;
	
	return rtnString;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
