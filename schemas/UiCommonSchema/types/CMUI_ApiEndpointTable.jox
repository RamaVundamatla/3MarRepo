    <JadeMethod name="change" id="aae12699-3344-4da0-b9d2-bae2fc770db0">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>change(table: Table input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023	navpw1	Initial creation TFS: 55215

*/

vars

begin
	inheritMethod(table);
	if self.parent.isKindOf(CM_EntryTable) then
		if self.parent.CM_EntryTable.accessCell(self.parent.CM_EntryTable.row, self.parent.CM_EntryTable.column).cellControl.isKindOf(self.class) then
			self.parent.CM_EntryTable.accessCell(self.parent.CM_EntryTable.row, self.parent.CM_EntryTable.column).text := self.accessCell(1, self.ColumnMethod).text &amp; Space &amp; self.accessCell(1, self.ColumnValue).text;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearRow" id="5aac9b60-66b7-40b1-8075-005600ae0f17">
        <updating/>
        <source>clearRow() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 July 2023	navcs2	Bug 58916: MTN - External Web Service API Endpoint issues

*/

vars
	cell : JadeTableCell;
	
begin
	cell := self.accessCell(1, self.ColumnMethod);
	if cell.cellControl &lt;&gt; null and cell.cellControl.isKindOf(ComboBox) then
		cell.comboIndex := 1;
	endif;
	
	cell := self.accessCell(1, self.ColumnValue);
	cell.text := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombo" id="359f06a5-5151-4977-9844-b3673b01e997">
        <updating/>
        <source>loadCombo() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023	navpw1	Initial creation TFS: 55215

*/

vars
	str 	: String;
begin
	str := Tab &amp; "POST" &amp; Tab &amp; "PUT" &amp; Tab &amp; "GET" &amp; Tab &amp; "DELETE";
	self.accessCell(1, self.ColumnMethod).comboList := str;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setValues" id="3169d31b-2143-45f8-85f0-43cac13b3acb">
        <updating/>
        <source>setValues(_value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2023	navpw1	Initial creation TFS: 55215
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
*/

vars
	spaceIdx	: Integer;
	methodType,
	path		: String;
	
begin
	//Example format below:
	//_value = POST&lt;Space&gt;RailReceival
	//methodType = POST
	//path = RailReceival
	//spaceIdx = 5 (position of space char in string, &lt;Space&gt; above is the space char)
	
	spaceIdx := _value.pos(Space, 1);
	if spaceIdx &lt; _value.length then				// TFS 57207
		methodType := _value[1 : spaceIdx -1];
		path := _value[spaceIdx +1 : end];
	else
		methodType := _value;
	endif;
	
	self.accessCell(1, self.ColumnMethod).text := methodType;
	self.accessCell(1, self.ColumnValue).text := path;
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setup" id="f39c734d-1cb3-4149-ae36-abc845e1e5c9">
        <updating/>
        <source>setup(_type : String; _backColor : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2023	navpw1	Initial creation TFS: 55215
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
*/

vars

begin
	self.loadCombo;
	self.change(self);
	self.accessColumn(self.ColumnSpacer).width := 5;
	self.accessColumn(self.ColumnSpacer).backColor := _backColor;
	if not self.parent.isKindOf(Table) then
		self.tabKey := J_key_Tab;
		self.rowHeight[1] := (self.height - 2).Integer;
	endif;
end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_backColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="364dbcee-b7f2-4c45-856e-674e3afcfd7c">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023	navpw1	Initial creation TFS: 55215

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.columns := 3;
	self.rows := 1;
	self.fixedRows := 0;
	self.fixedColumns := 0;
	self.show3D := self.Show3D_Not3D;
	self.alignment := self.Alignment_Left_Middle;
	self.scrollBars := self.ScrollBars_None;
	self.setup(null, White);
	self.accessCell(1, self.ColumnValue).inputType := self.InputType_TextBox;
	self.accessedCell.cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.accessCell(1, self.ColumnMethod).inputType := self.InputType_ComboBox;
	self.accessColumn(self.ColumnMethod).width := 70;
	self.accessCell(1, self.ColumnSpacer).inputType := self.InputType_None;
	
	self.accessColumn(self.ColumnSpacer).enabled := false;
	self.gridColor := White;
	self.ignoreSkin := true; //tfs43291
	
	//cnwmc5 - PAR 32613 - T822
	self.selectMode := self.SelectMode_None;

epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
