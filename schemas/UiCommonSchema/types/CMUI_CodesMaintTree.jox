    <JadeMethod name="showThumbnailData" id="77d0d446-31ed-48cd-991c-e6cb9e24699f">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// -----------------------------------------------------------------------------
// Created:		27 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if obj &lt;&gt; null and obj.isKindOf(SOP_ViewModelObject) then
		self.doTreeSelect(obj.SOP_ViewModelObject);
	endif;
	if self.myCurrentVMObject = null then //rs oct 2004
		return;
	endif;
	if (not self.myCurrentVMObject.myObject.isTransient) then
		self.myCurrentObject := self.myCurrentVMObject.myObject;
	endif;
	self.myCurrentVMObject.showThumbnail(self.myCurrentVMObject.myObject);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnNewChildTV.enabled:= false;
		self.btnNewTV.enabled:= false;
		
	endif;

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showTree" id="8b357bf9-a5a2-4b11-ada8-40f496b66629">
        <updating/>
        <source>showTree(_groupType : Integer; _clearArray : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		12 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	codeGroup 	: CM_CodeGroup;
	iter		: Iterator;
	passport	: CM_Passport;
	failedDAC  :CM_DataAccessController;
	
begin
	if _clearArray then
		passport := app.myPassport;
	
		self.allVMObjects.purge();
		self.setMyCurrentVMObject(null); //epr par 16841 17/7/08
		self.myLastVMObject := null;
		iter := app.myRoot.allCodeGroups.createIterator();
		while iter.next(codeGroup) do
			if codeGroup.groupType = _groupType then
				if codeGroup.canUserAccessSelf(null, failedDAC, passport) then
					codeGroup.loadTreeViewArray(self.allVMObjects, 1, self);
				endif;
			endif;
		endwhile;
	endif;
	
	myViewListbox.vCreateIterator(self.allVMObjects, true);	
	
	//19 June 2013	NDL	Par 31770
	if _groupType = CodeGroup_SourceLocation then
		myViewListbox.vLoadListboxPlusDummyLine();
	else
		myViewListbox.vLoadListbox();
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_groupType" type="Integer"/>
        <Parameter name="_clearArray" type="Boolean"/>
    </JadeMethod>
