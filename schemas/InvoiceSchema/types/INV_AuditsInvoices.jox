    <JadeMethod name="setMyCaption" id="0e34a6ac-0687-4598-81bb-769f697985d2">
        <updating/>
        <source>setMyCaption() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCaption: String;
	numItems : Integer;
begin
	numItems := self.tblData.rows - self.tblData.fixedRows;
	if self.mode = Mode_Unqualified then
		theCaption := app.getErrorString(INV_Unqualified) &amp; app.getErrorString(INV_Audit_Review);
	else
		theCaption := app.getErrorString(INV_Qualified) &amp; app.getErrorString(INV_Audit_Review);
	endif;
	if self.myCurrentRate &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; self.myCurrentRate.getCode() &amp; " " &amp; app.getErrorString(Rate) &amp; self.myCurrentRate.service.name; // PAR 16503
	elseif self.myCurrentRateEntry &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; app.getErrorString(INV_Rate_Entry) &amp; self.myCurrentRateEntry.rate.String;
	elseif self.myCurrentService &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; "Service " &amp;   self.myCurrentService.name;

	elseif self.myCurrentInvoiceLine &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; app.getErrorString(INV_Invoice_Item) &amp; self.myCurrentInvoiceLine.sequenceNum.String;
	elseif self.myCurrentCashPayment &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; "Cash Payment";
	elseif self.myCurrentCashReceipt &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; "Cash Receipt "&amp; self.myCurrentCashReceipt.getExternalInvoiceNumber();
	elseif self.myCurrentInvoice &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; app.getErrorString(INV_Invoice) &amp; self.myCurrentInvoice.sequenceNum.String;
	endif;
	theCaption := theCaption &amp; " (" &amp; numItems.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; ")";
	self.caption := theCaption;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="75ea424b-f296-465c-89c4-7be63159f63e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := false;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	self.getXMLSettingsForSetup();
	inheritMethod();
	
	self.mnuContextColourLegend.visible := false; //cnwas3 PAR 21153 begin 
	self.mnuColumnOrganiser.visible 	:= true;
	self.mnuContextHide.visible 		:= true;
	
	self.doMnuHideClick(self.mnuContextHide);	// cnwcs5 CCMS CPL 2017/PAR 27126
	self.doMnuHideClick(self.mnuContextHide);	// cnwcs5 CCMS CPL 2017/PAR 27126						//cnwas3 PAR 21153 end

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnQualAll.enabled := false;
		self.btnQualify.enabled := false;
	endif;	
end;</source>
    </JadeMethod>
