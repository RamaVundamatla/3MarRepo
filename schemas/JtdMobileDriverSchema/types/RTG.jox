    <JadeMethod name="rtg001_VMRF_btnAccept_click" id="0e1a9944-ad73-4d9b-a4ca-7a0efed8f9fc">
        <updating/>
        <source>rtg001_VMRF_btnAccept_click():Integer updating;

vars
	i,j,row:Integer;
	area,vehid:String;
	table:Table;
begin
	app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" is looking for a move to make");
	table:=myVehicleMounted_RTGForm.tblJobs;
	while true do :outer
		foreach row in 2 to table.rows do
			//write table.getCellText(row, 3);
			area:=table.getCellText(row, 4)[1];
			//write app.jmtComputerName&amp;" "&amp;area;
			vehid:=table.getCellText(row, 2);
			if vehid &lt;&gt; null and vehid &lt;&gt; "Aft" and vehid &lt;&gt; "Fwd"  // it's on an IMV
			and ((app.jmtComputerName[1:3] = "RTG" and area &lt;= "X") or (app.jmtComputerName[1:3] = "RTB" and area &gt;= "Y")) then  // one RTG does 40ft areas, the other does 20ft areas in the same lane
				if table.getCellText(row, 1) = "IMPORT" then  // wait for the IMV to notice and log the move
					//if pauseAndStop(30000) then return 0; endif;  // IMV travel time
					process.sleep(30000);  // IMV travel time
				else
					//if pauseAndStop(2000) then return 0; endif;  // RTG driver reaction time
					process.sleep(2000);  // RTG driver reaction time
				endif;
				app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" is accepting "&amp;table.getCellText(row, 1)&amp;" "&amp;table.getCellText(row, 2)&amp;" "&amp;table.getCellText(row, 3));
				if table.getCellText(row, 1) = "EXPORT" then  // wait for the IMV to arrive and pick up
					//if pauseAndStop(30000) then return 0; endif;  // IMV travel time
					process.sleep(30000);  // IMV travel time
				endif;
				break outer;
			endif;
		endforeach;
		if pauseAndStop(longPause) then return 0; endif;  // "safe" way to add a delay
	endwhile;
	// note that the table may have been updated during the IMV travel time above, in which case the row will be wrong
	myVehicleMounted_RTGForm.txtWrongData.text:=null;
	myVehicleMounted_RTGForm.tblJobs.row:=row;
	myVehicleMounted_RTGForm.tblJobs.column:=3;
	myVehicleMounted_RTGForm.tblJobs.clearAllSelected;
	myVehicleMounted_RTGForm.tblJobs.accessCell(row,3).selected:=true;
	myVehicleMounted_RTGForm.tblJobs.click(myVehicleMounted_RTGForm.tblJobs);
	//if pauseAndStop(shortPause) then return 0; endif;  // "safe" way to add a delay
	process.sleep(shortPause);  // "safe" way to add a delay

	myVehicleMounted_RTGForm.btnAccept.click(myVehicleMounted_RTGForm.btnAccept);
	// if the table had not been updated and we got a msgBox complaining about it, retry the select
	if app.lastMsgBoxText.jtdContains("You must select an item in the list") then
		app.lastMsgBoxText:=null;
		app.logMessage(method.qualifiedName&amp;" "&amp;app.jmtComputerName&amp;" trying again");
		return rtg001_VMRF_btnAccept_click;  // recursion!
	endif;
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rtg003_VMRF_btnMsgOK_click" id="613a4059-e4ad-43cb-9ec6-4d86699fecc6">
        <updating/>
        <source>rtg003_VMRF_btnMsgOK_click():Integer updating;

vars
	msg:String;
begin
	msg:=myVehicleMounted_RTGForm.lblMsg.caption;
	app.logMessage(method.qualifiedName&amp;" lblMsg=&lt;"&amp;msg&amp;"&gt;");
	if msg.jtdContains("Overstow move of") or msg.jtdContains(" from  to ") or msg.jtdEndsWith(" to ") then
		app.logMessage(method.qualifiedName&amp;" canceling");
		myVehicleMounted_RTGForm.btnMsgCancel.click(myVehicleMounted_RTGForm.btnMsgCancel);
	else
		myVehicleMounted_RTGForm.btnMsgOK.click(myVehicleMounted_RTGForm.btnMsgOK);
	endif;
	app.logMessage(method.qualifiedName&amp;" errorText="&amp;myVehicleMounted_RTGForm.txtWrongData.text);
	
	/*if      app.jmtComputerName = "RTG5" then myVehicleMounted_RTGForm.top:=200;
	elseif app.jmtComputerName = "RTB5" then myVehicleMounted_RTGForm.top:=400;
	endif;/**/
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="c13848fd-6465-434b-9635-04373eabec21">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('rtg001_VMRF_btnAccept_click');
	sa.add('rtg003_VMRF_btnMsgOK_click');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="6189a42e-fadc-4205-9b50-adbb1179b414">
        <updating/>
        <source>startup() updating;

begin
	app.atcgRecordingVersion:='1.1.14.0';
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="startup2" id="06d125b2-a2e5-40a3-b082-e7d008642338">
        <updating/>
        <source>startup2() updating;

begin
	myVehicleMounted_RTGForm:=app.getForm('VehicleMounted_RTGForm').VehicleMounted_RTGForm;
	myVehicleMounted_RTGForm.caption:=myVehicleMounted_RTGForm.caption&amp;" "&amp;app.jmtComputerName;
	if      app.jmtComputerName = "RTG5" then myVehicleMounted_RTGForm.top:=200;
	elseif app.jmtComputerName = "RTB5" then myVehicleMounted_RTGForm.top:=400;
	endif;/**/
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop" id="8956c793-f747-4a5f-a094-70dc202da8c2">
        <updating/>
        <source>stop() updating;

begin
	inheritMethod;
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop2" id="446b7c3b-d6b3-4455-9efd-5f53cdfbd759">
        <updating/>
        <source>stop2() updating;

begin
	myVehicleMounted_RTGForm.btnLogoff.click(myVehicleMounted_RTGForm.btnLogoff);
	app.doWindowEvents(shortPause);

	myHandHeldLogonForm:=app.getForm('HandHeldLogonForm').HandHeldLogonForm;
	if myHandHeldLogonForm &lt;&gt; null then
		myHandHeldLogonForm.btnExit.click(myHandHeldLogonForm.btnExit);
		app.doWindowEvents(shortPause);
	endif;
	
	if app.isValidObject(myVehicleMounted_RTGForm) then
		myVehicleMounted_RTGForm.unloadForm;
	endif;
	myVehicleMounted_RTGForm:=null;
	if app.isValidObject(myHandHeldLogonForm) then
		myHandHeldLogonForm.unloadForm;
	endif;
	myHandHeldLogonForm:=null;
end;
</source>
    </JadeMethod>
</Class>
