    <JadeMethod name="addForm" id="1e3fd7da-40d0-434d-91eb-0693dd775188">
        <updating/>
        <source>addForm(pTheForm : Form; pIsIncluded : Boolean) : String updating;

vars
	helpForm	: CnEcHelpFormDetail;
	error		: String;
begin
	if pTheForm = null then
		return "Form is null";
	endif;

	if pIsIncluded then
		if not self.allIncludedForms.includes(pTheForm) then
			helpForm := self.getHelpForm(pTheForm);

			if helpForm = null then
				error := self.createHelpForm(helpForm, pTheForm);
				if error.length &gt; 0 then
					return error;
				endif;
			endif;
			
			self.allIncludedForms.add(pTheForm);
		endif;
	else
		if not self.allExcludedForms.includes( pTheForm ) then
			self.allExcludedForms.add(pTheForm);
		endif;
	endif;

	return "";
end;</source>
        <Parameter name="pTheForm" type="Form"/>
        <Parameter name="pIsIncluded" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="addTime" id="3167ab74-40a6-45b5-a877-16e093226b6f">
        <source>addTime(pProjectName : String; pDate : TimeStamp; pTimeEstimate, pTime : Real) : String;

vars
	theHelpTime		: CnEcHelpTime;
	object			: Object;
	error			: String;

begin
	foreach object in self.allTimes do
		theHelpTime := object.CnEcHelpTime;
		if pProjectName = theHelpTime.project then
			break;
		endif;
	endforeach;

	if theHelpTime = null or pProjectName &lt;&gt; theHelpTime.project then
		create theHelpTime;
		self.allTimes.add(theHelpTime);
	endif;

	error := theHelpTime.update(self, pProjectName, pDate, pTimeEstimate, theHelpTime.timeUsed + pTime);

	return error;
end;</source>
        <Parameter name="pProjectName" type="String"/>
        <Parameter name="pDate" type="TimeStamp"/>
        <Parameter name="pTimeEstimate" type="Real"/>
        <Parameter name="pTime" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearLists" id="40b8336f-987b-47d9-a0be-d4c4cbccb075">
        <source>clearLists();

begin
	self.allExcludedForms.clear();
	self.allIncludedForms.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="clearTimes" id="7c508740-be81-41a3-8552-32a0e1099d5c">
        <source>clearTimes();

vars
	theObject	: Object;

begin
	foreach theObject in self.allTimes do
		delete theObject.CnEcHelpTime;
	endforeach;
	
	self.allTimes.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="createHelpForm" id="34ff20b4-cfc6-465e-8884-2702bafbf32f">
        <source>createHelpForm(pTheHelpForm : CnEcHelpFormDetail io; pTheForm : Form) : String;

vars
	error	: String;

begin
	if pTheHelpForm = null then
		create pTheHelpForm;
		error := pTheHelpForm.createForm(self, pTheForm, pTheForm.creationTime());	//	form.cnEcGetModifyTimeStamp
		
		if error.length &gt; 0 then
			return error;
		endif;
		
		self.allHelpFormDetails.add( pTheHelpForm );
	endif;
	return "";
end;</source>
        <Parameter name="pTheHelpForm" type="CnEcHelpFormDetail" usage="io"/>
        <Parameter name="pTheForm" type="Form"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dropForm" id="1e6e270e-475d-4191-b026-f252e6d120d1">
        <source>dropForm(pTheForm : Form; pIsIncluded : Boolean);

begin
	if pTheForm = null then
		return;
	endif;

	if pIsIncluded then
		if self.allIncludedForms.includes(pTheForm) then
			self.allIncludedForms.remove(pTheForm);
		endif;
	else
		if self.allExcludedForms.includes(pTheForm) then
			self.allExcludedForms.remove(pTheForm);
		endif;
	endif;
end;</source>
        <Parameter name="pTheForm" type="Form"/>
        <Parameter name="pIsIncluded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChangedForms" id="f91ed7de-53ea-4a44-9799-a7820004f072">
        <source>getChangedForms(pFormListSet : ObjectSet; pNewFormSet, pUpdatedFormSet : ObjectSet io);

vars
	theForm				: Form;
	allIncludedObjects	: ObjectSet;
	allExcludedObjects	: ObjectSet;
	theHelpForm			: CnEcHelpFormDetail;
	theObject			: Object;
	formTimeStamp		: TimeStamp;
	modifyTime			: Integer;
	storeTime			: Integer;

begin
	create allIncludedObjects transient;
	create allExcludedObjects transient;
	self.allExcludedForms.copy(allExcludedObjects);
	self.allIncludedForms.copy(allIncludedObjects);

	pNewFormSet.clear();
	pUpdatedFormSet.clear();

	foreach theObject in pFormListSet do
		theForm		:= theObject.Form;
		theHelpForm	:= null;

		if allExcludedObjects.size() &gt; 0 and allExcludedObjects.includes(theForm) then	// check excluded forms list
			allExcludedObjects.remove(theForm);

		elseif allIncludedObjects.size() &gt; 0 and allIncludedObjects.includes(theForm) then	// may be - timestamp check needed
			allIncludedObjects.remove(theForm);

			theHelpForm := self.getHelpForm(theForm);

			if theHelpForm = null then		// if helpForm = null ERROR - the collections don't match
				app.msgBox("Collections do not match in CnEcHelp", "Internal error", MsgBox_OK_Only);
				return;
			endif;

			formTimeStamp := self.getFormTimeStamp(theForm);
			
			if formTimeStamp.date &gt; theHelpForm.modified.date then
				pUpdatedFormSet.add(theForm);
				
			elseif formTimeStamp.date = theHelpForm.modified.date then
				modifyTime	:= formTimeStamp.time.Integer div 1000;
				storeTime	:= theHelpForm.modified.time.Integer div 1000;
//				write(form.name &amp; "modify date = stored date, modify time=" &amp; modifyTime.String &amp; "(" &amp; modifyTime.Integer.String &amp; ") stored= " &amp; storeTime.String &amp; " (" &amp; storeTime.Integer.String);

				if modifyTime &gt; storeTime then
					pUpdatedFormSet.add(theForm);
				endif;
			endif;
		else
			pNewFormSet.add(theForm);
		endif;
	endforeach;
epilog
	delete allIncludedObjects;
	delete allExcludedObjects;
end;</source>
        <Parameter name="pFormListSet" type="ObjectSet"/>
        <Parameter name="pNewFormSet" type="ObjectSet" usage="io"/>
        <Parameter name="pUpdatedFormSet" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFormTimeStamp" id="aeaa3304-b385-4ffa-80ca-4f663fe71e66">
        <source>getFormTimeStamp(pTheForm : Form) : TimeStamp;

vars
	ts		: TimeStamp;
	theClass	: Class;
	schema	: Schema;

begin
	foreach schema in Schema.instances do
		theClass := schema.getClass(pTheForm.name);	
		
		if theClass &lt;&gt; null then
			break;
		endif;
	endforeach;

	if theClass = null then
		return null;
	else
		return class().cnEcGetModifyTimeStamp();
	endif;
end;</source>
        <Parameter name="pTheForm" type="Form"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getHelpForm" id="2b60b82d-a6d0-4b1c-a826-8c167ff8d294">
        <source>getHelpForm(pTheForm : Form) : CnEcHelpFormDetail;

vars
	helpForm	: CnEcHelpFormDetail;
	object		: Object;
	
begin
	if pTheForm &lt;&gt; null then
		foreach object in self.allHelpFormDetails do
			helpForm := object.CnEcHelpFormDetail;
			
			if helpForm.myForm = pTheForm then
				return helpForm;
			endif;
		endforeach;
	endif;

	return null;
end;</source>
        <Parameter name="pTheForm" type="Form"/>
        <ReturnType type="CnEcHelpFormDetail"/>
    </JadeMethod>
    <JadeMethod name="getName" id="43aa96a2-79d0-44a2-bcfe-a3cc6fb6f2a3">
        <source>getName() : String;

begin
	return self.name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="remove" id="df147a27-c0e2-47a0-8b73-79e9aaf07cc0">
        <updating/>
        <source>remove() updating;

vars
	cnHelpForm	: CnEcHelpFormDetail;
	theObject	: Object;

begin
	self.clearLists();
	
	foreach theObject in self.allHelpFormDetails do
		delete theObject.CnEcHelpFormDetail;
	endforeach;
	
	foreach theObject in self.allTimes do
		delete theObject.CnEcHelpTime;
	endforeach;
	
	self.allTimes.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="removeTime" id="e56d6e1a-7e18-444d-b28b-83d4416c5df8">
        <updating/>
        <source>removeTime(pTheHelpTime : CnEcHelpTime) updating;

vars
	theObject	: Object;

begin
	foreach theObject in self.allTimes do
		if theObject = pTheHelpTime then
			break;
		endif;
	endforeach;

	if theObject = pTheHelpTime then
		self.allTimes.remove(theObject);
		delete theObject;
	endif;
end;</source>
        <Parameter name="pTheHelpTime" type="CnEcHelpTime"/>
    </JadeMethod>
    <JadeMethod name="update" id="52ffc9dc-8e5d-4ed5-8fad-70c55dca55b4">
        <updating/>
        <source>update(pNewName : String; pNewBuildDate : TimeStamp; pTheSchema : Schema; pHasSubschemas : Boolean; pHasTimeRecording : Boolean) updating;

vars
	str	: String;

begin
	str := pNewName.trimBlanks;
	
	if str.length &gt; 0 and str &lt;&gt; self.name then
		self.name := str;
	endif;
	
	if pNewBuildDate &lt;&gt; self.lastBuildDate then
		self.lastBuildDate := pNewBuildDate; 
	endif;
	
	if self.usesTimeRecording &lt;&gt; pHasTimeRecording then
		self.usesTimeRecording := pHasTimeRecording;
	endif;
	
	if pHasSubschemas &lt;&gt; self.includeSubSchemas then
		self.includeSubSchemas := pHasSubschemas;
	endif;
	
	if pTheSchema &lt;&gt; self.myFormSchema then
		self.myFormSchema := pTheSchema;
	endif;
end;</source>
        <Parameter name="pNewName" type="String"/>
        <Parameter name="pNewBuildDate" type="TimeStamp"/>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pHasSubschemas" type="Boolean"/>
        <Parameter name="pHasTimeRecording" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFlagText" id="d52059d4-216e-469f-a4d2-46c0338f5fe5">
        <updating/>
        <source>updateFlagText(pFlag1Text:String; pFlag2Text : String) : String updating;

vars
	flag1	: String;
	flag2	: String;

begin
	flag1 := pFlag1Text.trimBlanks;

	if flag1.length &gt; 10 then
		return "Flag 1 text is longer than 10 characters";
	endif;

	flag2 := pFlag2Text.trimBlanks();

	if flag2.length &gt; 10 then
		return "Flag 2 text is longer than 10 characters";
	endif;

	if flag1 &lt;&gt; self.flag1Text then
		self.flag1Text := flag1;
	endif;

	if flag2 &lt;&gt; self.flag2Text then
		self.flag2Text := flag2;
	endif;

	return "";
end;</source>
        <Parameter name="pFlag1Text" type="String"/>
        <Parameter name="pFlag2Text" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
