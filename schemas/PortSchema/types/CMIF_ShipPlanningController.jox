<Class name="CMIF_ShipPlanningController" id="2b9d8ee0-5a9e-4f7e-90b4-03365368a941">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
###############################
###############################

Items on GUI CMUI_ShipFullyPlanForm

YARD SEPERATION 

chkRowEnd 		= Top Height Plan From Row Ends 	= CMIF_ShipPlanController.useRowEnds
txtHeight 			= Top Height Position 					= CMIF_ShipPlanController.topPosition
chkSplitTopHight 	= Split Row For Mixed Cargo 			= CMIF_ShipPlanController.autoLoadPlanAt3Height
txtRows 			= Number Of Rows For Seperation 	= CMIF_ShipPlanController.rowsSeperation

TERMINAL SEPERATION

optCrossTermNo 		= Do Not Plan Across Terminal Areas 		= not used
optCrossTermOne 	= Plan Across Terminal Areas Individually 	= CMIF_ShipPlanController.isDoingTASepByInd
optCrossTermCol 		= Plan Across Terminal Areas by Column 	= CMIF_ShipPlanController.isDoingTASepByCol

chkColReversed 		= Plan Reversed Within Row/Column 		= CMIF_ShipPlanController.flippedH
chkUseWieights 		= Use Weight Consideration  					= CMIF_ShipPlanController.useWeights
txtWeight 				= Comparison Heavy Weight 					= CMIF_ShipPlanController.weightAve
chkNoPlanIfStops 	= Ignore Items With Customs Stops 		= CMIF_ShipPlanController.ignoreTIsWithErrors
chkIgnoreWarning 	= Ignore All Warnings 							= CMIF_ShipPlanController.ignoreWarnings</text>
