<Class name="CM_RemoteRegradingExtra" id="6b97f8b2-9bd3-4e0e-8a6d-9910a94de5b8">
    <superclass name="CM_RemoteDataExtra"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="itemId" id="e0a34156-9a3d-453b-9a81-7c139a763002">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="newItemId" id="9bbc3b20-51d9-491d-a265-29e849381bf8">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="reasonCode" id="1bf21e1e-d331-43ca-8589-5a425ef9cffe">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sedMax" id="deb0a0d3-c94b-45fa-84c3-126d8df67d95">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sedMin" id="cd5ce4f8-2d28-4efa-861d-22615f4800f7">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDescription" id="0c067423-5419-45ed-bb77-5a02f36f0694">
        <source>getDescription(): String;

// cnwdvb1 31 March 2003 

vars

begin
	return 'Regrading extra detail';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="aaae8506-035e-442f-8ef2-0083be16bd32">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns: Integer) updating;

// cnwdvb1 31 March 2003 

vars

begin
	
	self.itemId		:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.newItemId	:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.sedMin		:= _table.accessCell(4,_entryTableColumns).text.Integer;
	self.sedMax		:= _table.accessCell(5,_entryTableColumns).text.Integer;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2c7657e5-a98f-40ba-892a-405e762f573b">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteRegradingExtra; _remoteDataDtl: CM_RemoteDataDtl) updating;

// cnwdvb1 28 March 2003 

vars

begin
	inheritMethod(_proxy, _remoteDataDtl);
	self.itemId		:= _proxy.itemId;
	self.newItemId	:= _proxy.newItemId;
	self.sedMin		:= _proxy.sedMin;
	self.sedMax		:= _proxy.sedMax;
	self.reasonCode	:= _proxy.reasonCode;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteRegradingExtra"/>
        <Parameter name="_remoteDataDtl" type="CM_RemoteDataDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyForRegradingExtra" id="1d838291-05e1-4280-aa66-d60a519de011">
        <updating/>
        <source>setProxyForRegradingExtra(_remoteDtl : CM_RemoteDataDtl; _orginalItemId, _newItemId, _reasonCode : String; _sedMin, _sedMax : Integer) updating;

// cnwdvb1 27 March 2003 

vars

begin

	self.itemId		:= _orginalItemId;
	self.newItemId	:= _newItemId;
	self.sedMin		:= _sedMin;
	self.sedMax		:= _sedMax;
	self.reasonCode	:= _reasonCode;
	self.setProxy(_remoteDtl);

end;</source>
        <Parameter name="_remoteDtl" type="CM_RemoteDataDtl"/>
        <Parameter name="_orginalItemId" type="String"/>
        <Parameter name="_newItemId" type="String"/>
        <Parameter name="_reasonCode" type="String"/>
        <Parameter name="_sedMin" type="Integer"/>
        <Parameter name="_sedMax" type="Integer"/>
    </JadeMethod>
</Class>
