    <JadeMethod name="setupForm" id="e4ed69e4-0d72-4b98-8df9-48f75ab876a4">
        <updating/>
        <source>setupForm() updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 10 Sep 2021  navma1 		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.fldDetails.tabsHeight := -1;
	
	self.modalResult := IDCANCEL;

	self.isSelectorCapable := true;
	
	self.btnCargoSelector.visible	:= app.getMyUser().canDo(self.myTerminal,  PmAdmSelectorEntry);
	self.frmData.backColor 			:= self.backColor;
	self.grpCargoIDs.backColor 		:= self.backColor;
	self.grpBulkReleases.backColor  := self.backColor;
	self.grpRequests.backColor 		:= self.backColor;
	self.grpWorkOrders.backColor 	:= self.backColor;
	self.grpBookings.backColor 		:= self.backColor;
	
	self.headingCargoIDs 	 := self.lblCargoIDs.caption;
	self.headingBulkReleases := self.lblBulkReleases.caption;
	self.headingRequests 	 := self.lblRequests.caption;
	self.headingWorkOrders 	 := self.lblWorkOrders.caption;
	self.headingBookings 	 := self.lblBookings.caption;
	
	self.tblThumb.backColor					:= self.colorControlBack;
	self.tblThumb.accessColumn(1).backColor := self.colorHeadingColumn;
	
	self.cmbWorkOrder.listCollection(self.myTerminal.allWorkOrders, true, 0);


	if self.myRealWorkOrder &lt;&gt; null then
		self.setCaption(app.getErrorString(Cargo_source_work_order) &amp; self.myRealWorkOrder.id );
	else
		self.setCaption(app.getErrorString(Cargo_source_work_order_new));
	endif;
	
	if self.myMainForm &lt;&gt; null then
		self.myMainForm.enabled := false;
	endif;
		
	//10.09.2021 navma1 #51002
	if self.myProxySource &lt;&gt; null and self.myProxySource.isSourceForPack then
		self.txtCargoIDs.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showGroup" id="1ce4a52e-8fe2-4c37-9c0b-cc1e97e47332">
        <source>showGroup(_cntrl : Control);
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	cargoType : Integer;	
begin

	// we need to save off the cargo id list before changing group
	if self.cmbCargoType.listObject &lt;&gt; null then
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id;
	endif;

	if self.grpCargoIDs.visible  and (_cntrl = self.grpCargoIDs) = false then
		self.myProxySource.setProxy( cargoType, self.txtCargoIDs.text );
	endif;
	
	if _cntrl &lt;&gt; null then
		self.fldDetails.visible := true;
		_cntrl.CMUI_Sheet.showMySheet();
	else
		self.fldDetails.visible := false;
	endif;
	
	/*
	self.grpCargoIDs.visible 		:= (_cntrl = self.grpCargoIDs);
	self.grpBulkReleases.visible 	:= (_cntrl = self.grpBulkReleases);
	self.grpRequests.visible 		:= (_cntrl = self.grpRequests);
	self.grpWorkOrders.visible 		:= (_cntrl = self.grpWorkOrders);
	self.grpBookings.visible 		:= (_cntrl = self.grpBookings);
	*/

epilog

end;</source>
        <Parameter name="_cntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="showSelector" id="993365f4-59d6-4e63-90e7-a7f21af797cc">
        <updating/>
        <source>showSelector() updating, protected;
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 10 Sep 2021  navma1 		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars

	theSelector		 : CMUI_Selector;
	queryModeInteger : Integer;
	queryType 		 : Integer;
	
begin

	if self.mySelectorForm &lt;&gt; null then
		theSelector := self.mySelectorForm;
		theSelector.windowState := WindowState_Normal;
	else	
		theSelector := app.loadForm(CMUI_Selector, null, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Selector;
		theSelector.myParent := self;
		theSelector.myTerminal := self.myTerminal;
	endif;
	
	if theSelector = null then
		return;
	endif;
	

	if self.cmbCargoType.listObject &lt;&gt; null then
	
		//23 Nov 2009	NDL	CCMS 1028
		queryModeInteger := self.cmbCargoType.listObject.CM_CargoType.id;
		if queryModeInteger &gt;= BOLType_Min and queryModeInteger &lt;= BOLType_Max then
			queryType := CM_QueryDefinition.BOL_Query_Type;
		else
			queryType := CM_QueryDefinition.TrackedItem_Query_Type;
		endif;
	
		if self.myProxySource &lt;&gt; null and self.myProxySource.isSourceForPack then  //10.09.2021 navma1 #51002
			queryModeInteger := 0;
		endif;
		theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[queryType, queryModeInteger];
	endif;
	
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.show;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDef" id="32854d5d-a9aa-4a1d-beab-81fdbd383ba7">
        <source>showThumbnailForDef(pDefName : String; _obj : CM_Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwrd1	Initial creation

*/

vars
	entTableDef	: EntTableDef;
	tmpHeadings	: StringArray;
	tmpData		: HugeStringArray;
	str,
	dataStr		: String;
	count,
	i, rowIdx,
	dataSize,
	rowHeight	: Integer;
	
begin
	entTableDef := app.myController.getEntTableDef(pDefName);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; pDefName &amp; ') not found');
		return;
	endif;

	create tmpHeadings transient;
	create tmpData transient;

	_obj.getDataForDef(entTableDef, tmpHeadings, tmpData, self.myTerminal);

	dataSize := tmpData.size;
	foreach str in tmpHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := tmpData[i];
		rowIdx := tblThumb.addItem(str &amp; Tab &amp; dataStr);
		tblThumb.formatRow(rowIdx);  // PAR 19910
	endforeach;
	
//	tblThumb.optimiseHeadingColumn();

epilog
	delete tmpHeadings;
	delete tmpData;	
end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDefWithView" id="4ed3154c-d13e-4dec-84d4-655d76f95c4d">
        <source>showThumbnailForDefWithView(pDefName, pViewName : String; _obj : CM_Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwrd1	Initial creation

*/



vars
	entTableDef	: EntTableDef;
	entTableView: EntTableView;
	entTableRow	: EntTableRow;
	tmpHeadings	: StringArray;
	tmpData		: HugeStringArray;
	str,
	dataStr		: String;
	count,
	i, rowIdx,
	dataSize,
	rowHeight	: Integer;
	showRow 		: Boolean;
	
begin
	entTableDef := app.myController.getEntTableDef(pDefName);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; pDefName &amp; ') not found');
		return;
	endif;
	if pViewName &lt;&gt; null then
		entTableView := entTableDef.allEntTableViews[pViewName];
	endif;

	create tmpHeadings transient;
	create tmpData transient;
	
	_obj.getDataForETView(entTableDef, entTableView, tmpHeadings, tmpData, self.myTerminal);

	dataSize := tmpData.size;
	foreach str in tmpHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := tmpData[i];
	
		rowIdx := tblThumb.addItem(str &amp; Tab &amp; dataStr);
		//expand row if text has carrage returns
		count := dataStr.countOccurrences(Cr);
		tblThumb.accessRow(rowIdx);
		if count &gt; 0 then
			rowHeight := tblThumb.accessRow(rowIdx).height;
			tblThumb.accessedRow.height := rowHeight * (count+1);
		endif;

		tblThumb.accessRow(rowIdx);
	endforeach;
	
//	tblThumb.optimiseHeadingColumn();

epilog
	delete tmpHeadings;
	delete tmpData;	
end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="pViewName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4299fa9a-0a4f-4ffd-9380-8b39be375dd8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012487, locale);
	btnAddBookingRef.translateCaption(Xlat_0012488, locale);
	btnAddBulkRel.translateCaption(Xlat_0012489, locale);
	btnAddRequest.translateCaption(Xlat_0012490, locale);
	btnAddWorkOrder.translateCaption(Xlat_0012491, locale);
	btnCancel.translateCaption(Xlat_0012492, locale);
	btnCargoSelector.translateCaption(Xlat_0012493, locale);
	btnDelRequest.translateCaption(Xlat_0012494, locale);
	btnOK.translateCaption(Xlat_0012495, locale);
	btnRemBookingRef.translateCaption(Xlat_0012496, locale);
	btnRemBulkRel.translateCaption(Xlat_0012497, locale);
	btnRemWorkOrder.translateCaption(Xlat_0012498, locale);
	btnUpdRequest.translateCaption(Xlat_0012499, locale);
	btnViewSource.translateCaption(Xlat_0013802, locale);
	dkbSources.translateCaption(Xlat_0012500, locale);
	lblBookingRef.translateCaption(Xlat_0014670, locale);
	lblBookings.translateCaption(Xlat_0012502, locale);
	lblBulkRelease.translateCaption(Xlat_0012503, locale);
	lblBulkReleases.translateCaption(Xlat_0012504, locale);
	lblCargoIDs.translateCaption(Xlat_0012505, locale);
	lblCargoType.translateCaption(Xlat_0012506, locale);
	lblISOGroup.translateCaption(Xlat_0013803, locale);
	lblOperator.translateCaption(Xlat_0012507, locale);
	lblReqAvailGrade.translateCaption(Xlat_0012508, locale);
	lblReqCargoType.translateCaption(Xlat_0012509, locale);
	lblReqClean.translateCaption(Xlat_0012511, locale);
	lblReqHeavyDuty.translateCaption(Xlat_0012512, locale);
	lblReqISOType.translateCaption(Xlat_0012513, locale);
	lblReqOperatorGr.translateCaption(Xlat_0012514, locale);
	lblReqProduct.translateCaption(Xlat_0012515, locale);
	lblReqRequested.translateCaption(Xlat_0012516, locale);
	lblRequests.translateCaption(Xlat_0012517, locale);
	lblSourceArea.translateCaption(Xlat_0012518, locale);
	lblWorkOrder.translateCaption(Xlat_0012519, locale);
	lblWorkOrders.translateCaption(Xlat_0012520, locale);
	shtBooking.translateCaption(Xlat_0013804, locale);
	shtCargoIDs.translateCaption(Xlat_0013805, locale);
	shtRelease.translateCaption(Xlat_0013806, locale);
	shtRequestByType.translateCaption(Xlat_0013807, locale);
	shtWorkOrder.translateCaption(Xlat_0013808, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtCargoIDs_change" id="6d0e2e37-e1fd-4319-bd9b-b701bf82f10b">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoIDs_change(textbox: TextBox input) updating;
// -----------------------------------------------------------------------------
// Created:		06 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	pos : Integer;
	saveStart : Integer;
	str : String;
	
begin
	if not self.canSourcesBeRemoved and self.initialTiTextList &lt;&gt; null then
		if txtCargoIDs.text.length &gt; self.initialTiTextListLength then
			saveStart := txtCargoIDs.selStart;
			pos := self.initialTiTextListLength + 1;
			if txtCargoIDs.text[pos:1] &lt;&gt; " " 
			and txtCargoIDs.text[pos:1] &lt;&gt; "," then
				str := txtCargoIDs.text;
				txtCargoIDs.text := str[1:self.initialTiTextListLength] &amp; ", " &amp; str[pos : end];
				txtCargoIDs.selStart := saveStart + 2;
			endif;
		endif;
	endif;
		
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoIDs_keyDown" id="a646ff3b-8dae-4320-b163-5e1781c12951">
        <controlMethod name="TextBox::keyDown"/>
