    <JadeMethod name="structureTypeString" id="af33e7e6-5281-4a12-b2ca-2c120c3c4545">
        <methodInvocation>mapping</methodInvocation>
        <source>structureTypeString(set: Boolean; _value: String io) mapping;
//--------------------------------------------------
// Created:	30 Apr 2012	cnwrs1	Par 29395
//
// 7 Mar 13	PJS 	PAR #31232  
//--------------------------------------------------
vars


begin
	if set then
		// set code here
	else
		//epr par 27566 20/5/2011 
		
		// PAR # 31232
		
	//	_value := app.vesselStructureTypeEnumToStr(self.structureType);
	
	
		// cannot mark a vessel as logs currently
	
		if self.structureIncludesLOLO then
			_value :=_value.appendCommaSeparatedValue(LOLOStr,true);
		endif;
		
		if self.structureIncludesRORO then
			_value := _value.appendCommaSeparatedValue(ROROStr,true);
		endif;
		
		if self.structureIncludesHolds then
			_value :=_value.appendCommaSeparatedValue(HoldsStr,true);
		endif;
				
		if _value = null then
			_value := StructureTypeNullStr;
		endif;
		
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateProxyVoyageRequest" id="b5d140f1-7002-4e9a-bbd6-4b50fc9e86c5">
        <source>updateProxyVoyageRequest(_pxyVoyage : CM_Voyage input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2021	jlier1	Initial creation 51963

*/

vars
	realVoyage : CM_Voyage;
	lastVoyage 	: CM_Voyage;
	terminal : CM_Terminal;
	craneClearance 				: Integer;
	callSign					: String;
	lloydsNumber 				: String;
	starboardBerthed 			: Boolean;
	vesselType					: Integer;
	voyageColor					: Integer;
	displayOption 				: Integer;
	defaultLineGroupDebtor 		: CM_LineGroupDebtor;
	dishargeCompany 			: CM_Bank;
	trade 						: CM_Trade;
	shippingLine 				: CM_ShippingLine;
	pxyGlobalVoyage 			: CM_VoyageGlobal;
	voyagePlanningCode 			: CM_VoyagePlanningCode;
	moveMapRec, moveMapRel 		: CM_MoveMap;
	altVoyage 					: CM_Voyage;
	voyageNumber 				: Integer;
	allOperators 				: CM_OperatorByCodeDict;
	useVoyageAllocations 		: Boolean;
	externalRef					: String;
	yearOfBuild 				: Integer;
	airDraft 					: Decimal[6,2];
	maxVesselBeam 				: Decimal[6,2];
	draftBow 					: Decimal[6,2];
	draftMid 					: Decimal[6,2];
	draftStern 					: Decimal[6,2];
	buildingLine				: Decimal[6,2];
	loaWithRampDown 			: Decimal[6,2];
	useOutOfSequenceLoadingJobs : Boolean;
	pxyHMSVoyage 				: HMS_VoyageData;
	paymentType					: Integer;
	isBarge						: Boolean;
	defaultBerth 				: HMS_Berth;
begin	
	if _pxyVoyage = null then
		app.raiseCMException(Voyage_code_must_specifi,null,null);
		return;
	endif;
	realVoyage:=_pxyVoyage.pxyGetRealObject;
	if realVoyage.myVessel = self then
		return; //nothing to do it is the same
	endif;
	terminal:=realVoyage.myTerminal;
	if terminal.myHarbour &lt;&gt; null then
		lastVoyage := terminal.myHarbour.getVesselsLastVoyage(self.code);
	else
		lastVoyage := self.getLastVoyage(terminal);
	endif;
	create allOperators transient;
	if lastVoyage &lt;&gt; null then
		lloydsNumber 			:= lastVoyage.lloydsNumber;
		craneClearance			:= lastVoyage.craneClearance;
		callSign				:= lastVoyage.callSign;
		starboardBerthed 		:= lastVoyage.starboardBerthed;
		displayOption			:= lastVoyage.displayOption;
		voyageColor				:= lastVoyage.colour;
		vesselType				:= lastVoyage.vesselType;
		defaultLineGroupDebtor 	:= lastVoyage.myDefaultLineGroupDebtor;
		dishargeCompany 		:= lastVoyage.myDischargeCompany;
		trade 					:= lastVoyage.myTrade;
		shippingLine 			:= lastVoyage.myShippingLine;
		voyagePlanningCode		:= lastVoyage.myVoyagePlanningCode;
		moveMapRec 				:= lastVoyage.myMMReceival;
		moveMapRel 				:= lastVoyage.myMMRelease;
		altVoyage 				:= lastVoyage.myCusresAltVoyage;
		voyageNumber 			:= lastVoyage.voyageNumber +1;
		useVoyageAllocations 	:= lastVoyage.useVoyageAllocations;
		externalRef 			:= lastVoyage.externalRef;
		yearOfBuild 			:= lastVoyage.yearOfBuild;
		airDraft 				:= lastVoyage.airDraft;
		maxVesselBeam 			:= lastVoyage.maxVesselBeam;
		draftBow 				:= lastVoyage.draftBow;
		draftMid				:= lastVoyage.draftMid;
		draftStern				:= lastVoyage.draftStern;
		buildingLine			:= lastVoyage.buildingLine;
		loaWithRampDown			:= lastVoyage.loaWithRampsDown;
		useOutOfSequenceLoadingJobs := lastVoyage.allowOutOfOrderJobs;
	//	externalCode := lastVoyage.voyageCodeExternal;

		isBarge					:= lastVoyage.isBarge; // jlgka1 TFS 37102
	endif;
	paymentType 			:= PaymentType_None; //epr TFS 43823 13/3/19
	//if no last voyage or no value default from the vessel
	if lloydsNumber = null then
		lloydsNumber:=self.lloydsNumber;
	endif;
	if craneClearance = null then
		craneClearance:=self.craneClearance;
	endif;
	if callSign = null then
		callSign:=self.callSign;
	endif;
	if vesselType = null then //never used
		vesselType:=self.vesselType;
	endif;
	if trade = null then
		trade:=self.myDefaultTrade;
	endif;
	if self.myHMSVesselData &lt;&gt; null then
		if shippingLine = null then
			shippingLine :=self.myHMSVesselData.myDefaultShippingLine;
		endif;
	endif;
	if yearOfBuild = null then
		yearOfBuild :=self.yearOfBuild;
	endif;
	if airDraft = null then
		airDraft :=self.airDraft;
	endif;
	if maxVesselBeam = null then
		maxVesselBeam :=self.maxVesselBeam;
	endif;
	if draftBow = null then
		draftBow :=self.draftBow;
	endif;
	if draftMid = null then
		draftMid :=self.draftMid;
	endif;
	if draftStern = null then
		draftStern :=self.draftStern;
	endif;
	if buildingLine = null then
		buildingLine :=self.buildingLine;
	endif;
	if loaWithRampDown = null then
		loaWithRampDown :=self.loaWithRampsDown;
	endif;
	if trade &lt;&gt; null then
		trade.operators.copy(allOperators);
	endif;
	_pxyVoyage.setProxyVoyage(_pxyVoyage.bitmap, //vessel image
							callSign, //callsign
							_pxyVoyage.code, 
							_pxyVoyage.inwardCode,//inward
							_pxyVoyage.remarks,//remarks
							self.code,
							self.name,
							lloydsNumber, //lloyds
							false, //archived
							false, //transferred
							starboardBerthed, //starboard berthed - defaults to false
							craneClearance, //crane clearance
							displayOption, 
							voyageColor,
							_pxyVoyage.status,
							vesselType,
							null, //archivedDT
							_pxyVoyage.arrivedDT,
							_pxyVoyage.departedDT,
							null, //loadStartDT
							null, //loadEndDT
							null, //nonPlannedEffectiveDT
							null, //cutoffDT
							defaultLineGroupDebtor,
							dishargeCompany,
							_pxyVoyage.myOperator,
							trade,
							shippingLine,
							terminal,
							pxyGlobalVoyage,
							voyagePlanningCode,
							Voyage_Invoice_Status_NotGen,
							moveMapRec,
							moveMapRel,
							altVoyage,
							voyageNumber,
							false, //ovveride defaults
							allOperators,
							null, //default receival cutoffs from terminal,
							useVoyageAllocations,
							externalRef,
							yearOfBuild,
							airDraft   ,
							maxVesselBeam ,
							draftBow ,
							draftMid ,
							draftStern ,
							buildingLine ,
							loaWithRampDown ,
							useOutOfSequenceLoadingJobs,
							_pxyVoyage.estimatedArrivalDT,  //expected arrival 
							_pxyVoyage.estimatedDepartureDT,  //expected departure
							null,  //generalLandingDate
							_pxyVoyage.voyageCodeExternal,
							paymentType,
							isBarge,	 // jlgka1 TFS 37102
							_pxyVoyage.voyageGroupCode,         //03/06/2020 cnwma1 Tfs #49400
							false	// 31.Aug.2023 navsp1 TFS 57809
							);
	_pxyVoyage.setMyVessel(self);
	
	if 	self.myHMSVesselData &lt;&gt; null and terminal.myHarbour &lt;&gt; null then
		pxyHMSVoyage:=_pxyVoyage.myHMSVoyageData;
		if pxyHMSVoyage = null then
			create pxyHMSVoyage transient;
			_pxyVoyage.setHMSVoyageData(pxyHMSVoyage);
		endif;
		
		//jlier1 TFS 52194  15/10/21
		defaultBerth:=terminal.myHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival);
		if lastVoyage &lt;&gt; null and lastVoyage.myHMSVoyageData &lt;&gt; null then
			lastVoyage.myHMSVoyageData.setProxyVoyageHMSData(pxyHMSVoyage,defaultBerth);
		else	
			self.myHMSVesselData.setProxyVoyageHMSData(pxyHMSVoyage,true,terminal);
		endif;
		
		
	endif;
epilog
	delete allOperators;
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="use40Id" id="7b787445-176c-4f6a-87d1-989583cb5906">
