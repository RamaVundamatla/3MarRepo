    <JadeMethod name="getResourceUsageQuantStringJRW" id="5619f74a-2126-441e-8651-891071c72fab">
        <source>getResourceUsageQuantStringJRW(): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		3 March 2011
//
// Implemented version: JMT 8.8.1.
// Date  		User  		Change
// 18/04/2012	cnwsh3		PAR29461
//----------------------------------------------------------------------
vars
	resourceUsage : CM_ResourceTypeUsage;
	str : String;
	firstTime : Boolean;
	dec		: Decimal[12,2];
begin
	firstTime := true;
	foreach resourceUsage in self.allResourceUsages do
		if resourceUsage.myResourceType &lt;&gt; null then
			dec := resourceUsage.quantity;
			if firstTime then
				str := resourceUsage.myResourceType.code &amp; ' ('&amp; dec.String &amp; ')';
				firstTime := false;
			else
				str := str &amp; ', ' &amp; resourceUsage.myResourceType.code&amp; ' ('&amp; dec.String &amp; ')';
			endif;
		endif;
	endforeach;
	return str;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
