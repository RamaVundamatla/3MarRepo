    </JadeMethod>
    <JadeMethod name="loadSpeciesCombo" id="da7ab32c-236b-421d-9392-c92386f0b31e">
        <updating/>
        <source>loadSpeciesCombo(_operator : CM_Operator; _tbl : CM_EntryTable input;
	_cmbSpecies, _cmbGrade, _cmbType, _cmbTreat, _cmbLength : ComboBox input) protected, updating;

vars
	tempCodes : CM_CodesByCodeDict;


begin
	
	_cmbSpecies.clear;
	_cmbGrade.clear;
	_cmbGrade.CMUI_ComboLogGrade.setObjectAndSpecies(null,null);
	_cmbType.clear;
	_cmbType.CMUI_ComboLogType.setObjectAndGrade(null,null);
	_cmbTreat.clear;
	_cmbTreat.CMUI_ComboLogTreatment.setObjectAndGrade(null,null);
	_cmbLength.clear();
	_cmbLength.CMUI_ComboLogLength.setObjectAndGrade(null,null);


	_tbl.setValueByName(ETRow_Species, null);
	_tbl.setValueByName(ETRow_Length, null);
	_tbl.setValueByName(ETRow_Grade, null);
	_tbl.setValueByName(ETRow_Treatment, null);
	_tbl.setValueByName(ETRow_Type, null);

	if _operator &lt;&gt; null then
		self.allCodes.clear;
		tempCodes := _operator.getAllLogSpecies();
		if tempCodes &lt;&gt; null then
			tempCodes.copy(self.allCodes);
			_cmbSpecies.CMUI_ComboLogSpecies.setObjectAndOperator(null,_operator);			
//			self.myAssistant.comboBoxGeneral(_cmbSpecies, allCodes);
		endif;
	endif;
end;</source>
