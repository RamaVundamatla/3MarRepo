    <JadeMethod name="showLogDataDef" id="7bdc24bb-1d4c-435e-9f6c-44f72fc760ac">
        <source>showLogDataDef(_obj : CM_Object; _sheetNum : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl			: CM_DataTable;
	tmpColor,
	idx			: Integer;
	str			: String;
	tmpHeadings	: StringArray;
	tmpData		: HugeStringArray;
	theDef		: EntTableDef;

begin
	if _sheetNum &lt;&gt; 2 then
		// if this happens then add a tblView form to the appropriate sheet.
		// done like this to avoid the requirement to add unncessary controls to the form
		app.raiseUnexpectedProgramError(class.name, method.name, 'Need to add tblViewX to sheet ' &amp; idx.String);
		return;
	endif;

	create tmpHeadings transient;
	create tmpData transient;
	
	theDef := app.myController.getEntTableDef(ETDef_LogData);

	_obj.getDataForDef(theDef, tmpHeadings, tmpData, self.myTerminal);

	tbl := self.tblView2;

	tbl.rows := 0;
	tbl.fixedRows := 1;
	tbl.columns := 8;
	tbl.fixedColumns := 0;
	tbl.scrollBars := Table.ScrollBars_Both;
	//par 15462
	tbl.selectMode :=Table.SelectMode_CurrentRow;
	
	tbl.addItemAt('Ticket' &amp; Tab &amp; 'Min' &amp; Tab &amp; 'Max' &amp; Tab &amp; 'Mean' &amp; Tab &amp; 'Volume' &amp; Tab &amp; 'Scaler' &amp; Tab &amp; 'Location' &amp; Tab &amp; 'Scaled',1);

	tbl.removeItem(2);  // to delete extra empty row that gets put in. (might be better way to add header row? HJG 05/04/05
						//	so colouring in here can lead to all rows being same colour
	foreach str in tmpData do
		idx := tbl.addItem(str);
	endforeach;
	
	if self.columnTblView2 &gt; 0 then 				// value set from XML
		tbl.sortAscending := self.sortAscendingTblView2;	
		tbl.resortTableByColumn(self.columnTblView2);
	else 
		tbl.sortAscending := true;					// default sort column ref: Par 9917
		tbl.resortTableByColumn(8);
	endif;
	
	tbl.colourRows(self.colorRow1,self.colorRow2);  // recolour after all added HJG
	
	tbl.visible := true;
	tblEdit2.visible := false;
	

	
		
	
epilog
	delete tmpHeadings;
	delete tmpData;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_sheetNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showNumRowsShown" id="c6c77138-a46c-4b88-a299-9322c731c7f3">
        <updating/>
        <source>showNumRowsShown() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2021	navndl1	Initial creation	TFS 51648

*/

vars

begin

	inheritMethod();  // sets up the default data
	
	self.staMain.caption := self.staMain.caption &amp; "          " &amp; app.getErrorString1 (Num_Rows_Selected, self.tblData.allSelectedObjects.size.String);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showOnboardCargo" id="098819a0-57f4-4b79-988c-e21e6a5fe845">
        <source>showOnboardCargo(_tbl : CM_EntryTable input; _mode : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     08 May 2008 cnwer1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	objArray			: CM_TIArray;
	masterTI,
	currentTI,
	ti 					: CM_TrackedItem;
	currentTILC 		: CM_TILC;
	lc 					: CM_LocationsController;

begin
	if _tbl = null then
		return;
	endif;
	
	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	currentTI := self.myCurrentObject.CM_TrackedItem;
	
	if not currentTI.isKindOf(CM_TILC) then
		return;
	endif;
	
	currentTILC:=currentTI.CM_TILC;
	
	
	create objArray transient;
	
	foreach lc in currentTILC.allLCs discreteLock do
		if _mode = REAL_MODE then
			foreach ti in lc.allTrackedItems do
				objArray.add(ti);
			endforeach;
		elseif _mode = QUEUE_MODE then
			 lc.getAllQueuedTrackedItems(objArray,false);
		elseif _mode = PLANNING_MODE then
			 lc.getAllPlannedTrackedItems(objArray,false,false);
		endif;
	endforeach;
	
	masterTI := objArray.first.CM_TrackedItem; //jlier1 TFS 54700 15/9/22
	self.myAssistant.showCargoEnquiryForTIs(masterTI, objArray, self.myMasterMenuAction, false);
epilog
	delete  objArray; //epr leaking transient
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showOnlyFreightForwarder" id="899239dd-6e80-4896-8a96-069987c71260">
        <updating/>
        <source>showOnlyFreightForwarder(	_obj 		: CM_Object;
							_numDefs : Integer io) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2007	cnwer1	Initial creation - PAR#xxxx
CCMS 1776 user-defined cargo layout does not affect this case - still use the ent table definitions as before

*/
vars
	entRowArray		: EntTableRowArray;
	maxHeadingWidth	: Integer;
	entDef			: EntTableDef;
	tbl				: CM_EntryTable;
	entRow 			: EntTableRow;
	
begin
	tbl	:=	self.tblAlpha;
	create entRowArray transient;

	entDef	:=	app.myController.getEntTableDef(ETDef_DefaultCargoEnt);
	entRow	:=	entDef.myEntTableGroup.allEntTableRowsByName[ETRow_FreightForwarderCode];
	entRowArray.add(entRow);
	
	// PAR 17823
	entRow	:=	entDef.myEntTableGroup.allEntTableRowsByName[ETRow_BookingReference];

	// PAR 18219 - 
	entRowArray.add(entRow);
	
	self.setTableForObject(tbl, entRowArray, _obj, 'Freight Forwarder', true, maxHeadingWidth);
	self.shtEdit1.caption	:=	'Freight Forwarder';
	self.shtEdit1.visible	:=	true;
	_numDefs	:=	1;	//this will hide all the other sheets/tables later on
	
	tbl.accessColumn(CM_EntryTable.ColumnHeading).width	:=	maxHeadingWidth;
	tbl.optimiseHeadingColumn();
epilog
	delete entRowArray;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_numDefs" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showParentBOL" id="99180ab3-6a88-4d18-a6be-5b82c803b77a">
        <source>showParentBOL(_tbl : CM_EntryTable input; _entRowName : String) protected;
// ---------------------------------------------------------------------------
// Created:     26 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bol			: CM_BOL;
	objArray			: ObjectArray;
begin
	if _tbl = null then
		return;
	endif;

	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	bol := self.myCurrentObject.CM_TrackedItem.myReceivalBOL;
	if bol = null then
		app.msgBox('This tracked item has no receival bill of lading','No receival bill Of lading', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	create objArray transient;
	objArray.add(bol);
	self.myAssistant.showCargoEnquiryForBOLs(bol, objArray, self.myMasterMenuAction, false);


epilog
	delete objArray;				
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showParentTI" id="064ef8a1-dee7-42ff-88bc-bc7abe365002">
        <source>showParentTI(_tbl : CM_EntryTable input; _entRowName : String) protected;
// ---------------------------------------------------------------------------
// Created:     26 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	parentTI			: CM_TrackedItem;
begin
	if _tbl = null then
		return;
	endif;

	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	parentTI := self.myCurrentObject.CM_TrackedItem.myParent;
	if parentTI = null then
		app.msgBox('This tracked item has no parent','No parent', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.myAssistant.showCargoEnquiryForm(parentTI, self.myMasterMenuAction, true, false);
					
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showSelector" id="c75ade83-31f6-42b1-83e9-ed5cc6b91b74">
        <updating/>
        <source>showSelector() protected, updating;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	frm					: CMUI_Selector;
	cargoType 			: CM_CargoType;
begin
	frm := app.getSelectorForm(self, self.myMasterMenuAction);

	if frm = null then
		return;
	endif; 
	
	frm.myEnquiryCollectionClass := CM_ObjectSet;
	frm.myTerminal := self.myTerminal;	
	
	if self.cmbSelector.getCurrentItemObject = null then
		//+cnwml2 PAR25111
		//set the mode of the selector to the default Cargo Type of the Terminal
		cargoType := app.myRoot.allCargoTypesById[self.myTerminal.defaultCargoType];
		if cargoType.id = TI_CargoType_Container then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, cargoType.id];
		elseif cargoType.id = TI_CargoType_Log then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 9];
		elseif cargoType.id = TI_CargoType_Generator then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 4];
		elseif cargoType.id = TI_CargoType_COU then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 2];
		elseif cargoType.id = TI_CargoType_Timber then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 6];
		elseif cargoType.id = TI_CargoType_LCL then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 8];
		elseif cargoType.isBreakBulk() then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 3];		// TI_CargoType_BreakBulk
		elseif cargoType.productType = ProductType_Trailer then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 10];		// TI_CargoType_Chassis
		elseif cargoType.productType = ProductType_Vehicle then
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 7];		// TI_CargoType_Car
		else
			frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];
		endif;

		frm.defaultSiteStr := TI_SITE_ONSITE_str;
	endif;
	frm.show;
	//epr TFS 47132 18/12/19
	frm.showQuery(self.cmbSelector.getCurrentItemObject.CM_MenuUserQuery);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showStopsForm_BOL" id="c40bf3af-4fe1-4326-815c-d35c17eeb391">
        <source>showStopsForm_BOL()protected;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	frm		: CMUI_StopsForm_BOL;
	realBOL	: CM_BOLIn;
	coll	:CM_ObjectSet;
	obj		: Object;
begin
	if (not CM_BOLIn.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	realBOL	:= self.myCurrentObject.CM_BOLIn;
	
	create coll transient;
	
	foreach obj in self.tblData.allSelectedObjects do
		if CM_BOLIn.hasInstance(obj) then
			coll.add(obj.CM_BOLIn);
		endif;
	endforeach;
	if not coll.includes(realBOL) then
		coll.add(realBOL);
	endif;
		
	self.myAssistant.showStopsForm_BOL (realBOL, coll, self.mode &lt;&gt; Mode_Update and self.canUpdate);	
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showStopsForm_TI" id="993042d5-129b-4ac2-8378-9331ccef2732">
        <source>showStopsForm_TI()protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	tbl					: CM_EntryTable;
//	frm					: CMUI_StopsForm_TI;
//	menuAction 			: CMUI_MenuAction;
	realTI				: CM_TrackedItem;
begin
	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	realTI	:= self.myCurrentObject.CM_TrackedItem;
	
	//self.myAssistant.showStopsForm_TI (realTI, self.tblData.allSelectedObjects, self.mode &lt;&gt; Mode_Update and self.canUpdate);	
	self.myAssistant.showStopsForm_TI (realTI, self.tblData.allSelectedObjects, self.mode &lt;&gt; Mode_Update and app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showStorageExpLoadDetails" id="f3e550db-d35a-42d2-9ab1-b10788c948fd">
        <source>showStorageExpLoadDetails(_obj : CM_Object; _sheet : CMUI_Sheet );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 September 2023 	CR 58250 Task 58253: UI - Cargo Enquiry New Sheet
11 December 2024	jlizm1	MTN 33442 Mafi load details column organiser not saved
*/

vars
	tbl			: CM_DataTable;
	ti          : CM_TrackedItem;
	theDef		: EntTableDef;
	
begin
	if not _obj.isKindOf(CM_TrackedItem) then
		return;
	endif;
	theDef := app.myController.getEntTableDef(ETDef_StorageExpDetails);
	tbl := self.tblView2;
	
	if tbl.myEntTableDef = null or tbl.myEntTableDef &lt;&gt; theDef then
		if self.xmlStrTblView2 &lt;&gt; null then
			tbl.setTblDataEntRowsArray(theDef, null, self.xmlStrTblView2);
		else
			tbl.setTblDataEntRowsFromDefUser(theDef, true);
		endif;
	endif;
	
	//tbl.parent:=self.shtEdit8;
	tbl.parent := _sheet;
	tbl.selectionType := tbl.SelectionType_Row;
	tbl.scrollBars := Table.ScrollBars_Both;
	tbl.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	ti := _obj.CM_TrackedItem;
	self.loadStorageExpDetailsTable(ti);
	
	tbl.visible := true;
	self.tblEdit8.visible:=false;
	

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_sheet" type="CMUI_Sheet"/>
    </JadeMethod>
    <JadeMethod name="showTILCLoadDetails" id="df956ad8-87a0-44d4-a511-a0c6122511d4">
        <source>showTILCLoadDetails(_obj : CM_Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2022	jlier1	Initial creation 54700
14/04/2023	navkc1	CR 57036 Task 57590 - UI - Cargo Enquiry Create New Cargo
11/12/2024	jlizm1	MTN 33442 Mafi load details column organiser not saved
*/

vars
	tbl			: CM_DataTable;
	tilc		: CM_TILC;

	theDef		: EntTableDef;
	
begin
	if (not CM_TILC.hasInstance(_obj)) then
		return;
	endif;
	tilc := _obj.CM_TILC;
	// 14/04/2023	navkc1	CR 57036 Task 57590 - Use the default cargo enquiry entdef
	theDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	tbl := self.tblView2;
	
	// 14/04/2023	navkc1	CR 57036 Task 57589 - Prevent setting entdef everytime user click on a mafi
	if tbl.myEntTableDef = null or tbl.myEntTableDef &lt;&gt; theDef then
	
		if self.xmlStrTblView2 &lt;&gt; null then
			tbl.setTblDataEntRowsArray(theDef, null, self.xmlStrTblView2);
		else
			tbl.setTblDataEntRowsFromDefUser(theDef, true);
		endif;
	endif;
	
	tbl.parent:=self.shtEdit3;
	tbl.selectionType := tbl.SelectionType_Row;
	tbl.scrollBars := Table.ScrollBars_Both;
	
	// 14/04/2023	navkc1	CR 57036 Task 57589
	tbl.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	self.loadTILCLoadDetailsTable(tilc);
	
	tbl.visible := true;
	self.tblEdit3.visible:=false;
	

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showTableAlphabetised" id="f97846c1-512c-4fdb-9fa1-d3d90c03d328">
        <updating/>
        <source>showTableAlphabetised() protected, updating;
// ---------------------------------------------------------------------------
// Created:     21 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin

	//03 Jun 2015	NDL	Par 36338
	if self.myDataClass = CM_CargoGroup then
		app.msgBox(app.getErrorString(CM_ContainerEnq_Cant_Alpha), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.isShowingAlphabetised := true;
	self.mnuShowAlphabetised.translateCaption_Unconditional( Xlat_0009090, app.myCurrentLocale ); //.caption := 'Show Categorically';
	self.tblAlpha.visible := true;
	self.showThumbnailData(self.myCurrentObject.CM_Object);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTableCategorically" id="40d0ffe4-b352-4bdf-99ff-7ba3807dc3ae">
        <updating/>
        <source>showTableCategorically() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
	self.mnuShowAlphabetised.translateCaption_Unconditional( Xlat_0008343, app.myCurrentLocale );  //.caption := 'Show Alphabetised';
	self.isShowingAlphabetised := false;
	self.tblAlpha.visible := false;
	self.showThumbnailData(self.myCurrentObject.CM_Object);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnailAlphbetised" id="73c776d2-5980-4cf2-a1ab-2817aeb2087f">
        <updating/>
        <source>showThumbnailAlphbetised(_numDefs 	: Integer io; 
						_obj 		: CM_Object; 
						_isForEdit 	: Boolean) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
29/07/2022	 navkc1		 Bug 54197: MTN - Bulk edit of offsite or onship cargo results in changing other fields
----------   ----------  --------------------------------------------------
*/
vars
	rowDynaDict		: DynaDictionary;
	entRowArray		: EntTableRowArray;
	oa				: ObjectArray;
	maxHeadingWidth	: Integer;
	tbl				: CM_EntryTable;
	displayObject	: CM_Object;
begin
	//collect up all the rows from all the defs, then populate the single alpha table
	//N.B can't overcome anomalies with use of Jade table sort to do this hence the 
	//use of a dynaDict
	create rowDynaDict transient;
	create entRowArray transient;
	// 35199 move the sort out to include cargo type/sub-type display names
	self.doAlphaSort(_obj, rowDynaDict);
	
	// 29/07/2022	navkc1	#54197  --&gt;
	//Align with showThumbnailDataForSheet() to display proxy object in Edit mode
	if _isForEdit then
		displayObject := self.myProxyObject;
	else
		displayObject := self.myCurrentObject.CM_Object;
	endif;	
	// &lt;--- 29/07/2022	navkc1	#54197
	
	tbl := self.tblAlpha;
	rowDynaDict.copy(entRowArray);
	//self.setTableForObject(tbl, entRowArray, _obj, 'Alphabetised definition', _isForEdit, maxHeadingWidth);			// 29/07/2022	navkc1	#54197
	self.setTableForObject(tbl, entRowArray, displayObject, 'Alphabetised definition', _isForEdit, maxHeadingWidth);	// 29/07/2022	navkc1	#54197
	self.shtEdit1.caption := 'Alphabetised Data';
	self.shtEdit1.visible := true;
	_numDefs := 1;		// this will hide all the other sheets/tables later on
	tbl.accessColumn(CM_EntryTable.ColumnHeading).width := maxHeadingWidth;
	tbl.optimiseHeadingColumn();
	
epilog
	delete rowDynaDict;
	delete entRowArray;
	delete oa;
end;</source>
        <access>protected</access>
        <Parameter name="_numDefs" type="Integer" usage="io"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_isForEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="596114ef-bda8-40ef-aa49-2b1ce729d35c">
        <updating/>
        <source>showThumbnailData(_obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2001 by cnwrs2
//
// Purpose:     
//
// Updated		06 MAR
// ---------------------------------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 - add Reefer Ent Def to allow non-container reefer maintenance
// 16/02/2010	cnwmh5		PAR 22310 - Add test for storage to btnTranship.enabled
// 29/03/2010	cnwdap1		PAR #23224 If not a container, check commodity to see if it has temperature - further check on whether to show Reefer tab
// 15/06/2010	cnwcs5		par 24342 - no longer using CMUI_StopsListTable

vars
	theTI		: CM_TrackedItem;
	theBOL		: CM_BOL;
	cbType		: CM_CargoBOLType;
	ucTab		: CM_UserConfigTab;
	tmpDefArray	: StringArray;
	idx,
	maxHeadingWidth,
	numDefs		: Integer;
	capStr		: String;
	ls			: Boolean;
	sheet		: CMUI_Sheet;
	entDef		: EntTableDef;
	tbl			: CM_EntryTable;
	infoText	: String;
	infoHeight	: Integer;
	infoCell	: JadeTableCell;
	topTblHeight	: Real;
	reefer		: Boolean;
	commodity	: CM_Commodity;		// PAR #23224
	invalidObj : Boolean;
	createdTime		: TimeStamp;
	columnWidth : Integer;
begin
	//app.myPassport.myActivityCapture.startCaptureDebugMisc('Container Enq showThumbnailData');
	if self.mode = self.Mode_Update then
		if not self.amInitialisingWithObject and
		   not self.amInitialisingInEditMode then
			return;	//the tops sheets tbl will be initialized and data displayed from the setControlsForAddEdit&gt;&gt;showThumbnailForSheet
		endif;
	endif;
	
	//self.btnMoveIt.enabled := false;		//cnwmc5 - 5 March 2014 - PAR 33608
	self.btnMoveIt.enabled := true;			//cnwmc5 - 5 March 2014 - PAR 33608
	
	//cnwjo3 par 23635
	if _obj &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,_obj,invalidObj);
		createdTime := _obj.createdTime;  //this should throw exception to identify if object is invalid
	endif;
	
	if invalidObj or _obj = null then
		return;
	endif;

	
	if CM_TrackedItem.hasInstance(_obj) then
		theTI := _obj.CM_TrackedItem;
		// PAR #23224 Does the commodity require temperature?
		commodity := app.myRoot.allCommodities[theTI.commodity];
		// CCMS 1007 does the tracked item's subcargo type allow reefer details?
		if not theTI.isContainer and (theTI.isReefer or (commodity &lt;&gt; null and commodity.hasTemp)) then
			reefer := true;
		endif;
	elseif CM_BOL.hasInstance(_obj) then
		theBOL := _obj.CM_BOL;
	endif;

	if theTI &lt;&gt; null then
		if capStr = null then
			capStr := theTI.id;
		endif;
	endif;
	
	if self.useTxtThumb then
		// further changes for header text
		if self.filterTerminalArea &lt;&gt; null then
			self.txtHeader.text := self.staMain.caption &amp; '; ' &amp; self.filterTerminalArea.getTextHeader();
		endif;

		if theTI &lt;&gt; null then
			txtThumbnail.text := theTI.getInfoStr(true);
		elseif theBOL &lt;&gt; null then
			txtThumbnail.text := 'BOL ' &amp; theBOL.number;
		endif;
		// ==== RETURN =====
		return;
	endif;

	cbType := self.getCargoBOLTypeOfObject(_obj);

	if cbType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CargoType is null for ' &amp; _obj.String);
		return;
	endif;

	self.setEditEnabledDisabled(cbType.id);
	
	if theTI &lt;&gt; null then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		self.btnTranship.enabled := (not theTI.isTranshipItem and not theTI.isExport and not theTI.isStorage); // 16/02/2010 cnwmh5 #22310
		
	endif;
	
	// CCMS 1776 user-defined cargo config
	if self.myUserCargoType &lt;&gt; null then
		if self.myUserCargoType.myCargoBOLType &lt;&gt; cbType then
			delete self.myUserCargoType;
			delete self.myReeferCargoType;
			self.myUserCargoType := app.myPassport.myUser.getUserCargoType(cbType, false);
			self.myReeferCargoType := app.myPassport.myUser.getUserCargoTypeReefer(self.myUserCargoType);
		// 28374 Nov 2011 if Logs edit table showing (only 5 attributes) then refresh it to enquiry table
		elseif cbType.id = TI_CargoType_Log and
		   self.myUserCargoType.allUserConfigTabs.first.allAttributes.size &lt; 10 then
			self.myUserCargoType := null;
		endif;
	endif;
	if self.myUserCargoType = null then
		self.myUserCargoType := app.myPassport.myUser.getUserCargoType(cbType, false);
		self.myReeferCargoType := app.myPassport.myUser.getUserCargoTypeReefer(self.myUserCargoType);
	endif;
	self.isReeferTabVisible := false;
	
	numDefs := self.myUserCargoType.allUserConfigTabs.size;
	// CCMS 1007 add Reefer definition 
	if reefer and self.myReeferCargoType &lt;&gt; null and
	   numDefs &lt; self.NUMBER_OF_SHEETS then
		numDefs := numDefs + 1;
		self.isReeferTabVisible := true;
	endif;
	self.numberOfSheets := numDefs;

	if self.mode = self.Mode_Update then
		if self.amInitialisingWithObject or
		   self.amInitialisingInEditMode then
			return;		// have set up enough for the edit now
		endif;
	endif;

	self.allEntryTableDefs.clear();
	self.allInitializedSheets.clear();
	
	app.cmsBeginLoad(ls);
	_obj.shareLockSelfAndChildren();
	
	entDef := tblInputTop.myEntTableDef;
	
	//epr TFS 47132 14/11/19 
	self.tblInputTop.visible		:= true;
	self.tblInputTop.clearValues();
	self.tblInputTop.setTableFromCM_Object(_obj,null);
	
	//always pass through true for isForEdit for this table- this will just enable user to copy and paste item ID
	// epr TFS 47132 when setting the 3 row heading table would do all the stuff it would normally do for the larger thumbnail
	//self.setTableForObject(tblInputTop, entDef.allEntTableRows, _obj, entDef.name, true, maxHeadingWidth);
	
	//PAR 6158
	self.tblInputTop.enableRowByName(ETRow_TopID);
	self.txtID.readOnly := true;
	//+cnwml2 PAR21056
	if self.mode = self.Mode_Update or self.mode = self.Mode_Update_CargoType then
		self.tblInputTop.enableRowByName(ETRow_CargoTypeEntry);
	else
		self.tblInputTop.disableRowByName(ETRow_CargoTypeEntry);
	endif;
		
	if self.standardRowHeight = 0 then
		self.standardRowHeight := self.tblInputTop.accessRow(1).height + 1;
	endif;
	
	infoText := self.tblInputTop.getValueByName(ETRow_Info).String;
	
	if infoText &lt;&gt; null then
		infoCell := self.tblInputTop.accessedCell;
		infoCell.backColor := Red;
		infoCell.foreColor := White;
		infoCell.wordWrap := true;
	//	infoHeight := self.tblInputTop.getTextHeightForWidth(infoText, self.tblInputTop.accessColumn(self.tblInputTop.ColumnValue).width - 18).Integer + 10; 	// add fudge factor
		columnWidth := self.tblInputTop.accessColumn(self.tblInputTop.ColumnValue).width;	//03 Mar 2015	NDL	Par 35733
		infoHeight := self.tblInputTop.getTextHeightForWidth(infoText, columnWidth).Integer + 10; 	// add fudge factor
		self.tblInputTop.accessedRow.height := infoHeight;
		topTblHeight := (self.standardRowHeight * 2) + infoHeight;
	else
		self.tblInputTop.accessedCell.backColor := CM_EntryTable.ReadOnlyRowColour;
		// set height back incase it has changed
		self.tblInputTop.accessedRow.height := self.standardRowHeight;
		topTblHeight := (self.standardRowHeight * 3);
	endif;

	self.tblInputTop.height := topTblHeight;
	self.sptThumbEdit.setLeftToRightSizeAndResize(topTblHeight.Integer + 4);
	
	if self.filterTerminalArea &lt;&gt; null then
		capStr := self.filterTerminalArea.id;
	endif;

	if capStr = null and theBOL &lt;&gt; null then
		self.setCaption(theBOL.number);
	else
		self.setCaption(capStr);
	endif;

	//show sheets for number of defs
	if self.isShowingAlphabetised then
		self.showThumbnailAlphbetised(numDefs, _obj, false);
		self.tblEdit1.visible	:=	false;
	else
		self.tblAlpha.visible	:=	false;
		idx := 0;
		foreach ucTab in self.myUserCargoType.allUserConfigTabs do
			idx := idx + 1;
			sheet := self.getEditSheetForIndex(idx);
			if ucTab.name = ETDef_TranshipData and theTI &lt;&gt; null  and not theTI.isTranshipItem then
				sheet.visible := false;
				continue;
			endif;
			sheet.caption := ucTab.description;
			//jlier1 TFS 54700 -1/9/22
			if ucTab.name = ETDef_TrailorData and theTI &lt;&gt; null then
				sheet.caption:=theTI.myCargoType.description &amp; Space &amp; app.getErrorString(CM_Details);
			elseif ucTab.name = ETDef_TILCLoadDetails and theTI &lt;&gt; null then
				sheet.caption:=theTI.myCargoType.description &amp; Space &amp; app.getErrorString(Load_details);
			endif;
			sheet.visible := true;
		endforeach;
		if self.isReeferTabVisible then
			foreach ucTab in self.myReeferCargoType.allUserConfigTabs do	// only one tab
				idx := idx + 1;
				sheet := self.getEditSheetForIndex(idx);
				sheet.caption := ucTab.description;
				sheet.visible := true;
			endforeach;
		endif;
	endif;
	self.showThumbnailDataForSheet(self.fldEdit.topSheet.CMUI_Sheet, false);

	if numDefs &lt; self.NUMBER_OF_SHEETS then
		// hide any other sheets
		foreach idx in (numDefs + 1) to self.NUMBER_OF_SHEETS do
			sheet := self.getEditSheetForIndex(idx);
			sheet.visible := false;
			tbl := self.getEditTableForIndex(idx);
			tbl.clear();
			tbl.allEntRowTransients.purge();
			tbl.rows := tbl.fixedRows;
			tbl.setMyEntTableDef(null);
		endforeach;	
	endif;
	
	
	if theTI &lt;&gt; null and theTI.myCargoType.useTareCargoWeight then									//+cnwml2 MSL CCMS 1017
		self.tblEdit1.showRowByName(ETRow_TareWeight, false);
		self.tblData.showColumnByColName(ETRow_TareWeight);
		self.tblEdit1.showRowByName(ETRow_CargoWeight, false);
		self.tblData.showColumnByColName(ETRow_CargoWeight);
	else
		self.tblEdit1.hideRowByName(ETRow_TareWeight, false);
		self.tblData.hideColumnByColName(ETRow_TareWeight);
		self.tblEdit1.hideRowByName(ETRow_CargoWeight, false);
		self.tblData.hideColumnByColName(ETRow_CargoWeight);
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint)
	and not self.canChangeFreightForwarder()	//25 July 2018	NDL	TFS 39579
	then
		self.mnuCargo.enabled := false;
		self.btnTranship.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnEditTV.enabled:= false;
	endif;
epilog
	app.cmsEndLoad(ls);	
	delete tmpDefArray;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailDataForSheet" id="0817179f-7085-472a-8576-f1e2d10d463c">
        <updating/>
        <source>showThumbnailDataForSheet(_sheet : CMUI_Sheet input; _printing : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 17/06/2010	cnwcs5	par 24342 - adjust heading for stops row depending on whether we 
//						are viewing or updating the tracked item
// 14/04/2023	navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
// 10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet
vars
	maxHeadingWidth,
	idx			: Integer;

	ucTab		: CM_UserConfigTab;
	ucAttr		: CM_UserConfigAttribute;
	editTable,
	tbl			: CM_EntryTable;
	isForEdit	: Boolean;
	displayObject : CM_Object; //cnwrd 25.5.09 ccms  - form updated from real object on edti instead of proxy, this needed to change
	entRows		: EntTableRowArray;
	entDef 		: EntTableDef;
begin
	
	if _sheet = null then
		return;
	endif;
	
	isForEdit := (self.mode = self.Mode_Update);

	idx := self.getIndexForEditSheet(_sheet);
	if self.allInitializedSheets.includes(idx) then
		return;
	endif;
	
	if idx &lt; 1 or idx &gt; self.numberOfSheets then
		return;
	endif;
	
	if isForEdit then //cnwrd 25.5.09 ccms
		displayObject :=  self.myProxyObject;
	else
		displayObject :=  self.myCurrentObject.CM_Object;
	endif;
	
	 //03 Jun 2015	NDL	Par 36338
	 if displayObject &lt;&gt; null and displayObject.isKindOf(CM_CargoGroup) then
		entDef := app.myController.getEntTableDef(ETDef_CargoGroupData);
		if entDef &lt;&gt; null then
			self.shtEdit2.visible := false;
			self.shtEdit3.visible := false;
			self.shtEdit4.visible := false;
			self.shtEdit5.visible := false;
			self.setTableForObject(self.tblEdit1, entDef.allEntTableRows, displayObject, app.getErrorString(Cargo_group), isForEdit, maxHeadingWidth); 
			return;
		endif;
    endif;
	
	if idx &lt;= self.myUserCargoType.allUserConfigTabs.size then
		ucTab := self.myUserCargoType.allUserConfigTabs[idx];
	else
		ucTab := self.myReeferCargoType.allUserConfigTabs[1];	// single reefer table so single tab
	endif;
	create entRows transient;
	foreach ucAttr in ucTab.allAttributes do
		entRows.add(ucAttr.myEntTableRow);
	endforeach;
	tbl := self.getEditTableForIndex(idx);
	// Logs and General Dockets show a special table on sheet 2 - this still works as before with
	//   the user-configurable changes for CCMS 1776, as these two cases are not included as user-configurable
	//jlier1 TFS 54700 15/9/22
	self.tblView2.parent:=self.shtEdit2;
	self.tblView2.visible:=false;
	self.tblEdit3.visible:=true;
	
	// 14/04/2023	navkc1	CR 57036 Task 57589
	//if ucTab.name &lt;&gt; ETDef_TILCLoadDetails then //10 September 2023 CR 58250 Task 58253:
	if ucTab.name &lt;&gt; ETDef_TILCLoadDetails or  ucTab.name &lt;&gt; ETDef_StorageExpDetails then //10 September 2023 CR 58250 Task 58253:
		self.tblView2.setMyEntTableDef(null);
	endif;
	self.endNotificationForSubscriber(tblView2);
	self.allMAFIOnboardNotify.clear();
	
	if ucTab.name = ETDef_LogData and 
	   self.myCurrentCargoBOLType.id = BOLType_Log and
	   (fldEdit.topSheet = _sheet or _printing) then
		self.showLogDataDef(displayObject, idx);	 //cnwrd 25.5.09 ccms ++
		return; // ### TFS BUG 58170 07JUN2023 NAVAB1
	elseif ucTab.name = ETDef_GeneralDocketAttach and
	   self.myCurrentCargoBOLType.id = BOLType_GeneralBillOfLading and
	   (fldEdit.topSheet = _sheet or _printing) then
		self.showGeneralCargoAttachments(displayObject, idx);//cnwrd 25.5.09 ccms ++
		// ** this is still subject to review **
	elseif ucTab.description = ETDef_GeneralData  then
		tbl := self.getEditTableForIndex(idx);
		self.setTableForObject(tbl, entRows, self.myCurrentObject.CM_Object, ucTab.description, isForEdit, maxHeadingWidth);
	elseif ucTab.name = ETDef_TILCLoadDetails and //jlier1 TFS 54700 15/9/22
	   (fldEdit.topSheet = _sheet) then
		
		self.showTILCLoadDetails(displayObject);
		_sheet.cnEcResizeContents();
		return;
	//10 September 2023 CR 58250 Task 58253 - start
	elseif ucTab.name = ETDef_StorageExpDetails and
	   (fldEdit.topSheet = _sheet) then
		
		self.showStorageExpLoadDetails(displayObject,_sheet);
		_sheet.cnEcResizeContents();
		return;
	//10 September 2023 CR 58250 Task 58253: - end
	else	
		if idx = 2 then
			// specific stuff for sheet 2, used for log data and general cargo attachments
			tblView2.visible := false;
			tblEdit2.visible := true;
			
		endif;
		
		tbl := self.getEditTableForIndex(idx);
		self.setTableForObject(tbl, entRows, displayObject, ucTab.description, isForEdit, maxHeadingWidth); 	 //cnwrd 25.5.09 ccms ++

	endif;
	// need to resize sheets as show/hide of sheets
	// can change the height of the sheets depending
	// on how many rows of tabs end up at the top of
	// the folder
	editTable := self.getTableForRow(ETRow_MyTranshipToPort);
	if displayObject &lt;&gt; null and 
		displayObject.isKindOf(CM_TrackedItem) and 
		displayObject.CM_TrackedItem.isExport and self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then//cnwas3 par 21749
		if editTable &lt;&gt; null and not (self.isHideThumbnailEmtpy and self.mode =  Mode_View)  then
			editTable.showRowByName(ETRow_MyTranshipToPort, false);
		endif;
		self.tblData.showColumnByColName(ETRow_MyTranshipToPort);
		self.tblAlpha.showRowByName(ETRow_MyTranshipToPort, false);
	else
		if editTable &lt;&gt; null then
			editTable.hideRowByName(ETRow_MyTranshipToPort, false);
		endif;
		self.tblData.hideColumnByColName(ETRow_MyTranshipToPort);
		self.tblAlpha.hideRowByName(ETRow_MyTranshipToPort, false);
	endif;
	// par 24342 - if we are update mode the user cannot maintain stops so we change
	// the heading in the table to 'Stops' without the double click on  it.
	if self.mode &lt;&gt; self.Mode_View and
		tbl.getRowByName (ETRow_AllStops) &lt;&gt; null then
		tbl.setHeadingByName (ETRow_AllStops, app.getErrorString (Stops));
	endif;
	
	if self.isShowingAlphabetised then		// 35199 use the correct table for alpha display
		self.setTableForGeneralCargo(displayObject, self.tblAlpha);
	else
		self.setTableForGeneralCargo(displayObject, tbl);
	endif;

	_sheet.cnEcResizeContents();
	tbl.accessColumn(CM_EntryTable.ColumnHeading).width := maxHeadingWidth;
	self.allInitializedSheets.add(idx);
	
epilog
	delete entRows;
end;</source>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
        <Parameter name="_printing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showToDoTasksForm" id="f59922ee-e7ef-42d6-aabe-2e5747741571">
        <updating/>
        <source>showToDoTasksForm() protected, updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	formName			: String;
	tbl					: CM_EntryTable;
	frm					: Form;
	frmTasksToAdd,
//	frmTasksToComplete,
	frmTasksToCompleteSimple,
	frmTasksToCompleteComplex,
	frmTasksToRemove	: IntegerArray;
	menuAction 			: CMUI_MenuAction;
	subSystem			: CMUI_SubSystem;
	assistantClass,
	formClass			: Class;
	idx					: Integer;
	pxyToDoTask			: CM_TiToDoTask;
	toDoTask			: CM_ToDoTask;
	realTI,
	pxyTI				: CM_TrackedItem;
	loadState			: Boolean;
	tiDict				: CM_TIByIdDict;
	queryFilter			: CMQF_TerminalTIs;
	objSelected,
	objProxy			: Object;//added by cnwyl1 22052006 for Par 11791
	int : Integer;	//06 Dec 2012	NDL	Par 30854
begin
	
	if (not CM_TrackedItem.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
//if self.btnEditTV.enabled:= false;
	
	realTI := self.myCurrentObject.CM_TrackedItem;
	pxyTI := self.myProxyObject.CM_TrackedItem;
	
	if (self.mode = Mode_Update) and (not self.hasEditedToDoTasks) then
		self.allTasksToAdd.clear();
		self.allTasksToComplete.clear();
		self.allTasksToRemove.clear();
		
		self.hasEditedToDoTasks := true;
	endif;
	
	//here we are getting a form from a sub schema (Yard schema) using literals
	subSystem := app.myController.allSubSystems['YardSchema'];	
	if subSystem = null then
		return;
	endif;
	
	if self.mode = self.Mode_Update then
		formName := 'YRD_ToDoTasksFormModal';
	else
		formName := 'YRD_ToDoTasksForm';
	endif;
	
	subSystem.getFormDetails(formName, formClass, assistantClass);	
	frm := app.loadForm(formClass, assistantClass, false, false, false, self.myTerminal, menuAction).CM_BaseForm;
	
	if frm = null then
		return;
	endif;
	
	frm.CM_BaseForm.setMyTerminal(self.myTerminal);
	//if not in edit mode, then just update the persistent TI, 
	//it will refresh the ToDo task info automagically	-  JC  Confirmed this behaviour as correct 4/03/2005 - DO NOT use allProxyObjects when in update mode
	if self.mode &lt;&gt; Mode_Update then
		//frm.setPropertyValue('myInitializationTI', realTI);
		queryFilter := frm.getPropertyValue('myTIQueryFilter').CMQF_TerminalTIs;
		self.tblData.allSelectedObjects.copy(queryFilter.allQryTrackedItems);
		if (not queryFilter.allQryTrackedItems.includes(self.myCurrentObject.CM_TrackedItem)) then
			queryFilter.allQryTrackedItems.add(self.myCurrentObject.CM_TrackedItem);
		endif;
		
		frm.show;
		return;
	else
		frm.setPropertyValue('myInitializationTI', pxyTI);//added by cnwyl1 for PAR 11791 22052006
		queryFilter := frm.getPropertyValue('myTIQueryFilter').CMQF_TerminalTIs;
		self.allProxyObjects.copy(queryFilter.allQryTrackedItems);
	endif;
	
	frm.showModal;
	
	if frm.modalResult &lt;&gt; MB_OK then
		return;
	endif;
	
	frmTasksToAdd := frm.getPropertyValue('allTasksToAdd').IntegerArray;
	//frmTasksToComplete := frm.getPropertyValue('allTasksToComplete').IntegerArray;
	//06 Dec 2012	NDL	Par 30854
	frmTasksToCompleteSimple := frm.getPropertyValue('allTasksToCompleteSimple').IntegerArray;
	frmTasksToCompleteComplex := frm.getPropertyValue('allTasksToCompleteComplex').IntegerArray;
	
	frmTasksToRemove := frm.getPropertyValue('allTasksToRemove').IntegerArray;
	
	frmTasksToAdd.copy(self.allTasksToAdd);
	//frmTasksToComplete.copy(self.allTasksToComplete);
	
	//06 Dec 2012	NDL	Par 30854
	if frmTasksToCompleteSimple &lt;&gt; null then
		frmTasksToCompleteSimple.copy(self.allTasksToComplete);
	endif;
	if frmTasksToCompleteComplex &lt;&gt; null then
		foreach int in frmTasksToCompleteComplex do
			self.allTasksToComplete.add(int);
		endforeach;
	endif;
	
	frmTasksToRemove.copy(self.allTasksToRemove);
	
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	tbl.setValueByName(ETRow_ToDoTasks, pxyTI.getDisplayStringForAttribute(ETRow_ToDoTasks, false));
	
epilog
	app.cmsEndLoad(loadState);

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTransactionsEdit" id="9994da0a-cd31-4648-8899-c270d5026424">
        <source>showTransactionsEdit(_tbl : CM_EntryTable input; _entRowName : String) protected;
// ---------------------------------------------------------------------------
// Created:     26 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	transType			: Integer;
	transMaintForm		: CMUI_TITransMaintModal;
	ti					: CM_TrackedItem;	
begin
	if _tbl = null then
		return;
	endif;

	if (not self.mode = Mode_Update) or
		self.doingMultiEdit or
		(self.myCurrentObject = null) or
		(not self.myCurrentObject.isKindOf(CM_TrackedItem)) then
		return;
	endif;

	ti := self.myCurrentObject.CM_TrackedItem;
	
	if _entRowName = ETRow_MoveDT then
		transType := TRANS_TYPE_MOVE;
	elseif _entRowName = ETRow_DamagedDT then
		transType := TRANS_TYPE_DAMAGED;
	elseif _entRowName = ETRow_FirstConnectDT then
		transType := TRANS_TYPE_CONNECT_POWER;
	elseif _entRowName = ETRow_FuelledDT then
		transType := TRANS_TYPE_FUELED;
	elseif _entRowName = ETRow_FumigateDT then
		transType := TRANS_TYPE_FUMIGATE;
	elseif _entRowName = ETRow_InspectDT then
		transType := TRANS_TYPE_INSPECT;		
	elseif _entRowName = ETRow_LastConnectDT then
		transType := TRANS_TYPE_CONNECT_POWER;
	elseif _entRowName = ETRow_PackedDT then
		transType := TRANS_TYPE_PACK;
	elseif _entRowName = ETRow_PreTripDT then
		transType := TRANS_TYPE_PRETRIP;
	elseif _entRowName = ETRow_RepackedDT then
		transType := TRANS_TYPE_REPACK;
	elseif _entRowName = ETRow_RepairDT then
		transType := TRANS_TYPE_REPAIR;
	elseif _entRowName = ETRow_SealDT then
		transType := TRANS_TYPE_SEALED;
	elseif _entRowName = ETRow_SweptDT then
		transType := TRANS_TYPE_SWEEP;
	elseif _entRowName = ETRow_UnpackedDT then
		transType := TRANS_TYPE_UNPACK;
	elseif _entRowName = ETRow_WashDT then
		transType := TRANS_TYPE_WASH;
	elseif _entRowName = ETRow_Transactions then
		transType := TRANS_TYPE_MOVE;//default to move?
	else
		return;
	endif;
	
	if self.allTITxnControllers.isEmpty then
		ti.createTITxnControllers(self.allTITxnControllers);
	endif;
	
	transMaintForm := app.loadForm(CMUI_TITransMaintModal, 
								CMUI_Assistant, 
								false, 
								false,
								false, 
								self.myTerminal,
								null).CMUI_TITransMaintModal;
	//cnwdz2 par 15260
	if transMaintForm = null then
		return;
	endif;
	
	transMaintForm.caption := 'Transactions for ' &amp; ti.id;

	transMaintForm.isForCargoEdit := true;
	self.allTITxnControllers.copy(transMaintForm.allTITxnControllers);
	transMaintForm.myCurrentTrackedItem := ti;
	transMaintForm.myCurrentTransactionType := transType;
	transMaintForm.showModal();
		
	self.allTITxnControllers.clear();
	transMaintForm.allTITxnControllers.copy(self.allTITxnControllers);
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="613a8355-263c-4a74-b449-6b9ccf2eff09">
        <updating/>
        <source>showWithObject(pObj: CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	self.allowExportCSV := false;
	
	
	
	inheritMethod(pObj, _thumbnailOnly, _doEdit);
	
	
	if pObj.isKindOf(CM_TrackedItem) and pObj.CM_TrackedItem.hasBeenMerged then
		self.allowUpdate:=false;
	endif;
	
	self.btnPrintList.enabled 	:= false;
	
	
	if (CM_TrackedItem.hasInstance(pObj)) then
		self.tblSearch.setValueByName(ETRow_FilterId, pObj.CM_TrackedItem.id);
	endif;
	
end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
