    <JadeMethod name="tblDataDisplayRow" id="f9d20846-c88a-476b-b70f-bf71b2e7a7ea">
        <source>tblDataDisplayRow(_history : CM_PackageHistoryHdr);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	count 		: Integer;
	rowHeight 	: Integer;
	str 		: String;
	idx 		: Integer;
	table		: CM_DataTable;
begin
	table	:= self.tblHistory;
	str 	:= _history.getAttributeStringForDefArray(table.allTblDataEntRows);
	idx 	:= table.addItemObject(_history, str);
	
	// CCMS 2120 Nov 2011 expand row if text has carrage returns, from email 
	count := str.countOccurrences(Cr);
	
	if count &gt; 0 then
		rowHeight 					:= table.accessRow(idx).height;
		table.accessedRow.height 	:= rowHeight * (count+1);
	endif;
				
end;</source>
        <Parameter name="_history" type="CM_PackageHistoryHdr"/>
    </JadeMethod>
    <JadeMethod name="tblHistory_contextMenu" id="b7f0c47a-1696-426d-923d-f382f08b709b">
