    <JadeMethod name="setForCreate" id="5bc9220b-a034-4a5d-bdb6-1b4eb242c357">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
21 March 2012	cnwab1	Initial creation
*/

vars
	theCargoLayer : CM_DeckLayerLayout;
begin
	inheritMethod(_proxyDeckItem, _passport);

	
	theCargoLayer := self.myDeck.myDeckLayout.getCargoLayer();
	if theCargoLayer &lt;&gt; null then // PAR 30092
		theCargoLayer.hideContainerPositionsUnderGA(self.myLayout); // PAR 29178
	endif;
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="089a55b6-4281-49d5-ba4b-d1a7f34fcee4">
        <updating/>
        <source>setForUpdate(_proxyGeneralItem: SelfType; _passport: CM_Passport input) updating;
/*
Date		    Who			Reason
16 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	inheritMethod(_proxyGeneralItem,_passport);
	
	self.weight:=_proxyGeneralItem.weight;
	
	if self.myDeck &lt;&gt; null then
		if _proxyGeneralItem.pxyGetRealObject = null then
			self.myDeck.causeEvent(EVENT_DECK_ITEM_CREATE,false,self);
		else
			self.myDeck.causeEvent(EVENT_DECK_ITEM_UPDATE,false,self);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyGeneralItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
