    <JadeMethod name="addLastSeparatorToFilePath" id="cfc5295e-8273-4a83-8d3b-4c910c115acd">
        <source>addLastSeparatorToFilePath() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		28 July 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	fileName 	: String;
	namePos,
	pos,
	fileLength 	: Integer;
begin
	fileName := self;
	fileLength := fileName.length;
	
	if fileName.pos("\", 1) &gt; 0 then
		if not fileName[fileLength] = '\' and
		   not fileName[fileLength] = '/' then
			fileName := fileName &amp; '\';
		endif;
	elseif fileName.pos("/", 1) &gt; 0 then
		if not fileName[fileLength] = '/' and
		   not fileName[fileLength] = '\'then
			fileName := fileName &amp; '/';
		endif;
	endif;
		
	return fileName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="addLine" id="ffcddc88-ca7d-488a-87d8-0224f99187c6">
