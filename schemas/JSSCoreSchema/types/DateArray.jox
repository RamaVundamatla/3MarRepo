<CollClass name="DateArray">
    <JadeMethod name="jssDoSort" id="a500d2b2-19e8-4f62-b1c2-6a698cf3836b">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pSorterObj: JSSSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateValue		: Date;
	sortKeyObj		: Object;

begin
	foreach dateValue in self do
		pSorterObj.addValue(dateValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.mySortColl do
		self.add(sortKeyObj.JSSSortKey.getValue.Date);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
