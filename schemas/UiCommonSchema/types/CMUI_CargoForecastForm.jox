    <JadeMethod name="initTblCargoForecast" id="4b838cfc-c6a0-4820-aa68-56572a88386d">
        <source>initTblCargoForecast(_theEntDef : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblCargoForecast;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_CargoForecast);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblCargoForecast);	
		//self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCargoForecastTable" id="f31e6784-0c5c-4784-be05-cbd6ab1040ed">
        <source>loadCargoForecastTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	proxy	: CM_Object;
	table	: CM_DataTable;
	idx		: Integer;
	item 	: CM_CargoForecast;
begin 
	proxy := self.myObject;
	
	if proxy = null then
		return;
	endif;
	
	table := self.tblCargoForecast;
	
	table.rows := 1;
	table.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	table.multiSelect := CM_BaseTable.MultiSelect_None;
	
	if self.myObject.isKindOf(CM_Voyage) then
		foreach item in proxy.CM_Voyage.allCargoForecasts do
			idx := table.updateItemObject(item, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	else
		foreach item in proxy.CM_Train.allCargoForecasts do
			idx := table.updateItemObject(item, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	endif;
	table.allSelectedObjects.clear; 
	
	//self.loadTotals(proxy);
end;
</source>
    </JadeMethod>
