    <JadeMethod name="initTblFileLine" id="8e2176f2-0419-4ba8-a823-dfb22f108e5f">
        <source>initTblFileLine();
// ---------------------------------------------------------------------------
// Created:		01 August 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.tblFileLine.clear;
	self.tblFileLine.selectMode := CM_BaseTable.SelectMode_Row;
	
	self.tblFileLine.inputType := Table.InputType_TextBox;	
	self.tblFileLine.userInputEnabled := true;
	self.tblFileLine.selectionType := CM_BaseTable.SelectionType_None;
	self.tblFileLine.columns := self.COLUMN_CHANGED; //par17172 cnwrs1 July 2008
	self.tblFileLine.accessColumn(self.COLUMN_DATA).visible := true; //par 17172 cnwrs1 July 2008
	self.tblFileLine.accessColumn(self.COLUMN_CHANGED).visible := false; //par 17172 cnwrs1 July 2008
	self.tblFileLine.fixedRows := 0;
	self.tblFileLine.rows := 0;
//	self.tblFileLine.cnAdjustColumnWidths();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="insertEDITI" id="dfe89ee0-cef8-49f1-99ba-ae3dd78028e3">
        <source>insertEDITI(_tab : Integer);
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18/12/2012	cnwcs5	par 30501 - fix leak, use local varaiables, don't assume ID first thing in table
vars
	table			: CM_DataTable;
	ediData			: CM_EDIData;
	newRow 			: Integer;
	tiClasses		: ClassColl;
	ediTI			: CM_EDITrackedItem;
begin
	table 	:= self.tblEDITI.getControl(_tab);		// par 30501 oct 2012
	newRow 	:= table.row;							// par 30501 oct 2012
	ediData := self.myCurrentObject.CM_EDIData;
	
	if ediData = null then 							// ccms1845 sept 2009 cnwrs1
		return;
	endif;
	
	create tiClasses transient;
	
	ediData.getEDITITypes(tiClasses);
	
	if _tab &gt;= tiClasses.size then
		return;
	endif;
	
	ediTI := app.myTrxCA.trxCreateEDITI(ediData, tiClasses[_tab+1], app.myPassport);

	table.addItemAt(null, newRow);							// par 30501 oct 2012
	
	table.setCellValueByName (ETRow_Id, newRow, ediTI.id);	// par 30501 oct 2012
	table.accessRow(newRow).itemObject := ediTI;			// par 30501 oct 2012
epilog
	delete tiClasses;										// par 30501 oct 2012
end;</source>
        <Parameter name="_tab" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertFileLine" id="cc846182-e7b2-46cb-87ac-280b0b62cc13">
        <source>insertFileLine();
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	newRow 		:Integer;
//	longString 	: CM_LongString;
	text		: String;
	errors : CM_ErrorSet; //par17172 cnwrs1 July 2008
	error : CM_Error;
begin
	newRow := self.tblFileLine.row;		
	/*
	beginTransaction;
		create longString;
		self.myEDIFileInError.messages.insert(newRow,longString);
	commitTransaction;
	*/
	create errors transient; //par17172 cnwrs1 July 2008
	app.myPassport.allErrors.copy(errors);
	foreach error in errors do
		error.setMyErrorPassport(null);
	endforeach;
	app.myTrxCA.trxCreateEDIMessage(self.myEDIFileInError, newRow, text, app.myPassport);
	foreach error in errors do
		error.setMyErrorPassport(app.myPassport);
	endforeach;
	errors.clear;
	
	self.tblFileLine.addItemAt(newRow.String&amp;'i'&amp;Tab&amp;text, newRow); //par17172 cnwrs1 July 2008
//	self.tblFileLine.accessRow(newRow).itemObject := longString;
epilog
	delete errors;
end;</source>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="144edecc-15bc-4fb8-ab43-d9c83cb409c3">
        <source>inspectObject();
//----------------------------------------------------------------
//	Created:	20 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj	: Object;
begin
	obj := self.mnuTblVInspectObject.userObject;
	
	if obj = null then
		inheritMethod();
		return;
	endif;
	
	if CM_EDITrackedItem.hasInstance(obj) then
		obj.inspect;
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="isAnEDITITable" id="8b5f7685-994b-41f7-afb2-5250b443934e">
        <source>isAnEDITITable(_win : Window ) : Boolean;
// ---------------------------------------------------------------------------
// Created:	29 September 2009 By Graeme Black cnwgb1
// Purpose:	Determine if inputted window is (a clone of) self.tblEDITI
// MES 1011 Multiple EDITI types PAR 20320 
// ---------------------------------------------------------------------------
// 18/12/2012	cnwcs5	par 30501 - simplify method
vars
	
begin
	return _win.name = self.tblEDITI.name;
epilog

end;</source>
