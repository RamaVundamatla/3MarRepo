<Class name="CM_SnapshotField_Max" id="f2ea6261-b37b-43bf-be58-e1058b033709">
    <superclass name="CM_SnapshotField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="snapshots"/>
    <PrimAttribute name="max" id="a7a6fb24-6039-4a1e-ba85-64f9a4592fcc">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="aa9ff9e9-0541-46ed-8c8f-6026b3ff8720">
        <source>getValue(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation

*/

vars
	value	:Decimal[23,8];
begin
	value := self.max;		
	
	if value = 0 then		
		return null;		
	endif;					
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);	// cnwcs5 07/12/2009

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXTABFieldFunction" id="9353a1e0-6493-4bbc-876c-f391b88d4781">
        <source>getXTABFieldFunction(): Integer;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 - snapshot summaries  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return CM_XTABField.Function_Max;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromCmifAndXtabFields" id="c31a33ab-dd99-48b2-ba8a-85f2de1713d1">
        <updating/>
        <source>setFromCmifAndXtabFields(_cmifField: CMIF_OutputField; _xtabField: CM_XTABField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	inheritMethod(_cmifField, _xtabField);
	
	self.max := _cmifField.CMIF_OutputField_Max.max;

epilog

end;</source>
        <Parameter name="_cmifField" type="CMIF_OutputField"/>
        <Parameter name="_xtabField" type="CM_XTABField"/>
    </JadeMethod>
</Class>
