    <JadeMethod name="pxyCreateUpdateProxy" id="92e2b563-3650-418a-af2e-658c07f7f92b">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Date			Who		Reason
14 October 2008	cnwrd1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxy	: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3004d904-6507-4e90-90f1-b2834c6ba327">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2008	cnwrd1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
15/05/2025	navcs2	MTN-34844 Development - Portschema Implementation
*/

vars

begin
	inheritMethod(_proxyEDITI);
	
	self.description	:= _proxyEDITI.description;		// PAR21225
	self.coolingType := _proxyEDITI.coolingType ;
	self.extHeight := _proxyEDITI.extHeight ;
	self.extLength := _proxyEDITI.extLength ;
	self.extWidth := _proxyEDITI.extWidth ;
	self.from := _proxyEDITI.from ;
	self.generatorType := _proxyEDITI.generatorType ;
	self.height := _proxyEDITI.height ;
	self.intHeight := _proxyEDITI.intHeight ;
	self.intLength := _proxyEDITI.intLength ;
	self.intWidth := _proxyEDITI.intWidth ;
	self.isCommunicating := _proxyEDITI.isCommunicating ;
	self.isForDelete := _proxyEDITI.isForDelete ;
	self.isHeavyLift := _proxyEDITI.isHeavyLift ;
	self.isoGroup := _proxyEDITI.isoGroup ;
	self.isoType := _proxyEDITI.isoType ;
	self.length := _proxyEDITI.length ;
	self.licenseIssuer := _proxyEDITI.licenseIssuer ;
	self.licenseNumber := _proxyEDITI.licenseNumber ;
	self.myOwner := _proxyEDITI.myOwner ;
	self.operatorCode := _proxyEDITI.operatorCode ;
	self.owner := _proxyEDITI.owner ;
	self.tILCType := _proxyEDITI.tILCType ;
	self.tareWeight := _proxyEDITI.tareWeight ;
	self.type := _proxyEDITI.type ;
	self.voltageType := _proxyEDITI.voltageType ;
	self.volume := _proxyEDITI.volume ;
	self.weight := _proxyEDITI.weight ;
	self.attachedCargoId := _proxyEDITI.attachedCargoId;      	//27.02.2018 cnwma1 ChangeRequest #36813
	self.attachedCargoType := _proxyEDITI.attachedCargoType;  	//27.02.2018 cnwma1 ChangeRequest #36813
	self.floorType := _proxyEDITI.floorType; 					// 15/05/2025	navcs2	MTN-34844

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="2d8629de-6d9b-4265-9ffb-23fc632ba2e7">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533
06 Jul       2018   cnwma1	Bug 39554: JMT - Measerment Value cant be altered in EDI operations
*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	//06.7.2018  cnwma1	Bug 39554
	if rowName = ETRow_TareWeight then
		self.tareWeight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if rowName = ETRow_Volume then
		self.volume := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if rowName = ETRow_ExtHeight then
		self.extHeight  := _value.asIntegerJMT;
		return true;
	endif;
	if rowName = ETRow_ExtLength then
		self.extLength  := _value.asIntegerJMT;
		return true;
	endif;
	if rowName = ETRow_ExtWidth then
		self.extWidth  := _value.asIntegerJMT;
		return true;
	endif;
	
	if rowName = ETRow_IntHeight then
		self.intHeight  := _value.asIntegerJMT;
		return true;
	endif;
	if rowName = ETRow_IntLength then
		self.intLength  := _value.asIntegerJMT;
		return true;
	endif;
	if rowName = ETRow_IntWidth then
		self.intWidth  := _value.asIntegerJMT;
		return true;
	endif;
	//06.7.2018  cnwma1	Bug 39554
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPropertyByName" id="ff4b2c44-3381-495b-a7e8-605f594cc5af">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
//
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//
vars
	value : String;
	contRange : CM_ContRange;
begin
	if _columnName = ETRow_CoolingType then
		value := _value.toUpper;
		if value = 'AIR' or value = 'AC' or value = 'A' or value = ContainerAirCooledStr.toUpper then
			self.coolingType := ContainerAirCooled;
		elseif value = 'WATER' or value = 'WC' or value = 'W' or value = ContainerWaterCooledStr.toUpper then
			self.coolingType := ContainerWaterCooled;
		else
			contRange := self.getContRange();
			if contRange &lt;&gt; null then
				self.coolingType := contRange.coolingType;
			else
				self.coolingType := ContainerCooledNull;
			endif;
		endif;
		return true;
	elseif _columnName = ETRow_VoltageType then
		value := _value.toUpper; 
		if value = 'DUAL' or value = 'DV' or value = 'D' or value = ContainerDualVoltStr.toUpper then 
			self.voltageType := ContainerDualVolt;
		elseif value = 'SINGLE' or value = 'SV' or value = 'S' or value = ContainerSingleVoltStr.toUpper then
			self.voltageType := ContainerSingleVolt;
		else
			self.voltageType := ContainerVoltNull;
		endif;
		return true;
	else
		return inheritMethod(_columnName, _value);
	endif;
end;
</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
