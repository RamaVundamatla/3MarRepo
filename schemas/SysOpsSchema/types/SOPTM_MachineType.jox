    <JadeMethod name="setControlsForAddEdit" id="7c45c1be-72b5-4ed7-a304-570408da5ca6">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect3.userInputEnabled := true;
	theForm.mulSelect6.userInputEnabled := true;	
	theForm.btnSetDefault1.enabled := false;
	theForm.btnSingle1Edit.enabled:=true;
	theForm.btnSingle1Delete.enabled:=true;
	theForm.btnSingle1New.enabled:=true;
	theForm.btnSingle1Down.enabled:=true;
	theForm.btnSingle1Up.enabled:=true;
//	theForm.btnSetDefault2.enabled := true;	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		theForm.mulSelect6.setSelected(null);
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		

	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_MachineType);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;



end;</source>
    </JadeMethod>
