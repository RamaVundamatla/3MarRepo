    <JadeMethod name="getDependentProperties" id="400c9c01-1ca5-4146-a388-42f93352255c">
        <source>getDependentProperties(_dependentPropNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25  Nov 2019 jlger1	Initial creation TFS 47132

*/

vars

begin
	if _dependentPropNames &lt;&gt; null then
		_dependentPropNames.add(CM_TrackedItem::myProduct.name);
		_dependentPropNames.add(CM_TrackedItem::getMyTILCType.name);
		_dependentPropNames.add(CM_Container::isoType.name);
	endif;

epilog

end;</source>
