	self.sendMailHelper.assembleMessage(_mail, _fromAddress.StringUtf8, _toAddress.StringUtf8, _ccAddress.StringUtf8, _bccAddress.StringUtf8, _subject.StringUtf8, _message.StringUtf8, self.logFileName, app.logLevel);
	
	return not exceptionOccurred;
epilog

