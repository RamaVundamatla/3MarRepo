    <JadeMethod name="processEvent" id="aa1fc9fb-d312-4765-8ab6-9f0666d411f9">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navmp20	ChangeRequest 56801: EUP - EDI Message Type - Transport Status Message Processing
22 Jun 2023	navdap1	TFS 58351 EUP - Receiver field and Carrier Code is always blank in the Transport Status message
11 Sep 2023	jlika1	TFS 60337 EUP | FR EDI - EUP CAMS protocols: Translations based on Receiver
25 Apr 2024 navsaa30 Bug 63172: EUP | FR - 54537 - EDI Data Translation For Carriers Not Translating in Transport Status message
20 May 2024 navsp1  ChangeRequest 60623: EUP | FR - 54537 - Transport Status StartDateTime and EndDateTime
25 Jun 2024 navmd1	TFS 61725 Fix Timestamps not being reported in UTC (as the mapper expects UTC/Zulu time)
28 Oct 2024 navbs1	Bug MTN-32975: EUP | 54537 Transport Status - Start End Time Detail Data Incorrect
*/

vars
	truckEvent : CMEVT_TruckEvent;
	camMessage : CM_CamMessage;
	operatorCodeArray : StringArray;
	bookingSlotArray  : ObjectArray;
	visit      : CM_VehicleVisitRecord;
	booking    : CM_VehicleBookingTimeSlot;
	bookingSlot : CM_VehicleBookingTimeSlot;
	gateEntity : CMGTE_Entity;
	statusMessage : CMIF_JsonTransportStatusMsgEUP;
	operatorCode  : String;
	transportStatus : CMIF_JsonTransportStatusEUP;
	carrier         : CMIF_JsonCarrierPartyEUP;
	code : String;
	truckInfo    : CMIF_JsonTruckInfoEUP;
	subCarrier   : CM_Carrier;
	subHaulier   : CMIF_JsonSubHaulierEUP;
	outChassis : CMGTE_Release;
	ti : CM_TrackedItem;
	event : CM_EventTransaction;				//TFS 60623
	truckJobStartTS, truckJobEndTS : TimeStamp;	//TFS 60623
begin
	
	if not _transaction.isA(CMEVT_TruckEvent) then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Transaction not processed since its not a CMEVT_TruckEvent');
		endif;
		
		return;
	endif;
	truckEvent := _transaction.CMEVT_TruckEvent;
	if _transaction.type &lt;&gt; EVT_TruckArrival and _transaction.type &lt;&gt; EVT_TruckDeparture and _transaction.type &lt;&gt; EVT_TruckCancellation then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Transaction not processed since its not a CMEVT_TruckEvent');
		endif;
		
		return;
	endif;
	
	if truckEvent.myVisit = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Transaction not processed since it does not have vehicle visit record');
		endif;
		
		return;
	endif;
	
	visit := truckEvent.myVisit;
	camMessage := self.getCamMessage(_camFile, null, null, self.TransportStatus, false);
	create operatorCodeArray transient;
	create bookingSlotArray transient;
	
	foreach booking in visit.allVehicleBookingSlots do
		if booking.allVehicleBookingItems.size &gt; 0 then
			bookingSlotArray.add(booking);
		endif;
	endforeach;
	if bookingSlotArray.isEmpty then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Booking slot array is empty - no message will be produced", LogDEBUG);
	endif;
	
	truckJobStartTS := null;									//TFS 60623
	truckJobEndTS 	:= null;									//TFS 60623
	foreach event in visit.allEventTransactions do				//TFS 60623
		if event.isKindOf(CMEVT_TruckEvent) then				//TFS 60623
			if event.type = EVT_TruckJobStart then				//TFS 60623
				if truckJobStartTS = null or truckJobStartTS &gt; event.dateTime then		//TFS 60623
					truckJobStartTS := event.dateTime;			//TFS 60623
				endif;											//TFS 60623
			//elseif event.type = EVT_TruckJobStop then			//TFS 60623				//28.10.2024  navbs1  #32975
			elseif event.type = EVT_TruckJobComplete then								//28.10.2024  navbs1  #32975
				if truckJobEndTS = null or truckJobEndTS &lt; event.dateTime then			//TFS 60623
					truckJobEndTS := event.dateTime;			//TFS 60623
				endif;											//TFS 60623
			endif;												//TFS 60623
		endif;													//TFS 60623
	endforeach;													//TFS 60623
	
	foreach gateEntity in truckEvent.myVisit.allGateEntities do
		if gateEntity.operatorCode &lt;&gt; null and not operatorCodeArray.includes(gateEntity.operatorCode) then
			operatorCodeArray.add(gateEntity.operatorCode);
		endif;
	endforeach;
	// Truck Cancellation vehicle visit records don't have gate entities
	if operatorCodeArray.isEmpty and _transaction.type = EVT_TruckCancellation then
		foreach ti in truckEvent.myVisit.allReceivedTrackedItems do
			if not operatorCodeArray.includes(ti.operatorCode) then
				operatorCodeArray.add(ti.operatorCode);
			endif;
		endforeach;
		foreach ti in truckEvent.myVisit.allReleasedTrackedItems do
			if not operatorCodeArray.includes(ti.operatorCode) then
				operatorCodeArray.add(ti.operatorCode);
			endif;
		endforeach;
	endif;
	if operatorCodeArray.isEmpty then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Operator array is empty - no message will be produced", LogDEBUG);
	endif;
	
	foreach operatorCode in operatorCodeArray do
		foreach bookingSlot in bookingSlotArray as CM_VehicleBookingTimeSlot do			
			create statusMessage transient;
			statusMessage.buildHeader(truckEvent, _camProtocol, operatorCode, bookingSlot);
			create transportStatus transient;
			statusMessage.transports.add(transportStatus);
			transportStatus.transportationMode := "Road";
			transportStatus.transportType := "Truck";
			transportStatus.dateTimeOfArrival := truckEvent.myVisit.getArrivalTime().localToUTCTime;
			if truckEvent.type = EVT_TruckDeparture then
				transportStatus.dateTimeOfDeparture := truckEvent.myVisit.getRoadExitTime().localToUTCTime;
				//transportStatus.startDateTime       := truckEvent.myVisit.getFirstCargoRemovedTime(); //TFS 60623
			endif;
			//if truckEvent.myVisit.getFirstCargoPlacedTime &lt;&gt; null then								//TFS 60623
				//transportStatus.startDateTime := truckEvent.myVisit.getFirstCargoPlacedTime();		//TFS 60623
			//endif;																					//TFS 60623
			//transportStatus.endDateTime := truckEvent.myVisit.getReadyToLeaveTime();					//TFS 60623
			if truckJobStartTS.isValid() then 															//28.10.2024  navbs1  #32975
				transportStatus.startDateTime	:= truckJobStartTS.localToUTCTime;							//TFS 60623
			endif;
			if truckJobEndTS.isValid() then 															//28.10.2024  navbs1  #32975
				transportStatus.endDateTime		:= truckJobEndTS.localToUTCTime;							//TFS 60623
			endif;
			if truckEvent.type = EVT_TruckArrival or truckEvent.type = EVT_TruckCancellation then
				transportStatus.status := "Arrived";
			else
				transportStatus.status := "Departed";
			endif;
			create carrier transient;
			transportStatus.carrierParty := carrier;
			code := truckEvent.myVisit.carrierCode;																																	// TFS 58351
			transportStatus.carrierParty.code := self.getXlatedForeignCode(operatorCode, code, XLATION_TYPE_CARRIER_BYOP, _camProtocol.terminal);	// TFS 58351		//25/4/24  navsaa30  #63172
			transportStatus.carrierParty.name := truckEvent.myVisit.getCarrierDescription();
			create truckInfo transient;
			transportStatus.truckInfo := truckInfo;
			if _transaction.type = EVT_TruckDeparture and truckEvent.myVisit.myOutCMGTE_Chassis &lt;&gt; null then
				outChassis := truckEvent.myVisit.myOutCMGTE_Chassis.CMGTE_Release;
				if outChassis.myTILCType &lt;&gt; null then
					transportStatus.truckInfo.type := outChassis.myTILCType.code;
				elseif outChassis.myTrackedItem &lt;&gt; null and outChassis.myTrackedItem.isChassis then
					transportStatus.truckInfo.type := outChassis.myTrackedItem.CM_TILC.myTILCType.code;
				endif;
			elseif (_transaction.type = EVT_TruckArrival or _transaction.type = EVT_TruckCancellation) and truckEvent.myVisit.myInCMGTE_Chassis &lt;&gt; null then
				transportStatus.truckInfo.type := truckEvent.myVisit.myInCMGTE_Chassis.myTILCType.code;
			endif;
			transportStatus.truckInfo.licensePlate := truckEvent.myVisit.regNumber;
			
			if _transaction.type = EVT_TruckDeparture and truckEvent.myVisit.myOutCMGTE_Chassis &lt;&gt; null then
				transportStatus.truckInfo.trailerLicensePlate := truckEvent.myVisit.myOutCMGTE_Chassis.id;
			elseif (_transaction.type = EVT_TruckArrival or _transaction.type = EVT_TruckCancellation) and truckEvent.myVisit.myInCMGTE_Chassis &lt;&gt; null then			
				transportStatus.truckInfo.trailerLicensePlate := truckEvent.myVisit.myInCMGTE_Chassis.id;
			endif;

			transportStatus.truckInfo.slot := bookingSlot.myVBTimeSlotType.description;
			transportStatus.truckInfo.driverName := truckEvent.myVisit.driversName;
			transportStatus.truckInfo.driverLicenseNumber := truckEvent.myVisit.driverCode;
			transportStatus.truckInfo.transportReferenceCustomer := bookingSlot.externalReference;
			transportStatus.truckInfo.transportReferenceInternal := bookingSlot.id;
			subCarrier := truckEvent.myVisit.getMySubCarrier;			
			if subCarrier &lt;&gt; null then
				code := subCarrier.code;	//navra1
				create subHaulier transient;
				transportStatus.truckInfo.subhaulier := subHaulier;
				transportStatus.truckInfo.subhaulier.code := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_CARRIER_BYOP, _camProtocol.terminal); //jlika1 TFS 60337
				transportStatus.truckInfo.subhaulier.name := subCarrier.description;
			endif;
			self.addMessage(camMessage.group3, statusMessage.getJsonForTransportStatus, _camAgent);
			delete statusMessage;
			//delete subHaulier;
		endforeach;
	endforeach;
epilog
	delete bookingSlotArray;
	delete operatorCodeArray;
	delete statusMessage;
	//delete subHaulier;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
