    <JadeMethod name="trxUpdateMachinesQueue" id="9460c0e9-bb19-4652-8d8e-3933c267d547">
        <updating/>
        <source>trxUpdateMachinesQueue(_machines : CM_MachineSet; _queue : CM_RadioTelemetryQueue input;	_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     August 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 20474

// ---------------------------------------------------------------------------

vars
	pxyMach : CM_Machine;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	foreach pxyMach in _machines  discreteLock do
		app.myUtilityUA.utlUpdateMachineQueue(pxyMach,_queue, _passport);
		if _passport.hasErrorsOrWarnings() then
			return;
		endif;
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machines" type="CM_MachineSet"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
