<GUIClass name="CM_BaseForm">
    <JadeMethod name="doUpdateDeckCellProxies" id="c7eca878-d563-41fb-a89e-0473142a7b21">
        <source>doUpdateDeckCellProxies( _onDeckTable: Table input; _underDeckTable: Table input; _anythingChanged : Boolean output );

/*

Purpose:	

			This variant picks up any change the user has made that hasn't yet been followed by a mouse move or cell lost focus.
			I.e. It is possible for a user to user a short cut key to do the save, having not yet lost focus or tabbed from
			the last cell that they have changed a value in.
			Another scenario is where the user positions teh cursor over the save button, but uses the tab key to negotiate the 
			around the cells.  There was then potential for the last change to be missed, if they clicked the mouse over the save.
			Equally changing the Bay could do the same.
			

Parameters:			

Return Value:		


Date		Who		Reason
18 October 2010		cnwndl1	Initial creation
04 March 2021		navmd1	Make sure we're checking maxHeight consistently

*/

vars

	col : Integer;
	aCellDef : CM_CellDefn;
	max20Pile : Integer;
	max40Pile : Integer;
	maxHeightForm,
	maxHeightObj : Decimal [5,2];
	invalidObject : Boolean;
		
begin

	on Exception do app.handleDeletedObject( exception, aCellDef, invalidObject);

	foreach col in 1 to _onDeckTable.columns do
		aCellDef := _onDeckTable.accessColumn(col).itemObject.CM_CellDefn;
		if aCellDef = null then
			continue;
		endif;

		max20Pile := _onDeckTable.getCellText(2, col).Integer;	//column 2 = "On Deck Cell 20 Max Pile"
		max40Pile := _onDeckTable.getCellText(3, col).Integer;	//column 3 = "On Deck Cell 40 Max Pile"
		maxHeightForm := _onDeckTable.getCellText(4, col).asDecimalJMT();	//column 4 = "On Deck Cell Max Height"
		
		if aCellDef.maxPileWeight20 &lt;&gt; max20Pile then
			aCellDef.setMaxPileWeight20( max20Pile );
			_anythingChanged := true;
		endif;
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
		if aCellDef.maxPileWeight40 &lt;&gt; max40Pile then
			aCellDef.setMaxPileWeight40( max40Pile );
			_anythingChanged := true;
		endif;
		
		maxHeightObj := aCellDef.maxHeight;
		if maxHeightObj &lt;&gt; maxHeightForm then	
			aCellDef.setMaxHeight( maxHeightForm );
			_anythingChanged := true;
		endif;
	endforeach;
	
	foreach col in 1 to _underDeckTable.columns do
		aCellDef := _underDeckTable.accessColumn(col).itemObject.CM_CellDefn;
		if aCellDef = null then
			continue;
		endif;
		
		max20Pile := _underDeckTable.getCellText(2, col).Integer;	//column 2 = "Under Deck Cell 20 Max Pile"
		max40Pile := _underDeckTable.getCellText(3, col).Integer;	//column 3 = "Under Deck Cell 40 Max Pile"
		maxHeightForm := _underDeckTable.getCellText(4, col).asDecimalJMT();	//column 4 = "Ubnder Deck Cell Max Height"
		
		if aCellDef.maxPileWeight20 &lt;&gt; max20Pile then
			aCellDef.setMaxPileWeight20( max20Pile );
			_anythingChanged := true;
		endif;
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
		if aCellDef.maxPileWeight40 &lt;&gt; max40Pile then
			aCellDef.setMaxPileWeight40( max40Pile );
			_anythingChanged := true;
		endif;
		
		maxHeightObj := aCellDef.maxHeight;
		if maxHeightObj &lt;&gt; maxHeightForm then	
			aCellDef.setMaxHeight( maxHeightForm );
			_anythingChanged := true;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_onDeckTable" type="Table" usage="input"/>
        <Parameter name="_underDeckTable" type="Table" usage="input"/>
        <Parameter name="_anythingChanged" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doUpdateDeckCellProxy" id="f81ef39e-b769-459d-9043-36ad2bddcf40">
        <updating/>
        <source>doUpdateDeckCellProxy( _table: Table input; _anythingChanged : Boolean output ):Boolean updating;

/*

Purpose:

				This method is called as the user moves between cells, so that if necessary they get any error message in real time
				instead of presenting hundreds of errors on the save !!!
				

Parameters:			

Return Value:		


Date				Who			Reason
28 July 2010		cnwndl1		Initial creation	Par 25127	/ CCMS 1140
18 October 2010		cnwjo3		par 25630.  Just changing slightly so 0,00 - 99,00 is displayed instead of 0.00 - 99.00.
*/

constants
	MinHeight : Decimal[4,2] = 0.00;
	MaxHeight : Decimal[4,2] = 99.99;
vars

	aCellDef : CM_CellDefn;
	currentRow : Integer;
	currentColumn : Integer;
	newValueString : String;
	
begin

	_anythingChanged := false;
	currentRow := _table.row;
	currentColumn := _table.column;
	aCellDef := _table.accessColumn(currentColumn).itemObject.CM_CellDefn;
	if aCellDef = null or (not aCellDef.isTransient) then
		return true;
	endif;
	
	newValueString := _table.getCellText(currentRow,currentColumn);
	
	if currentRow = 2 then	//"On Deck Cell 20 Max Pile"
		if ( not newValueString.isInteger ) or ( newValueString.Integer &lt; 0 ) or ( newValueString.Integer &gt; 999 ) then
			app.msgBox(app.getErrorString3(MustBeInRange,app.getErrorString(CM_Number),"0","999"),app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		if aCellDef.maxPileWeight20 &lt;&gt; newValueString.Integer then
			aCellDef.setMaxPileWeight20(newValueString.Integer);
			_anythingChanged := true;
		endif;
	elseif currentRow = 3 then	//"On Deck Cell 40 Max Pile"
		if ( not newValueString.isInteger ) or ( newValueString.Integer &lt; 0 ) or ( newValueString.Integer &gt; 999 ) then
			app.msgBox(app.getErrorString3(MustBeInRange,app.getErrorString(CM_Number),"0","999"),app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		if aCellDef.maxPileWeight40 &lt;&gt; newValueString.Integer then
			aCellDef.setMaxPileWeight40(newValueString.Integer);
			_anythingChanged := true;
		endif;
	elseif currentRow = 4 then	//"On Deck Cell Max Height"
		//if ( not newValueString.isDecimal ) or ( newValueString.Decimal &lt; 0 ) or ( newValueString.Decimal &gt; 99.99 ) then //commented by #25630 13/10/2010. The isDecimal() method doesn't understand Italian locale.
		if ( newValueString.asDecimalJMT() &lt; 0 ) or ( newValueString.asDecimalJMT() &gt; 99.99 ) then
			app.msgBox(app.getErrorString3(MustBeInRange,app.getErrorString(CM_Number),MinHeight.asStringJMT(),MaxHeight.asStringJMT()),app.getErrorString(Error),MsgBox_OK_Only);	// decimal changed by asDecimalJMT().	#25630 13/10/2010
			return false;
		endif;
		if aCellDef.maxHeight &lt;&gt; newValueString.asDecimalJMT() then	// decimal changed by asDecimalJMT().	#25630 13/10/2010
			aCellDef.setMaxHeight( newValueString.asDecimalJMT() );	// decimal changed by asDecimalJMT().	#25630 13/10/2010
			_anythingChanged := true;
		endif;
	endif;

	return true;
	
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_anythingChanged" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
