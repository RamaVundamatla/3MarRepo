<CollClass name="CM_SpecialLiftByCodeDict" id="4154b9e4-fa4e-4ab1-a0c7-9240355fc652">
    <loadFactor>66</loadFactor>
    <memberType name="CM_SpecialLift"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="radioTelemetry"/>
    <MemberKey>
        <property name="CM_SpecialLift::code"/>
    </MemberKey>
    <JadeMethod name="auditIdDisplay" id="815337d7-e9b6-437d-ae35-113c151b80bd">
        <source>auditIdDisplay(): String;
//18 November 2010	cnwml2
//+cnwml2 PAR26349
vars
	sl : CM_SpecialLift;
	rtnStr: String;
begin
	foreach sl in self do
		if rtnStr = null then
			rtnStr := sl.auditId();
		else
			rtnStr := rtnStr &amp; "::" &amp; sl.auditId();
		endif;
	endforeach;
	
	return rtnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
