    <JadeMethod name="setupForm" id="02da717d-3dd8-4bd9-8212-d6e0ad51b165">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	entTableDef	: EntTableDef;
	realCargoType : CM_CargoType;

begin

	inheritMethod();
	
	self.minimumHeight := 642;
	self.minimumWidth := 675;
	
	self.height := 642;
	self.width := 675;
	
	self.centreOverParent( 1 );
	
	entTableDef := app.myController.getEntTableDef( ETDef_RecipeComponent );
	self.tblComponents.setTblDataEntRowsFromDef(entTableDef);
	self.tblComponents.selectMode := Table.SelectMode_CurrentRow;
	self.tblComponents.selectionType := self.tblComponents.SelectionType_Row;
	self.tblComponents.multiSelect := self.tblComponents.MultiSelect_None;
	
	if not self.myCargoType.isTransient then
		self.cmbRecProduct.listCollection( self.myCargoType.allProducts, false, 0 );
	else
		realCargoType := self.myCargoType.pxyGetRealObject();
		if realCargoType &lt;&gt; null then
			self.cmbRecProduct.listCollection( realCargoType.allProducts, false, 0 );
		endif;
	endif;
	
	self.tblVolume.tabKey := J_key_Tab;
	self.tblWeight.tabKey := J_key_Tab;
	self.tblAmount.tabKey := J_key_Tab;
	
	self.populateFromProxyRecipe();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblComponents_click" id="5f486083-b6e2-47ce-abb0-871c14edab3f">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblComponents_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	component : CM_RecipeComponent;
	rowIndex : Integer;

begin

	rowIndex := self.tblComponents.row;
	if rowIndex &gt; self.tblComponents.fixedRows and rowIndex &lt;= self.tblComponents.rows then
		component := self.tblComponents.accessRow( rowIndex ).itemObject.CM_RecipeComponent;
	endif;

	self.doShowComponent( component );

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="aa6ca58f-efc7-4af1-88ff-0b823f5e6f7f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 June 2021 10:48:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024283, locale);
	btnCloseAll.translateBubbleHelp(Xlat_0024284, locale);
	btnCloseAll.translateCaption(Xlat_0024285, locale);
	btnCompAdd.translateBubbleHelp(Xlat_0024286, locale);
	btnCompAdd.translateCaption(Xlat_0024287, locale);
	btnCompDelete.translateBubbleHelp(Xlat_0024288, locale);
	btnCompDelete.translateCaption(Xlat_0024289, locale);
	btnCompUpdate.translateBubbleHelp(Xlat_0024290, locale);
	btnCompUpdate.translateCaption(Xlat_0024291, locale);
	btnSaveRecipe.translateBubbleHelp(Xlat_0024292, locale);
	btnSaveRecipe.translateCaption(Xlat_0024293, locale);
	chkScale.translateCaption(Xlat_0024294, locale);
	grpCompMaint.translateCaption(Xlat_0024295, locale);
	grpComponents.translateCaption(Xlat_0024296, locale);
	grpRecipe.translateCaption(Xlat_0024297, locale);
	lblAmount.translateCaption(Xlat_0024298, locale);
	lblCargoType.translateCaption(Xlat_0024299, locale);
	lblCode.translateCaption(Xlat_0024300, locale);
	lblDescription.translateCaption(Xlat_0024301, locale);
	lblInstructions.translateCaption(Xlat_0024302, locale);
	lblOrder.translateCaption(Xlat_0024303, locale);
	lblProduct.translateCaption(Xlat_0024304, locale);
	lblQuantity.translateCaption(Xlat_0024305, locale);
	lblRecCargoSubType.translateCaption(Xlat_0024306, locale);
	lblVolume.translateCaption(Xlat_0024307, locale);
	lblWeight.translateCaption(Xlat_0024308, locale);
end;</source>
    </JadeMethod>
</GUIClass>
