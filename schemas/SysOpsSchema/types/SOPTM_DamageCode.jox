    <JadeMethod name="initShtMultiSelect" id="bb94d151-1208-4ad5-8ac9-7155302d3f57">
        <source>initShtMultiSelect();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 24 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	obj : Object;
	coll : CM_MachineTypeByTypeDict;
	machineType : CM_MachineType;
begin
	theForm := self.myForm;
	inheritMethod();
	
	self.setupMultiSelect1(app.getErrorString(Cargo_Types_Access), app.myRoot.allCargoTypesById, SOP_TableMaintForm::displayEntryCargoType.name);
	
	create coll transient;
	foreach machineType in app.myRoot.allMachineTypes where machineType.isKindOf(CM_WagonMachineType) do
		coll.add(machineType);
	endforeach;
	self.setupMultiSelect2(app.getErrorString(MachineTypes), coll, SOP_TableMaintForm::displayEntryMachineTypes.name);
	
	
epilog
delete coll;
end;</source>
    </JadeMethod>
