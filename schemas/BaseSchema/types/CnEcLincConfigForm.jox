    <JadeMethod name="populateAllControls" id="1ca535b3-a02d-4739-9424-027a62eb5adb">
        <updating/>
        <source>populateAllControls() updating;

vars
    i : Integer;

begin
	// Link the combo boxes to the Linc System and ISPEC collections
	self.populateSystemCombo();

	if currentLincSystem &lt;&gt; null then
		self.populateConnectionSettings();

		// Populate the tables on various sheets
		self.populateIspecTable();
		self.populateFieldsTable();
		self.populateTimeoutsTable();

		// Populate the Log file name sheet text box (Diagnostics sheet)
		// and the general options
		beginLoad;
			txtDiagLogFile.text	:= currentLincSystem.logFilename;
			chkLogFull.value := currentLincSystem.logFullMessages;

			if currentLincSystem.logFileSize &gt; 0 then
				txtFileSize.text := currentLincSystem.logFileSize.String;
			else
				txtFileSize.text := currentLincSystem.LogFilesize_default.String;
			endif;	

			// set the radiobuttons to show which form of file rollover is required
			// new as BaseSchema code was migrated to Jade 4.0 (12/97 PS)

			if currentLincSystem.logRollOverDateTime then 
				optFileDate.value := true;
			else
				optFileOld.value := true;
			endif;

			// Populate the Log File  option check-boxes (Diagnostics sheet)

			chkDiagLog1.value := currentLincSystem.diagnosticLogOptions[1];
			chkDiagLog2.value := currentLincSystem.diagnosticLogOptions[2];	
			chkDiagLog3.value := currentLincSystem.diagnosticLogOptions[3];	
			chkDiagLog4.value := currentLincSystem.diagnosticLogOptions[4];	
			chkDiagLog5.value := currentLincSystem.diagnosticLogOptions[5];	
			chkDiagLog6.value := currentLincSystem.diagnosticLogOptions[6];
			chkDiagLog7.value := currentLincSystem.diagnosticLogOptions[7];
			chkDiagLog8.value := currentLincSystem.diagnosticLogOptions[8];
		endLoad;
	endif;	// currentLincSystem &lt;&gt; null
end;</source>
    </JadeMethod>
    <JadeMethod name="populateConnectionSettings" id="843f885a-6d73-4c5e-a2f4-48ad232c83d0">
        <updating/>
        <source>/*******************************************************
*
* Description : Populate the controls on the Connection
*				settings sheet
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
populateConnectionSettings() updating;

begin
	beginLoad;
 		txtTcpHostName.text := currentLincSystem.tcpHostname;
		txtPort.text := currentLincSystem.tcpPort.String;
		txtLocalPort.text := currentLincSystem.localPort.String;

		if currentLincSystem.applicationId = "" then 
  			txtAppId.text := currentLincSystem.name;
		else
		    txtAppId.text := currentLincSystem.applicationId;
		endif;

		txtDialogs.text := currentLincSystem.dialogs.String;
		txtRetryConnection.text := currentLincSystem.retryConnection.String;
  	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateFieldsTable" id="19d60c94-a89a-4485-a3ca-702e17186280">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Ispec Fields details table column
*				width and headers
*
*				Display the field details for the 
*				currently selected ISPEC in the ISPEC 
*				Field Contents table
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	10/12/96	Initial version
*
*******************************************************/
populateFieldsTable() updating;

vars
	ispec		: CnEcLincIspecDef;
	field		: CnEcLincFieldDef;

begin
	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	tabFieldContents.clear();

	// Set table configuration access mode to 'by cell'
	tabFieldContents.accessMode := tabFieldContents.AccessMode_Cell;
	tabFieldContents.rows := Field_initial_table_rows;

	/**************************************************************

	  Set up TABLE SORTING by Ispec name + field offset, ascending

	**************************************************************/

//	tabFieldContents.sortColumn[1]	:= 1;	// first sort column is 1
//	tabFieldContents.sortAsc[1]		:= true;
//	tabFieldContents.sortCased[1]     := true;
//	tabFieldContents.sortColumn[3] 	:= 3;	//. third sort column is 3
//	tabFieldContents.sortAsc[3] 		:= true;

	/**************************************************************

	  Set up TABLE and COLUMN WIDTHS

	**************************************************************/

	tabFieldContents.columnWidth[1] := Field_col_width_name;
	tabFieldContents.columnWidth[2] := Field_col_width_offset;
	tabFieldContents.columnWidth[3] := Field_col_width_type;
	tabFieldContents.columnWidth[4] := Field_col_width_length;
	tabFieldContents.columnWidth[5] := Field_col_width_trueLength;
	tabFieldContents.columnWidth[6] := Field_col_width_decimals;
	tabFieldContents.columnWidth[7] := Field_col_width_default;

	// Set the overall table width
	tabFieldContents.width := Field_col_width_name +
								Field_col_width_offset +
								Field_col_width_type +
								Field_col_width_length +
								Field_col_width_trueLength +
								Field_col_width_decimals +
								Field_col_width_default +
								Col_width_scrollbar + 
								Col_width_border;

	/**************************************************************

	  Set up COLUMN HEADINGS

	**************************************************************/

	tabFieldContents.row			:= 1;

	tabFieldContents.column		:= 1;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Center;
	tabFieldContents.text			:= Field_col_head_name;

	tabFieldContents.column		:= 2;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Center;
	tabFieldContents.text			:= Field_col_head_offset;

	tabFieldContents.column		:= 3;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Center;
	tabFieldContents.text			:= Field_col_head_type;

	tabFieldContents.column		:= 4;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Center;
	tabFieldContents.text			:= Field_col_head_length;

	tabFieldContents.column		:= 5;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Center;
	tabFieldContents.text			:= Field_col_head_trueLength;


	tabFieldContents.column		:= 6;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Center;
	tabFieldContents.text			:= Field_col_head_decimals;

	tabFieldContents.column		:= 7;
	tabFieldContents.alignment	:= tabFieldContents.Alignment_Left;
	tabFieldContents.text		:= Field_col_head_default;

	// Only display table contents if there is a valid Linc System
	if ( currentLincSystem = null or currentLincIspec = null ) then
		return;
	endif;

	/**************************************************************

	  Display the ISPEC and FIELD content details in the table

	**************************************************************/

	tabFieldContents.rows	:= currentLincIspec.countFields + 1;
	tabFieldContents.row	:= 1;

	/****************
	  ROW 1 (Header)
	 ***************/
	tabFieldContents.rowHeight[1] := Tab_row_height_header;

	beginLoad;
		app.mousePointer := Window.MousePointer_HourGlass;

		foreach field in currentLincIspec.allLincFieldDefs do

			tabFieldContents.row := tabFieldContents.row + 1;

			/***************
	 		 ROW n (Others)
	 		 **************/
			tabFieldContents.rowHeight[tabFieldContents.row] := Tab_row_height_other;

			/***********
			  COLUMN 1
			 ***********/

			tabFieldContents.column := 1;

			tabFieldContents.alignment := tabFieldContents.Alignment_Left;

			tabFieldContents.text := "  " &amp; field.name;		// Left pad

			if field.copyFromOccurs &gt; 0 then 
				tabFieldContents.text := (tabFieldContents.text &amp; (" (" &amp; field.copyFromOccurs.String &amp; " )"));
			endif;

			/***********
			  COLUMN 2
			 ***********/
			tabFieldContents.column := 2;
			tabFieldContents.alignment := tabFieldContents.Alignment_Right;
			tabFieldContents.text := field.offset.String &amp; "      ";		// Right pad

			/***********
			  COLUMN 3
			 ***********/
			tabFieldContents.column := 3;
			tabFieldContents.alignment := tabFieldContents.Alignment_Center;
			tabFieldContents.text := field.type.String;	// No padding

			/***********
			  COLUMN 4
			 ***********/
			tabFieldContents.column := 4;
			tabFieldContents.alignment := tabFieldContents.Alignment_Right;
			tabFieldContents.text := field.length.String &amp; "      ";		// Right pad

			/***********
			  COLUMN 5
			 ***********/
			tabFieldContents.column := 5;
			tabFieldContents.alignment := tabFieldContents.Alignment_Right;
			tabFieldContents.text := field.trueLength.String &amp; "      ";		// Right pad

			/***********
			  COLUMN 6
			 ***********/
			tabFieldContents.column := 6;
			tabFieldContents.alignment := tabFieldContents.Alignment_Right;
			tabFieldContents.text := field.decimals.String &amp; "       ";		// Right pad

			/***********
			  COLUMN 7
			 ***********/
			tabFieldContents.column := 7;
			tabFieldContents.alignment := tabFieldContents.Alignment_Left;

			// Set up a text edit box
 			tabFieldContents.inputType := tabFieldContents.InputType_TextBox;
 			tabFieldContents.maxLength := field.defaultValue.maxLength;

 			if field.secureField = true then 
 				tabFieldContents.text := "*****";
 			else
 				tabFieldContents.text := field.defaultValue.String;		// No padding
 			endif;

			tabFieldContents.itemObject := field;

		endforeach; // field

		app.mousePointer := Window.MousePointer_Default;
	endLoad;

//	tableFieldContents.resort();
end;</source>
    </JadeMethod>
    <JadeMethod name="populateIspecCombo" id="f905734a-ad05-4263-b4a3-83729fc45da0">
        <updating/>
        <source>/*******************************************************
*
* Description : Populate the ISPEC combo box with the 
*				ISPEC names in LincIspecDefDict for the
*				currently selected Linc System definition
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
populateIspecCombo() updating;

begin
	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	// Populate the Linc system combo box
	beginLoad;
		comboIspec.listCollection(currentLincSystem.allLincIspecDefs, true, 0);
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateIspecTable" id="455f2020-1e27-4753-b12a-9ad366e48128">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Ispec details table column
*				width and headers
*
*				Display the currently selected Linc 
*				System ISPEC and field details in the
*				Ispec Contents table
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	10/12/96	Initial version
*
*******************************************************/
populateIspecTable() updating;

vars
	ispec	: CnEcLincIspecDef;
	isLogon	: Boolean;

begin
	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	tabIspecContents.clear();

	// Set table configuration access mode to 'by cell'
	tabIspecContents.accessMode := tabIspecContents.AccessMode_Cell;
	tabIspecContents.rows := Ispec_initial_table_rows;

	/**************************************************************

	  Set up TABLE SORTING by Ispec name + field offset, ascending

	**************************************************************/

	tabIspecContents.sortColumn[1]	:= 1;	// first sort column is 1
	tabIspecContents.sortAsc[1]		:= true;
	tabIspecContents.sortColumn[3] 	:= 3;	//. third sort column is 3
	tabIspecContents.sortAsc[3] 	:= true;

	/**************************************************************

	  Set up TABLE and COLUMN WIDTHS

	**************************************************************/

	tabIspecContents.columnWidth[1] := Ispec_col_width_name;
	tabIspecContents.columnWidth[2] := Ispec_col_width_fieldcount;
	tabIspecContents.columnWidth[3] := Ispec_col_width_logon;

	// Set the overall table width
	tabIspecContents.width := Ispec_col_width_name +
								Ispec_col_width_fieldcount +
								Ispec_col_width_logon +
								Col_width_scrollbar + 
								Col_width_border;

	/**************************************************************

	  Set up COLUMN HEADINGS

	**************************************************************/

	tabIspecContents.row		:= 1;

	tabIspecContents.column		:= 1;
	tabIspecContents.alignment	:= tabIspecContents.Alignment_Left;
	tabIspecContents.text			:= "    " &amp; Ispec_col_head_name;

	tabIspecContents.column		:= 2;
	tabIspecContents.alignment	:= tabIspecContents.Alignment_Center;
	tabIspecContents.text			:= Ispec_col_head_fieldcount;

	tabIspecContents.column		:= 3;
	tabIspecContents.alignment	:= tabIspecContents.Alignment_Center;
	tabIspecContents.text			:= Ispec_col_head_logon;

	// Only display table contents if there is a valid Linc System
	if currentLincSystem = null then
		return;
	endif;

	/**************************************************************

	  Display the ISPEC content details in the table

	**************************************************************/

	tabIspecContents.rows	:= currentLincSystem.countIspecs + 1;
	tabIspecContents.row	:= 1;

	/****************
	  ROW 1 (Header)
	 ***************/
	tabIspecContents.rowHeight[1] := Tab_row_height_header;

	beginLoad;
		app.mousePointer := Window.MousePointer_HourGlass;

		foreach ispec in currentLincSystem.allLincIspecDefs do

			tabIspecContents.row := tabIspecContents.row + 1;

			/***************
	 		 ROW n (Others)
	 		 **************/
			tabIspecContents.rowHeight[tabIspecContents.row] := Tab_row_height_other;

			// Is this ISPEC set as the logon ISPEC?
			isLogon := ( ispec = currentLincSystem.logonIspec );

			/***********
			  COLUMN 1
			 ***********/
			tabIspecContents.column := 1;
			tabIspecContents.alignment := tabIspecContents.Alignment_Left;
			tabIspecContents.text := "    " &amp; ispec.name;		// Left pad

			/***********
			  COLUMN 2
			 ***********/
			tabIspecContents.column := 2;
			tabIspecContents.alignment := tabIspecContents.Alignment_Right;
			tabIspecContents.text := ispec.countFields.String &amp; "              ";	// Right pad

			/***********
			  COLUMN 3
			 ***********/
			tabIspecContents.column := 3;
			tabIspecContents.alignment := tabIspecContents.Alignment_Center;
			tabIspecContents.text := isLogon.String;	// No padding
		endforeach; // ispec

		app.mousePointer := Window.MousePointer_Default;
	endLoad;

	return;
	
//	tableIspecContents.resort();
end;</source>
    </JadeMethod>
    <JadeMethod name="populateSystemCombo" id="affccb77-21e0-43ef-aace-4180e831f46a">
        <updating/>
        <source>/*******************************************************
*
* Description : Populate the Linc System combo box with 
*				the Linc System definitions in 
*				collection LincSystemDefDict
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
populateSystemCombo() updating;

begin
	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	// Populate the Linc system combo box
	beginLoad;
		comboLincSystem.listCollection(CnEcLincDefRoot.firstInstance.allLincSystemDefs, true, 0);
	endLoad;

	// Update the ISPEC combo box contents
	if currentLincSystem &lt;&gt; null then
		self.populateIspecCombo();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTimeoutsTable" id="52204e1b-3f9b-4861-8194-9853091e10ea">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the Timeout values table column
*				width and headers
*
*				Display the configured timeout values
*				for each transaction priority level
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	10/12/96	Initial version
*
*******************************************************/
populateTimeoutsTable() updating;

vars
	thisPriority	: Integer;
	
begin
	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	tabTimeouts.clear();

	// Set table configuration access mode to 'by cell'
	tabTimeouts.accessMode := tabTimeouts.AccessMode_Cell;
	tabTimeouts.rows := Timeout_initial_table_rows;

	/**************************************************************

	  Set up TABLE and COLUMN WIDTHS

	**************************************************************/

	tabTimeouts.columnWidth[1] := Timeout_col_width_priority;
	tabTimeouts.columnWidth[2] := Timeout_col_width_userValue;
	tabTimeouts.columnWidth[3] := Timeout_col_width_defaultValue;

	// Set the overall table width
	tabTimeouts.width := Timeout_col_width_priority +
						   Timeout_col_width_userValue +
						   Timeout_col_width_defaultValue +
						   Col_width_border;

	/**************************************************************

	  Set up COLUMN HEADINGS

	**************************************************************/

	tabTimeouts.row		:= 1;

	tabTimeouts.column	:= 1;
	tabTimeouts.alignment	:= tabTimeouts.Alignment_Center;
	tabTimeouts.text		:= Timeout_col_head_priority;

	tabTimeouts.column	:= 2;
	tabTimeouts.alignment	:= tabTimeouts.Alignment_Center;
	tabTimeouts.text		:= Timeout_col_head_userValue;

	tabTimeouts.column	:= 3;
	tabTimeouts.alignment	:= tabTimeouts.Alignment_Center;
	tabTimeouts.text		:= Timeout_col_head_defaultValue;

	// Only display table contents if there is a valid Linc System
	if currentLincSystem = null then
		return;
	endif;

	/**************************************************************

	  Display the timeout details in the table

	**************************************************************/

	tabTimeouts.rows	:= currentLincSystem.Timeout_priority_count + 1;
	tabTimeouts.row	:= 1;
	thisPriority := 0;

	/****************
	  ROW 1 (Header)
	 ***************/
	tabTimeouts.rowHeight[1] := Tab_row_height_header;

	beginLoad;
		app.mousePointer := Window.MousePointer_HourGlass;

		while thisPriority &lt; currentLincSystem.Timeout_priority_count do
			thisPriority := thisPriority + 1;

			tabTimeouts.row := tabTimeouts.row + 1;

			/***************
	 		 ROW n (Others)
	 		 **************/
			tabTimeouts.rowHeight[tabTimeouts.row] := Tab_row_height_other;

			/***********
			  COLUMN 1
			 ***********/
			tabTimeouts.column := 1;
			tabTimeouts.alignment := tabTimeouts.Alignment_Center;
			tabTimeouts.text := thisPriority.String;		// No padding

			/***********
			  COLUMN 2
			 ***********/
			tabTimeouts.column := 2;
			tabTimeouts.alignment := tabTimeouts.Alignment_Right;

			// Set up a text edit box
 			tabTimeouts.inputType := tabTimeouts.InputType_TextNumeric;
			tabTimeouts.text := currentLincSystem.timeoutValues[thisPriority].String; // No padding

			/***********
			  COLUMN 3
			 ***********/
			tabTimeouts.column := 3;
			tabTimeouts.alignment := tabTimeouts.Alignment_Right;
			tabTimeouts.text := currentLincSystem.timeoutDefaults[thisPriority].String &amp; "   ";	// Right padding
		endwhile;

		app.mousePointer := Window.MousePointer_Default;
	endLoad;

//	tableTimeouts.resort();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentIspec" id="c21440b9-6a28-4c36-9c3d-93cfed8217f8">
        <updating/>
        <source>setCurrentIspec(instance:CnEcLincIspecDef) updating;

vars
	previousSelected : CnEcLincIspecDef;

begin
	/************************************************************************
	   Set the currently selected Linc ISPEC, as follows ...
	************************************************************************/

	if instance = null then
		// Set the first instance in the collection
   	    currentLincIspec := currentLincSystem.allLincIspecDefs.first();
	elseif instance = currentLincIspec then
		// Do nothing if the selected Linc ISPEC hasn't changed
		return;
	else
		// Set the selected instance
		currentLincIspec := instance;
	endif;

	/************************************************************************
	   If no Linc ISPEC definitions exist in the collection ... 
	************************************************************************/

	if currentLincIspec = null then
		app.msgBox("Error : No ISPEC definitions exist for " &amp; currentLincSystem.name, "", 0);
	else
		// Read the field details and populate the table (Fields sheet)
		self.populateFieldsTable();
	endif;
end;</source>
        <Parameter name="instance" type="CnEcLincIspecDef"/>
    </JadeMethod>
    <JadeMethod name="setCurrentLincSystem" id="42c048fd-f2e7-4162-931f-bf16d3f8d4fe">
        <updating/>
        <source>/*******************************************************
*
* Description :	Set the value of the attribute 
*				'currentLincSystem'. This indicates the
*				Linc System the user has selected in the 
*				combo box.
*
* Parameters :	instance		Reference to required
*								Linc System
*
* Return :		None
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
setCurrentLincSystem(instance:CnEcLincSystemDef) updating;

vars
	previousSelected : CnEcLincSystemDef;

begin
	/************************************************************************
	   Set the currently sellected Linc System, as follows ...
	************************************************************************/

	if instance = null then
		// Set the first instance in the collection
   	    beginLoad;
   	    	currentLincSystem := CnEcLincDefRoot.firstInstance.allLincSystemDefs.first();
//			comboLincSystem.listIndex := 1;
   	    endLoad;

	elseif instance = currentLincSystem then
		// Do nothing if the selected Linc System hasn't changed
		return;

	else
		// Set the selected instance
		currentLincSystem := instance;

	endif;

	/************************************************************************
	   If no Linc system definitions exist in the collection ... 
	************************************************************************/

	if currentLincSystem = null then
		btnDelete.enabled := false;				// Disable the Delete button
		folderLincDef.visible := false;			// Don't display the folder controls
		btnNew.gotFocus(btnNew);				// Set the focus to the New button
		populateSystemCombo();
		comboLincSystem.clear();				// Blank out the combo boxes
		comboIspec.clear();
	else
		btnDelete.enabled := true;
		folderLincDef.visible := true;
//		sheetIspecDefs.showMySheet();

		// Set the currently selected ISPEC as the first in the list
		setCurrentIspec(null);

		// Populate the controls on all sheets using the current Linc System settings
		populateAllControls();

		// Set the ISPEC combo edit area to display the selected item
		if currentLincSystem.allLincIspecDefs.size() &gt;= 1 then
			comboIspec.listIndex := 1;
		endif;

		// Fill in the Linc System combo box
		comboLincSystem.text := currentLincSystem.name;	
	endif;
end;</source>
        <Parameter name="instance" type="CnEcLincSystemDef"/>
    </JadeMethod>
    <JadeMethod name="tabFieldContents_change" id="73b7afe4-5fb8-4769-9ab2-a8164a69e733">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>/*******************************************************
*
* Description : Respond to the user changing the contents
*				of a table cell. Call the appropriate
*				method to set the value in the 
*				LincFieldDef object.
*
*				Column 6 provides a text box that allows
*				the user to enter or edit the default
*				value for an ISPEC field
*
* Parameters :	table
*
* Return :		None
*
* History :		rmb	19/12/96	Initial version
*
*******************************************************/
tabFieldContents_change(table: Table input) updating;

vars
    row		: Integer;
    field	: CnEcLincFieldDef;

begin
	// this is not an ideal way to be updating this table ie upon every character being
	// entered.... 
	// however, since its unlikely that more than a couple of fields will be entered, and 
	// users have gotten used to not being requested re 

	fieldsChanged := true;
	field := tabFieldContents.itemObject.CnEcLincFieldDef;

 	beginTransaction;
 		if field.secureField then
 			field.setDefaultFieldValue ( password.trimBlanks.toUpper );

 		else 
 			field.setDefaultFieldValue ( tabFieldContents.text.trimBlanks.toUpper );
 		endif;
 	commitTransaction;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tabFieldContents_gotFocus" id="f347ca5a-60af-4ac5-af90-42df39649a37">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tabFieldContents_gotFocus(table: Table input) updating;

vars
	field : CnEcLincFieldDef;

begin
//	write "gotfocus";
//	if tabFieldContents.column = 7 then 
//		field := tabFieldContents.itemObject.LincFieldDef;
//		if field.secureField = true then 
//			tabFieldContents.text := null; 
//			password := null;
//		endif;
//	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tabFieldContents_keyPress" id="b61a7f44-b2ad-4144-9a91-0b641be3bc32">
        <controlMethod name="Table::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tabFieldContents_keyPress(table: Table input; keyCode: Integer io) updating;

vars
	strTemp	: String;

begin
	if secureInput then 

		if (keyCode &gt; 31) and (keyCode &lt; 127) then 
			password := password &amp; keyCode.Character;
			keyCode := 42;    // '*'
		elseif	keyCode = 8 then   // backspace
			if password.length &gt; 1 then 
		 		strTemp := password;
		 		password := strTemp[1:(strTemp.length - 1)];
		 	else 
		 		password := null;
		 	endif;
		else
			keyCode := 0;
		endif; 

	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tabFieldContents_lostFocus" id="b2535413-5f3a-468b-9395-7a0f5fa0e1c6">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tabFieldContents_lostFocus(table: Table input) updating;

begin
	// Update the field default values (column 7) from the database
	self.updateFieldsTable();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tabFieldContents_rowColumnChg" id="5b8c0b53-0498-4b4f-9173-9a6edb88ae97">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tabFieldContents_rowColumnChg(table: Table input) updating;

vars
	field : CnEcLincFieldDef;

begin
	if currentRow &lt;&gt; tabFieldContents.row then
		// Update the field default values (column 7) from the database
		self.updateFieldsTable();
		currentRow := tabFieldContents.row;
	endif;

	if tabFieldContents.column = 7 then
		field := tabFieldContents.itemObject.CnEcLincFieldDef;
		
		if field.secureField then 
			secureInput  := true;
			password := null;
			tabFieldContents.text := null;
		else
			self.updateFieldsTable();
			secureInput := false;
		endif;
    endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tabIspecContents_dblClick" id="25cfb73a-5da2-47ee-ad92-f219806de10b">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tabIspecContents_dblClick(table: Table input) updating;

vars
    row		: Integer;
    ispec	: CnEcLincIspecDef;

begin
	// Initialise row counter to the first (fixed) row
	row := 1;

	// Find the ISPEC that relates to the selected table row
	foreach ispec in currentLincSystem.allLincIspecDefs do
		row := row + 1; 

		if row = tabIspecContents.row then	// Set the new logon ISPEC
			beginTransaction;
   				currentLincSystem.setLogonIspec(ispec);
   			commitTransaction;
   		endif;
   	endforeach;

	populateIspecTable ();	// Refresh the table to display 'true' in the correct row
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tabTimeouts_change" id="3d6fae37-bc14-4b70-b998-cc5b62348a49">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>/*******************************************************
*
* Description : Respond to the user changing a table cell :
*				Column 2 shows the timeout values for a
*				Priority setting. A text box allows the 
*				user to enter a new value.
*
* Parameters :	table
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
tabTimeouts_change(table: Table input) updating;

vars
    row				: Integer;
	thisPriority	: Integer;
begin
	// Initialise counters
	row := 1;
	thisPriority := 0;

	// Find the Priority setting that relates to the selected table row
	while ( thisPriority &lt; currentLincSystem.Timeout_priority_count ) do
		thisPriority := thisPriority + 1;

  		row := row + 1; 

     	if ( row = tabTimeouts.row ) then

			// Set the new timeout value for the current Linc system
			beginTransaction;
     			currentLincSystem.setNewTimeoutValues ( tabTimeouts.text.Integer, thisPriority );
     		commitTransaction;
     	endif;

    endwhile;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tabTimeouts_lostFocus" id="b110f82e-6cec-4e53-adfb-f47fd074b7ca">
