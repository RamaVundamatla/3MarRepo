<CollClass name="CM_LogStockOrderLineSet" id="7bfff51e-a11a-4749-824f-db578ea0b13c">
    <memberType name="CM_LogStockOrderLine"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkOrd"/>
    <JadeMethod name="alreadyIncludesOneLikeMe" id="0d88349d-89a5-4cab-ab47-818af8b761a5">
        <source>alreadyIncludesOneLikeMe( _logStockOrderLine : CM_LogStockOrderLine; _cmif : CMIF_LogStockOrderLine; _mode : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2015	cnwndl1	Initial creation	Par 35483
04/03/2015		cnwmh5 Transient Leaks
*/

vars

	iter : Iterator;
	logStockOrderLine : CM_LogStockOrderLine;
	codeValue : String;

begin

	iter := self.createIterator;
	
	while iter.next( logStockOrderLine ) do
	
		if _logStockOrderLine = logStockOrderLine and _mode = 2 then
			//do not check yourself when updating.
			continue;
		endif;
		
		if _cmif.myLogLot &lt;&gt; logStockOrderLine.myLogLot then
			//different lot
			continue;
		endif;
		
		if logStockOrderLine.myStockOrderHeader &lt;&gt; null then
			if _cmif.myOperator &lt;&gt; logStockOrderLine.myStockOrderHeader.myOperator then
				//different supplier
				continue;
			endif;
		endif;
		
		codeValue := null;
		if _cmif.myLogSpecies &lt;&gt; null then
			codeValue := _cmif.myLogSpecies.code;
		endif;
		if codeValue &lt;&gt; logStockOrderLine.logSpeciesCode then
			//different species
			continue;
		endif;
		
		codeValue := null;
		if _cmif.myLogGrade &lt;&gt; null then
			codeValue := _cmif.myLogGrade.code;
		endif;
		if codeValue &lt;&gt; logStockOrderLine.logGradeCode then
			//different grade
			continue;
		endif;
		
		codeValue := null;
		if _cmif.myLogType &lt;&gt; null then
			codeValue := _cmif.myLogType.code;
		endif;
		if codeValue &lt;&gt; logStockOrderLine.logTypeCode then
			//different type
			continue;
		endif;
		
		codeValue := null;
		if _cmif.myLogTreatment &lt;&gt; null then
			codeValue := _cmif.myLogTreatment.code;
		endif;
		if codeValue &lt;&gt; logStockOrderLine.logTreatmentCode then
			//different treatment
			continue;
		endif;
		
		codeValue := null;
		if _cmif.myLogLength &lt;&gt; null then
			codeValue := _cmif.myLogLength.code;
		endif;
		if codeValue &lt;&gt; logStockOrderLine.logLengthCode then
			//different length
			continue;
		endif;
		
		//This one matches on Lot, Supplier, Species, Grade, Type, Treatment and Length
		return true;
		
	endwhile;
	
	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_logStockOrderLine" type="CM_LogStockOrderLine"/>
        <Parameter name="_cmif" type="CMIF_LogStockOrderLine"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
