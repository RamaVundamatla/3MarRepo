    <JadeMethod name="addToolbarControls" id="ebe3354d-1291-4361-8197-9f0c76e65456">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On By Reason
// ---------- ---------- --------------------------------------------------
// 04 Mar 2022  navgm20   TFS #53051 MTN - Add Filter to Vessel Enquiry, Voyage Enquiry
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnReportOptions, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnShowSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnVesselDefin, CMUI_Toolbar.Control_Alignment_Left);					
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	
	/*//23/04/2024	navkc1 CR63736 Task 63770 Use new filter control
		// ### TFS 53051  --START
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
		self.txtFilterBox.parent 	:= self.frmFilter;
		self.txtFilterBox.visible 	:= true;
		self.txtFilterBox.left 		:= 0;
		self.txtFilterBox.top 		:= 2; 
		toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		// ### TFS 53051 --END
	*///23/04/2024	navkc1 CR63736 Task 63770 end
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImport, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);				
	
//	if app.myCurrentUserCan(self.myTerminal, PmShipPlanning) then
	// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)
	//if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then//07 Oct 2019	NDL	TFS 46169
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
		toolbar.addButton(self.btnBayDefinition, CMUI_Toolbar.Control_Alignment_Left);
		if app.myCurrentUserCan(self.myTerminal, Mod_VesselRORO) then
			toolbar.addButton(self.btnRoRoDeckDef, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		toolbar.addButton(self.btnHoldDef, CMUI_Toolbar.Control_Alignment_Left);	//15 Jul 2013	NDL	Par 31965
		toolbar.addButton(self.btnJobPriority, CMUI_Toolbar.Control_Alignment_Left);			
		toolbar.addButton(self.btnEditCraneRate,CMUI_Toolbar.Control_Alignment_Left);
	//else
	//	self.mnuBayDefinition.visible := false;
	//endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;
	
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCloseSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	//Added 20/04/2006 to allow for captions to be shown on the search toolbar.
	self.setSearchToolbar();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnBayDefinition_click" id="7a313c1d-945f-45b4-99e6-2810b0537d72">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBayDefinition_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	29 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentVessel &lt;&gt; null then
		self.myAssistant.showVesselBayDefinForm(self.myCurrentVessel.myCellularVesselStructure, self.myMasterMenuAction, false);
	else
		self.myAssistant.showVesselBayDefinForm(null, self.myMasterMenuAction, false);
	endif;					
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
