    <JadeMethod name="isEventBlockUnit" id="c7df5674-8a25-45df-86d1-6a76970e80e3">
        <source>isEventBlockUnit( _theCalculationType : CM_CalculationType) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description
23/08/2022		jlika1		TFS 54897 	MTN - Days being charged is incorrect
****************************************************/

vars

begin
	if (_theCalculationType.calculationType = INV_CALC_TYPE_EVENT_TIME_DAYS or
		_theCalculationType.calculationType = INV_CALC_TYPE_EVENT_TIME_HOURS or
		_theCalculationType.calculationType = INV_CALC_TYPE_EVENT_TIME_MINUT or
		_theCalculationType.calculationType = INV_CALC_TYPE_EVENT_DAYS_FULL)  then
		
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_theCalculationType" type="CM_CalculationType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
