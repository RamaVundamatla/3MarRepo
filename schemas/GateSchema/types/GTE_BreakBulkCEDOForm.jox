        <source>setControlsForEdit() protected, updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.mode := self.Mode_Update;

	self.btnPrint.enabled := false;
	self.btnShowSearcher.enabled := false;
	self.btnEditItem.enabled := false;
	self.btnDelete.enabled := false;
	self.btnSelectAll.enabled := false;
