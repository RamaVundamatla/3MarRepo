    <JadeMethod name="testIsControllerRestricted" id="76e5a3fd-ec17-4457-9578-ab38aa191a51">
        <source>testIsControllerRestricted(_autoMovePlan: CMIF_AutoMovePlan input);
//Returns true if this LC has a labour or location restriction.
//If 40' TI, we check next position as well..)
// 29/04/2013	cnwcs5	par 30475 - removed isISoRequest

vars

begin

	if _autoMovePlan.myTrackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "No TI", null, null);
		return;	
	endif;
	//---------------
	//Labour Restrictions (ALWAYS!!!!)
	//---------------
	testIsControllerLabrRestricted(_autoMovePlan);
	
	if _autoMovePlan.getController = null then
		//-------------
		//Labour Restriction in force!
		//-------------
		_autoMovePlan.addLogEntry(app.getErrorString(Labour_restric_found_skippin), IsForLogging, Labour_restric_found_skippin);
		return;
	endif;
	//-------------
	//This sets targetLocation null if the location restriction wont
	//let the TI visit.
	//-------------
	self.testIsControllerLocnRestricted(_autoMovePlan);
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
