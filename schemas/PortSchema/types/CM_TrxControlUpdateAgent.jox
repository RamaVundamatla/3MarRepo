/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2018	jlgns1	Initial creation
//14/06/2018 	JLGNS1	Bug 38885: SNO - VGM Issue
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _realTI = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'TI_VGM', null, null);
		return;
	endif;

	// Start the transaction
	beginTransaction;

	app.myUtilityUA.utlUpdateContainerVGM(_realTI, _ediPrenoteTI, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
