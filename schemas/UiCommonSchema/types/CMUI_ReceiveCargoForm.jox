    <JadeMethod name="validateAustCAN" id="6b7d2787-5521-4663-bf16-db8c934d1009">
        <source>validateAustCAN():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2016	cnwndl1	Initial creation	TFS 2714

*/

vars

	str : String;
	debugReason : String;
	imexObj : CM_IMEXStatus;
	msg : String;

begin

	str := self.txtCustomsExDel.getString();
	
	if not self.myTerminal.getConfig(ValidateAustCAN).Boolean then
		// we are not doing any checking
		return true;
	endif;
	
	imexObj := self.cmbImexStatus.getObject.CM_IMEXStatus;
	if imexObj &lt;&gt; null then
		if imexObj.code = TI_IMEX_STATUS_STORAGE then
			// cargo marked as storage doesn't get checked.
			return true;
		endif;
	endif;
	
	if not app.validateAustCAN( str, debugReason ) then
		msg := self.txtCustomsExDel.getMyCaption &amp; Tab &amp; app.getErrorString(Austr_custo_autho_numbe_does_n);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
