    <JadeMethod name="zInputShipManifest" id="f8fe1b35-41c2-4122-a3ac-b3ff05fb9f70">
        <source>zInputShipManifest(voyageName : String) : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 18 June 2019
TFS#		: 44416
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	str : String;
begin
 str := '
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest&gt;
&lt;AllBOLHeader&gt;
  &lt;BOLHeader&gt;
    &lt;bolType&gt;5003&lt;/bolType&gt;
    &lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
    &lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
    &lt;id&gt;BOLVOYSHIPGEN444161&lt;/id&gt;
