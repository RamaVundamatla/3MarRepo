    <JadeMethod name="addBoolean" id="b367df37-3cfc-430e-937e-6b1a7fc48526">
        <source>addBoolean( _name : String; _value : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	ccProp : CMIF_CCPropBoolean;
	
begin

	create ccProp transient;
	ccProp.name := _name;
	ccProp.value := _value.display;
	self.properties.add(ccProp);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addDateTime" id="bcde0c8f-bb66-484c-8f19-7576804564fd">
        <source>addDateTime(_name : String;
			_value : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2019	jlger1	Initial creation

*/

vars
	ccProp : CMIF_CCPropDateTime;
	timeToSeconds : Time;
begin
	create ccProp transient;
	ccProp.name:=_name;
	timeToSeconds:=_value.time.truncateToSecond;
	ccProp.value:=_value ;
	ccProp.value.setTime(timeToSeconds);
	self.properties.add(ccProp);
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
