    <JadeMethod name="doCmbBankBuild" id="0c00b7f8-3591-4042-9e5f-76ff7f70b177">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="6ed44ea3-404e-4b49-a4d5-935f3c84e284">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
 
	while true do
 	app.myTrxDA.trxDeleteGLCode(self.myCurrentObject.CM_GLCode, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("General Ledger Code", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="38827b16-c3a2-4138-97c5-edb5164870b7">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			Filters the tree

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true;
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx); // ### TFS 51912 17Sep2021 NAVPW1 Needed as we use accessedRow below. Plus needed for columns of current row
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;

	self.tblData.topRow := 1;
	*/
end;</source>
    </JadeMethod>
