    </PrimAttribute>
    <PrimAttribute name="toInvoiceSeqNum" id="4fe5e35c-b176-4dee-bec7-5b278872f118">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getDateTime" id="d18834b1-60de-4ee3-bcec-d3b6d99fb7bd">
        <source>getDateTime() : TimeStamp;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

begin
	return self.mergeTS;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="37615119-a91b-4f46-bd8a-4059bcadfc79">
        <source>getDateTimeLocalTZ() :TimeStamp;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars

begin
	return self.systemToLocalTime(self.mergeTS);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1c64721f-1ac1-4c5d-936d-3b3e714b9502">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars

begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.remarks;	
	elseif _attrName = ETRow_User  then
		return self.mergeUser;	
	elseif _attrName = ETRow_EndDate  then
		return self.systemToLocalTime(self.mergeTS).String;		// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Ti  then
		return null;	
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMovedDTLocalTZ" id="043188b3-db88-4c0d-89dd-cfa5e8ad241e">
        <source>getMovedDTLocalTZ():TimeStamp;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars

begin
	return self.systemToLocalTime(self.mergeTS);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="2d7db7d9-8e74-434c-9bb1-29283c94e902">
        <source>getPropertyCol(): String;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars
	str : String;
begin
	str := sequenceNum.String &amp; Tab;
	str := str &amp; remarks &amp; Tab;
	str := str &amp; mergeUser &amp; Tab;
	str := str &amp; mergeTS.date.shortFormatJMT() &amp; " " &amp; mergeTS.time.currentLocaleFormatJMT() &amp; Tab;
	str := str &amp; "";

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="ef625f2c-e9e7-4368-b329-af997a13817c">
        <source>getTypeDescription(): String;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

begin
	return "Line Merged";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserId" id="b43f9c51-259c-4fb0-8bc4-b102af94bba7">
