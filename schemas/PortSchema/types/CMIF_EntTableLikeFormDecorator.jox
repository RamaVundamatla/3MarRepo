    <JadeMethod name="addGridAroundCell" id="2af4dd25-70b9-4377-abbf-b6a77c5db86d">
        <source>addGridAroundCell( _row,_column : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwer1	Initial creation

*/

vars
	table : Table;
begin
	table:=self.myTable;
	if table.accessCell(_row,_column).inputType = Table.InputType_None then
		table.accessCell(_row,_column).inputType:=Table.InputType_TextBox;
		table.accessCell(_row,_column).maxLength:=20;
	endif;
	if self.textInputBackColour = null then
		table.accessCell(_row,_column).backColor:=White;
	else
		table.accessCell(_row,_column).backColor:=self.textInputBackColour;
	endif;
	table.accessCell(_row,_column).foreColor:=self.myTable.foreColor;
	if table.rows &gt;= _row-1 then
		table.accessCell(_row-1,_column).gridBottom:=true;
		if table.accessCell(_row,_column).mergeCells &gt; 0 then
			table.accessCell(_row-1,_column+1).gridBottom:=true;
		endif;
	endif;
	table.accessCell(_row,_column).gridBottom:=true;
	table.accessCell(_row,_column).gridRight:=true;
	if table.columns &gt;= _column-1 then
		table.accessCell(_row,_column-1).gridRight:=true;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addNewEntRow" id="98bee268-2787-4213-aea0-d5df603e7fd6">
        <source>addNewEntRow(_entRow: EntTableRow) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	newRow : Integer;
	accessedCell : JadeTableCell;	
	heading : String;
	textWidth : Integer;
begin
	self.addGapRow();
	
	newRow:=self.myTable.addItem(null);
	if _entRow &lt;&gt; null then
		heading:=_entRow.getHeading(null, self.myTerminal, app.myCurrentLocale);
	endif;
	self.myTable.accessCell(newRow,self.headingColumn).text:=heading;
	
	accessedCell:=self.myTable.accessCell(newRow,self.dataColumn);
	accessedCell.inputType:=Table.InputType_None;
	self.myTable.accessRow(newRow).itemObject:=_entRow;

	return newRow;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entRow" type="EntTableRow"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addNewEntRowWithData" id="ac03830c-fa86-40f8-a525-227bb83edd9e">
        <source>addNewEntRowWithData(_entRow: EntTableRow; _data : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2012	cnwer1	Initial creation HAT 2200

*/

vars
	newRow : Integer;
begin
	newRow :=self.addNewEntRow(_entRow);
	self.myTable.accessCell(newRow,self.dataColumn).text:=_data;
	
	return newRow;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_data" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeCellInputType" id="4ffa8092-c417-4eba-ba83-a3222619071c">
        <source>changeCellInputType(_row,_col : Integer; _inputType : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	accessedCell : JadeTableCell;
begin
	accessedCell:=self.myTable.accessCell(_row,_col);
	if accessedCell.inputType = _inputType then
		return;
	endif;
	accessedCell.inputType:=_inputType;

	self.myTable.accessCell(_row,_col).foreColor:=self.myTable.foreColor;
	if _inputType =  Table.InputType_TextBox or
		 _inputType =  Table.InputType_ComboBox then	
		self.addGridAroundCell(_row,_col);
	else
		self.removeGridAroundCell(_row,_col);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_inputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeEntRowColInputType" id="0b440bf4-e1a2-4ca2-ab50-f66c112bc896">
        <source>changeEntRowColInputType(_entRowName: String; _col: Integer; _inputType: Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	entRow 		: EntTableRow;
	accessedCell : JadeTableCell;
	row			 : Integer;
begin
	entRow := self.myEntTableDef.getEntTableRow(_entRowName);
	if entRow = null then
		return;
	endif;
	row :=self.findRowWithEntRow(entRow);
	if row = 0 then
		return;
	endif;
	self.changeCellInputType(row,self.dataColumn,_inputType);
	

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_inputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatGapRow" id="fb73535a-22af-4b80-a543-e4ad2718a868">
        <source>formatGapRow(newRow : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.myTable.accessRow(newRow).height:=self.getGapRowHeight();
	self.myTable.accessRow(newRow).enabled:=false;
epilog

end;</source>
        <access>protected</access>
