    <JadeMethod name="totLocations" id="c6958782-14ba-480f-86bb-4ba51157fb03">
        <methodInvocation>mapping</methodInvocation>
        <source>totLocations(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		return;
	else
		_value := self.totalLocnEmpty + self.totalLocnOccupied;
		if _value = 0 then
			_value := 1;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateFromLC" id="84fdd7cc-1ada-4f75-a3e5-9e8faf9a2293">
        <updating/>
        <source>updateFromLC(_lc : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		07 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _lc.allTrackedItems.isEmpty then
		self.totalLocnEmpty := self.totalLocnEmpty + 1;
		self.totalLocnOccupied := self.totalLocnOccupied - 1;
	else
		if _lc.allTrackedItems.size = self.maxStackHeight then
			self.totalLocnFull := self.totalLocnFull + 1;
		endif;
		if _lc.allTrackedItems.size = 1 then // was empty
			self.totalLocnOccupied := self.totalLocnOccupied + 1;
			self.totalLocnEmpty := self.totalLocnEmpty - 1;
		endif;
	endif;
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="updateFromMOVE" id="47521d85-2a5e-41e6-8e35-b9b88c1bf6fb">
        <updating/>
        <source>updateFromMOVE(_params : String) updating;
// ---------------------------------------------------------------------------
// Created:		07 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
vars
	array : StringArray;
	totTEU : Real;
	maxTIs, stackIndex, stackValue, totTI, padsMT, padsOccupied, padsFull : Integer;
begin
	
	// 22 Jun 2016	NDL	TFS 1752 - No longer update from notes...
	return;
	

/*	create array transient;
	_params.getTokensForDelimiter(Delimiter, array);
	
	if array.size &lt;&gt; 8 then
		return;
	endif;
	
	totTI := array[1].Integer;
	totTEU := array[2].Real;
	padsMT := array[3].Integer;
	padsOccupied := array[4].Integer;
	padsFull := array[5].Integer;
	stackIndex := array[6].Integer;
	stackValue := array[7].Integer;
	maxTIs := array[8].Integer;

	// These numbers are adjusters they should have a value of 1, 0 or -1
	
	self.totalTEUs := self.totalTEUs + totTEU;
	self.totalTIs := self.totalTIs + totTI;
	self.totalLocnEmpty := self.totalLocnEmpty + padsMT;
	self.totalLocnFull := self.totalLocnFull + padsFull;
	self.totalLocnOccupied := self.totalLocnOccupied + padsOccupied;
	self.availStackHeights[stackIndex] := self.availStackHeights[stackIndex] + stackValue;
	self.maxTIs := self.maxTIs + maxTIs;

	*/
epilog
	delete array;
end;</source>
        <Parameter name="_params" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateFromTI" id="eed33b38-6518-43c0-b9e4-e96a1762967b">
        <updating/>
        <source>updateFromTI(_in : Boolean; _ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		07 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	teu : Real;
	inOut : Integer;
begin
	if _in then
		inOut := 1;
	else
		inOut := -1;
	endif;
	
	teu := _ti.getNumTEU(); // PAR 16415 CCMS 1029
	self.totalTEUs := self.totalTEUs + (teu * inOut);
	/*
	if _ti.isForty() then
		self.totalTEUs := self.totalTEUs + (2 * inOut);
	else
		self.totalTEUs := self.totalTEUs + (1 * inOut);
	endif;
	*/
	self.totalTIs := self.totalTIs + (1 * inOut);
		
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateLocnTotals" id="ad7c1736-f5d3-4b4f-a99f-3361bd72acc0">
        <updating/>
        <source>updateLocnTotals(_lc : CM_LocationsController; _mt : Boolean; _full : Boolean; _stackedTo : Integer; _locnActualMax : Integer; _agent : CMIF_SpaceUtilisationQryAgent input) updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
//20 Jul 2021	NDL	TFS 51518 Make Block Stacks and other new Terminal Areas actually work.
// ---------------------------------------------------------------------------
vars
	fromSlot,toSlot,avail : Integer;
	minMax : CM_TerminalAreaProductMinMax;
	footPrint : Decimal [16,4];
	areaTotalItems : Integer;
	areaTotalQuantity : Integer;
	areaTotalVolume : Decimal [16,4];
	areaTotalWeight : Decimal [16,4];
	ta : CM_TerminalArea;
	ti : CM_TrackedItem;	//20 Jul 2021	NDL	TFS 51518
	roroTeuAvailLength : Decimal [12,1];	//20 Jul 2021	NDL	TFS 51518
	roroTeuUsedLength : Decimal [12,1];	//20 Jul 2021	NDL	TFS 51518
	bsCap : Integer;	//20 Jul 2021	NDL	TFS 51518
	tiArray : CM_TIArray;	//20 Jul 2021	NDL	TFS 51518
	locTotTEUs : Real;
begin
	
	
	if self.getTA.CM_TerminalArea.isIrregularBlockArea then	//22 Jun 2016	NDL	TFS 1752
		if _lc.isKindOf(CM_RackShelfController) then
			//we only process the ground position objects
			return;
		else
			minMax :=  _lc.getMinMaxForFirstTI();
			if minMax = null then
		//		self.maxTIs := self.maxTIs + _lc.CM_IrregularBlockController.getCurrentCapacity;
				//20 Jul 2021	NDL	TFS 51518 - should be 'teu' if we can work it out
				ti := _lc.allTrackedItems.first;
				if ti = null or ti.getNumTEU = 0 then
					self.maxTIs := self.maxTIs + _lc.CM_IrregularBlockController.getCurrentCapacity;
				else
					self.maxTIs := self.maxTIs + ( _lc.CM_IrregularBlockController.getCurrentCapacity / ti.getNumTEU ).rounded;
				endif;
			else
				footPrint := _lc.CM_IrregularBlockController.getFootPrintInMetres();
		//		self.maxTIs := self.maxTIs + ( (footPrint * minMax.maxQuantity).truncated );
				//20 Jul 2021	NDL	TFS 51518 - should be 'teu' if we can work it out
				ti := _lc.allTrackedItems.first;
				if ti = null or ti.getNumTEU = 0 then
					self.maxTIs := self.maxTIs + ( (footPrint * minMax.maxQuantity).truncated );
				else
					self.maxTIs := self.maxTIs + ( (footPrint * minMax.maxQuantity).truncated / ti.getNumTEU ).rounded;
				endif;
				self.capacityVolume := self.capacityVolume + ( footPrint * minMax.maxVolume );
				self.capacityWeight := self.capacityWeight + ( footPrint * minMax.maxWeight );
			endif;
			create tiArray transient;
			_lc.CM_IrregularBlockController.getTIs( tiArray, REAL_MODE, true );
			foreach ti in tiArray do
				if not _agent.allQryCargoTypes.isEmpty and not _agent.allQryCargoTypes.includes( ti.myCargoType ) then
					continue;
				endif;
				self.totalTEUs := self.totalTEUs + ti.getNumTEU;
			endforeach;
			delete tiArray;
			if self.maxTIs &gt; self.totalTEUs then
				self.availStackHeights[1] := ( self.maxTIs - self.totalTEUs ).rounded;
				self.maxStackHeight := 1;
			endif;
		endif;
		
	elseif _lc.isRoRoController then	//22 Jun 2016	NDL	TFS 1752
		self.capacityLength := self.capacityLength + _lc.CM_RoRoController.length;
		self.totalLength := self.totalLength + _lc.CM_RoRoController.usedLengthActual;

		roroTeuAvailLength := ( _lc.CM_RoRoController.length / ( 20 * .3048 ) ).roundedTo(1);	//20 Jul 2021	NDL	TFS 51518 - 20ft units
		roroTeuUsedLength := ( _lc.CM_RoRoController.usedLengthActual / ( 20 * .3048 ) ).roundedTo(1);	//20 Jul 2021	NDL	TFS 51518 - 20ft units
		self.maxTIs := self.maxTIs + roroTeuAvailLength.rounded;
		self.totalTEUs := self.totalTEUs + roroTeuUsedLength;
		if self.maxTIs &gt; self.totalTEUs then
			self.availStackHeights[1] := ( self.maxTIs - self.totalTEUs ).rounded;
			self.maxStackHeight := 1;
		endif;
	
	elseif self.getTA.CM_TerminalArea.isBulkArea then	//22 Jun 2016	NDL	TFS 1752
		minMax :=  _lc.getMinMaxForFirstTI();
		if minMax = null then
			ta := self.getTA.CM_TerminalArea;
			ti := _lc.allTrackedItems.first;
			if ta.isKindOf(CM_BulkArea) then
				self.capacityVolume := self.getTA.CM_BulkArea.maxVolume;
				self.capacityWeight := self.getTA.CM_BulkArea.maxVolume;
			elseif ta.isKindOf(CM_BlockStack) then
				//	self.maxTIs := self.getTA.CM_BlockStack.getMaxCapacity;
				//20 Jul 2021	NDL	TFS 51518
				bsCap := ta.CM_BlockStack.getMaxCapacity;
				if bsCap = 0 then
					//Just use the foot print value. Its better than nothing, we just don't have a height
					bsCap := ( ta.CM_BlockStack.columns * ta.CM_BlockStack.rows );
				endif;
				if ti = null or ti.isContainer or ti.getNumTEU = 0 then
					self.maxTIs := bsCap;
				else
					self.maxTIs := ( bsCap / ti.getNumTEU ).rounded;
				endif;
				foreach ti in _lc.allTrackedItems do
					if not _agent.allQryCargoTypes.isEmpty and not _agent.allQryCargoTypes.includes( ti.myCargoType ) then
						continue;
					endif;
					self.totalTEUs := self.totalTEUs + ti.getNumTEU;
				endforeach;
				if bsCap &gt; self.totalTEUs then
					self.availStackHeights[1] := ( bsCap - self.totalTEUs ).rounded;
					self.maxStackHeight := 1;
				endif;
				
			endif;
		else
		//	self.maxTIs := self.maxTIs + minMax.maxQuantity;
			if ti = null or ti.getNumTEU = 0 then
				self.maxTIs := minMax.maxQuantity;
			else
				self.maxTIs := ( minMax.maxQuantity / ti.getNumTEU ).rounded;
			endif;
			self.capacityVolume := self.capacityVolume + minMax.maxVolume;
			self.capacityWeight := self.capacityWeight + minMax.maxWeight;
		endif;
	
/*	elseif self.getTA.CM_TerminalArea.isBlockStack then          //26/02/2015  cnwma1 PAR #33352
		minMax :=  _lc.getMinMaxForFirstTI();
		if minMax = null then
			self.maxTIs := self.getTA.CM_BlockStack.getMaxCapacity;
		else
			//22 Jun 2016	NDL	TFS 1752
			self.maxTIs := self.maxTIs + minMax.maxQuantity;	
			self.capacityVolume := self.capacityVolume + minMax.maxVolume;
			self.capacityWeight := self.capacityWeight + minMax.maxWeight;
		endif; */
		
	else
		self.maxTIs := self.maxTIs + _locnActualMax;
	endif;
	
	//22 Jun 2016	NDL	TFS 1752
//	_lc.getTotalsQVW( areaTotalItems, areaTotalQuantity, areaTotalVolume, areaTotalWeight );
//	self.totalQuantity := self.totalQuantity + areaTotalQuantity;
//	self.totalVolume := self.totalVolume + areaTotalVolume;
//	self.totalWeight := self.totalWeight + areaTotalWeight;
	
	//22 Jun 2016	NDL	TFS 1752
	if self.getTA.CM_TerminalArea.isIrregularBlockArea
	or _lc.isRoRoController
	or self.getTA.CM_TerminalArea.isBulkArea
	or self.getTA.CM_TerminalArea.isBlockStack
	then
		return;
	endif;
	
	toSlot := _locnActualMax;
	if toSlot = 0 then
		toSlot := self.maxStackHeight;
	endif;
	
	if _mt then
		self.totalLocnEmpty := self.totalLocnEmpty + 1; // nothing
		if _locnActualMax = 0 then // is empty and has height restrictions to stack nothing.
			return;
		endif;
		
		fromSlot := 1;
	else
		self.totalLocnOccupied := self.totalLocnOccupied + 1; // something
		
		fromSlot := _stackedTo + 1;
		
		if _full then
			self.totalLocnFull := self.totalLocnFull + 1; // maxed
			return; // is full .
		else
			fromSlot := _stackedTo + 1;
		endif;
	endif;

	if self.availStackHeights.size &lt;&gt; 0 then
		foreach avail in fromSlot to toSlot do
			self.availStackHeights[avail] := self.availStackHeights[avail] + 1;
		endforeach;
	endif;
	
epilog

	delete tiArray;
	
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_mt" type="Boolean"/>
        <Parameter name="_full" type="Boolean"/>
        <Parameter name="_stackedTo" type="Integer"/>
        <Parameter name="_locnActualMax" type="Integer"/>
        <Parameter name="_agent" type="CMIF_SpaceUtilisationQryAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTotals" id="0b2c0bc3-ee67-4bf4-aa4c-1df4cda2d041">
        <updating/>
        <source>updateTotals(_tmpTi : CM_TrackedItem) updating;
//updateTotals(_is40 : Boolean) updating;  	//26/02/2015  cnwma1 PAR #33352
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars

	ct : CM_CargoType;
	lc : CM_LocationsController;
	
begin

	//22 Jun 2016	NDL	TFS 1752
	ct := _tmpTi.myCargoType;
	if ct.productType = ProductType_Bulk then
		if ct.isTrackByWeight then
			self.totalWeight := self.totalWeight + _tmpTi.totalWeight;
		elseif ct.isTrackByVolume then
			self.totalVolume := self.totalVolume + _tmpTi.totalVolume;
		endif;
		self.totalQuantity := self.totalQuantity + _tmpTi.totalQuantity.max(1);
	elseif ct.isBreakBulk then
		self.totalQuantity := self.totalQuantity + _tmpTi.totalQuantity.max(1);
	else
		self.totalQuantity := self.totalQuantity + _tmpTi.totalQuantity.max(1);
	endif;

	self.totalTIs := self.totalTIs + 1;
	
	/*if _is40 then								//26/02/2015  cnwma1 PAR #33352
		self.totalTEUs := self.totalTEUs + 2;
	else
		self.totalTEUs := self.totalTEUs + 1;
	endif;*/
	
	lc := _tmpTi.myPrimaryActualLocation;
	if lc &lt;&gt; null then
		if lc.isRoRoController
		or lc.isKindOf( CM_IrregularBlockController )
		or lc.getMyTerminalArea.isKindOf( CM_BlockStack )
		then
			return;
		endif;
	endif;
	self.totalTEUs := self.totalTEUs + _tmpTi.getNumTEU;		//26/02/2015  cnwma1 PAR #33352
	
end;</source>
        <Parameter name="_tmpTi" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
