    <JadeMethod name="getTrucksUsed" id="22d39377-3850-4d0c-807e-ca5f07eda848">
        <source>getTrucksUsed(truckArray : CM_VehicleArray io );
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 July 2019
TFS#		: 45289
Function	: Copied from MobileUISchema::MOB_HandHeldForm::getTrucksFromBulkRelease

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	request	: CM_Request;
	roadJob : CM_RoadJob;
	truck 	: CM_Vehicle;
begin	
	if self.isRoadType then
		foreach request in self.allRequestsBeingActioned do
			if request.myJob = null or not request.myJob.isRoadJob then
				//Not a road job
				continue;
			endif;
			roadJob := request.myJob.CM_RoadJob;
			if roadJob.isCompleteForExit then
				// already completed
				continue;
			endif;
			if roadJob.myVehicleVisit = null or not roadJob.myVehicleVisit.isIncomplete then
				// NOT incomplete
				continue;
			endif;
			truck := roadJob.myVehicle;
			if truck &lt;&gt; null then
				truckArray.addExclusive( truck );
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="truckArray" type="CM_VehicleArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="bfedcda6-845d-4a4c-8d8f-a4053d0a3db5">
