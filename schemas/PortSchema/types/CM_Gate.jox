    <JadeMethod name="getInTransitToYardLocation" id="d5ac348e-c0b3-41b7-bcf0-c17142e573dd">
        <source>getInTransitToYardLocation():CM_YardController;
// ---------------------------------------------------------------------------
// Created:     17 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     The default location for vehicle going into yard
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	icArea	:CM_InterchangeArea;
begin
	icArea := self.myDefaultInterchangeArea;
	
	if icArea = null then
		return null;
	endif;
	
	return icArea.myInTransitToLocation;
epilog

end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getNextLocation_IN" id="b2759624-c51f-4cc7-9df0-71f38414f9a5">
        <source>getNextLocation_IN(_vehicle :CM_Vehicle):CM_YardController;
// ---------------------------------------------------------------------------
// Created:     20 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc		:CM_YardController;
	usage	:CM_GateAreaUsage;
	area	:CM_TerminalArea;
	got_it	:Boolean;
begin
	lc := _vehicle.myPrimaryActualLocation;
	
	if lc = null then
		// put them i-t-t the first gate area for the a-gate
		usage := self.allGateAreas_IN.first;
		
		if usage = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Gate has no gate areas');
		endif;
		
		area := usage.myGateArea;
		
		return area.CM_GateArea.myInTransitToLocation;	// in transit to gate 
	endif;
	
	area := lc.myTerminalArea;
	
	if not area.isGateArea then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for vehicle not at gate');
	endif;
	
	if not self.hasGateArea_IN (area.CM_GateArea) then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for vehicle at different gate');
	endif;
	
	foreach usage in self.allGateAreas_IN do
		if usage.myGateArea = area.CM_GateArea then
			got_it := true;
			continue;
		endif;
		if usage.isTrouble then
			// we won't put them in trouble automatically
			continue;
		endif;
		if got_it then
			// next gate area
			return usage.myGateArea.myInTransitToLocation;
		endif;
	endforeach;
	
	// if we get to here the area must have been last in the collection - send them into the yard
	return self.getDefaultYardLocation_IN (_vehicle);
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getPGateAreas_IN" id="b1bf6271-0a3e-4963-9c93-d69f2c96db26">
        <source>getPGateAreas_IN(_coll :CM_ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	usage	:CM_GateAreaUsage;
begin
	foreach usage in self.allGateAreas_IN do
		if usage.isPGate then
			_coll.addNoDuplicates (usage.myGateArea, false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
