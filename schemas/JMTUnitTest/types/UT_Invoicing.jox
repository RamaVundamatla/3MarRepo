    <JadeMethod name="validateEscalatingCharges6" id="0306a678-6f18-441f-9a4a-619309ff4e0e">
        <source>validateEscalatingCharges6(_ti : CM_TrackedItem; _instance : Integer);
//	 for tStorageQRMTest, each has 2 storage transactions with 2 or 3 invoice lines in total
vars
	msg			: String;
	qty1,
	qty2		: Integer;
	invCount	: Integer;
	invLine	: CM_InvoiceLine;
begin
	// expected quantities
	if _instance = 1 then
		qty1 := 1;
		qty2 := 0;
	elseif _instance = 2 then
		qty1 := 2;
		qty2 := 0;
	elseif _instance = 3 then
		qty1 := 2;
		qty2 := 1;
	elseif _instance = 4 then
		qty1 := 2;
		qty2 := 2;
	elseif _instance = 5 then
		qty1 := 2;
		qty2 := 3;
	elseif _instance = 6 then
		qty1 := 2;
		qty2 := 4;
	endif;
	msg := "TI " &amp; _instance.String &amp; " ";

	foreach invLine in _ti.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, 3.Real, msg &amp; "line 1 quantity");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", msg &amp; "line 1 ILD");
		elseif invCount = 2 then
			self.assertEqualMsg(invLine.quantity, qty1.Real, msg &amp; "line 2 quantity");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", msg &amp; "line 2 ILD");
		elseif invCount = 3 then
			self.assertEqualMsg(invLine.quantity,qty2.Real, msg &amp; "line 3 quantity");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore2", msg &amp; "line 3 ILD");
		endif;
	endforeach;
	if _instance &lt; 3 then
		self.assertEqualMsg(invCount, 2, "Storage invoice lines");
	else
		self.assertEqualMsg(invCount, 3, "storage invoice lines");
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_instance" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateFirstLastExports" id="79826b17-fce2-4c34-abb9-83245a3602e0">
        <source>validateFirstLastExports(_voyage : CM_Voyage; _include : Boolean);

vars
	transCount,
	invCount	: Integer;
	disp1,
	disp2	: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach ti in _voyage.allExportTIs do
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				transCount := transCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 13.Real, transCount.String &amp; " Export quantity");
						else
							self.assertEqualMsg(invLine.quantity, 12.Real, transCount.String &amp; " Export quantity");
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeLastLoad", "Export ILD");
					endif;
				endforeach;
				self.assertEqualMsg(invCount, 1, transCount.String &amp; " Export invoice lines");
				disp1 := trans.getDisplayStringForAttribute(ETRow_Details,false);
				disp2 := trans.getEnquiryRow;
				if disp2.length &gt; 18 then
					disp2 := disp2[disp2.length-18:end];
				endif;
				if _include then
					self.assertEqualMsg(disp1, "Stored for 13 days ", transCount.String &amp; " Export getDisplayString");
					self.assertEqualMsg(disp2, "Stored for 13 days ", transCount.String &amp; " Export getEquiryRow");
				else
					self.assertEqualMsg(disp1, "Stored for 12 days ", transCount.String &amp; " Export getDisplayString");
					self.assertEqualMsg(disp2, "Stored for 12 days ", transCount.String &amp; " Export getEquiryRow");
				endif;
			endif;
		endforeach;
	endforeach;
	// REEF2077447 and REEF4077441 don't have storage for some reason, so total is 34 not 36
	// also after changes to over-height containers Dec 2011 the 5 over-dimensioned containers don't get planned so total shrinks to 29
	//self.assertEqualMsg(transCount, 29, "Export storage transactions");
	// using the instant moves, all cargo gets moved so back to 36 tracked items and hence storage transactions
	self.assertEqualMsg(transCount, 4, "Export storage transactions");
	
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateFirstLastImports" id="e45b8ee4-ff3b-4c3d-948c-cb36824ef72d">
        <source>validateFirstLastImports(_voyage : CM_Voyage; _include : Boolean);
// the first three imported TIs have two storage transactions, to test escalating storage handling, of 9 days and 2 days (exclusive)
//  or 10 and 2 exclusive.  Each storage transaction should have one invoice line only.
vars
	hasTwoStorage	: Boolean;
	tiCount,
	transCount,
	perTiCount,
	invCount	: Integer;
	disp1,
 	disp2	: String;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	tiId : String;
begin
	foreach ti in _voyage.allImportTIs do
		hasTwoStorage := false;
		if ti.id = "GENL2X22331" or
		   ti.id = "GENL2X22334" or
		   ti.id = "GENL2X22335" then
			hasTwoStorage := true;
		endif;
		tiCount := tiCount + 1;
		id := tiCount.String &amp; " " &amp; ti.id;
		perTiCount := 0;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				transCount := transCount + 1;
				perTiCount := perTiCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if _include then
						if not hasTwoStorage then
							self.assertEqualMsg(invLine.quantity, 12.Real, method.qualifiedName &amp; " 1 - " &amp; id &amp; " Import quantity");
						else
							if perTiCount = 1 then
								self.assertEqualMsg(invLine.quantity, 10.Real, method.qualifiedName &amp; " 2 - " &amp;  id &amp; " Import quantity");
							else
								self.assertEqualMsg(invLine.quantity, 2.Real, id &amp; " Import quantity");
							endif;
						endif;
					else
						if not hasTwoStorage then
							self.assertEqualMsg(invLine.quantity, 11.Real, method.qualifiedName &amp; " 3 - " &amp;  id &amp; " Import quantity");
						else
							if perTiCount = 1 then
								self.assertEqualMsg(invLine.quantity, 9.Real, method.qualifiedName &amp; " 4 - " &amp;  id &amp; " Import quantity");
							else
								self.assertEqualMsg(invLine.quantity, 2.Real, method.qualifiedName &amp; " 5 - " &amp;  id &amp; " Import quantity");
							endif;
						endif;
					endif;
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeFirstDischarge", id &amp; " Import ILD");
				endforeach;
				self.assertEqualMsg(invCount, 1, id &amp; " Import invoice line(s)");
				disp1 := trans.getDisplayStringForAttribute(ETRow_Details,false);
				disp2 := trans.getEnquiryRow;
				if disp2.length &gt; 18 then
					disp2 := disp2[disp2.length-17:end];
				endif;
				if _include then
					if not hasTwoStorage then
						self.assertEqualMsg(disp1, "Stored for 12 days ", method.qualifiedName &amp; " 6 - " &amp;  id &amp; " Import getDisplayString");
						self.assertEqualMsg(disp2, "tored for 12 days ", method.qualifiedName &amp; " 6 - " &amp;  id &amp; " Import getEquiryRow");
					else
						if perTiCount = 1 then
							self.assertEqualMsg(disp1, "Stored for 10 days ", method.qualifiedName &amp; " 7 - " &amp;  id &amp; " Import getDisplayString");
							self.assertEqualMsg(disp2, "tored for 10 days ", method.qualifiedName &amp; " 8 - " &amp;  id &amp; " Import getEquiryRow");
						else
							self.assertEqualMsg(disp1, "Stored for 2 days ", method.qualifiedName &amp; " 9 - " &amp;  id &amp; " Import getDisplayString");
							self.assertEqualMsg(disp2, "Stored for 2 days ", method.qualifiedName &amp; " 10 - " &amp;  id &amp; " Import getEquiryRow");
						endif;
					endif;
				else
					if not hasTwoStorage then
						self.assertEqualMsg(disp1, "Stored for 11 days ", method.qualifiedName &amp; " 11 - " &amp;  id &amp; " Import getDisplayString");
						self.assertEqualMsg(disp2, "tored for 11 days ", id &amp; " Import getEquiryRow");
					else
						if perTiCount = 1 then
							self.assertEqualMsg(disp1, "Stored for 9 days ", method.qualifiedName &amp; " 12 - " &amp;  id &amp; " Import getDisplayString");
							self.assertEqualMsg(disp2, "Stored for 9 days ", method.qualifiedName &amp; " 13 - " &amp;  id &amp; " Import getEquiryRow");
						else
							self.assertEqualMsg(disp1, "Stored for 2 days ", method.qualifiedName &amp; " 14 - " &amp;  id &amp; " Import getDisplayString");
							self.assertEqualMsg(disp2, "Stored for 2 days ", method.qualifiedName &amp; " 15 - " &amp;  id &amp; " Import getEquiryRow");
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
	// first two TIs have 2 storage, the rest have 1.  Should be 4 TIs, so 6 transactions.
	self.assertEqualMsg(transCount, 6,  method.qualifiedName &amp; " 16 - " &amp;  "Import storage transactions");
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateFirstLastImports2" id="83ddb85e-6c1d-4156-a3d2-252d365b1dc1">
        <source>validateFirstLastImports2(_voyage : CM_Voyage; _include : Boolean);
// 
vars
	tiCount,
	transCount,
	perTiCount,
	invCount	: Integer;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach ti in _voyage.allImportTIs do
		tiCount := tiCount + 1;
		perTiCount := 0;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				transCount := transCount + 1;
				perTiCount := perTiCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					id := tiCount.String &amp; " " &amp; ti.id &amp; " inv " &amp; invCount.String;
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 6.Real, id &amp; " Import quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTLineTypeLL16To21", id &amp; " Import ILD");
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 7.Real, id &amp; " Import quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTLineTypeLL22To28", id &amp; " Import ILD");
					elseif invCount = 3 then
						self.assertEqualMsg(invLine.quantity, 7.Real, id &amp; " Import quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTLineTypeLL29To35", id &amp; " Import ILD");
					elseif invCount = 4 then
						self.assertEqualMsg(invLine.quantity, 7.Real, id &amp; " Import quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTLineTypeLL36To42", id &amp; " Import ILD");
					elseif invCount = 5 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 132.Real, id &amp; " Import quantity");
						else
							self.assertEqualMsg(invLine.quantity, 131.Real, id &amp; " Import quantity");
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTLineTypeLL43To49", id &amp; " Import ILD");
					endif;
				endforeach;
				id := tiCount.String &amp; " " &amp; ti.id;
				self.assertEqualMsg(invCount, 5, id &amp; " Import invoice line(s)");
			endif;
		endforeach;
		self.assertEqualMsg(perTiCount, 1, ti.id &amp; " Import storage transaction per TI");
	endforeach;
	
	self.assertEqualMsg(transCount, 6, "Import storage transactions");
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateFirstLastImports3" id="7627f7d4-d4a9-4db3-a4b4-3d82aa598f3a">
        <source>validateFirstLastImports3(_voyage : CM_Voyage; _include : Boolean);
// 
vars
	tiCount,
	transCount,
	perTiCount,
	invCount	: Integer;
	ild,
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin

	foreach ti in _voyage.allImportTIs do
		tiCount := tiCount + 1;
		perTiCount := 0;
		if ti.isForty() then
			ild := "UTLineType40LL16ToMax";
		else
			ild := "UTLineType20LL16ToMax";
		endif;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				transCount := transCount + 1;
				perTiCount := perTiCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					id := tiCount.String &amp; " " &amp; ti.id &amp; " inv " &amp; invCount.String;
					if invCount = 1 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 200.Real, id &amp; " Import quantity");
						else
							self.assertEqualMsg(invLine.quantity, 199.Real, id &amp; " Import quantity");
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, ild, id &amp; " Import ILD");
					endif;
				endforeach;
				id := tiCount.String &amp; " " &amp; ti.id;
				self.assertEqualMsg(invCount, 1, id &amp; " Import invoice line(s)");
			endif;
		endforeach;
		self.assertEqualMsg(perTiCount, 1, ti.id &amp; " Import storage transaction per TI");
	endforeach;
	
	self.assertEqualMsg(transCount, 8, "Import storage transactions");
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateGPHAInvoiceFiles" id="87c24b4a-a8dd-4784-af45-820d0c2d2628">
        <source>validateGPHAInvoiceFiles(_invoice : CM_Invoice);
/*
Purpose:			
Date		Who		Reason
21 May 2013	NAVAB1	Initial creation
12 Oct 2015 cnwjre1	37040 TFS 778 (dev 901) file format is now XML not CSV
12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
25 Mar 2020	jlgdap1	TFS 48959 GPHA MS Dynamics Interface Enhancement
*/
vars
	now : TimeStamp;
	ioFin : CM_GPHAInterface;
	oArray : ObjectArray;
	field,
	value, path, line, expectedLine	: String;
	file : File;
	pos,
	idx	: Integer;
	invLine : CM_InvoiceLine;
	checkDecimal10 : Boolean;

begin

	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	create oArray transient;
	CM_GPHAInterface.allInstances(oArray, 0, false);
	ioFin := oArray[1].CM_GPHAInterface;
	
	path := ioFin.exportPath.normaliseDirectory().substituteDirectory();
	
	create file;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	// ### CHECK GPHA FILE
	file.fileName := path &amp; _invoice.sequenceNum.String &amp;  ".xml";
	invLine := _invoice.invoiceLines.first;
	idx := 0;
	while not file.endOfFile do
		checkDecimal10 := false;
		line := file.readLine();
		idx := idx + 1;
	//write idx.String &amp; " "   &amp; line;
	//continue;
		expectedLine := "";
		if idx = 1 then
			expectedLine := '&lt;?xml version="1.0"?&gt;';
		elseif idx = 2 then
			//expectedLine := '&lt;ns0:Invoice xmlns:ns0="http://JMT_INTEGRATION_PROD.InvoiceXML"&gt;';	// TFS 48959
			expectedLine := '&lt;JMT&gt;';																// TFS 48959	// TFS 49178
		elseif idx = 5 then
			expectedLine := '&lt;DebtorName&gt;UT_MDHDebtorZ&lt;/DebtorName&gt;';
		elseif idx = 6 then
			expectedLine := '&lt;SequenceNo&gt;' &amp; _invoice.sequenceNum.String &amp; '&lt;/SequenceNo&gt;';
		elseif idx = 7 then
			expectedLine := '&lt;Description&gt;Unit test&lt;/Description&gt;';
		elseif idx = 8 then
			expectedLine := '&lt;InvoiceFrom&gt;' &amp; _invoice.fromDT.date.format("d/M/yyy") &amp; '&lt;/InvoiceFrom&gt;';
		elseif idx = 12 then	
			expectedLine := '&lt;PurchaseOrder&gt;ABC123&lt;/PurchaseOrder&gt;';
		elseif idx = 18 then
			expectedLine := '&lt;TermsOfTrade&gt;End Of Month&lt;/TermsOfTrade&gt;';
		//elseif idx = 28 then																				// TFS 48959
		//	expectedLine := '&lt;Quantity&gt;' &amp; invLine.quantity.String &amp; '&lt;/Quantity&gt;';							// TFS 48959
		elseif idx = 37 then																				// TFS 48959
			//expectedLine := '&lt;Quantity&gt;' &amp; invLine.quantity.String.padDecimalsWithZeros(4) &amp; '&lt;/Quantity&gt;';	// TFS 48959
			expectedLine := '&lt;Quantity&gt;' &amp; invLine.getLineQuantityTen() &amp; '&lt;/Quantity&gt;';
			checkDecimal10 := true;
			field := "getLineQuantityTen";
			value := invLine.getLineQuantityTen();
			self.assertEqualMsg(value, "16823.0123654321", "quantity value should be exactly the same");
		//elseif idx = 29 then																				// TFS 48959
		elseif idx = 39 then																				// TFS 48959
			expectedLine := '&lt;Rate&gt;' &amp; invLine.getRate().String &amp; '&lt;/Rate&gt;';
		elseif idx = 40 then																				//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
			expectedLine := '&lt;TotalExclTax&gt;' &amp; invLine.getLineTotalTen().String &amp; '&lt;/TotalExclTax&gt;';
			checkDecimal10 := true;
			field := "getLineTotalTen";
			value := invLine.getLineTotalTen().String;
			self.assertEqualMsg(value, "1413.1330386963", "total excl tax value should be exactly the same");
		//elseif idx = 30 then																				// TFS 48959
		elseif idx = 41 then																				// TFS 48959
			expectedLine := '&lt;GLCode&gt;1235-993838&lt;/GLCode&gt;';
		//elseif idx = 31 then																				// TFS 48959
		elseif idx = 42 then																				// TFS 48959
			expectedLine := '&lt;ServiceName&gt;' &amp; invLine.invoiceLineDesc.narration.String &amp; '&lt;/ServiceName&gt;';
		elseif idx = 43 then																				//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
			expectedLine := '&lt;ExternalReference1&gt;' &amp; invLine.getFirstServiceRef1() &amp; '&lt;/ExternalReference1&gt;';
		elseif idx = 44 then																				//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
			expectedLine := '&lt;ExternalReference2&gt;' &amp; invLine.getFirstServiceRef2() &amp; '&lt;/ExternalReference2&gt;';
		//elseif idx = 32 then																				// TFS 48959
		elseif idx = 45 then																				// TFS 48959
			expectedLine := '&lt;TaxCode&gt;UT_GPHATAX&lt;/TaxCode&gt;';		// test 37586
		elseif idx = 46 then																				//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
			expectedLine := '&lt;TaxValue&gt;' &amp; invLine.getTotalTaxAmountForLineTen().String &amp; '&lt;/TaxValue&gt;';		
			checkDecimal10 := true;
			field := "getTotalTaxAmountForLineTen";
			value := invLine.getTotalTaxAmountForLineTen().String;
			self.assertEqualMsg(value, "240.2326165784", "tax value should be exactly the same");
			
		elseif idx = 47 then																				//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
			expectedLine := '&lt;TotalInclTax&gt;' &amp; invLine.getLineTotalWithTaxTen().String &amp; '&lt;/TotalInclTax&gt;';		
			checkDecimal10 := true;
			field := "getLineTotalWithTaxTen";
			value := invLine.getLineTotalWithTaxTen().String;
			self.assertEqualMsg(value, "1653.3656552747", "tax value should be exactly the same");
		endif;
		if expectedLine &lt;&gt; null then
			self.assertEqualMsg(line, expectedLine, "Error in line " &amp; idx.String);
		endif;
		//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
		if checkDecimal10 then
			pos := value.pos(".", 1);
			self.assertEqualMsg(value[pos+1:end].length(), 10, field &amp; " decimal not 10");
		endif;
	endwhile;
	//self.assertEqualMsg(idx, 85, "Invoice export file lines");											// TFS 48959
	//self.assertEqualMsg(idx, 100, "Invoice export file lines");												// TFS 48959
	self.assertEqualMsg(idx, 130, "Invoice export file lines");												//16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	
epilog
	delete oArray;
	if file &lt;&gt; null then
		if file.isOpen then
			file.close();
		endif;
	endif;
	delete file;
end;</source>
