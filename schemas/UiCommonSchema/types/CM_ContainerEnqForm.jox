// 03/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
vars
	weighAuth, wa : CM_WeighAuthority;
	iter : Iterator;
	idx : Integer;

begin
	//TFS 6735 jlgns1 31/08/2017 
//	self.cmbAuthName.clear();
	self.tblEdit1.setValueByName(ETRow_WeightCertifiedPerson, null);
	weighAuth := combobox.listObject.CM_WeighAuthority;
	if weighAuth = null then
		self.tblEdit1.setValueByName(ETRow_WeightCertifiedBy, null);
		return;
	endif;
	
	self.tblEdit1.setValueByName(ETRow_WeightCertifiedBy, weighAuth.certifiedName);
/*	iter := app.myRoot.allWeighAuthorities.createIterator;
	app.myRoot.allWeighAuthorities.startKeyGeq(weighAuth.certifiedName, null, iter);
	while iter.next(wa) do
		if wa.certifiedName &lt;&gt; weighAuth.certifiedName then
			break;
		endif;
		idx := self.cmbAuthName.addItemObject(wa.authorisedName, wa);
	endwhile;
	if self.cmbAuthName.listCount = 1 then
		self.cmbAuthName.listIndex := 1;
		self.tblEdit1.setValueByName(ETRow_WeightCertifiedPerson, self.cmbAuthName.listObject.CM_WeighAuthority.authorisedName);
	endif; */
	self.myAssistant.listWeighAuthorityPersons(  self.cmbAuthName, self.myTerminal, weighAuth.certifiedName );
	if self.cmbAuthName.listCount = 2 then
		self.cmbAuthName.listIndex := 2;
		self.tblEdit1.setValueByName(ETRow_WeightCertifiedPerson, weighAuth.authorisedName);
	endif;

epilog
//	delete iter;
end;</source>
