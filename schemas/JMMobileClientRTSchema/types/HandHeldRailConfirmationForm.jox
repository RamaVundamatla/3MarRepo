    <JadeMethod name="getValidContainerInwards" id="51153e9c-dfd5-42ac-9134-34e3bf2fdb4c">
        <source>getValidContainerInwards();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error					: DTO_HandHeldGateError;
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
	wagonPos				: MobileHandHeldThin::DTO_WagonPosition;
	
begin
	wagonPos := self.myDTOWagonIn.allDTOWagonPositions[self.showingContainerNumIn,1];
	containerInfo:=wagonPos.myDTOContainer;
	containerInfo.containerId:=self.txtId.text;
	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldRailGuiAgent.getValidContainerInwards( wagonPos);

	if not errorMsgs.isEmpty then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	endif;
	
epilog
	self.btnDamage.enabled:=containerInfo.myPxyTrackedItem &lt;&gt; null;
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;

end;</source>
    </JadeMethod>
    <JadeMethod name="getValidContainerOutwards" id="385b1d77-6164-464f-a2a5-d7e407f5c906">
        <source>getValidContainerOutwards();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error					: DTO_HandHeldGateError;
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
	wagonPos				: MobileHandHeldThin::DTO_WagonPosition;
	
begin
	wagonPos := self.myDTOWagonOut.allDTOWagonPositions[self.showingContainerNumOut,1];
	containerInfo:=wagonPos.myDTOContainer;
	containerInfo.containerId:=self.txtId.text;
	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldRailGuiAgent.getValidContainerOutwards( self.myDTOWagonOut,wagonPos,errorMsgs);

	if not errorMsgs.isEmpty then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	endif;
	
epilog
	self.btnDamage.enabled:=containerInfo.myPxyTrackedItem &lt;&gt; null;
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;

end;</source>
    </JadeMethod>
