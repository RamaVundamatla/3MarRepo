        <source>comboBoxTruckLoadScan( pCmb : ComboBox input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2016	cnwndl1	Initial creation	TFS 3129

*/

vars

	index : Integer;

begin

	pCmb.clear();
