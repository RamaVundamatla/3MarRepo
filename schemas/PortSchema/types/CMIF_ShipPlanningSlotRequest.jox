/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars

begin
	
	if self.mySlotRequest &lt;&gt; null and not self.mySlotRequest.getAttrOverDimensioned() then
		return false;
	
	elseif self.myRORORequest &lt;&gt; null and not self.myRORORequest.getAttrOverDimensioned() then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testRest" id="90366dac-8c62-4a62-a194-1c0744b50d72">
        <source>testRest(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation

*/

vars

begin
	return not self.testCommodityGroup or not self.testHazardous or not self.testWaterCooled or not self.testOverDim();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
