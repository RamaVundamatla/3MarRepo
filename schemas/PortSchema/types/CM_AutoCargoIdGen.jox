        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="newIdNotAlreadyUsed" id="5ddffde6-98dd-4e29-955a-8f3ff07786e0">
        <source>newIdNotAlreadyUsed( _newId : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation

*/

vars

	existingTi : CM_TrackedItem;

begin

	existingTi := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( _newId, null );
	if existingTi = null or existingTi.id &lt;&gt; _newId then
		// no existing onsite cargo with the same id.
		return true;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="67d7eecd-22d8-477d-896e-32ea5b253dbf">
        <updating/>
        <source>setForUpdate(_proxy: CM_AutoCargoIdGen) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

begin

	self.cargoLabelFormat := _proxy.cargoLabelFormat;
	self.useCargoTypeAbbrv := _proxy.useCargoTypeAbbrv; //01/09/2022 navmv20 TFS 54610
	
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoCargoIdGen"/>
    </JadeMethod>
