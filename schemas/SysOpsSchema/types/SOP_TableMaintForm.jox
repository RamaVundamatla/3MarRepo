        <updating/>
        <source>tblDataRefresh(_obj : CM_Object) updating;

/*
Date				Who		Reason
13 September 2012	cnwar2	#30239

*/
vars
	i : Integer;

begin
	self.zTblDataSortAndShow(true);
	
	foreach i in tblData.fixedRows + 1 to tblData.rows do
		tblData.accessRow(i).selected := false;
	endforeach;
	self.tblData.selectObject(_obj, false);
	self.zTblDataSelectRow(tblData.accessedRow.row);
end;</source>
