    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="7f577894-73bc-4d7d-9467-0a56c83d0869">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm :=self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_TempConversionTbl);
//	theForm.zAddColumn('Celsius', 'celsius', Table.InputType_None, 30);
//	theForm.zAddColumn('Fahrenheit', 'fahrenheit', Table.InputType_None, 30);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Celsius, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_TempConversionMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="17a5706f-7947-4ef0-9fab-747b00df7d1a">
        <updating/>
        <source>showThumbnail(pTemperatureConversion : CM_TemperatureConversion) updating;

vars

	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Celsius, pTemperatureConversion.celsius);
	theForm.tblInput1.setValueByName(ETRow_Fahrenheit,	pTemperatureConversion.fahrenheit.roundedTo(2));
end;</source>
        <Parameter name="pTemperatureConversion" type="CM_TemperatureConversion"/>
    </JadeMethod>
</Class>
