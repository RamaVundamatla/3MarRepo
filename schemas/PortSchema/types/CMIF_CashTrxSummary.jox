    <JadeMethod name="setFilterColls" id="92791457-b501-4387-a9c0-62029805cc6b">
        <updating/>
        <source>setFilterColls( filterDrs : CM_DebtorSet; filterTerms : CM_TerminalByCodeDict ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation

*/

vars

begin

	if not filterDrs.isEmpty then
		filterDrs.copy( self.allFilterDebtors );
	endif;
	if not filterTerms.isEmpty then
		filterTerms.copy( self.allFilterTerminals );
	endif;

epilog

end;</source>
        <Parameter name="filterDrs" type="CM_DebtorSet"/>
        <Parameter name="filterTerms" type="CM_TerminalByCodeDict"/>
    </JadeMethod>
</Class>
