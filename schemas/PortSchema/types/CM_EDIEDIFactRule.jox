    <JadeMethod name="setProxy" id="fff16e22-ed83-4afe-be2c-06818c8a6109">
        <updating/>
        <source>setProxy(_item, _value :String; _function :Integer) updating;
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
