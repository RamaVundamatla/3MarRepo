<Class name="CMQF_VoyageSummary">
    <JadeMethod name="setFromAgent" id="04c69775-4151-42fb-98bf-70cab133d223">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_agent);
	if _agent.isRowIncluded(ETRow_Voyage) then
		if _agent.useCurrentDefaultVoyage() then
			self.doUseAppDefaultVoyage := true;
		else
			self.doUseAppDefaultVoyage := false;
			self.setMyVoyage( _agent.getSelectedCellularVoyage() );
		endif;
		/*
		if CMUI_ReportBuilder.hasInstance(_agent.myParentForm) then
			if _agent.myCmbCellularVoy.text = _agent.OPT_DEFAULT_VOYAGE then
				self.doUseAppDefaultVoyage := true;
			else
				self.doUseAppDefaultVoyage := false;			
			endif;
		else
			self.myVoyage := _agent.myCmbCellularVoy.listObject.CM_Voyage;
		endif;
		*/
	endif;
	
	
	if _agent.isRowIncluded(ETRow_Operator) then
		self.myOperator := _agent.getSelectedOperator();
	
	endif;

// cnwdad1 30/08/2006 - Constant is no longer used.
//	self.actualProposedOption := _agent.getValueByName(ETRow_SummaryOption).String;
	if _agent.isRowIncluded(ETRow_OrderedBy) then
		self.orderKey1 := _agent.getValueByName(ETRow_OrderedBy).String;
			
	endif;
	
	if _agent.isRowIncluded(ETRow_OrderedBy2) then
		self.orderKey2 := _agent.getValueByName(ETRow_OrderedBy2).String;
	endif;

	self.planningState := _agent.getSelectedState();

	if _agent.isRowIncluded(ETRow_Mode) then
		self.actualProposedOption := _agent.getValueByName(ETRow_Mode).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedDateFrom ) then
		//if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		 //  _agent.state = _agent.STATE_TEMPLATE_EDIT then
		//	/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_DepartedDateFrom).String, 
		//						self.departDateFromType, self.departDateFromFactor, ETRow_DepartedDateFrom);*/
		//	self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DepartedDateFrom), 
		//						self.departDateFromType, self.departDateFromFactor, ETRow_DepartedDateFrom);
		//else
			self.departDateFrom := _agent.getValueByNameIfVisible(ETRow_DepartedDateFrom).Date;
		//endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedDateTo) then
		//if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		//   _agent.state = _agent.STATE_TEMPLATE_EDIT then
		//	/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_DepartedDateTo).String, 
		//						self.departDateToType, self.departDateToFactor, ETRow_DepartedDateTo);*/
		//	self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DepartedDateTo), 
		//						self.departDateToType, self.departDateToFactor, ETRow_DepartedDateTo);
		//else
			self.departDateTo := _agent.getValueByNameIfVisible(ETRow_DepartedDateTo).Date;
		//endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedTimeFrom) then
//		self.departTFrom := _agent.getSelectedHMSTime(ETRow_DepartedTimeFrom);
		self.departTimeFrom  := _agent.getValueByNameIfVisible(ETRow_DepartedTimeFrom).Time;
		
	endif;
	
	if _agent.isRowIncluded(ETRow_DepartedTimeTo) then
//		self.departTTo := _agent.getSelectedHMSTime(ETRow_DepartedTimeTo);
		self.departTimeTo  := _agent.getValueByNameIfVisible(ETRow_DepartedTimeTo).Time;

	endif;
	
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
