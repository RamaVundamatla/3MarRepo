    <JadeMethod name="setErrorsFromPassport" id="e61d124e-c284-47b7-b2e9-e7b62d7227d4">
        <updating/>
        <source>setErrorsFromPassport() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars
	passport		: CM_Passport;
	error			: CM_Error;
	messageProxy	: WS_NMessage;
	
begin
	passport := app.myPassport;
	if passport = null then
		return;
	endif;

	foreach error in passport.allErrors do
		create messageProxy transient;
		messageProxy.setProxyFromObject(error, true);
		self.messages.add(messageProxy);
	endforeach;
	
	if not passport.warningsIgnored then
		foreach error in passport.allWarnings do
			create messageProxy transient;
			messageProxy.setProxyFromObject(error, false);
			self.messages.add(messageProxy);
		endforeach;
	endif;	
		
	passport.clearErrorsWarnings();
epilog

end;</source>
    </JadeMethod>
</Class>
