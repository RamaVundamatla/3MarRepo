    <JadeMethod name="doShowInvoiceLines" id="9c99cf6f-2ab8-4b0f-a8e4-59b9f31d17dd">
        <updating/>
        <source>doShowInvoiceLines() updating;
// Oct 2010 cnwjre1	CCMS 1043 21800
// show all invoice lines that have been generated from this snapshot data
vars
	row				: Integer;
	snapshotData	: CM_SnapshotData;
	dynObj			: CM_DynamicObject_Snapshot;
	invLine			: CM_InvoiceLine;
	lines			: CM_InvoiceLineBySeqNumDict;
	invoiceForm 	: CM_BaseForm;
	menuAction 		: CMUI_MenuAction;
begin
	row := self.tblData.row;
	if row &lt;= self.tblData.fixedRows then
		return;
	endif;

	create lines transient;
	snapshotData := tblData.accessRow(row).itemObject.CM_SnapshotData;
	foreach dynObj in snapshotData.allSnapshotData do
		foreach invLine in dynObj.allInvoiceLines do
			lines.add(invLine);
		endforeach;
	endforeach;
	
	menuAction := app.myController.createMenuAction(PmAdmInvoicelinesView, null, null, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null);
	if invoiceForm = null then
		return;
	endif;

	lines.copy(invoiceForm.getPropertyValue("allInvoiceLines").Collection);
	invoiceForm.setPropertyValue("specialQuery", true);
	invoiceForm.show();
epilog
	delete lines;
end;</source>
    </JadeMethod>
