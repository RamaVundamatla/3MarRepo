vars
	
begin
	_pxyBulkRelease.validateForUpdate(_passport);
	
	_pxyBulkRelease.validateCargoOperatorPins(_allTIPins);  //cnwrd1 CCMS POL 2032 par 25594 10.12.2010
end;</source>
