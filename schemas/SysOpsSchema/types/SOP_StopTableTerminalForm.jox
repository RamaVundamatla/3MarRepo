    <JadeMethod name="translateForm" id="8c9feeac-0e91-442b-b9b8-6bc84ae19833">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 May 2019 15:05:37.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022809, locale);
	btnURAdd.translateCaption(Xlat_0023569, locale);
	btnURDelete.translateCaption(Xlat_0023570, locale);
	btnURUpdate.translateCaption(Xlat_0023571, locale);
	chkChildIgnore.translateCaption(Xlat_0010830, locale);
	chkChildOnly.translateCaption(Xlat_0010831, locale);
	chkCoastalIgnore.translateCaption(Xlat_0010832, locale);
	chkCoastalOnly.translateCaption(Xlat_0010833, locale);
	chkFullsOnly.translateCaption(Xlat_0010834, locale);
	chkMTsOnly.translateCaption(Xlat_0010835, locale);
	chkTranshipIgnr.translateCaption(Xlat_0014078, locale);
	chkTranshipOnly.translateCaption(Xlat_0014079, locale);
	label1.translateCaption(Xlat_0010836, locale);
	label2.translateCaption(Xlat_0010837, locale);
	label3.translateCaption(Xlat_0010838, locale);
	shtUpdRequest.translateCaption(Xlat_0023572, locale);
	sht_Sheet1.translateCaption(Xlat_0010839, locale);
	sht_Sheet2.translateCaption(Xlat_0010840, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="9c622b2f-5144-4f12-8525-6116b2c1ec72">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//ccms1824 cnwrs1 may 2009
vars

begin
	// 23/08/2016 cnwjre1 from TFS 2570 development delete the CM_String transients
	self.allAvailablePreventStopAreas.purge;
	self.allAvailableSetStopAreas.purge;
	self.allAvailableProcessStopAreas.purge;
	
	inheritMethod;
end;
