    <JadeMethod name="getStopsString" id="40a4d218-80dd-4496-8dad-edd8717f1c93">
        <source>getStopsString():String protected;
// ---------------------------------------------------------------------------
// Created:     01 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stopTable			:CM_StopsTable;
	strStop, strAll		:String;
begin
	foreach stopTable in self.myTIMaster.allStopsNew do
		strStop := stopTable.id.String;
		strAll 	:= strAll &amp; strStop;
	endforeach;
	
	return strAll;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initStopsToAddTable" id="a87443ae-698e-410e-a969-d825a276bae5">
        <source>initStopsToAddTable(_table: CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	etDef	:EntTableDef;
begin
	etDef := app.myController.getEntTableDef(ETDef_StopsDetails_TM_Add);
	
	_table.setTblDataEntRowsFromDef (etDef);
	
	_table.hideColumnByColName (ETRow_ClearanceExpiryDate);
	
	inheritMethod (_table);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
