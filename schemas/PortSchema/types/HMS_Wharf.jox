    <JadeMethod name="getResourceForHarbourMovement" id="8b364fb1-da17-4238-8b5a-f4d5f44b3f8e">
        <source>getResourceForHarbourMovement(_movement : String; _order : Integer) : HMS_Resource;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		pass in the resource type and the resourse number. (1st resource or 2nd Resource)
//				NOTE: Wharf has 2 resourses for each movement. not like tug and others. 
//				There are constants First_Resource and SecondResource on HMS_Warf which can be used 
//				in the signature of this method.
//
// ---------------------------------------------------------------------------

vars
	realResource : HMS_Resource;
	resourceWharf : HMS_ResourceForWharf;
begin		
//	if _harbour = null then
//		return null;
//	endif;
	
	resourceWharf := self.allResourcesForWharf[self.getHarbourReal, self, _order];
	if resourceWharf &lt;&gt; null then
		if _movement = HMSMovementTypeArrival then
			return resourceWharf.myArrivalResource;
		elseif _movement = HMSMovementTypeDeparture then
			return resourceWharf.myDepartResource;
		else
			return resourceWharf.myShiftResource;
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_movement" type="String"/>
        <Parameter name="_order" type="Integer"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="hasHookCode_MinResidenceTime" id="0679a5f2-d35f-43b1-90c7-bb6d49282fef">
        <source>hasHookCode_MinResidenceTime():Boolean;
/*
Date		Who		Reason
28 September 2011	cnwcs5	Initial creation - CCMS RIO 2230 / par 28261 Start/Stop Times
*/
vars
	hook	:CM_HookCode;
begin
	hook	:= self.myHookCode;
	
	return self.getJadeCode &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="eda75c5b-b568-414a-aab0-af59ea8ea665">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 27/09/2011	cnwcs5		CCMS RIO 2130 / par 28261 - Minimum residence times
// 26.08.24		navhn30		ChangeRequest 65521: NSW | OnePort Integration - Setting voyage process by wharf
vars
	proxy : HMS_Wharf;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	proxy.myDefaultVoyageProcess	:= self.myDefaultVoyageProcess;	// 26.08.24	navhn30	TFS 65521
	self.allTerminals.copy(proxy.allTerminals);
	
	if self.myHookCode &lt;&gt; null then
		proxy.myHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
