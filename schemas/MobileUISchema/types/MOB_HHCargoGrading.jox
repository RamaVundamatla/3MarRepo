    <JadeMethod name="setupControls" id="b782ae99-2dba-4f27-affa-d6a740f229a6">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation

*/

vars

begin

	self.doResizeControls(true);
	
	if self.wasCalledViaContext(true) then
		self.btnThree.caption := app.getErrorString(Enquiry);
	endif;
	
	self.populateTrackedItem();	
