    <JadeMethod name="cloneMySelf" id="67896319-1738-43e6-ab73-ce572e07ff95">
        <source>cloneMySelf(_newDeck : CM_Deck; _copy : Boolean) : CM_DeckLayout;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	aDeckLayer, newDeckLayer : CM_DeckLayerLayout;
	newMe : SelfType;
	iter : Iterator;
	idx, totItems : Integer;
begin
	newMe := self.cloneSelf(_copy);

	newMe.myDeck := _newDeck;
	
	totItems := self.allDeckLayerLayouts.size;
	while true do
		idx := idx + 1;
		if idx &gt; totItems then
			break;
		endif;
		aDeckLayer := self.allDeckLayerLayouts[idx];
		if aDeckLayer &lt;&gt; null then
			newDeckLayer := aDeckLayer.cloneMySelf(newMe, _copy);
		endif;
	endwhile;
	
	return newMe;
	
epilog
end;</source>
        <Parameter name="_newDeck" type="CM_Deck"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckLayout"/>
    </JadeMethod>
    <JadeMethod name="doCopyDeck" id="364de1c8-10d0-46fd-b4d3-6ba647739e79">
        <source>doCopyDeck(_deck : CM_Deck);
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpLayer : CM_DeckLayerLayout;
	currentBun, newBun : CM_DeckLayout;
	pxyGraphic, clonedGraphic : CM_Graphic;
	obj : Object;
begin
	currentBun := self;
	
	create newBun transient;
	
	newBun.setProxy(app.getErrorString(New).toUpper(), self.description, self.remarks, _deck);
	
	foreach tmpLayer in self.allDeckLayerLayouts discreteLock do
		tmpLayer.doCopyPxyLayer(newBun);
	endforeach;


epilog

end;</source>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
