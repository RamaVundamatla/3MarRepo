    <JadeMethod name="positionSptMain" id="1c30cd2b-7f5c-4b38-89cb-3c8a0f140239">
        <updating/>
        <source>positionSptMain() updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTop	: Integer;

begin

	// Position the Main splitter control

	tmpTop := self.getSptMainTop();

	sptMain.move(WinLeftMargin, tmpTop,	self.width - sptMain.left - WinRightMargin,	self.height - tmpTop - WinBottomMargin - VerticalSpacing);

end;</source>
