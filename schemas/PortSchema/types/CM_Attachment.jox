    <JadeMethod name="auditId" id="44583d06-511c-47a8-ab98-474563e4775b">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2025 navhl20 Defect MTN-36235: Audits are not capturing date, time, and user for changes to photo.

*/

vars

begin
	if self.myParent &lt;&gt; null and self.myParent.isKindOf(CM_VehicleVisitRecord) then
		return self.myParent.CM_VehicleVisitRecord.regNumber;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
