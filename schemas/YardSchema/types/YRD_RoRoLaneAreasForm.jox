    <JadeMethod name="doSetCaption" id="67c11fa4-763b-4279-aadd-69ca6070e5cd">
        <updating/>
        <source>doSetCaption() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	flipString, accessString, naviString : String;
	theCaption : String;
	aTA : Object;
	tmpDC :	YRD_RoRoLaneDrawingController;
begin
	tmpDC := self.myCurrentDrawingController;

		//cnwvu1 PAR 13144
	if tmpDC &lt;&gt; null then
		if tmpDC.flipHorizontal then
			flipString := " (Flipped Horizontal Only)";
			if tmpDC.flipVertically then
				flipString := " (Flipped Horizontally &amp; Vertically)";
			else
				flipString := " (Flipped Horizontally Only)";
			endif;
		else
			if tmpDC.flipVertically then
				flipString := " (Flipped Vertically Only)";
			else
				flipString := null; //" (Normal View)";
			endif;
		endif;	
	endif;
	
	theCaption := null;
	naviString := theCaption;
	
	foreach aTA in self.allTerminalAreas do
		
		theCaption := theCaption  &amp; aTA.CM_RoRoLaneArea.id.trimBlanks &amp; ", ";
		naviString := theCaption;
	endforeach;
	if self.allTerminalAreas.size = 1 then
		theCaption := theCaption &amp; " RoRo Lane Area.";
	else
		theCaption := theCaption &amp; " RoRoLane Areas.";
	endif;
	theCaption := theCaption &amp; " " &amp; flipString;
	theCaption := theCaption &amp; " " &amp; self.myTerminal.code;
	naviString := naviString[1:naviString.length - 2];

	self.caption := theCaption;
	// Update the navigator
	self.setNavigatorHeading(naviString); 

end;</source>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="360f3bd2-b8eb-413e-bdca-e81ad50e74f4">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		CALLED FROM CM_ColorLegendTable dblClick
//
// ---------------------------------------------------------------------------
vars
	anObject : CM_Object;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin

	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	anObject := table.accessRow(table.row).itemObject.CM_Object;
	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(anObject.CM_Voyage, self.myMasterMenuAction, false, false);
		else
			self.myAssistant.showTableMaintForm(anObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblPopupInfoDbClick" id="291fe1e6-4ace-4118-a21c-6d782b735d83">
        <updating/>
        <source>doTblPopupInfoDbClick(table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/07/2014	cnwdap1		PAR #34325 Avoid 75776 and 75768 errors when double-clicking the terminal area or yard allocation cells in the extra info table
// 06/03/2015	cnwmh5		Transient Leak
vars
	obj	: Object;
	objArray : ObjectArray;							// PAR #34325
begin
	if table.row &lt;= table.fixedRows or 
	   table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then

		if obj.isKindOf(CM_SlotController) or 
			   obj.isKindOf(CM_GridController) or 
			   obj.isKindOf(CM_RoRoController) or									// PAR #34325
			   obj.isKindOf(CM_SlotDefn) or 
			   obj.isKindOf(CM_SlotRequest) or 
			   obj.isKindOf(CM_Bay) or 
			   obj.isKindOf(CMUI_GridDrawingController) or
			   obj.isKindOf(CM_WorkListEntry) or
			   obj.isKindOf(CM_Voyage) then
			if app.isAllowedToInspect then
				obj.inspect;
			endif;

//		elseif obj.isKindOf(CM_GridController) then
//			self.myAssistant.showTerminalAreaForm(obj.CM_LocationsController.myTerminalArea, self.myMasterMenuAction);
		elseif obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		elseif obj.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(obj.CM_Voyage, self.myMasterMenuAction, false, false);
			
		elseif obj.isKindOf(CM_YardAllocation) then									// PAR #34325
			create objArray transient;												// PAR #34325
			objArray.add(obj);														// PAR #34325
			app.mousePointer := MousePointer_Default;								// PAR #34325
			self.myAssistant.showYAMaintForm(objArray, null, self, null, null);		// PAR #34325
			delete objArray;														// PAR #34325

		elseif obj.isKindOf(CM_Object) then
			self.myAssistant.showTableMaintForm(obj.CM_Object, self.myMasterMenuAction, true, true);
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
	delete objArray;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="cb4621b0-6b35-4fac-b65c-587e00bed151">
        <source>doTurnOffContextMenus();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	mnuChild : MenuItem;	
	idx : Integer;
	useTaskForm : Boolean;

begin
	
	self.mnuYANew.visible := false;
	self.mnuGridSeperator03.visible := false;
	self.mnuColumnOrg.visible := false;
	self.mnuYAGroupNew.visible := false;
	self.mnuYAEdit.visible := false;
	self.mnuYADeckingOptions.visible := false;
	self.mnuInspect.visible := false;
	self.mnuYardAllocation.visible := false;
	self.mnuRebuildStats.visible := false;
	self.mnuProcessMovementLog.visible := false;
	self.mnuYADelete.visible := false;
	
	self.mnuResetAllFreed.visible := false;
	self.mnuResetFreed.visible := false;
	self.mnuCargoTestAP.visible := false;
	self.mnuCargoAP.visible		:= false;
	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuCargoTaskAdd.visible := true;
		self.mnuCargoTaskComplete.visible := true;
		self.mnuCargoTaskRemove.visible := true;
		self.mnuCargoTaskRemarks.visible := true;
		
		self.mnuTaskAdd.visible := false;
		self.mnuTaskComplete.visible := false;
		self.mnuTaskRemove.visible := false;
	else
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemove.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		
		self.mnuTaskAdd.visible := true;
		self.mnuTaskComplete.visible := true;
		self.mnuTaskRemove.visible := true;
	endif;
	self.mnuStops.visible := true;

	self.mnuGridSeperator01.visible := true;
	self.mnuGridBigFont.visible := false;
	self.mnuGridSelector.visible := false;
	self.mnuGridSelectorClear.visible := false;
	self.mnuCargo.visible 	:= false;
	self.mnuZoomSub.visible := false;
	self.mnuMove.visible := false;
	self.mnuDisplay.visible := false;
	self.mnuOther.visible := false;
	self.mnuAddLabourRestrict.visible := false;
	self.mnuRemoveLabRestrict.visible := false;

	self.mnuGridSelectAreas.visible := false;
	
	self.mnuGridPlanDischarge.visible := false;
	self.mnuGridPlanLoad.visible := false;
	self.mnuGridBulkEdit.visible := false;
	self.mnuGridBulkUnqueue.visible := false;
	
	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideToolbar.visible := true;
	self.mnuGridSelector.visible := true;
//###
	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideMacro.visible := true;
	self.mnuGridHideToolbar.visible := true;
	self.mnuGridSelectAreas.caption := "Select Terminal &amp;Areas...";
	self.mnuGridSelectAreas.visible := true;



end;</source>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="18cabc71-79d6-479c-912e-21ed657b4fb5">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input; _isOverstow : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx 					: Integer;
	lTI						: CM_TrackedItem;
	aStr					: String;
	lResult					: Integer;
	lMoveControl			: CMIF_MoveController;
	lTransferArea			: CM_TerminalArea;
	lQEntry					: CM_RTQueueEntry;
	wle						: CM_WorkListEntry;
	futureMove				: CM_FutureMove;
	theTIs : CM_TISet;
begin
	mousePointer := MousePointer_HourGlass;	

	if _theTI = null then
		app.msgBox("Please select a Tracked Item.","Unplanning", MsgBox_OK_Only);
		return;
	else
		create lMoveControl transient;
		lMoveControl.setMoveMode(QUEUE_MODE);
		lMoveControl.setMyTrackedItem(_theTI);
		futureMove := _theTI.setFMUnqueueIndex(_isOverstow,lMoveControl);
		if futureMove &lt;&gt; null then
			lMoveControl.setMyWorkListEntry(futureMove.myWorkListEntry);
		endif;

		lMoveControl.isOverstowMove := _isOverstow;


		if self.mnuGridBulkUnqueue.visible then
			create theTIs transient;
			self.mnuGridBulkUnqueue.userObject.Collection.copy(theTIs);
			foreach lTI in theTIs do
				if _theTI = lTI then
					theTIs.remove(lTI);
				elseif lTI.myPrimaryQueuedLocation = null then
					theTIs.remove(lTI);
				endif;
			endforeach;
			if theTIs.isEmpty then
				app.msgBox("There is nothing to unqueue.", "No Unqueue", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			lMoveControl.setAllOtherTrackedItems(theTIs);
		endif;	
		while true do	
			app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				lResult := app.showErrorWarningDialog('Unplan', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and  lResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		
	endif;
epilog 
	delete lMoveControl;
	delete theTIs;
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isOverstow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doYAMTableSelection" id="a1394786-ab5c-46f6-bd8f-1005358e81d9">
        <updating/>
        <source>doYAMTableSelection() updating;
/*

Purpose:		Filter display of Yard Allocation lines to match selections	in YAM table.

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	Initial creation

*/
vars
	filter	: CM_YardAllocationSet;
	obj		: Object;
	ydc 	: YRD_RoRoLaneDrawingController;

begin
	create filter transient;
	
	self.tblYAM.getSelectedYardAllocations(filter);	
		
	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_RoRoLaneDrawingController;
		ydc.filterYardAllocationLines(filter);
	endforeach;
epilog
	delete filter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doZoom" id="3ab20f51-2e30-4d63-96a2-6c534a2739d5">
        <updating/>
        <source>doZoom(pFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     Implement in subclass`
// ---------------------------------------------------------------------------
vars
	posH, posV : Real;
	theHValue, theVValue,tmpVM : Integer;	
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
	tmpFrame : CMUI_GridAreaScrollableFrame;
	cdc : YRD_RoRoLaneDrawingController;
	key1	: Point;
begin

	self.mousePointer := Window.MousePointer_HourGlass;

	tmpDkbGridArea := self.dkbGridArea;
	tmpFrame := self.myCurrentDrawingController.getScrollablleFrame();
	cdc := self.myCurrentDrawingController;
	posH := (tmpFrame.getHScrollValue() / tmpFrame.getHScrollMax).Real;
	posV := (tmpFrame.getVScrollValue() / tmpFrame.getVScrollMax).Real;
	
	tmpVM := self.myCurrentDrawingController.viewMode;

	if tmpVM &lt;&gt; 0 then
		self.myCurrentDrawingController.setViewMode(tmpVM);
	endif;
	self.myCurrentDrawingController.doZoom(pFactor);
	if tmpVM &lt;&gt; 0 then
		self.myCurrentDrawingController.setViewMode(tmpVM);
	endif;

	self.xmlZoomFactor := pFactor;

	if cdc.allSelectedObjects.isEmpty then
		theHValue := (tmpFrame.getHScrollMax * posH).Integer;
		theVValue := (tmpFrame.getVScrollMax * posV).Integer;
	else
//		cdc.allGridObjects.findObjectInDictGetXY(cdc.allSelectedObjects.first,key1, key2);
		theHValue := key1.x;
		theVValue := key1.y;

		theHValue := (tmpFrame.left + theHValue).Integer - (tmpFrame.width / 2).Integer;
		theVValue := (tmpFrame.top + theVValue).Integer - (tmpFrame.height / 2).Integer;
		
	endif;
	
	tmpFrame.scrollTo(theHValue,theVValue);
	
epilog 
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
