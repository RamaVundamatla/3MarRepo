    <JadeMethod name="setCurrentVoyages" id="e167e23e-1f68-447f-b85a-9cebf3cb22b3">
        <updating/>
        <source>setCurrentVoyages()	updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	checkDT : TimeStamp;
	iter : Iterator;
	aVoyage : CM_Voyage;
	failedDAC : CM_DataAccessController;
	gracePeriod : Integer;
	
begin

	term := self.getTerminal;
	checkDT := app.actualTimeServer();
	gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	self.allCurrentVoyages.clear();
	
	iter := term.allVoyagesNew.createIterator();
	
	while iter.next(aVoyage) do
		if aVoyage.isNullVoyage then
			continue;
		endif;
		if aVoyage.displayOption = VoyageDisplayNever then
			continue;
		endif;
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		if (not aVoyage.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			continue;
		endif;
		if aVoyage.archived or aVoyage.myTerminalArchived &lt;&gt; null then
			continue;
		endif;
		if (not aVoyage.isActiveDisplay(checkDT)) then
			continue;
		endif;
		if not self.allCurrentVoyages.includes(aVoyage) then
			self.allCurrentVoyages.add(aVoyage);
		endif;
	endwhile;
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
