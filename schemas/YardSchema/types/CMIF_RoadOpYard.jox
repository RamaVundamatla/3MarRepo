    <JadeMethod name="changeProceedOptionsEnabled" id="ab21f389-590d-463e-a466-480e3c115590">
        <source>changeProceedOptionsEnabled();
/*
Purpose:			
Return Value:		

Date			Who		Reason
24 August 2006	cnwer1	Initial creation - PAR#xxxx
17 August 2009	cnwcs5	ccms 1061 - road ops form changes
12/10/2009		cnwcs5	par 20800 - exceptions due to deleted gates
*/
vars
	obj 			: Object;
	menu 			: MenuItem;
	glc 			: CM_GateAreaLaneController;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, glc, invalidObject);	// par 20800
	
	foreach obj in self.allMenuItems do
		menu:=obj.MenuItem;
		if menu.name &lt;&gt; YRD_RoadOperationsForm::mnuProceed.name or
			not menu.userObject.isKindOf(CM_GateAreaLaneController) then
			continue;
		endif;
		
		glc := menu.userObject.CM_GateAreaLaneController;
		
		menu.enabled := (not glc.isUnavailable) and glc.isOut and not glc.hasVehicles; 
		
		// if glc is invalid our exception handler will resume here
		if invalidObject then					// par 20800
			self.allMenuItems.remove (menu);	// par 20800
			delete menu;						// par 20800
			invalidObject := false;				// par 20800
		endif;									// par 20800
	endforeach;
epilog

end;</source>
    </JadeMethod>
