    <JadeMethod name="picRemarks_click" id="5f61685f-3b81-4298-9ae0-6f97726a6657">
        <controlMethod name="Picture::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>picRemarks_click(pict: Picture input) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars

	remarksFrm	: CMUI_Remarks;
	anObject : CM_Object;
begin

	create remarksFrm;
	self.setNavigatorHeading(remarksFrm.caption); 
	remarksFrm.centreWindow;
	remarksFrm.myCurrentObject := pict.userObject.CM_Object;
	remarksFrm.setMyTerminal(self.myTerminal);
	remarksFrm.showModal;
	
	//17 Apr 2012	NDL	Par 29444
	if pict.userObject.isKindOf( CM_DeckItem ) then
		pict.bubbleHelp := pict.userObject.CM_DeckItem.myLayout.code &amp; " - " &amp; pict.userObject.CM_DeckItem.remarks;//
	endif;
epilog




end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="repositionAllBackFrames" id="70cf0ef8-8253-462f-ad0b-4d7e6d193e93">
        <source>repositionAllBackFrames();
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	backFrame : Frame;
	obj : Object;
	tbHeight : Real;
begin

	tbHeight := self.frmROROTB.height; // PAR 28719


	foreach obj in self.allBackgroundFrames do
		backFrame := obj.Frame;
		backFrame.move(self.frmScrollable.myDrawingFrame.left - 1, self.frmScrollable.myDrawingFrame.top + tbHeight - 1,self.frmScrollable.myDrawingFrame.width, self.frmScrollable.myDrawingFrame.height);
		backFrame.zOrder(0);
	endforeach;
epilog

end;</source>
    </JadeMethod>
