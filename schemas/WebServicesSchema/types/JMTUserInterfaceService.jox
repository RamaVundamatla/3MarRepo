    <JadeWebServicesMethod name="createNewCargo" id="eca686ef-f52b-4845-a4ed-039138a7b64e">
        <source>createNewCargo(request : WS_CargoItemUpdateRequest) : WS_Response webService;
/*

Purpose:Create a new cargo	to load on the truck

Parameters:			

Return Value:		

Date			Who			Reason
02 March 2017	cnwam15		Initial creation
13 March 2017	cnwam15		Updated reefer and vehicle details
30 may 2017		cnwdap1		TFS 4449 STWR Mark and Mark Number field length adjustments
13 March 2019 	jlgzm1		TFS 43548 Seals not being created
28.06.2022		navsrk20	Task 53923	: Implement shipping line in WS_CargoItemUpdateRequest
09.09.2022      navds21     Bug 54056	: CUX - 1090 when calling createNewCargo with no cargoType specified
22.02.2023		navpw1		Defect 56563 : MTN - Truck Load &amp; Unloader - Adding Bags of Sand not saving all fields - Added Diameter, Grade, Grammage, Rolling Length
22.02.2023		navpw1		Bug 56182 : MTN - Truck Load &amp; Unloader - Adding Trailer/Chassis has an error message pop up even though you have entered the required data
23.02.2023      navsa20     Bug 56179: MTN - Truck Load &amp; Unloader - Errors raised when trying to add Reefer
26.05.2023		jlika1		TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
01 Sep 2023 	navsck1		Bug 57873: MTN - Truck Loader/Unloader: Cannot add a reefer container which has a requires temp commodity when operator display in fahrenheit
20 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	response			: WS_Response;
	flexiController 	: CMIF_FlexiGateController;
	pxyGateEntity 		: CMGTE_Receival;
	completedOK			: Boolean;
	term				: CM_Terminal;
	cargoType			: CM_CargoType;
	product 			: CM_Product;
	operator 			: CM_Operator;
	commodity 			: CM_Commodity;
	imex 				: CM_IMEXStatus;	
	destination 		: CM_Port;
	discharge			: CM_Port;
	ti 					: CM_TrackedItem;
	consignee 			: CM_ConsigneeConsignor;
	controller 			: CMIF_MobileGenericAgent;
	truck				: CM_Vehicle;
	pxyCustomsSeal,
	pxyOperatorSeal,
	pxyShippersSeal,
	pxyVentSeal 		: CM_SealTI;
	now 				: TimeStamp;
	iter				: Iterator;		// ### TFS 56182 22Feb2023 NAVPW1
	trailerType			: CM_TILCType;	// ### TFS 56182 22Feb2023 NAVPW1
	txnControlller 		: CMIF_BBDiscrepancyController;
	newTITxn 			: CM_TITransaction;
	cargoGroup			: CM_CargoGroup;
	tmpOperator			: CM_Operator;
	permissionsToCheck 	: IntegerArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
		
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	if term = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	//app.checkCurrentUserHasAccess(PmHandHeldTruckUnloader);
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//20.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//20.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHandHeldTruckUnloader);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	

	create controller transient;
	create flexiController transient;
		
	truck := term.findTruck(request.truckIdForLoad.toUpper,null,null);
	
	//tfs43548 if truck is null causes 1090
	if truck = null or truck.visitRecords.last = null then
		app.raiseCMException(Input_required_field_truckNum, null, null);
		completedOK := true;
		return response;
	endif;
	
	flexiController.id := request.id;
	flexiController.myTerminal := term;
	flexiController.myVehicle := truck;
	flexiController.myVehicleVisitRecord := truck.visitRecords.last;
		
	controller.setMyTerminal(term);
	controller.setTruck(truck);
	
	//cargo type
	if request.cargoType &lt;&gt; null then
		cargoType :=app.myRoot.allCargoTypesById[request.cargoType.Integer];
		if cargoType &lt;&gt; null then
			flexiController.cargoType := cargoType.id;
		else
			app.raiseCMException(Input_required_field_cargoType,null,null);
			completedOK := true;
			return response;
		endif;
		//Start 09.09.2022 navds21 TFS 54056
	 else
        app.raiseCMException(Input_required_field_cargoType,null,null);
        completedOK := true;
        return response;
		//End 09.09.2022 navds21 TFS 54056
	endif;
	
	//commodity
	commodity := app.myRoot.allCommodities[request.commodityCode];
	if commodity &lt;&gt; null then
		flexiController.commodity := commodity.code;
		if cargoType.id = TI_CargoType_Container then
			if commodity.isEmpty then
				flexiController.jobType := CMGTE_Entity.JobType_EmptyIN; 
			else
				flexiController.jobType := CMGTE_Entity.JobType_FullIN;   
			endif;
		else
			flexiController.jobType := CMGTE_Entity.JobType_GeneralIN;
		endif;
	else
		if cargoType.isCommodityRequired then
			app.raiseCMException(Input_required_field_commodity,null,null);
			completedOK := true;
			return response;
		endif;
	endif;
		
	flexiController.isoTypeCode := request.isoType;
	
	if request.product &lt;&gt; null then
		product := cargoType.getProductFromCode(request.product);
		flexiController.myProduct := product;
	endif;
	
	flexiController.voyageCode := request.voyageCode;
	
	destination := app.myRoot.allPorts[request.destinationPort];
	if destination &lt;&gt; null then
		flexiController.destinationPort := destination.code;
	endif;
	
	discharge := app.myRoot.allPorts[request.dischargePort];
	if discharge &lt;&gt; null then
		flexiController.dischargePort := discharge.code;
	endif;
	
	imex := app.myRoot.allImexStatuses[request.imexStatus];
	if imex &lt;&gt; null then
		flexiController.imexStatus := imex.code;
	endif;
	
	operator := app.myRoot.allOperators[request.operatorCode];
	if operator &lt;&gt; null then
		flexiController.operatorCode := operator.code;
	endif;
	
	if request.weightTotal &lt;&gt; null then
		flexiController.weightTotal := request.weightTotal.asDecimalJMT;
	endif;
	
	//jlier1 TFS 56680 23/2/23
	if request.weightTare &lt;&gt; null then
		flexiController.weightTare:=request.weightTare.asDecimalJMT;
	endif;
	
	if request.consignee &lt;&gt; null then
		consignee := app.myRoot.allConsigneeConsignors[request.consignee];
		if consignee &lt;&gt; null then
			flexiController.consigneeCode := consignee.code;
		endif;
	endif;
	
	if cargoType.isBulkByQuantity then
		flexiController.quantity := request.quantity;		
	endif;
			
	if request.width &lt;&gt; null then
		flexiController.width := request.width.asDecimalJMT;
	endif;
	
	if request.length &lt;&gt; null then
		flexiController.length := request.length.asDecimalJMT;
	endif;
	
	if request.volumeTotal &lt;&gt; null then
		flexiController.volumeTotal := request.volumeTotal.asDecimalJMT;
	
	else
		//epr 2/2/18 testing truck loader could not create cargo on truck that is track by volume
		if cargoType.isBulkByVolume and request.weightTotal &lt;&gt; null then
			if product &lt;&gt; null  and product.getDensityValue &lt;&gt; null then
				flexiController.volumeTotal :=flexiController.weightTotal/product.getDensityValue;
			else
				flexiController.volumeTotal :=flexiController.weightTotal/cargoType.density;
			endif;
		endif;
		
	endif;
	
	
	if request.height &lt;&gt; null then
		flexiController.height := request.height.asDecimalJMT;
	endif;
	
	flexiController.numItems := request.numItems;
	
	//tfs43548 start
	now := app.actualTimeServer();
	//These are the only seal types supported by the request currently
	if request.sealNumCustoms &lt;&gt; null then
		create pxyCustomsSeal transient;
		pxyCustomsSeal.setProxy(request.sealNumCustoms, null, null, SealType_Customs, now, null);
		flexiController.allSeals.add(pxyCustomsSeal);
	endif;
	
	if request.sealNum &lt;&gt; null then
		create pxyOperatorSeal transient;
		pxyOperatorSeal.setProxy(request.sealNum, null, null, SealType_Operator, now, null);
		flexiController.allSeals.add(pxyOperatorSeal);
	endif;
	
	if request.sealNumShippers &lt;&gt; null then
		create pxyShippersSeal transient;
		pxyShippersSeal.setProxy(request.sealNumShippers, null, null, SealType_Shipper, now, null);
		flexiController.allSeals.add(pxyShippersSeal);
	endif;
	if request.sealNumVent &lt;&gt; null then
		create pxyVentSeal transient;
		pxyVentSeal.setProxy(request.sealNumVent, null, null, SealType_Vent, now, null);
		flexiController.allSeals.add(pxyVentSeal);
	endif;
	//tfs43548 end
	
	//update vehicle
	flexiController.make := request.make;
	flexiController.model := request.model;
	flexiController.carType := request.carType;
	flexiController.year := request.year;		
	//flexiController.mark := request.mark;					// TFS 4449
	flexiController.mark := request.mark[1:150];			// TFS 4449
	
	//update reefer
	if request.carriageTemp &lt;&gt; null then
		//flexiController.carriageTempC := request.carriageTemp;											//	01.09.2023 navsck1 #57873
		tmpOperator := app.myRoot.allOperators[request.operatorCode];										//	01.09.2023 navsck1 #57873
		if tmpOperator &lt;&gt; null then																			//	01.09.2023 navsck1 #57873
			if tmpOperator.displayTempFahrenheit then														//	01.09.2023 navsck1 #57873
				flexiController.carriageTempF := app.temperatureConversion(true, request.carriageTemp);		//	01.09.2023 navsck1 #57873
			else
				flexiController.carriageTempC := request.carriageTemp;										//	01.09.2023 navsck1 #57873
			endif;																							
		endif;																								
	endif;
	if request.ventilation &lt;&gt; null then
		flexiController.ventilation := request.ventilation;		
	endif;
	
	if request.shippingLine &lt;&gt; null then								//28.06.2022 navsrk20 TFS 53923
		flexiController.shippingLineCode := request.shippingLine;		//28.06.2022 navsrk20 TFS 53923
	endif;																//28.06.2022 navsrk20 TFS 53923
	
	// ### TFS 56563 01Dec2022 NAVPW1
	if request.diameter &lt;&gt; null then
		flexiController.diameter := request.diameter.asDecimalJMT;
	endif;
	
	if request.grade &lt;&gt; null then
		flexiController.grade := request.grade;
	endif;
	
	if request.grammage &lt;&gt; null then
		flexiController.grammage := request.grammage.asDecimalJMT;
	endif;
	
	if request.rollingLength &lt;&gt; null then
		flexiController.rollingLength := request.rollingLength.asDecimalJMT;
	endif;
	// ### TFS 56563 22Feb2023 NAVPW1
	
	// ### TFS 56182 22Feb2023 NAVPW1
	if request.trailerType &lt;&gt; null then
		if request.cargoType &lt;&gt; null and cargoType &lt;&gt; null then
			iter := cargoType.allTILCTypes.createIterator;
		else
			iter := app.myRoot.allTILCTypes.createIterator;
		endif;
		
		while iter.next(trailerType) do
			// always include _trailerType but exclude other
			// which are not available for entry
			if trailerType.isNotAvailableForEntry then
				continue;
			endif;
			
			if trailerType.code &lt;&gt; request.trailerType then
				continue;
			endif;
			
			flexiController.myChassisType := trailerType;
			break;
		endwhile;
	endif;
	// ### TFS 56182 22Feb2023 NAVPW1
	
	flexiController.carriageTempC := request.carriageTemp;   //23.02.2023 NAVSA20 TFS 56179
	//jlika1 TFS 56398 --&gt;	
	cargoGroup := term.getCargoGroupItem(request.cargoGroupId);
	if cargoGroup &lt;&gt; null and cargoGroup.id &lt;&gt; request.cargoGroupId then
		cargoGroup := null;		
	endif;
	if cargoGroup = null then
		flexiController.cargoGroupId := request.cargoGroupId;
	endif;	
	flexiController.myCargoGroup := cargoGroup;		
	flexiController.alternativeId := request.alternativeId;
	flexiController.markNumber := request.markNumber;
	
	flexiController.remarks := request.remarks;
	//jlika1 TFS 56398 &lt;--
	
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(cargoType);
	pxyGateEntity.setMoveToTruckOnly(true);
	
	app.myPassport.setWarningsIgnored(true);
	controller.doRealTrackedItemCreate(pxyGateEntity,controller.myReceivalRequestInfo,ti);
		
	if not app.myPassport.trxCompletedOK then
		app.myPassport.removeDuplicateWarnings();
	endif;
	
	if (request.isOverlanded and ti &lt;&gt; null) then
		create txnControlller transient;
		txnControlller.type := TRANS_TYPE_OVERLANDED;
		txnControlller.myTrackedItem := ti;
		app.myTrxCA.trxCreateTITransaction(txnControlller, newTITxn, app.myPassport);
		delete txnControlller;
	endif;
	
	completedOK := true;	
	return response;

	
epilog
	delete iter;	// ### TFS 56182 22Feb2023 NAVPW1
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	flexiController.allSeals.purge();
	delete flexiController;
	delete pxyGateEntity;
	delete controller; //epr TFS 3760 20/4/17
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoItemUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createNewRailCargo" id="2f483d61-1d7c-4a56-92be-cc1024494680">
        <source>createNewRailCargo(request : WS_CargoItemUpdateRequest) : WS_TrackedItemUpdateResponse webService;
/*

Purpose:Create a new, or move an existing cargo item on a wagon

Parameters:			

Return Value:		

Date			Who			Reason
04 April 2017	cnwsc8		Initial creation
20 May   2019   cnwma1		Bug 38792: JMT - Mobile Apps - Rail Confirm - Adding 2 containers to a wagon doesn't seem to be working correct
*/

vars
	response	   : WS_TrackedItemUpdateResponse;
	completedOK	   : Boolean;
	terminal	   : CM_Terminal;
	error		   : CM_Error;
	ti 			   : CM_TrackedItem;
	mess 		   : String;
	wagon 		   : CM_Wagon;
	locnController : CM_WagonController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
		
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr TFS 5535 4/8/17
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		// Replace with appropriate permission
		
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	if terminal = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		completedOK := true;
		return response;
	endif;
	
	if request.id = "" then
		app.raiseCMException(ERR_TIID_MISSING,null,null);
		completedOK := true;
		return response;
	endif;

	if request.wagonUid = "" then
		app.raiseCMException(ERR_NO_WAGON_ID,null,null);
		completedOK := true;
		return response;
	endif;
	
	if request.wagonCargoIsoType = "" then
		app.raiseCMException(ERR_INVALID_ISOTYPE,null,null);
		completedOK := true;
		return response;
	endif;

	//epr TFS 5535 4/8/17 
	wagon := app.myPassport.getObjectOfTypeFromOid(request.wagonUid,CM_Wagon).CM_Wagon;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if wagon = null then
		app.raiseCMException(ERR_INVALID_WAGONNO,null,null);
		completedOK := true;
		return response;
	endif;
	
	if wagon.getTerminal() &lt;&gt; terminal then
		completedOK := true;
		return response;
	endif;
	
	if wagon.isBoxcar or wagon.isSkeletonCar then
		locnController := wagon.allLocationsControllers.first();
	elseif wagon.isFlatcar or wagon.isWellcarVisit then
		if request.wagonCargoPos &lt; 1 or request.wagonCargoPos &gt; wagon.allLocationsControllersArray.size then
			app.raiseCMException(Please_select_positionPOP,null,null);
			completedOK := true;
			return response;
		endif;
		locnController := wagon.allLocationsControllersArray[request.wagonCargoPos];
	endif;
	if locnController = null then
		app.raiseCMException(Please_select_positionPOP,null,null);
		completedOK := true;
		return response;		
	endif;
	
	ti := wagon.createNewTIFromHandHeld(request.id, locnController, request.wagonCargoIsoType.toUpper, self.class, mess);
	
	if ti = null and mess &lt;&gt; "" then
		create error transient;
		error.setErrorText(mess,false);        //05.20.2019 cnwma1 Bug #38792
		error.addToPassport(app.myPassport);
	endif;
	
	if ti &lt;&gt; null then
		response.cargoUidUpdated := ti.getOidAsString;
	endif;
	
	if not app.myPassport.trxCompletedOK then
		app.myPassport.removeDuplicateWarnings();
	endif;
	
	completedOK := true;	
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoItemUpdateRequest"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createPreNote" id="eed6cf18-131e-4c4b-8f50-2418a9c328fd">
        <usesRPC>default</usesRPC>
        <source>createPreNote(preNoteCreateReq : WS_PreNoteUpdateRequest) : WS_TrackedItemUpdateResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Sep 2008	cnwkao1	Initial creation
13 Jun 2013	cnwdap1	PAR #31754 CCMS SFW 1321 Imperial Measurements
13 Jun 2013 cnwdap1	PAR #31700 Added number of items for break-bulk
17/06/2013	cnwdap1	PAR #31800 Added alternative ID, client ref, itemDesc, colour, mark number and remarks 
24/09/2013	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
05/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
30/05/2017	cnwdap1	TFS 4449 STWR Mark and Mark number field length adjustments
15/11/2017  jlger1	TFS 7744 Webportal dev refactoring - prenotes now handles all seals, tranship port, entered cargo and tare weight
16/09/2019  cnwma1	Bug 46485: JMT - Web Portal - Warnings do not show for updating release requests
04/11/2019	jlgdap1	TFS 47272 PNL Web Portal (RIA) not saving prenote - RIA does not cope with warnings
26/11/2020  cnwma1  Bug 50394: NXL-Cannot create prenote from RIA or SOAP
11/08/2023  navrv30 Bug 59370: NXL-Creating prenotes in MTN encountered performance issues in Conlinxx
*/

vars
	iFPreNote			: CMIF_PreNote;

	iFArray				: CMIF_TIObjectArray;
	response			: WS_TrackedItemUpdateResponse;
	completedOK			: Boolean;
	terminal			: CM_Terminal;
	tmpTI				: CM_TrackedItem;
	cargoId 			: String;
	cargoType 			: Integer;
	infoMessage 		: WS_InfoMessage;
	cargoTypeObj        : CM_CargoType;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	//epr tfs 7744 15/11/17 refactored into method  
	preNoteCreateReq.validateDimensions();
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	
	create iFArray transient;
	create iFPreNote transient;
	
	terminal := app.myPassport.myTerminal;
	
	cargoType    := preNoteCreateReq.cargoType.Integer;
	cargoTypeObj := app.myRoot.allCargoTypesById[cargoType];	//18/03/2010 cnwdz2 23232
	if cargoTypeObj = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "CargoType ", preNoteCreateReq.cargoType.String, null, null);
		completedOK := true;															
		return response;																
	endif;
	
	cargoId := preNoteCreateReq.idTextBox.toUpper();
	
	tmpTI := terminal.lookupTrackedItem(cargoId, cargoType, TI_STATE_NOTIFIED, null, true);
	if tmpTI = null then
		tmpTI := terminal.lookupTrackedItem(cargoId, cargoType, TI_STATE_NORMAL, null, true);
	endif;
	
	if tmpTI &lt;&gt; null and tmpTI.site &lt;&gt; TI_SITE_ONSITE  then
		app.raiseCMException3(ERR_TI_PRE_NOTIFIED, tmpTI.cargoTypeDescr, tmpTI.id, tmpTI.myTerminal.code, null, null);

	else
	
		if tmpTI &lt;&gt; null then
			app.raiseCMWarning3(ERR_TI_ONSITE, tmpTI.cargoTypeDescr, tmpTI.id, tmpTI.myTerminal.code, null, null, null); //cwnrd1 par 25075 ccms 1973 3.11.2010	
			//app.raiseCMException3(ERR_TI_ONSITE, tmpTI.cargoTypeDescr, tmpTI.id, tmpTI.myTerminal.code, null, null);	
		endif;
		//epr tfs 7744 15/11/17 refactored into one method  
		preNoteCreateReq.setCMIF_Prenote(iFPreNote);
			
		iFArray.add(iFPreNote);
		
		//if app.myRoot.isClientPortNelson or app.myRoot.isClientPortOtago then		  // TFS 47272    //26.11.2020 cnwma1 #50394															  // TFS 47272
		app.myPassport.setWarningsIgnored(preNoteCreateReq.warningsAcknowledged);     //12/09/2019 cnwma1 #46485
		app.myTrxCA.trxCreatePreNotes(iFArray, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			if iFPreNote.myPersistentTrackedItem &lt;&gt; null then
				response.cargoUidUpdated:=iFPreNote.myPersistentTrackedItem.getOidAsString;
			endif;
		endif;
	endif;
	
	//06/07/2009 cnwdz2 par 20233
	if app.myPassport.allErrors.isEmpty() then
		create infoMessage transient;
		if iFPreNote.transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR 
			and iFPreNote.pinNo &lt;&gt; null	//It can be null, when no PIN generation for hazardous or over dimension cargo. ccms 1676 Feb 2009.
		then
			infoMessage.text :=	'Pre-Note added with PIN (' &amp; iFPreNote.pinNo &amp; ')';
		else
			infoMessage.text := 'Pre-Note added successfully';
		endif;	
		response.allInfo.add(infoMessage);
	endif;
	completedOK := true;
	return response;
	
epilog
	// Tidy up local transients
	delete iFArray;
	if iFPreNote &lt;&gt; null then                         //11/08/2023   navrv30  Bug 59370
		delete iFPreNote.myEmailDefaults;
		iFPreNote.allDamageInstancesByPos.purge;
		delete iFPreNote;
	endif;


	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="preNoteCreateReq" type="WS_PreNoteUpdateRequest"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createPreNoteAttachment" id="de20b701-dbd8-4be2-afb0-113e85d1c2bd">
        <source>createPreNoteAttachment(attachmentCreateReq : WS_AttachmentUpdateRequest) : WS_AttachmentUpdateResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jan 2009	cnwdz2	Initial creation

*/

vars
	
	response	  : WS_AttachmentUpdateResponse;
	completedOK	  : Boolean;
	terminal	  : CM_Terminal;
	
	intFaceAttach : CMIF_InOutAttachment;
	
	tmp,
	isoType,
	cargoId       : String; 
	weightTotal,   
	cargoType     : Integer;
	
	cargoTypeArray,
	idTextBoxArray,
	isoTypeArray,
	weightTotalArray  : StringArray;
	
	//cnwmc5 - 19 Feb 2015 - PAR 34346
	cargoTypeObj	: CM_CargoType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	create intFaceAttach transient;

	// apparently we have been instructed to ignore warnings.... aren't they interested in data integrity?
	self.setIgnoreWarnings(true);
	
	terminal := app.myPassport.myTerminal;
	
	cargoTypeArray := attachmentCreateReq.cargoTypeArray;
	tmp := cargoTypeArray.removeAt(1);
	if tmp &lt;&gt; null and tmp.length() &gt; 0 and tmp.isInteger() then
		cargoType := tmp.Integer;
	else
		cargoType := TI_CargoType_Null;
	endif;
	
	idTextBoxArray := attachmentCreateReq.idTextBoxArray;
	tmp := idTextBoxArray.removeAt(1);
	if tmp &lt;&gt; null and tmp.length() &gt; 0 then
		if idTextBoxArray.includes(tmp) then
			app.raiseCMException1(VB_DUPLICATED_ITEM, 'Cargo Item ' &amp; tmp, 'id', null);
			completedOK := true;
			return response;
		endif;
		cargoId := tmp;
	endif;
	
	tmp := attachmentCreateReq.isoTypeArray.first();
	if tmp &lt;&gt; null and tmp.length() &gt; 0 then
		isoType := tmp;
	endif;
	
	tmp := attachmentCreateReq.weightTotalArray.first();
	if tmp &lt;&gt; null and tmp.length() &gt; 0 and tmp.isInteger() then
		weightTotal := tmp.Integer;
	endif;
	
	//cnwmc5 - 19 Feb 2015 - PAR 34346
	tmp := attachmentCreateReq.productTypeArray.first();
	if tmp &lt;&gt; null and tmp.length() &gt; 0 then
		cargoTypeObj := app.myRoot.allCargoTypesById[cargoType];
		if cargoTypeObj = null then
			//app.raiseCMException1(null,null,null,null);
		endif;
	endif;
	
	intFaceAttach.set(terminal,cargoType,cargoId,isoType,weightTotal);
	intFaceAttach.checkFieldsNotNull(cargoType);	
	
	completedOK := true;
	return response;
	
	
epilog
	// Tidy up any local transients
	delete intFaceAttach;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="attachmentCreateReq" type="WS_AttachmentUpdateRequest"/>
        <ReturnType type="WS_AttachmentUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createSourceLocation" id="d0772448-c345-4732-bc6a-0dbf36394a3a">
        <source>createSourceLocation(request : WS_SourceLocationUpdateRequest) : WS_SourceLocationResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_SourceLocationResponse;
	completedOK		: Boolean;
	
	pxyCodeGroup,
	newCodeGroup	: CM_CodeGroup;
	
	code,
	code2,
	code3			: CM_Code;
	
	wsCodeGroup,
	wsCodeGroupNew	: WS_CodeGroupSourceLocation;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCodeGroupMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsCodeGroup := request.myCodeGroupSourceLocation;
	
	create pxyCodeGroup transient;
	wsCodeGroup.setProxyCodeGroup(pxyCodeGroup);
	
	app.myTrxCA.trxCreateCodeGroupSrcLocTree(pxyCodeGroup, newCodeGroup, app.myPassport);
	
	if newCodeGroup &lt;&gt; null and app.myPassport.noErrors() then
		create wsCodeGroupNew transient;
		wsCodeGroupNew.setProxyFromObject(newCodeGroup);
		response.setCodeGroupSourceLocation(wsCodeGroupNew);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyCodeGroup;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_SourceLocationUpdateRequest"/>
        <ReturnType type="WS_SourceLocationResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createVehicleVisit" id="247faeee-adb8-4967-9c57-0140f7e60855">
        <source>createVehicleVisit(vehicleVisitRequest : WS_VehicleVisitUpdateRequest) : WS_VehicleVisitResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2015	cnwmc5	Initial creation
27 Feb 2015	cnwkpd1	PAR #35773 - issues in createVehicleVisit web service 

*/

vars
	response			: WS_VehicleVisitResponse;
	completedOK			: Boolean;
	wsRealVVR			: WS_VehicleVisit;
	
	pxyVVR,
	realVVR				: CM_VehicleVisitRecord;
	terminal			: CM_Terminal;
	wsVVR				: WS_VehicleVisit;
	allProformaLines	: ObjectSet;
	
	pxyVBTS,
	vbts			: CM_VehicleBookingTimeSlot;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	
	//epr TFS 5535 17/8/17
	app.checkCurrentUserHasAccess(PmWebCreateVVR);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	wsVVR := vehicleVisitRequest.myVehicleVisit;
	
	create allProformaLines transient;
	create pxyVVR transient;
	wsVVR.setVehicleVisitProxy(pxyVVR);
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	self.setIgnoreWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, realVVR, allProformaLines, app.myPassport);
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if realVVR &lt;&gt; null then
		create wsRealVVR transient;
		wsRealVVR.setProxyFromObject(realVVR);
		response.allVehicleVisits.add(wsRealVVR);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if pxyVVR &lt;&gt; null then
		if pxyVVR.myVehicleBookingTimeslot &lt;&gt; null and pxyVVR.myVehicleBookingTimeslot.isTransient then
			delete pxyVVR.myVehicleBookingTimeslot;
		endif;
		delete pxyVVR;
	endif;
	
	delete allProformaLines;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="vehicleVisitRequest" type="WS_VehicleVisitUpdateRequest"/>
        <ReturnType type="WS_VehicleVisitResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createVoyageHoldCargoRequest" id="aa471ac9-c25b-4f95-9ab2-b76d0b224a23">
        <source>createVoyageHoldCargoRequest(_request : WS_VoyageHoldCargoRequest)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
27 March 2018		jlger1		Initial creation 37664
21 Feb 2024			navsck1		ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal
26 March 2024		navpw1		TFS: 62849 (62927) - Reverted Code by adding beginLoad/endLoad

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	allPxyWorkOrderDetals,
	allDocuments		: ObjectArray;
	voyage  : CM_Voyage;
	obj: Object;
	nextStatus : CM_VoyageStatus;
	wsVoyageHoldCargo  : WS_VoyageHoldCargo;
	berth 			: HMS_Berth;
	realCargoRequest,
	pxyWorkOrderDtl : CM_WodCargoRequest;
	statusDesc 		: String;
	wsDocument : WS_Document;
	occursOnDT  : TimeStamp;
	
	pxyResourceUsed : HMS_ResourceUsed;
	wsHMSResourceUsed : WS_HMSResourceUsed;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	
begin

	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	voyage:=app.myPassport.getObjectOfTypeFromOid(_request.voyage,CM_Voyage).CM_Voyage;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);

	create allPxyWorkOrderDetals transient;
	foreach wsVoyageHoldCargo in _request.allVoyageHoldCargo discreteLock do
			pxyWorkOrderDtl:=null;
			//epr TFS 41824 7/11/18 - issue where editing cargo request would clear data not displayed on web portal
			// i.e. special stow &amp; inaportnet rpkroNumber 
			if wsVoyageHoldCargo.cmObjectId &lt;&gt; null then
				realCargoRequest:=app.myPassport.getObjectOfTypeFromOid(wsVoyageHoldCargo.cmObjectId,CM_WodCargoRequest).CM_WodCargoRequest;
				if realCargoRequest &lt;&gt; null then
					pxyWorkOrderDtl := realCargoRequest.cloneSelf(true);
				endif;
			endif;	
			
			if pxyWorkOrderDtl = null then
				create pxyWorkOrderDtl transient;
			endif;
	
			wsVoyageHoldCargo.setProxyWodCargoRequest(	pxyWorkOrderDtl);
			allPxyWorkOrderDetals.add(pxyWorkOrderDtl);
	endforeach;
	
	
	create allDocuments transient;							// 21.02.2024 navsck1 #62237
	beginLoad;												// 21.02.2024 navsck1 #62237
	_request.allDocuments.setProxyDocuments(allDocuments);	// 21.02.2024 navsck1 #62237
	endLoad;												// 21.02.2024 navsck1 #62237
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if _request.berthOid &lt;&gt; null then
		berth:=app.myPassport.getObjectOfTypeFromOid(_request.berthOid,HMS_Berth).HMS_Berth;
	endif;
	if _request.occursOnDT &lt;&gt; null then
		occursOnDT:=_request.occursOnDT.asTimeStampFromWebInterface;
	endif;
	
	// TFS 40127
	create allPxyHMSResourcesUsed transient;
	foreach wsHMSResourceUsed in _request.allHMSResourcesUsed discreteLock do
		create pxyResourceUsed transient;
		wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
		allPxyHMSResourcesUsed.add(pxyResourceUsed);		
	endforeach;
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	

	app.myTrxCA.trxCreateVoyageCargoRequest(voyage,null,allPxyWorkOrderDetals, allDocuments, null,berth,occursOnDT, allPxyHMSResourcesUsed,false, app.myPassport);
	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	

	if allDocuments &lt;&gt; null then
		allDocuments.purge;
	endif;
	delete allDocuments;
	
	if allPxyWorkOrderDetals &lt;&gt; null then
		allPxyWorkOrderDetals.purge;
	endif;
	
	delete allPxyWorkOrderDetals;
	
	delete allPxyHMSResourcesUsed;	//31 May 2019	NDL	TFS 44773
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_VoyageHoldCargoRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createVoyageRequest" id="ef408392-0739-4502-bf06-ff5df3d14765">
        <source>createVoyageRequest(request : WS_CreateVoyageRequest)  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/03/2018	jlger1	Initial creation 37331
20/11/2018	jlgdap1	TFS 42024 PEL1 Incorrect Ports in Voyage Request
20/09/2021 	jlier1	TFS 51963
08/11/2021	jlier1 TFS 52302
18/08/2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
*/

vars
	response : WS_Response;
	completedOK : Boolean;
	voyageProcess : CM_VoyageProcess;	//27 Sep 2018	NDL	TFS 41109
	voyageStatus : CM_VoyageStatus;	//27 Sep 2018	NDL	TFS 41109
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmVoyageDefEdit);		// Replace with appropriate permission
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return response;
	endif;
	
//	app.myPassport.myTerminal.validateCanCreateVoyageRequest();
	//27 Sep 2018	NDL	TFS 41109
	voyageProcess := app.myPassport.myTerminal.getDefaultVoyageProcess();
	if voyageProcess &lt;&gt; null then
		if voyageProcess.isMTNWOProcess then
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_VoyRequested];
		elseif voyageProcess.isEUPDefaultProcess then									// TFS 54298
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReq];		// TFS 54298
		endif;
	endif;
	if voyageStatus = null then
		app.raiseCMException1(Voyage_process_create_voyage,"Voyage Requested",null,null);
	elseif not voyageStatus.userCanSet(app.myPassport.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, app.myPassport.myTerminal.code, voyageStatus.description, "status", null);	// TFS 37445
	endif;

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
			
	
	request.createVoyageRequest(false);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
		
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CreateVoyageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createWorkOrderDetail" id="dd9d3509-9553-4a79-a785-bf369af5c4bb">
        <source>createWorkOrderDetail(request : WS_WorkOrderDetailUpdateReq )  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation
28 Aug 2023 navhl20 Bug 60008: MTN - 1223 exception when actioning Pack Work Order
*/

vars
	response : WS_Response;
	completedOK : Boolean;
	realWorkOrder,
	pxyWorkOrder : CM_WorkOrder;
	infoMessage			: WS_InfoMessage;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;	
	
	if not request.myWorkOrderDetail.isVoyageWorkOrder and request.myWorkOrderDetail.requiredByDT = null and app.myPassport.myTerminal.isUseYardJobsForCargoWo = true then			//28.8.2023 navhl20 #60008
		app.raiseCMException(Work_order_yard_req_date, null, null);
	endif;
	
	pxyWorkOrder := request.createProxyWorkOrder(true);
	
	if pxyWorkOrder = null then
		completedOK:=true;
		return response;
	endif;
	
	if pxyWorkOrder.isVoyageWorkOrder then
		app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyMaint);		// Replace with appropriate permission
	else
		app.checkCurrentUserHasAccess(PmWebWorkOrderMaint);		// Replace with appropriate permission
	endif;
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,app.myPassport);
	
	//14 Feb 2019	NDL	Found while testing TFS 43318
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if realWorkOrder &lt;&gt; null then
		app.myPassport.clearErrorsWarnings;
		create infoMessage transient;
		infoMessage.text := app.getErrorString1(Work_order_added,realWorkOrder.id);
		response.allInfo.add(infoMessage);
		
		//epr TFS 39166 creates proforma stuff down after trx finished
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	delete pxyWorkOrder;	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_WorkOrderDetailUpdateReq"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="deleteBooking" id="2c0bd954-bedd-422b-bf07-f3c4e06e1ff3">
        <source>deleteBooking(bookingRequest : WS_BookingUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	bookingRef		: CM_BookingRef;	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmGteBookingRefMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation
	if bookingRequest.myBooking &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		bookingRef :=app.myPassport.getObjectOfTypeFromOid(bookingRequest.myBooking.cmObjectId,CM_BookingRef).CM_BookingRef;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if bookingRef = null  then
		app.raiseCMException1(Matching_found, app.getErrorString(Booking), null, null);
		completedOK := true;
		return response;
	endif;

	// Do the delete 
	app.myTrxDA.trxDeleteBookingRef(bookingRef, null, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="bookingRequest" type="WS_BookingUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="deleteBulkRelease" id="2074baa7-c69d-4a30-abab-bf5e701dbafa">
        <source>deleteBulkRelease(bulkReleaseRequest : WS_BulkReleaseUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	bulkRelease		: CM_BulkRelease;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
