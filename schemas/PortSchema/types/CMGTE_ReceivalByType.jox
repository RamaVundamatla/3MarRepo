    <JadeMethod name="actionForCreateInternal" id="0dceb832-4f37-49bb-80ba-62b4d5f1f33e">
        <updating/>
        <source>actionForCreateInternal(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI : CM_TrackedItem input): Boolean updating, protected;
//01 February 2010	cnwdw1	
// 11/01/2022		navpw1	TFS: 52631 Added Backdating for VVR transactions
//
vars

begin

	if _passport.noErrors then
		if not self.createRequestByType(_passport) then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSplitTotalQuantity" id="1690bcb4-8a06-4658-88ac-6a3592e0a258">
        <source>canSplitTotalQuantity(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

	cm_cargoType : CM_CargoType;

begin

	if self.myReceivalInfo &lt;&gt; null then
		cm_cargoType := self.myReceivalInfo.myCargoType;
	endif;
	
	if cm_cargoType &lt;&gt; null then
		if not cm_cargoType.allowDuplicates then
			return false;
		endif;
	endif;
	
	if self.getTotalQuantity &gt; 1 then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeAllowsDuplicates" id="618c7e68-ad0d-419c-bde0-e8fdfe322e41">
        <source>cargoTypeAllowsDuplicates(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2013	cnwrd1	Initial creation

*/

vars

begin

	if self.myReceivalInfo = null then
		return false;
	else
		return  self.myReceivalInfo.cargoTypeAllowsDuplicates;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRequestByType" id="e525c73d-8ab7-448c-9725-7f7919fac32a">
        <updating/>
        <source>createRequestByType(_passport : CM_Passport input) : Boolean updating ;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	roadJob : CM_RoadJob;
	realReceivalRequest,
	proxyReceivalRequest : CM_ReceivalRequest;
begin

	if self.myVehicleVisitRecord &lt;&gt; null then //cnwrd1 par 24792 9.7.2010 this should now be set? but doesnt seem to be set on a child item so we go look for the parents.
		roadJob := self.myVehicleVisitRecord.myRoadJob;
	elseif self.myParent &lt;&gt; null then
		if  self.myParent.myVehicleVisitRecord &lt;&gt; null then
			roadJob := self.myParent.myVehicleVisitRecord.myRoadJob;
		else
			app.raiseCMException(Cannot_find_roadJob, null, null);
			return false;
		endif;
	else
		app.raiseCMException(Cannot_find_roadJob, null , null);
		return false;
	endif;
		
	realReceivalRequest := roadJob.getSingleRequestInstance().CM_ReceivalRequest;
	if realReceivalRequest &lt;&gt; null then
		proxyReceivalRequest := realReceivalRequest.pxyCreateUpdateProxy();
	else
		create proxyReceivalRequest transient;
	endif;

	proxyReceivalRequest.setProxy(self.myReceivalInfo);
								
	if _passport.noErrors() then	
		proxyReceivalRequest.validate(_passport.myUser);
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;
	
		if realReceivalRequest &lt;&gt; null then
		// This request has already been added to the job.  We just need to update the request details
		realReceivalRequest.setForUpdate(proxyReceivalRequest);
		if _passport.hasErrors() then
			return false;
		endif;
	else
		//Add the request to the job	
		self.myYardRequest := roadJob.addRequest(proxyReceivalRequest, _passport).CM_YardRequest;
		if _passport.hasErrors() then
			return false;
		endif;
	endif;
	
	return true;
epilog
	delete proxyReceivalRequest;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="76ff62fc-93e9-42d0-a709-9c88c26a697e">
        <source>getCargoType():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars

begin

	if self.myReceivalInfo &lt;&gt; null then
		return self.myReceivalInfo.myCargoType;
