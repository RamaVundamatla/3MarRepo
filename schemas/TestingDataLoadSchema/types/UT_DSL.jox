    <JadeMethod name="updateDeckingRulesCustomYA" id="7007ed66-04e9-498b-ac7b-f4674fdabfcb">
        <source>updateDeckingRulesCustomYA(_yaName: String; _isIn: Boolean; _order: IntegerArray);
//31 December 2008	cnwdw1	
//
vars
	ya: CM_YardAllocation;
	pxyDecking, decking: CM_YADeckingOptions;
	newCells, oldCells: CM_YALocationCellArray;
	index: Integer;
begin
	ya := self.getYA(_yaName);
	assertNotNull(ya);
	decking := ya.allYABlocksIn.first.myDeckingOptions;
	pxyDecking := app.createUpdateProxy(decking).CM_YADeckingOptions;
	create newCells transient;
	if _isIn then
		pxyDecking.setProxy(decking.showHeightsForCustom, decking.useReverseOfIn, ya.allYABlocksIn.first);
		pxyDecking.allDeckingRulesIn.first.setProxy(true, DeckingRule_Custom, 0, 0, 0, 0);
		assertEqual(pxyDecking.allYALocationCellsIn.size, _order.size);
		oldCells := pxyDecking.allYALocationCellsIn;
	else
		pxyDecking.setProxy(decking.showHeightsForCustom, false, ya.allYABlocksIn.first);
		pxyDecking.allDeckingRulesOut.first.setProxy(false, DeckingRule_Custom, 0, 0, 0, 0);
		assertEqual(pxyDecking.allYALocationCellsOut.size, _order.size);
		oldCells := pxyDecking.allYALocationCellsOut;
	endif;
	// Update the cell order
	foreach index in 1 to _order.size do
		newCells.add(oldCells[_order[index]]);
	endforeach;
	oldCells.clear;
	newCells.copy(oldCells);  // Copy over top of orginal order
	app.myTrxUA.trxApplyDeckingRule(pxyDecking, DeckingLevel_YA, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete newCells;
	delete pxyDecking;
end;</source>
        <Parameter name="_yaName" type="String"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_order" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="updateDeckingRulesTA" id="0a7f1729-df77-4c27-87fa-866248d1700c">
        <source>updateDeckingRulesTA(_taName: String; _isIn: Boolean; _areaRule, _stackRule, _rowRule, _patternRule, _topupTier: Integer);
//31 December 2008	cnwdw1	
//
vars
	pxyTa, ta: CM_TerminalArea;
	pxyDecking: CM_YADeckingOptions;
begin
	ta := self.getTerminalArea(_taName);
	assertNotNull(ta);
	pxyTa := app.createUpdateProxy(ta).CM_TerminalArea;
	pxyDecking := pxyTa.myYADeckingOptions;
	if _isIn then
		pxyDecking.setProxy(pxyDecking.showHeightsForCustom, pxyDecking.useReverseOfIn, pxyTa);
		pxyDecking.allDeckingRulesIn.first.setProxy(_isIn, _areaRule, _stackRule, _rowRule, _patternRule, _topupTier);
	else
		pxyDecking.setProxy(pxyDecking.showHeightsForCustom, false, pxyTa);
		pxyDecking.allDeckingRulesOut.first.setProxy(_isIn, _areaRule, _stackRule, _rowRule, _patternRule, _topupTier);
	endif;
	app.myTrxUA.trxApplyDeckingRule(pxyDecking, DeckingLevel_TA, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyTa;
end;</source>
        <Parameter name="_taName" type="String"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_areaRule" type="Integer"/>
        <Parameter name="_stackRule" type="Integer"/>
        <Parameter name="_rowRule" type="Integer"/>
        <Parameter name="_patternRule" type="Integer"/>
        <Parameter name="_topupTier" type="Integer"/>
    </JadeMethod>
