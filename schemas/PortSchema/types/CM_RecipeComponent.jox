    </JadeMethod>
    <JadeMethod name="setForUpdate" id="83d23254-bc22-4824-8a42-9568e46be06d">
        <updating/>
        <source>setForUpdate( _proxy : CM_RecipeComponent; _recipe : CM_Recipe ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.code := _proxy.code;
	self.description := _proxy.description;
	self.order := _proxy.order;
	
	self.updateAmounts(	_proxy.myCargoType, //_cargoType : CM_CargoType;
						_proxy.quantity,	//_quantity : Integer;
						_proxy.volume,	//_volume : Decimal;
						_proxy.weight	//_weight : Decimal
						);
	
	self.myProduct := _proxy.myProduct;
	self.myCargoType := _proxy.myCargoType;
	self.myRecipe := _recipe;


epilog

end;</source>
        <Parameter name="_proxy" type="CM_RecipeComponent"/>
        <Parameter name="_recipe" type="CM_Recipe"/>
    </JadeMethod>
