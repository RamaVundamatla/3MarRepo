    <JadeMethod name="setForUpdate" id="b6a5cf77-2974-4b96-b83c-426942b39cf0">
        <updating/>
        <source>setForUpdate(pProxyLogGrade: CM_LogGrade) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxyLogGrade);
	self.minSED 		:= pProxyLogGrade.minSED;
	self.maxSED 		:= pProxyLogGrade.maxSED;
	self.minMeanSED 	:= pProxyLogGrade.minMeanSED;
	self.maxMeanSED 	:= pProxyLogGrade.maxMeanSED;
	
	self.allLogLengths.clear;
	self.allLogLengthsBySortOrder.clear;
	self.allLogTreatments.clear;
	self.allLogTypes.clear;

	pProxyLogGrade.allLogLengths.copy(self.allLogLengths);
	pProxyLogGrade.allLogLengthsBySortOrder.copy(self.allLogLengthsBySortOrder);
	pProxyLogGrade.allLogTreatments.copy(self.allLogTreatments);
	pProxyLogGrade.allLogTypes.copy(self.allLogTypes);
	self.colour := pProxyLogGrade.colour;
end;</source>
        <Parameter name="pProxyLogGrade" type="CM_LogGrade"/>
    </JadeMethod>
