<GUIClass name="SHP_VoyageChangeVessel" id="6951635b-3510-41aa-8bdd-cb39d51f4f4d">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cmbVessel" id="d56fdf21-ccd4-4006-bd14-af95d96da98a">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblVessel" id="e5ca090b-24cc-4add-b5c0-7b42bdf5fa40">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblVoyageCode" id="1c5939fb-d702-48c6-b26f-c22296e8c0e9">
