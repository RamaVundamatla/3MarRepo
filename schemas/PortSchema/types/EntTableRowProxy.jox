    <PrimAttribute name="nameForProxy" id="bb2dde48-ab4d-4da4-8057-6b9ab6a3b612">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>
This is a copy of the name used for adding/updating as
the name on the actual object is a virual.</text>
    </PrimAttribute>
    <JadeMethod name="getName" id="679124cb-3308-45ba-90eb-6cb082bc9e2b">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.nameForProxy;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslation" id="3b3a3174-a25f-4937-a070-21f5a735bf0e">
        <source>getTranslation(_locale : CM_Locale):XLAT_Translation;

// override for proxies that create items on the fly ... if no translation, then falls back to use the heading

begin
	if myRealObject &lt;&gt; null then
		return myRealObject.getTranslation(_locale);
	else
		return null;
	endif;
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="XLAT_Translation"/>
    </JadeMethod>
    <JadeMethod name="setBasicDetails" id="0590d35f-f739-414b-9169-9bfb1194b100">
        <updating/>
        <source>setBasicDetails(_name, _heading : String;_inputType : Integer; _visible : Boolean) updating;
//-----------------------------------------
// Created: November 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	// 34658 handle measurement types
	self.nameForProxy	:= _name[1:30].trimBlanks;
	//epr TFS 49582 11/5/21 - performance improvements if not deriving name everytime
	self.name:=self.nameForProxy;
	self.heading		:= _heading[1:60];
	self.inputType		:= _inputType;
	self.visible 		:= _visible;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_inputType" type="Integer"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="a8ea8f24-c1b2-4720-841d-d7c80cba9705">
        <updating/>
        <source>setForProxy(pName, pHeading, pShortHeading, pControlName : String; 
    pInputType : Integer;
    pInputTypeForWeb : Integer;
    _termType : CM_TerminologyType;
    pVisible,
    pValueToDisplayIfNull : Boolean;
    pSortFieldName,
    pClickMethod,
    pGotFocusMethod,
    pLostFocusMethod,
    pErrorReturnString : String;
	pMeasurementType : String;					// PAR #31155
	_isMandatoryField : Boolean;
    pEntTableGroup : EntTableGroup) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields

vars

begin

	if self.myEntTableCellControl &lt;&gt; null then
		// inputType has changed so delete the existing
		// as it will be of the wrong class
		if self.inputType &lt;&gt; pInputType then
			delete self.myEntTableCellControl;
		endif;
	endif;

	self.nameForProxy	:= pName;
	//epr TFS 49582 11/5/21 - performance improvements if not deriving name everytime
	self.name:=self.nameForProxy;
	self.heading		:= pHeading;
	self.shortHeading	:= pShortHeading;
	self.controlName	:= pControlName;
	self.inputType		:= pInputType;
	self.inputTypeForWeb := pInputTypeForWeb;
	self.myTerminologyType := _termType;
	self.visible		:= pVisible;
	self.sortFieldName	:= pSortFieldName;
	self.clickMethodName := pClickMethod;
	self.gotFocusMethodName := pGotFocusMethod;
	self.lostFocusMethodName := pLostFocusMethod;
	self.displayNullIfZero	:= pValueToDisplayIfNull;
	//self.minColumnWidth	:= pMinColWidth;
	//self.columnWidthFactor	:= pColWidthFactor;
	self.measurementType := pMeasurementType;			// PAR #31155
	self.isMandatoryField := _isMandatoryField;			//12.01.2026 navlc30 #36954

	if pErrorReturnString = null then
		errorReturnString := pName;
	else
		errorReturnString := pErrorReturnString;
	endif;
	
	myGroup := null;
	
	if myGroup &lt;&gt; pEntTableGroup then
		myGroup := pEntTableGroup;
	endif;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pShortHeading" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
        <Parameter name="pInputTypeForWeb" type="Integer"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
        <Parameter name="pVisible" type="Boolean"/>
        <Parameter name="pValueToDisplayIfNull" type="Boolean"/>
        <Parameter name="pSortFieldName" type="String"/>
        <Parameter name="pClickMethod" type="String"/>
        <Parameter name="pGotFocusMethod" type="String"/>
        <Parameter name="pLostFocusMethod" type="String"/>
        <Parameter name="pErrorReturnString" type="String"/>
        <Parameter name="pMeasurementType" type="String"/>
        <Parameter name="_isMandatoryField" type="Boolean"/>
        <Parameter name="pEntTableGroup" type="EntTableGroup"/>
    </JadeMethod>
    <JadeMethod name="setFromRealObject" id="a25e54c7-77df-4bca-8eb9-7eec317f487c">
        <updating/>
        <source>setFromRealObject(pReal : EntTableRow) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 15/07/2015	cnwkpd1		PAR #36562 - Ensure ETRow object is unlocked if this is called 
//							when not in tran state
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields

							
vars
	proxyControl	: EntTableCellControl;
	
begin

	sharedLock(pReal);		// ensure we have latest copy

	pReal.allEntTableDefs.copy(self.allEntTableDefs);
	pReal.allEntTableViews.copy(self.allEntTableViews);
	
	self.controlName	:= pReal.controlName;
	self.errorReturnString	:= pReal.errorReturnString;
	self.heading		:= pReal.heading;
	self.shortHeading	:= pReal.shortHeading;
	self.inputType		:= pReal.inputType;
	self.inputTypeForWeb		:= pReal.inputTypeForWeb;
	self.myTerminologyType := pReal.myTerminologyType;
	self.nameForProxy	:= pReal.name;
	//epr TFS 49582 11/5/21 - performance improvements if not deriving name everytime
	self.name:=pReal.name;
	self.clickMethodName := pReal.clickMethodName;
	self.gotFocusMethodName := pReal.gotFocusMethodName;
	self.lostFocusMethodName := pReal.lostFocusMethodName;
	self.sortFieldName		:= pReal.sortFieldName;
	self.visible		:= pReal.visible;
	self.displayNullIfZero	:= pReal.displayNullIfZero;
	self.measurementType	:= pReal.measurementType;			// PAR #31155
	self.isMandatoryField	:= pReal.isMandatoryField;			//12.01.2026 navlc30 #36954

	if pReal.myEntTableCellControl &lt;&gt; null then
		proxyControl := pReal.myEntTableCellControl.cloneSelf(true);
		proxyControl.myEntTableRow := self;
	endif;
	
	pReal.allDependencies.copy(self.allDependencies);
	
	self.myRealObject := pReal;

epilog
	unlock(pReal);		// PAR #36562
end;</source>
        <Parameter name="pReal" type="EntTableRow"/>
    </JadeMethod>
</Class>
