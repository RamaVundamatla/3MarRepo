    <JadeMethod name="doCopytoTrade" id="1f5d64e4-9baf-40af-a294-3787fdaeb419">
        <updating/>
        <source>doCopytoTrade() updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 June 2009		cnwrl1	Initial creation as part of PAR 19998 - Copy To Trade

*/
	
vars
	form	: SOP_CopyToTradeForm;
	
begin
	form	:= app.loadForm(	SOP_CopyToTradeForm,
								CMUI_Assistant,
								false,							// Maximized
								false,							// Show
								true,							// Modal
								self.myTerminal,
								null ).SOP_CopyToTradeForm;		// CMUI_MenuAction
	
	form.setParentForm( self );
	
	if form.showModal &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="710e068e-c8f0-4c53-becd-64ea5155dc32">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	30 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpH : Real;
	
begin
	inheritMethod();
	lblHeading.top		:= self.frmToolbar.height;
	
	// cnwrl1 23/06/2009 PAR 19998 - start of coding
	self.btnCopyToTrade.top		:= self.lblHeading.top + 5;
	self.btnCopyToTrade.left	:= self.lblHeading.left + self.lblHeading.width + 10;
	// cnwrl1 23/06/2009 PAR 19998 - end of coding
	
	self.tblDetail.top	:= lblHeading.top + lblHeading.height + VerticalSpacing;
	self.grp1.top		:= self.tblDetail.top + self.tblDetail.height + VerticalSpacing;
	
	tmpH := self.clientHeight - self.grp1.top;
	tmpH := (tmpH / 2).Integer;
	
	self.grp1.height := tmpH - VerticalSpacing;
	
	self.grp2.top		:= self.grp1.top + self.grp1.height + VerticalSpacing;
	self.grp2.height	:= tmpH;
	
	self.grp2.cnEcResizeContents();
	self.grp1.cnEcResizeContents();
	self.mulDebtors.cnEcResizeContents();
	self.mulPorts.cnEcResizeContents();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="437def65-2a7c-4ec8-b312-bbe89dd24b61">
        <updating/>
        <source>doSave() : Boolean updating;

vars
	errObj						: CM_Error;
	idx							: Integer;
	ignoreWarnings,
	rtnValue					: Boolean;
	proxyShipPortGroup 			: CM_ShipPortGroup;
	proxyShipPort				: CM_ShipPort;
	lineGroupDebtor,
	proxyLineGroupDebtor 		: CM_LineGroupDebtor;
	lCode,lDescription 			: String;
	shippingLineCode 			: String;
	lShippingLine 				: CM_ShippingLine;
	tmpSelectedDebtors,
	tmpSelectedPorts 			: ObjectArray;
	lShipPorts,
	lLineGroupDebtors			: ObjectArray;
	tempObj						: Object;
	lineGroupCode				: String;
	result						: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;

	create lShipPorts transient;
	create lLineGroupDebtors transient;
	create tmpSelectedPorts transient;
	create tmpSelectedDebtors transient;
	
	shippingLineCode := self.tblDetail.getValueByName(ETRow_ShippingLine).String;
	if shippingLineCode &lt;&gt; null then
		lShippingLine := app.myRoot.allShippingLines[shippingLineCode];
	endif;

	lCode := self.tblDetail.getValueByName(ETRow_Code).String;
	lDescription := self.tblDetail.getValueByName(ETRow_Description).String;
  	
	self.mulPorts.getSelected(tmpSelectedPorts);
	self.mulDebtors.getSelected(tmpSelectedDebtors);

	foreach tempObj in tmpSelectedPorts do
		create proxyShipPort transient;
		proxyShipPort.setProxy(tempObj.CM_Port);
		lShipPorts.add(proxyShipPort);
	endforeach;
	
	if self.myProxyShipPortGroup = null then
		if self.mode = self.Mode_Add then
			create self.myProxyShipPortGroup as CM_ShipPortGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	//get rid of theses here - want to create new proxies each time, not keep reusing the original ones
	self.myProxyShipPortGroup.lineGroupDebtors.purge();		//new proxies created below
	
	//use the ShipPortGroup code from the real here - if updated we still need to be able to get at the lgd
	if self.myCurrentShippingLine &lt;&gt; null
	and self.myCurrentShipPortGroup &lt;&gt; null then
		lineGroupCode := self.myCurrentShippingLine.code &amp; ' ' &amp; self.myCurrentShipPortGroup.code &amp; ' ';
	endif;
	
	foreach tempObj in tmpSelectedDebtors do
		lineGroupDebtor := null;
		if self.myCurrentShipPortGroup &lt;&gt; null then
			lineGroupDebtor := self.myCurrentShipPortGroup.lineGroupDebtors[lineGroupCode&amp;tempObj.CM_DebtorNode.name];
		endif;
		if lineGroupDebtor = null then
			//this is a new one
			create proxyLineGroupDebtor transient;
		else
			//new update proxies
			proxyLineGroupDebtor := app.createUpdateProxy(lineGroupDebtor).CM_LineGroupDebtor;
		endif;
		proxyLineGroupDebtor.setProxy(self.myCurrentShippingLine.code, lCode, tempObj.CM_DebtorNode);
		
		lLineGroupDebtors.add(proxyLineGroupDebtor);
	endforeach;
	
	proxyShipPortGroup := self.myProxyShipPortGroup;
	proxyShipPortGroup.setProxy(lCode, lDescription, lLineGroupDebtors, lShipPorts, lShippingLine);

	while true do	
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateShipPortGroup(proxyShipPortGroup, self.myCurrentShipPortGroup, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateShipPortGroup(proxyShipPortGroup, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.mode.String &amp; ')');
			return false;
		endif;
		
		if (not app.myPassport.trxCompletedOK) then
			result := app.showErrorWarningDialog(app.getErrorString(ShippingLinePortGroup), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			//we had a cancelled update - refresh data
			if self.myCurrentShipPortGroup &lt;&gt; null then
				delete self.myProxyShipPortGroup;
				self.myProxyShipPortGroup := app.createUpdateProxy(self.myCurrentShipPortGroup).CM_ShipPortGroup;
			endif;
			self.showThumbnail(self.myProxyShipPortGroup);
			return false;
		else
			self.clearErrorWarnings();
			self.tblDetail.setFocus();
			self.tblDetail.goToRowByName(ETRow_Code);
			self.clearProxyDetails();
	  		self.myProxyShipPortGroup := app.createUpdateProxy(self.myCurrentShipPortGroup).CM_ShipPortGroup;
	  		break;
		endif;
		break;
	endwhile;

epilog
  delete lShipPorts;
  delete lLineGroupDebtors;
  delete tmpSelectedDebtors;
  delete tmpSelectedDebtors;
  delete tmpSelectedPorts;		// PAR #27874
  app.mousePointer := MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="578e944d-f401-40cc-a55d-28207d1f4e91">
        <updating/>
        <source>init(_mode : Integer; pCurrentShippingLine : CM_ShippingLine; pCurrentShipPortGroup : CM_ShipPortGroup) updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
  
    if (pCurrentShippingLine = null) then
    	app.raiseUnexpectedProgramError(class.name, method.name ,' Current Shipping Line Is Null');
    	return;
    endif;
    self.mode := _mode;
    self.myCurrentShippingLine  := pCurrentShippingLine;
    self.myCurrentShipPortGroup := pCurrentShipPortGroup;
	if _mode = Mode_Update then
		btnNext.visible := false;
		if(pCurrentShipPortGroup = null) then
		    app.raiseUnexpectedProgramError(class.name, method.name ,'CurrentShippingLine');
		    return;
		endif;
  		self.myProxyShipPortGroup := app.createUpdateProxy(pCurrentShipPortGroup).CM_ShipPortGroup;
	else
		btnNext.visible :=true;
	endif;
	
	self.mulPorts.multiSelect := ListBox.MultiSelect_Extended;
	self.mulDebtors.multiSelect := ListBox.MultiSelect_Extended;
	
 end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="pCurrentShippingLine" type="CM_ShippingLine"/>
        <Parameter name="pCurrentShipPortGroup" type="CM_ShipPortGroup"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="36d428d0-f244-436d-939b-58457ab1c96e">
        <updating/>
        <source>initForm() updating;

vars
	entTableDef : EntTableDef;
	entTableRow		: EntTableRow;
begin
	entTableDef := app.myController.getEntTableDef(ETDef_ShipPortGroup);
	
	//21/12/2009 cnwdz2 Par22041
	entTableRow := entTableDef.allEntTableRows[entTableDef.getRowByName(ETRow_Description)];
	beginTransaction;
	entTableRow.myEntTableCellControl.EntTableTextBox.case := TextBox.Case_None;
	commitTransaction;
	
	self.tblDetail.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblDetail.disableRowByName(ETRow_ShippingLine);
	self.setColorsForEntryTable(tblDetail);
	self.initShtMultiSelect;
	self.showThumbnail(self.myProxyShipPortGroup);
	self.caption := self.myCurrentShippingLine.description &amp; ' ' &amp; self.caption;
	self.tblDetail.cnEcResizeContents();	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="a2e2e96b-128b-4bb3-9875-870a6a97af36">
        <source>initShtMultiSelect();

vars
	availableSet : ObjectArray;
	shipPortGroup : CM_ShipPortGroup;
	shipPort      : CM_ShipPort;
begin

    mulPorts.selectedHeading := app.getErrorString(Ports_Selected);
    mulPorts.availableHeading := app.getErrorString(Ports_Avail);
    mulPorts.cnEcResizeContents;
    mulPorts.formDisplayEntryMethodName :='displayEntryShipPort';
    create availableSet transient;
    //app.myRoot.allPorts.copy(availableSet);
    app.myRoot.allActivePorts.copy(availableSet);
    foreach shipPortGroup in self.myCurrentShippingLine.shipPortGroups do
    	if(shipPortGroup = self.myCurrentShipPortGroup) then
    		continue;
    	else
    		foreach	shipPort in shipPortGroup.shipPorts do
    			//cnwsh3 19/04/2006 - app.myRoot.allPorts is now app.myRoot.allActivePorts so check if the set includes the port
    			if availableSet.includes(shipPort.port) then
    				availableSet.remove(shipPort.port);
    			endif;
    		endforeach;
    	endif;
    endforeach;
    mulPorts.setAvailable(availableSet, true);
    delete availableSet; 
   
    mulDebtors.selectedHeading := app.getErrorString(Debtors_Selected);
    mulDebtors.availableHeading := app.getErrorString(Debtors_Available);
 	
	mulDebtors.cnEcResizeContents;
	mulDebtors.formDisplayEntryMethodName :='displayEntryLineGroupDebtor';
	mulDebtors.setAvailable(CM_Debtor.instances,true);
	
epilog
	delete availableSet;		// PAR #27874
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7577fea5-234b-4e2a-b79c-85c8a7c8077c">
        <updating/>
        <source>setupForm() updating;

vars

begin
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	inheritMethod();
	
	self.minimumHeight	:= 450;		// cnwrl1 23/06/2009 PAR 19998
	self.minimumWidth	:= 600;		// cnwrl1 23/06/2009 PAR 19998
	
	self.initForm;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mulDebtors.readOnly := true;
		self.mulPorts.readOnly := true;
		self.tblDetail.userInputEnabled:= false;
		self.btnCopyToTrade.enabled:= false;
		self.btnNext.enabled:= false;
		self.btnSaveBase.enabled:= false;
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7cb6e701-30f4-43f0-908f-646a334b0f72">
        <source>showThumbnail(pShipPortGroup : CM_ShipPortGroup);

vars
	tmpSet	: ObjectArray;
	tmpShipPort	: CM_ShipPort;
	tmpLineGroupDebtor : CM_LineGroupDebtor;
begin
	self.tblDetail.setValueByName(ETRow_ShippingLine, self.myCurrentShippingLine.code);
	if(pShipPortGroup = null) then
		self.tblDetail.setValueByName(ETRow_Code, null);
		self.tblDetail.setValueByName(ETRow_Description, null);
		mulPorts.setSelected(null);
		mulDebtors.setSelected(null);
	else
		self.tblDetail.setValueByName(ETRow_Code, pShipPortGroup.code);
		self.tblDetail.setValueByName(ETRow_Description, pShipPortGroup.description);
		create tmpSet  transient;
		foreach tmpShipPort in pShipPortGroup.shipPorts do
			if tmpShipPort.port &lt;&gt; null then
				tmpSet.add(tmpShipPort.port);
			endif;
		endforeach;
		mulPorts.setSelected(tmpSet);
        tmpSet.clear;
		foreach tmpLineGroupDebtor in pShipPortGroup.lineGroupDebtors do
			if tmpLineGroupDebtor.debtor &lt;&gt; null then
				tmpSet.add(tmpLineGroupDebtor.debtor);
			endif;
		endforeach;
		mulDebtors.setSelected(tmpSet);
		delete tmpSet;
	endif;

epilog
	delete tmpSet;		// PAR #27874
end;</source>
        <Parameter name="pShipPortGroup" type="CM_ShipPortGroup"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8146fa2a-c71c-4061-83a5-0488385e0e7b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007070, locale);
	btnCopyToTrade.translateCaption(Xlat_0011273, locale);
	btnNext.translateBubbleHelp(Xlat_0003942, locale);
	btnNext.translateCaption(Xlat_0003943, locale);
	grp1.translateCaption(Xlat_0003944, locale);
	grp2.translateCaption(Xlat_0003945, locale);
	lblHeading.translateCaption(Xlat_0003941, locale);
end;</source>
    </JadeMethod>
