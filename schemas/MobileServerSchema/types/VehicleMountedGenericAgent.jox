    <JadeMethod name="timerEvent" id="d2193bdd-9e35-4239-a0a0-cccd6fb4b8e5">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Date		Who		Reason
12 February 2014	cnwer1	Initial creation PAR 33494

*/

vars

begin
	if eventTag = RTQueueEntry_Available_Event and self.myMachine.allCurrentQueueTasks.size = null then
		self.doGetNextTask(null,false);
	endif;
epilog

end;</source>
