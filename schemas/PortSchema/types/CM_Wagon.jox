    <JadeMethod name="getReleaseCommodityCode" id="0fd891f7-6b3a-49fe-a3bb-fd752c738bae">
        <source>getReleaseCommodityCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2023	navmk20	Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info

*/

vars
	cont 					: CM_WagonController;
	wle 					: CM_WorkListEntry;
	myRequest				: CM_Request;
	myReserveDetail			: CM_ReserveDetail;
	data					: String;
	myCommodityCriteria		: String; 
	criteriaCodes : CM_StringArray;
	
begin 
	
	foreach cont in self.allLocationsControllers do 
		foreach wle in cont.CM_WagonController.allRailWLELoad do
			myRequest := wle.myRequest;
			if myRequest &lt;&gt; null then
				myReserveDetail :=  myRequest.myReserveDetail;
				
				if myReserveDetail &lt;&gt; null then 
					criteriaCodes := myReserveDetail.getMyCommodityCriteria();
					if criteriaCodes &lt;&gt; null then
						foreach myCommodityCriteria in criteriaCodes do
							/*
							if data.pos(myCommodityCriteria,1) = 0 then
								if data = null then
									data := myCommodityCriteria;
								else
									data := data &amp; ", " &amp; myCommodityCriteria;
								endif;
							endif; 
							*/
							
							data.addStringToList(myCommodityCriteria, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
						endforeach; 
					endif;
					delete criteriaCodes;
				endif;
			endif;
		endforeach;
	endforeach; 
	return data;
epilog
	delete criteriaCodes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
