    <JadeMethod name="getXMLSettingsForSave" id="a86399d2-3a10-4fb0-8ba3-ccf5d5374764">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// 10/03/2011	cnwcs5	CCMS CPL 2017/PAR 27126
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true) &amp;
	          self.tblInfo.getXmlStrForColumns(true) &amp;
			  global.formatAsXML(XML_HM, self.isHideMacro.Integer.String);
	
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
