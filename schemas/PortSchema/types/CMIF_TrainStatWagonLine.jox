    <JadeMethod name="addWagon" id="2b33b0a1-a553-4321-827f-dcd48b044ad2">
        <updating/>
        <source>addWagon(	_inward : Boolean;
			_tareWeight : Decimal ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if _inward then
		self.numWagonsIn := self.numWagonsIn + 1;
		self.tareWeightIn := self.tareWeightIn + _tareWeight; 
	else
		self.numWagonsOut := self.numWagonsOut + 1;
		self.tareWeightOut := self.tareWeightOut + _tareWeight; 
	endif;
	
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_tareWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLineStrings" id="3c57566a-a799-46be-bf9b-c4b7ba9fdd1a">
        <source>getLineStrings(	_wagonClass : String output;	
				_numWagonsIn : String output;
				_totTareWeightIn : String output;
				_numWagonsOut : String output;
				_totTareWeightOut : String output;
				_useSeperator : Boolean
				);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	
begin
	
	_wagonClass := wagonClass;
	_numWagonsIn := self.numWagonsIn.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTareWeightIn := self.tareWeightIn.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_numWagonsOut := self.numWagonsOut.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTareWeightOut := self.tareWeightOut.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	
epilog

end;</source>
        <Parameter name="_wagonClass" type="String" usage="output"/>
        <Parameter name="_numWagonsIn" type="String" usage="output"/>
        <Parameter name="_totTareWeightIn" type="String" usage="output"/>
        <Parameter name="_numWagonsOut" type="String" usage="output"/>
        <Parameter name="_totTareWeightOut" type="String" usage="output"/>
        <Parameter name="_useSeperator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseDetails" id="e6595a43-5314-43e3-8064-cfc1b21ca0da">
        <updating/>
        <source>setBaseDetails(	_wagonClass : String;
				_myCMIF_TrainStatCargoLineTot : CMIF_TrainStatTotalsObject
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	self.wagonClass := _wagonClass;
	self.myCMIF_TrainStatTotalsObject := _myCMIF_TrainStatCargoLineTot;
	
epilog

end;</source>
        <Parameter name="_wagonClass" type="String"/>
        <Parameter name="_myCMIF_TrainStatCargoLineTot" type="CMIF_TrainStatTotalsObject"/>
    </JadeMethod>
</Class>
