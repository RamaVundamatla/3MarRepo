    </JadeMethod>
    <JadeMethod name="doAdd" id="e42574cb-868b-470f-8035-b121592aceac">
        <updating/>
        <source>doAdd() updating, protected;
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars

begin

 
	self.myAssistant.showInvoiceCargoAllocMapping(self.myInvoiceAlllocation, null,  self.myInvoiceAlllocation.class); // ### TFS 51219 25MAY2021 NAVAB1

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddSub" id="5a4f43e4-53db-41c8-8de3-a0a84eb655da">
        <updating/>
        <source>doAddSub() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/01/2025	navkc1 JIRA Sub-task MTN-19517: MTN | Jade Sub quantity Range Invoice Cargo Allocations

*/

vars
	qrm		  : CM_QuantityRangeMap;
	parentMap : CM_QuantityMap;
	
begin
	
	qrm := self.myQuantityRangeMap;
	
	if qrm &lt;&gt; null then
		parentMap := qrm.myChildQuantityMap;
	endif;
	
	self.myAssistant.showCargoAllocSubMap(parentMap, qrm, null, true);
	
	self.cmbGroup_click(self.cmbGroup);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="0a31b56b-9517-4c26-a4ba-b53baf9a3f9b">
        <updating/>
        <source>doEdit() updating, protected;
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	qrm		: CM_QuantityRangeMap;
begin
	
	qrm := self.myQuantityRangeMap; //09/01/2025	navkc1 JIRA Sub-task MTN-19517
	
	if qrm = null then
		return;
	endif;
	
	//09/01/2025	navkc1 JIRA Sub-task MTN-19517
	if qrm.isSubRange() then
		self.myAssistant.showCargoAllocSubMap(qrm.myQuantityMap, qrm, qrm, true);
	else
		self.myAssistant.showInvoiceCargoAllocMapping(self.myInvoiceAlllocation, self.myQuantityRangeMap, self.myInvoiceAlllocation.class); // ### TFS 51219 25MAY2021 NAVAB1
	endif;
	
	self.cmbGroup_click(self.cmbGroup);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNoMaintPermDisableControls" id="e99c7edf-9f35-4420-adbc-ab9f76ad2a91">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.btnAdd.enabled := false;
	self.btnDelete.enabled := false;
	self.cmbGroup.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblRowColumnChg" id="52d50895-d64b-425f-99cd-58b109264dd7">
        <updating/>
        <source>doTblRowColumnChg() updating, protected;
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	table	: CM_DataTable;
	qrm : CM_QuantityRangeMap;
begin
	table := self.tblGroups;
	if table.row &gt; table.fixedRows then
		qrm := table.accessRow(table.row).itemObject.CM_QuantityRangeMap;
		
		if qrm &lt;&gt; null then	//04 Dec 2010	NDL:	TFS 50467
			//self.myInvoiceAlllocation := qrm.myQuantityMap.myInvoiceAllocation.CM_InvoiceAllocation;
			self.myInvoiceAlllocation := qrm.getInvoiceAllocation(); //09/01/2025	navkc1 JIRA Sub-task MTN-19517
		endif;
		self.myQuantityRangeMap := qrm;
		
	endif;
	
	//19 Dec 2017	NDL	TFS 8095
	self.btnAudits.enabled := self.myQuantityRangeMap &lt;&gt; null and self.myQuantityRangeMap.hasAudits;	//14 Jan 2021	NDL	TFS 50152
	
	//09/01/2025	navkc1 JIRA Sub-task MTN-19517
	self.btnAddSub.enabled := self.myQuantityRangeMap &lt;&gt; null and not self.myQuantityRangeMap.isSubRange();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
