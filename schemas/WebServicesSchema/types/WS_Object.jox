    <JadeMethod name="setFromXMLElement" id="909c5680-e7f9-4481-b9ff-94400a336acd">
        <updating/>
        <source>setFromXMLElement( _element : JadeXMLElement ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	tagName : String;
	data : String;
	property : Property;

begin

	tagName := _element.tagName;
	data := _element.textData.trimCharacters(CrLf).trimBlanks;

	if data.trimBlanks &lt;&gt; null then
		property := self.class.getPropertyInHTree( tagName );
		if property &lt;&gt; null then
			if property.type = Boolean then
				self.setPropertyValue( tagName, data.Boolean );
			elseif property.type = Character then
				self.setPropertyValue(tagName, data.Character);
			elseif property.type = Date then
				self.setPropertyValue(tagName, data.Date);
			elseif property.type = Decimal then
				self.setPropertyValue(tagName, data.Decimal);
			elseif property.type = Integer then
				self.setPropertyValue(tagName, data.Integer);
			elseif property.type = Point then
				self.setPropertyValue(tagName, data.Point);
			elseif property.type = Real then
				self.setPropertyValue(tagName, data.Real);
			elseif property.type = Time then
				self.setPropertyValue(tagName, data.Time);
			elseif property.type = TimeStamp then
				self.setPropertyValue(tagName, data.TimeStamp);
			elseif property.type = Binary then
				self.setPropertyValue(tagName, data.Binary);
			else
			//	write self.class.name &amp; "::" &amp; tagName;
				self.setPropertyValue( tagName, data );
			endif;
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_element" type="JadeXMLElement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
