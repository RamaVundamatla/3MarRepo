    <JadeMethod name="handleListBoxClick" id="e042a90e-51c8-4132-a984-c742d0b7b3d8">
        <source>handleListBoxClick(_listBox: CM_MultiSelectListBox);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _listBox = self.mySelectedListBox then
		inheritMethod(_listBox);
	endif;

end;</source>
        <Parameter name="_listBox" type="CM_MultiSelectListBox"/>
    </JadeMethod>
