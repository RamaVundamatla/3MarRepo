    <JadeMethod name="hideShowMenu" id="39fa03d8-0d5c-4ee6-91bf-de49862cc60a">
        <updating/>
        <source>hideShowMenu(_hide : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwer1	Initial creation

*/

vars

begin

	self.frmMenuBtm.visible:=not _hide;
	
	if _hide then
		self.moveMdiClient(0,0,self.clientWidth,self.clientHeight);
		self.activeChild.move(self.left , self.top ,self.clientWidth,self.clientHeight);	
		
	else
		self.moveMdiClient(frmMenuBtm.width,0,self.clientWidth-frmMenuBtm.width,self.clientHeight);
		self.activeChild.move(frmMenuBtm.width , self.top ,self.clientWidth-frmMenuBtm.width,self.clientHeight);	
		
	endif;
	
	
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="organiseButtons" id="8052b68b-058b-42e3-bc58-7f689905058b">
        <source>organiseButtons() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation
06 Nov 2012 cnwer1	PAR 30678 CCMS HAT 2200
*/
constants
	Margin = 5;
	MinButonHeight = 35;
	MinButtonWidth = 150;
	ButtonMargin = 30;
vars
	allButtons : ObjectArray;
	bottomButton,
	rightButton  : Button;
	buttonObj	: Object;
	row,col, i : Integer;
	buttonHeight,
	buttonWidth  : Integer;
	maxScroll : Integer;
begin
	self.resizeBottomButtons();
	create allButtons transient;
	
	buttonHeight:=self.btnEnquiry.getTextHeight(self.btnEnquiry.caption);
	buttonHeight:= buttonHeight + (Margin *2);
	buttonHeight:=buttonHeight.max(MinButonHeight);
	
	buttonWidth:= self.btnEnquiry.getTextExtent(self.btnEnquiry.caption);
	buttonWidth:=buttonWidth + (self.btnEnquiry.getTextExtent("W") *2);
	buttonWidth:=buttonWidth.max(MinButtonWidth);
	
	
	if app.myVMAgent.getMyRTVehicleConfig.allowCargoSearch and not app.isWarehouseVMTApp then
		self.btnEnquiry.visible:=true;
		allButtons.add(self.btnEnquiry);
	endif;
	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHMaintainTasks) then
		allButtons.add(self.btnToDoTask);
		self.btnToDoTask.visible:=true;
	endif;
	
	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHDamageReport) then
		allButtons.add(self.btnDamage);
		self.btnDamage.visible:=true;
	endif;
	
	//epr par 25049 15/7/10
	if app.myCurrentUserCan(app.myVMAgent.myTerminal, PmHHGrading) then
		allButtons.add(self.btnGrading);
		self.btnGrading.visible:=true;
	endif;
	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHMaintainStops) then
		allButtons.add(self.btnStops);
		self.btnStops.visible:=true;
	endif;
	
//	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHMaintainSeals) then
//		allButtons.add(self.btnSeals);
//		self.btnSeals.visible:=true;
//	endif;
	
	if app.myCurrentUserCan(app.myVMAgent.myTerminal, PmRTSelectorQueries) and
		app.myVMAgent.getMyRTVehicleConfig.myQueriesForDrivers &lt;&gt; null then
		allButtons.add(self.btnReports);
		self.btnReports.visible:=true;
	endif;	
	
	if allButtons.isEmpty then
		return;
	endif;
	
	
	row:=1;
	col:=1;
	foreach buttonObj in allButtons do
		if col = 1 then
			buttonObj.Button.left:=ButtonMargin;
		else
			buttonObj.Button.left:=buttonWidth  + (ButtonMargin * 2);
		endif;
		buttonObj.Button.width:=buttonWidth;
		buttonObj.Button.height:=buttonHeight;
		buttonObj.Button.top:=((row-1) * buttonHeight) + (row * 5);//10 *row) + 
		
		i:=i+1;
		//add to a second column
		if self.width &gt;= ((buttonWidth * 2) + (ButtonMargin*3)) and i = 4 then
			row:=1;
			col:=2;
			bottomButton:=buttonObj.Button;
		else
			row:=row+1;
			bottomButton:=buttonObj.Button;
		endif;
		rightButton:=buttonObj.Button;
	endforeach;	
	
	//epr par 25494 19/8/10

	self.picBody.scrollBars:=Picture.ScrollBars_Both;
	self.picBody.setScrollRange(ScrollBar_Vertical, 0,((bottomButton.top + bottomButton.clientHeight).Integer -self.frmMenuBdy.clientHeight).max(0), 20, 100);
	self.picBody.setScrollRange(ScrollBar_Horizontal, 0,((rightButton.left + rightButton.clientWidth).Integer -self.frmMenuBdy.clientWidth).max(0), 20, 100);
	
epilog
	delete allButtons;
end;
</source>
        <access>protected</access>
    </JadeMethod>
