        <source>utlUpdateTermDrPaymentType(_drTerm : CM_DebtorTerminal input; _paymentType: Integer; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2018	jlgmp6	Initial creation	TFS37731

*/


vars

begin

