    <JadeWebServicesMethod name="getOperators" id="5d1a8539-949f-467b-a0ed-7b1a45628496">
        <usesRPC>default</usesRPC>
        <source>getOperators(operatorsRequest : WS_OperatorsRequest) : WS_OperatorsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23/07/2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
11/10/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operators in Web Portal
02/02/2022  navma1	Bug 52648: SAL - Operator Data Access (Cargo / Permit Request)
*/


vars
	response			: WS_OperatorsResponse;
	completedOK			: Boolean;
	vessel 				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	proxyOperator		: WS_Operator;
	operatorColl		: CM_OperatorByCodeDict;
	failedDAC			: CM_DataAccessController;
	passport			: CM_Passport;
	ignoreDataAccess	: Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	//02.02.2022 navma1 # 52648
	if operatorsRequest.operatorProcess = WS_OperatorsRequest.CONTEXT_IGNORE_DATA_ACCESS then	
		ignoreDataAccess := true;
	endif;
	
	// Validate response - cloned from CMUI_ComboOperatorByVoyage
	if operatorsRequest.voyageCode &lt;&gt; null then
		//epr Tfs 38213 23/4/18
		voyage := passport.myTerminal.allVoyagesNew.getAtKeyGeq(operatorsRequest.voyageCode, null);
		if voyage.code &lt;&gt; operatorsRequest.voyageCode then
			voyage :=null;
		endif;
		if voyage = null then
			voyage := app.myPassport.getObjectOfTypeFromOid(operatorsRequest.voyageCode,CM_Voyage).CM_Voyage;
		endif;
	else
		//epr TFS 37331 web portal pelindo changes
		if operatorsRequest.vessel &lt;&gt; null then
			vessel:=app.myRoot.allVessels[operatorsRequest.vessel];
			if vessel = null then
				vessel:=app.myPassport.getObjectOfTypeFromOid(operatorsRequest.vessel,CM_Vessel).CM_Vessel;
			endif;
			
			if vessel = null then
				completedOK:=true;
				return response;
			endif;
		endif;
	endif;			

	// Get the appropriate Operator collection
	if voyage &lt;&gt; null and not voyage.isNullVoyage() then
		if operatorsRequest.operatorProcess &lt;&gt; null then				// TFS 41305
			operatorColl := app.myRoot.allOperators;					// TFS 41305
		else															// TFS 41305
			operatorColl := voyage.allOperators;
		endif;															// TFS 41305
	elseif vessel &lt;&gt; null and vessel.myDefaultTrade &lt;&gt; null and vessel.myDefaultTrade.operators.size &gt; 0 then  //epr tfs 39113 8/6/18
		operatorColl := vessel.myDefaultTrade.operators;
	else
		operatorColl := app.myRoot.allOperators;	
	endif;
	
	// Populate the response
	foreach operator in operatorColl discreteLock do
		if operator.isNotAvailableForEntry then
			continue;
		endif;
		
		// TFS 41305 if we want all operators, ignore data access check
		//02.02.2022 navma1 # 52648
		if not ignoreDataAccess then
			if  not operator.canUserAccessSelf(null, failedDAC, passport) then	// TFS 41305
				continue;
			endif;
		endif;
		
		if vessel &lt;&gt; null and  operator.isKindOf(CM_NullOperator) then
			continue;
		endif;
		
		create proxyOperator transient;
		proxyOperator.setProxyFromObject(operator);
		response.allOperators.add(proxyOperator);
	endforeach;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getOperators</wsdlName>
        <Parameter name="operatorsRequest" type="WS_OperatorsRequest"/>
        <ReturnType type="WS_OperatorsResponse"/>
    </JadeWebServicesMethod>
