    <JadeMethod name="isObjectRelevant" id="c25a5e08-bc2d-4747-94bc-57ba700ee82f">
        <source>isObjectRelevant(_obj: Object): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Nov 2023 navhl20 Bug 61460: MTN - Instruction Type defined at terminal level is also applied to all the other terminals.

*/

vars

begin
	if inheritMethod(_obj) then
		if _obj.CM_DamageReason.myTerminal = self.myForm.myTerminal then
			return true;
		endif;	
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
