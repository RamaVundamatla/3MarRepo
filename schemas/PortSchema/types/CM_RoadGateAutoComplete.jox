    <JadeMethod name="getDisplayStringForAttribute" id="3aee5eef-1649-4e15-bc33-bb26bf4de3f5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	jlier1	Initial creation 64018

*/

vars

begin
	if _attrName = ETRow_Type then
		if self.isRelease then
			return app.getErrorString(Release);
		else
			return app.getErrorString(Receive);
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="da842636-bd77-4d2e-b92d-58a3e4ee89e1">
        <source>getTableDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars

begin
	return self.getCriteriaSummary(", ");	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matches" id="6fd53270-056e-4da4-b3c9-f87541f9f803">
        <source>matches(_ti: CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	criteria : CM_YACriteria;

begin

	if _ti = null then
		return false;
	endif;
	
	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isStorageDetailMatch(_ti,null) then
			return false; // if any criterion is unmatched, result is no match
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="67b7e036-1227-452f-9feb-19d601fa122f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  
*/

vars
	criteria : CM_RoadGateAutoComplete;
	completedOK : Boolean;
begin
	criteria := inheritMethod();
	criteria.setBaseData(self.description, self.name, self.myTerminal,self.isRelease);
	completedOK := true;
	
	return criteria;

epilog

	if not completedOK then
		delete criteria;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="82bf7f94-4f46-45a0-a3d2-5b9b48ce44eb">
        <updating/>
        <source>setBaseData(_description, _name : String; _myTerminal : CM_Terminal; _isRelease : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  
*/

vars

begin
	self.description := _description;
	self.name := _name;	
	self.isRelease:=_isRelease;
	self.myTerminal := _myTerminal;
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_isRelease" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cc6988fd-891f-4d9f-9fb8-d94a3d59bd77">
        <updating/>
        <source>setForUpdate(_proxy: CM_RoadGateAutoComplete) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  
*/

vars

begin
	inheritMethod(_proxy);
	self.setBaseData(_proxy.description,
					 _proxy.name,
					 _proxy.myTerminal,
					 _proxy.isRelease);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RoadGateAutoComplete"/>
    </JadeMethod>
</Class>
