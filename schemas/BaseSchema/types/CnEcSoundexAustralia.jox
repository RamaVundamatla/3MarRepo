    <DbClassMap file="basedvpr"/>
    <JadeMethod name="doSoundexConversion" id="c4f71adc-8b95-4260-9d2b-6191593e77d7">
        <source>doSoundexConversion(pMaxLength: Integer): String protected;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 26/05/1999	grp			Rule 1 below  :: if the last character is an 'S'and if
//							the preceding character  : is NOT an 'I', 'D' or 'U'
//							then drop the 'S' - however if the 'S' is the only
//							character then it gets dropped also - causing "index
//							used in substring is out of bounds" error.  Have coded
//							around the error.
// --------------------------------------------------------------------------------
vars
	resultString	: String;
	nameLength		: Integer;
	charPos			: Integer;
	charCount		: Integer;
	lastChar		: String[1];
	tempWork		: String[1];
	tempWork1		: String[1];
	tempWork2		: String[2];
	tempWork3		: String[3];
	tempWork4		: String[4];
	tempWork5		: String[4];
	nameString		: String[24];
	nameOut			: String[24];
	
begin
//  : ABOR-PHONETIC
//  :
//  : Used to encrypt an Aboriginal Name into an phonetic code
//  :
//  :---------------------------------------------------------------------

	nameString	:=	self.inputString.padBlanks(16);

//  :
//  : Clean up
//  : Remove double characters ie (OO)
//  :

	charCount	:=	1;
	nameLength	:=	0;
	tempWork	:=	"";

	while true do :loop_1
		tempWork1	:=	nameString.padBlanks(24)[charCount:1];
		tempWork1	:=	tempWork1.trimRight;

		if tempWork1 = "" then
			break loop_1;
		endif;

		if tempWork1 &lt;&gt; tempWork then
			nameOut		:=	(nameOut &amp; tempWork1)[1:24];
			tempWork	:=	tempWork1;
			nameLength	:=	nameLength + 1;
		endif;

		charCount	:=	charCount + 1;
	endwhile loop_1;


	nameString	:=	nameOut;
	nameOut		:=	"";

//  : Rule 1
//  : Check if the last character is an 'S'. If the preceding character
//  : is NOT an 'I', 'D' or 'U' then drop the 'S'
//  :

	tempWork	:=	nameString.padBlanks(24)[nameLength:1];
	tempWork	:=	tempWork.trimRight;

	if tempWork = "S" then
		charPos	:=	nameLength;
		
		if charPos &gt; 1 then		//grp TIR 978	26/5/1999
			charPos	:=	charPos - 1;
		endif;					//grp TIR 978	26/5/1999	
		
		tempWork	:=	nameString.padBlanks(24)[charPos:1];
		tempWork	:=	tempWork.trimRight;

		if tempWork &lt;&gt; "I"
		and tempWork &lt;&gt; "O"
		and tempWork &lt;&gt; "U"
		then
			nameString[nameLength:(24 + 1 - nameLength)]	:=	"";
			nameString	:=	nameString.trimRight;
		endif;
	endif;

//  :
//  : Rule 2
//  : Check the first two characters to see if we can convert them
//  : into a special value.

	tempWork2	:=	nameString.padBlanks(24)[1:2];
	tempWork2	:=	tempWork2.trimRight;
	charPos		:=	0;
	tempWork	:=	"";

	if tempWork2 = "CE"
	or tempWork2 = "CI"
	or tempWork2 = "CY"
	or tempWork2 = "PS"
	or tempWork2 = "TS" then
		tempWork	:=	"S";
		
	elseif tempWork2 = "DF"
	or tempWork2 = "PF"
	or tempWork2 = "PH" then
		tempWork	:=	"F";
		
	elseif tempWork2 = "DG" then
		tempWork	:=	"G";
		
	elseif tempWork2 = "DJ"
	or tempWork2 = "NJ"
	or tempWork2 = "TJ" then
		tempWork	:=	"J";
		
	elseif tempWork2 = "GF" then
		tempWork	:=	"F";
		
	elseif tempWork2 = "GM"
	or tempWork2 = "LM"
	or tempWork2 = "MB"
	or tempWork2 = "MP" then
		tempWork	:=	"M";
		
	elseif tempWork2 = "GN"
	or tempWork2 = "KN"
	or tempWork2 = "NG"
	or tempWork2 = "PN" then
		tempWork	:=	"N";
		
	elseif tempWork2 = "TZ" then
		tempWork	:=	"Z";
		
	elseif tempWork2 = "WR" then
		tempWork	:=	"R";
		
	endif;

	if tempWork &lt;&gt; "" then
		nameOut	:=	tempWork;
		charPos	:=	3;
	endif;

//  :
//  : Rule 3
//  : If you have not done the prefix try one of these
//  : 'K'    'AH'    'STAN'   'STON'
//  : 'C'    'AR'    'SAN'    'SON'

	if tempWork = "" then
		tempWork1	:=	nameString.padBlanks(24)[1:1];
		tempWork1	:=	tempWork1.trimRight;
		tempWork4	:=	nameString.padBlanks(24)[1:4];
		tempWork4	:=	tempWork4.trimRight;

		if tempWork1 = "K" then
			nameOut	:=	"C";
			charPos	:=	2;
		endif;

		if tempWork2 = "AH" and nameOut = "" then
			nameOut	:=	"AR";
			charPos	:=	3;
		endif;

		if tempWork4 = "STAN" and nameOut = "" then
			nameOut	:=	"SAN";
			charPos	:=	5;
		endif;

		if tempWork4 = "STON" and nameOut = "" then
			nameOut	:=	"SON";
			charPos	:=	5;
		endif;
	endif;

	if (charPos &lt; nameLength or charPos = nameLength) then
		if charPos = 0 then
			charPos	:=	1;
		endif;

		charCount	:=	charPos;

		while true do :loop_2

			if charPos &gt; nameLength then
				break loop_2;
			endif;

			tempWork1	:=	nameString.padBlanks(24)[charPos:1];
			tempWork1	:=	tempWork1.trimRight;
			tempWork2	:=	nameString.padBlanks(24)[charPos:2];
			tempWork2	:=	tempWork2.trimRight;
			tempWork3	:=	nameString.padBlanks(24)[charPos:3];
			tempWork3	:=	tempWork3.trimRight;
			tempWork4	:=	nameString.padBlanks(24)[charPos:4];
			tempWork4	:=	tempWork4.trimRight;
			tempWork5	:=	"";

			if tempWork4 = "AUGH" then
				tempWork5	:=	"R";
				charPos		:=	charPos + 4;
			endif;

			if tempWork4 = "STON" then
				tempWork5	:=	"SON";
				charPos		:=	charPos + 4;
			endif;

			if tempWork4 = "STAN" then
				tempWork5	:=	"SAN";
				charPos		:=	charPos + 4;
			endif;

			if tempWork5 = "" then
				if tempWork3 = "GHT" then
					tempWork5	:=	"T";
					charPos		:=	charPos + 3;
				endif;

				if tempWork3 = "NDJ" then
					tempWork5	:=	"J";
					charPos		:=	charPos + 3;
				endif;
			endif;

			if tempWork5 = "" then
				if tempWork2 = "AW" then
					tempWork5	:=	"R";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "DF" or tempWork2 = "PH" then
					tempWork5	:=	"F";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "DG" then
					tempWork5	:=	"G";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "DJ" or tempWork2 = "NJ" or tempWork2 = "TJ" then
					tempWork5	:=	"J";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "DS" or tempWork2 = "TS" then
					tempWork5	:=	"S";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "GH" then
					tempWork5	:=	"H";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "HT" then
					tempWork5	:=	"T";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "LM" or tempWork2 = "MP" or tempWork2 = "MB" then
					tempWork5	:=	"M";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "ND" or tempWork2 = "NG" then
					tempWork5	:=	"N";
					charPos		:=	charPos + 2;
					
				elseif tempWork2 = "TZ" then
					tempWork5	:=	"Z";
					charPos		:=	charPos + 2;
					
				else
					tempWork5	:=	tempWork1;
					charPos		:=	charPos + 1;
					
				endif;
			endif;

			nameOut	:=	(nameOut &amp; tempWork5)[1:24];

		endwhile loop_2; // :BEGIN.LOOP

	endif;

//  :
//  :So by now we should have an SD-OUT that has been Filtered
//  :
//  :
//  :Next Rule
//  :Convert to a code. ANNNNNNNNNN etc
//  :Do not allow duplication of numbers. ie (99) should be (9)
//  :

	resultString	:=	"";
	charPos			:=	1;

	while true do :loop_3
		tempWork1	:=	"";
		tempWork	:=	nameOut.padBlanks(24)[charPos:1];
		tempWork	:=	tempWork.trimRight;

		if tempWork = "" then
			break loop_3;
		endif;

		if tempWork = "A"
		or tempWork = "E"
		or tempWork = "I"
		or tempWork = "O"
		or tempWork = "U"
		or tempWork = "W"
		or tempWork = "H"
		or tempWork = "Y" then
			tempWork1	:=	"";
			
		elseif tempWork = "B"
		or tempWork = "F"
		or tempWork = "V"
		or tempWork = "P" then
			tempWork1	:=	"1";
			
		elseif tempWork = "C"
		or tempWork = "G"
		or tempWork = "J"
		or tempWork = "K"
		or tempWork = "Q"
		or tempWork = "S"
		or tempWork = "X"
		or tempWork = "Z" then
			tempWork1	:=	"2";
			
		elseif tempWork = "D"
		or tempWork = "T" then
			tempWork1	:=	"3";
			
		elseif tempWork = "L" then
			tempWork1	:=	"4";
			
		elseif tempWork = "M"
		or tempWork = "N" then
			tempWork1	:=	"5";
			
		else
			tempWork1	:=	"6";
			
		endif;

		if charPos = 1 then
			resultString	:=	tempWork;
			lastChar		:=	tempWork1;
		endif;

		if tempWork1 &lt;&gt; "" and
		   tempWork1 &lt;&gt; lastChar then
			resultString	:=	(resultString &amp; tempWork1)[1:16];
			lastChar		:=	tempWork1;
		endif;

		charPos	:=	charPos + 1;
	endwhile loop_3;

	return resultString;
end;</source>
        <access>protected</access>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransform" id="49d3e5eb-eb10-4af5-92ef-bbb4ba63a9e9">
        <source>getTransform(pMaxLength: Integer): String;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad2
//
// Purpose:		Transforms an indigenous Australian string value into a soundex
//				value, and returns the result.
//
// Parameters:	pMaxLength - This parameter is ignored.
//
// Returns:		The soundex code of the receiver's string value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.doSoundexConversion(0);
end;</source>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
