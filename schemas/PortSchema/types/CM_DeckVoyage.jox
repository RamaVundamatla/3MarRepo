    <JadeMethod name="getTotalColourCode" id="6d9f9ac2-c097-44c7-9df3-37a75276d8de">
        <source>getTotalColourCode(_getLoad: Boolean; _includeDLR: Boolean; _checkJob: Boolean): Integer;
/*
Purpose:			
Date		Who		Reason
13 January 2015	cnwab1	Initial creation
*/

vars
	roroLC : CM_VoyageROROController;
	numCC : Integer;
	req : CM_RORORequest;
begin
	foreach roroLC in self.allROROControllers discreteLock do
		if _getLoad then
			req := roroLC.myRORORequestLoad;
		else
			req := roroLC.myRORORequestDischarge;
		endif;
		
		if not _includeDLR then
			if req.moveType = DLR_MOVETYPE then
				continue;
			endif;
		endif;
		
		if req &lt;&gt; null then
			if _checkJob then
				if req.myJob &lt;&gt; null then
					numCC := numCC + req.quantity.Integer;
				endif;
			else
				numCC := numCC + req.quantity.Integer;
		
			endif;
		endif;
	endforeach;
	
	return numCC;
epilog

end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <Parameter name="_checkJob" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalPlanned" id="e5f5ae20-c27b-490a-b68a-f04d26325bfd">
        <source>getTotalPlanned(_getLoad: Boolean; _includeDLR: Boolean): Integer;
/*
Purpose:			
Date		Who		Reason
13 January 2015	cnwab1	Initial creation
*/

vars
	roroLC : CM_VoyageROROController;
	numCC, numPlanned : Integer;
	req : CM_RORORequest;
begin
	foreach roroLC in self.allROROControllers discreteLock do
		if _getLoad then
			req := roroLC.myRORORequestLoad;
		else
			req := roroLC.myRORORequestDischarge;
		endif;
		
		if not _includeDLR then
			if req.moveType = DLR_MOVETYPE then
				continue;
			endif;
		endif;
		
		if req &lt;&gt; null then
			numPlanned := req.getNumTIsOfMode(PLANNING_MODE,false);
			numCC := numCC + numPlanned;
		endif;
	endforeach;
	
	return numCC;
epilog
end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
