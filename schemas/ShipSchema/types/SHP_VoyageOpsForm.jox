    <JadeMethod name="doMnuUnplanClick" id="01e27859-16be-4547-8614-0677eb77a701">
        <updating/>
        <source>doMnuUnplanClick(_menuItem : MenuItem input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	if _menuItem.helpKeyword = self.UnplanMenu_TypeMain then
		return;
	endif;
	if _menuItem.helpKeyword = self.UnplanMenu_TypeRehandle then
		 return;
	endif;

	if _menuItem.userObject.isKindOf(CM_TrackedItem) then
		if _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 		
			self.doUnqueueTI(_menuItem.userObject.CM_TrackedItem);
		else
			self.doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = "LOAD"));
		endif;
	elseif _menuItem.userObject.isKindOf(CM_FutureMove) then
		self.doUnqueueTIbyFM(_menuItem.userObject.CM_FutureMove);
	endif;
epilog

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMove_Unplan" id="e24d5636-005d-4406-b923-aeea0fc6cb87">
        <updating/>
        <source>doMove_Unplan(_all : Boolean; _table : CM_DataTable) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 10 December 2025	jlier1	JIRA# 36738
vars
	result	: Integer;
	tiSet	: CM_TISet;
	ti 		: CM_TrackedItem;
begin
	app.mousePointer := MousePointer_HourGlass;	
	create tiSet transient;
	
	if _all then
		self.getAllTIsInCurrentTable(_table, tiSet);
	else
		self.getCurrentlySelectedTIs(tiSet);
	endif;
	
	//jlier1 14/1/26 JIRA-36877 - don't unplan rrp cargo because it deletes the wle 
	foreach ti in tiSet do
		if ti.isRRPforVoyage then
			tiSet.remove(ti);
		endif;	
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateMoveTIsUndoForMode(tiSet, PLANNING_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	delete tiSet;
	app.mousePointer := MousePointer_Default;		
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doMove_Unqueue" id="79da28ae-2911-43f5-a9d7-961599ffc8cc">
        <updating/>
        <source>doMove_Unqueue(_all : Boolean; _table : CM_DataTable) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 10 December 2025	jlier1	JIRA# 36738
vars
	tiSet				: CM_TISet;
	result				: Integer;
	rrpWles , wlesWithWarnings			: CM_WLEArray;
begin
	app.mousePointer := MousePointer_HourGlass;	
	create tiSet transient;
	
	if _all then
		self.getAllTIsInCurrentTable(_table, tiSet);
	else
		self.getCurrentlySelectedTIs(tiSet);
	endif;

	create rrpWles transient;
	create wlesWithWarnings transient;
	if _table = self.tblOnsite then

		self.getRRPWles(tiSet,rrpWles,QUEUE_MODE);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateMoveTIsUndoForMode(tiSet, QUEUE_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

	if not rrpWles.isEmpty then
		while true do
			app.myTrxUA.trxUpdateWLEsUnqueue(rrpWles, wlesWithWarnings, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					
					// only reprocess the wles that had warnings.
					rrpWles.clear;
					wlesWithWarnings.copy(rrpWles);
					wlesWithWarnings.clear;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
	
epilog 
	app.mousePointer := MousePointer_Default;	
	delete tiSet;
	delete rrpWles;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="199f2713-9ba8-4aec-b35a-28cebc921642">
        <source>doNotableAdd(_ti : CM_TrackedItem);
//--------------------------------------------------
// Created:	28 June 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _ti = null then
		return;
	endif;
	
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	
	// 30 Jun 2010	NDL Par24602
	if (not self.allDisplayedTIs.includes(_ti)) then
		self.allDisplayedTIs.add(_ti);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="c32165d3-8fad-4e68-81be-2edb4a8be1f9">
        <updating/>
        <source>doNotableClear() updating;
//--------------------------------------------------
// Created:	28 June 2004 By: cnwgd1
//--------------------------------------------------
vars
	ti : CM_TrackedItem;
begin

	// 30 Jun 2010	NDL Par24602
	if self.listeningForClassNotes then
		self.listeningForClassNotes := false;
		self.endClassNotification( CM_TrackedItem, false, Any_System_Event );
	endif;
	self.allDisplayedTIs.clear;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doNoteForCurrentViewTI" id="b112a751-33d8-4a77-859b-437d63170c29">
        <updating/>
        <source>doNoteForCurrentViewTI( _ti : CM_TrackedItem io; _add : Boolean; _update : Boolean; _remove : Boolean )updating;
/*

Purpose:			

Parameters:			This version only applies when we are in hybrid mode or ECO just updating the 
					visible parts of the tables.

Return Value:		

Date			Who		Reason
15 March 2021	navndl1	Initial creation	TFS 50935
08 Nov	 2022	navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 Nov 2022		navmd1	TFS 55379 Refactor VoyageOpsCG Form

*/

vars

	isOnship : Boolean;
	isOnsite : Boolean; 
	isOffSite : Boolean;
	isNotified : Boolean;
	rowIdx : Integer;
	targetTable : CM_DataTable;
	targetTableIsHidden : Boolean;
	edition : Integer;
	invalid : Boolean;
	cg		: CM_CargoGroup;

begin

	if _ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _ti, invalid );
	edition := _ti.edition;
	
	cg	:= _ti.myCargoGroup;
	
	if _remove or invalid then
		//We are deleting one that should already be there.
		//It will only be in one of the tables.
		if self.tblOnship.allViewObjects.includes( _ti ) then
			self.tblOnship.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblOnship.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblOnship.allTblDataEntRows, self.tblOnship, rowIdx);
			endif;
			self.colourTableRows(tblOnship);
		elseif self.tblOnsite.allViewObjects.includes( _ti ) then
			self.tblOnsite.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblOnsite.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblOnsite.allTblDataEntRows, self.tblOnsite, rowIdx);
			endif;
			self.colourTableRows(tblOnsite);
		elseif self.tblOffsite.allViewObjects.includes( _ti ) then
			self.tblOffsite.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblOffsite.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblOffsite.allTblDataEntRows, self.tblOffsite, rowIdx);
			endif;
			self.colourTableRows(tblOffsite);
		elseif self.tblPreNote.allViewObjects.includes( _ti ) then
			self.tblPreNote.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblPreNote.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblPreNote.allTblDataEntRows, self.tblPreNote, rowIdx);
			endif;
			self.colourTableRows(tblPreNote);
		endif;	
		
	else
		//We are either adding or updating one.
		// Find out where it should be showing, It can only be one of the following
		isOnship := ( self.displayModeOnShip = DISPLAY_MODE_ACTUAL and (_ti.isOnVoyage(self.myCurrentVoyage))) 
					or ( self.displayModeOnShip = DISPLAY_MODE_QUEUE and self.isQueued(_ti) )
					or ( self.displayModeOnShip = DISPLAY_MODE_PLAN and self.isPlanned(_ti) );
		
		if isOnship then
			targetTable := self.tblOnship;
			targetTableIsHidden := false;
		else
			isOnsite := ( self.displayModeOnSite = DISPLAY_MODE_ACTUAL and ( self.myCurrentVoyage.allOnsiteTIsByIdCargoType.includes( _ti ) and not _ti.isTranshipOnInboundVoyage ) )
						or ( self.displayModeOnSite = DISPLAY_MODE_QUEUE and _ti.isQueuedToYard )
						or ( self.displayModeOnSite = DISPLAY_MODE_PLAN and _ti.isPlannedToYard );
			
			if isOnsite then
				targetTable := self.tblOnsite;
				targetTableIsHidden := false;
			else
				isOffSite :=_ti.isOffSite();
				
				if isOffSite then
					targetTable := self.tblOffsite;
					targetTableIsHidden := not self.dkcOffSite.visible;
				else
					isNotified := _ti.isNotified and (self.displayModePreNote = DISPLAY_MODE_PLAN and self.isPlanned(_ti)
							or self.displayModePreNote = DISPLAY_MODE_ACTUAL);
					if isNotified then
						targetTable := self.tblPreNote;
						targetTableIsHidden := not self.dkcPreNotes.visible;	//15 Mar 2021	NDL	TFS 50935 
					endif;
				endif;		
			endif;
		endif;
	
		if targetTable = null then
			//Apparently we don't want to see it, make sure its not here
			//It will only be in one of the tables.
			if self.tblOnship.allViewObjects.includes( _ti ) or self.tblOnship.allViewObjects.includes( cg ) then
				self.tblOnship.clearViewObject( _ti, Any_System_Event );
				if cg &lt;&gt; null and self.tblOnship.findObjectInRow(cg, rowIdx) then
					// 08/11/2022	navkc1	#54927 - update cargo group details
					self.populateCargoGroupDetails(-1, cg, self.tblOnship.allTblDataEntRows, self.tblOnship, rowIdx);
				endif;
				self.colourTableRows(tblOnship);
			elseif self.tblOnsite.allViewObjects.includes( _ti ) or self.tblOnsite.allViewObjects.includes( cg ) then
				self.tblOnsite.clearViewObject( _ti, Any_System_Event );
				if cg &lt;&gt; null and self.tblOnsite.findObjectInRow(cg, rowIdx) then
					// 08/11/2022	navkc1	#54927 - update cargo group details
					self.populateCargoGroupDetails(-1, cg, self.tblOnsite.allTblDataEntRows, self.tblOnsite, rowIdx);
				endif;
				self.colourTableRows(tblOnsite);
			elseif self.tblOffsite.allViewObjects.includes( _ti ) or self.tblOffsite.allViewObjects.includes( cg ) then
				self.tblOffsite.clearViewObject( _ti, Any_System_Event );
				if cg &lt;&gt; null and self.tblOffsite.findObjectInRow(cg, rowIdx) then
					// 08/11/2022	navkc1	#54927 - update cargo group details
					self.populateCargoGroupDetails(-1, cg, self.tblOffsite.allTblDataEntRows, self.tblOffsite, rowIdx);
				endif;
				self.colourTableRows(tblOffsite);
			elseif self.tblPreNote.allViewObjects.includes( _ti ) or self.tblPreNote.allViewObjects.includes( cg ) then
				self.tblPreNote.clearViewObject( _ti, Any_System_Event );
				if cg &lt;&gt; null and self.tblPreNote.findObjectInRow(cg, rowIdx) then
					// 08/11/2022	navkc1	#54927 - update cargo group details
					self.populateCargoGroupDetails(-1, cg, self.tblPreNote.allTblDataEntRows, self.tblPreNote, rowIdx);
				endif;
				self.colourTableRows(tblPreNote);
			endif;

			return;
		endif;
		
		if _add then
			if targetTable.allViewObjects.includes(_ti) then
				self.doUpdateCurrentViewTi( _ti, targetTable, targetTableIsHidden );
			else
				self.loadCargoForTable(_ti, rowIdx, targetTable, targetTableIsHidden, true);
			endif;
		
		elseif _update then
			self.doUpdateCurrentViewTi( _ti, targetTable, targetTableIsHidden );
			
		endif;
		self.colourTableRows(targetTable);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_add" type="Boolean"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_remove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="a820c304-252d-44d0-89b6-73e79e7e2d3c">
        <updating/>
        <source>doNoteHandlingObject(_notificationRecord: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/07/2025	navkc1 JIRA MTN 35478 MTN | Voyage Operations - Notification Framework
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	userInfo		: Any;
	edition,
	eventTag,
	eventType		: Integer;
	noteObj			: Object;
	invalid			: Boolean;
	ti				: CM_TrackedItem;
begin
	noteObj 	:= _notificationRecord.myObject;
	eventType 	:= _notificationRecord.eventType;
	eventTag 	:= _notificationRecord.eventTag;
	userInfo 	:= _notificationRecord.myUserInfo;
	
	if noteObj = null then
		return;
	endif;
	
	// Delete
	if eventType = Object_Delete_Event then
		self.handleDeletedTI(noteObj.CM_TrackedItem);
		return;
	endif;
	
	if noteObj.isKindOf(CM_TrackedItem) then
		ti := noteObj.CM_TrackedItem;
		
		self.updateTI(ti);
	else
		on Exception do app.handleDeletedObject(exception, noteObj, invalid );
		
		edition := noteObj.edition;
		
		if invalid then
			return;
		endif;
		
		if 	noteObj.isKindOf(CM_Wagon) or 
			noteObj.isKindOf(CM_Vehicle) then
				self.handleDDlocationNotes(noteObj.CM_Object);
		elseif noteObj.isKindOf(CM_Voyage) then
			if eventType = self.myTerminal.getTerminalEvent(EVENT_BARGEVESSELCHANGE)  then
				self.updateCaption(self.baseCaption);
				self.buildLoadToCombo();
			endif;
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_notificationRecord" type="CMIF_NotificationRecord"/>
    </JadeMethod>
    <JadeMethod name="doNoteRefresh" id="03078717-447e-43ad-9524-377cece5d100">
        <updating/>
        <source>doNoteRefresh() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//30/07/2025	navkc1 JIRA MTN 35478 MTN | Voyage Operations - Notification Framework

*/

vars

begin
	self.loadCurrentVoyage();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPostFilterTableProcessing" id="5cb6012b-ee47-46ad-85d7-aeccfacca508">
        <source>doPostFilterTableProcessing(_table: CM_FilterTable input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2015	cnwndl1	Initial creation
28/11/2022		navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default

*/

vars

begin

	//method is called from the CM_FilterTable after filtering has been created, altered or removed, and those changes have been applied.

	//self.updateStatusBarCounts();
	self.updateStatusBarCounts(true, null);  // 28/10/2022	navkc1	#55408

epilog

end;</source>
        <Parameter name="_table" type="CM_FilterTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQueryColourUp" id="311e7738-4e8d-43a9-89c4-b0167ce412c5">
        <source>doQueryColourUp(_table : CM_DataTable input;_theTI : CM_TrackedItem;_theRow : Integer);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/08/2010	cnwdap1		PAR #25371 Colour up the Tranship voyage and discharge port columns
// 14/09/2010	cnwdap1		PAR #25742 Avoid 1090 when we don't have a discharge port on the tranship details
// 09 Jan 2017	cnwrs1	Par 38524 when checking this par there were lost of 1090 dumps for _theTI.myPrimaryActualLocation.myTerminalArea
// 09/06/2017	cnwdap1		TFS 4750 AAT 1090 colouring Location when cargo item is in a swap stack
// ---------------------------------------------------------------------------

vars
	thePort : CM_Port;
	theColour, theColumn : Integer;
	theCommodity : CM_Commodity;
	theCommodityGrp : CM_CommodityGroup;
	theISOType : CM_ISOType;
	theConsignee : CM_ConsigneeConsignor;
	theConsignor : CM_ConsigneeConsignor;
	theTrain : CM_Train;
	theImexStatus : CM_IMEXStatus;
	theCell : JadeTableCell;
	drwAtt : CM_DrawingAttribute;	
	cs : CM_ContentsStatus;
	ts : CM_TransitStatus;
	ct : CM_CargoType;
	ig : CM_ISOTypeGroup;
	defaultColour : Integer;
	carrier: CM_Carrier;
	
begin
	if _theRow mod 2 = 0 then
		defaultColour := self.getRowColour(1, _table);
	else
		defaultColour := self.getRowColour(2, _table);
	endif;
	
	// COLOUR UP THE 'Planning State'
	theColumn := _table.getColumnByRowName(ETRow_PlanningStateLoadList);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.state = TI_STATE_ONSHIP then
			theColour := xmlColourOnShip;
		elseif _theTI.myPrimaryPlannedLocation &lt;&gt; null then 
			theColour := xmlColourPlanned;
		elseif _theTI.myPrimaryPlannedLocation = null then
			theColour := xmlColourNonPlanned;
		endif;	
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// Colour up the rest of the columns only if the "Colour Tables" option is ticked
	if not self.chkColourCells.value then
		return;
	endif;
	
	// COLOUR UP THE ISO Type
	theColumn := _table.getColumnByRowName(ETRow_IsoType);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isKindOf(CM_Container) then 
			theISOType := _theTI.CM_Container.getISOTypeObject();
			if theISOType &lt;&gt; null then
				theColour := theISOType.colour;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE ISO Type Description
	theColumn := _table.getColumnByRowName(ETRow_IsoTypeDesc);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isKindOf(CM_Container) then 
			theISOType := _theTI.CM_Container.getISOTypeObject();
			if theISOType &lt;&gt; null then
				theColour := theISOType.colour;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Ready To Ship
	theColumn := _table.getColumnByRowName(ETRow_ReadyToShip);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.readyToShip then
			theColour := Green;
		else
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Is Special Stow
	theColumn := _table.getColumnByRowName(ETRow_IsSpecialStow);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isSpecialStow then
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	theColumn := _table.getColumnByRowName(ETRow_SpecialStowCode);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isSpecialStow then
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE ISO Group
	theColumn := _table.getColumnByRowName(ETRow_IsoTypeGroupDesc);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		ig := app.myRoot.allISOTypeGroups[_theTI.isoTypeGroup];
		if ig &lt;&gt; null then
			theColour := ig.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Cargo Type
	theColumn := _table.getColumnByRowName(ETRow_CargoType);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		ct := app.myRoot.allCargoTypesById[_theTI.cargoType];
		if ct &lt;&gt; null then
			theColour := ct.colour;
			if theColour = 0 then // not set?
				if ct.myDrawingAttribute &lt;&gt; null then
					theColour := ct.myDrawingAttribute.colour;					
				endif;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Contents Status
	theColumn := _table.getColumnByRowName(ETRow_ContentsStatus);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		cs := app.myRoot.allContentsStatuses[_theTI.getContentsStatus()];
		if cs &lt;&gt; null then
			theColour := cs.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Transit Status
	theColumn := _table.getColumnByRowName(ETRow_TransitStatus);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		ts := app.myRoot.allTransitStatuses[_theTI.getTransitStatus()];
		if ts &lt;&gt; null then
			theColour := ts.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Operator
	theColumn := _table.getColumnByRowName(ETRow_OperatorCode);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.myOperator &lt;&gt; null then
			theColour := _theTI.myOperator.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Discharge Port
	theColumn := _table.getColumnByRowName(ETRow_DischargePort);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		thePort := app.myRoot.allPorts[_theTI.dischargePort];
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Load Port
	theColumn := _table.getColumnByRowName(ETRow_LoadPort);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		thePort := app.myRoot.allPorts[_theTI.loadPort];
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Commodity
	theColumn := _table.getColumnByRowName(ETRow_Commodity);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCommodity := app.myRoot.allCommodities[_theTI.commodity];
		if theCommodity &lt;&gt; null then
			theColour := theCommodity.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Commodity Group
	theColumn := _table.getColumnByRowName(ETRow_CommodityGroup);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCommodityGrp := app.myRoot.allCommodityGroups[_theTI.commodityGroup];
		if theCommodityGrp &lt;&gt; null then
			theColour := theCommodityGrp.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Voyage
	theColumn := _table.getColumnByRowName(ETRow_VoyageCode);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.myVoyage &lt;&gt; null then
			theColour := _theTI.myVoyage.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE Custom Export Delivery Number
	theColumn := _table.getColumnByRowName(ETRow_CustomExportEntryNumber);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text = null then
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE Custom Export Hold
	theColumn := _table.getColumnByRowName(ETRow_CustomExportStop);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
			if drwAtt &lt;&gt; null then
				theCell.foreColor := drwAtt.colour;
				theCell.text := drwAtt.fontCharacter.Character;	
				theCell.fontName := drwAtt.fontName;
			endif;								
		endif;			
	endif;	
	
	// COLOUR UP THE Tranship Discharge Port
	theColumn := _table.getColumnByRowName(ETRow_TranshipDischargePort);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		thePort := null;
		if _theTI.myTranshipDetail &lt;&gt; null and _theTI.myTranshipDetail.myDischargePort &lt;&gt; null then	
			thePort := app.myRoot.allPorts[_theTI.myTranshipDetail.myDischargePort.code];
		endif;
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Tranship Voyage
	theColumn := _table.getColumnByRowName(ETRow_TranshipExportVoyage);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isTranshipItem and _theTI.myExportVoyage &lt;&gt; null then
			theColour := _theTI.myExportVoyage.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Location Area
	theColumn := _table.getColumnByRowName(ETRow_LocationArea);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isOnSite and
		   _theTI.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and						// TFS 4750
		   _theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic &lt;&gt; null then		// TFS 4750
			theColour := _theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic.drawLineColour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Terminal Area
	theColumn := _table.getColumnByRowName(ETRow_TerminalAreaId);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isOnSite and
		   _theTI.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and						// TFS 4750
		   _theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic &lt;&gt; null then		// TFS 4750
			theColour := _theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic.drawLineColour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Consignee
	theColumn := _table.getColumnByRowName(ETRow_Consignee);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theConsignee := app.myRoot.allConsigneeConsignors[_theTI.consignee];
		if theConsignee &lt;&gt; null then 
			theColour := theConsignee.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Consignor
	theColumn := _table.getColumnByRowName(ETRow_Consignor);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theConsignor := app.myRoot.allConsigneeConsignors[_theTI.consignor];
		if theConsignor &lt;&gt; null then
			theColour := theConsignor.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Assigned Train
	theColumn := _table.getColumnByRowName(ETRow_MyAssignedTrain);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.myTrainAssigned &lt;&gt; null then
			theColour := _theTI.myTrainAssigned.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Actual Train
	theColumn := _table.getColumnByRowName(ETRow_Train);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theTrain := _theTI.getTrainActual;
		if theTrain &lt;&gt; null then
			theColour := theTrain.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Imex Status
	theColumn := _table.getColumnByRowName(ETRow_ImexStatusString);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theImexStatus := _theTI.getImExStatusObject;
		if theImexStatus &lt;&gt; null then
			theColour := theImexStatus.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE carrier	TFS4209 MAP 8/6/17
	theColumn := _table.getColumnByRowName(ETRow_Carrier);
	if theColumn &gt; 0 then
		carrier := app.myRoot.allCarriers[_theTI.carrier];
		if carrier &lt;&gt; null then
			theColour := carrier.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow, theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	theColumn := _table.getColumnByRowName(ETRow_ReleaseCarrier);
	if theColumn &gt; 0 then
		carrier := app.myRoot.allCarriers[_theTI.releaseCarrier];
		if carrier &lt;&gt; null then
			theColour := carrier.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="ec811a32-2719-4eff-b2c6-d23136767b8c">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------------------
//Created: 17 April 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 05/02/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 16/04/2019   cnwma1		Bug 44075: JMT - Voyage Operations - Selector - Voyage Types - Shouldn't refresh until Select button selected
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	tmpVoy  	: CM_Voyage;
	idx			: Integer;
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	tmpVoy := self.myCurrentVoyage;
	
	self.myCurrentVoyage := null;

	self.doBuildComboVoyages();
	
	if tmpVoy &lt;&gt; null 
	and global.isValidObject(tmpVoy) 
	//and self.allVoyages.includes(tmpVoy) then				// PAR #35397
	and self.cmbVoyage.findObject(tmpVoy) &lt;&gt; null then		// PAR #35397
		self.setMyCurrentVoyage(tmpVoy);
	else
		tmpVoy := app.getMyCurrentVoyage();
		// PAR #35397 Check if voyage is for this terminal	// PAR #35397
		if tmpVoy &lt;&gt; null and tmpVoy.myTerminal &lt;&gt; self.myTerminal then		// PAR #35397
			tmpVoy := null;									// PAR #35397
		endif;												// PAR #35397
	endif;
	
	if self.myCurrentVoyage = null 
	and tmpVoy &lt;&gt; null
	and global.isValidObject(tmpVoy) then
		self.setMyCurrentVoyage(tmpVoy);
	endif;
	self.cmbVoyage.listIndex := self.cmbVoyage.findObject(self.myCurrentVoyage);			// PAR #35397
	
	// change to always show the searcher if there is no voyage to allow the user to select a voyage (RJS 16 Dec 2010)
	//if self.myCurrentVoyage = null and (not self.frmQuery.visible) then					// PAR #35397
	if (self.myCurrentVoyage = null and (not self.frmQuery.visible))						// PAR #35397
	or (self.myCurrentVoyage &lt;&gt; null and self.frmQuery.visible ) then						// PAR #35397
		if not self.filterChangedOnly then 													//16.4.2019 cnwma1 TFS #44075
			self.showHideSelector();
		endif;
	endif;
	
	//epr par 36201 3/9/15 whole point of refresh is to do it with the same voyage
	//mpd tfs 55379 24/11/22 Yes, but only if we've actually closed the searcher, otherwise just changing whats *shown* in the voyage dropdown shouldn't refresh all the tables
	// As that takes *ages* on large voyages
	if not self.filterChangedOnly then
		self.loadCurrentVoyage();
	endif;
	
epilog
	self.filterChangedOnly := false;
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetDoorDirection" id="f00ac84e-429d-4015-95a4-f4e8b5bde9cb">
        <updating/>
        <source>doResetDoorDirection() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	wle 			: CM_WorkListEntry;
	req				: CM_YardRequest;
	newDoorsValue 	: Boolean;

begin
	// Toggles the 'doorsForward' setting on the associated Release request
	// only valid if the container is not already on the truck.
	
	wle := self.mnuDoorDirections.userObject.CM_WorkListEntry;
	if wle = null or wle.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;
	
	req := wle.myRequest.CM_YardRequest;
	if req = null or req.isReceivalType then
		return;
	endif;
	
	newDoorsValue := not req.doorsForward;
	
	app.myTrxUA.trxUpdateYardRequestDoorsDir( req, newDoorsValue, app.myPassport );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="080dd0eb-6596-44ed-852c-5f6a17d8435d">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.frmRetrospective.top := self.frmToolbar.height;
	self.frmRetrospective.centreHorizontallyInParent();
	self.dkcMain.top := 53;
	self.dkcMain.height := self.height - ( self.stbGeneral.height + self.dkcMain.top + 35 );
	
	self.stbGeneral.doResize();
	self.doResizeDisplayFrames();
	if not self.dkcOffSite.visible and not self.dkcPreNotes.visible then
		self.dkcBottom.visible := false;
	else
		self.dkcBottom.visible := true;
	endif;
	
	inheritMethod();
	
	self.fldQuery.top := self.frmQueryToolbar.height; // TFS 50421
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeDisplayFrames" id="9d8ea62b-194a-491f-a87a-5e652717554b">
        <source>doResizeDisplayFrames();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwndl1	Initial creation	CCMS 1031

*/

vars

begin

	self.frmDispOnship.left := self.stbOnship.width - self.frmDispOnship.width;
	self.lblOnshipCount.width := self.frmDispOnship.left;

	self.frmDispOnsite.left := self.stbOnsite.width - self.frmDispOnsite.width;
	self.lblOnsiteCount.width := self.frmDispOnsite.left;

	if self.chkShowOffsite.value then
		self.frmDispOffsite.left := self.stbOffsite.width - self.frmDispOffsite.width;
		self.lblOffsiteCount.width := self.frmDispOffsite.left;
		self.lblOffsite.visible := true;
		self.tblOffsite.visible := true;
		self.stbOffsite.visible := true;
		self.dkcOffSite.visible := true;
	else
		self.lblOffsite.visible := false;
		self.tblOffsite.visible := false;
		self.stbOffsite.visible := false;
		self.dkcOffSite.visible := false;
	endif;
	
	if self.chkPreNote.value then
		self.frmDispPreNote.left := self.stbPreNote.width - self.frmDispPreNote.width;
		self.lblPreNoteCount.width := self.frmDispPreNote.left;
		self.lblPreNote.visible := true;
		self.tblPreNote.visible := true;
		self.stbPreNote.visible := true;
		self.dkcPreNotes.visible := true;
	else
		self.lblPreNote.visible := false;
		self.tblPreNote.visible := false;
		self.stbPreNote.visible := false;
		self.dkcPreNotes.visible := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRetrospective" id="a34c11ab-99fe-45ad-b514-17e29e218853">
        <updating/>
        <source>doRetrospective(_dateTime : TimeStamp)updating;
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
//--------------------------------------------------
// Note: _dateTime can be null.
vars
	now,
	dateTimeSystem: TimeStamp;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	now := app.actualTimeServer();	// 10/5/16 cnwmp6 TFS 488 - Multi timezone support
	dateTimeSystem := self.localToSystemTime(_dateTime);
	
	if self.myCurrentVoyage = null then
		return;
	endif;

	if self.myCurrentVoyage.nonPlannedEffectiveDT = dateTimeSystem then
		return;
	endif;
	
	if self.cbRetrospective.value and dateTimeSystem &gt; now then
		app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective DateTime', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;	

	app.mousePointer := MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateVoyageNonPEffectiveDT(self.myCurrentVoyage, dateTimeSystem, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Effective DateTime', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doRetrospectiveClick" id="281ad5c9-a53d-4e4a-a40d-de99da3d8e66">
