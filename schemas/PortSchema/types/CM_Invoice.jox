    <JadeMethod name="hasInvoiceAPIRequest" id="e2cddb75-f57d-44fa-9941-85cc8172e2b6">
        <source>hasInvoiceAPIRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2025	jlier1	Initial creation  MTN-34357

*/

vars
	bgp : BGP_InvoiceAPIWSRequest;
	invalid : Boolean;
	invoice : CM_Invoice;
begin

	on Exception do app.handleDeletedObject(exception,invoice, invalid);
	foreach bgp in BGP_InvoiceAPIWSRequest.instances discreteLock do
		invoice:= bgp.myInvoice;
		if invoice = null then
			continue;
		endif;
		if invoice = self then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMergedTASCreditNote" id="5438b94f-cdfe-458a-8da9-6df06dc0c8f6">
