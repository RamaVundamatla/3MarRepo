    <JadeMethod name="getPictureButton" id="869adc14-e1f1-42aa-b272-1869cd2d7650">
        <source>getPictureButton(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	if self.pictureStringButton &lt;&gt; null then
		thePicture := app.myRoot.getConfig(self.pictureStringButton).Binary;
	endif;
	
	return thePicture;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
