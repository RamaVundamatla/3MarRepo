    <JadeMethod name="checkStaggerHeights" id="2c17d14b-8db3-40b7-9f07-bf832a8a00de">
        <updating/>
        <source>checkStaggerHeights(pStagger : String io) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		To clear out any unwanted dta in the string,leaving just a comma
//				seperated list of integers. Each of the integers will not be greater that the
//				stack height, plus there will only be 1 number for each cols (width).
//				The Staggering Heights are the maximum height that each column
//				can go to.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStagger	: String;
	i,c			: Integer;
	lHeights		: HugeStringArray;
	pos			: Integer;
	listString 	: String;
begin

	create lHeights transient;  // cnwrd1 par 22682 16.3.2010
	
	if pStagger.trimBlanks = "" then
		pStagger := self.heightOfStack.String;
	endif;
	// Get rid of anything that is not a number or a comma
	foreach i in 1 to pStagger.length do
		if pStagger[i:1] = ","  or pStagger[i:1].isInteger then
			tmpStagger := tmpStagger &amp; pStagger[i:1];
		endif;
	endforeach;
	
	
	// Put the numbers into an array to check that the numbers are not too big
	// Get rid of the commas, replace with a token
	tmpStagger.replaceChar("," , "/");
	// populate a string array splitting by the token
	
	tmpStagger.getTokensForDelimiterHuge( '/', lHeights); // cnwrd1 par 22682 16.3.2010 ++ incase of realy big but stupid numbers.
	//lHeights := tmpStagger.getTokens; // cnwrd1 par 22682 16.3.2010 --
	foreach i in 1 to lHeights.size do
		if lHeights[i].length &gt; 2 then // XPOSE 1765
			lHeights[i] := lHeights[i][1:2];
		endif;
		//if lHeights[i].Integer &gt; self.heightOfStack then										//-cnwml2 PAR26097
		if lHeights[i].Integer &gt; self.heightOfStack or lHeights[i].Integer = 0 then				//+cnwml2 PAR26097
			lHeights[i] := self.heightOfStack.String;
		endif;
	endforeach;
	
	// if there are not enough numbers then default each cols to self.height
	if lHeights.size &lt; self.numberOfRows then
		c :=  self.numberOfRows - lHeights.size;
		foreach i in 1 to c do
			lHeights.add(self.heightOfStack.String);
		endforeach;
	
	endif;
	
	// Now go through the array and produce a comma seperated list that has no more numbers in it than the width of the stack
	pStagger := "";
	foreach i in 1 to self.numberOfRows do
		pStagger := pStagger &amp; 	lHeights[i] &amp; ", ";
	endforeach;
	i := pStagger.length - 2; // get rid of the comma
	pStagger := pStagger[1:i];
epilog
	delete lHeights;	
end;</source>
        <Parameter name="pStagger" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doOverStowMove" id="506db484-d5c5-4d74-ac62-23b83193a6c1">
        <updating/>
        <source>doOverStowMove(_cmifAutoPlan: CMIF_AutoMovePlan input) protected, updating;

// cnwdvb1 25 July 2003 

vars

	tiToMove		: CM_TrackedItem;
	isMoveable		: Boolean;
	moveLocn		: CM_LocationsController;
	alert			: CM_SystemAlert;
	rtEntry			: CM_RTQueueEntry;
	tempAutoPlan	: CMIF_AutoMovePlan;

begin

	tiToMove := _cmifAutoPlan.myTrackedItem;
	exclusiveLock(tiToMove);
   	//_cmifAutoPlan.addLogEntry("Trying to move overstowing item " &amp; tiToMove.id, IsForLogging); //- cnwmd1, Par 20524
	_cmifAutoPlan.addLogEntry(app.getErrorString1(Trying_move_oversto_item, tiToMove.id), IsForLogging, Trying_move_oversto_item);
	isMoveable := true;  				//general purpose variable

	//Test if it is connected...
	if tiToMove.CM_Container.isConnected  then
		if not tiToMove.myTerminal.getConfig(ReeferMoveOSConnected).Boolean then  // ### TFS 51521 11AUG2021 NAVAB1
			isMoveable := false;
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is still connected. It is not currently moveable", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Still_connect_current_moveabl, tiToMove.id), IsForLogging, Still_connect_current_moveabl);
			//app.raiseCMException1(Err_QueueTaskUpdate, tiToMove.id &amp; " is still connected. It is not currently moveable", null, null); //- cnwmd1, Par 20524
			app.raiseCMException1(Still_connect_current_moveabl, tiToMove.id, null, null);
			return;

		endif;
	endif;
	//See if another machine is already working the top box
	if tiToMove.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then		
		if tiToMove.queueTaskStatus &lt;&gt; TASK_UNACTIONED and tiToMove.queueTaskStatus &lt;&gt; TASK_COMPLETE then
			//_cmifAutoPlan.addLogEntry("%1 is not unactioned or completed. It cannot be moved in this task" &amp; tiToMove.id, IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Unact_cmpl_cnnt_move_in_task, tiToMove.id), IsForLogging, Unact_cmpl_cnnt_move_in_task);
	    	isMoveable := false;
	    	//app.raiseCMException1(Err_QueueTaskUpdate, tiToMove.id &amp; " is not unactioned or completed. It cannot be moved in this task", null, null); //- cnwmd1, Par 20524
			app.raiseCMException1(Unact_cmpl_cnnt_move_in_task, tiToMove.id, null, null);
	    	return;
     	endif;
  	endif;

	_cmifAutoPlan.updateController(null);
	if isMoveable then
		//_cmifAutoPlan.addLogEntry("Testing ground positions in current row", IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Testing_ground_positio_current), IsForLogging, Testing_ground_positio_current);
	 	_cmifAutoPlan.iteration := 1;	// Empty location first
	 	
		self.getOverStowLocation(_cmifAutoPlan);
	
		//Do the move and update the queue entry		
		moveLocn := _cmifAutoPlan.getController.CM_GridController;
		// if we cannot find somewhere for it to go then put it in the FORK LIFT STACKS swap stack
		if moveLocn = null then 
			create alert;
   			alert.details := "Could not find an overstow move location for " &amp; tiToMove.id &amp; 
			" in " &amp; tiToMove.locationId &amp; ". Manual intervention required";
			alert.setSeverity(SEVERE_WARNING);
			alert.add;
			//_cmifAutoPlan.addLogEntry("Could not find an overstow move location for " &amp; tiToMove.id, IsForLogging);   	
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Could_find_overst_move_locati, tiToMove.id), IsForLogging, Could_find_overst_move_locati);   	
			//app.raiseCMException1(Err_QueueTaskUpdate, 'Unable to determine overstow location', null, null);
			app.raiseCMException(Unable_determi_oversto_locatio, null, null);
			return;
		endif;

	 	//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " will be moved to " &amp; moveLocn.getID &amp; " as an overstow move", IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString2(Will_moved_oversto_move, tiToMove.id, moveLocn.getID), IsForLogging, Will_moved_oversto_move);
	 	// Use temp auto to clear out references.
		create tempAutoPlan transient;
		tempAutoPlan.workingFromFront := _cmifAutoPlan.workingFromFront;
		tempAutoPlan.setMyTrackedItem(tiToMove);
		tempAutoPlan.setMyToPrimaryLocation(moveLocn);
		tempAutoPlan.setMoveMode(QUEUE_MODE);
		tempAutoPlan.isRadioTelemetryMove := true;
		tempAutoPlan.isOverstowMove := true;
		tempAutoPlan.isSystemMove := true;
		tempAutoPlan.setMyWorkListEntry(null);
		tempAutoPlan.myRTQueueEntry := _cmifAutoPlan.myRTQueueEntry;
		tempAutoPlan.isForkLiftOverStow := true;
		//-------------
		//Call the move method
		//-------------
		app.myPassport.clearErrorsWarnings();
		app.myUtilityUA.utlUpdateMoveTrackedItem(tempAutoPlan, app.myPassport);
		if not app.myPassport.noErrors then
			app.convertErrorsWarningsToAlert("Overstow Move Error", app.myPassport.allErrorWarnings);
		endif;
	endif;

epilog

	delete tempAutoPlan;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOverstowMoveYA" id="96201395-3cf4-4a7e-aa7c-a2dd4a12c8ce">
        <updating/>
        <source>doOverstowMoveYA(_cmifAutoPlan: CMIF_AutoMovePlan input) protected, updating;

// cnwdvb1 25 July 2003 

vars

	tiToMove		: CM_TrackedItem;
	moveLocn,
	tiToMoveLC		: CM_LocationsController;
	isMoveable		: Boolean;
	alert			: CM_SystemAlert;
	moveController	: CMIF_MoveController;
	lcArray			: CM_LCArray;
	yaAgent			: CM_YAAutoplanAgent;
	passport		: CM_Passport;

begin
	
	passport := app.myPassport;
	
	tiToMove := _cmifAutoPlan.myTrackedItem;
//	_cmifAutoPlan.addLogEntry("Trying to move overstowing item " &amp; tiToMove.id, IsForLogging);
	exclusiveLock(tiToMove);
	isMoveable := true;  				//general purpose variable
		
	//Test if it is connected...
	if tiToMove.CM_Container.isConnected then
		if not tiToMove.myTerminal.getConfig(ReeferMoveOSConnected).Boolean then  // ### TFS 51521 11AUG2021 NAVAB1 NOTE. doOverstowMoveYA is only called if the move is an overstow
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is still connected. It is not currently moveable", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Still_connect_current_moveabl, tiToMove.id), IsForLogging, Still_connect_current_moveabl);
			isMoveable := false;
		endif;
	endif;

	//See if another machine is already working the top box
	if tiToMove.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then		
		if tiToMove.queueTaskStatus &lt;&gt; TASK_UNACTIONED and
			tiToMove.queueTaskStatus &lt;&gt; TASK_COMPLETE then
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is assigned to another machine. It cannot be moved in this task", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Assig_anoth_machi_canno_moved_, tiToMove.id), IsForLogging, Assig_anoth_machi_canno_moved_);
			isMoveable := false;
		endif;
	endif;
	
	if isMoveable then
	
		moveLocn := app.autoPlanOverstowYA(self.myTerminal, self, tiToMove);
		
		if moveLocn = null then
			tiToMove.createInfomationTransaction(YardAllocationOSLogging, app.myYAAgent.getLoggingArray(true), null, passport);
			// Try for normal autoplan.
			moveLocn := app.autoPlanTiYA(self.myTerminal, null, tiToMove);
			if moveLocn = null then
				return;
			endif;
		endif;
		
		create moveController transient;
		moveController.hazardSegregationValidated := true;
		moveController.setMyTrackedItem(tiToMove);
		moveController.setMyToPrimaryLocation(moveLocn);

		moveController.setMoveMode(QUEUE_MODE);
		moveController.isRadioTelemetryMove := true;
		moveController.isOverstowMove := true;
		moveController.isSystemMove := true;
		moveController.setMyWorkListEntry(null);
		moveController.myRTQueueEntry := _cmifAutoPlan.myRTQueueEntry;
		//-------------
		//Call the move method
		//-------------

		passport.clearErrorsWarnings();
		app.myEventManager.initialise;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, passport);
		if not passport.noErrors then
			app.convertErrorsWarningsToAlert("Overstow Move Error", passport.allErrorWarnings);
		endif;
		
		if app.myYAAgent &lt;&gt; null then
			tiToMove.createInfomationTransaction(YardAllocationOSLogging, app.myYAAgent.getLoggingArray(true), null, passport);
		endif;
	endif;

epilog
	delete moveController;
	delete lcArray;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="3d6f2052-cda2-4b76-a543-4058e10f28ef">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

constants
	TOWER_POS = "T";
vars
	tStr : String;
	rowStr,
	colStr : String;
	lc : CM_GridController;
	rowStrLength : Integer;
	rowObj : CM_GridRow;
begin



//	inheritMethod(_strs, _foundLC, _foundHeight);

	if _strs.size = 0 then
		return;
	endif;
	//--------------------
	// Extract the LC part of the label
	//--------------------

	tStr := _strs[1].trimBlanks;

	if tStr = null then
		return;
	endif;
	

	if lc &lt;&gt; null then
		return;
	endif;	
	//----------------------
	//Derive the Row
	//----------------------
	if tStr.length = 1 then
		//Only 1 char for row/col!
		return;
	endif;
	
	//epr par 21526 - rows can be upto 4 characters can include "/-: etc anything but a space
	/*
		get row label length
		start at end less the min of 4 (the row label max that can be entered) or
		tStr length less 1 (assume col label is atleast 1 char)
	*/
	
	rowStrLength:=4.min(tStr.length-1);
	while rowStrLength &gt;=1  do
		rowStr:=tStr[(tStr.length  - rowStrLength) + 1:end];
		rowObj:=self.allGridRowsByLabel[rowStr];
		if rowObj &lt;&gt; null then
			break;
		endif;
		rowStrLength:=rowStrLength-1;
	endwhile;
	
	if rowObj = null then
		return;
	endif;
	
	
	colStr := tStr[1:tStr.length-rowStrLength];
	rowStr := tStr[(tStr.length-rowStrLength) + 1:end];
	
	if self.use40ftIds then 
		lc := self.allGridControllersBy40ftId[rowStr &amp; colStr];
	endif;

	if lc = null then
		lc := self.allGridControllersByName[rowStr &amp; colStr];
	endif;

	//----------------------
	//Derive the Height part
	//----------------------
	if _strs.size &gt; 1 then	
		if _strs[2].isInteger then
			_foundHeight := _strs[2].Integer;
		endif;
	endif;

	
	if lc = null then
		return;
	endif;
	
	_foundLC := lc; // AKB added
	
	if lc.mySubBlockStack &lt;&gt; null then
		//Tell the sub-block to findLocation
		lc.mySubBlockStack.findLocation(_strs, _noException, _foundLC, _foundHeight);
	else
		if _strs.size = 1 then
			//no last part.
			return;
		endif;
		tStr := _strs[2].trimBlanks;
		
		if tStr[1] &lt;&gt; TOWER_POS then
			return;
		endif;
		_foundLC := lc.getMyNextController(CM_TowerController).CM_TowerController;
	endif;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAvailUse" id="3374c1d0-fd27-407d-a03e-0e4cbdc06579">
        <source>getAvailUse(pRow : Integer; pAvail : Integer io);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

		if pAvail &lt;&gt; PAD_UNAVAILABLE then
			// The availability says how high up the pad is available, so look at the row heights to set the staggering heights on the area. This can be reset in the yard using Pad Edit
			//th2 PAR 13163
			if self.staggerHeights.size &lt; pRow then
				pAvail := PAD_AVAILABLE;
			elseif self.staggerHeights[pRow] = self.heightOfStack then
				pAvail := PAD_AVAILABLE;
			else
				 // 1 and 2 have general meanings of available or not, so add 3 on top. 
				 // If the stagger height is 2 then the availability must be set to 5. 
				 // Height of 2 plus 2 (because 1 and 2 mean something else) plus 1 because the availibility is 'nothing from this height up' so we want to say nothing from 3 up so add 1 equals 5
				pAvail := self.staggerHeights[pRow] + 3;
			endif;
		endif;


end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pAvail" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDirectionForward" id="b1c08e7e-85c4-4318-acf7-59247462e339">
        <updating/>
        <source>getDirectionForward(theAutoMovePlan: CMIF_AutoMovePlan input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30475 - renamed method from autoPlanTestRestriction (removing location restricions)
// ---------------------------------------------------------------------------

vars
	directionForward : Boolean;
begin
	if self.accessBack and self.accessFront then
		directionForward := true;
	else
		if self.accessBack and not self.accessFront then
			// if we do not have access from both sides then we will only be doing whole columns, if at all
			directionForward := false;
		else
			directionForward := true;
		endif;
	endif;	
	
	return directionForward;
epilog

end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="41fb036f-178e-494a-9362-d8156490da16">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_AccessBack then
		return self.accessBack.asStringJMT;
	elseif _attrName = ETRow_AccessFront then
		return self.accessFront.asStringJMT;
	elseif _attrName =ETRow_MaxHeightMT then
		return self.maxHeightMT.asStringJMT;
	elseif _attrName = ETRow_MaxHeightPower then
		return self.maxHeightPower.asStringJMT;
	elseif _attrName =ETRow_MaxHeightFull then
		return self.maxHeightFull.asStringJMT;
	elseif _attrName = ETRow_StaggerHeights then
		return self.getStaggerHeights;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridCaption" id="4e231417-50b7-4831-b572-31e7f16ab4a8">
        <source>getGridCaption() : String;
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	accessString : String;
begin
	accessString := null;
	if self.accessFront and self.accessBack then
		accessString := "Full Access";
	elseif self.accessFront and not self.accessBack then
		accessString := "Access Front Only";
	elseif not self.accessFront and self.accessBack then
		accessString := "Access Back Only";
	else
		accessString := "No Access Front Or Back";
	endif;
	return  self.id.trimBlanks &amp; " (" &amp; accessString &amp; "), ";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeightNoStackFrom" id="378cf103-754e-4729-8e7b-e9434eb30937">
        <source>getHeightNoStackFrom(): Integer;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
		return self.heightOfStack;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLCsRestrictingAccess" id="7c2993a5-2004-42a0-b0e2-0af019365f7d">
        <updating/>
        <source>getLCsRestrictingAccess(pSourceContainer : CM_TrackedItem;pTIA40, pCheckingSource : Boolean; tisFront, tisBack : CM_TIArray input) updating;
						

// cnwdvb1 06 June 2003 

vars
	lCol,
	pos		 				  					: Integer;
	sourceLocn, targetLocn						: CM_GridController; //CM_StackController;
	startRow, startCol							: Integer;
	lControllerArray	 		 				: CM_LCArray;
	queueLocn									: CM_LocationsController;
	tiToMoveLocn,
	lcn											: CM_LocationsController;
	tiArraySort									: CMIF_RTSortByPosDict;
	isFirst			 							: Boolean;
	ti											: CM_TrackedItem;
	infoCols, infoCols2							: IntegerArray;
	
begin

	create infoCols transient;
	create infoCols2 transient;
	create tiArraySort transient;
	sourceLocn := pSourceContainer.getPrimaryLocation(REAL_MODE).CM_GridController;
	// if the target is not a STack i.e. it is a wagon or a slot then for the purposes of this overstow logic make it the same as the source
	// this should not matter as the target location in this method is used to check ordinal columns and rows etc to make sure that the overstow TI
	// is not put in the way of the traget location of the actual TI move
	queueLocn := pSourceContainer.getPrimaryLocation(QUEUE_MODE);
	if queueLocn &lt;&gt; null then
		if queueLocn.isKindOf(CM_StackController) then
			targetLocn := queueLocn.CM_StackController;
		else
			targetLocn := sourceLocn;
		endif;
	else
		targetLocn := sourceLocn;
	endif;

	if pCheckingSource then
		sourceLocn.getMyRowColOrdinal(startRow, startCol);
	else
		// if we are checking the target location then only do this if the target is in a different column form the source
		sourceLocn.getMyRowColOrdinal(startRow, lCol);
		targetLocn.getMyRowColOrdinal(startRow, startCol);
		if startCol = lCol then
			return;
		endif;
	endif;

	// NEED TO GO THROUGH COLUMN INTEGERS NOT OBJECTS.
	create lControllerArray transient;
	// access from the front 
	if self.accessFront then
		// Get controllers that are in the way of move.
//		self.getControllersBetweenRowsCols(self.allGridRows[(startRow)].label, self.allGridColumns[startCol].label, self.allGridRows[(self.numberOfRows)].label,
		self.getControllersBetweenRowsCols(startRow, startCol, self.numberOfRows, startCol, lControllerArray);
		isFirst := true;
		foreach tiToMoveLocn in lControllerArray do 
			// Start with the source container.
			if isFirst then
				ti := pSourceContainer;
				ti.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols, false);
			else
				// We struck a 40 so get tis that are in the way.
				if infoCols.size &gt; 0 then
					foreach lCol in infoCols do
						lcn := self.allGridControllersByRowColumn[tiToMoveLocn.CM_GridController.row, lCol];
						if lcn &lt;&gt; null then
							ti := lcn.allTrackedItems.first;
							if ti &lt;&gt; null then
								ti.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols2, true);
							endif;
						endif;
					endforeach;
				else
					// No forties so just get first ti in the way.
					if tiToMoveLocn.allTrackedItems.size &gt; 0 then
						ti := tiToMoveLocn.allTrackedItems.first;
						ti.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols2, true);
					endif;
				endif;
			endif;
			// Unload latest tis into total front array.
			tiArraySort.unLoadTis(tisFront);
			foreach lCol in infoCols2 do
				if not infoCols.includes(lCol) then
					infoCols.add(lCol);
				endif;
			endforeach;
			tiArraySort.clear();
			infoCols2.clear();
			ti := null;
			isFirst := false;
		endforeach;
	endif;
	// access from the back 
	if self.accessBack then
		// if I am a 20 check to see if there are any 40s in front/behind of me, not including target
//		self.getControllersBetweenRowsCols(self.allGridRows[1].label, self.allGridColumns[startCol].label, self.allGridRows[(startRow)].label,
//					self.allGridColumns[startCol].label,lControllerArray);		
		self.getControllersBetweenRowsCols(1, startCol, startRow, startCol, lControllerArray);		
		isFirst := true;
		infoCols.clear();
		infoCols2.clear();
		foreach tiToMoveLocn in lControllerArray reversed do 
			// Start with the source container.
			if isFirst then
				ti := pSourceContainer;
				ti.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols, false);
			else
				// We struck a 40 so get tis that are in the way.
				if infoCols.size &gt; 0 then
					foreach lCol in infoCols do
						lcn := self.allGridControllersByRowColumn[tiToMoveLocn.CM_GridController.row, lCol];
						if lcn &lt;&gt; null then
							ti := lcn.allTrackedItems.first;
							if ti &lt;&gt; null then
								ti.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols2, true);
							endif;
						endif;
					endforeach;
				else
					// No forties so just get first ti in the way.
					if tiToMoveLocn.allTrackedItems.size &gt; 0 then
						ti := tiToMoveLocn.allTrackedItems.first;
						ti.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols2, true);
					endif;
				endif;
			endif;
			// Unload latest tis into total front array.
			tiArraySort.unLoadTis(tisBack);
			foreach lCol in infoCols2 do
				if not infoCols.includes(lCol) then
					infoCols.add(lCol);
				endif;
			endforeach;
			tiArraySort.clear();
			infoCols2.clear();
			ti := null;
			isFirst := false;
		endforeach;
	endif;

epilog

	delete lControllerArray;
	delete infoCols;
	delete infoCols2;
	delete tiArraySort;

end;</source>
        <Parameter name="pSourceContainer" type="CM_TrackedItem"/>
        <Parameter name="pTIA40" type="Boolean"/>
        <Parameter name="pCheckingSource" type="Boolean"/>
        <Parameter name="tisFront" type="CM_TIArray" usage="input"/>
        <Parameter name="tisBack" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMaxHeightGridAreaYA" id="b10a9c0b-8269-4593-935b-54468dc27907">
        <source>getMaxHeightGridAreaYA(_cmifAutoPlan  : CMIF_YAAutoPlan): Integer;
// -------------------------------------------
// Created 15 June 2005 by cnwdvb1
// -------------------------------------------
vars	
	maxHeight : Integer;
begin
		
	//11 May 2012	NDL	Par 29555
	if _cmifAutoPlan.isAttributeTrue(TI_Attrib_RequiresPower) then
		maxHeight := (self.maxHeightPower / HEIGHT_FULL_HIGH_CUBE).Integer;
	elseif _cmifAutoPlan.isFull() then
		maxHeight := (self.maxHeightFull / HEIGHT_FULL_HIGH_CUBE).Integer;
	elseif not _cmifAutoPlan.isFull() then
		maxHeight := (self.maxHeightMT / HEIGHT_FULL_HIGH_CUBE).Integer;
	endif;
	
	if maxHeight = 0 then
		//No max height value set up, use height.
		maxHeight := height;
		if maxHeight = 0 then
			//zero implies no limit.  call it 99.
			maxHeight := 99;
		endif; 
	endif; 
	
	return maxHeight;
	
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextAvailableLocation" id="9b7bb44f-c56f-4627-a22c-6fe952afda70">
        <source>getNextAvailableLocation(_startLC : CM_GridController) : CM_GridController;
/*
Purpose:			
Date				Who			Reason
AUGUST 2014	CNWAB1		Initial creation
*/

vars
	startColumn, gridColumn : CM_GridColumn;
	freeGC : CM_GridController;
begin

	startColumn := _startLC.myGridColumn;
	
	foreach gridColumn in self.allGridColumns  discreteLock where gridColumn.column &gt;= startColumn.column do
		
		freeGC := gridColumn.getNextAvailableLocation(REAL_MODE); // PAR 35397
		if freeGC &lt;&gt; null then
			break;
		endif;
		
	endforeach;
	
	
	return freeGC;
epilog

end;</source>
        <Parameter name="_startLC" type="CM_GridController"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getNoAccessString" id="6c7824e1-d897-4805-9f17-d81d83556d9e">
        <source>getNoAccessString(_theTI: CM_TrackedItem; _lc: CM_LocationsController): String;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.accessBack or self.accessFront then
		//return _theTI.id &amp; ". Location " &amp; _lc.getFullId &amp; " has restricted row access. Cargo is in front and/or behind." ;
		return app.getErrorString2(Locat_restr_acces_cargo_front_,_theTI.id, _lc.getFullId);
	endif;


	return inheritMethod(_theTI, _lc);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverStowLocation" id="76204826-212e-442d-96fb-448eaec52c01">
        <updating/>
        <source>getOverStowLocation(_cmifAutoPlan: CMIF_AutoMovePlan input) updating, protected;

// cnwdvb1 21 July 2003 

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2018	jlgmd1		TFS #37853 - Allow overstowing to work for 30, 45 and 53's
// ---------------------------------------------------------------------------

vars

	isTiToMove40,
	isOrginalTi40,
	isLeft			: Boolean;
	sourceLocn,
	targetLocn		: CM_StackController;
	startCol		: Integer;
	originalTi,
	toMoveTi		: CM_TrackedItem;
	selfAccess : Integer;
	overstowController : CMIF_OverstowController;
begin

	originalTi	:= _cmifAutoPlan.myOrginalTi;
	toMoveTi	:= _cmifAutoPlan.myTrackedItem;
	// Are we dealing with 40s
	isTiToMove40 := toMoveTi.isAttributeTrue(TI_Attrib_IsForty) or toMoveTi.isAttributeTrue(TI_Attrib_IsFortyFive) or toMoveTi.isAttributeTrue(TI_Attrib_IsFiftyThree);
	isOrginalTi40 := originalTi.isAttributeTrue(TI_Attrib_IsForty) or originalTi.isAttributeTrue(TI_Attrib_IsFortyFive) or originalTi.isAttributeTrue(TI_Attrib_IsFiftyThree);

	// Get source locatoins.
	sourceLocn		:= originalTi.getPrimaryLocation(REAL_MODE).CM_StackController;
	
	// Get target location.
	if originalTi.getPrimaryLocation(QUEUE_MODE).isKindOf(CM_StackController) then
		targetLocn := originalTi.getPrimaryLocation(QUEUE_MODE).CM_StackController;
	else
		targetLocn := sourceLocn;
	endif;
	
	// Are we going to look from the left or right to start with.
	startCol := sourceLocn.myGridColumn.column;
	if startCol &lt; (self.numberOfColumns / 2) then // try to a bit more efficient by looking which side of the area we are on roughly
		isLeft := true;
	endif;
	//epr tfs 39001 6/6/18
	create overstowController transient;
	overstowController.setGridLocation(sourceLocn);
	overstowController.getAllOverstows();
	selfAccess := overstowController.accessDirection; 
	if selfAccess = TA_ACCESS_BACK then
		_cmifAutoPlan.workingFromFront :=false;
	elseif selfAccess = TA_ACCESS_FRONT then
		_cmifAutoPlan.workingFromFront :=true;
	endif;
	app.verboseLogging := true;
	// Are we starting from the front or the back.
	if _cmifAutoPlan.workingFromFront then
		//STACK_UP_STACK STACK_ALONG_ROW
		if not self.testOverstowFront(_cmifAutoPlan, originalTi, toMoveTi, sourceLocn, targetLocn, isLeft, isOrginalTi40, isTiToMove40, true) then
			self.testOverstowBack(_cmifAutoPlan, originalTi, toMoveTi, sourceLocn, targetLocn, isLeft, isOrginalTi40, isTiToMove40, false);
			//_cmifAutoPlan.workingFromFront:=false; //epr TFS 37584 this matters when the overstow rt moves are sorted 
		endif;
	else
		if not self.testOverstowBack(_cmifAutoPlan, originalTi, toMoveTi, sourceLocn, targetLocn, isLeft, isOrginalTi40, isTiToMove40, true) then
			self.testOverstowFront(_cmifAutoPlan, originalTi, toMoveTi, sourceLocn, targetLocn, isLeft, isOrginalTi40, isTiToMove40, false);
			//_cmifAutoPlan.workingFromFront:=true; //epr TFS 37584 this matters when the overstow rt moves are sorted
		endif;
	endif;
epilog
	delete overstowController;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPowerPoints" id="dd436279-a072-4c4f-9c8e-a8847877d083">
        <source>getPowerPoints(pArray  : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:		March 2002 By Andrew Bishop cnwab1
//
// Purpose:		Pass back an array of all the gap positions that have power available.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	ta	: CM_TerminalArea;
	lPowerGap	: ObjectArray;
	lc	: CM_YardController;
	lc2	: CM_LocationsController;
	gc : CM_GridController;
begin
	pArray.clear;
	foreach lc in self.allGridControllersByRowColumn do
		
		gc :=  lc.CM_GridController.getNextControllerOfType(CM_GapController);
		
		if gc &lt;&gt; null then
			if gc.power then
				pArray.add(gc); // put the OIDs into an array
			endif;
		endif;
	endforeach;

epilog
end;</source>
        <Parameter name="pArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStaggerHeights" id="735dfff2-c167-4867-9f80-db035deac71b">
        <source>getStaggerHeights() : String;

vars
	line : String;
	i : Integer;
begin
	
	foreach i in 1 to self.staggerHeights.size do
		line := line &amp; staggerHeights[i].String &amp; ", ";
	endforeach;
	
	line := line[1:(line.length - 2)];
	return line;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIsRestrictingAccess" id="9e6d7f16-a554-4aa2-8cff-4bc1feb70a15">
        <updating/>
        <source>getTIsRestrictingAccess(_autoPlan : CMIF_AutoMovePlan; sourceTI : CM_TrackedItem;  tisInTheWay : CM_TIArray io; _workingFromTheFront  : Boolean output) updating;
// ---------------------------------------------------------------------------
// Created:		September 2001 By Andrew Bishop cnwab1
//
// Purpose:		there are boxes in front or behind the TI to be moved, that are restricting access, so we are going to move them out of the way
//				NOTE. The important thing to remeber is that this code collects the TIs to move in the correct order to be moved out of the way.
//				Also we collect an array from the front and from the back to work out the most efficent way
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lSourceContainer			: CM_Container;
	index						: Integer;
	sourceIs40					: Boolean;
	tisFront, tisBack 			: CM_TIArray;
	location,
	location40					: CM_LocationsController;
	area						: CM_GridArea;
	targetAccess,
	targetAccess40				: Integer;
		
begin


	if not sourceTI.isKindOf(CM_Container) then	
		return;
	endif;
	
	lSourceContainer := sourceTI.CM_Container;
	// we are going to use these 2 arrays to work out the most efficent way to get to the TI to be moved
	create tisFront transient;
	create tisBack transient;

	sourceIs40 := lSourceContainer.requiresMoreThan1TwentyLC();// PAR 16415 CCMS 1029
	tisInTheWay.clear;

	// ##########################
	// Allow access to the source column
	// ##########################

	self.getLCsRestrictingAccess(lSourceContainer,sourceIs40,true,tisFront,tisBack);
	
	if self.accessBack and self.accessFront then
	elseif self.accessBack then
		_workingFromTheFront := false;
		tisBack.copy(tisInTheWay);
		return;
	elseif self.accessFront then
		_workingFromTheFront := true;
		tisFront.copy(tisInTheWay);
		return;
	endif;
	
	// which ever is the smallest is the more efficient
	if (tisFront.size &lt; tisBack.size) then
		tisFront.copy(tisInTheWay);
		_workingFromTheFront := true;
		//_autoPlan.addLogEntry('Front because less tis', IsForLogging); //- cnwmd1, Par 20524\
		_autoPlan.addLogEntry(app.getErrorString(Front_because_less), IsForLogging, Front_because_less);
	elseif (tisBack.size &lt; tisFront.size) then
		tisBack.copy(tisInTheWay);
		_workingFromTheFront := false;
		//_autoPlan.addLogEntry('Back because less tis', IsForLogging); //- cnwmd1, Par 20524
		_autoPlan.addLogEntry(app.getErrorString(Back_because_less), IsForLogging, Back_because_less);
	else
	
		// They are the same. See if we can determine which way the target is accessed from.
		location := lSourceContainer.getPrimaryLocation(QUEUE_MODE);
		// Are we in the same terminal area.
		if location.myTerminalArea = self then
			// Get target access.
			targetAccess := lSourceContainer.myTerminalArea.isAccessRestricted(false, location, null,null); // What is their  access like - front, back or both?
			if sourceIs40 then
				location40 := location.CM_StackController.myNextController;
				targetAccess40 := location40.myTerminalArea.isAccessRestricted(false, location40, null,null);
			endif;
			// Are we front or back.
			if targetAccess = TA_ACCESS_BACK and (targetAccess40 = TA_ACCESS_BACK or targetAccess40 = 0) then
				tisBack.copy(tisInTheWay);
				_workingFromTheFront := false;
				//_autoPlan.addLogEntry('Back because have back access and tis are equal', IsForLogging);
				_autoPlan.addLogEntry(app.getErrorString(Back_becau_have_back_acces_equ), IsForLogging, Back_becau_have_back_acces_equ);
				return;
			elseif targetAccess = TA_ACCESS_FRONT  and (targetAccess40 = TA_ACCESS_FRONT or targetAccess40 = 0) then
				tisFront.copy(tisInTheWay);
				_workingFromTheFront := true;
				//_autoPlan.addLogEntry('Front because have front access and tis are equal', IsForLogging); //- cnwmd1, Par 20524
				_autoPlan.addLogEntry(app.getErrorString(Front_becau_have_front_acces_e), IsForLogging, Front_becau_have_front_acces_e);
				return;
			elseif targetAccess = TA_ACCESS_FRONT_BACK then
				if targetAccess40 = TA_ACCESS_BACK then	
					tisBack.copy(tisInTheWay);
					_workingFromTheFront := false;
					//_autoPlan.addLogEntry('Back because we are going off 40', IsForLogging); //- cnwmd1, Par 20524
					_autoPlan.addLogEntry(app.getErrorString(Back_because_going), IsForLogging, Back_because_going);
					return;
				elseif targetAccess40 = TA_ACCESS_FRONT then
					tisFront.copy(tisInTheWay);
					_workingFromTheFront := true;
					//_autoPlan.addLogEntry('Front because we are going off 40', IsForLogging);
					return;
				endif;
			endif;
		endif;
		// Couldn't determine from access so get closest end.
		location	:= lSourceContainer.getPrimaryLocation(REAL_MODE);	
		area		:= location.myTerminalArea.CM_GridArea;
		index := area.allGridRows.indexOf(location.CM_GridController.myGridRow);
		if index &lt; (area.allGridRows.size / 2) then
			tisBack.copy(tisInTheWay);
			_workingFromTheFront := false;
			//_autoPlan.addLogEntry('Back because we are closer to back', IsForLogging); //- cnwmd1, Par 20524
			_autoPlan.addLogEntry(app.getErrorString(Back_because_closer_back), IsForLogging, Back_because_closer_back);
		else
			tisFront.copy(tisInTheWay);
			_workingFromTheFront := true;
			//_autoPlan.addLogEntry('Front because we are closer to front', IsForLogging); //- cnwmd1, Par 20524
			_autoPlan.addLogEntry(app.getErrorString(Front_because_closer_front), IsForLogging, Front_because_closer_front);
		endif;
	endif;


epilog

	delete tisFront;
	delete tisBack;
end;</source>
        <Parameter name="_autoPlan" type="CMIF_AutoMovePlan"/>
        <Parameter name="sourceTI" type="CM_TrackedItem"/>
        <Parameter name="tisInTheWay" type="CM_TIArray" usage="io"/>
        <Parameter name="_workingFromTheFront" type="Boolean" usage="output"/>
    </JadeMethod>
