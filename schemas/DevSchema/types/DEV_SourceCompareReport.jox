    <JadeMethod name="addAttribute" id="0307dc44-5e24-4fb9-9e7e-496cd9d5fc1c">
        <source>addAttribute(_schemaName 	: String; 
				_attribute 	: DEV_Attribute;
				_reason 	: Integer);
/*

Purpose:			Adds an attribute to our report

Parameters:			_schemaName:	String			The name of the schema the attribute is associated with
					_attribute:		DEV_Attribute	The transient object we need to get our data from
					_reason:		Integer			Reason for adding the Attribute to the report either 1 (Missing) or 2 (Different)

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchema 			: DEV_Schema;
	devClass 			: DEV_Class;
	newAttribute 		: DEV_Attribute;
	modifiedTimeStamp 	: LSModifiedTimeStamp;
	
begin
	//Get Schema
	devSchema 	:= self.allSchemas.getAtKey(_schemaName);
	
	devClass 	:= devSchema.allClasses.getAtKey(_attribute.myClass.name);
	
	//Create timestamp object
	create modifiedTimeStamp transient;
	modifiedTimeStamp.setProperties(_attribute.modifiedBy, _attribute.modifiedVersion, _attribute.patchVersion, _attribute.modifiedTimeStamp);
	
	//else create the global constant category
	beginTransaction;
		newAttribute := create DEV_Attribute(_attribute.name, _attribute.type, _attribute.miscData, _attribute.documentationTextData, _attribute.length, _attribute.precision, _reason, devClass) persistent;
		newAttribute.setLastModifiedTimeStamp(modifiedTimeStamp);
	commitTransaction;
	
epilog
	delete modifiedTimeStamp;

end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_attribute" type="DEV_Attribute"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addClass" id="bac58d17-7d59-4987-bc61-2a5835478a5b">
        <source>addClass(_schemaName 	: String;
			_class 		: DEV_Class;
			_reason 	: Integer);
/*

Purpose:			Adds a class to our report

Parameters:			_schemaName:	String		The name of the schema the class is associated with
					_class:			DEV_Class	The transient object we need to get our data from
					_reason:		Integer		Reason for adding the Class to the report either 1 (Missing) or 2 (Different)

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchema 			: DEV_Schema;
	newClass 			: DEV_Class;
	modifiedTimeStamp 	: LSModifiedTimeStamp;
	
begin
	//Get Schema
	devSchema := self.allSchemas.getAtKey(_schemaName);
	
	//Check if category exists in schema all categories
	//If it does then return without doing anything
	if devSchema.allClasses.getAtKey(_class.name) &lt;&gt; null then
		return;
	endif;
	
	//Create timestamp object
	create modifiedTimeStamp transient;
	modifiedTimeStamp.setProperties(_class.modifiedBy, _class.modifiedVersion, _class.patchVersion, _class.modifiedTimeStamp);
	
	//else create the global constant category
	beginTransaction;
		newClass := create DEV_Class(_class.name, _class.documentationTextData, _class.isInterface, _reason, devSchema, null) persistent;
		newClass.update(_class.documentationTextData, _class.webServicesClassPropertiesText, _class.webServicesMethodDefinitionsText, _class.implementInterfacesText, _class.isInterface);
		newClass.setLastModifiedTimeStamp(modifiedTimeStamp);
	commitTransaction;
	
epilog
	delete modifiedTimeStamp;

end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_class" type="DEV_Class"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addConstant" id="415e07e1-85d5-4685-885c-17a0e759a4c3">
        <source>addConstant(_schemaName : String; 
			_constant 	: DEV_ClassConstant;
			_reason 	: Integer);
/*

Purpose:			Adds a constant to our report

Parameters:			_schemaName:	String			The name of the schema the constant is associated with
					_constant:		DEV_Constant	The transient object we need to get our data from
					_reason:		Integer			Reason for adding the Constant to the report either 1 (Missing) or 2 (Different)

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchema 			: DEV_Schema;
	devClass 			: DEV_Class;
	newConstant 		: DEV_ClassConstant;
	modifiedTimeStamp 	: LSModifiedTimeStamp;
	
begin
	//Get Schema
	devSchema := self.allSchemas.getAtKey(_schemaName);
	
	devClass := devSchema.allClasses.getAtKey(_constant.myClass.name);
	
	//Create timestamp object
	create modifiedTimeStamp transient;
	modifiedTimeStamp.setProperties(_constant.modifiedBy, _constant.modifiedVersion, _constant.patchVersion, _constant.modifiedTimeStamp);
	
	//else create the global constant category
	beginTransaction;
		newConstant := create DEV_ClassConstant(_constant.name, _constant.type, _constant.value, _constant.documentationTextData, _constant.miscData, _constant.delimiter, _reason, devClass) persistent;
		newConstant.setLastModifiedTimeStamp(modifiedTimeStamp);
	commitTransaction;
	
epilog
	delete modifiedTimeStamp;

end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_constant" type="DEV_ClassConstant"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addGcCategory" id="5244d622-8fc1-48cc-b82f-ff671ec69db4">
        <source>addGcCategory(_schemaName 				: String;
				_globalConstantCategory : DEV_GlobalConstantCategory;
				_reason 				: Integer);
/*

Purpose:			Adds a global constant category to our report

Parameters:			_schemaName:				String						The name of the schema the global constant category is associated with
					_globalConstantCategory:	DEV_GlobalConstantCategory	The transient object we need to get our data from
					_reason:					Integer						Reason for adding the Constant to the report either either 0 (Linking object), 1 (Missing) or 2 (Different)

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchema 					: DEV_Schema;
	newGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	modifiedTimeStamp 			: LSModifiedTimeStamp;
	
begin
	//Get Schema
	devSchema := self.allSchemas.getAtKey(_schemaName);
	
	//Check if category exists in schema all categories
	//If it does then return without doing anything
	if devSchema.allGlobalConstantCategories.getAtKey(_globalConstantCategory.name) &lt;&gt; null then
		return;
	endif;
	
	//Create timestamp object
	create modifiedTimeStamp transient;
	modifiedTimeStamp.setProperties(_globalConstantCategory.modifiedBy, _globalConstantCategory.modifiedVersion, _globalConstantCategory.patchVersion, _globalConstantCategory.modifiedTimeStamp);
	
	//else create the global constant category
	beginTransaction;
		newGlobalConstantCategory := create DEV_GlobalConstantCategory(_globalConstantCategory.name, _globalConstantCategory.documentationTextData, _reason, devSchema, null) persistent;
		newGlobalConstantCategory.setLastModifiedTimeStamp(modifiedTimeStamp);
	commitTransaction;
	
epilog
	delete modifiedTimeStamp;
	
end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_globalConstantCategory" type="DEV_GlobalConstantCategory"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addGlobalConstant" id="e9965af9-361f-44be-9479-6db3f4b983e2">
        <source>addGlobalConstant(_schemaName 		: String;
					_globalConstant : DEV_GlobalConstant;
					_reason 		: Integer);
/*

Purpose:			Adds a global constant to our report

Parameters:			_schemaName:		String				The name of the schema the global constant is associated with
					_globalConstant:	DEV_GlobalConstant	The transient object we need to get our data from
					_reason:			Integer				Reason for adding the Constant to the report either 1 (Missing) or 2 (Different)

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchema 					: DEV_Schema;
	devGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	newGlobalConstant 			: DEV_GlobalConstant;
	modifiedTimeStamp 			: LSModifiedTimeStamp;
	
begin
	//Get Schema
	devSchema := self.allSchemas.getAtKey(_schemaName);
	
	devGlobalConstantCategory := devSchema.allGlobalConstantCategories.getAtKey(_globalConstant.myGcCategory.name);
	
	//Create timestamp object
	create modifiedTimeStamp transient;
	modifiedTimeStamp.setProperties(_globalConstant.modifiedBy, _globalConstant.modifiedVersion, _globalConstant.patchVersion, _globalConstant.modifiedTimeStamp);
	
	beginTransaction;
		newGlobalConstant := create DEV_GlobalConstant(_globalConstant.name, _globalConstant.type, _globalConstant.value, _globalConstant.documentationTextData, _reason, devGlobalConstantCategory) persistent;
		newGlobalConstant.setLastModifiedTimeStamp(modifiedTimeStamp);
	commitTransaction;
	
epilog
	delete modifiedTimeStamp;
	
end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_globalConstant" type="DEV_GlobalConstant"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMethod" id="113d3ec0-e95b-4a81-93f8-ed9e19f1b28d">
        <source>addMethod(_schemaName 	: String; 
			_method 	: DEV_Method;
