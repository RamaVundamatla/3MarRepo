    <JadeMethod name="initialiseForm" id="49680c6b-5986-4d0b-8aa3-8cf06b5642f6">
        <updating/>
        <source>initialiseForm()updating;
//12 January 2009	cnwdw1	
//
vars
	rule: CM_YADeckingRule;
begin
	if self.myProxyDeckingOptions = null then
		return;
	endif;
	
	self.optByStackIn.value := true;
	self.optStkIncreasIn.value := true;
	self.optRowIncreasIn.value := true;
	self.optColumnwiseIn.value := true;
	if self.myProxyDeckingOptions.isAdvanced(DeckingDirectionIn) then
		rule := self.myProxyDeckingOptions.getAdvancedRule(DeckingDirectionIn); 
		if rule.areaRule = DeckingRule_ByStackFill then
			self.chkStkFillIn.value := true;
			self.optByStackIn.value := true;
		endif;
		if rule.areaRule = DeckingRule_ByStack then
			self.optByStackIn.value := true;
		endif;
		if rule.areaRule = DeckingRule_ByRowFill then
			self.chkRowFillIn.value := true;
			self.optByRowIn.value := true;
		endif;
		if rule.areaRule = DeckingRule_ByRow then
			self.optByRowIn.value := true;
		endif;
		if rule.areaRule = DeckingRule_Custom then
			self.optCustomIn.value := true;
		endif;
		
		if rule.stackRule = DeckingRule_Increasing then
			self.optStkIncreasIn.value := true;
		endif;
		if rule.stackRule = DeckingRule_Decreasing then
			self.optStkDecreasIn.value := true;
		endif;
		if rule.stackRule = DeckingRule_MiddleOut then
			self.optStkMiddleOutI.value := true;
		endif;

		if rule.rowRule = DeckingRule_Increasing then
			self.optRowIncreasIn.value := true;
		endif;
		if rule.rowRule = DeckingRule_Decreasing then
			self.optRowDecreasIn.value := true;
		endif;
		if rule.rowRule = DeckingRule_MiddleOut then
			self.optRowMiddleOutI.value := true;
		endif;
		
		if rule.patternRule = DeckingRule_Columnwise then		
			self.optColumnwiseIn.value := true;
		endif;
		if rule.patternRule = DeckingRule_Tierwise then
			self.optTierwiseIn.value := true;
		endif;
		if rule.patternRule = DeckingRule_Topup then
			self.optTopupIn.value := true;
			self.txtTopupTierIn.text := rule.topupTier.String;
		endif;
		if rule.patternRule = DeckingRule_SideToSide then
			self.optSideToSideIn.value := true;
		endif;
		
	else
		if self.myProxyDeckingOptions.inOptionType = DeckingRule_Custom then
			self.optCustomIn.value := true;
		endif;
	endif;
	self.chkOutUseRevOfIn.value := self.myProxyDeckingOptions.isReverseOut;

	//set options for out sheet
	self.optByStackOut.value := true;
	self.optStkIncreasOut.value := true;
	self.optRowIncreasOut.value := true;
	self.optColumnwiseOut.value := true;	
	if self.myProxyDeckingOptions.isAdvanced(DeckingDirectionOut) then
		rule := self.myProxyDeckingOptions.getAdvancedRule(DeckingDirectionOut); 
		if rule.areaRule = DeckingRule_ByStackFill then
			self.chkStkFillOut.value := true;
			self.optByStackOut.value := true;
		endif;
		if rule.areaRule = DeckingRule_ByStack then
			self.optByStackOut.value := true;
		endif;
		if rule.areaRule = DeckingRule_ByRowFill then
			self.chkRowFillOut.value := true;
			self.optByRowOut.value := true;
		endif;
		if rule.areaRule = DeckingRule_ByRow then
			self.optByRowOut.value := true;
		endif;
		if rule.areaRule = DeckingRule_Custom then
			self.optCustomOut.value := true;
		endif;
		
		if rule.stackRule = DeckingRule_Increasing then
			self.optStkIncreasOut.value := true;
		endif;
		if rule.stackRule = DeckingRule_Decreasing then
			self.optStkDecreasOut.value := true;
		endif;
		if rule.stackRule = DeckingRule_MiddleOut then
			self.optStkMiddleOutO.value := true;
		endif;

		if rule.rowRule = DeckingRule_Increasing then
			self.optRowIncreasOut.value := true;
		endif;
		if rule.rowRule = DeckingRule_Decreasing then
			self.optRowDecreasOut.value := true;
		endif;
		if rule.rowRule = DeckingRule_MiddleOut then
			self.optRowMiddleOutO.value := true;
		endif;
		
		if rule.patternRule = DeckingRule_Columnwise then
			self.optColumnwiseOut.value := true;
		endif;
		if rule.patternRule = DeckingRule_Tierwise then
			self.optTierwiseOut.value := true;
		endif;
		if rule.patternRule = DeckingRule_Topup then
			self.optTopupOut.value := true;
			self.txtTopupTierOut.text := rule.topupTier.String;
		endif;
		if rule.patternRule = DeckingRule_SideToSide then
			self.optSideToSideOut.value := true;
		endif; 
		
	else
		if self.myProxyDeckingOptions.outOptionType = DeckingRule_Custom then
			self.optCustomOut.value := true;
		endif;
	endif;	

	if self.myYaBlock &lt;&gt; null then
		self.caption := self.caption &amp; "  " &amp; self.myYaBlock.getYAMDisplay(false); 
	elseif self.myTerminalArea &lt;&gt; null then
		self.caption := self.caption &amp; "  " &amp; self.myTerminalArea.id; 
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		self.optCustomIn.enabled := false;
		self.optCustomOut.enabled := false;
		self.btnCustomIn.enabled := false;
		self.btnCustomOut.enabled := false;
	endif;

	self.showForm();
	
	//hide the toolbar
	self.frmToolbar.top := -100;
end;</source>
    </JadeMethod>
