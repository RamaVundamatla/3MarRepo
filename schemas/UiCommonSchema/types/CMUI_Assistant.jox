    <JadeMethod name="displayEntryTerminalArea" id="de1c2163-2a8b-4d8f-b82f-be4bc079282c">
        <source>displayEntryTerminalArea(pTerminal : CM_Terminal; pTerminalArea : CM_TerminalArea) : String;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pTerminal = null or pTerminalArea = null then
		return null;
	endif;
	
	if pTerminalArea.myTerminal &lt;&gt; pTerminal then
		return null;
	endif;

	if pTerminalArea.myType.isGantryInterchangeArea then
		return pTerminalArea.getDisplayName(false);
	endif;
	
	if pTerminalArea.type = TA_TYPE_BLOCK_STACK or 
	   pTerminalArea.type = TA_TYPE_SUBBLOCK_STACK then
		return pTerminalArea.id &amp; ' ' &amp; pTerminalArea.getMenuDetails(false,REAL_MODE);
	endif;
	
	
	return pTerminalArea.id;
	

end;</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
