    <JadeMethod name="eprTestCGValidateForAssign" id="388d1be5-2873-41d8-96f5-df5df524f4b9">
        <source>eprTestCGValidateForAssign();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2021	jlier1	Initial creation

*/

vars
	cg : CM_CargoGroup;
	cga : CM_CargoGroupAssignment;
	c : CM_TrackedItem;
	_nextCargoGroup : CM_CargoGroup ;
	_newLocation :CM_LocationsController ; 
	_completeGroup : Boolean ;
	_addToGroup : Boolean ;
	_clearCargoGroup : Boolean ;
	_clearLocation : Boolean ;
	strArray : StringArray;
begin
	cga:= "12774.6873".asOid.CM_CargoGroupAssignment;
	cg:="12712.42506".asOid.CM_CargoGroup;
	c:="2367.42143301".asOid.CM_TrackedItem;
	create strArray transient;
	if cga.getNotYetScanned( strArray, false ) = 1 then
		write strArray.first;
	endif;
	
	write cg.isSelectable.String;
	write cg.validateForAssignMove(cga,c,_nextCargoGroup,_newLocation,_completeGroup,_addToGroup,_clearCargoGroup,_clearLocation);
	
	write _completeGroup.String;
	write _addToGroup.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestCamResend" id="72331caa-2e2e-4a50-bf59-790a22c46c1c">
        <source>eprTestCamResend();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2023	jlier1	Initial creation

*/

vars
	_camHistory : CM_CamTaskHistory;
	camHistory : String;
	pos ,msgCount,_resendIndex: Integer;
	msg : String;
begin
_camHistory:="2181.2057019".asOid.CM_CamTaskHistory;
_resendIndex:=1;
	camHistory := _camHistory.getRawDataString();
	write camHistory.length;
	write camHistory;
	pos :=41592450;
	
	msg := camHistory.scanUntil(Cr, pos);
	write pos;
	return ;
	while true do		
		pos += 1;
		 //jlier1 TFS 59815 15/8/23
		msg:=null;
		if camHistory &lt;&gt; null then
			msg := camHistory.scanUntil(Cr, pos);
		endif;
	//	write msg;
		write method.qualifiedName &amp; " CamHistory "  &amp; _camHistory.getOidAsString &amp; " position: " &amp; pos.String;
		
		msgCount += 1;
		//jlier1 TFS 58637 20/6/23
		if _resendIndex &gt; 0 then
			//we are resending only send the message we are interested in - usually the one that failed
			if msgCount &lt;&gt; _resendIndex then
				write method.qualifiedName &amp; " Message " &amp; msgCount.String &amp; ": ignored. Only resending " &amp; _resendIndex.String;
				if pos = 0 then
					break;
				endif;
				continue;
			endif;
		endif;
		//agent.setMsgIndex(msgCount);
		write method.qualifiedName &amp; " Message " &amp; msgCount.String &amp; ": " &amp; msg;
	
		// send this to the endpoint
		//app.writeLog(method.qualifiedName &amp; " Sending CAMS to : " &amp; serviceDef.name, LogINFO);
		//response := agent.doSendHTTPRequest(qualifiedEndpoint, verb, agent.getAdditionalHeadersForHTTP(), msg, responseCode);	// TFS 57207
		
		//if responseCode = null or not responseCode.isOneOf(HttpResponseOK, HttpResponseCreated) then
		//	app.writeLog(method.qualifiedName &amp; " FAILED: Response from " &amp; serviceDef.name &amp; " was " &amp; responseCode.String &amp; ":" &amp; response, LogERROR);
		//else
		//	app.writeLog(method.qualifiedName &amp; " Response from " &amp; serviceDef.name &amp; " was " &amp; responseCode.String &amp; ":" &amp; response, LogINFO);
		//endif;
		
		if pos = 0 or pos = 20 then
			break;
		endif;
		
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestCams" id="63ea09ea-143a-4b16-a38e-473b2c9bedab">
        <source>eprTestCams();
/*

Date		Who		Reason
18 December 2014	cnwer1	Initial creation PAR

*/


// You can edit this one! Don't bother copying it first. Basically the only things you need
// to modify are the start timestamp, the end timestamp, and the protocol name. - cnwgb1 19.5.09
// cnwsh3 19/01/2010 - modify the details in constants to run a cam protocol.
//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
constants
	//CAMProtocol : String = "Trans";
	//CAMProtocol : String = "test";
	CAMProtocol : String = "Chestnut EDI";
	StartDate	: Date = '3/09/2015'.Date;// setup start and end dates/time and protocol to use
	StartTime	: Time = '06:00:00:000'.Time;
	EndTime		: Time = '14:00:00:000'.Time;
	Terminal1	: String = 'JBL';
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
	adhocRunForm 	: CMUI_CamsAdhocRun;
	camTaskHistory : CM_CamTaskHistory;
	
begin
	app.initialize();
	terminal		:= app.myRoot.allTerminals[Terminal1];
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode("CNWER1");
	adhocRunForm:=app.loadForm(CMUI_CamsAdhocRun,CMUI_Assistant,false, true, true, terminal, null).CMUI_CamsAdhocRun;

epilog
	

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestCargoPriority" id="d3deecc1-2b0b-4019-b6e2-cd04104bd1b8">
        <source>eprTestCargoPriority();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2023	jlier1	Initial creation

*/

vars
	start ,diff: Decimal  [20];
	customerPriority , lowest		: CM_CustomerPriority;
	customerPriorityColl	: DynaDictionary;
begin

	app.initialize;
	start := app.relativeMachineMicros();
	
		create customerPriorityColl transient;
		customerPriorityColl.setMembership(CM_CustomerPriority);
		customerPriorityColl.addMemberKey(CM_CustomerPriority::priority.name, false, false);					
		customerPriorityColl.endKeys(true);					
		app.myRoot.allCustomerPriorities.copy(customerPriorityColl);		
		customerPriority  := customerPriorityColl.last().CM_CustomerPriority;
	diff := app.relativeMachineMicros() - start;
	write diff;
	start := app.relativeMachineMicros();
	
	foreach customerPriority in app.myRoot.allCustomerPriorities where customerPriority.priority &lt;&gt; 0 do
		if lowest = null or customerPriority.priority &gt; lowest.priority then
			lowest:=customerPriority;
		endif;
	endforeach;
//	write lowest.priority;
	
	diff := app.relativeMachineMicros() - start;
	write diff;
	
epilog
	delete customerPriorityColl;
end;</source>
    </JadeMethod>
