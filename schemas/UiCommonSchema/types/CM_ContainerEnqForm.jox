    <JadeMethod name="doMenuRequestTaskClick" id="1797dde9-4d90-428f-9a31-794e34ee61da">
        <source>doMenuRequestTaskClick();
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	tiSet			: CM_TISet;
	obj				: Object;
	form			: CM_BaseForm;
begin
	// get all selected cargo items 
	create tiSet transient;
	
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance(obj) then
			tiSet.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	
	form := app.loadForm (CMUI_JobRequestForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_BaseForm;
	
	form.displaySelectorResults (tiSet, null);
	
	form.show;
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMenuTaskAddClick" id="fe2acfc0-465a-4b22-9c23-c35443ad16ce">
        <updating/>
        <source>doMenuTaskAddClick(_taskDesc: CM_ToDoTaskDesc) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti				: CM_TrackedItem;
	tiSet			: CM_TISet;
	obj				: Object;
	result			: Integer;
begin

	ti := self.myCurrentObject.CM_TrackedItem;
	// get all selected cargo items to add or remove stop from all.
	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance(obj) then
			tiSet.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	
	if (not tiSet.includes(ti)) then
		tiSet.add(ti);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(_taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; _taskDesc.description &amp; ' added to ' &amp; tiSet.size.String &amp; ' item(s).', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doMenuTaskCompleteClick" id="5b5f5394-484a-463a-a625-b6d2404c974b">
        <updating/>
        <source>doMenuTaskCompleteClick(_taskDesc: CM_ToDoTaskDesc) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
22/11/2018  	JLGNS1	ChangeRequest 39691: SNO- VGM Gate Process
*/
vars

	ti			    	: CM_TrackedItem;
	realTiSet			: CM_TISet;
	pxyTiSet			: CM_TISet;

	result				: Integer;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	pxyTI, ti1			: CM_TrackedItem;
	match				: Boolean;

begin

	// get all selected cargo items to add or remove stop from all.
	create realTiSet transient;
	if not tblData.allSelectedObjects.isEmpty then
		tblData.allSelectedObjects.copy(realTiSet);
	endif;
	
	ti  := self.myCurrentObject.CM_TrackedItem;

	if ti = null and realTiSet.isEmpty then
		return;
	endif;
	
	create pxyTiSet transient;
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( _taskDesc.code, pxyTiSet, ti, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
			

	//perform the updating
	while true do
		//cnwjo3 par 25879
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(_taskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window

			if self.ackTodoStop then
				app.msgBox(app.getErrorString2(Completed_for,_taskDesc.description,realTiSet.size.String), app.getString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
				
			endif;
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;

epilog
	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	
	delete realTiSet;

	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge;
		delete resourceUsageProxys;
	endif;
end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doMenuTaskRemoveClick" id="55d24cda-ac01-4133-8b94-b51bc5ccc019">
        <updating/>
        <source>doMenuTaskRemoveClick(_taskDesc: CM_ToDoTaskDesc) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti				: CM_TrackedItem;
	tiSet			: CM_TISet;
	obj				: Object;
	result			: Integer;
begin
	
	ti := self.myCurrentObject.CM_TrackedItem;
	// get all selected cargo items to add or remove stop from all.
	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance(obj) then
			tiSet.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	
	if (not tiSet.includes(ti)) then
		tiSet.add(ti);
	endif;

	//result := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	result := app.msgBox('Are you sure you want to remove task ' &amp;
			_taskDesc.description &amp; ' from ' &amp; tiSet.size.String &amp; ' item(s)?', 
			app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if result = MsgBox_Return_No then
		return;
	endif;

	while true do
		app.myTrxUA.trxUpdateTIToDoTaskRemBulk(_taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; _taskDesc.description &amp; ' removed from ' &amp; tiSet.size.String &amp; ' item(s).', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Remove Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;


epilog
	delete tiSet;
end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doMenuUnassignClick" id="3a15cb7a-a1bc-45e2-937a-525cc57101e6">
        <updating/>
        <source>doMenuUnassignClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	anObject	: Object;
	theTI : CM_TrackedItem;
	brCode				: String;
	tiSet				: CM_TISet;
	realBulkRelease		: CM_BulkRelease;
	tbl					: CM_DataTable;
	passport			: CM_Passport;
	idStr				: String;
	ti					: CM_TrackedItem;
	idx					: Integer;
	realMenu : MenuItem;
	brID : String;
	theReturn : Integer;
begin
	realMenu := menuItem.description.asOid.MenuItem;
	
	if realMenu = null then
		return;
	endif;
	anObject := realMenu.userObject;
	
	if not anObject.isKindOf(MenuItem) then
		return;
	endif;
	anObject := anObject.MenuItem.userObject;
	
	if not anObject.isKindOf(CM_TrackedItem) then
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	theTI := anObject.CM_TrackedItem;
	
	if (not theTI.isHeldForRelease) then
		return;
	endif;
	
	brID := theTI.allBulkReleasesAssigned.getAtKeyGeq(null,BR_ACTIVE,null,null).code;
	
	create tiSet transient;
	tiSet.add(theTI);
	
	passport := app.myPassport;
	
	while true do
		app.myTrxUA.trxUpdateUnassignRelease(tiSet, passport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			app.msgBox(theTI.id &amp; ' has been successfully unassigned from Bulk Release ' &amp; brID, 'Release unassign completed...', MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog("Bulk Release assignment update", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	
epilog
	delete tiSet;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuAreaFullClick" id="1c6e06fc-3049-4342-9caa-56d09b610e0a">
