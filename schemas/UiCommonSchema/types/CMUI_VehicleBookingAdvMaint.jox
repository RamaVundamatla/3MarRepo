/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
03 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
*/

vars

	carrier : CM_Carrier;
	driver 	: CM_DriverDetails;
	idx 	: Integer;

begin

	carrier := self.cmbCarrier.listObject.CM_Carrier;
	driver  := self.cmbDriver.listObject.CM_DriverDetails;
	idx 	:= self.cmbSubCarrier.findObject(self.cmbCarrier.listObject.CM_Carrier);
	
	if self.myProxyVehicleBookingTimeSlot&lt;&gt; null then
		self.myProxyVehicleBookingTimeSlot.setCarrier(carrier);			//03.08.2023 navma1 #59263
	endif;
	
	if idx &gt; 0 then
		self.cmbSubCarrier.listIndex := idx;
	endif;
	
	self.setupDriverCombo( carrier, driver );

epilog

end;</source>
