    <JadeMethod name="doInitializeWithTI" id="18bdb591-64ca-4d74-b2a2-bc5a4cd62977">
        <updating/>
        <source>doInitializeWithTI(_anArea : CM_TerminalArea;_aLocation : CM_LocationsController; _aTI : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwrd1	Initial creation
01/05/2010	cnwmh5	Par23880 - if initialize myInitializeObject then we need to
					update the screen details from this as is loading data for 
					first time
*/

vars
	theTA : CM_TerminalArea;
	theLC : CM_LocationsController;
begin
	if _aLocation.isKindOf(CM_LocationsController) then
		theLC := _aLocation.CM_LocationsController;

		theTA := theLC.myTerminalArea;
		
		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_IrregularBlockArea) then
			self.myInitializeObject := theTA.CM_IrregularBlockArea;
			self.myInitializeLocation := theLC;
			self.myInitializeTI := _aTI;
		endif;
	elseif _anArea.isKindOf(CM_IrregularBlockArea) then
		theTA := _anArea.CM_IrregularBlockArea;

		if theTA = null then
			return;
		endif;
		
		if theTA.isKindOf(CM_IrregularBlockArea) then
			self.myInitializeObject := theTA.CM_IrregularBlockArea;
		endif;
	endif;
	
	// 10/05/2010 cnwmh5 #23880 - Start
	// have a CM_IrregularBlockArea and myInitializeObject &lt;&gt; null so now load areas details
	if theTA.isKindOf(CM_IrregularBlockArea) and self.myInitializeObject &lt;&gt; null then
		self.myCurrentTerminalArea := self.myInitializeObject;
		self.setupFormFromAreaSelector();
	endif;
	// 10/05/2010 cmwnh5 #23880 - End
	
end;</source>
        <Parameter name="_anArea" type="CM_TerminalArea"/>
        <Parameter name="_aLocation" type="CM_LocationsController"/>
        <Parameter name="_aTI" type="CM_TrackedItem"/>
    </JadeMethod>
