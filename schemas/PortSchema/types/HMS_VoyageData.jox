    <JadeMethod name="getVesselIsTramper" id="f0e4c49f-28fa-4a8e-970d-260456108295">
        <source>getVesselIsTramper():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2018	jlgndl1	Initial creation	TFS  40778

*/

vars

	vessel : CM_Vessel;
	vesselData : HMS_VesselData;

begin

	if self.myVoyage &lt;&gt; null then
		vessel := self.myVoyage.myVessel;
		if vessel &lt;&gt; null then
			vesselData := vessel.myHMSVesselData;
			if vesselData &lt;&gt; null then
				return vesselData.isTramper;
			endif;
		endif;
	endif;
		
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
