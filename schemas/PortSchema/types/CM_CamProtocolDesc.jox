    <JadeMethod name="includeEvent" id="b5050c67-e114-4819-85e1-0493e228f813">
        <source>includeEvent(_eventTransaction : CM_EventTransaction; _camProtocol: CM_CamProtocol;  _camAgent : CM_CamControllerAgent):Boolean;
//
//20 Apr 2016	cnwrs1	Par 37788 TFS Came 1875 Events does not check cam group operators nor cargotype list
//
vars
	ti : CM_TrackedItem;
	visit: CM_VehicleVisitRecord;
	operators : CM_Operator;
	camGroup : CM_CamGroup;
begin
	
	//epr TFS 2385 18/7/16 check cam group
	camGroup:=_camProtocol.camGroup;
	if _eventTransaction.isKindOf(CMEVT_TruckEvent) then
		visit:= _eventTransaction.CMEVT_TruckEvent.myVisit;
		if visit &lt;&gt; null then
			foreach ti in visit.allReceivedTrackedItems discreteLock do
				if _camProtocol.useTiOperator then
					if  camGroup.operators[ti.operatorCode] &lt;&gt; null then
						return true;
					endif;
				endif;
				
				if _camProtocol.useVoyageOp then
					if  camGroup.operators[ti.getVoyageOperatorCode] &lt;&gt; null then
						return true;
					endif;
				endif;
			endforeach;
			
			foreach ti in visit.allReleasedTrackedItems discreteLock do
				if _camProtocol.useTiOperator then
					if  camGroup.operators[ti.operatorCode] &lt;&gt; null then
						return true;
					endif;
				endif;
				
				if _camProtocol.useVoyageOp then
					if  camGroup.operators[ti.getVoyageOperatorCode]  &lt;&gt; null then
						return true;
					endif;
				endif;
			endforeach;
		endif;
		
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_eventTransaction, 'Event transaction ' &amp; _eventTransaction.getDisplayID &amp;  ' does not match cam group oprerator');
		endif;
		return false;
	
	endif;
	
	return true;
end;
</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
