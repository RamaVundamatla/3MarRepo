	app.setContinueCMExceptions(true);

	pProxyYardInternalJob.pxyGetRealObjectAndEdition(realYardInternalJob, expectedEdition);
	
	if realYardInternalJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YardInternalJob.name, null, null);
		return;
	endif;

	app.myValUA.valYardInternalJob(realYardInternalJob, pProxyYardInternalJob);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
