    <DbClassMap file="edi"/>
    <JadeMethod name="getDataTypeFromDefName" id="554f5de8-f79f-4987-8b07-7cefd763900f">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _name = ETDef_EDITIVoyage then
		return EDIDataType_Voyage;
	elseif _name = ETDef_EDITIPort then
		return EDIDataType_Port;
	elseif _name = ETDef_EDITIVoyageCutoff then 
		return EDIDataType_VoyageRecCutoff;
	elseif _name = ETDef_EDITIVoyageMovement then 
		return EDIDataType_VoyageMovement;
	endif;
epilog
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEDIChildDataTypes" id="8c77ef44-3f84-41ef-95fe-e7f45552d227">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	_types.add(EDIDataType_Voyage);
	_types.add(EDIDataType_Port);
