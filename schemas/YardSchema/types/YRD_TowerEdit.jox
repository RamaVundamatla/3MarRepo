	endif;

	self.doDisplayTowerTable();
	self.doDisplayContainer(self.tblContainer1,self.myContainerNext);	
	self.doDisplayContainer(self.tblContainer2,self.myContainerPrev);
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="81e0513b-f837-4402-add0-3afdd3e7cceb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008945, locale);
	btnClose.translateCaption(Xlat_0004708, locale);
	btnEdit.translateCaption(Xlat_0004709, locale);
	btnSave.translateCaption(Xlat_0004710, locale);
	shtContainer1.translateCaption(Xlat_0004711, locale);
	shtContainer2.translateCaption(Xlat_0004712, locale);
	shtTowerDetails.translateCaption(Xlat_0004713, locale);
end;</source>
    </JadeMethod>
</GUIClass>
