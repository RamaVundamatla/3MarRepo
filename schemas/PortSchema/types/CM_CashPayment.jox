    <JadeMethod name="auditIdDisplay" id="fdf0ebf9-1e98-411e-a2d2-d07caf27feb3">
        <source>auditIdDisplay(): String;
/*

Purpose: Set up the class for auditing

Parameters:			

Return Value:		

Date		Who		TFS		Reason
==========================================================
16 Jul 2019	jlgdi1	45301	Initial creation 
==========================================================
*/

constants
	OPEN_BRACE : String = '{';
	CLOSE_BRACE : String = '}';
	
vars
	desc : String;
	invalid : Boolean;
	object : Object;
begin

	on Exception do app.handleDeletedObject(exception, object, invalid); 
	desc := app.getErrorString(Cash_payment) 
		   &amp; Space &amp; Hyphen &amp; Space 
		   &amp; self.auditId();

	if self.myInvoiceLine &lt;&gt; null then // TFS 46032
		object := self.myInvoiceLine;
		desc := desc 
				&amp; Space &amp; Hyphen &amp; Space 
				&amp; OPEN_BRACE &amp; self.myInvoiceLine.auditIdDisplay() &amp; CLOSE_BRACE;
	
	elseif self.myProformaDetail &lt;&gt; null 
	and self.myProformaDetail.myInvoiceLineType &lt;&gt; null then // TFS 46032
		object := self.myProformaDetail.myInvoiceLineType;
		desc := desc 
				&amp; Space &amp; Hyphen &amp; Space 
				&amp; OPEN_BRACE &amp; 
				app.getErrorString(Proforma) &amp; Space &amp; Hyphen &amp; Space &amp; 
				self.myProformaDetail.myInvoiceLineType.narration &amp; CLOSE_BRACE;
	
	endif;
	
	if self.myTrackedItem &lt;&gt; null then 
		desc := desc 
				&amp; Space &amp; Hyphen &amp; Space 
				&amp; OPEN_BRACE &amp; self.myTrackedItem.id &amp; CLOSE_BRACE;
	endif;

	
	if self.myInvoice &lt;&gt; null then 
		desc := desc 
				&amp; Space &amp; Hyphen &amp; Space 
				&amp; OPEN_BRACE &amp; self.myInvoice.auditIdDisplay() &amp; CLOSE_BRACE;
	endif;
	
	return desc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
