    <JadeMethod name="txtBow_lostFocus" id="a76955dc-5ab2-4709-ad86-257147974c89">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBow_lostFocus(textbox: TextBox input) updating;

vars
	bow : Decimal[12,2];
begin
	if self.lastValidRow &gt; 1 then
		self.tblPrefBerth.dragMode := self.tblPrefBerth.DragMode_None;
		//bow := self.tblPrefBerth.accessCell(self.lastValidRow, self.tblPrefBerth.getColumnByRowName(ETRow_DefaultBowMark)).cellControl.TextBox.text.Decimal;	
		bow := self.tblPrefBerth.accessCell(self.lastValidRow, self.tblPrefBerth.getColumnByRowName(ETRow_DefaultBowMark)).cellControl.TextBox.text.asDecimalJMT();	//01 APR 2010	NDL	Par 23556	
		self.tblPrefBerth.accessedCell.text := bow.asStringJMT;
		self.setMeterMarks(bow, self.lastValidRow, false);
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
