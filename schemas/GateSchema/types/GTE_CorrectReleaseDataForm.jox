        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminalArea_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars
	terminalArea : CM_TerminalArea;
begin
	terminalArea := self.cmbTerminalArea.getCurrentItemObject.CM_TerminalArea;
	
	if terminalArea &lt;&gt; null then
		self.buildCmbSubTerminalAreas(terminalArea);
	endif;
epilog

end;</source>
