<Class name="WS_GAPIErrorResponse" id="c64133ff-a3ed-44d3-817a-d779d334fe48">
    <superclass name="WS_GAPIResponse"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="errorCode" id="c7e3f255-4605-401e-8530-2e0136f824f8">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="errorItem" id="265821fa-6c63-419a-b240-6e0c366cae1c">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setErrorFromPassport" id="eb3e8d20-7a8d-4e23-b941-65a8cd258390">
        <updating/>
        <source>setErrorFromPassport() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	passport 	: CM_Passport;
	error		: CM_Error;
	
begin
	passport := app.myPassport;
	if passport = null then
		return;
	endif;
	
	if passport.hasErrors and passport.allErrors.size &gt; 0 then
		error			:= passport.allErrors.first;
		self.errorCode 	:= error.errorCode;
		self.errorItem 	:= error.text;
	endif;
	
	//ToDo: Add logging for Passport Errors
	passport.clearErrorsWarnings(); //Clear errors and warnings when processed
	
epilog

end;</source>
    </JadeMethod>
</Class>
