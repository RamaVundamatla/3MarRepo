    </JadeMethod>
    <JadeMethod name="getContainerLength" id="09e46006-65eb-408a-92fe-c335d2630057">
        <source>getContainerLength() : Integer;
/*
Purpose:	28479		
Date		Who		Reason
27 October 2011	cnwab1	Initial creation
*/

vars
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;

begin
	isoType := app.myRoot.allISOTypes[self.isoType];
	if isoType &lt;&gt; null then
		if not isoType.is20ftLong then
			return 40;
		endif;
	else
		isoGroup := app.myRoot.allISOTypeGroups[self.isoTypeGroup];
		if isoGroup &lt;&gt; null then
			if not isoGroup.is20ftLong then
				return 40;
			endif;
		endif;
	endif;

	return 20;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b23aac3d-dbc4-4813-8e87-241559ce02d3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
// 23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
// 30 Apr 2019	jlgrs1		TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
// 21 Nov 2022	navma1		ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//
vars
	strSize		: Integer;
	rowName, 
	type 		: String;									
begin
	if _attrName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		else
			return "Y";
		endif;
	elseif _attrName = ETRow_StowageId then
      
		strSize := self.stowageId.length;
		/*	WAS. LOLO is Bay/Cell/Tier 6 characters, but the standard files have a leading zero, so take off. If RORO use whole ID
		if strSize &gt;= 6 then
			//hide the leading zero
			return self.stowageId[strSize-5:6];
		endif;
		NOW */
		if strSize = 7 and self.stowageId.isInteger then
			//hide the leading zero
			return self.stowageId[2:end];
		endif;
	elseif _attrName = ETRow_NewStowageId then
		strSize := self.newStowageId.length;
		/*	WAS. LOLO is Bay/Cell/Tier 6 characters, but the standard files have a leading zero, so take off. If RORO use whole ID
		if strSize &gt;= 6 then
			//hide the leading zero
			return self.newStowageId[strSize-5:6];
		endif;
		NOW */
		if strSize = 7 and self.newStowageId.isInteger then
			//hide the leading zero
			return self.newStowageId[2:end];
		endif;
	elseif _attrName = ETRow_CooledType then
		if self.cooledType = ContainerAirCooled then
			return "AC";
		elseif self.cooledType = ContainerWaterCooled then
			return "WC";
		else
			return null;
		endif;
	//elseif _attrName = ETRow_Weight then //cnwrd1 par  19701 18.5.09					//-cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_TotalWeight then											//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();
	elseif _attrName = ETRow_Height then
		return self.height.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();				
	elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then			//21.11.2022 navma1 #55424
		return self.getHazardsAsString();																		//21.11.2022 navma1 #55424	
	elseif _attrName.isMeasurementType then										// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);							// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);		// PAR #33005
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorID" id="97f87135-329e-42a1-8f9f-9c6052e24ea5">
        <source>getErrorID(): String;
//----------------------------------------------------------------
//	Created:	21 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.stowageId.length &gt; 1 then
		return self.stowageId[2:end];
	else
		return self.stowageId;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardsAsString" id="ea69cc8e-ffe5-4420-a84b-31630c507232">
        <source>getHazardsAsString(): String;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	tmpHazards : ObjectArray;
	hazards : CM_HazardByCodeDict;
	haz : CM_Hazard;
	str : String;
begin
	create tmpHazards transient;
	create hazards transient;
	if self.imCodes.isEmpty then
		return null;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);
	if hazards.isEmpty then
		return null;
	endif;
	foreach haz in hazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
	str := str[1:str.length - 2];
	return str;
epilog
	tmpHazards.purge();
	delete tmpHazards;
	delete hazards;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="91816b57-4a32-4419-a210-d3ae2f7d9e98">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
