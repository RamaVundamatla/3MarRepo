    <JadeMethod name="addToolbarControls" id="0beafd36-6696-4203-b5a0-7ea08c9cd8a8">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	23 January 2004 By: cnwgd1
// 03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint,CMUI_Toolbar.Control_Alignment_Left); // CCMS 2109 epr 27/7/11
	toolbar.addButton(self.btnSelectorShow, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnRedo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnUndo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);						
	toolbar.addButton(self.btnLock, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnWharfChanges, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTimeChanges, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNSEWChanges, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewVoyage, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSenarioVoyage, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnRoadStead, CMUI_Toolbar.Control_Alignment_Left);							
	toolbar.addButton(self.btnTidalModel, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefreshScales, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnConflicts, CMUI_Toolbar.Control_Alignment_Left);

	if   self.btnBerthUsage.visible then          //03.10.2017	cnwma1  TFS #7257
		toolbar.addButton(self.btnBerthUsage, CMUI_Toolbar.Control_Alignment_Left);		
	endif;
	if self.btnVoyageStat.visible then
		toolbar.addButton(self.btnVoyageStat, CMUI_Toolbar.Control_Alignment_Left);				
	endif;

	// PAR 16389
	//toolbar.addButton(self.btnResourcesUsed, CMUI_Toolbar.Control_Alignment_Left);		// PAR 10973
	if app.myCurrentUserCan(self.myTerminal, PmHMSVoyResUsedView) then
		toolbar.addButton(self.btnResourcesUsed, CMUI_Toolbar.Control_Alignment_Left);		// PAR 10973
	endif;
	
	self.buildResourceButtons();

	toolbar.addButton(self.btnPosDetail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);													
	toolbar.addFrame(self.frmVesselDetails, CMUI_Toolbar.Control_Alignment_Left);
			
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.addButton(self.btnSelectrSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectorReset, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectorClose, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);														
	toolbar.addFrame(self.frmSelector, CMUI_Toolbar.Control_Alignment_Left);
	chkShowVoyages.move(1, 3, chkShowVoyages.width, chkShowVoyages.height);
	frmShowVoyages.width	:=	chkShowVoyages.width + 3;
	toolbar.addFrame(frmShowVoyages, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

	//=======================================
	// now setup meterMarkToolbar
	//=======================================
	toolbar := self.frmMarksToolbar;

	toolbar.addButton(self.btnSaveExtra, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmMeterMark, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnCancel, CMUI_Toolbar.Control_Alignment_Right);			
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addVoyageToView" id="6d1f4b6f-31ea-48bf-9b6f-80e29ce91a80">
        <updating/>
        <source>addVoyageToView(_workingVoyage : CMIF_HMS_WorkingVoyage)updating;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	//Done below in self.rebuildVoyage();
