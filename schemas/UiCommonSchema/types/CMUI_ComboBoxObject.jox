    <JadeMethod name="getKeyValue" id="83420cd5-da78-4a5d-9895-cc528f9e24b2">
        <source>getKeyValue() : String protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pos	: Integer;
	tmpText,
	key	: String;

begin

	pos := 1;
	tmpText := self.text;
	if tmpText &lt;&gt; null then
		key := tmpText.scanUntil(Tab, pos);
	endif;	
	return key;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
