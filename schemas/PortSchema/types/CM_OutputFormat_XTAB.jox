    <JadeMethod name="getQueryProperty" id="587f996e-5f16-4d49-ab89-da5ad3d03e8f">
        <source>getQueryProperty(_property: String): CM_QueryProperty;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	prop	:CM_QueryProperty;
begin
	if self.type = CM_QueryDefinition.Snapshot_Query_Type then
		prop := self.myOutputFormat_SS.getQueryProperty (_property);
		
		if prop &lt;&gt; null then
			return prop;
		endif;
	endif;
	// must be one of the extra properties defined for a snapshot
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="String"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
