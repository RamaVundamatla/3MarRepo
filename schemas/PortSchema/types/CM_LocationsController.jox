        <source>getNumTIsQueuedIn(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars


begin
	return self.allQueuedFutureMoves.size;
	

epilog

