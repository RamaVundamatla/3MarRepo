    <JadeMethod name="setStorageConfigAndDetails" id="fbfeeee0-b2a7-42e1-b440-0746acd8837a">
        <source>setStorageConfigAndDetails(_updController : CnEcReleaseController);
/*

Purpose:			
		This script will be used to populate new attributes added 
			CM_StorageConfig::railReceivalType
			CM_StorageConfig::roadReceivalType
			CM_StorageConfig::unpackReceivalType
			
			CM_StorageDetail::shipReceivalType
			CM_StorageDetail::railReceivalType
			CM_StorageDetail::roadReceivalType
			CM_StorageDetail::unpackReceivalType
			
Parameters:			

Return Value:		

Date		Who		Reason
08/06/2023	navkc1	CR 58003 Task 58004: JADE - Storage Config - Upgrade Scripts

*/

vars
	storageConfig		: CM_StorageConfig;
	storageDetail		: CM_StorageDetail;
	objArray			: ObjectArray;
	allStorageDetails	: CM_StorageDetailSet;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Populating CM_StorageConfig and CM_StorageDetail", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_StorageConfig and CM_StorageDetail") ;	
	endif;
	
	create objArray transient;
	CM_StorageConfig.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach storageConfig in objArray as CM_StorageConfig do
		
		storageConfig.setPropertyValue(CM_StorageConfig::railReceivalType.name, Storage_RailActualReceival);
		storageConfig.setPropertyValue(CM_StorageConfig::roadReceivalType.name, Storage_RoadActualReceival);
		storageConfig.setPropertyValue(CM_StorageConfig::unpackReceivalType.name, Storage_UnpackActualUnpack);
		
		foreach storageDetail in storageConfig.allStorageDetails do
			storageDetail.setPropertyValue(CM_StorageDetail::shipReceivalType.name, storageConfig.shipReceivalType);
			storageDetail.setPropertyValue(CM_StorageDetail::railReceivalType.name, Storage_RailActualReceival);
			storageDetail.setPropertyValue(CM_StorageDetail::roadReceivalType.name, Storage_RoadActualReceival);
			storageDetail.setPropertyValue(CM_StorageDetail::unpackReceivalType.name, Storage_UnpackActualUnpack);
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed populating CM_StorageConfig and CM_StorageDetail", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed populating CM_StorageConfig and CM_StorageDetail") ;
	endif;
	// Defect 58828: MTN - Upgrade Script missing addScriptRun
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
	delete allStorageDetails;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setStorageDetailsFirstLastDay" id="8c3fc495-db80-4cf8-89dd-a43b00e0b7bc">
        <source>setStorageDetailsFirstLastDay(_updController : CnEcReleaseController);
/*

Purpose:			We added "includeFistDay" and "includeLastDay" options to CM_StorageDetails.
					This script will set these option based on the Storage Config.

Parameters:			

Return Value:		

Date		Who		Reason
29/02/2023	navkc1 CR 61899 Task 61902: Jade - Upgrade Script Audits

*/

vars
	storageConfig		: CM_StorageConfig;
	storageDetail		: CM_StorageDetail;
	objArray			: ObjectArray;
begin
if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Populating CM_StorageDetail", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_StorageDetail") ;	
	endif;
	
	create objArray transient;
	CM_StorageConfig.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach storageConfig in objArray as CM_StorageConfig do
		foreach storageDetail in storageConfig.allStorageDetails do
			storageDetail.setPropertyValue(CM_StorageDetail::includeFirstDay.name, storageConfig.includeFirstDay);
			storageDetail.setPropertyValue(CM_StorageDetail::includeLastDay.name,storageConfig.includeLastDay);
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed populating CM_StorageDetail", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed populating CM_StorageDetail") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setWebPackingIncludePackComp" id="cde5b35f-432e-4890-9503-c49b28ca66f9">
        <source>setWebPackingIncludePackComp(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2024	jlier1	Initial creation 66302

*/

vars
terminal : CM_Terminal;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	//this was set to true if cargo groups were enabled
	if not app.isCargoGroupEnabled then
		self.addScriptRun(method.name);
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initializing Packing Parents list - include cargo that are Pack Complete config", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing Packing Parents list - include cargo that are Pack Complete config") ;	
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig(WebIncludePackComplete, true);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Initializing Packing Parents list - include cargo that are Pack Complete configg complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Initializing Packing Parents list - include cargo that are Pack Complete config complete") ;
	endif;

	self.addScriptRun(method.name);
	

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
