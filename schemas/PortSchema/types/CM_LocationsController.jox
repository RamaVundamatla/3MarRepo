    <JadeMethod name="getMySubTerminalAreaDef" id="80caaa83-ee33-48f1-98b1-3e6a5d1079e7">
        <source>getMySubTerminalAreaDef(): CM_SubTerminalAreaDef;
/*

Purpose:			

Parameters:		Needed until we can reorg a reference on Locations Controller.		

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	subTermAreaDef : CM_SubTerminalAreaDef;
	iter : Iterator;
	gridObject : CM_GridObject;

begin

	if self.mySubTerminalAreaDef &lt;&gt; null then
		return self.mySubTerminalAreaDef;
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		subTermAreaDef := self.myTerminalArea.mySubTerminalAreaDef;
		if subTermAreaDef &lt;&gt; null then
			return subTermAreaDef;
		endif;
	endif;
	
	if self.isGridLocation then
		if self.CM_GridController.myGridColumn &lt;&gt; null then
			gridObject := self.CM_GridController.myGridColumn;
		endif;
		if self.CM_GridController.myGridRow &lt;&gt; null then
			gridObject := self.CM_GridController.myGridRow;
		endif;
		if gridObject &lt;&gt; null then
			subTermAreaDef := gridObject.getMySubTerminalAreaDef;
			if subTermAreaDef &lt;&gt; null then
				return subTermAreaDef;
			endif;
		endif;
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_SubTerminalAreaDef"/>
    </JadeMethod>
