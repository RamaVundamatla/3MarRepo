    <JadeMethod name="isMyQEntryTL" id="9d13b700-61f2-401a-b8b3-1aed1e8b73a4">
        <source>isMyQEntryTL() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 26013 This is to see if the WLEs RTQ Entry is twin lift
// With a voyage WLE the crane may be doing twin lift but the machine bringing the container is not.
// ---------------------------------------------------------------------------

vars
	rtq : CM_RTQueueEntry;
begin
	foreach rtq in self.allRTQueueEntries discreteLock do
		if rtq.getTwinCarryFlag() &lt;&gt; 0 then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
