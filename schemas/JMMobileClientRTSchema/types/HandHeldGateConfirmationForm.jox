		self.fldMain.topSheet := self.shtError;
	endif;
	
epilog
	self.btnDamage.enabled:=containerInfo.myPxyTrackedItem &lt;&gt; null;
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;</source>
