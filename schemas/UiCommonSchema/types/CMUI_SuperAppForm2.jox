    <JadeMethod name="setDocoMenu" id="82ed5be2-c79e-4da1-8d9c-a456bd47c969">
        <updating/>
        <source>setDocoMenu() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user				: CM_User;
	checkLicence		: Boolean;
	root				: CM_Root;
	
begin
	user	:=	app.getMyUser();
	
	if app.isSpecial() then
		return;//leave everything visible
	endif;
	
	root	:=	app.myRoot;

	self.mnuJMTSAG.visible		:=	user.isAdministrator;
	self.mnuJMTVTMIS.visible	:=	root.canDo(Mod_Harbour);
	self.mnuJMTIMG.visible		:=	root.canDo(Mod_Invoicing);
	self.mnuJMTCMG.visible		:=	root.canDo(Mod_GeneralCargo);
	self.mnuJMTLMG.visible		:=	root.canDo(Mod_Logs);
//	self.mnuJMTRMG.visible		:=	root.canDo(PmReeferMonitorMod);
	self.mnuJMTRMG.visible		:=	root.canDo(Mod_BaseSystem);	//07 Oct 2019	NDL	TFS 46169
	self.mnuJMTRDTUG.visible	:=	root.canDo(Mod_Queuing); //par17693
	self.mnuJMTRORO.visible 	:= root.canDo(Mod_VesselRORO); //epr par 30601
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLblUserName" id="945007f7-6a50-4abd-bc92-843597e86fd7">
