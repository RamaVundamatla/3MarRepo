<GUIClass name="CheckBox">
    <JadeMethod name="controlNamePrefix" id="eace6d41-7de7-4bbe-b189-57122159c119">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "chk";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="4c54c48e-2b31-44af-8f08-5a36cd641275">
        <updating/>
        <source>jssSet(pValue:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's boolean flag with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.value &lt;&gt; pValue then
		self.value	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
</GUIClass>
