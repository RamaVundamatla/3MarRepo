    <JadeMethod name="translateForm" id="7b5f3f16-9a6b-4dd1-97ef-50ff15fead24">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005811, locale);
	btnAddCode.translateCaption(Xlat_0001315, locale);
	btnBack.translateCaption(Xlat_0001316, locale);
	btnCancelClone.translateCaption(Xlat_0001309, locale);
	btnCloneCodes.translateCaption(Xlat_0001311, locale);
	btnCloneProduct.translateCaption(Xlat_0014375, locale);
	btnDoClone.translateCaption(Xlat_0001317, locale);
	btnRemoveCode.translateCaption(Xlat_0001312, locale);
	btnUpdateCode.translateCaption(Xlat_0001313, locale);
	
	chkOverwriteCode.translateCaption(Xlat_0001308, locale);
	lblCloneAttr.translateCaption(Xlat_0014376, locale);
	lblCloneCT.translateCaption(Xlat_0001319, locale);
	lblCloneProduct.translateCaption(Xlat_0014377, locale);
	lblEntCode.translateCaption(Xlat_0001320, locale);
	lblSelectClone.translateCaption(Xlat_0001310, locale);
	mnuContext.translateCaption(Xlat_0005812, locale);
	mnuEditAttributes.translateCaption(Xlat_0011526, locale);
	mnuEditCodes.translateCaption(Xlat_0005813, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zCheckTblDataRowChange" id="6854265a-128f-4fb5-b5a6-bc6ec8031019">
        <updating/>
        <source>zCheckTblDataRowChange(): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 September 2005	cnwhjg1
//
// Purpose:     Reimplemented so can add a bit of text to msg box if codes have
//				been edited to remind user they have changed codes. 
// ----------   ----------  --------------------------------------------------
vars

	result	: Integer;

begin

	if self.mode = self.Mode_View then

		// viewing so no check needed.
		return true;
	endif;


	if self.isCodesEdited then 
		// reset.
		
		result := app.msgBox(app.getErrorString(QueryRowChange) &amp; CrLf &amp; CrLf &amp;'PLEASE NOTE: Changes made to codes will not be saved', self.caption &amp; " Window Closing !", MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
	
		if result = MsgBox_Return_Cancel then
		// do NOT move to new row.
			return false;
		elseif result = MsgBox_Return_No then
			self.isCodesEdited := false;
		// cancel changes to existing item and move to the next row
			self.zDoCancel();
			return true;
		elseif result = MsgBox_Return_Yes then
		// save the existing item, if successful then move to the new row;
			return self.zDoSave();
		endif;
		
	else		
		result := app.msgBox(app.getErrorString(QueryRowChange),  app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		
		if result = MsgBox_Return_Cancel then
			// do NOT move to new row.
			return false;
		elseif result = MsgBox_Return_No then
			// cancel changes to existing item and move to the next row
			self.zDoCancel();
			return true;
		elseif result = MsgBox_Return_Yes then
			// save the existing item, if successful then move to the new row;
			return self.zDoSave();
		endif;
	
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
