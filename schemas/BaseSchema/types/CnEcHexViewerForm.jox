    <JadeMethod name="getBinaryData" id="fdef21bf-5991-4565-9563-c679d9f4e4e7">
        <source>getBinaryData():Binary;
// --------------------------------------------------------------------------------
// Created:		02 May 1999 by cnwdad1
//
// Purpose:		Returns the hex data stream, as a BLOB.
//
// Parameters:	None
// Returns:		The hex data stream.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	return self.aBinaryData;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getChunkSize" id="2059720b-9c47-449c-9bfd-2e53f8f61275">
        <source>getChunkSize():Integer protected;
// --------------------------------------------------------------------------------
// Created:		01 May 1999 by cnwdad1
//
// Purpose:		Returns the size of the hex data stream.
//
// Parameters:	None
// Returns:		The size of the hex data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	chunkSize	: Integer;
	rowCount	: Integer;
	columnCount	: Integer;

begin
	rowCount	:=	tblHexData.rows;
	columnCount	:=	tblHexData.columns - 2;

	if (columnCount &gt; 0) then
		chunkSize	:=	columnCount * rowCount;
	else
		chunkSize	:=	0;
	endif;
epilog
	return chunkSize;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="7beba19e-0fe5-4e26-ad39-8576761387ad">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.aIsFormLoading	:=	true;
	app.mousePointer	:=	Busy;
	centreWindow();
	self.formSetup();
epilog
	self.aIsFormLoading	:=	false;
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="cae4be33-cdee-4506-9674-455daf3ea3a8">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		01 May 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	btnClose.move((self.width - btnClose.width - tblHexData.left - 10), (self.height - btnClose.height - 35), btnClose.width, btnClose.height);
	tblHexData.move(tblHexData.left, tblHexData.top, (self.width - tblHexData.left - vScrollHex.width - 20), (self.height - 80));
	vScrollHex.move((tblHexData.width + 10), vScrollHex.top, vScrollHex.width, tblHexData.height);
	lblOffsetLabel.move(lblOffsetLabel.left, (btnClose.top + 2), lblOffsetLabel.width, lblOffsetLabel.height);
	lblOffset.move(lblOffset.left, (btnClose.top + 2), lblOffset.width, lblOffset.height);
	lblSizeLabel.move(lblSizeLabel.left, (btnClose.top + 2), lblSizeLabel.width, lblSizeLabel.height);
	lblSize.move(lblSize.left, (btnClose.top + 2), lblSize.width, lblSize.height);

	self.updateHexRowsAndColumns();
	self.displayHexData();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllowEditing" id="177045cd-2ab2-4f11-8389-514a42053585">
        <updating/>
        <source>setAllowEditing(pValue: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 1999 by cnwdad1
//
// Purpose:		Sets a boolean flag to indicate whether the hex data can be edited.
//
// Parameters:	pValue - True if the hex data can be edited.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if self.aAllowEditing &lt;&gt; pValue then 
		self.aAllowEditing	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBinaryData" id="96f5c694-0c3c-4273-8a5e-748d812ca994">
        <updating/>
        <source>setBinaryData(pBin : Binary) updating;

begin
	self.aBinaryData	:=	pBin;
	lblSize.caption	:=	self.aBinaryData.length.userNumberFormat($CNEC_NO_DECIMALS);
end;</source>
        <Parameter name="pBin" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setDataDescription" id="67cd3de4-0af3-419f-89c2-b438f7a75539">
        <updating/>
        <source>setDataDescription(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		17 July 1999 by cnwdad1
//
// Purpose:		Sets a description of the hex data, which is used in the receiver's
//				caption.
//
// Parameters:	pValue - A description of the hex data.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if aDataDescription &lt;&gt; pValue then 
		aDataDescription := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateHexRowsAndColumns" id="efea3b51-2c04-4037-b944-63ed5ae30941">
        <source>updateHexRowsAndColumns() protected;
// --------------------------------------------------------------------------------
// Created:		01 May 1999 by cnwdad1
//
// Purpose:		Updates the hex data table's rows and columns, typically after the
//				form itself has been resized.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	colCount		: Integer;
	columnIndex		: Integer;
	heightOfRows	: Integer;
	widthOfColumns	: Integer;
	hexColumns		: Integer;
	canAddRow		: Boolean;
	canAddColumn	: Boolean;
	chunkSize		: Integer;

begin
	tableObj	:=	tblHexData;

	// First work out how many rows we can fit in.

	tableObj.accessMode	:=	Table.AccessMode_Row;
	tableObj.rows		:=	0;
	canAddRow			:=	true;

	while (canAddRow) do
		if (tableObj.rows &gt; 0) then
			tableObj.row	:=	tableObj.rows;
			heightOfRows	:=	tableObj.positionTop + (tableObj.rowHeight[tableObj.row] * 2);
		endif;

		if	(tableObj.rows &gt; 0)
		and ((heightOfRows &gt; tableObj.height)
		or (heightOfRows = CNEC_NULL_INDEX))
		then
			canAddRow	:=	false;
		else
			tableObj.addItem('');	//(table.rows + 1).String.padLeadingZeros(6));
		endif;
	endwhile;

	// Now work out how many columns we can fit in.

	tableObj.accessMode	:=	Table.AccessMode_Sheet;
	tableObj.alignment	:=	Table.Alignment_Center;
	tableObj.columns	:=	2;
	tableObj.accessMode	:=	Table.AccessMode_Column;

	// Column 1 always shows the starting pointer for the row's data (in hex).

	tableObj.column			:=	1;
	tableObj.inputType		:=	Table.InputType_None;
	tableObj.columnWidth[1]	:=	tableObj.getTextExtent(' WWWWWWWWW ');

	// The last column always shows the ASCII value for the row's hex data.

	tableObj.column			:=	2;
	tableObj.alignment		:=	Table.Alignment_Left;

	if (self.aAllowEditing) then
		tableObj.inputType		:=	Table.InputType_TextBox;
	else
		tableObj.inputType		:=	Table.InputType_None;
	endif;

	tableObj.columnWidth[2]	:=	tableObj.getTextExtent(' WWWWWWW ');

	// Now add the hex value columns between column 1 and the last column.

	canAddColumn		:=	true;

	while (canAddColumn) do
		if (tableObj.columns &gt; 0) then
			tableObj.column	:=	tableObj.columns;
			widthOfColumns	:=	tableObj.positionLeft + tableObj.columnWidth[tableObj.columns] + tableObj.getTextExtent(' W ');
		endif;

		if	(tableObj.columns &gt; 0)
		and ((widthOfColumns &gt; tableObj.width)
		or (widthOfColumns = CNEC_NULL_INDEX))
		then
			canAddColumn	:=	false;
		else
			tableObj.columns					:=	tableObj.columns + 1;
			columnIndex							:=	tableObj.columns;

			// Set up the 2nd last column.

			tableObj.column							:=	columnIndex - 1;
			tableObj.columnWidth[columnIndex - 1]	:=	tableObj.getTextExtent(' W ');
			tableObj.alignment						:=	Table.Alignment_Center;

			if (self.aAllowEditing) then
				tableObj.inputType					:=	Table.InputType_TextBox;
			else
				tableObj.inputType					:=	Table.InputType_None;
			endif;

			tableObj.maxLength	:=	2;

			// Set up the last column.

			tableObj.column						:=	columnIndex;
			tableObj.columnWidth[columnIndex]	:=	tableObj.getTextExtent('W'.String.padBlanks(columnIndex));
			tableObj.alignment					:=	Table.Alignment_Left;
			colCount							:=	columnIndex - 2;

			if (colCount &gt; 2) then
				if (self.aAllowEditing) then
					tableObj.inputType	:=	Table.InputType_TextBox;
				else
					tableObj.inputType	:=	Table.InputType_None;
				endif;

				tableObj.maxLength	:=	colCount;
			else
				tableObj.inputType	:=	Table.InputType_None;
				tableObj.maxLength	:=	0;
			endif;
		endif;
	endwhile;

	tableObj.accessMode	:=	Table.AccessMode_Cell;
	chunkSize			:=	self.getChunkSize();

	if (self.aBinaryData.length &gt; 0) and (chunkSize &gt; 0) then
		hexColumns				:=	tableObj.columns - 2;
		vScrollHex.max			:=	self.aBinaryData.length;		//(self.binaryData.length div chunkSize);
		vScrollHex.largeChange	:=	chunkSize - hexColumns;

		if (hexColumns &gt; 0) then
			vScrollHex.smallChange	:=	hexColumns;
		else
			vScrollHex.smallChange	:=	1;
		endif;
	else
		vScrollHex.max	:=	1;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="vScrollHex_change" id="e5ea0ad3-06ef-46cf-aaa0-1d147822db29">
        <controlMethod name="ScrollBar::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>vScrollHex_change(scroll: ScrollBar input) updating;
// --------------------------------------------------------------------------------
// Created:		01 May 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	app.mousePointer	:=	Busy;

	if (scroll.value &gt; 0) then
		tblHexData.tag	:=	scroll.value.String;
	else
		tblHexData.tag	:=	'1';
	endif;

	self.displayHexData();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
</GUIClass>
