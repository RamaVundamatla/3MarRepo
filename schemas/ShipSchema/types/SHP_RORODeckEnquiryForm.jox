    <JadeMethod name="doUserNotify" id="a58ea178-223e-45c2-8470-a71babd601cd">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deck : CM_Deck;

begin
	
	if eventType = EVENT_VESSEL_DECK_CREATE then
		deck:=userInfo.CM_Deck;
		self.addTableItem(deck);
	elseif eventType = EVENT_VESSEL_DECK_UPDATE then
		deck:=userInfo.CM_Deck;
		self.updateTableItem(deck);
	elseif eventType = EVENT_VESSEL_DECK_DELETE then
		deck:=userInfo.CM_Deck;
		self.removeTableItem(deck);
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
