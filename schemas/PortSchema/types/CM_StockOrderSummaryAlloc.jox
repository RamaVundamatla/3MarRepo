    <ExplicitInverseRef name="allStockOrderLineAllocations" id="11b12fac-1e12-4f76-b5c7-c46a1995bd25">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_StockOrderLineAllocSet"/>
        <access>readonly</access>
        <Inverse name="CM_StockOrderLineAlloc::myStockOrderSummaryAlloc"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myStockOrderSummary" id="eacb06ed-cde0-440c-8439-4a29fb9fce08">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
