<Class name="CMIF_OutputField_CountAbstract" id="8610cbcc-0391-48bd-8356-0c721f8e202c">
    <superclass name="CMIF_OutputField"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>This class is abstract superclass for all counting classes.

</text>
    <DbClassMap file="query"/>
    <PrimAttribute name="count" id="b41cfd05-f38c-474c-b8e4-c334579778da">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="ce0eeea5-c667-4c07-9f3c-8a7395dea7bc">
        <source>getValue() : String;

// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwcs5		ccms 1028 - hide 0 values
// ---------------------------------------------------------------------------

vars
	value	:Integer;
begin
	value := self.count;	// cnwcs5 07/12/2009
	
	if value = 0 then		// cnwcs5 07/12/2009
		return null;		// cnwcs5 07/12/2009
	endif;					// cnwcs5 07/12/2009
	
	return value.asStringJMTWithOptionalCommas( self.useSeperator, false );	// cnwcs5 07/12/2009
	
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="b1633d3f-4bbd-4b35-82a7-0a7e10dacc94">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating, abstract;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2010	cnwcs5		ccms 1925 / par 22295 - new functions for release summaries
//							I have taken out the code the does not count empty string values
//							and replaced with new Count_Not_Null function
// ---------------------------------------------------------------------------
</source>
        <abstract/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
