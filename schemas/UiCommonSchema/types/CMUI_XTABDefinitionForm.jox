    <JadeMethod name="registerForNotifications" id="b7419f91-81f8-4359-92b0-7437fd3392ea">
        <source>registerForNotifications() protected;

/*

Purpose:		CCMS SFW 1047 - Totals Only Lists
Parameters:		
Return Value:	

Date				Who		Reason
12 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	// register this class for system notifications on creates and deletes only.
	self.beginClassNotification( CM_OutputFormat_XTAB, false, Object_Create_Event, Response_Continuous, null );
	self.beginClassNotification( CM_OutputFormat_XTAB, false, Object_Delete_Event, Response_Continuous, null );
	
epilog
	
end;
</source>
        <access>protected</access>
