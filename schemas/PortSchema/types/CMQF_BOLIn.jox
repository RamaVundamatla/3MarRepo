<Class name="CMQF_BOLIn" id="7ce38829-7529-4bce-b26f-41ca449b067d">
    <superclass name="CMQF_BOL"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="includesObject" id="b620fc27-6120-40a1-b9b0-45f38b1d5e03">
        <updating/>
        <source>includesObject(_bol: CM_BOL; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnValue			: Boolean;
begin
	rtnValue := inheritMethod(_bol, _passport, _breakOut);

	if (not CM_BOLIn.hasInstance(_bol)) then
		rtnValue := false;
	endif;
	
	return rtnValue;

end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
