    <JadeMethod name="getReleaseConsigneeCode" id="e280a3bb-a8c6-443d-96c8-4a22cd025375">
        <source>getReleaseConsigneeCode() : String;
//
// Purpose:		Do not delete - used in reports	
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/03/2016	cnwdap1		Initial creation PAR #37523 Show "update consignee" on Road Receipt and Driver Details reports
//
vars
	gte : CMGTE_Entity;
begin
	
	gte := self.myGateEntity;
	
	if gte &lt;&gt; null and gte.isKindOf(CMGTE_Release) then
		if gte.CMGTE_Release.updateConsigneeCode &lt;&gt; null then
			return gte.CMGTE_Release.updateConsigneeCode;
		endif;
	endif;
	
	return null;

epilog

end;</source>
