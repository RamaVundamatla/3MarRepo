    <JadeMethod name="filterObjects" id="bcc56403-66e4-47ab-b351-fc68d6b63f3d">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking


*/

vars

	breakOut			: Boolean;
	globalVoyage		: CM_VoyageGlobal;
	voyageGlobalDict	: CM_VoyageGlobalByCodeDict;

begin
	
	voyageGlobalDict := app.myRoot.allVoyagesGlobal;
	foreach globalVoyage in voyageGlobalDict discreteLock do
		if self.includesObject(globalVoyage, _passport, breakOut) then
			_collection.add(globalVoyage);
		endif;
		
		if breakOut then
			break;
		endif;
		
	endforeach;


end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="547d0037-b3cf-4400-846b-bddcd1b88593">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

	runDate	: Date;
    oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
	/*
	runDate := app.actualTimeServer().date;

	// Arrival
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateFromType, self.arriveDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateToType, self.arriveDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsTimeFrom then
		return self.arriveTimeFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_ArrivalsTimeTo then
		return self.arriveTimeTo.shortFormatJMT();
	endif;
	

	return inheritMethod(_attrName, _getCalculatedDate);

*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="0a12682c-bdac-45e2-b08e-6fc71ef468b0">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

	runDate	: Date;

begin
	
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support

	// Arrival
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateFromType, self.arriveDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateToType, self.arriveDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsTimeFrom then
		return self.arriveTimeFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_ArrivalsTimeTo then
		return self.arriveTimeTo.shortFormatJMT();
	endif;
	

	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="7965282f-79c4-467e-b899-61da2c1972c8">
        <updating/>
        <source>includesObject(_globalVoyage : CM_VoyageGlobal; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	arriveFromTS,
	arriveToTS,
	departFromTS,
	departToTS			: TimeStamp;
	
begin
	
	self.numSearched := self.numSearched + 1;
	
	arriveFromTS.setDate(self.arriveDateFrom);
	arriveFromTS.setTime(self.arriveTimeFrom);
	arriveToTS.setDate(self.arriveDateTo);
	arriveToTS.setTime(self.arriveTimeTo);
	
	if (arriveFromTS.isValid and _globalVoyage.arrivalDT &lt; arriveFromTS) or
	   (arriveToTS.isValid and _globalVoyage.arrivalDT &lt; arriveFromTS) then
	   return false;
	endif;

	self.numFound := self.numFound + 1;
	return true;

end;


</source>
        <access>protected</access>
        <Parameter name="_globalVoyage" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="26ec3381-79e3-4f4b-90cd-52e23913b8dc">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_runDate);
	self.arriveDateFrom := self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, _runDate);
	self.arriveDateTo	:= self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, _runDate);
	
end;


</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="5b1d210b-fc15-4435-b14e-fabacd779718">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_obj, _runDate, _allEventData);
	self.arriveDateFrom := self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, _runDate);
	self.arriveDateTo	:= self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, _runDate);

end;


</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
</Class>
