    <JadeMethod name="doSendInspection" id="cad8af2e-dca6-4629-827e-f18153675e31">
        <updating/>
        <source>doSendInspection( _vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		        Who		Reason
15 December 2022	navmp20	ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
14/02/2024			navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy (Changed Signature)
*/

vars
	vvr       : CM_VehicleVisitRecord;
	theReturn : Integer;
begin
	vvr := _vvr;
	while true do
		app.myTrxUA.trxUpdateVVRInspection(vvr, app.myPassport);			 //14/02/2024 navcs2 Bug 62454
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doSendToReport" id="b913ca0a-5f21-4525-89e4-0028953a2579">
        <source>doSendToReport(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

*/

vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	outputType		: Integer;
	filePath		: String;
begin
	app.isReportWriter := true;
	create pathList transient;
	pathList.add( CM_JRWVehicleVisit::allVehicleVisitRecords.name );
	
	//Get the report we want to send our invoice items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_VehicleVisitView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		arrayCheck.add(_obj);
		
		app.sendItemsToReport(CM_JRWVehicleVisit, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doShowCargoReview" id="3fad51e2-f238-42ff-984b-0c0a3cdd7e1c">
        <source>doShowCargoReview(_table : CM_GroupingTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	cgReviewForm			: CMUI_CargoReview;
	criteriaLine			: CM_SelectorCriteriaLine;
	qdef					: CM_QueryDefinition;
	wle						: CM_WorkListEntry;
	job						: CM_Job;
	obj						: Object;
	vvr						: CM_VehicleVisitRecord;
	vvrNum					: String;
	criteriaLines			: CM_SelectorCriteriaLineArray;
	sa						: StringArray;
begin
	
	if _table.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	cgReviewForm := app.loadForm(CMUI_CargoReview, CMUI_Assistant, true, true, false, self.getMyTerminal(), null).CMUI_CargoReview;
	
	if cgReviewForm = null then
		return;
	endif;
	
	qdef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.TrackedItem_Query_Mode];
	
	if qdef = null then
		return;
	endif;
	
	create criteriaLines transient;
	create sa transient;
	
	foreach obj in _table.allSelectedObjects where obj.isKindOf(CM_WorkListEntry) do
		wle := obj.CM_WorkListEntry;
		
		job := wle.job;
		
		if job = null or not job.isRoadJob() then
			continue;
		endif;
		
		vvr := job.CM_RoadJob.myVehicleVisit;
		
		if vvr = null then
			continue;
		endif;
		
		vvrNum := vvr.visitNumber;
		if sa.indexOf(vvrNum) = 0 then
			sa.add(vvrNum);
		endif;
	endforeach;
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getVehicleVisitNumber.name, CM_QueryOperator.Operator_Range, sa.asCSV(false));
	criteriaLines.add(criteriaLine);
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	criteriaLines.add(criteriaLine);
	
	cgReviewForm.createCriteriaLinesFromParent(criteriaLines);
	cgReviewForm.setParentForm(self);
	cgReviewForm.show();
	cgReviewForm.autoDoCustDocFromParent(); //23/02/2023	navkc1 CR 62580 Task 62581
epilog
	delete criteriaLines;
	delete sa;
end;</source>
        <Parameter name="_table" type="CM_GroupingTable"/>
    </JadeMethod>
