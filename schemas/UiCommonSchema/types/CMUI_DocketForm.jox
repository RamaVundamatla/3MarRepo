    <JadeMethod name="doAddEditBOL" id="6c10b356-f137-44a4-9042-8df1191d73b7">
        <updating/>
        <source>doAddEditBOL(_add : Boolean)updating;
//06 January 2010	cnwml2


vars
	form : CMUI_BOLMaintForm;
begin
	form := app.loadForm(CMUI_BOLMaintForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_BOLMaintForm;
	
	if form = null then		// 09/04/2010 cnwar2 #23230
		return;				// may have failed security check
	endif;
	
	if _add then
		form.setCaption(app.getString(AddShipBOL));
		form.setMode(Mode_Add);
		form.setMyCurrentBOL(null);
		//new blank form
	else

		form.setCaption(app.getString(EditShipBOL));
		form.setMode(Mode_Update);
		//chuck in existing values
		if self.btnShowBOLItems.value then
			form.setMyCurrentBOL(self.myCurrentObject.CM_BOLDtl.myBOL);
		else
			form.setMyCurrentBOL(self.myCurrentObject.CM_BOL);
		endif;
	endif;

	form.setMyBOLType(self.cmbDocketType.listObject.CM_BOLType);
	
	form.show();
	
epilog

end;</source>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnShowBOLItems" id="c4d6b0e9-620e-4d5b-a4d9-642ccfd42944">
        <updating/>
        <source>doBtnShowBOLItems(_filterDocketType : Integer; _filterDocketNumber : String; _filterVoyage : String; _filterOperator: String; _filterStatus : String; _filterRecon : String) updating;
//13 January 2010
//+cnwml2 SFW CCMS 1071
vars

begin
	self.allowSearch := true;
	self.setupForm;
	
	self.tblSearch.setValueByName(ETRow_FilterDocketType, _filterDocketType);
	self.filterDocketType := _filterDocketType;
	self.tblSearch.setValueByName(ETRow_FilterDocketNumber, _filterDocketNumber);
	self.filterDocketNumber := _filterDocketNumber;
	self.tblSearch.setValueByName(ETRow_FilterVoyage, _filterVoyage);
	self.filterVoyage := _filterVoyage;
	self.tblSearch.setValueByName(ETRow_OperatorCode, _filterOperator);
	self.filterOperatorCode := _filterOperator;
	self.tblSearch.setValueByName(ETRow_FilterStatus, _filterStatus);
	self.filterStatus := _filterStatus;
	self.tblSearch.setValueByName(ETRow_FilterReconciled, _filterRecon);
	self.filterReconciled := _filterRecon;
	
	
	self.zGetDataForTable(null);
	
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_BOLDtl) then
			self.btnDeleteTV.enabled := false;
		else
			if self.myCurrentObject.CM_BOL.bolType = BOLType_Log then	
				self.btnDeleteTV.enabled := false;
			else
				self.btnDeleteTV.enabled := true;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_filterDocketType" type="Integer"/>
        <Parameter name="_filterDocketNumber" type="String"/>
        <Parameter name="_filterVoyage" type="String"/>
        <Parameter name="_filterOperator" type="String"/>
        <Parameter name="_filterStatus" type="String"/>
        <Parameter name="_filterRecon" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="f03d38c2-a91c-491e-84e0-6dd5dbd3e7a7">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 23 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	if self.tblMain.hasChanged then
		self.confirmCancel(app.getErrorString(The_Current_Item));
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="0c417d8c-7d24-4c6c-a542-f23b784fa110">
        <updating/>
        <source>doDelete(): Boolean updating;
//18 January 2010	cnwml2


vars
	obj		: Object;
	passport: CM_Passport;
	
begin
	//return inheritMethod();
	//app.myPassport.setWarningsIgnored(true); comented by PAR 23211 11/05/2010
	passport	:= app.myPassport;
	
	foreach obj in self.tblData.allSelectedObjects do
		app.myPassport.setWarningsIgnored(true);	// added by PAR 23211 11/05/2010 to kepp existing functionality
		app.myTrxDA.trxDeleteBOL(obj.CM_BOL, passport);
	endforeach;
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog('BOL Deletion', passport, ErrWarnMode_Update);
		self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
	endif;
	


epilog
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilter" id="7a00d984-75c2-4a1d-845f-4474c965c8c4">
        <updating/>
        <source>doFilter()updating;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;

	self.isDataFiltered := true;
	
	self.setFilterValues();
		
	if self.filterAppliesToThumbnail then
		self.zShowThumbnailData(self.myCurrentObject);
	else
		self.zTblDataSortAndShow(true);
		self.zTblDataSelectObject(null);
	endif;
	
	//lblFiltered.visible := true;
	
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCargoLabelPrint" id="ea40a90b-a303-4a48-9ea1-5345652f40cc">
        <source>doMnuCargoLabelPrint();
/*

Purpose:			Print Bar Code Labels

Parameters:			

Return Value:		

Date			Who		Reason
08 March 2010	conkc1	Initial creation

*/
vars
	tiArray : CM_ObjectArrayActual;
	obj     : Object;
begin
	
	if self.tblData.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create tiArray transient;

	foreach obj in self.tblData.allSelectedObjects do
		if obj.isKindOf(CM_BOLIn) then
			tiArray.add( obj.CM_BOLIn );
		elseif obj.isKindOf(CM_BOLDtl) then
			if obj.CM_BOLDtl.myBOL &lt;&gt; null then
				tiArray.addExclusive( obj.CM_BOLDtl.myBOL );
			endif;
		endif;

	endforeach;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);

epilog

	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuReceived" id="f1569674-2afb-4f4d-9cd7-661d5e882ad9">
        <source>doMnuReceived(_tiArray : ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2009	cnwml2	Initial creation

*/

vars

	realObj,pxyBOLDtl: CM_BOLDtl;
	ti 		: CM_TrackedItem;
	obj 	: Object;								
	bol 	: CM_BOL;
	bolDtl : CM_BOLDtl;
	
begin
	if self.btnShowBOLItems.value then
		if self.tblData.allSelectedObjects.size &gt; 0 then
			foreach obj in tblData.allSelectedObjects do
				bolDtl := obj.CM_BOLDtl;
				if bolDtl.allTrackedItems.size &gt; 0 then
					foreach ti in bolDtl.allTrackedItems do
						_tiArray.add(ti);
					endforeach;
				endif;
			endforeach;
		endif;
	else
		if self.tblData.allSelectedObjects.size &gt; 0 then
			foreach obj in tblData.allSelectedObjects do
				bol := obj.CM_BOL;
				if bol.allTrackedItems.size &gt; 0 then
					foreach ti in bol.allTrackedItems do
						_tiArray.add(ti);
					endforeach;
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
