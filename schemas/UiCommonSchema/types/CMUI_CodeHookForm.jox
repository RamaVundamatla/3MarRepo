    <JadeMethod name="setControlsForAddEdit" id="133995be-5905-47bb-a623-943ff71b59ce">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	self.txtCode.setFocus();
	self.txtCode.readOnly				:= false;
	self.cmbHookType.enabled			:= true;
	self.lstTblLinks.userInputEnabled	:= true;
	self.txtJadeCode.readOnly		 	:= false;
	if self.mode = self.Mode_Add then
		self.clearDetailFrame();
	endif;
	// TFS 2010 restrict the hook types that can be added or changed to
	self.cmbHookType.listCollection(self.addHookTypes, false, 0);
	if self.mode = self.Mode_Update then
		self.cmbHookType.listObject := self.myCurrentObject.CM_HookCode.myHookType;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="5a55752c-a70c-4d1b-8057-0ca517899566">
        <updating/>
        <source>setControlsForView() updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();

	self.cmbHookType.enabled			:= false;
	self.lstTblLinks.userInputEnabled	:= false;
	self.txtJadeCode.readOnly			:= true;
	self.txtCode.readOnly				:= true;
	// TFS 2010 restore the hook types after an add or edit
	self.cmbHookType.listCollection(self.fullHookTypes, false, 0);

end;</source>
    </JadeMethod>
