    <JadeMethod name="createReeferDataTelegram" id="537b63b4-9afb-4397-9f59-75780f40cc81">
        <source>createReeferDataTelegram(_ti:CM_TrackedItem/*CM_Container*/; _type:Integer):Binary;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//							Method signature change to reflect this
// ---------------------------------------------------------------------------

vars
	message,data		: Binary;
	header				: Binary;
	length				: Integer;
	bin					: Binary;
begin

//	self.logMonitor(method.name);
	header := self.messageHeader(_type);
	data := self.messageData(_type, _ti);
	length := header.length + data.length;
	bin := length.Binary;
	header[1:1] := bin[2:1];	//MSB
	header[2:1] := bin[1:1];	//LSB
	message := header&amp;data;
	return message;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="createReeferRequest" id="8cb2caf0-84ce-45f9-ac25-263c89422004">
        <source>createReeferRequest(_id: String): Binary;
//----------------------------------------------------------------
//	Created:	30 June 2004	by Jason Chapman  (cnwjc2)
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
//----------------------------------------------------------------
vars
	message,data		: Binary;
	header				: Binary;
	length				: Integer;
	bin					: Binary;
	now					: TimeStamp;
begin
	now := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	header := self.messageHeader(Reefer_Monitor_Request);
	data := (self.timeOfAct(now) &amp; self.rfcIdent(_id)).asANSI(0);// 14/3/16  cnwns1 PAR 36286 unicode version
	
	length := header.length + data.length;
	bin := length.Binary;
	header[1:1] := bin[2:1];	//MSB
	header[2:1] := bin[1:1];	//LSB
	message := header&amp;data;
	return message;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="createTempReading" id="090a461d-1b51-4630-82db-7dfe41136088">
        <updating/>
        <source>createTempReading(_reefer: CM_TrackedItem /*CM_Container*/; _temperature: Real; _timeStamp, _firstCommTime: TimeStamp; _noCharge: Boolean; _isRefConReading, _allowConnect, _connectOnly: Boolean; _refConRawData: Binary) updating;
//----------------------------------------------------------------
//	Created:	16 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #17953 - Allow connect to work by creating proxy TI
10 Dec 2009	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
27 Sep 2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
*/

vars
	//reefer			: CM_Container;		// CCMS 1007
	reefer				: CM_TrackedItem;	// CCMS 1007
	strTemp				: String;
	timeStmp			: TimeStamp;
	connectParams		: CMIF_ConnectParams;
	tempReadingParams	: CMIF_TempReading;
	loadState			: Boolean;
	//theProxyTI		: CM_Container;		// CCMS 1007
	theProxyTI			: CM_TrackedItem;	// CCMS 1007
	err					: CM_Error;
begin

	if _reefer = null then
		return;
	endif;
	
	timeStmp.setDate(_timeStamp.date);
	timeStmp.setTime(_timeStamp.time);
	reefer := _reefer;
	
	if not reefer.isConnected and
	   _isRefConReading and
	   _allowConnect then
		create connectParams transient;
		connectParams.dateTime := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		connectParams.noCharge := true; //TFS 3844 part of Refcon funtionality
		connectParams.myTerminal := app.getMyTerminalDO_NOT_USE();
	//	the following is set in the trx when allTrackedItems is used or below for COUs	
	//	connectParams.urNumber := aURNumber;
		connectParams.userId := app.getMyUserCode();
		connectParams.action := ACTION_CONNECT;
	//	connectParams.gapController := self.myPowerPoint;
		connectParams.radioTelemetryIgnoreWarnings := true;
		connectParams.radioTelemetryUser := false;
			
		app.cmsBeginLoad(loadState);					// PAR #17953
		theProxyTI := reefer.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		connectParams.allTrackedItems.add(theProxyTI);

		app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);
		
		delete theProxyTI;

		if (not app.myPassport.trxCompletedOK) then
			foreach err in app.myPassport.allErrors do
				self.logMonitor("Error connecting container " &amp; err.text &amp; " " &amp; _timeStamp.String&amp;" "&amp;reefer.id);
			endforeach;
				
			app.myPassport.clearErrorsWarnings();
		endif;
	endif;
	create tempReadingParams transient;
	
//	tempReadingParams.isRefConReading := _isRefConReading;
//	tempReadingParams.refConRawData := _refConRawData;
//	tempReadingParams.dateTime := timeStmp;
//	tempReadingParams.noCharge := reefer.noChargeForTemperature(false, timeStmp);
//	tempReadingParams.userId := app.getMyUserCode();
//	tempReadingParams.myTerminal := app.getMyTerminalDO_NOT_USE;
//	tempReadingParams.allowConnect := _allowConnect;
//	tempReadingParams.connectOnly := _connectOnly;
	
	app.cmsBeginLoad(loadState);
	theProxyTI := reefer.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
//	tempReadingParams.myTrackedItem := theProxyTI;
	
//	tempReadingParams.temperature := _temperature;

	//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
	tempReadingParams.initialise(	theProxyTI,	//_reefer : CM_TrackedItem;
									false,	//_defaultNoChargeValue : Boolean;
									timeStmp,	//_dateTime : TimeStamp;			// TFS 52081
									_temperature	//_temperature : Real
									);
	tempReadingParams.setConnectAttribs( _allowConnect, _connectOnly );	//01 Sep 2021	NDL	TFS 51874
	tempReadingParams.setIsRefConAgent( _isRefConReading, _refConRawData );	//01 Sep 2021	NDL	TFS 51874
	
	app.myTrxCA.trxCreateTempReading(tempReadingParams, _firstCommTime, app.myPassport);	

	if (not app.myPassport.trxCompletedOK) then
		foreach err in app.myPassport.allErrors do
			self.logMonitor("Error creating temperature reading " &amp; err.text &amp; " " &amp; _timeStamp.String&amp;" "&amp;reefer.id);
		endforeach;
			
		app.myPassport.clearErrorsWarnings();
	endif;

epilog
	app.cmsEndLoad(loadState);			// 08/04/2011 cnwmh5 #27347
	delete theProxyTI;
	delete tempReadingParams;
	delete connectParams;
	
end;</source>
        <Parameter name="_reefer" type="CM_TrackedItem"/>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_firstCommTime" type="TimeStamp"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_isRefConReading" type="Boolean"/>
        <Parameter name="_allowConnect" type="Boolean"/>
        <Parameter name="_connectOnly" type="Boolean"/>
        <Parameter name="_refConRawData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="doProcessLength" id="5945ac0c-7a2b-4dfe-a905-2ccc6fc67eae">
        <updating/>
        <source>doProcessLength() protected, updating;

// cnwdvb1 01 May 2003 

vars

	messageLength		: Integer;
	bin, data, extra	: Binary;

begin

	data 	:= null;
	extra	:= null;
	if self.buffRemain.length &gt;= 2 then
		bin[1:1] := self.buffRemain[2:1];
		bin[2:1] := self.buffRemain[1:1];
		messageLength := bin.Integer;
		if self.buffRemain.length = messageLength then
			data := self.buffRemain;
			self.buffRemain := null;
		elseif self.buffRemain.length &gt; messageLength then
			data := self.buffRemain[1 : messageLength];
			extra := self.buffRemain[messageLength + 1 : end]; 
			self.buffRemain := extra;
		endif;
	endif;
	if data &lt;&gt; null then
		self.processIndividualMessage(data);
		self.doProcessLength();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="297c2e21-d1e0-4c13-ae62-cea4500a3d2c">
        <updating/>
        <source>init(_controller: BGP_TCPClient) updating;

// cnwdvb1 28 April 2003 

vars

begin
	inheritMethod(_controller);
	beginClassNotification(CM_DisconnectPower, false, Object_Create_Event, Response_Continuous, 0); 
	beginClassNotification(CM_ConnectPower, false, Object_Create_Event, Response_Continuous, 0); 
	beginClassNotification(CM_Edit, false, Object_Create_Event, Response_Continuous, 0);
	beginNotification(app.getMyTerminalDO_NOT_USE, app.getMyTerminalDO_NOT_USE.getTerminalEvent(EVENT_REFCON_REQUEST), Response_Continuous, 0);
	
	self.connectNonComms := app.getMyTerminalDO_NOT_USE.getConfig(RefConConnectNonComms).Boolean;	
	self.commGracePeriod := app.getMyTerminalDO_NOT_USE.getConfig(RefConCommGracePeriod).Integer;	
					
end;</source>
        <Parameter name="_controller" type="BGP_TCPClient"/>
    </JadeMethod>
    <JadeMethod name="messageData" id="362059be-ec0d-4a24-ad50-694ede91585a">
        <source>messageData(_subOpCode :Integer;_ti :CM_TrackedItem/*CM_Container*/):Binary protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/12/209	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
//							method signature changed to reflect this
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	message		: String;
	now			: TimeStamp;
	emptyStr	: String;
	
begin

	message := "";
	now := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if _subOpCode = Reefer_Data then
		message := message &amp; self.timeOfAct(now);
		message := message &amp; self.rfcIdent(_ti.id);
		message := message &amp; self.rfcLocation(_ti);
		message := message &amp; self.rfcAttributes(_ti);
		message := message &amp; self.rfcCarrierInfo(_ti);

		self.logMonitor("Send Reefer_Data "&amp;now.String&amp;" "&amp;_ti.id);
	elseif _subOpCode = Reefer_Delete then
		message := message &amp; self.timeOfAct(now);
		message := message &amp; self.rfcIdent(_ti.id);
		self.logMonitor("Send Reefer_Delete "&amp;now.String&amp;" "&amp;_ti.id);
	elseif _subOpCode = Reefer_Key_Change then
		message := message &amp; self.timeOfAct(now);
		message := message &amp; self.rfcOldIdent(_ti);
		message := message &amp; self.rfcNewIdent(_ti);
		self.logMonitor("Send Reefer_Key_Change "&amp;now.String&amp;" "&amp;_ti.id&amp;" "&amp;_ti.id);
	elseif _subOpCode = Reefer_Monitor then
		message := message &amp; self.timeOfAct(now);
		message := message &amp; self.rfcIdent(_ti.id);
		message := message &amp; self.rfcAttributes(_ti);
		self.logMonitor("Send Reefer_Monitor "&amp;now.String&amp;" "&amp;_ti.id);
	elseif _subOpCode = Recall_Reefer_Data then
		message := message&amp;self.timeOfAct(now);
		self.logMonitor("Send Recall_Reefer_Data "&amp;now.String);
	elseif _subOpCode = Reefer_Monitor_Request then
		message := message&amp;self.timeOfAct(now);
		message := message &amp; self.rfcIdent(_ti.id);
		self.logMonitor("Send Reefer_Monitor_Request "&amp;now.String&amp;" "&amp;_ti.id);
	elseif _subOpCode = Handler_RFR10 then
		message := message &amp; self.recordType();
		message := message &amp; emptyStr;
		message := message &amp; self.timeOfAct(now);
		message := message &amp; self.rfcIdent(_ti.id);
		message := message &amp; self.rfcLocation(_ti);
		message := message &amp; self.rfcAttributes(_ti);
		message := message &amp; self.rfcNewIdent(_ti);
		self.logMonitor("Send Handler_RFR10 "&amp;now.String&amp;" "&amp;_ti.id);
	else
		self.logMonitor("Unknown subOpCode "&amp;now.String&amp;" "&amp;_ti.id);
	endif;
	
	return message.asANSI(0);// 14/3/16  cnwns1 PAR 36286 unicode version

end;</source>
        <access>protected</access>
        <Parameter name="_subOpCode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="messageHeader" id="ec8a1d49-425e-4de7-82af-c449279d9729">
        <source>messageHeader(_subOpCode:Integer):Binary protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	message:Binary[10];
begin
//	self.logMonitor(method.name);
	message := null;
	message[1:1] := #00.Binary[1:1]; //MSB message length
	message[2:1] := #00.Binary[1:1]; //LSB message Length
	message[3:1] := #00.Binary[1:1]; //Task number
	message[4:1] := #03.Binary[1:1]; //OpCode
	message[5:1] := self.refconComputerDest;//#00.Binary[1:1]; //message computer description
	message[6:1] := self.refconTaskDest;//#00.Binary[1:1]; //message task destination
	message[7:1] := #00.Binary[1:1]; //message computer source
	message[8:1] := #00.Binary[1:1]; //message task source
	if _subOpCode = Reefer_Data then
		message[9:1] := #01.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Delete then
		message[9:1] := #02.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Key_Change then
		message[9:1] := #03.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Monitor then
		message[9:1] := #04.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Recall_Reefer_Data then
		message[9:1] := #05.Binary[1:1]; //SubOpCode
	elseif _subOpCode = Reefer_Monitor_Request then
		message[9:1] := #06.Binary[1:1]; //SubOpCode
	endif;
	message[10:1] := #00.Binary[1:1]; //Dummy

	return message;
end;</source>
        <access>protected</access>
        <Parameter name="_subOpCode" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processImAlive" id="d5b526b9-64ac-44ae-9703-b10440adeac0">
        <updating/>
        <source>processImAlive(_buf:Binary) protected, updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	temp		: Binary[2];
	buffer		: Binary;
begin

//	self.logMonitor(method.name);
	buffer := _buf;
	temp := _buf[5:2];
	buffer[5:2] := buffer[7:2];
	buffer[7:2] := temp;
	self.sendTelegram(buffer);
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processIndividualMessage" id="8faea80e-fc64-4269-a742-ffefe8e64fcd">
        <updating/>
        <source>processIndividualMessage(_processBuff : Binary) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	opCode		:Binary[1];
	subOpCode	:Binary[1];
	id 			: String;
	
begin

	on Exception do self.xHandler(exception);
//	self.logMonitor('Processing Message');
	opCode := _processBuff[4:1];
	subOpCode := _processBuff[9:1];
	if opCode = #02.Binary[1:1] then
		if subOpCode = #04.Binary[1:1] then
			self.processImAlive(_processBuff);
		elseif subOpCode = #0A.Binary[1:1] then
			self.processInitialise(_processBuff);
		else
		endif;
	elseif opCode = #03.Binary[1:1] then
		if subOpCode = #01.Binary[1:1] then
			self.processReeferData(_processBuff);
		elseif subOpCode = #02.Binary[1:1] then
			self.processReeferDelete(_processBuff);
		elseif subOpCode = #03.Binary[1:1] then
			self.processReeferKeyChange(_processBuff);
		elseif subOpCode = #04.Binary[1:1] then
			self.processReeferMonitor(_processBuff);
		elseif subOpCode = #05.Binary[1:1] then
			self.processRecallReeferData(_processBuff);
		elseif subOpCode = #06.Binary[1:1] then
			self.processReeferMonitorRequest(_processBuff);
		endif;
	else
		self.buffRemain := null;
		id := _processBuff[25:4].ansiToString() &amp; _processBuff[30:7].ansiToString();
		self.logMonitor("WARNING: " &amp; self.class.name &amp; "::" &amp; method.name &amp; " - " &amp; "Invalid opcode: " &amp; opCode.asHex &amp; " " &amp; subOpCode.asHex &amp; " " &amp; opCode.ansiToString() &amp; " " &amp; id);
		self.logMonitor(_processBuff.ansiToString());
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_processBuff" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processInitialise" id="8c006919-8e32-4c52-9911-c1cd1eaa7a12">
        <updating/>
        <source>processInitialise(_buf:Binary) protected, updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

//	self.logMonitor("Processed Initialise message");
	self.refconComputerDest := _buf[7:1]; //message computer description
	self.refconTaskDest := _buf[8:1]; //message task destination
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processReadData" id="c5689bbd-8694-4ff5-ac25-21cbcbb2a4ec">
        <updating/>
        <source>processReadData(_buf: Binary) updating;

// cnwdvb1 01 May 2003 

vars

	processBuff		: Binary;
	count			: Integer;
	
begin
	
	//protection
	if (self.buffRemain.length + _buf.length) &gt; 2048 then	//something has gone wrong if it's this big
		self.buffRemain := _buf;
	else
		self.buffRemain := self.buffRemain &amp; _buf;
	endif;
	
	self.doProcessLength();
	
end;</source>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processRecallReeferData" id="84c43a15-5674-45e9-aeab-a3ee81cc3e3d">
        <updating/>
        <source>processRecallReeferData(_buf:Binary) protected, updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
// ---------------------------------------------------------------------------

vars
	message		: Binary;
	ti			: CM_TrackedItem;	
	terminal	: CM_Terminal;
	iter		: Iterator;
begin
//	self.logMonitor(method.name);
	terminal := app.getMyTerminalDO_NOT_USE();
	
	self.logMonitor("Receive Recall_Reefer_Data "&amp;readTimeOfAct(_buf[11:14].String).String);
	iter := terminal.allOnsiteTIsByCargoTypeId.createIterator;
	terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iter);
	while iter.next(ti) do
		//if ti.cargoType &lt;&gt;  TI_CargoType_Container then		// CCMS 1007
		//	break;												// CCMS 1007
		//endif;												// CCMS 1007
		//if ti.CM_Container.isRefConMonitored then				// CCMS 1007
		if ti.isRefConMonitored then							// CCMS 1007
			//if (not app.isDevelopmentSystem)
			//or ti.myTerminalArea.id = "A" then
				//message := self.createReeferDataTelegram(ti.CM_Container,Reefer_Data);	// CCMS 1007
				message := self.createReeferDataTelegram(ti,Reefer_Data);					// CCMS 1007
				self.sendTelegram(message);
				process.sleep(50);
			//endif;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
