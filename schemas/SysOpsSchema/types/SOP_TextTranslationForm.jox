	self.btnEdit.enabled := canEditTT;
	
	self.mnuAddTranslatableText.enabled 	:= self.btnNew.enabled;
	self.mnuDeleteXlatableText.enabled 	:= self.btnDelete.enabled;
	self.mnuEditTranslatablText.enabled := canEditTT;
	
	self.btnImport.enabled := canEditTT; // TFS 2198
	self.mnuRemoveFromTable.enabled := canEditTT; // TFS 2198
	self.mnuSetAsReviewed.enabled := canEditTT; // TFS 2198
	self.btnShowReplace.enabled := canEditTT; // TFS 2198
	
end;</source>
