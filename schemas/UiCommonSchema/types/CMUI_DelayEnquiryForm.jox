        <source>doRefresh() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	15 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.initialiseWithObject then
		self.loadSelectedDelays();
	else
		self.doQuery();
	endif;
end;
