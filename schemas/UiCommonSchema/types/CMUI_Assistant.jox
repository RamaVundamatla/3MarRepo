    <JadeMethod name="showSetPassword" id="d83ef984-dba6-4d6d-b27c-4a232b3a9750">
        <source>showSetPassword( _mode : Integer; _pxyObject : CM_Object; _config : CMIF_Config; _configField : String; _updated : Boolean output; _maxRawLength : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	form : CMUI_SetPassword;
	msg : String;
	
begin

	_updated := false;

	if _pxyObject = null and _config = null and _mode &lt;&gt; CM_TableViewForm.Mode_Add then
		msg := app.getErrorString( Proxy_Object_Null_For_Update );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return null;
	endif;
	
	
	form := app.loadForm(CMUI_SetPassword, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_SetPassword;	
	
	if form = null then
		return null;
	endif;
	
	form.setMyPxyObject( _mode, _pxyObject, _config, _configField, _maxRawLength );
	
	form.showModal;
	
	if form.modalResult = 0 then
		_updated := true;
		return form.encryptedPassword;
	endif;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_pxyObject" type="CM_Object"/>
        <Parameter name="_config" type="CMIF_Config"/>
        <Parameter name="_configField" type="String"/>
        <Parameter name="_updated" type="Boolean" usage="output"/>
        <Parameter name="_maxRawLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="showShipFullyPlanForm" id="a888a44b-d250-4628-b646-ffaded1663e7">
        <source>showShipFullyPlanForm(_voyage : CM_Voyage; _jobs : CM_JobArray; _js : CM_VoyageJobSheet; _mode : Integer; _masterMenuAction : CMUI_MenuAction) : Boolean;
//--------------------------------------------------
// Created:	08 May 2006 By: cnwgd1
//--------------------------------------------------
vars
	planForm : CMUI_ShipFullyPlanForm;
begin

	if _voyage = null and _js = null and _jobs = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Parameters');
		return null;
	endif;
		
	planForm := app.loadForm(CMUI_ShipFullyPlanForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_ShipFullyPlanForm;
	if planForm = null then
		return false;
	endif;	
	
	planForm.mode := _mode;
	planForm.myCurrentVoyage := _voyage;
	planForm.myCurrentJS := _js;
	planForm.myBorrowedMenuAction := _masterMenuAction;
	
	if _jobs &lt;&gt; null then
		_jobs.copy(planForm.allJobs);
	endif;
	planForm.show();

	return planForm.modalResult = IDOK;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobs" type="CM_JobArray"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
