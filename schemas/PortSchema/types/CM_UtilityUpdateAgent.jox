    <JadeMethod name="utlUpdateStopsTable" id="c45faebc-3050-41bc-819a-ec419114fa82">
        <source>utlUpdateStopsTable(_proxyStopTable : CM_StopsTable input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realStopTable	: CM_StopsTable;
	expectedEdition	: Integer;
begin

	self.initialiseActivity();

	_proxyStopTable.raiseExceptionIfNotProxy(method);
	_proxyStopTable.pxyGetRealObjectAndEdition(realStopTable, expectedEdition);
	
	if realStopTable = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_StopsTable.name, null, null);
		return;
	endif;

	exclusiveLock(realStopTable);

	if _passport.noErrors and realStopTable.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Stops Table', null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valStopTable(_proxyStopTable, realStopTable); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStopTable, true);
	endif;
	
	if _passport.noErrors then
		realStopTable.setForUpdate(_proxyStopTable);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStopTable, false);
	endif;

end;</source>
        <Parameter name="_proxyStopTable" type="CM_StopsTable" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateStorageConfig" id="92f32b5d-0064-4625-9ab8-7c72a23e4b46">
        <source>utlUpdateStorageConfig(_proxyStorageConfig : CM_StorageConfig; _passport : CM_Passport input);
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
vars
	realStorageConfig	: CM_StorageConfig;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();

	_proxyStorageConfig.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyStorageConfig.pxyGetRealObjectAndEdition(realStorageConfig, expectedEdition);

	if realStorageConfig= null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_StorageConfig.name, null, null);
		return;
	endif;

	//app.myValUA.valStorageConfig(_proxyStorageConfig);											//-TFS7228
	app.myValUA.valStorageConfig(_proxyStorageConfig, realStorageConfig);		//+TFS7228

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realStorageConfig);

	if _passport.noErrors and realStorageConfig.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "storageConfig", null, null);
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStorageConfig, true);
	endif;

	if _passport.noErrors then
		realStorageConfig.setForUpdate(_proxyStorageConfig,_passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStorageConfig, false);
	endif;

end;
</source>
        <Parameter name="_proxyStorageConfig" type="CM_StorageConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateStorageConfigTypeSSL" id="304b7a6b-928f-41a6-b585-5f9423d3fda7">
        <updating/>
        <source>utlUpdateStorageConfigTypeSSL(	_allExtraDayCargoTypes : IntegerArray input; 
								_passport : CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2022	jlier1	Initial creation TFS 52292

*/

vars

	storageConfigSSL : CM_StorageConfigTypeSSL;
begin
	self.initialiseActivity();


	app.setContinueCMExceptions(true);

	storageConfigSSL:=CM_StorageConfigTypeSSL.firstInstance;

	if storageConfigSSL= null then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	self.myUpdateAuditAgent.audUpdateGeneric(storageConfigSSL, true);
	
	storageConfigSSL.setAllExtraDayCargoTypes(_allExtraDayCargoTypes);
	
	self.myUpdateAuditAgent.audUpdateGeneric(storageConfigSSL, false);
	

epilog

end;</source>
