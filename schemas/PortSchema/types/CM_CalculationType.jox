    <JadeMethod name="isStorageCalculation" id="88989ac4-6c33-4025-974d-c8d4b327721c">
        <source>isStorageCalculation() : Boolean;
// return true if the calculation type is used for cargo storage
//  used for CCMS 1279 escalating charge option
vars

begin
	if self.calculationType = INV_CALC_TYPE_DAYS_SINCE_RECVL or
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_SUBTERM or	//28 Jun 2018	NDL	TFS 39338
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_EN or
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_VOY_IN or
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_VOY_OUT or
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU or
	   self.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT or	//08 May 2018	NDL	TFS 38525
	   self.calculationType = INV_CALC_TYPE_DAYS_WEIGHT or 
	   self.calculationType = INV_CALC_TYPE_DAYS_VOLUME or 
	   self.calculationType = INV_CALC_TYPE_DAYS_ONSITE_AT or
	   self.calculationType = INV_CALC_TYPE_DAYS_CONNECTED	
	   then	
		return true;
	else
		return false;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
