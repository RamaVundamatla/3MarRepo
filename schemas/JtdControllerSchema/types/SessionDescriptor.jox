    <JadeMethod name="doCmdTerminateMachine" id="aa394989-eb50-4861-b73b-3a6c19d0830d">
        <source>doCmdTerminateMachine(md : MachineDescriptor);

vars
	pd : ProcessDescriptor;
	
begin
	if md = null then
		return;
	endif;
	
	foreach pd in md.allProcessDescriptors do
		if pd.myProcess &lt;&gt; null then
			self.doCmdTerminate(pd.myProcess);
		endif;
	endforeach;
end;</source>
        <Parameter name="md" type="MachineDescriptor"/>
    </JadeMethod>
    <JadeMethod name="doPingResponse" id="c548c19c-65d3-4616-b0c5-f798682b9534">
        <updating/>
        <source>doPingResponse(response : String) updating, protected;

vars
	processMD, nodeMD : MachineDescriptor;
	i, n, eventNo, len : Integer;
	respondingProcess : Process;
	nodeDescCreated : Boolean;
	s, profileName : String;
	jds : JtdDriverSummary;
	d : ProcessDescriptor;
	nd : NodeDescriptor;
	o : Object;
	
begin
	respondingProcess := null;
	profileName := "&lt;Unknown&gt;";
	nodeDescCreated := false;
	len := response.length;
	eventNo := 0;
	n := 1;

	// get the process oid
	s := response.scanUntil(';', n);
	if n &lt; 1 or s = null then
		return;
	endif;
	o := s.asOid;
	if o = null or (not Process.hasInstance(o)) then
		return;
	endif;
	respondingProcess := o.Process;

	// move past the delimiter
	n := n + 1;

	// get the profile name
	if n &lt;= len then
		profileName := response.scanUntil(';', n);
		if n &lt; 1 or profileName = null then
			return;
		endif;
		// move past the delimiter
		n := n + 1;
	endif;
	i := profileName.length;
	if i &gt; self.maxProfileNameLength then
		self.maxProfileNameLength := i;
	endif;

	// extract the remainder of the response
	if n &gt; len then
		s := null;
	else
		s := response[n : end];
	endif;

	// process the machine information - this returns the remainder
	// of the string following the machine information (if any)
	s := self.processMachineInfoFromString(s, processMD, nodeMD);
	
	// do we have an existing descriptor for this process?
	d := self.allProcessDescsByProcess[respondingProcess];
	
	if d &lt;&gt; null then
		// yes, so update it
		nd := d.myNodeDescriptor;
		if nd &lt;&gt; null then
			self.mySummary.jtdSubtractSummary(nd.mySummary, false);
			nd.mySummary.jtdSubtractSummary(d.mySummary, false);
		endif;
			
		eventNo := ProcessDescriptorUpdated;
	else
		// no, so create a new descriptor
		nd := self.getNodeDescriptor(respondingProcess.node, nodeMD, nodeDescCreated);
		
		create d transient;
		d.updateForCreate(respondingProcess, processMD, self, nd);

		if nd &lt;&gt; null then
			self.mySummary.jtdSubtractSummary(nd.mySummary, false);
		endif;

		if nodeDescCreated then
			eventNo := NodeAndProcessDescCreated;
		else
			eventNo := ProcessDescriptorCreated;
		endif;
	endif;

	// update the driver details on the descriptor
	d.updateDriverDetailsFromString(s, profileName);

	if nd &lt;&gt; null then
		jds := d.mySummary;
		nd.mySummary.jtdAddSummary(jds, false);
		self.mySummary.jtdAddSummary(nd.mySummary, false);
	endif;

	// set the elapsed time on the summaries
	d.setElapsedSecondsOnSummary;
	nd.setElapsedSecondsOnSummary;
	self.setElapsedSecondsOnSummary;
	
	// cache rate values
	jds := self.mySummary;
	self.lastReadTPS := jds.jtdGetReadTPS;
	self.lastUpdTPS := jds.jtdGetUpdTPS;
	self.lastTotalTPS := self.getTotalTPS;
		
	// store the current available db server disk space and memory
	self.getDbServerFreeDiskAndMemory;
	
	if eventNo &gt; 0 then
		process.causeEvent(eventNo, true, d);
	endif;
	
epilog
	if respondingProcess &lt;&gt; null then
		// our responding process won't send another ping until it
		// knows we received this one (to stop the controller from
		// being flooded with notifications)
		respondingProcess.causeEvent(CmdEventNumber, true, CmdPingAck);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="response" type="String"/>
    </JadeMethod>
    <JadeMethod name="doProcessDeleted" id="612fd313-21ec-49c2-99cb-26b68881a0f4">
        <updating/>
        <source>doProcessDeleted(p : Process) updating, protected;

vars
	d, dSave : ProcessDescriptor;
	n, nSave : NodeDescriptor;
	
begin
	d := self.allProcessDescsByProcess[p];
	if d = null then
		return;
	endif;

	dSave := d;
	n := d.myNodeDescriptor;
	nSave := n;

	if n &lt;&gt; null then
		self.mySummary.jtdSubtractSummary(n.mySummary, false);
		n.mySummary.jtdSubtractSummary(d.mySummary, false);
		self.mySummary.jtdAddSummary(n.mySummary, false);
	endif;

	self.subtractTrxDescsForProcessDesc(d);
	
	delete d; // this will set d to null, but we still have dSave

	if n &lt;&gt; null then
		if n.allProcessDescriptors.size &lt; 1 then
			delete n; // this will set n to null, but we still have nSave
				
			if self.allNodeDescriptorsByName.size &lt; 1 then
				self.initialize;
				process.causeEvent(SessionDescriptorInitialized, true, null);
				return;
			endif;
		else
			if not n.isRunning then
				n.stopClock;
			endif;
		endif;
	endif;

	if not self.isRunning then
		self.stopClock;
	endif;

	process.causeEvent(ProcessDescriptorDeleted, true,
		getOidStringForObject(dSave) &amp; ';' &amp; getOidStringForObject(nSave));
end;</source>
        <access>protected</access>
        <Parameter name="p" type="Process"/>
    </JadeMethod>
    <JadeMethod name="doProfileMethodResponse" id="7cda3bd1-4ceb-4c9a-bfa1-e1f3daf789ac">
        <source>doProfileMethodResponse(response : String) protected;

// response string is &lt;errNo&gt; ; &lt;method name&gt; ; &lt;file name&gt;

vars
	errNo, firstDelimPos, secondDelimPos, len, result : Integer;
	mthName, fileName, errTxt : String;
	
begin
	len := response.length;
	
	if len &lt; 5 then
		// bad response - don't do anything with it
		return;
	endif;

	// look for the first delimiting ';'
	firstDelimPos := response.pos(';', 1);

	if firstDelimPos &lt; 2 or firstDelimPos &gt;= len then
		// bad response - don't do anything with it
		return;
	endif;
	
	// look for the second delimiting ';'
	secondDelimPos := response.pos(';', firstDelimPos + 1);

	if secondDelimPos &lt;= (firstDelimPos + 1) or secondDelimPos &gt;= len then
		// bad response - don't do anything with it
		return;
	endif;
	
	errNo := response[1 : firstDelimPos - 1].Integer;
	mthName := response[firstDelimPos + 1 : secondDelimPos - firstDelimPos - 1];
	fileName := response[secondDelimPos + 1 : end];
	
	if errNo &lt;&gt; 0 then
		app.msgBox("The process profiling method " &amp; mthName &amp;
			" encountered an error when saving the profile information." &amp; CrLf &amp;
			CrLf &amp; "The most common causes of error are an invalid output file " &amp;
			"name, or the file name not being" &amp; CrLf &amp; "accessible to the process " &amp;
			"capturing the profile." &amp; CrLf &amp; CrLf &amp; "Error Number: " &amp; errNo.String &amp;
			CrLf &amp; CrLf &amp; "File Name: " &amp; fileName, "Error Saving Profile Information",
			MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox("Profile of method " &amp; mthName &amp; " complete." &amp; CrLf &amp; CrLf &amp;
		"The profile information has been written to " &amp; fileName &amp; CrLf &amp; CrLf &amp;
		"Do you want to open the file now?", "Method Profile Complete",
		MsgBox_Information_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes
	then
		return;
	endif;

	errNo := 0;
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	if app.isUnicode then
		result := call winShellExecuteW(app.myControllerForm.hwnd, "open", fileName, null, null, 1);
	else
		result := call winShellExecuteA(app.myControllerForm.hwnd, "open", fileName, null, null, 1);
	endif;

	if errNo &lt;&gt; 0 then
		app.msgBox("Error opening file: " &amp; fileName &amp; CrLf &amp; CrLf &amp;
			'[' &amp; errNo.String &amp; "] " &amp; errTxt, "Error Opening File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if result &lt;= 32 then
		app.msgBox("Error opening file: " &amp; fileName &amp; CrLf &amp; CrLf &amp;
			"Windows error code: " &amp; result.String, "Error Opening File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="response" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTrxPingResponse" id="4fc979a4-583c-4818-87eb-4a1e7a501966">
        <updating/>
        <source>doTrxPingResponse(pingResponse : String) updating, protected;

vars
	processTD : ProcessTransactionDescriptor;
	sessionTD : SessionTransactionDescriptor;
	isUpdating, processDescCreated : Boolean;
	processDesc : ProcessDescriptor;
	s, trxName, response : String;
	jts : JtdTransactionSummary;
	n, eventNo : Integer;
	p : Process;
	o : Object;
	
begin
	eventNo := 0;
	
	// assume transaction is updating by default
	isUpdating := true;

	// work with a local variable so parameter doesn't have to be io
	response := pingResponse; 
	
	// get the process oid
	n := 1;
	s := response.scanUntil(';', n);
	if n &lt; 1 or s = null then
		return;
	endif;
	o := s.asOid;
	if o = null or (not Process.hasInstance(o)) then
		return;
	endif;
	p := o.Process;

	// do we have a descriptor for the process that's responded?
	processDesc := self.allProcessDescsByProcess[p];
	if processDesc = null then
		// no, so don't process any responses from this process yet
		return;
	endif;
	
	// extract the remainder of the response
	if (n + 1) &gt; response.length then
		// no transaction name in response - can't do anything!
		return;
	endif;
	response := response[n + 1 : end];

	// get the transaction name
	n := 1;
	trxName := response.scanUntil(';', n).trimBlanks;
	if n &lt; 1 or trxName = null then
		// no transaction name in response - can't do anything!
		return;
	endif;
	
	// extract the remainder of the response
	if (n + 1) &gt; response.length then
		response := null;
	else
		response := response[n + 1 : end];
	endif;

	// is the transaction updating or read-only?
	if response &lt;&gt; null then
		n := 1;
		s := response.scanUntil(';', n).trimBlanks;
		if n &gt; 0 then
			isUpdating := (s = "true" or s = "TRUE");
			
			// extract the remainder of the response
			if (n + 1) &gt; response.length then
				response := null;
			else
				response := response[n + 1 : end];
			endif;
		endif;
	endif;

	// does our process descriptor have a descriptor for this transaction?
	processDescCreated := false;
	processTD := processDesc.allTransactionDescsByName[trxName];
	if processTD = null then
		// no, so create a new transaction descriptor
		create processTD transient;
		processTD.updateForCreate(trxName, isUpdating, processDesc);
		processDescCreated := true;
	endif;
	jts := processTD.mySummary;

	// does our session (self) have a descriptor for this transaction?
	sessionTD := self.allSessionTrxDescsByName[trxName];
	if sessionTD = null then
		// no, so create a new transaction descriptor
		create sessionTD transient;
		sessionTD.updateForCreate(trxName, isUpdating, self);
		eventNo := TransactionDescriptorCreated;
	else
		eventNo := TransactionDescriptorUpdated;
		// we have an existing session transaction descriptor, so if we haven't
		// just created a process transaction descriptor, we must subtract it
		// from our session totals before updating it and adding it back, below
		if not processDescCreated then
			sessionTD.mySummary.jtdSubtractSummary(jts, false);
		endif;
	endif;
		
	// update the process descriptor's transaction descriptor
	processTD.updateFromString(response);
	
	// add the updated process transaction descriptor into the session's totals
	sessionTD.mySummary.jtdAddSummary(jts, false);
	
	if eventNo &gt; 0 then
		process.causeEvent(eventNo, true, sessionTD);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pingResponse" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommandTarget" id="8daa4f36-fa15-43e4-90ef-4ae33d4f1b06">
        <source>getCommandTarget() : Object;

begin
	return system;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getDbServerFreeDiskAndMemory" id="3999b15f-6221-4fa6-9a12-672df23b8d99">
        <updating/>
        <source>getDbServerFreeDiskAndMemory() updating;

vars
	freeDisk : Decimal[23];
	driveName : String;
	freeMem : Integer;
	
begin
	system.getFreeDiskAndMemoryOnDbServer(freeMem, freeDisk, driveName);

	// our db server descriptor should have been created by our constructor
	if self.myDbServerMachineDescriptor &lt;&gt; null then
		self.myDbServerMachineDescriptor.setAvailableMemory(freeMem);
	endif;
	
	self.dbServerFreeDisk := freeDisk;
	self.dbServerDriveName := driveName.toUpper;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDbServerFreeMemoryMegabytes" id="5f8bfa8b-3a85-48d7-a157-ee9a97577eb8">
        <source>getDbServerFreeMemoryMegabytes() : Real;

begin
	if self.myDbServerMachineDescriptor = null then
		return 0;
	endif;
	return self.myDbServerMachineDescriptor.availableMemory.asMegabytes;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNodeDescriptor" id="93de3b43-5775-455f-a5b6-509ca5db7045">
        <source>getNodeDescriptor(_node : Node; _machine : MachineDescriptor;
	_created : Boolean output) : NodeDescriptor protected;

vars
	nd : NodeDescriptor;
	
begin
	_created := false;
	
	if _node = null then
		return null;
	endif;
	
	nd := self.allNodeDescriptorsByNode[_node];
	
	if nd = null then
		create nd transient;
		nd.updateForCreate(_node, _machine, self);
		_created := true;
	endif;
	
	return nd;
end;</source>
        <access>protected</access>
        <Parameter name="_node" type="Node"/>
        <Parameter name="_machine" type="MachineDescriptor"/>
        <Parameter name="_created" type="Boolean" usage="output"/>
        <ReturnType type="NodeDescriptor"/>
    </JadeMethod>
    <JadeMethod name="getProfileSummaryString" id="64a33c11-cd05-4097-a614-077f98624d5a">
        <source>getProfileSummaryString(gap : Integer; numProfiles : Integer output) : String;

vars
	profileName, prevProfileName, s : String;
	n, t, gapChars : Integer;
	pd : ProcessDescriptor;
	iter : Iterator;
	p : Process;
	
begin
	numProfiles := 0;
	
	iter := self.allProcessDescsByProfileProc.createIterator;

	s := null;
	profileName := null;
	prevProfileName := null;
	n := 0;
	t := 0;

	if gap &lt; 1 then
		gapChars := 0;
	else
		gapChars := gap;
	endif;
			
	while iter.next(pd) do
		self.allProcessDescsByProfileProc.getIteratorKeys(profileName, p, iter);
		
		if prevProfileName &lt;&gt; null and profileName &lt;&gt; prevProfileName then
			if s &lt;&gt; null then
				s := s &amp; CrLf;
			endif;
			s := s &amp; prevProfileName.padBlanks(self.maxProfileNameLength + gapChars) &amp; n.String;
			n := 0;
			t := t + 1;
		endif;
		
		n := n + 1;
		prevProfileName := profileName;
	endwhile;
	
	if n &gt; 0 then
		if s &lt;&gt; null then
			s := s &amp; CrLf;
		endif;
		s := s &amp; prevProfileName.padBlanks(self.maxProfileNameLength + gapChars) &amp; n.String;
		t := t + 1;
	endif;

	numProfiles := t;
	
	return "Name".padBlanks(self.maxProfileNameLength + gapChars) &amp; "Processes" &amp; CrLf &amp; s;
	
epilog
	delete iter;
end;</source>
        <Parameter name="gap" type="Integer"/>
        <Parameter name="numProfiles" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableString" id="2a636977-f865-4fd1-b468-56dc01826f58">
        <source>getTableString() : String;

vars
	s : String;
	
begin
	if self.myDbServerMachineDescriptor &lt;&gt; null then
		s := self.myDbServerMachineDescriptor.getAvailableMemoryString;
	else
		s := null;
	endif;
	
	return "System" &amp; Tab &amp; self.getTableStringFromSummary &amp; Tab &amp; s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalAndLatestTimeStrings" id="cf6506b4-43cd-4807-b5a2-b52fc0be296b">
        <source>getTotalAndLatestTimeStrings(totalStr, latestStr : String output);

vars
	totalSecs : Real;
	
begin
	totalStr := 0.Real.asTimeStringFromSeconds;
	latestStr := totalStr;
	
	totalSecs := self.getTotalSecs;
	
	if totalSecs &lt;= 0 then
		return;
	endif;
	
	totalStr := totalSecs.asTimeStringFromSeconds;
	
	if self.mostRecentRunElapsedSecs &gt;= totalSecs then
		latestStr := totalStr;
		return;
	endif;
	
	latestStr := self.mostRecentRunElapsedSecs.asTimeStringFromSeconds;
end;</source>
        <Parameter name="totalStr" type="String" usage="output"/>
        <Parameter name="latestStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="db0ee9cf-f274-403e-86f9-1267d63ab8fb">
        <updating/>
        <source>initialize() updating;

begin
	self.allProcessDescsByName.purge;
	self.allNodeDescriptorsByName.purge;
	self.allSessionTrxDescsByName.purge;
	self.allMachineDescriptors.purge;
	
	self.mySummary.jtdInitialize;

	self.clockStart := 0;
	self.clockElapsed := 0;
	
	self.lastReadTPS := 0;
	self.lastUpdTPS := 0;
	self.lastTotalTPS := 0;
	self.lastProfiledMethodName := null;
	self.lastProfiledOutputFileName := null;
	self.lastAutoPingSetting := 0;
	self.lastTrxDelaySetting := 0;

	self.mostRecentRunElapsedSecs := 0;
	self.maxRunMinutes := 0;

	self.maxProfileNameLength := 0;
	self.maxMachineNameLength := 0;
		
	self.cloneAppServer := null;
	self.cloneAppServerPort := 0;
	self.cloneFatClientsExternally := false;
	
	self.createDbServerMachineDesc;
end;</source>
    </JadeMethod>
    <JadeMethod name="isRunning" id="33444c6a-e377-4fd9-872f-912059cd98d4">
        <source>isRunning() : Boolean;

begin
	return self.allRunningProcessDescsByName.size &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processMachineInfoFromString" id="9fef24e8-2b17-4f22-af47-3e00bc73f541">
        <updating/>
        <source>processMachineInfoFromString(infoString : String; processMD,
	nodeMD : MachineDescriptor output) : String updating, protected;

vars
	localMachineName, thinMachineName, localCPU, thinCPU : String;
	localTotal, localAvail : Integer;
	thinTotal, thinAvail : Integer;
	i, n, len, nameLen : Integer;
	vs, s : String;
	
begin
	processMD := null;
	nodeMD := null;

	if infoString = null or infoString.pos(';', 1) &lt; 1 then
		// The supplied string is null or has no delimiter characters.
		// Either way, we're not going to find any machine info!
		return infoString;
	endif;

	// we can safely trim any leading spaces because we know we're going
	// to process at least one token (there is at least one delimiter in
	// the string - determined above)
	vs := infoString.trimLeft;

	i := 1;
	n := 1;
	len := vs.length;
		
	while n &lt;= len do
		s := vs.scanUntil(';', n).trimBlanks;
		
		if n &lt; 1 then
			break;
		endif;

		if i = 1 then
			localMachineName := s;
		elseif i = 2 then
			localTotal := s.Integer;
		elseif i = 3 then
			localAvail := s.Integer;
		elseif i = 4 then
			localCPU := s;
		elseif i = 5 then
			thinMachineName := s;
		elseif i = 6 then
			thinTotal := s.Integer;
		elseif i = 7 then
			thinAvail := s.Integer;
		elseif i = 8 then
			thinCPU := s;
			n := n + 1;
			break;
		endif;

		n := n + 1;
		i := i + 1;
	endwhile;

	if n &gt; len then
		// there is nothing to return beyond the machine info
		s := null;

	elseif n &gt; 0 then
		// 'n' is the position of the first character after the last
		// delimiter, so we need to return the remainder of the string
		// starting from this character
		s := vs[n : end];
		
	else
		// 'n' is less than 1, so 's' has been set to the remainder of
		// the string by the last scanUntil (above)
	endif;
	
	if thinMachineName &lt;&gt; null then
		// the process is to be associated with the thin client machine
		processMD := self.allMachineDescriptors[thinMachineName];
		if processMD = null then
			create processMD transient;
			processMD.updateForCreate(thinMachineName, thinTotal, thinAvail, thinCPU, self);
			nameLen := thinMachineName.length;
			if nameLen &gt; self.maxMachineNameLength then
				self.maxMachineNameLength := nameLen;
			endif;
		else
			processMD.setTotalAndAvailableMemory(thinTotal, thinAvail);
		endif;
	endif;
	
	if localMachineName &lt;&gt; null then
		if localMachineName = thinMachineName then
			// the thin client is running on the same machine as the app server,
			// so both the thin client process (handled above) and the node (app
			// server) refer to the same machine descriptor
			nodeMD := processMD;

		elseif thinMachineName = null then
			// we don't have a thin client, so this must be a fat client process
			// in which case the process and node are on the same machine
			processMD := self.allMachineDescriptors[localMachineName];
			if processMD = null then
				create processMD transient;
				processMD.updateForCreate(localMachineName, localTotal, localAvail, localCPU, self);
				nameLen := localMachineName.length;
				if nameLen &gt; self.maxMachineNameLength then
					self.maxMachineNameLength := nameLen;
				endif;
			else
				processMD.setTotalAndAvailableMemory(localTotal, localAvail);
			endif;
			nodeMD := processMD;

		else
			// we have a thin client but it's running on a different machine,
			// therefore the local machine is hosting the app server which is
			// the node of the thin client process
			nodeMD := self.allMachineDescriptors[localMachineName];
			if nodeMD = null then
				create nodeMD transient;
				nodeMD.updateForCreate(localMachineName, localTotal, localAvail, localCPU, self);
				nameLen := localMachineName.length;
				if nameLen &gt; self.maxMachineNameLength then
					self.maxMachineNameLength := nameLen;
				endif;
			else
				nodeMD.setTotalAndAvailableMemory(localTotal, localAvail);
			endif;
		endif;
	endif;
	
	return s;
end;</source>
        <access>protected</access>
        <Parameter name="infoString" type="String"/>
        <Parameter name="processMD" type="MachineDescriptor" usage="output"/>
        <Parameter name="nodeMD" type="MachineDescriptor" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="start" id="e06745ee-2010-4a00-8aa7-2d0d5a839952">
        <updating/>
        <source>start() updating;

vars
	nd : NodeDescriptor;
	
begin
	self.startClock;
	
	foreach nd in self.allNodeDescriptorsByNode do
		nd.start;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="startClock" id="169e3f9c-eff4-4d59-a233-8990858220fc">
        <updating/>
        <source>startClock() updating;

begin
	if self.clockStart &lt;= 0 then
		self.clockStart := app.clock;

		self.endTimer(self.MaxRunMinutesTimerEvent);
				
		if self.maxRunMinutes &gt; 0 then
			self.beginTimer(self.maxRunMinutes * 60000, Timer_OneShot, self.MaxRunMinutesTimerEvent);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stop" id="fca4502d-cc49-4570-a841-0d012050f1e2">
        <updating/>
        <source>stop() updating;

vars
	nd : NodeDescriptor;
	
begin
	foreach nd in self.allNodeDescriptorsByNode do
		nd.stop;
	endforeach;
	
	self.stopClock;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopClock" id="35044480-13ae-4ec5-bc7a-019f9df4924f">
        <updating/>
        <source>stopClock() : Real updating;

vars
	elapsedSecs : Real;
	
begin
	elapsedSecs := inheritMethod;
	
	self.endTimer(self.MaxRunMinutesTimerEvent);

	if elapsedSecs &gt; 0 then
		self.mostRecentRunElapsedSecs := elapsedSecs;
	endif;
	
	return elapsedSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="subtractTrxDescsForProcessDesc" id="ea122296-f2ca-4c54-9eff-00de4cd4ef63">
        <source>subtractTrxDescsForProcessDesc(pd : ProcessDescriptor) protected;

vars
	processTD : ProcessTransactionDescriptor;
	sessionTD : SessionTransactionDescriptor;
	
begin
	if pd = null then
		return;
	endif;
	
	foreach processTD in pd.allTransactionDescsByName do
		sessionTD := self.allSessionTrxDescsByName[processTD.name];
		if sessionTD &lt;&gt; null then
			sessionTD.mySummary.jtdSubtractSummary(processTD.mySummary, false);
			process.causeEvent(TransactionDescriptorUpdated, true, sessionTD);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pd" type="ProcessDescriptor"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="ca9fc783-1fa1-4f4a-9d51-851813f27974">
        <updating/>
        <source>sysNotification(eventType : Integer; theObject : Object; eventTag : Integer) updating;

begin
	if eventType &lt;&gt; Object_Delete_Event then
		return;
	endif;
	
	// If we get any exceptions processing a notification, we just abort
	// the operation which will cut the stack back to an idle point. The
	// notification is effectively ignored.
	on Exception do app.abortActionExHandler(exception);
	
	if not Process.hasInstance(theObject) then
		return;
	endif;

	self.doProcessDeleted(theObject.Process);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="bcc2cd8c-4d01-45f9-8640-67cb0438eecc">
        <updating/>
        <source>timerEvent(eventTag : Integer) updating;

begin
	if eventTag &lt;&gt; self.MaxRunMinutesTimerEvent then
		return;
	endif;
	
	if self.isRunning then
		self.doCmdStop(null);
/*		app.msgBox("The maximum run time has been achieved." &amp; CrLf &amp;
			CrLf &amp; "Drivers have been asked to stop after " &amp;
			self.mostRecentRunElapsedSecs.asTimeStringFromSeconds,
			"Run Stopped", MsgBox_Information_Icon + MsgBox_OK_Only); /* */
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="d11a38cc-5465-4b53-8518-87b64f3d99a7">
        <updating/>
        <source>userNotification(eventType : Integer; theObject : Object; eventTag : Integer; userInfo : Any) updating;

vars
	obj : Object;
	
begin
	// If we get any exceptions processing a notification, we just abort
	// the operation which will cut the stack back to an idle point. The
	// notification is effectively ignored.
	on Exception do app.abortActionExHandler(exception);

	if eventType = CmdPingResponseEventNumber then
		self.doPingResponse(userInfo.String);
		if self.maxRunMinutes &gt; 0 and
		   (self.getCurrentRunElapsedSeconds / 60) &gt;= self.maxRunMinutes and
		   self.isRunning
		then
			self.doCmdStop(null);
/*			app.msgBox("The maximum run time has been achieved." &amp; CrLf &amp;
				CrLf &amp; "Drivers have been asked to stop after " &amp;
				self.mostRecentRunElapsedSecs.asTimeStringFromSeconds,
				"Run Stopped", MsgBox_Information_Icon + MsgBox_OK_Only); /* */
		endif;

	elseif eventType = CmdTrxPingResponseEventNumber then
		self.doTrxPingResponse(userInfo.String);
		
	elseif eventType = CmdProfileMthResponseEventNo then
		self.doProfileMethodResponse(userInfo.String);
		
	elseif eventType = CmdDriverStopResponseEventNo then
		obj := userInfo.String.asOid();//Object;
		if obj &lt;&gt; null and Process.hasInstance(obj) then
			self.doCmdStop(obj);
		endif;

	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
