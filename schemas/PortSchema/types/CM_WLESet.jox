<CollClass name="CM_WLESet" id="52673bd0-99ab-4a79-bea6-f7542ab5a549">
    <memberType name="CM_WorkListEntry"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <JadeMethod name="getExistingPlannedROROJob" id="83d8b611-8dbd-4c72-9cf7-90ef9736d04c">
        <source>getExistingPlannedROROJob( _toLc : CM_LocationsController ):CM_Job;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2015	cnwndl1	Initial creation	Par 35643	Par 35643  &amp; 35655

*/

vars

	iter : Iterator;
	wle : CM_WorkListEntry;
	job : CM_Job;
	term : CM_Terminal;
	lc : CM_LocationsController;
	tmpFoundHeight : Integer;
	
begin

	if _toLc = null then
		return null;
	endif;

	iter := self.createIterator;
	while iter.next( wle ) do
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		if wle.locationTarget.trimBlanks = null then
			continue;
		endif;
		if term = null then
			term := wle.getMyTerminal();
			if term = null then
				continue;
			endif;
		endif;
		lc := null;
		term.findLocationFromString( wle.locationTarget, true, lc, tmpFoundHeight);
		if lc = null then
			continue;
		endif;
		if lc = _toLc then
			job := wle.job;
			if  job &lt;&gt; null and job.isKindOf( CM_VoyageROROJob ) then
				return job;
			endif;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;
</source>
        <Parameter name="_toLc" type="CM_LocationsController"/>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnactionedWLE" id="df022c45-d9fd-436d-9e6c-918aea4c54d9">
        <source>getFirstUnactionedWLE() : CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2016	cnwmc5	Initial creation		PAR 37483 

*/

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self do
		if wle.status = WLE_UNACTIONED then
			return wle;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getFirstWleOfClass" id="1faaeef5-56ff-4d09-93ce-5412c0f6a467">
        <source>getFirstWleOfClass( _class : Class ) : CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2019	jlgzm1	Initial creation TFS42863

*/

vars
	wle : CM_WorkListEntry; 
begin
	foreach wle in self where wle.class = _class do
		return wle;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
</CollClass>
