    <JadeMethod name="validateMe" id="c5d2383a-b244-4aca-82f2-74cfefefe369">
        <source>validateMe();
/*
Purpose:			

Return Value:		

Date		Who		Reason
11 April 2007	cnwer1	Initial creation - PAR#xxxx
           required fields for Chassis are ID, Operator, Trailer Type
*/
vars
	taskDescObj		: CM_ToDoTaskDesc;
	cargoTypeObj	: CM_CargoType;
	raisedGenSet	: Boolean;
	
begin

	inheritMethod();

	//process.debug();
/*	if self.myInitialLocation = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Initial Location', null, null);
	endif;
*/
	
	if self.myTILCType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Trailer_Type), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Trailer_Type), null, null); // cnwdb2	PAR 35364
	endif;

		
	cargoTypeObj	:=	self.getCargoTypeObject();

	if cargoTypeObj &lt;&gt; null then
		foreach taskDescObj in self.allToDoTaskDesc do
			if not self.validateTaskForGenSet(taskDescObj) then	//Par18302. Jan 2009
				if not raisedGenSet	then	// avoiding message duplicate - there are 2 tasks: Attcah and Detach Gen Set
					app.raiseCMException(ERR_AttachAndDetachGenSet, null, self);
					raisedGenSet := true;
				endif;
			endif;
		endforeach;
	endif;

	
end;</source>
    </JadeMethod>
