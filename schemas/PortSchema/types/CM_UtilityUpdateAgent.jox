    <JadeMethod name="utlResetSystemDefForView" id="d953054a-6a2d-4450-9ab8-379868e22996">
        <updating/>
        <source>utlResetSystemDefForView(_view : EntTableView; _rowArray : EntTableRowArray; _def : EntTableDef; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	row		: EntTableRow;
	newView	: EntTableView;
	
begin
	exclusiveLock(_view);
	
	if _view.isTransient() then
		self.raiseExceptionIfNull(_def, 'Entry Table Definition');
		create newView persistent;
		newView.set(_view.name, _view.description, _def);
	else
		newView := _view;
	endif;
	
	newView.clearRows();
	
	foreach row in _rowArray do
		newView.addRow(row);
	endforeach;
end;</source>
        <Parameter name="_view" type="EntTableView"/>
        <Parameter name="_rowArray" type="EntTableRowArray"/>
        <Parameter name="_def" type="EntTableDef"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
