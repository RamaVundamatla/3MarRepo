    <JadeMethod name="highlightCurrentVoyage" id="813dd7c6-2c47-4b42-908a-c71aec30c067">
        <updating/>
        <source>highlightCurrentVoyage():Boolean updating;

vars
	count:			Integer;
	currVoyage:		CMIF_HMS_WorkingVoyage;
	obj:			Object;
	found:			Boolean;
begin
 	// This method scan the matches table to see if the current voyage is included
 	// If it is, highlight this row.

 	if  self.myViewController = null then
 		return false;
 	endif;

 	if self.myViewController.myCurrentWorkingMovement = null then
 		return false;
 	endif;
 	 	
 	currVoyage	:= self.myViewController.myCurrentWorkingMovement.myWorkingVoyage;
 	found:=false;
 	if currVoyage &lt;&gt; null then
 		count:=1;
 		while count &lt;= self.tblMatchesFound.rows do
 			obj := self.tblMatchesFound.accessRow(count).itemObject;
 			if obj &lt;&gt; null then
 				if obj.CM_Voyage = currVoyage.ofPermanentVoyage then
 					// Select this row
 					self.tblMatchesFound.accessRow(count).selected := true;
 					found:=true;
 					break;
 				endif;
 			endif;
 			count	:= count+ 1;
 		endwhile;
 	endif;
 	return found;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCombos" id="07513513-0240-4a22-a0b5-20f61e49770f">
        <updating/>
        <source>initCombos() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	rootObj		: CM_Root;
	vesselObj	: CM_Vessel;
	shipTypeObj	: HMS_VesselType;
	agentObj	: CM_ShippingAgent;
	shipLineCo	: CM_ShippingLine;
	passportObj	: CM_Passport;
	failedDAC  :CM_DataAccessController;

begin
	passportObj	:=	app.myPassport;
	
	// This method loads all collections into comboboxes
	rootObj	:=	app.myRoot;
  	// Load Ship Names
  	// Add blank selection as first entry
  	cbxShipName.addItem(" N/A");
	
  	foreach vesselObj in rootObj.allVessels do
		if vesselObj.canUserAccessSelf(null, failedDAC, passportObj) then
			cbxShipName.addItem(vesselObj.name);
			cbxShipName.itemObject[cbxShipName.newIndex]	:=	vesselObj;
		endif;
  	endforeach;
	
  	cbxShipName.listIndex	:=	1;
  	cbxShipName.text		:=	cbxShipName.itemText[cbxShipName.listIndex];

  	// Load Agents
  	// Add blank selection as first entry
  	cbxAgent.addItem(" N/A");
	
  	foreach agentObj in rootObj.allShippingAgentsByCode do
  		cbxAgent.addItem(agentObj.description);
  		cbxAgent.itemObject[cbxAgent.newIndex]	:=	agentObj;
  	endforeach;
	
  	cbxAgent.listIndex	:=	1;
  	cbxAgent.text		:=	cbxAgent.itemText[cbxAgent.listIndex];
  	
	// Load Ship Line Companies
  	// Add blank selection as first entry
  	cbxShipLineCo.addItem(" N/A");
	
  	foreach shipLineCo in rootObj.allShippingLines do
  		cbxShipLineCo.addItem(shipLineCo.description);
  		cbxShipLineCo.itemObject[cbxShipLineCo.newIndex]	:=	shipLineCo;
  	endforeach;
	
  	cbxShipLineCo.listIndex	:=	1;
  	cbxShipLineCo.text		:=	cbxShipLineCo.itemText[cbxShipLineCo.listIndex];
	
  	// Load Ship Types
  	// Add blank selection as first entry
  	cbxShipType.addItem(" N/A");
	
  	foreach shipTypeObj in app.myRoot.allVesselTypes do
  		cbxShipType.addItem(shipTypeObj.description);
  		cbxShipType.itemObject[cbxShipType.newIndex]	:=	shipTypeObj;
  	endforeach;
	
  	cbxShipType.listIndex	:=	1;
  	cbxShipType.text		:=	cbxShipType.itemText[cbxShipType.listIndex];

	self.buildCombosForHarbour();
end;</source>
    </JadeMethod>
