    <JadeMethod name="validateForUpdate" id="0bcee429-cea2-4d5a-a60a-9778a737f901">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/07/2022  navcs2 	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
22/03/2024	navcs2	ChangeRequest 61199: EUP | FR | 54329 | VBS - Release Line validation
11/07/2024	navpw1	TFS: 61525 (61527) - Added validation for max weight field
21/08/2024	navpw1	TFS: 65653 (65719) - Refactored code and added more variables for references accessed multiple times
											Added validation to make sure max weight is not greater than the release weight
10/08/2024	navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
*/

vars
	vbsItem					: CM_VehicleBookingTimeSlotItem;
	reserveDetail			: CM_ReserveDetail;
	outstandingWeight,
	totalWeightRequested,
	currentWeight			: Decimal[14,2];
	outstandingQuant,
	currentQuant,
	totalRequested			: Integer;
	weightStr,
	quantityStr				: String;
	cargoType				: CM_CargoType;
	weightMeasurementType	: CM_MeasurementType;
	cargoTypeDesc,
	cargoTypeUnit,
	reserveHeaderCode		: String;
	reserveHeader			: CM_BulkRelease;
	allBookingSlotItems		: CM_VehicleBookingTSItemSet;
	
begin
	reserveDetail := self.myReserveDetails;
	quantityStr := app.getErrorString(VBS_Quantity);	
	weightStr := app.getErrorString(VBS_Quantity);
	
	if reserveDetail &lt;&gt; null then
		reserveHeader := reserveDetail.myReserveHeader;
		if reserveHeader.releaseByType then
			reserveHeaderCode :=  reserveHeader.code;
			
			if reserveDetail.byTypeByWeight then
				outstandingWeight := reserveDetail.getWeightOutstanding;
				totalWeightRequested := reserveDetail.getTotalWeightRequested;
				
				cargoType := reserveDetail.getCargoType();
				if cargoType &lt;&gt; null then
					cargoTypeDesc := cargoType.description;
					weightMeasurementType := app.getDefaultMeasurementForType(Type_Weight);
					if weightMeasurementType &lt;&gt; null then
						cargoTypeUnit := weightMeasurementType.shortName;
					endif;
					
				endif;
				
				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
				if self.maxWeight = null then
					app.raiseCMException3(Vbs_max_weight_required, reserveHeaderCode, totalWeightRequested.asStringJMT() &amp; Space &amp; cargoTypeUnit, cargoTypeDesc, null, null);
				endif;
				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
				
				// ### TFS 65653 (65719) 21Aug2024 NAVPW1
				if self.maxWeight &lt;&gt; null and self.maxWeight &gt; totalWeightRequested then
					app.raiseCMException5(Vbs_max_weight_too_much, self.maxWeight.asStringJMT &amp; Space &amp; cargoTypeUnit, reserveHeaderCode, totalWeightRequested.asStringJMT() &amp; Space &amp; cargoTypeUnit, cargoTypeDesc, totalWeightRequested.asStringJMT() &amp; Space &amp; cargoTypeUnit, null, null);
					
				endif;
				// ### TFS 65653 (65719) 21Aug2024 NAVPW1
				
			else
				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
				cargoType := reserveDetail.getCargoType();
				if cargoType &lt;&gt; null then
					cargoTypeDesc := cargoType.description;
					
				endif;
				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
				
				outstandingQuant := reserveDetail.getTotalOutstanding;
				totalRequested := reserveDetail.getTotalRequested;
				
				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
				if self.maxWeight = null and self.quantity = null then
					app.raiseCMException3(Vbs_max_weight_quanti_required, reserveHeaderCode, totalRequested.asStringJMT(), cargoTypeDesc, null, null);
					
				// ### JIRA: MTN-33630 16Dec2024 NAVPW1 - Cannot have both quantity and weight entered on this form causing issues with wles not being added correctly
				elseif self.maxWeight &lt;&gt; null and self.quantity &lt;&gt; null then																						// 10/08/2024	navcs2	MTN-14819
					app.raiseCMException3(Vbs_max_weight_quan_both_enter, reserveHeaderCode, totalRequested.asStringJMT(), cargoTypeDesc, null, null);			// 10/08/2024	navcs2	MTN-14819
					
				endif;
				// ### TFS 61525 (61527) 11Jul2024 NAVPW1
				
			endif;
			
			allBookingSlotItems := self.myVehicleBookingSlot.allVehicleBookingItems;
			
			foreach vbsItem in allBookingSlotItems where vbsItem &lt;&gt; self and vbsItem.myReserveDetails = reserveDetail do
				if reserveDetail.byTypeByWeight then
					currentWeight := currentWeight + vbsItem.weight;
					if currentWeight + self.weight &gt; reserveDetail.getTotalOutstandingDisplay.asDecimalJMT then
						app.raiseCMException5(Quant_shoul_less_than_reserve,weightStr,reserveDetail.getTotalOutstandingDisplay,weightStr,currentWeight.String,weightStr,null,null);
						break;
					endif;
					
				else
					currentQuant := currentQuant + vbsItem.quantity;
					if currentQuant + self.quantity &gt; reserveDetail.getTotalOutstandingDisplay.asDecimalJMT then
						app.raiseCMException5(Quant_shoul_less_than_reserve,quantityStr,reserveDetail.getTotalOutstandingDisplay,quantityStr,currentQuant.String,quantityStr,null,null);
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTrailerType" id="1caf0e78-828d-4c3e-92ae-6094eefe48ec">
        <source>validateTrailerType(_trailerType : CM_TILCType; _instructionCode : String output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2024 navlc30 ChangeRequest 63714: EUP | FR | 53984 - Kiosk - Further issues and Remedial work - Issue 2

*/

vars
	bulkRelease            : CM_BulkRelease;
	releaseInstruction     : CM_InstructionsIssued;
	releaseInstructionType : CM_InstructionType;
	reserveDetail		   : CM_ReserveDetail;
	reserveInstruction     : CM_InstructionsIssued;
	reserveInstructionType : CM_InstructionType;	
	
begin

	reserveDetail := self.myReserveDetails;
	
	if reserveDetail &lt;&gt; null then
		reserveInstruction := reserveDetail.myInstructions;
	endif;
	
	if reserveInstruction &lt;&gt; null then 

		reserveInstructionType := reserveInstruction.myInstructionType;
		
		if reserveInstructionType = null then
			return true;
		endif;
		
		if not reserveInstructionType.allTrailerTypes.includes(_trailerType) then	
			_instructionCode := reserveInstructionType.code;		
			return false;
		endif;
	else 
		bulkRelease := self.myBulkRelease;
		
		if bulkRelease &lt;&gt; null then 
			releaseInstruction := bulkRelease.myInstructions;
		endif;	
		
		if releaseInstruction &lt;&gt; null then												
			releaseInstructionType := releaseInstruction.myInstructionType;
			
			if releaseInstructionType = null then
				return true;
			endif;
				
			if not releaseInstructionType.allTrailerTypes.includes(_trailerType) then
				_instructionCode := releaseInstructionType.code;
				return false;			
			endif;
		endif;
		
	endif;
		
	return true;
epilog

end;</source>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_instructionCode" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
