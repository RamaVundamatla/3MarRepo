    <JadeMethod name="includeObject" id="52a6915b-5025-4abc-bd4c-8a44ae594252">
        <source>includeObject(_wle: CM_WorkListEntry; _controller: CMIF_RoadOpController): Boolean protected;

/*
Date			Who		Reason
25 September 2014	cnwar2	Initial creation

*/
vars
	job	:CM_RoadJob;
begin
	// 25/09/2014 cnwar2 #34333
	if _controller.hideCompletedJobs then
		job := _wle.job.CM_RoadJob;
		
		if job &lt;&gt; null and job.isJobComplete then
			return false;
		endif;
	endif;
	
	return inheritMethod(_wle, _controller);

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_controller" type="CMIF_RoadOpController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
