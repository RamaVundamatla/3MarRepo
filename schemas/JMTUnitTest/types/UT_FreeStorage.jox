        <source>setupStorageConfig4(_calendar : CM_Calendar; _includeFirstDay : Boolean; _includeLastDay : Boolean; _shipReceivalType : Integer; _shipReleaseType : Integer; _chargedDaysWorking : Boolean;
					_freeDaysWorking : Boolean; _deriveDebtorFrom : CM_DebtorType; _triggers : CM_StorageTriggerByType; _createDetails : Boolean) : CM_StorageConfig protected;
/*
Purpose - 	
Who - NAVAB1
Date - 24JAN2024
