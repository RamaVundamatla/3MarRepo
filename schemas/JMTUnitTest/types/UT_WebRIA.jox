    <JadeMethod name="tGetUnpackedCargo" id="ed9386cf-2901-472f-bf43-6920066740bc">
        <source>tGetUnpackedCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2020	jlgndl1	Initial creation	TFS 47356
12 Apr 2021	navmd1	TFS 51050 Make sure any TI can be unpacked, not just ISO Containers
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

constants

	BLOCKSTACK = "PCKD";
	ParentId = "PRNT4997700";
	ChildId = "CHLD49977";
	ChildCargoType = "UTREBAR";
	UNPackLoc1 = "UPK1";
	UNPackLoc2 = "UPK2";
	UNPackLoc3 = "UPK3";
	Cargo_Type = "UTCOAL";
	
vars

	term : CM_Terminal;
	operatorCode : String;
	operator : CM_Operator;
	index,
	testRun : Integer;
	bs : CM_BlockStack;
	childCargoTypeId : Integer;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	childId : String;
	bsUpk1 : CM_BlockStack;
	bsUpk2 : CM_BlockStack;
	bsUpk3 : CM_BlockStack;

	container : CM_TrackedItem;
	xtraTestString : String;
	expectedError : Integer;
	unpackedCargoArray : HugeStringArray;
	
	unpackItem : CM_TrackedItem;
	unpackItemId : String;
	expectedIdsAndLocations : String;
	
	cargoType : CM_CargoType;
	voyage : CM_Voyage;
begin

	term := self.getTerminal();
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := app.myRoot.allOperators.getAtKey( operatorCode );
	childCargoTypeId := app.myRoot.getCargoTypeIDFromAbbrev( ChildCargoType );

	//Clean up
	foreach index in 1 to 10 do
		childId := ChildId &amp; index.padLeadingWith('0',2 );
		self.deleteCargo( childId, childCargoTypeId );
	endforeach;

	self.deleteTerminalArea( BLOCKSTACK );
	self.deleteTerminalArea( UNPackLoc1 );
	self.deleteTerminalArea( UNPackLoc2 );
	self.deleteTerminalArea( UNPackLoc3 );

	//set up
	bs := self.addBlockStack( BLOCKSTACK, null, null );
	bsUpk1 := self.addBlockStack( UNPackLoc1, null, null );
	bsUpk2 := self.addBlockStack( UNPackLoc2, null, null );
	bsUpk3 := self.addBlockStack( UNPackLoc3, null, null );

	foreach testRun in 1 to 2 do
		self.deleteContainer(ParentId);
		
		if attachments &lt;&gt; null and not attachments.isEmpty then
			attachments.purge;
		endif;
		delete attachments;
		delete unpackedCargoArray;
	
		if testRun = 1 then
			container := self.addContainerAtLocation(ParentId, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, bs);
		elseif testRun = 2 then
			cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
			self.assertNotNullMsg(cargoType, "Expecting UTCOAL Cargo Type to exist");
			voyage := term.allVoyagesByCode.first;
			self.assertNotNullMsg(voyage, "Expecting /a/ voyage - doesn't actually matter what one really");
			
			// Yeah, don't ask me how /any/ non-container item is allowed to have children... it doesn't make sense to me either.
			container := self.addCargoBulkAtLocation(ParentId, cargoType, 100, bs.getLocationsController(), null, TI_IMEX_STATUS_STORAGE, voyage, operator, null);
		else
			container := null;
		endif;
		self.assertNotNull(container);
	
		create attachments transient;	
		foreach index in 1 to 10 do
			childId := ChildId &amp; index.padLeadingWith('0',2 );
			create attach transient;
			attach.set( getTerminal, childCargoTypeId, childId, "", 100 ); 
			attach.totalQuantity := 100;
			attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
			attach.imExStatus := container.getImExStatus;
			attachments.add(attach);
		endforeach;
		
		self.addContainerChildren(container, attachments);
	
		create unpackedCargoArray transient;
		
		//Check results with nothing unpacked.
		xtraTestString := "test 1 ";
		self.webServiceCallWithParams(	CM_UnitTestAgent::wsGetUnpackedCargo.name,
										container,	//_container : CM_TrackedItem;
										xtraTestString,	//_xtraTestString : String;
										expectedError,	//_expectedError : Integer;
										unpackedCargoArray	//_unpackedCargoArray : ObjectArray io
										);
										
		self.assertTrueMsg( unpackedCargoArray.isEmpty, xtraTestString &amp; " Nothing has been unpacked, there should be nothing returned." );
		self.assertTrueMsg( container.allChildren.size = 10, xtraTestString &amp; " should still be 10 children in the container.");
		
		//unpack one item completely
		xtraTestString := "test 2 ";
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;
		expectedIdsAndLocations := unpackItemId &amp; " " &amp; bsUpk1.id;
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
		
		self.webServiceCallWithParams(	CM_UnitTestAgent::wsGetUnpackedCargo.name,
										container,	//_container : CM_TrackedItem;
										xtraTestString,	//_xtraTestString : String;
										expectedError,	//_expectedError : Integer;
										unpackedCargoArray	//_unpackedCargoArray : ObjectArray io
										);
		
		self.assertTrueMsg( unpackedCargoArray.size = 1, xtraTestString &amp; "Should be one unpacked item [" &amp; expectedIdsAndLocations &amp; "]." );
		self.assertTrueMsg( container.allChildren.size = 9, xtraTestString &amp; " should now be 9 children in the container.");
		
		//unpack a second item partially
		xtraTestString := "test 3 ";
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;
		expectedIdsAndLocations := expectedIdsAndLocations &amp; ", " &amp; unpackItemId &amp; " " &amp; bsUpk1.id;
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, 50, 50,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, 50, 50,false,null, app.myPassport);  //09.01.2023 navma1 #60947
		
		self.webServiceCallWithParams(	CM_UnitTestAgent::wsGetUnpackedCargo.name,
										container,	//_container : CM_TrackedItem;
										xtraTestString,	//_xtraTestString : String;
										expectedError,	//_expectedError : Integer;
										unpackedCargoArray	//_unpackedCargoArray : ObjectArray io
										);
		
		self.assertTrueMsg( unpackedCargoArray.size = 2, xtraTestString &amp; "Should be two unpacked items [" &amp; expectedIdsAndLocations &amp; "]." );
		self.assertTrueMsg( container.allChildren.size = 9, xtraTestString &amp; " should still be 9 children in the container. (one has been split)");
		
		//complete unpacking the second item (2nd bit should merge)
		xtraTestString := "test 4 ";
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false,null, app.myPassport);	//14.03.2024 navhl20 #62861
		
		self.webServiceCallWithParams(	CM_UnitTestAgent::wsGetUnpackedCargo.name,
										container,	//_container : CM_TrackedItem;
										xtraTestString,	//_xtraTestString : String;
										expectedError,	//_expectedError : Integer;
										unpackedCargoArray	//_unpackedCargoArray : ObjectArray io
										);
		
		self.assertTrueMsg( unpackedCargoArray.size = 2, xtraTestString &amp; "Should still be two unpacked items [" &amp; expectedIdsAndLocations &amp; "]." );
		self.assertTrueMsg( container.allChildren.size = 8, xtraTestString &amp; " should now be 8 children in the container.");
		
		
		//unpack a third item to two seperate areas
		xtraTestString := "test 5 ";
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;
		expectedIdsAndLocations := expectedIdsAndLocations &amp; ", " &amp; unpackItemId &amp; " " &amp; bsUpk2.id;
		
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk2.myLocationsController, 50, 50,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk2.myLocationsController, 50, 50,false,null, app.myPassport);	//14.03.2024 navhl20 #62861
		
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;	
		expectedIdsAndLocations := expectedIdsAndLocations &amp; ", " &amp; unpackItemId &amp; " " &amp; bsUpk3.id;
		
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk3.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk3.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false,null, app.myPassport);	//14.03.2024 navhl20 #62861
		
		self.webServiceCallWithParams(	CM_UnitTestAgent::wsGetUnpackedCargo.name,
										container,	//_container : CM_TrackedItem;
										xtraTestString,	//_xtraTestString : String;
										expectedError,	//_expectedError : Integer;
										unpackedCargoArray	//_unpackedCargoArray : ObjectArray io
										);
		
		self.assertTrueMsg( unpackedCargoArray.size = 4, xtraTestString &amp; "Should be four unpacked items [" &amp; expectedIdsAndLocations &amp; "]." );
		self.assertTrueMsg( container.allChildren.size = 7, xtraTestString &amp; " should now be 7 children in the container.");
		
		//unpack a fourth item to two seperate areas and half of a fifth item to a third area
		xtraTestString := "test 6 ";
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;
		expectedIdsAndLocations := expectedIdsAndLocations &amp; ", " &amp; unpackItemId &amp; " " &amp; bsUpk1.id;
		
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, 50, 50,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk1.myLocationsController, 50, 50,false,null, app.myPassport);	//14.03.2024 navhl20 #62861
		
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;	
		expectedIdsAndLocations := expectedIdsAndLocations &amp; ", " &amp; unpackItemId &amp; " " &amp; bsUpk2.id;
		
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk2.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk2.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false,null, app.myPassport);	//14.03.2024 navhl20 #62861
		
		unpackItem := container.getFirstChild();
		unpackItemId := unpackItem.id;
		expectedIdsAndLocations := expectedIdsAndLocations &amp; ", " &amp; unpackItemId &amp; " " &amp; bsUpk3.id;
		
		//app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk3.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		app.myTrxUA.trxUpdateUnpackCargo( unpackItem, bsUpk3.myLocationsController, unpackItem.totalQuantity, unpackItem.totalWeight,false,null, app.myPassport); 	//14.03.2024 navhl20 #62861
		
		self.webServiceCallWithParams(	CM_UnitTestAgent::wsGetUnpackedCargo.name,
										container,	//_container : CM_TrackedItem;
										xtraTestString,	//_xtraTestString : String;
										expectedError,	//_expectedError : Integer;
										unpackedCargoArray	//_unpackedCargoArray : ObjectArray io
										);
		
		self.assertTrueMsg( unpackedCargoArray.size = 7, xtraTestString &amp; "Should be seven unpacked items [" &amp; expectedIdsAndLocations &amp; "]." );
		self.assertTrueMsg( container.allChildren.size = 5, xtraTestString &amp; " should now be 5 children in the container.");
	
	endforeach;	//testRun
								
	//Clean up
	foreach index in 1 to 10 do
		childId := ChildId &amp; index.padLeadingWith('0',2 );
		self.deleteCargo( childId, childCargoTypeId );
	endforeach;
	self.deleteContainer(ParentId);
	self.deleteTerminalArea( BLOCKSTACK );
	self.deleteTerminalArea( UNPackLoc1 );
	self.deleteTerminalArea( UNPackLoc2 );
	self.deleteTerminalArea( UNPackLoc3 );

epilog

	if attachments &lt;&gt; null and not attachments.isEmpty then
		attachments.purge;
	endif;
	delete attachments;
	delete unpackedCargoArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tLogLocationMaint" id="4e1eaac2-386a-439b-a418-fe94997d0cc5">
