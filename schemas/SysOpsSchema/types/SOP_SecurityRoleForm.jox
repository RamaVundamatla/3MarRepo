        <source>displayEntryStatus(_obj : CM_VoyageStatus) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/03/2018	jlgdap1		Initial creation TFS 37445 PEL1 Voyage Status Security
