        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mySubjectClass" id="0ebfcf6c-4e68-468b-b5ba-e06129d9411d">
        <methodInvocation>mapping</methodInvocation>
        <source>mySubjectClass(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05 Apr 2017	cnwkpd1		TFS 3369 - Push Events application - invalid object exception
// ---------------------------------------------------------------------------
vars
	subject 		: CM_Object;
	invalid			: Boolean;
	
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	subject := self.mySubject;
	if subject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, subject, invalid);
		_value := subject.class;
	else
		_value := null;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateFromCMEdit" id="6f6a5311-a232-45c0-982c-7c84de30739d">
        <updating/>
        <source>populateFromCMEdit( _auditConfig : CM_AuditConfig; _edit : CM_Edit ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	before : String;
	after : String;
	
	fieldName : String;
	oldValue : String;
	newValue : String;
	index : Integer;

begin

	if _edit = null or _edit.myTrackedItem = null or _edit.fieldsValues.size &lt; 1 then
		return false;
	endif;
	
	foreach index in 1 to _edit.fieldsValues.size  do
		_edit.getFieldValues( index, fieldName, oldValue, newValue );
		if oldValue = null and newValue = null then
			_edit.getFieldValuesForSystemSeals( index, fieldName, oldValue, newValue );
		endif;
		before := before &amp; fieldName &amp; AuditStringSeparator &amp; oldValue.length.String &amp; AuditStringSeparator &amp; oldValue &amp; AuditStringSeparator;
		after := after &amp; fieldName &amp; AuditStringSeparator &amp; newValue.length.String &amp; AuditStringSeparator &amp; newValue &amp; AuditStringSeparator;
	endforeach;

	self.auditText := before;
	self.postAuditText := after;
	
	self.timestamp := _edit.dateTime;
	self.myUser := app.getMyUser;
	
	type := 0;
	userCode := _edit.userId;
	
	self.mySubject := _edit.myTrackedItem;
	self.myAuditConfig := _auditConfig;
	
	return true;

epilog

end;</source>
        <Parameter name="_auditConfig" type="CM_AuditConfig"/>
        <Parameter name="_edit" type="CM_Edit"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateSpecificManualUpdate" id="57560b79-62ef-4f34-bff6-aaa4a94d684f">
        <updating/>
        <source>populateSpecificManualUpdate( _auditConfig : CM_AuditConfig; _ti : CM_TrackedItem; _fieldName : String; _before : String; _after : String ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars


begin

	if _auditConfig = null or _ti = null or _fieldName = null or ( _before = null and _after = null ) then
		return false;
	endif;

	if _before &lt;&gt; null then
		self.auditText := _fieldName &amp; AuditStringSeparator &amp; _before.length.String &amp; AuditStringSeparator &amp; _before &amp; AuditStringSeparator;
	endif;
	if _after &lt;&gt; null then
		self.postAuditText := _fieldName &amp; AuditStringSeparator &amp; _after.length.String &amp; AuditStringSeparator &amp; _after &amp; AuditStringSeparator;
	endif;
	
	self.timestamp := app.actualTimeAppServer;
	self.myUser := app.getMyUser;
	
	type := 0;
	if self.myUser &lt;&gt; null then
		userCode := self.myUser.code;
	endif;
	
	self.mySubject := _ti;
	self.myAuditConfig := _auditConfig;
	
	return true;

epilog

end;</source>
        <Parameter name="_auditConfig" type="CM_AuditConfig"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_before" type="String"/>
        <Parameter name="_after" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAuditText" id="c3e9c61c-a77c-48f2-a2e6-0b4692f2f571">
        <updating/>
        <source>setAuditText(pText : String) updating;
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
