    <JadeMethod name="trxDeleteVehicles" id="f599d885-025c-41b7-81a9-8b1fe29fba7d">
        <updating/>
        <source>trxDeleteVehicles(	_allVehicles : ObjectArray input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	vehicleSet : CM_VehicleSet;
	vehicle : CM_Vehicle;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	create vehicleSet transient;
	_allVehicles.copy( vehicleSet );

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach vehicle in vehicleSet do
		app.myUtilityDA.utlDeleteVehicle(vehicle, _passport);
		if _passport.hasErrors then
			break;
		endif;
	endforeach;
	
epilog

	self.finaliseActivityWithPassport(_passport);
	delete vehicleSet;

end;</source>
        <Parameter name="_allVehicles" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
