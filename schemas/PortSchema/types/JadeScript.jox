begin

	app.initialize();
	
	dutyDocRoot:=CM_DutyDocRoot.firstInstance;
	
	if dutyDocRoot = null then
		beginTransaction;
		create dutyDocRoot persistent;
		commitTransaction;	
	endif;
	
	root := CM_Root.firstInstance;
		
	beginTransaction;
		foreach terminal in root.allTerminals do	
			terminal.createDutyDocTerminalRoot();
		endforeach;
	commitTransaction;
	
	//set up the changed ent table stuff
	create etAgent transient;
