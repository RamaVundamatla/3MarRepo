<Class name="CMQF_DLRSOBMoves" id="e6d256b2-a60d-45d7-8b71-0c9c6c3d2dce">
    <superclass name="CMQF_Container"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="7f9fbc38-db50-4d39-8992-ac223d708580">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		12 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
begin

	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
		//search ship
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType  discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.doStats(ti);
				endif;
			endif;
			
//			if breakOut then
//				break;
//			endif;
		endforeach;
		//search onsite
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType  discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.doStats(ti.CM_Container);
				endif;
			endif;
			
//			if breakOut then
//				break;
//			endif;
		endforeach;
	endif;
		
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="14e308f4-5406-484e-a8c5-d826fa13c36a">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin


	if (_ti.isRehandle or 
	   (_ti.isSOB and _ti.site = TI_SITE_ONSHIP)) and
	   inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	/*
	if inheritMethod(_ti, _passport, _breakOut) then
		if _ti.isRehandle then	
			return true;
		elseif _ti.isSOB and _ti.site = TI_SITE_ONSHIP then	
			return true;
		endif;
	endif;
	*/

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
