    <JadeMethod name="doUpdateFortyBackEndDisch" id="6f618e5a-ccc7-4f2b-b7e5-08abe5532790">
        <updating/>
        <source>doUpdateFortyBackEndDisch(_bayPoint : SHP_BayPoint ) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	aPoint : CMUI_GridPoint;
	matchingBayArea : CMUI_GridArea;
	aString : String;
	matchingPoint : SHP_BayPoint;
	drawHoldVertical, ls : Boolean;
	pxySD : CM_SlotDefn;
	theSlotController : CM_SlotController;
	pxySR,realSlotRequest : CM_SlotRequest;
	theCargoID,theMoveType : Integer;
	theCommodityCode, theDPortCode : String;
	trxUpdateOK,isVesselDefn : Boolean;
	theCargoType : CM_CargoType;
begin
	drawHoldVertical := self.drawTheHoldVertical;
	
	matchingPoint := _bayPoint.getMatching40Point(drawHoldVertical,matchingBayArea,true);
	if matchingPoint &lt;&gt; null then
		theMoveType := DISCHARGE_MOVETYPE;
		if _bayPoint.tiInfo40 then
			matchingPoint.cloneAttributesDischarge( _bayPoint);
		else
			self.doNullColDischPoint(matchingPoint);
			theMoveType := NULL_MOVETYPE;
		endif;
		
		// ################
		// TRX MATCHING POINT
		theSlotController := matchingPoint.myLocationsController.CM_SlotController;
		realSlotRequest := theSlotController.mySlotRequestDischarge;

		if realSlotRequest = null then
			theCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container]; //default	
			create pxySR transient;
			pxySR.setProxyForCreate(theSlotController,theMoveType, false, theCargoType, null);
			app.myTrxCA.trxCreateSlotRequest(pxySR, realSlotRequest, app.myPassport);
			
			delete pxySR;
		endif;
		
		if app.myPassport.trxCompletedOK then
			realSlotRequest := theSlotController.mySlotRequestDischarge;
	
			if matchingPoint.colDischDLR then
				theMoveType := DLR_MOVETYPE;
			elseif matchingPoint.colDischSOB then
				theMoveType := SOB_MOVETYPE;
			endif;
			app.cmsBeginLoad(ls);
			pxySR := realSlotRequest.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			// PAR7496 AKB2004FEB	,pxySR.reefer
			pxySR.setProxyForUpdate(pxySR.doorsDirection,pxySR.motorDirection,theMoveType,pxySR.numSeqPortCustom,
										pxySR.numSeqStarboardCustom,pxySR.getAttrEmpty(),pxySR.fixed,pxySR.getAttrHalfHeight(),pxySR.getAttrHazardous(),
										pxySR.getAttrOverDimensioned(),pxySR.getAttrPowerRequired(),pxySR.sequenced,pxySR.unavailable,
										pxySR.getAttrWaterCooled(),pxySR.getAttrHiCubed(), false,true,  // PAR 7899 //pxySR.fortyFront, 
										matchingPoint.colDischMyDischPort,pxySR.getAttrCommodityGroup(),pxySR.getAttrCargoType());
								
			app.myTrxUA.trxUpdateSlotRequest(pxySR,app.myPassport);
			delete pxySR;
			// NOT drawing on screen is done by notification
	//		matchingPoint.drawSelf(matchingBayArea.myGridAreaFrame);
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	return app.myPassport.trxCompletedOK;
end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateFortyBackEndLoad" id="152a0642-9a8b-484f-91ca-bc928f62bd89">
        <updating/>
        <source>doUpdateFortyBackEndLoad(_bayPoint : SHP_BayPoint ) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	aPoint : CMUI_GridPoint;
	matchingBayArea : CMUI_GridArea;
	aString : String;
	matchingPoint : SHP_BayPoint;
	drawHoldVertical, ls : Boolean;
	pxySD : CM_SlotDefn;
	theSlotController : CM_SlotController;
	pxySR,realSlotRequest : CM_SlotRequest;
	theCargoID,theMoveType : Integer;
	theCommodityCode, theDPortCode : String;
	trxUpdateOK,isVesselDefn : Boolean;
	theCargoType : CM_CargoType;
begin
	drawHoldVertical := self.drawTheHoldVertical;
	
	matchingPoint := _bayPoint.getMatching40Point(drawHoldVertical,matchingBayArea,true);
	if matchingPoint &lt;&gt; null then
		
		theMoveType := LOAD_MOVETYPE;
		if _bayPoint.colLoadFortyFoot then
			matchingPoint.cloneAttributesLoad( _bayPoint);
		else
			self.doNullColLoadPoint(matchingPoint);
			theMoveType := NULL_MOVETYPE;
		endif;
		// ################
		// TRX MATCHING POINT
		theSlotController := matchingPoint.myLocationsController.CM_SlotController;
		realSlotRequest := theSlotController.mySlotRequestLoad;

		if realSlotRequest = null then
			theCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container]; //default	
			create pxySR transient;
			pxySR.setProxyForCreate(theSlotController,theMoveType, true, theCargoType, null);
			app.myTrxCA.trxCreateSlotRequest(pxySR, realSlotRequest, app.myPassport);
			delete pxySR;
		endif;

		if app.myPassport.trxCompletedOK then
	
			app.cmsBeginLoad(ls);
			pxySR := realSlotRequest.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			
			// ONLY SET DLR SOB on the UPDATE, never on the create. Else the load does not know to set its slot controller
			if matchingPoint.colLoadDLR then
				theMoveType := DLR_MOVETYPE;
			elseif matchingPoint.colLoadSOB then
				theMoveType := SOB_MOVETYPE;
			endif;
			// PAR7496 AKB2004FEB matchingPoint.colLoadPortHole
			pxySR.setProxyForUpdate(pxySR.doorsDirection,pxySR.motorDirection,theMoveType,pxySR.numSeqPortCustom,
										pxySR.numSeqStarboardCustom,matchingPoint.colLoadEmpty,pxySR.fixed,matchingPoint.colLoadHalfHeight,matchingPoint.colLoadIsHazardous,
										matchingPoint.colLoadIsOverDimensioned,matchingPoint.colLoadPower,pxySR.sequenced,matchingPoint.colLoadUnavailable,
										matchingPoint.colLoadWaterCooled,matchingPoint.colLoadHiCube, false,true,  // PAR 7899 //matchingPoint.colLoadFortyFoot, 
										matchingPoint.colLoadMyDischPort,matchingPoint.colLoadMyCommodityGroup,matchingPoint.colLoadMyCargoType);
								
			app.myTrxUA.trxUpdateSlotRequest(pxySR,app.myPassport);
			delete pxySR;
	
			// NOT drawing on screen is done by notification
	//		matchingPoint.drawSelf(matchingBayArea.myGridAreaFrame);
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	return app.myPassport.trxCompletedOK;

end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawMinature" id="2b3e2dba-d86e-4ae0-a6a2-0eda81a16693">
