    <JadeMethod name="getAPIJSONRequestData" id="8ea22e8b-b425-4689-ae51-a76f62213c0e">
        <source>getAPIJSONRequestData(_stateDataDict : CM_StateDataDict input) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 July 2024		navmd1	Initial creation TFS 65226 Debug Code of sorts, to keep the initial JSON data somewhere easily findable

*/

vars
	compressedBinary	: Binary;
begin
	if _stateDataDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "CM_StateDataDict not provided or null");
		return null;
	endif;
	
	global.getExtraData(_stateDataDict, APIRequestJSONData, compressedBinary);
	if compressedBinary = null then
		return null;
	endif;
	
	return compressedBinary.uncompressToString();
epilog

end;</source>
        <Parameter name="_stateDataDict" type="CM_StateDataDict" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
