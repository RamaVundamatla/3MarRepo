    <JadeMethod name="returnIsPrim" id="6b741595-766b-4993-b845-92dbe48f515a">
        <source>returnIsPrim() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2023	navkc1	Initial creation

*/

vars

begin
	
	if 
		self.getTypeOfReturnType() = Any or
		self.getTypeOfReturnType() = Binary or
		self.getTypeOfReturnType() = Boolean or
		self.getTypeOfReturnType() = Byte or
		self.getTypeOfReturnType() = Character or
		self.getTypeOfReturnType() = Date or
		self.getTypeOfReturnType() = Decimal or
		self.getTypeOfReturnType() = Integer or
		self.getTypeOfReturnType() = Integer64 or
		self.getTypeOfReturnType() = MemoryAddress or
		self.getTypeOfReturnType() = Point or
		self.getTypeOfReturnType() = Real or
		self.getTypeOfReturnType() = String or
		self.getTypeOfReturnType() = StringUtf8 or
		self.getTypeOfReturnType() = Time or
		self.getTypeOfReturnType() = TimeStamp or
		self.getTypeOfReturnType() = TimeStampInterval or
		self.getTypeOfReturnType() = TimeStampOffset 
	then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
