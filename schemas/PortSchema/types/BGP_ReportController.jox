<Class name="BGP_ReportController" id="c4470c36-016a-4809-9465-e5ac864ea1b2">
    <superclass name="BGP_Controller"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;This report controller should be run as a fat client session. This is done by starting its manager from a BGP shortcut.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="myPDFPrinter" id="a96f78d5-5f1c-4c30-8df7-ce3389949357">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_PrinterDef"/>
        <access>readonly</access>
        <Inverse name="CM_PrinterDef::allBGPReportControllers"/>
    </ExplicitInverseRef>
    <PrimAttribute name="tempFileLocation" id="18dbfad5-4515-4937-9600-549302df91f8">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="appName" id="5ad97d0d-f775-42e7-9f23-578705cc8286">
        <methodInvocation>mapping</methodInvocation>
        <source>appName(set: Boolean; _value: String io) mapping;
// -------------------------------------------
// Created 23 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if set then
		return;
	endif;
	_value := 'BGP_ReportControllerApp';
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFields" id="f4850c6d-ea30-4706-b42f-831cfd637241">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_DefaultPDFPrinter);
	_allFields.add(ETRow_TempFileLocation);
	
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="6b172383-d210-4b0e-9a85-afaa8212d489">
