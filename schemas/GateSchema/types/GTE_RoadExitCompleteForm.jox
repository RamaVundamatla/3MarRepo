    <JadeMethod name="addNewWokEntry" id="e0051cc9-4c58-4562-8d63-ded4ce09fa09">
        <updating/>
        <source>addNewWokEntry(_deliveryRequest : CM_DeliveryRequest input) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 28 June 2007
//
//----------------------------------------------------------------------

vars
	result : Integer;
begin
	if _deliveryRequest = null then
		app.msgBox('Please select a release by type from the list to add a work list entry to.', 'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;			
		
	while true do
		app.myTrxUA.trxUpdateReleaseWLEQty(_deliveryRequest, 1, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Add work list entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;			
end;</source>
        <access>protected</access>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="639a8144-07fd-4140-a7c8-8db5017b12ba">
        <updating/>
        <source>addToolbarControls() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007
//
//----------------------------------------------------------------------

vars
	toolbar : CMUI_Toolbar;
begin

	inheritMethod();
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addWorkEntry" id="a27c28ad-61cd-40ba-8a2a-bfcc8f1a5f5a">
        <updating/>
        <source>addWorkEntry(_wle : CM_WorkListEntry) protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007
//
//----------------------------------------------------------------------

vars
	rowStr			: String;
	entRow			: EntTableRow;
	entDef			: EntTableDef;
	col				: Integer;
	idx				: Integer;
	wle 			: CM_WorkListEntry;
	combo			: CMUI_ComboBox;
	tbl 			: CM_DataTable;
begin
	if not CM_YardWLE.hasInstance(_wle) then
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1. Receiving non Yard WLEs here");
		return;
	endif;
	
	wle := _wle;
	
	if wle.isReceipt then
		tbl := self.tblReceivals;
	else
		tbl := self.tblReleases;
	endif;
	
	rowStr := self.displayRowForDataTable(wle, tbl);
	idx := tbl.rows + 1;
	tbl.addItemAt(rowStr, idx);
	//idx := tbl.addItem(rowStr);
	tbl.accessRow(idx).itemObject := wle;
	
	if wle.myTrackedItem = null then
//		idx := tbl.rows;
		self.addControlToTable(idx, self.newIndex, tbl, true, false, wle);
	endif;
	
	if wle.isReceipt then
		idx := tbl.rows;
		self.addControlToTable(idx, self.newIndex, tbl, false, false, wle);
	else
		if wle.myTrackedItem = null then
			self.addCargoTypeControl(idx, self.newIndex, false);
		endif;
	endif;

	self.addWorkEntryToCollection(wle);
	
	self.tblWorkEntryColor(tbl, wle, idx);
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="addWorkEntryToCollection" id="9c4bbbe2-2aad-41a9-b57e-a15228c0c742">
        <updating/>
        <source>addWorkEntryToCollection(_wle : CM_WorkListEntry) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 28 June 2007
//
//----------------------------------------------------------------------

vars

begin
	if _wle = null then
		return;
	endif;
	
	if _wle.isReceipt then
		self.allReceiveWLEs.add(_wle);
	else
		self.allReleaseWLEs.add(_wle);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="areRequestsComplete" id="1afccdcb-3807-4a33-addf-551fbc111aa3">
        <updating/>
        <source>areRequestsComplete() : Boolean updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//
//----------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.myJob.workListEntries discreteLock where wle.myTrackedItem = null do
		return false;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="f064a396-87bf-4425-be95-e29faa3a35ed">
        <updating/>
        <source>armNotesForObject(_obj : Object) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	tmpRoadJob	: CM_RoadJob;
	ti			: CM_TrackedItem;
	wle 		: CM_WorkListEntry;
begin

	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);
	self.beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);

	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Release), Response_Continuous, 0);

	if _obj.isKindOf(CM_RoadJob) then  
		tmpRoadJob := _obj.CM_RoadJob;
		foreach ti in tmpRoadJob.allReceiveTrackedItems do 
			self.beginNotification(ti, Object_Update_Event, Response_Continuous, 0);
		endforeach;
		
		foreach ti in tmpRoadJob.allReleaseTrackedItems do 
			self.beginNotification(ti, Object_Update_Event, Response_Continuous, 0);
		endforeach;
		
		foreach wle in tmpRoadJob.workListEntries do 
			self.beginNotification(wle, Object_Update_Event, Response_Continuous, 0);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="assignTIToReleaseRequest" id="9e688f34-f8d2-4361-b712-f59e7528becf">
        <updating/>
        <source>assignTIToReleaseRequest(_ti : CM_TrackedItem; _wle : CM_WorkListEntry) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 06 June 2007
//
//----------------------------------------------------------------------

vars
	result : Integer;
	moveController : CMIF_MoveController;
	origLocn : CM_LocationsController;
begin
	create moveController transient;	
	app.myMoveController := moveController;
	moveController.setMoveMode(self.moveModeForm);			
	moveController.setMyTrackedItem(_ti);
	origLocn := _ti.getPrimaryLocation(REAL_MODE);	
	if origLocn &lt;&gt; null then
		moveController.setEffectiveTimeStampOverride(origLocn.getEffectiveTimeStamp());
	endif;

	if _wle = null then
		return;
	else
		sharedLock(_wle);
	endif;
	
	moveController := app.myMoveController;
	moveController.setMyToPrimaryLocation( _wle.getRoadReleaseLC());
	moveController.setMyWorkListEntry(_wle);

	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not  app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	if _wle &lt;&gt; null then
		unlock(_wle);
	endif;
	
	app.myDraggedTrackedItem := null;
	
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;		
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
