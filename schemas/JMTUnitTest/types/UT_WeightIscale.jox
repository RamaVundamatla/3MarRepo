    <JadeMethod name="uBasicPennIscaleTest" id="83a5d238-e4ff-4370-81d5-2a3937c2fcd6">
        <source>uBasicPennIscaleTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2016	cnwrh7	Initial creation

*/
constants
		//IscaleIpAddress 							: String = "192.168.180.101";
		IscaleIpAddress 							: String = "192.168.50.195";
		//IscalePortNumber 					: Integer = 5008;
		IscalePortNumber 						: Integer = 10001;
		IscaleTimeOut 								: Integer = 5000;
		ReturnWeightBinary   				: Binary = #[42 28 00 00];
		
		
		
vars
		iScaleTcpIpConnection  			:	TcpIpConnection;
		getWeightCommandBytes		:	ByteArray; 
		responseBinary								:	Binary;
		responseString								:	String;
		i															:	Integer;
		getWeigthMessage						:	Binary;
		
begin
		create iScaleTcpIpConnection;													//basic info
		iScaleTcpIpConnection.name := IscaleIpAddress;
		iScaleTcpIpConnection.timeout := IscaleTimeOut;
		iScaleTcpIpConnection.port := IscalePortNumber;
		iScaleTcpIpConnection.usePresentationClient := false;
		iScaleTcpIpConnection.open();
		
		create getWeightCommandBytes transient; 
		getWeightCommandBytes[1] 		:= 255.Byte;							//start byte
		getWeightCommandBytes[2] 	:= 6.Byte;								//format version of this command
		getWeightCommandBytes[3]		:= 10.Byte;							//command "Get Data"
		getWeightCommandBytes[4] 	:= 1.Byte;								//length of data send in command	--(lowest byte)
		getWeightCommandBytes[5] 	:= 0.Byte;								//length of data send in command --(higher byte)
		getWeightCommandBytes [6] 	:= 0.Byte;								//length of data send in command --(higher byte)
		getWeightCommandBytes [7] 	:= 0.Byte;								//length of data send in command --(highest byte)
		getWeightCommandBytes [8] 	:= 5.Byte;								//ID of device sending command --(Depnding on situation) Need Device ID here???
		getWeightCommandBytes [9] 	:= 255.Byte;							//end byte
		
		i :=1;
		while i &lt;= getWeightCommandBytes.size do 
				getWeigthMessage := getWeigthMessage &amp; getWeightCommandBytes[i].Binary;
				i:= i+1;
		endwhile;		
		
		if iScaleTcpIpConnection = null then
				responseString := "No connection";
				return;
		elseif iScaleTcpIpConnection.state = TcpIpConnection.Connected then
				responseString :=  "Connected";
		elseif iScaleTcpIpConnection.state = TcpIpConnection.Connecting then
				responseString :=  "Connecting";
		elseif iScaleTcpIpConnection.state = TcpIpConnection.Disconnecting then
				responseString :=  "Disconnecting";
				return;
		elseif iScaleTcpIpConnection.state = TcpIpConnection.Disconnected then
				responseString :=  "Disconnected";
				return;
		endif;
		
		if iScaleTcpIpConnection.state = TcpIpConnection.Connected then
			iScaleTcpIpConnection.writeBinary (getWeigthMessage);
		endif;
		
		responseBinary	:= iScaleTcpIpConnection.readBinary(509);
		responseString := responseBinary.ansiToString();
		
		
epilog
		if iScaleTcpIpConnection &lt;&gt; null then
			iScaleTcpIpConnection.close;
		endif;

		delete iScaleTcpIpConnection;
		delete getWeightCommandBytes;
end;</source>
    </JadeMethod>
    <JadeMethod name="uTestWeightDataConversion" id="f8c82c2b-6a9f-455d-ada7-2f9ca3f7b498">
        <source>uTestWeightDataConversion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2016	cnwrh7	Initial creation

*/

constants
	Delimiter 					: String = " ";
	WeightDataStartPoint : Integer = 0;
vars
	t 										: CMIF_IscaleWeightDataWrap;
	int,int2							: Integer;
	weightDataBinary	: Binary;
	weightDataString		: String;
	weightReal					: Real;
	weightDecInKg			: Decimal[15,3];
	byteArray					: ByteArray;
begin
	create byteArray transient;					//sample data from iscale 4bytes per float
	byteArray[1] := 	 42.Byte;
	byteArray[2] :=	28.Byte;
	byteArray[3] :=	00.Byte;
	byteArray[4] := 00.Byte;
	create t transient;
	int :=1;
	while int &lt;= byteArray.size do			//we need 4 Byte in the return buffer binary start from postion 109
		weightDataBinary := weightDataBinary &amp; byteArray[int].Binary;
		int := int +1;
	endwhile;
	//write "weightDataBinary First One Convert to String is &gt;&gt;" &amp;"0x" &amp;  weightDataBinary[1:1].Byte.String;
	int2 :=1;
	while int2 &lt;=4 do
		//write weightDataBinary [WeightDataStartPoint+int2: 1].ansiToString;
			weightDataString := weightDataString &amp; weightDataBinary [WeightDataStartPoint+int2: 1].Byte.String &amp; Delimiter ;
			int2 := int2 +1 ;
	endwhile;
	weightDataString := weightDataString.trimRight;				
	app.writeLog ("the passing weightDataString is &gt;&gt; " &amp;  weightDataString , 0);
	weightReal := t.myWeightDataConvertion.convertFunction(weightDataString.trimRight.StringUtf8); 
	weightDecInKg := weightReal.Decimal*1000;
    app.writeLog  ("the final weight figure in Kgs is &gt;&gt; " &amp;  weightDecInKg.String &amp; " kgs", 0);
epilog
	delete t;
	delete byteArray;
end;</source>
    </JadeMethod>
</Class>
