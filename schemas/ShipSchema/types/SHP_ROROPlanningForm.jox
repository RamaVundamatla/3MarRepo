    <JadeMethod name="doPicCloseRemarksClick" id="216a0de7-dc26-40be-9ddc-ae5dda336e49">
        <source>doPicCloseRemarksClick(_picture :CMUI_Picture)protected;
/*
Date		Who		Reason
21 Aug 2012	cnwcs5	Initial creation - par 29124:2
*/
vars
	parent	:Window;
	frame	:CMUI_MoveableRemarksFrame;
begin
	parent := _picture.parent;
	
	if parent &lt;&gt; null and parent.isKindOf(CMUI_MoveableRemarksFrame) then
		frame := parent.CMUI_MoveableRemarksFrame;
	endif;
	
	if frame = null then
		return;
	endif;
	
	self.allRemarksControls.removeIfPresent (frame);
	
	delete frame;	// will delete receiver
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_picture" type="CMUI_Picture"/>
    </JadeMethod>
    <JadeMethod name="doPicRemarksClick" id="83b607c0-ba39-455c-9e0b-668b7227c24d">
        <updating/>
        <source>doPicRemarksClick(_picture :Picture) updating, protected;
/*
Date		Who		Reason
26 Jul 2012	cnwcs5	Initial creation - par 29124
21/Aug 2012	cnwcs5	par 29124:2
*/
constants
	Offset 		= 5;
	Width		= 200;
vars
	frame			:CMUI_MoveableRemarksFrame;
	remarks			:String;
	graphic			:CM_DeckItemLayout;					// par 29124:2 Aug 2012
	gotException	:Boolean;							// par 29124:2 Aug 2012
	closeButton		:Picture;							// par 29124:2 Aug 2012
begin
	frame 		:= self.frmRemarks.getControl (_picture.index);
	
	if frame = null then
		on Exception do app.handleDeletedObject (exception, graphic, gotException);	// par 29124:2 Aug 2012

		graphic	:= _picture.userObject.CM_DeckItemLayout;							// par 29124:2 Aug 2012
		remarks	:= graphic.getROROLayoutRemarks ();									// par 29124:2 Aug 2012

		if gotException then														// par 29124:2 Aug 2012
			// graphic has been deleted - should not be possible 
			return;
		endif;																		// par 29124:2 Aug 2012
		
		// need to create it
		frame 				:= self.frmRemarks.loadControl (_picture.index).CMUI_MoveableRemarksFrame;
		frame.wordWrap		:= true;
		frame.setContents (graphic.code, remarks, Width, Offset);					// par 29124:2 Aug 2012
		frame.userObject	:= graphic;
		frame.parent		:= _picture.parent;
	
		self.allRemarksControls.add(frame);
		
		frame.move (_picture.left + _picture.width + Offset, _picture.top, frame.width, frame.height);	// par 29124:2 Aug 2012
		
		// also create button to close it
		closeButton 		:= self.picCloseRemarks.loadControl (_picture.index).CMUI_Picture;	// par 29124:2 Aug 2012
		closeButton.parent	:= frame;															// par 29124:2 Aug 2012
		closeButton.borderStyle	:= Picture.BorderStyle_None;									// par 29124:2 Aug 2012
		
		closeButton.move (frame.width - closeButton.width - 2, 1, 16, 16);
	else
		frame.move (_picture.left + _picture.width + Offset, _picture.top, frame.width, frame.height);	// par 29124:2 Aug 2012	
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_picture" type="Picture"/>
    </JadeMethod>
