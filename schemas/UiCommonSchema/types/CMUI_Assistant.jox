    <JadeMethod name="displayEntryShippingLine" id="f0658f22-b562-47ba-a5a9-cf68f912bd33">
        <source>displayEntryShippingLine(_shippingLine : CM_ShippingLine) : String;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	failedDAC  :CM_DataAccessController;
begin

	if _shippingLine = null then
		return null;
	endif;

	if (not _shippingLine.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if self.myTerminal.getConfig(ComboByNameLine).Boolean then			// TFS 53362
		return _shippingLine.description &amp; Tab &amp; _shippingLine.code;	// TFS 53362
	else																// TFS 53362
		return _shippingLine.code &amp; Tab &amp; _shippingLine.description;
	endif;																// TFS 53362
	
end;</source>
