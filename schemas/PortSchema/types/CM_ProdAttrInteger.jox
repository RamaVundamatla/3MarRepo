    <JadeMethod name="create" id="02cf2098-5e70-48a1-b60f-e3436160d92a">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     
//
