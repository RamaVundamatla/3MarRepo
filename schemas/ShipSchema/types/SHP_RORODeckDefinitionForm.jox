    <JadeMethod name="doNewSubDeck" id="a441ad0f-118a-4728-af99-5b6c48a8c42d">
        <updating/>
        <source>doNewSubDeck() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwer1	Initial creation

*/

vars
	parentDeck : CM_Deck;
begin
	parentDeck := self.myCurrentDeck;
	
	if self.myCurrentDeck = null then
		//need to raise an appropriate error - required field etc
		return;
	endif;
	
	self.isSubDeck:=true;
	//set to null so doChangeMode clears all the fields 
	self.myCurrentDeck:=null;
	
	self.doChangeMode(self.Mode_New);
	
	//set back so on save we have a reference to use as the parent deck
	self.myCurrentDeck:=parentDeck;
	
epilog

end;</source>
        <access>protected</access>
