    <JadeMethod name="attachTI" id="f753b6ac-969c-408b-b30e-d7ca79eac26d">
        <updating/>
        <source>attachTI(pChild : CM_TrackedItem input) updating;
//--------------------------------------------------------------
//Created: 04 February 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars

begin

	exclusiveLock(self);

	if pChild = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "No tracked item passed in", null, null);		
	endif;

	pChild.attachToBOL(self);
	
	self.updateObjectEdition (self);	// par 30292

end;</source>
        <Parameter name="pChild" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
