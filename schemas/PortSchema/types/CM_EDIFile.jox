    <JadeMethod name="canFileBeUpdatedOrCancelled" id="b370a5c7-c140-4ab7-b3de-2cf95046a184">
        <source>canFileBeUpdatedOrCancelled() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/07/2023	navdap1		Initial creation TFS 58923 EUP Calloff EDI Data Type / EDI Load
// 13/11/2023	navmd1		TFS 61214 - Fix 1292 when cancelling a file with a large number of Work Order Details
// 23/11/2023	navdap1		TFS 58929 EUP | CallOff Cancel Processing
// 04/04/2024   navsp1      Bug 63176: EUP* | FR - 53824 Manifest Created Duplicate Cargo During Replace Action of EDI File
// 05/04/2024   navsp1      Bug 63492: EUP: Update/ Cancel request for the Road/ Rail manifest message does not raise an exception if the TI already processed.
// 22/11/2024   navsp1      JIRA 33407 EUP | FR 53824 - Unable to update Manifest/VBS Appointment after WO Approved
vars
	iter : Iterator;
	terminal : CM_Terminal;
	train, foundTrain : CM_Train;		// TFS 58929
	transportMode : String;
	woAssociated : CM_WorkOrder;
	wod : CM_WorkOrderDtl;
	voyage : CM_Voyage;
	vehicle : CM_Vehicle;
	ediDataManifest : CM_EDIDataTransManifest;
	ediDataCallOff : CM_EDIDataCallOff;
	ediTI : CM_EDITrackedItem;
	trainCode : String;
	voyageCode : String;
	now : TimeStamp;
	vbsTerminal : CM_VehicleBookingTerminal;
	vbsTS : CM_VehicleBookingTimeSlot;
	allEDITrackedItems : CM_EDITIById;
	transportRefInternal, transportRefExternal : String;
	manifestNumber : String;
	ti : CM_TrackedItem;
	invalidTi : Boolean;
	errStr : String;
	failCount : Integer;
	workOrderId : String;
	wagon : CM_Wagon;//TFS 63492
	isCallOff : Boolean; //TFS 63492
begin
	if self.ediData.isKindOf(CM_EDIDataTransManifest) then
		ediDataManifest := self.ediData.CM_EDIDataTransManifest;
		
		if ediDataManifest.myGateDocument &lt;&gt; null then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ROAD;
			allEDITrackedItems := ediDataManifest.myGateDocument.allEDITrackedItems;
		elseif ediDataManifest.myCargoOnSite &lt;&gt; null then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ONSITE;
			allEDITrackedItems := ediDataManifest.myCargoOnSite.allEDITrackedItems;
		elseif ediDataManifest.myShipManifest &lt;&gt; null then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_SEA;
			allEDITrackedItems := ediDataManifest.myShipManifest.allEDITrackedItems;
		elseif ediDataManifest.myTrainConsist &lt;&gt; null then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_RAIL;
			allEDITrackedItems := ediDataManifest.myTrainConsist.allEDITrackedItems;
		endif;
		transportRefExternal := ediDataManifest.transportReferenceCustomer;
		transportRefInternal := ediDataManifest.transportReferenceInternal;
		manifestNumber := ediDataManifest.manifestNumber;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Checking Transport Manifest " &amp; manifestNumber, LogINFO);
		isCallOff := false;//TFS 63492
	elseif self.ediData.isKindOf(CM_EDIDataCallOff) then
		ediDataCallOff := self.ediData.CM_EDIDataCallOff;
		allEDITrackedItems := ediDataCallOff.myRequestMultiLine.allEDITrackedItems;
		
		if ediDataCallOff.transportationMode.toUpper = BR_TYPE_ROAD_STR.toUpper then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ROAD;
		elseif ediDataCallOff.transportationMode.toUpper = BR_TYPE_RAIL_STR.toUpper then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_RAIL;
		elseif ediDataCallOff.transportationMode.toUpper = BR_TYPE_SHIP_STR.toUpper then
			transportMode := CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_SEA;
		endif;
		transportRefExternal := ediDataCallOff.transportReferenceCustomer;
		transportRefInternal := ediDataCallOff.transportReferenceInternal;
		manifestNumber := ediDataCallOff.manifestNumber;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Checking CallOff " &amp; manifestNumber, LogINFO);
		isCallOff := true;//TFS 63492
	else
		// don't know what to do
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No idea what we're doing here with EDI data " &amp; self.ediData.class.name, LogERROR);
		return false;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	// Checking if voyage has arrived is only relevant for Manifest
	if transportMode = CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_SEA and ediDataManifest &lt;&gt; null then
		
		foreach ediTI in allEDITrackedItems do
			//if ediTI.isKindOf(CM_EDIBOLHdrTI) or ediTI.isKindOf(CM_EDIRequestHeaderTI) then	//TFS 63176
				voyageCode := ediTI.getVoyageCode();
				if voyageCode &lt;&gt; null then														//TFS 63176
					break;
				endif;																			//TFS 63176
			//endif;																			//TFS 63176
		endforeach;
	
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
		
		/*	16.Jul.24 navsp1 TFS 61945/64660 - commenting as it no longer required
		if voyage &lt;&gt; null and voyage.code = voyageCode and ((voyage.arrivedDT.isValid and voyage.arrivedDT.date &lt;= now.Date) or voyage.status &gt;= Voyage_Status_EUP_Arrived) then //30.Jan.24 navsp1 TFS 61945//13.May.24 navsp1 TFS 61945
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Voyage " &amp; voyageCode &amp; " has arrived - " &amp; voyage.arrivedDT.date.asStringJMT &amp; " - return false", LogDEBUG);
			return false;
		endif;*/
		
		workOrderId := voyageCode;		//30.Jan.24 navsp1 TFS 61945 - voyage code is used as single work order id.
		
	elseif transportMode = CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ROAD then	
		
		vbsTerminal := terminal.myVehicleBookingTerminal;	
		if transportRefExternal &lt;&gt; null then
			vbsTS := vbsTerminal.allVBTimeslotsByExtRef.getAtKey(transportRefExternal);
			workOrderId := transportRefExternal;	//TFS 63492
		elseif transportRefInternal &lt;&gt; null then
			vbsTS := vbsTerminal.allVBTimeslotsById.getAtKey(transportRefInternal);
			workOrderId := transportRefInternal;	//TFS 63492
		endif;
		if vbsTS &lt;&gt; null then
			if vbsTS.getStatusInteger.isOneOf(vbsTS.BookedArrivedEarlyInt, vbsTS.BookedArrivedLateInt, vbsTS.BookedArrivedOntimeInt) then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Vehicle Booking Slot " &amp; vbsTS.id &amp; " has status " &amp; vbsTS.getStatusString &amp; " - return false", LogDEBUG);
				return false;
			endif;
			vehicle := vbsTS.myVehicle;
			
			//Note : WorkOrderId - Using the same logic as in the WO creation method(utlCreateWOForRoadManifest) to get the value for "WorkOrderId".		//TFS 63492
			if vehicle &lt;&gt; null then																															//TFS 63492
				workOrderId := vehicle.regNumber;																											//TFS 63492
			endif;																																			//TFS 63492
			
		endif;
		
		if vehicle &lt;&gt; null and vehicle.isOnsite then 
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Vehicle " &amp; vehicle.regNumber &amp; " is on site - return false", LogDEBUG);
			return false;
		endif;
		
	elseif transportMode = CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_RAIL then
		foreach ediTI in allEDITrackedItems do
			if ediTI.isKindOf(CM_EDITrainTI) then
				trainCode := ediTI.CM_EDITrainTI.trainCode;
				break;
			endif;
		endforeach;
		
		foreach train in terminal.allTrainsArrival where train.code = trainCode do
			foundTrain := train;			// TFS 58929
			break;
		endforeach;
		
		//if train &lt;&gt; null and not train.isNullTrain and train.arrivalDT.isValid and train.arrivalDT &lt;= now then //the train has arrived					// TFS 58929
		if foundTrain &lt;&gt; null and not foundTrain.isNullTrain and foundTrain.arrivalDT.isValid and foundTrain.arrivalDT &lt;= now then //the train has arrived	// TFS 58929
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Train " &amp; trainCode &amp; " has arrived - " &amp; train.arrivalDT.date.asStringJMT &amp; " - return false", LogDEBUG);
			return false;
		endif;
		if ediDataManifest &lt;&gt; null and ediDataManifest.myTrainConsist &lt;&gt; null then					//TFS 63492
			wagon := terminal.getLatestWagonByCode(ediDataManifest.myTrainConsist.currentWagonCode);//TFS 63492
			if wagon &lt;&gt; null then																	//TFS 63492
				workOrderId := wagon.id;															//TFS 63492
			endif;																					//TFS 63492
		endif;																						//TFS 63492
	elseif transportMode = CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ONSITE then		//05.Oct.2023 navsp1 TFS 58058
		failCount := 0;
		iter := terminal.allOffsiteTIsByIdCargoType.createIterator();
		foreach ediTI in allEDITrackedItems do
			terminal.allOffsiteTIsByIdCargoType.startKeyGeq(ediTI.id, ediTI.cargoType, null, iter);
			while iter.next(ti) do
				if ti.id &lt;&gt; ediTI.id then
					break;
				endif;
				if ti.getMyCargoGroupId = ediTI.getCargoGroupId then
					failCount := failCount + 1;
					//Raise an exception if the cargo is off-site
					app.writeLog(method.qualifiedName &amp; Tab &amp; app.getErrorString2(This_item_already_moved, ti.id, app.getErrorString(OffSite)), LogERROR);															
					errStr := app.getErrorString2(This_item_already_moved, ti.id, app.getErrorString(OffSite));			
					app.myPassport.addErrorFull(This_item_already_moved, errStr, null, null, null);	
				endif;
			endwhile;
		endforeach;
		delete iter;
		if failCount &gt; 0 then
			return false;
		endif;
	endif;
	
	//30.Jan.24 navsp1 TFS 61945
	if workOrderId = null or isCallOff then	 //TFS 63492		
		workOrderId := manifestNumber;
	endif;	
	
	// if we reached here, that means the transport(train/truck/vessel has not come)
	// now check if any of the goods have arrived
	woAssociated := terminal.allWorkOrders[workOrderId];
	if woAssociated &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalidTi ); //18.Aug.2023 navsp1 TFS 59872
		
		foreach wod in woAssociated.allWoDtls do
			if wod.isKindOf(CM_WorkOrderTIDtl) then
				// if any of the TIs on this WO detail have been actioned or completed, we can't change the work order
				//if not wod.CM_WorkOrderTIDtl.allActionedTIs.isEmpty	//JIRA-33407 - Exception raise only if the TI actioned.
				if not wod.CM_WorkOrderTIDtl.allCompleteTIs.isEmpty then
					app.writeLog(method.qualifiedName &amp; Tab &amp; "Work Order " &amp; woAssociated.id &amp; " has cargo that has been actioned / completed - return false", LogDEBUG);
					return false;
				endif;
				
				// double-check (because if the work order isn't Approved, then TIs will still 
				// be in the allSelected Tis collection)
				foreach ti in wod.CM_WorkOrderTIDtl.allSelectedTIs discreteLock do
					
					//01.Mar.24 navsp1 TFS 61427 
					//If any of the TI has been already processed from the same WO but different manifest file was causing problems.
					//Check TI's only from the same manifest messages
					if ti.getManifestIndexValue(1) &lt;&gt; manifestNumber then
						continue;
					endif;
					
					invalidTi := false;
					if ediDataManifest &lt;&gt; null and ti.receivedDT &lt;&gt; null then
						// TI has been received - cannot do anything with this work order
						app.writeLog(method.qualifiedName &amp; Tab &amp; "Work Order " &amp; woAssociated.id &amp; " has cargo that has been received - return false", LogDEBUG);
						return false;
					elseif ediDataCallOff &lt;&gt; null and ti.releasedDT &lt;&gt; null then
						// TI has been released - cannot do anything with this work order
						app.writeLog(method.qualifiedName &amp; Tab &amp; "Work Order " &amp; woAssociated.id &amp; " has cargo that has been released - return false", LogDEBUG);
						return false;
					endif;
					if invalidTi then												//18.Aug.2023 navsp1 TFS 59872
						continue;
					endif;
				endforeach;
			endif;
		endforeach;
		
	endif;
	
	//if we reached here, it means, the transport has not come yet, nor have any of the TIs
	app.writeLog(method.qualifiedName &amp; Tab &amp; "All good - return true", LogDEBUG);
	return true;

epilog	
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="2ad59ef3-5e3f-4b16-b99e-f335f50387aa">
        <source>canUserSet(_propName: String): Boolean;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _propName = CM_EDIFile::fileRecipientCode.name 
	or _propName = CM_EDIFile::fileRef.name 
	or _propName = CM_EDIFile::fileSenderCode.name 
	or _propName = CM_EDIFile::fileTypeCode.name then
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="9bad64a4-a0ad-468c-9176-e05bc580b762">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//
//	7th June 2023 navra1 	TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
//----------------------------------------------------------------
vars

begin
	exclusiveLock(self);
	
	self.ediData := null; 
	
	self.allHeaderReferences.purge();

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
