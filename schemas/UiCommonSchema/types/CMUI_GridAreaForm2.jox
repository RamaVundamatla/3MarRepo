    <JadeMethod name="showHideLayout" id="765b7ace-f9c1-4566-9d38-8374f733c2e8">
        <updating/>
        <source>showHideLayout(_show : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDkbPos	: CMUI_JadeDockBar;
begin

	tmpDkbPos := self.dkbPosition;
	
	if _show then
		self.mnuGridLayout.caption := app.getErrorString(HideLayoutOverview);
		self.mnuWorkDisplayLayout.caption := app.getErrorString(HideLayoutOverview);

		self.layoutRedraw(true);

		if (not tmpDkbPos.isFloating) then
			// some problem here where float event seems to get height
			// screwed up - RJS
			tmpDkbPos.height := tmpDkbPos.height + 25;
			tmpDkbPos.centreWindow();
			tmpDkbPos.float(layoutFramePosition.x, layoutFramePosition.y, tmpDkbPos.width.Integer, tmpDkbPos.height.Integer);
		endif;

		tmpDkbPos.visible := true;
		
	else
		tmpDkbPos.visible := false;
		
		// if the dockbar was closed by clicking its close button then
		// the left and right are no longer valid - refer PAR-34941 where
		// have asked if can tell what position was
		layoutFramePosition.set(tmpDkbPos.left.Integer, tmpDkbPos.top.Integer);

		self.mnuGridLayout.caption := app.getErrorString(ShowLayoutOverview);
		self.mnuWorkDisplayLayout.caption := app.getErrorString(ShowLayoutOverview);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
