    <JadeMethod name="createTransaction" id="e7f48d25-6bbd-44eb-955d-bd62bdc88b95">
        <source>createTransaction(_realTI : CM_TrackedItem input; _type : Integer; _ts : TimeStamp) : CM_TITransaction;
// cnwrs1 
vars
	transParams: CMIF_TITransactionController;
	tranTS : TimeStamp;
	now : Date;
	transObj : CM_TITransaction;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	create transParams transient;
	transParams.type := _type;
	transParams.noCharge := false;
	transParams.userId := app.getMyUserCode();
	if _ts = null or
	   not _ts.isValid() then
		tranTS.setDate(now);
		transParams.dateTime := tranTS;
	else
		transParams.dateTime := _ts;
	endif;
	beginTransaction;
	transObj := _realTI.createTransaction(transParams, app.myPassport);
	if self.opts.includesKey("CamsDate") then
		transObj.setCAMSTimeStamp(self.opts.str("CamsDate").TimeStamp);
	endif;
	commitTransaction;
	return transObj;
epilog
	delete transParams;
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createTransactionMap" id="e3a56c7f-91ee-4c26-903a-87a2f3e80d79">
        <source>createTransactionMap(_mapName : String) : CM_TranMap;

vars
	bank		: CM_Bank;
	cargoMap,
	proxyMap	: CM_TranMap;

begin
	bank := self.getTerminal().getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[_mapName];
	if cargoMap = null then
		create proxyMap transient;
		proxyMap.setProxy(bank, _mapName, _mapName);
		app.myTrxCA.trxCreateInvoiceTranMap(proxyMap, cargoMap, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	return cargoMap;
epilog
	delete proxyMap;
end;
</source>
        <Parameter name="_mapName" type="String"/>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="createUpdateYATemplate" id="3160eae9-6fb0-496a-ae41-0023bfa6cc8f">
        <source>createUpdateYATemplate(_yATemplate: CM_YATemplate; proxyYA: CM_YardAllocation io; proxyCriterias: CMIF_Array io) : CM_YATemplate;
//18 July 2008	cnwdw1	
//
vars
	proxyYATemplate: CM_YATemplate;
	criteria: CM_YACriteria;
begin
	proxyYATemplate := app.createUpdateProxy(_yATemplate).CM_YATemplate;
	proxyYA := proxyYATemplate.myYardAllocation;
	create proxyCriterias transient;
	foreach criteria in _yATemplate.myYardAllocation.allCriteria do
		proxyCriterias.add(criteria.getTransient());
	endforeach;
	
	return proxyYATemplate;
end;</source>
        <Parameter name="_yATemplate" type="CM_YATemplate"/>
        <Parameter name="proxyYA" type="CM_YardAllocation" usage="io"/>
        <Parameter name="proxyCriterias" type="CMIF_Array" usage="io"/>
        <ReturnType type="CM_YATemplate"/>
    </JadeMethod>
    <JadeMethod name="createVesselFromXML" id="08862c05-2146-4c47-9d57-14728d734b75">
        <source>createVesselFromXML(_code, _theXML : String) : CM_Vessel;

vars
	proxyVessel : CM_Vessel;
	realVessel : CM_Vessel;
	conflictManager		: CMIF_HMS_ConflictsManager;
	operator				: CM_Operator;
	trade					: CM_Trade;
begin
	create proxyVessel as CM_Vessel transient;	
	proxyVessel.setProxyVesselFromXML(_theXML);
	if proxyVessel.myCellularVesselStructure &lt;&gt; null then
		proxyVessel.myCellularVesselStructure.setPropertyValue(CM_CellularVesselStructure::isImported.name, true);
	endif;
	proxyVessel.setPropertyValue(CM_Vessel::code.name, _code);
	if proxyVessel.myHMSVesselData &lt;&gt; null then								// 05/10/2017 jlgmh5
		proxyVessel.myHMSVesselData.setPropertyValue(HMS_VesselData::myRoot.name, app.myRoot);
	endif;
	if self.opts.includesKey("Operator") then								// 05/10/2017 jlgmh5
		operator := app.myRoot.allOperators[self.opts.str("Operator")];
		proxyVessel.setPropertyValue("myOperator", operator);
	endif;
	if self.opts.includesKey("VesselName") then								// 05/10/2017 jlgmh5
		proxyVessel.setPropertyValue("name", self.opts.str("VesselName"));
	endif;
	if self.opts.includesKey("DefaultTrade") then
		trade := app.myRoot.allTradesByDescription[self.opts.str("DefaultTrade")];
		proxyVessel.setPropertyValue("myDefaultTrade", trade);
	endif;
	app.myTrxCA.trxCreateVessel(proxyVessel, realVessel, conflictManager, app.myPassport);
	return realVessel;
epilog
	delete proxyVessel;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_theXML" type="String"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="createVoyageDelay" id="60d9defc-8688-469b-8fd4-d5d683f6df91">
        <source>createVoyageDelay(_startTS, _endTS, _estEndTS: TimeStamp; _voyage : CM_Voyage; _delayCode : String) : CM_Delay;
/*

Purpose:	Create voyage delay		
	

Date		Who		Reason
15/03/2018	jlgmh5	Initial creation

*/

vars

	delayProxy 			: CM_Delay;
	realDelay 			: CM_Delay;
	delayType 			: CM_DelayType;
	machine				: CM_Machine;
	
	remarks				: String;

begin

	self.deleteVoyageDelay(_startTS, _endTS, _estEndTS, _voyage);
	
	// get the delay type
	delayType := app.myRoot.allDelayTypes[_delayCode].CM_DelayType;
	self.assertNotNull(delayType);
	
	if self.opts.includesKey("Machine") then
		machine := self.getMachine(self.opts.str("Machine"));
		self.assertNotNull(machine);
	endif;
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	create delayProxy transient;
	delayProxy.setProxy(_voyage.myTerminal,
					_voyage,
					delayType,
					_startTS,
					_estEndTS,
					_endTS,
					machine,
					app.getMyUser(),
					null,
					remarks);
	app.myTrxCA.trxCreateDelay(delayProxy, realDelay, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realDelay;	
	
epilog
	
	delete delayProxy;

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_estEndTS" type="TimeStamp"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_delayCode" type="String"/>
        <ReturnType type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="createWorkPointJobSheet" id="570b99ae-af83-4640-b57d-fce1c3eacf4e">
        <source>createWorkPointJobSheet(workPointName, externalName : String; shiftStartDT, shiftEndDT : TimeStamp) : CM_WorkPointJobSheet;
/*

Purpose:		Create Work Point Job Sheet	

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2023	navmh5	Initial Creation
*/
vars

	pxyWorkPointJobSheet				: CM_WorkPointJobSheet;
	realJobSheet  						: CM_WorkPointJobSheet;
	workPoint							: CM_WorkPoint;
	shift								: CM_Shift;
	
	allShiftDays						: CM_ShiftStartDateCodeDict;
	
begin

	self.deleteWorkPointJobSheet(externalName);
	
	
	create allShiftDays transient;
	allShiftDays.purge();
	self.getTerminal().getShiftsFromRange(allShiftDays, shiftStartDT, shiftEndDT);
	
	if (allShiftDays.isNotEmpty) then
		shift := allShiftDays.first;
	endif;
	
	workPoint := self.getTerminal().allWorkPointsByCode[workPointName];
	self.assertNotNullMsg(workPoint, "Work point (" &amp; workPointName &amp; ") NOT found.");
			
	create pxyWorkPointJobSheet transient;
	pxyWorkPointJobSheet.setProxy(shift, self.getTerminal, workPoint, shift.startDateTime, externalName, "", "", "");
	
	app.myTrxCA.trxCreateWorkPointJobSheet(pxyWorkPointJobSheet, realJobSheet, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return realJobSheet;

epilog

	delete pxyWorkPointJobSheet;
	
	if allShiftDays &lt;&gt; null then
		allShiftDays.purge();
		delete allShiftDays;
	endif;

end;
</source>
        <Parameter name="workPointName" type="String"/>
        <Parameter name="externalName" type="String"/>
        <Parameter name="shiftStartDT" type="TimeStamp"/>
        <Parameter name="shiftEndDT" type="TimeStamp"/>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="createYA" id="d978a8ff-0110-4c85-9c09-e39ef35c3615">
        <source>createYA(name: String; _terminal: CM_Terminal; _locations: CM_LCArray; _fillOptionIn, _fillOptionOut: Integer; _separateRanges : Boolean) : CM_YardAllocation;
//16 July 2008	cnwdw1	
// The locations are treated as a collection of pairs - the first is topleft corner, and second bottom right.
vars
	proxyYA : CM_YardAllocation;
	terminalArea : CM_TerminalArea;
	proxyGroup	: CM_YABlockGroup;
	yaBlock : CM_YABlock;
	location: CM_LocationsController;
	topLeftLocation, bottomRightLocation : CM_GridController;
	firstLane, lastLane: CM_RoRoController;
	allYABlocksIn : CM_YABlockArray;
	allYABlocksOut : CM_YABlockArray;
	
	locations: CM_LCArray;
	iter: Iterator;
	allBlockGroupsIn: CM_YABlockGroupArray;
	allBlockGroupsOut: CM_YABlockGroupArray;
	
	row,col,lane: Integer;
	
	lastTa : CM_TerminalArea;
	taLocations : CM_LCArray;
	yaAgent : CM_YAAgent;
	
begin
	create proxyYA transient;
	
	if _locations &lt;&gt; null then
		create allYABlocksIn transient;
		create allYABlocksOut transient;
		create locations transient;
		iter := locations.createIterator;
		
		_locations.copy(locations);
		
		// Add  YA Block for the locations
		
		if _separateRanges then
		
			create proxyGroup transient;  // auto deleted
			proxyGroup.setProxy("Default", allYABlocksIn, allYABlocksOut);
			create allBlockGroupsIn transient;
			allBlockGroupsIn.add(proxyGroup);
			create allBlockGroupsOut transient;
			allBlockGroupsOut.add(proxyGroup);
			
			proxyYA.setProxy(	name,
								name&amp;" Description",
								name&amp;" Remarks",
								_fillOptionIn,  //YAFillOption_Alternating,
								_fillOptionOut, //YAFillOption_Alternating,
								YAExpiryType_Never,
								null,
								1000,  // colour
								null,  //cnwjo3 par 24145
								YAOverlap_Always,
								YANoLocation_Continue,
								null,
								0,
								false,
								false,
								allBlockGroupsIn,
								allBlockGroupsOut,
								false,
								_terminal);
		
			create yaAgent transient;
			create taLocations transient;
			lastTa := locations.first.myTerminalArea;
			while iter.next(location) do
				terminalArea := location.myTerminalArea;
				if lastTa = terminalArea then
					taLocations.add(location);
					continue;
				else
					yaBlock := yaAgent.addYABlock( proxyYA, taLocations);
					taLocations.clear();
					taLocations.add(location);
					lastTa := terminalArea;
				endif;
			endwhile;
			if not taLocations.isEmpty then
				yaBlock := yaAgent.addYABlock( proxyYA, taLocations);
			endif;
			
			return proxyYA;
		
		else
		
			if locations.size = 1 and (locations.first.isKindOf(CM_GridController) or locations.first.isKindOf(CM_RoRoController)) then
				locations.add(locations.last);
			endif;
			while iter.next(location) do
				if location.isKindOf(CM_GridController) then
					topLeftLocation := location.CM_GridController;
					yaBlock := topLeftLocation.yaBuildBlock(true, null);
					iter.next(location);
					bottomRightLocation := location.CM_GridController;
					if bottomRightLocation = null then
						delete yaBlock;
						continue;
					endif;
					terminalArea := topLeftLocation.myTerminalArea;
					foreach row in topLeftLocation.row to bottomRightLocation.row do
						foreach col in topLeftLocation.column to bottomRightLocation.column do
							yaBlock.allYardControllers.add(terminalArea.CM_GridArea.allGridControllersByRowColumn[row, col]);
						endforeach;
					endforeach;	
				elseif location.isKindOf(CM_RoRoController) then
					firstLane := location.CM_RoRoController;
					yaBlock := firstLane.yaBuildBlock(true, null);
					terminalArea := firstLane.myTerminalArea;
					iter.next(location);
					lastLane := location.CM_RoRoController;
					foreach lane in firstLane.laneNumber to lastLane.laneNumber do 
						yaBlock.allYardControllers.add(terminalArea.CM_RoRoLaneArea.allLanesByLaneNumber[lane]);
					endforeach;	
				else
					yaBlock := location.yaBuildBlock(true, null);
					yaBlock.allYardControllers.add(location.CM_YardController);
				endif;
				
				yaBlock.setProxyDeckingOptions();
				allYABlocksIn.add(yaBlock);
				allYABlocksOut.add(yaBlock);
			endwhile;
		
		endif;
			
		// Add a Group
		create proxyGroup transient;  // auto deleted
		proxyGroup.setProxy("Default", allYABlocksIn, allYABlocksOut);
		create allBlockGroupsIn transient;
		allBlockGroupsIn.add(proxyGroup);
		create allBlockGroupsOut transient;
		allBlockGroupsOut.add(proxyGroup);
	endif;
	
	proxyYA.setProxy(name,
						name&amp;" Description",
						name&amp;" Remarks",
						_fillOptionIn,  //YAFillOption_Alternating,
						_fillOptionOut, //YAFillOption_Alternating,
						YAExpiryType_Never,
						null,
						1000,  // colour
						null,  //cnwjo3 par 24145
						YAOverlap_Always,
						YANoLocation_Continue,
						null,
						0,
						false,
						false,
						allBlockGroupsIn,
						allBlockGroupsOut,
						false,
						_terminal);

	return proxyYA;
	
epilog
	delete allYABlocksIn;
	delete allYABlocksOut;
	delete allBlockGroupsIn;
	delete allBlockGroupsOut;
	delete locations;
	delete iter;
	delete taLocations;
	delete yaAgent;
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_fillOptionIn" type="Integer"/>
        <Parameter name="_fillOptionOut" type="Integer"/>
        <Parameter name="_separateRanges" type="Boolean"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="createYACriteria" id="11eaefab-143e-4275-9c27-582f842b5e9f">
        <source>createYACriteria(_criteria: Integer; _value: Any) : CMIF_YACriteriaPriority;
//16 July 2008	cnwdw1	
//
vars
	proxyCriteria: CM_YACriteria;
	criteriaType : CM_YACriteriaType;
	cmifCriteria : CMIF_YACriteriaPriority;
	objects: CM_ObjectSet;
	itemCode : String;
	value: Any;
begin
	if _value.isKindOf(CM_Object) then
		create objects transient;
		objects.add(_value.CM_Object);
		value := objects;
	else
		value := _value;
	endif;
	// Add Criteria
	create proxyCriteria transient;
	criteriaType := app.myRoot.allYACriteriaTypes[_criteria]; 
	itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
	proxyCriteria.setProxy(criteriaType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);	
	return cmifCriteria;
epilog
	delete objects;

end;</source>
        <Parameter name="_criteria" type="Integer"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="createYACriterias" id="5cad844e-9f1e-404c-9f54-049b3e7d2015">
        <source>createYACriterias(criteria1: Integer; value1: Any;
					  criteria2: Integer; value2: Any;
					  criteria3: Integer; value3: Any) : CMIF_Array;
//16 July 2008	cnwdw1	
// 06/03/2015	cnwmh5	Update to allow for more than 3 criteria via opts
constants

	TextToCheck			: String = "YACriteriaType_";

vars
	proxyYACriteria		: CMIF_Array;
	
	localOpts			: CM_Association;
	constantCategory	: ConstantCategory;
	constant			: Constant;
	
	constDict			: ConstantColl;
	
	iter				: Iterator;
	iterConstant		: Iterator;
	
	
	criteria			: Integer;
	value				: Any;
	
	optsKey				: String;
	firstTime			: Boolean;
	
begin
	// Add Criteria
	create proxyYACriteria transient;
	if criteria1 &gt; 0 then
		proxyYACriteria.add(self.createYACriteria(criteria1, value1));
	endif;
	if criteria2 &gt; 0 then
		proxyYACriteria.add(self.createYACriteria(criteria2, value2));
	endif;
	if criteria3 &gt; 0 then
		proxyYACriteria.add(self.createYACriteria(criteria3, value3));
	endif;
	
	// loop through the assocations looking for ones starting with "YACriteriaType_" to create
	firstTime := true;
	create constDict transient;
	iter := self.opts.createIterator;
	while iter.next(localOpts) do
		self.opts.getIteratorKeys(optsKey, iter);
		if optsKey[1:TextToCheck.length] = TextToCheck.toUpper() then
		
			if firstTime then
				constantCategory := rootSchema.getSchema(PortSchemaName).getCategory("YACriteriaTypes");
				self.assertNotNull(constantCategory);
				firstTime := false;
				constantCategory.cnEcGetConstants().copy(constDict);
				iterConstant := constDict.createIterator;
			endif;		
		
			value := localOpts.getValue();
			
			iterConstant.reset;
			while iterConstant.next(constant) do
				if constant.name.toUpper() = optsKey then
					criteria := constant.getSource().Integer;
					break;
				endif;
			endwhile;
			proxyYACriteria.add(self.createYACriteria(criteria, value));
		endif;
	endwhile;
	
	return proxyYACriteria;
	
epilog
	delete iter;	
	delete iterConstant;
	delete constDict;
end;</source>
        <Parameter name="criteria1" type="Integer"/>
        <Parameter name="value1" type="Any"/>
        <Parameter name="criteria2" type="Integer"/>
        <Parameter name="value2" type="Any"/>
        <Parameter name="criteria3" type="Integer"/>
        <Parameter name="value3" type="Any"/>
        <ReturnType type="CMIF_Array"/>
    </JadeMethod>
    <JadeMethod name="createYAPriority" id="784744c2-218c-4386-ab27-dc4088adc7ca">
        <source>createYAPriority(_criteria: Integer; _value: Any) : CMIF_YACriteriaPriority;
//16 July 2008	cnwdw1	
//
vars
	proxyCriteria: CM_YAPriority;
