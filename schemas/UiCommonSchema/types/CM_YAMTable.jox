    <JadeMethod name="registerNotes" id="1e0069b5-5328-4888-ad41-6c48f1538f60">
        <source>registerNotes();
//21 August 2008	cnwdw1	
//17 July 	2017 	jlgns1 TFS 4566:CPL - Users encountered 1309 error at same time in Master Terminal
//
vars
	terminal: CM_Terminal;
begin
	terminal := self.getTerminal();
	// cnwjk3 09/03/2009 - PAR 19052
	if (not self.allNotableObjects.includes(terminal)) then
		self.allNotableObjects.add(terminal);
		self.beginNotification(terminal, terminal.getTerminalEvent(Event_YardAllocationCreate), Response_Continuous, 0);
		self.beginNotification(terminal, terminal.getTerminalEvent(Event_YardAllocationUpdate), Response_Continuous, 0);
		self.beginNotification(terminal, terminal.getTerminalEvent(Event_YardAllocationDelete), Response_Continuous, 0);
		self.beginNotification(terminal, terminal.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), Response_Continuous, 0);
		self.beginNotification(terminal, terminal.getTerminalEvent(EVENT_YA_CP_UPDATE), Response_Continuous, 0);			//TFS 4566
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItemYAAt" id="18391544-1163-48b8-89e9-4e48d2126082">
        <updating/>
        <source>removeItemYAAt(_ya: CM_YardAllocation; _row:  Integer): Integer updating;
//25 August 2008	cnwdw1	
//	Remove the ya from the table
//  14 July 2017 jlgns1 TFS 4566:CPL - Users encountered 1309 error at same time in Master Terminal
vars
	rowIndex: Integer;
	invalidObject : Boolean;
begin
	rowIndex := _row;

	if not self.findObjectInRow(_ya, rowIndex) then
		return 0;
	endif;

	// PAR 19368 Try to delete the YA from the priority collection, may fail if the YA has been deleted
	on Exception do app.handleDeletedObject(exception, _ya, invalidObject);
	if 	self.allYardAllocationsByPriority.includes(_ya) then
		self.allYardAllocationsByPriority.remove(_ya);
	else																			//TFS 4566
		//if _ya.priorityValue has been changed includes and remove won't find it	//TFS 4566
		self.allYardAllocationsByPriority.removeObject(_ya);						//TFS 4566
	endif;
	
	if invalidObject then
		// The ya has been deleted so we are left with a invalid object in the transient collection PAR 19305
		self.allYardAllocationsByPriority.removeInvalidObjects();
	endif;

	self.removeItemObjWithIndex(_ya, rowIndex);	// remove the YA

	while rowIndex &lt;= self.rows and self.isChildRow(rowIndex) do
		if self.isBlockGroupRow(rowIndex) then
			self.removeItemYABlockGroupAt(self.accessRow(rowIndex).itemObject.CM_YABlockGroup, rowIndex);	// Remove the YABlockGroup
		else
			self.removeItemYABlockAt(self.accessRow(rowIndex).itemObject.CM_YABlock, rowIndex);	// Remove the YABlock
		endif;
	endwhile;
	
	return rowIndex;	
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeItemYABlockAt" id="98770428-08e0-4425-bc5c-f9795ced42ae">
        <updating/>
        <source>removeItemYABlockAt(_yaBlock: CM_YABlock; _row: Integer): Integer updating;
//25 August 2008	cnwdw1	
//	Remove the yaBlock from the table
vars
	row: Integer;
begin
	row := _row;
	if row &lt;= 0 then
		self.findObjectInRow(_yaBlock, row);
	endif;
	if row &gt; 0 then
		self.removeItemObjWithIndex(CM_YABlock, row);
	endif;
	
	return row;	
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeItemYABlockGroupAt" id="3c95265a-25a9-4eaf-b73a-707776a8781d">
        <updating/>
        <source>removeItemYABlockGroupAt(_yaBlockGroup: CM_YABlockGroup; _row: Integer): Integer updating;
//25 August 2008	cnwdw1	
//	Remove the yaBlockGroup from the table
vars
	row: Integer;
begin
	row := _row;
	if row &lt;= 0 then
		self.findObjectInRow(_yaBlockGroup, row);
	endif;
	if row &gt; 0 then
		self.removeItemObjWithIndex(CM_YABlockGroup, row);
	endif;
	
	return row;	
end;</source>
        <Parameter name="_yaBlockGroup" type="CM_YABlockGroup"/>
