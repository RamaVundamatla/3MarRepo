	self.setQueryControl(self.cmbInvCategory);
	//24/02/2023 navmv20 TFS 56403 Task 56404 - end
	
	//24/02/2023 navmv20 TFS 56403 Task 56460 - start
	//29/03/2023 navmv20 Bug 57023 - START
	//self.setQueryControl(self.txtExternalNumber);
	//self.setQueryControl(self.lblExternalNumber);
	//24/02/2023 navmv20 TFS 56403 Task 56460 - end
	self.setQueryControl(self.lblSearchFor);
	self.setQueryControl(self.cmbSearchFor);
	self.setQueryControl(self.textSearch);
	//29/03/2023 navmv20 Bug 57023 - END
	
	//self.setQueryControl(self.chkArchive);		//11.9.2023 navhl20 #59376
	//self.setQueryControl(self.lblSearchInv);	//14 Apr 2016	NDL	TFS 1849 //29/03/2023 navmv20 Bug 57023
	//self.setQueryControl(self.grpSearchBy); //29/03/2023 navmv20 Bug 57023
	
	self.setQueryControl(self.lblCargoID_);
