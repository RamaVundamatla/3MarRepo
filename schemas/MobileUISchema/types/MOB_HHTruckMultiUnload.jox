    <JadeMethod name="translateForm" id="e09a846a-7099-4fd9-93ce-4ddafab1ee4b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018494, locale);
	lblCargoType.translateCaption(Xlat_0018495, locale);
	lblLocation.translateCaption(Xlat_0018496, locale);
	lblNumItems.translateCaption(Xlat_0018497, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_gotFocus" id="77d0b56b-b7f4-4a71-954c-96bcb4264f72">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

begin

	if txtLocation.text = lblLocation.caption.toUpper then
		txtLocation.selStart := 0;
		txtLocation.selLength := lblLocation.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_lostFocus" id="60d337b1-95c8-4b8e-9699-bac0672486ad">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

begin

	if txtLocation.text.trimBlanks = null then
		txtLocation.text := lblLocation.caption.toUpper;
	endif;
	
	txtLocation.selStart := 0;
	txtLocation.selLength := 0;
	
	self.doFindLocation();

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
