    <JadeMethod name="displayMeasurements" id="abc06d79-cc88-474f-b72b-36f952f931d5">
        <source>displayMeasurements( _wagon : CM_Wagon; _wagonClass : CM_WagonClass ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2013	cnwndl1	Initial creation	Par 32172
25 July	 2022		jlika1	TFS 53741 - EUP- Max Wagon Payload
*/

vars

	measureType			: CM_MeasurementType;
	weight 				: Decimal [12,2];
	height 				: Decimal [12,2];
	allowWagonWeights	: Boolean;
begin
	if self.myTerminal &lt;&gt; null then
		allowWagonWeights := self.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	//weights
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if (allowWagonWeights and _wagon &lt;&gt; null) then
		weight := _wagon.tareWeight;	
	elseif _wagon &lt;&gt; null then
		weight := _wagon.getWagonTareWeight;
	elseif _wagonClass &lt;&gt; null then
		weight := _wagonClass.tareWeight;
	else
		weight := 0;
	endif;
	
	if allowWagonWeights then	
		self.txtTareWeight.visible := false;
		self.tblTare.setup(Type_Weight, self.backColor);
		self.tblTare.tabKey := J_key_Tab;
		self.tblTare.visible := true;	
		self.tblTare.setValues(app.convertMeasurementForDisplay(measureType.shortName, weight) &amp; Space &amp; measureType.shortName);
	else
		self.tblTare.visible := false;	
		self.txtTareWeight.visible := true;
		self.txtTareWeight.text := app.convertMeasurementForDisplay(measureType.shortName, weight) &amp; " " &amp; measureType.shortName;		
	endif;
	
	
	if (allowWagonWeights and _wagon &lt;&gt; null) then
		weight := _wagon.maxCargoWeight;
	elseif _wagon &lt;&gt; null then
		weight := _wagon.getMaxCargoWeight;
	elseif _wagonClass &lt;&gt; null then
		weight := _wagonClass.maxLoadWeight;
	else
		weight := 0;
	endif;
	
	if allowWagonWeights then	
		self.txtMaxWeight.visible := false;
		self.tblMaxCWeight.setup(Type_Weight, self.backColor);
		self.tblMaxCWeight.tabKey := J_key_Tab;
		self.tblMaxCWeight.visible := true;	
		self.tblMaxCWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, weight) &amp; Space &amp; measureType.shortName);
	else
		self.tblMaxCWeight.visible := false;	
		self.txtMaxWeight.visible := true;
		self.txtMaxWeight.text :=  app.convertMeasurementForDisplay(measureType.shortName, weight) &amp; " " &amp; measureType.shortName;
	endif;
	
	//Heights
	measureType := app.getDefaultMeasurementForType(Type_Height);
	if _wagon &lt;&gt; null then
		height := _wagon.getMaxCargoHeight;
	elseif _wagonClass &lt;&gt; null then
		height := _wagonClass.getMaxHeight;
	else
		height := 0;
	endif;
	self.txtMaxHeight.text := app.convertMeasurementForDisplay(measureType.shortName, height) &amp; " " &amp; measureType.shortName;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
