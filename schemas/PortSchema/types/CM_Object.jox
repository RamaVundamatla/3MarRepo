    <JadeMethod name="writeExceptionDetail" id="024e7ad1-27d6-455f-b6cd-a13bf27d0047">
        <source>writeExceptionDetail( _exc : Exception ):Integer;
/*

Purpose:			

Parameters:			Add as an additional exception handler to see what gets handled

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation	TFS 50152

*/

constants
	
vars

begin

	process.isNDLref;

	write _exc.errorCode.String &amp; ", "
		&amp; "resumable = " &amp; _exc.resumable.getYesNo &amp; ", "
		&amp; _exc.errorObject.String &amp; ", "
		&amp; "getOwner = " &amp; self.getOwnerForObject(_exc.errorObject).String;
		
	
	return Ex_Pass_Back;

epilog

	

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
