<Class name="Object">
    <JadeMethod name="cnGetInstanceId" id="102ef270-33ff-4447-b3c8-1ca2e21d1c52">
        <source>cnGetInstanceId(obj : Object) : Integer;

vars
	str, s		: String;
	posn, t, i 	: Integer;
begin
	posn := 1;
	str := getOidStringForObject(obj);
	posn := str.reversePos(".") + 1;
	return str[posn : end].Integer;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
