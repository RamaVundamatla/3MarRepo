    <JadeMethod name="getExtraInfoForHatchLid" id="992def20-35cb-4480-a284-e83216c43958">
        <updating/>
        <source>getExtraInfoForHatchLid(_hatchLid : CM_HatchLid; _dataContainer : CM_DataContainer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date			Changed By	PAR				Reason     
// -----------  ----------  --------------  ----------------------------------
// 12/10/2009	cnwmh5		PAR 21297		Add test for special for displaying
//											of hatch lid oid     
// ---------------------------------------------------------------------------
vars
	block : CM_DataContainerBlock;
begin

	if _hatchLid = null then
		return;
	endif;

	_hatchLid.getExtraInfo(_dataContainer);

	if app.isDevelopmentSystem and app.isSpecial then				// 12/10/2009 cnwmh5 #21297 - Add test for special
		block := _dataContainer.addNewBlock;
		block.addNewItem("Hatch Lid", DC_Label, 1, _hatchLid);
		block.addNewItem(_hatchLid.String, DC_Data, 1, _hatchLid);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_hatchLid" type="CM_HatchLid"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForObject" id="e2196820-8a86-4a43-8245-ded06fbbbdba">
        <updating/>
        <source>getExtraInfoForObject(_obj : Object; _dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#	Description
============================================================================
23/12/2019	jlgka1	48113	JMT - LOLO Planning Load Release Request Info
============================================================================*/
vars

	theTI				: CM_TrackedItem;
	tmpDisplayMode		: Integer;
	tmpSlotController,
	myNeighbour			: CM_SlotController;
	theVoyage			: CM_Voyage;
	amInEDIMode			: Boolean;
	aSlotRequest		: CM_SlotRequest;
	block				: CM_DataContainerBlock;
	theWLE				: CM_WorkListEntry;
	tmpSlotDefn			: CM_SlotDefn;
	tmpBay				: CM_Bay;
	ediIndex,
	numTIs				: Integer;
	cellDef 			: CM_CellDefn;
	dummyContainer 		: CM_DataContainer;
	dummyBlock 			: CM_DataContainerBlock;
	dummyItem 			: CM_DataContainerItem;
	dummyIcon 			: CM_DataContainerIcon;

begin

	if _obj = null then
		return;
	endif;

	if CM_HatchLid.hasInstance(_obj) then
		self.getExtraInfoForHatchLid(_obj.CM_HatchLid, _dataContainer);
		return;
	elseif (not CM_SlotController.hasInstance(_obj)) then
		return;
	endif;
	
	tmpSlotController := _obj.CM_SlotController;
	tmpSlotDefn := tmpSlotController.mySlotDefnVoyage;
	tmpBay		:= tmpSlotDefn.myBay;

	tmpDisplayMode := self.displayMode;
	amInEDIMode := (tmpDisplayMode = ShpDisplayMode_EDI);

	self.picCargo.picture := null;
	
	
	ediIndex := 1;
	if self.myBayDrawingController &lt;&gt; null then
		ediIndex := self.myBayDrawingController.currentEDIIndex;
	endif;
	
	if tmpSlotController &lt;&gt; null then
		theTI := tmpSlotController.getTIForDisplayMode(tmpDisplayMode, ediIndex, numTIs);
		if theTI &lt;&gt; null then
			self.picCargo.picture := self.showCargoPicture(theTI);
		endif;
	endif;

	if tmpBay &lt;&gt; null then
		tmpBay.getExtraInfo(_dataContainer);
	endif;
	
	//02 Aug 2010	NDL	Par 25127 / CCMS 1140
	if tmpSlotDefn.isOnDeck then
		cellDef := tmpBay.allCellsOnDeckByOrdinal[tmpSlotDefn.ordinalCell];
	else
		cellDef := tmpBay.allCellsUnderDeckByOrdinal[tmpSlotDefn.ordinalCell];
	endif;
	if cellDef &lt;&gt; null then
		cellDef.getExtraInfoForPlanning( _dataContainer, tmpDisplayMode );
	endif;
	if theTI &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cargo_Details) , DC_MoreInfo, 1, null);
	endif;
	//^^^ end of 25127
	
	if tmpDisplayMode = ShpDisplayMode_Actual or 
	   tmpDisplayMode = ShpDisplayMode_EDI or
	   tmpDisplayMode = ShpDisplayMode_Proposed then
		if amInEDIMode then
			if theTI &lt;&gt; null then	
				theTI.getExtraInfo(_dataContainer);
			endif;
		else
			self.getExtraInfoTI(tmpSlotController, _dataContainer);
		endif;
		
	elseif tmpDisplayMode = ShpDisplayMode_Defn then

	elseif tmpDisplayMode = ShpDisplayMode_ColCodeDisch then
		
		create dummyContainer transient;	//kludge for bish
		
		aSlotRequest := tmpSlotController.mySlotRequestDischarge;
		if aSlotRequest &lt;&gt; null then
			aSlotRequest.getExtraInfo(dummyContainer);
		endif;
		self.getExtraInfoTI(tmpSlotController, dummyContainer);
		
		if not dummyContainer.allBlocks.isEmpty then
		
			block := _dataContainer.addNewBlock;
			block.addNewItem("Colour Code Details", DC_MoreInfo, 1, null);
			foreach dummyBlock in dummyContainer.allBlocks do
				block := _dataContainer.addNewBlock;
				foreach dummyItem in dummyBlock.allItems do
					if dummyItem.isIcon then	// 03 Nov 2010	NDL	Par 26205
						dummyIcon := dummyItem.CM_DataContainerIcon;
						block.addNewIcon(dummyIcon.character, dummyIcon.getScaleFactor, dummyIcon.myObject,	dummyIcon.font, dummyIcon.colour);
					else
						block.addNewItem(dummyItem.text, dummyItem.getType, dummyItem.getScaleFactor, dummyItem.myObject);
					endif;
				endforeach;
			endforeach;
			
		endif;
	
		delete dummyContainer;

	elseif tmpDisplayMode = ShpDisplayMode_ColCodeLoad then
	
		create dummyContainer transient;	//kludge for bish
		
		aSlotRequest := tmpSlotController.mySlotRequestLoad;
		if aSlotRequest &lt;&gt; null then			
			//jlgka1 TFS 48113 --&gt;
			if aSlotRequest.myBulkReleaseReserveDetail &lt;&gt; null then
				aSlotRequest.myBulkReleaseReserveDetail.getExtraInfoRel(dummyContainer); 
			endif;
			//jlgka1 TFS 48113 &lt;--
			aSlotRequest.getExtraInfo(dummyContainer);
		endif;
		self.getExtraInfoTI(tmpSlotController, dummyContainer);
		
		if not dummyContainer.allBlocks.isEmpty then
		
			block := _dataContainer.addNewBlock;
			block.addNewItem("Colour Code Details", DC_MoreInfo, 1, null);
			foreach dummyBlock in dummyContainer.allBlocks do
				block := _dataContainer.addNewBlock;
				foreach dummyItem in dummyBlock.allItems do
					if dummyItem.isIcon then	// 03 Nov 2010	NDL	Par 26205
						dummyIcon := dummyItem.CM_DataContainerIcon;
						block.addNewIcon(dummyIcon.character, dummyIcon.getScaleFactor, dummyIcon.myObject,	dummyIcon.font, dummyIcon.colour);
					else
						block.addNewItem(dummyItem.text, dummyItem.getType, dummyItem.getScaleFactor, dummyItem.myObject);
					endif;
				endforeach;
			endforeach;
			
		endif;
		
		
		delete dummyContainer;
		
	endif;

	//02 Aug 2010	NDL	Par 25127 / CCMS 1140
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Slot_Details) , DC_MoreInfo, 1, null);
	
	// ############################
	// always show this stuff
	tmpBay.getExtraInfoForSlotDefn(tmpSlotDefn, _dataContainer);
	
	if tmpSlotController &lt;&gt; null then
		// ####### AFT SLOT
		myNeighbour := tmpSlotController.myAftSlot;
		if myNeighbour &lt;&gt; null then
			if tmpDisplayMode = ShpDisplayMode_Actual or 
			   tmpDisplayMode = ShpDisplayMode_EDI then
				theTI := myNeighbour.getTIAtIndex(REAL_MODE,1);
			elseif tmpDisplayMode = ShpDisplayMode_Proposed 	then
				theTI := myNeighbour.getTIAtIndex(PLANNING_MODE,1);
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Aft Slot", DC_Label, 1, myNeighbour);
			if theTI &lt;&gt; null  then
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(theTI) &amp; " (" &amp; theTI.id &amp;  ")",
						DC_Data, 1, myNeighbour);
			else
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(null),
						DC_Data, 1, myNeighbour);
			endif;
		endif;
		// ####### FORWARD SLOT
		myNeighbour := tmpSlotController.myForwardSlot; //;
		if myNeighbour &lt;&gt; null then
			if tmpDisplayMode = ShpDisplayMode_Actual or tmpDisplayMode = ShpDisplayMode_EDI then
				theTI := myNeighbour.getTIAtIndex(REAL_MODE,1);
			elseif tmpDisplayMode = ShpDisplayMode_Proposed 	then
				theTI := myNeighbour.getTIAtIndex(PLANNING_MODE,1);
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Forward Slot", DC_Label, 1, myNeighbour);
			
			if theTI &lt;&gt; null then
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp;  myNeighbour.getStowageId(theTI)&amp; " (" &amp; theTI.id &amp;  ")",
						DC_Data, 1, myNeighbour);
			else
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(null),
						DC_Data, 1, myNeighbour);
			endif;
		endif;
	endif;
	
	if app.isSpecial() then
	
		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay Point", DC_Label, 1, self.myBayDrawingController);
		block.addNewItem(self.myBayDrawingController.String, DC_Data, 1, self.myBayDrawingController);
		
		// ### Show All Load Requests and WLEs
		aSlotRequest := tmpSlotController.mySlotRequestLoad;
		 if aSlotRequest &lt;&gt; null then
		 	foreach aSlotRequest in tmpSlotController.allSlotRequestsLoad do
				block := _dataContainer.addNewBlock;
				block.addNewItem("Load Request", DC_Label, 1, aSlotRequest);
				block.addNewItem(aSlotRequest.String, DC_Data, 1,
						aSlotRequest);
				foreach theWLE in aSlotRequest.allWorkListEntries do
					block := _dataContainer.addNewBlock;
					block.addNewItem("Load WLE", DC_Label, 1,theWLE );
					block.addNewItem(theWLE.String, DC_Data, 1, theWLE);
				endforeach;
			endforeach;
		endif;

		// ### Show All Discharge Requests and WLEs
		aSlotRequest := tmpSlotController.mySlotRequestDischarge;
		 if aSlotRequest &lt;&gt; null then
		 	foreach aSlotRequest in tmpSlotController.allSlotRequestsDischarge do
				block := _dataContainer.addNewBlock;
				block.addNewItem("Discharge Request", DC_Label, 1, aSlotRequest);
				block.addNewItem(aSlotRequest.String, DC_Data, 1,
						aSlotRequest);
				foreach theWLE in aSlotRequest.allWorkListEntries do
					block := _dataContainer.addNewBlock;
					block.addNewItem("Discharge WLE", DC_Label, 1,theWLE );
					block.addNewItem(theWLE.String, DC_Data, 1, theWLE);
				endforeach;
			endforeach;
		endif;

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Controller", DC_Label, 1, tmpSlotController);
		block.addNewItem(tmpSlotController.String, DC_Data, 1, tmpSlotController);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay", DC_Label, 1, tmpBay);
		block.addNewItem(tmpBay.String, DC_Data, 1, tmpBay);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Definition", DC_Label, 1, tmpSlotDefn);
		block.addNewItem(tmpSlotDefn.String, DC_Data, 1, tmpSlotDefn);
		
	endif;
	
epilog

	delete dummyContainer;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoTI" id="3b7b3e30-0ee9-411e-93e7-622ecae1aa7f">
        <source>getExtraInfoTI(_slotController : CM_SlotController; _dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theTI	: CM_TrackedItem;
	numTIs,
	idx		: Integer;
	tmpSlotController : CM_SlotController;
	block : CM_DataContainerBlock;
	theTIs : CM_TIArray;
	tmpDisplayMode	: Integer;
begin

	if _slotController = null then
		return;
	endif;

	tmpDisplayMode := self.displayMode;
	
	tmpSlotController := _slotController;

	if tmpDisplayMode = ShpDisplayMode_Actual or 
	   tmpDisplayMode = ShpDisplayMode_EDI then
		theTIs := tmpSlotController.allTrackedItems;
   	elseif tmpDisplayMode = ShpDisplayMode_Proposed then
   		create theTIs transient;
		//tmpSlotController.getAllPlannedTrackedItems(theTIs, true, false);
		tmpSlotController.getProposedTIs(theTIs);	//07 Sep 2010	NDL Par 25256
		if tmpSlotController.isBulkRelease() then
			tmpSlotController.mySlotRequestLoad.getExtraInfoBulkRelease(_dataContainer);
		endif;
	endif;

	if theTIs &lt;&gt; null then
		numTIs := theTIs.size;
		if numTIs = 1 then
			theTI := theTIs.first;
			if theTI &lt;&gt; null then	
				theTI.getExtraInfo(_dataContainer);
			endif;
		else
			foreach theTI in theTIs do
				if theTI &lt;&gt; null then	
					idx := idx + 1;
					theTI.getExtraInfo(_dataContainer);
					if numTIs &lt;&gt; idx then
						block := _dataContainer.addNewBlock;
						block.addNewItem(GridPointStringMoreCargo, DC_MoreInfo, 1, null);
					endif;
				endif;
			endforeach;
		endif;
   	
   	endif;

epilog
	if tmpDisplayMode = ShpDisplayMode_Proposed then
		delete theTIs;
	endif;

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMoveMode" id="03f7369c-3295-49ca-8cc5-eec8ac2600eb">
        <source>getMoveMode(): Integer;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.displayMode = ShpDisplayMode_Actual then
		return CMUI_GridAreaStatusLine.MENU_MOVE_INSTANT_ONLY ;
	elseif self.displayMode = ShpDisplayMode_Proposed then
		return CMUI_GridAreaStatusLine.MENU_MOVE_PLAN_ONLY ;
	elseif self.workingMode = WorkMode_Plan then
		return CMUI_GridAreaStatusLine.MENU_MOVE_PLAN_ONLY ;
	else
		return inheritMethod();
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
