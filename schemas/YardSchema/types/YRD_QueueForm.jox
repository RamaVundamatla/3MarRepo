    <JadeMethod name="tblMachines_contextMenu" id="79a13218-5281-4467-b610-40bcd649e714">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Sep 2009	cnwkpd1		PAR #20551 - allow RTQ Login As for Messina
// 14 Jul 2010	cnwkpd1		PAR #24978 - rework to show both Login As for DCT in
//							customer systems as well as development
// 08 Apr 2025 	naviv1		MTN-34407 - MTN | Remove old Windows CE based Handheld and Vehicle apps from Quick Find
// ---------------------------------------------------------------------------
vars

begin
	//epr CCMS 1099 separate permission to run this
	if app.myCurrentUserCan(null,PmAdmVehicleRTLogonAs) then
		self.mnuMachineLoginAs.visible := true;
		self.mnuMachLoginAsGdansk.visible := (app.isDevelopmentSystem and app.isSpecial);
		self.mnuMachineDebugLogin.visible := app.isDevelopmentSystem;
	else
		self.mnuMachineLoginAs.visible := false;
		self.mnuMachLoginAsGdansk.visible := false;							// PAR #24978
		self.mnuMachineDebugLogin.visible := false;
	endif;

	if app.myRoot.getConfig(HideAccessHHandVMApps).Boolean then //JIRA-34407
		self.mnuMachineLoginAs.visible := false;
		self.mnuMachineDebugLogin.visible := false;
	endif;

	return self.doShowContextMenu(mnuMachine, cntrl, conwin, mouse, x, y);

end;</source>
