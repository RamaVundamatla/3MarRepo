    <JadeMethod name="getTaxRateForLineTen" id="99de6957-c169-4234-b2ba-c49a1fbba315">
        <source>getTaxRateForLineTen() : Decimal;
/*

Purpose:			Return tax rate in 10 decimal

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2025	navkc1 JIRA EPIC-34131 STORY-34815 GPHA | XML Invoice Export 10DC - Ten Decimal Place Methods

*/

vars
	taxRate 	: Decimal[23,10];
	charge		: CM_Charge;
begin
	
	taxRate := 0; // Set this so it display 10 decimal 
	
	if self.charges &lt;&gt; null then
		charge := self.charges.first();
		
		if charge &lt;&gt; null then
			taxRate := charge.getTaxRateForCharge();
