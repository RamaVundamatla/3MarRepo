    <JadeMethod name="getDensity" id="c50db61d-f213-465f-9bb9-403dada6b11f">
        <source>getDensity() : Decimal;
/*

Date		Who		Reason
25 September 2014	cnwer1	Initial creation PAR

*/

vars
	product : CM_Product;
	ct : CM_CargoType;
begin
	if self.density &lt;&gt; null then
		return self.density;
	endif;
	
	product := self.myProduct;																	// PAR #32371
	if product = null then		
		ct:=self.getMyCargoType;
		if ct &lt;&gt; null then
			product:=self.getMyCargoType.mySystemProductType;
		endif;
	endif;
	
	if product &lt;&gt; null then
		return product.getDensityValue();
	endif;
		
	return null;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="68d1ef30-1f8d-4a88-b157-d9bf22190cac">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	tiHazard : CM_TIHazard;

begin
	if _attrName = ETRow_HazardCode then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then	
			return null;
		endif;
		return tiHazard.getUndgCodesAsString(true);	//25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
	elseif _attrName = ETRow_Limited then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then
			return null;
		endif;
		return tiHazard.limitedQuantity.cnEcGetYesNo;
	elseif _attrName = ETRow_Selection then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then
			return null;
		endif;
		return tiHazard.getSelectionString;
	elseif _attrName = ETRow_HazardDescription then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then
			return null;
		endif;
		return tiHazard.description;
	elseif _attrName = ETRow_Weight then
		return app.convertMeasurementForDisplay(app.getDefaultMeasurementForType(Type_Weight).shortName, self.weightTotal);
	elseif _attrName = ETRow_Quantity then
		if self.totalQuantity &lt;&gt; null then
			return self.totalQuantity.String;
		else
			return self.quantity.String;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
