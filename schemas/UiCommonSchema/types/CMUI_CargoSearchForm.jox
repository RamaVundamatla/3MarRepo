        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoTypes_click(combobox: ComboBox input) updating;
//07 September 2009	cnwml2


vars
	
begin
	self.cmbSubCargoTypes.setOperator(self.cmbOperatorCode.myObject.CM_Operator);
	self.cmbSubCargoTypes.setCargoType(self.cmbCargoTypes.myObject.CM_CargoType);
epilog

