    <JadeWebServicesMethod name="getTrackedItemsForLane" id="f6de0ee1-34db-4895-8e98-607210730e22">
        <source>getTrackedItemsForLane(request : WS_TrackedItemsLaneRequest ): WS_TrackedItemsLaneResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2017	jlgam15	Initial creation

*/

vars
	response : WS_TrackedItemsLaneResponse;
	completedOK : Boolean;
	ti : CM_TrackedItem;
	roroArea : CM_RoRoLaneArea;
	roroLane : CM_RoRoController;
	totalScanned : Integer;
	voyage : CM_Voyage;
	proxyRoroVehicle : WS_RoroVehicleDetails;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	totalScanned := 0;
	
	roroArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RORO_LANE_AREA, request.roroAreaId].CM_RoRoLaneArea;	
	roroLane := roroArea.allLanesByLaneNumber[request.roroLaneNumber];	
	
	foreach ti in roroLane.allTrackedItems do
		if not ti.isCar then
			continue;
		endif;
		
		if(ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then
			totalScanned := totalScanned + 1;
			
			create proxyRoroVehicle transient;
			proxyRoroVehicle.setProxyFromObject(ti);
			response.roroVehicleDetailsArray.add(proxyRoroVehicle);
		endif;
	endforeach;

	response.totalScannedForLane := totalScanned;
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_TrackedItemsLaneRequest"/>
        <ReturnType type="WS_TrackedItemsLaneResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTrades" id="92e9cf62-8cc6-4605-853a-b216504ef9a1">
        <source>getTrades() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	trade : CM_Trade;
	iter : Iterator;
	wsCode : WS_Code;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	iter := app.myRoot.allTradesByDescription.createIterator;
	while iter.next(trade) do
		create wsCode transient;
		wsCode.setProxyDetails(trade, trade.code, trade.description);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTrailerTypesForCargoType" id="5350f23c-5615-4ef0-ab1d-e495d7a76458">
        <source>getTrailerTypesForCargoType(cargoTypeId : String) : WS_TrailerTypeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2016	cnwmc5	Initial creation
8 Sep 2022 	navlw1 	TFS 54709 Trailer Type list is not filtered based on cargoType

*/

vars
	response		: WS_TrailerTypeResponse;
	completedOK		: Boolean;
	cargoType		: CM_CargoType;
	trailerType		: CM_TILCType;
	wsTrailerType	: WS_TrailerType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	//if app.myPassport.hasErrors then
	//	completedOK := true;
	//	return response;
	//endif;
	
	cargoType := app.myRoot.allCargoTypesById[cargoTypeId.Integer];
	if cargoType = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, cargoTypeId, null, null);
		completedOK := true;
		return response;
	endif;
	
	if cargoType.isTrailer then
		foreach trailerType in cargoType.allTILCTypes do // 8 Sep 2022 navlw1 tfs 54709 
			if trailerType.isNotAvailableForEntry then
				continue;
			endif;
			
			create wsTrailerType transient;
			wsTrailerType.setProxyFromObject(trailerType);
			response.allTrailerTypes.add(wsTrailerType);
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoTypeId" type="String"/>
        <ReturnType type="WS_TrailerTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTrains" id="efff8d97-1da5-41e3-8b49-59046465eebe">
        <source>getTrains() :WS_TrainsResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Jan 2017	#cnwsc8	TFS 2532 - Development of new MTM Web Service application 
27 May 2019 cnwma1	Bug 44905: Rail Lander Confirm bugs                   
28 Jun 2022	jlika1 TFS 53971 - MTN - Rail Confirm App to React
*/

vars
	response		: WS_TrainsResponse;
	completedOK		: Boolean;
	train			: CM_Train;
	trainProxy	    : WS_Train;
	terminal		: CM_Terminal;
	checkDT         : Date;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal:= app.myPassport.myTerminal;
	checkDT := app.actualTimeServer().Date;  //27.05.2019 cnwma1 #44905
	checkDT := checkDT.addDays(2);	         //27.05.2019 cnwma1 #44905
	
	foreach train in terminal.allTrainsOnTerminal do
		// Populate response
		if train.isNullTrain() then
			continue;
		endif;
		
		if train.scheduledArrivalDT.Date &gt;= checkDT then     //27.05.2019 cnwma1 #44905
			continue;
		endif;
		
		create trainProxy transient;
		trainProxy.setProxyFromObject(train);
		trainProxy.setProxyWagons(train);
		response.allTrains.add(trainProxy);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_TrainsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTransactionTypes" id="a7a522ee-eadf-471e-a600-92544605d3fe">
        <source>getTransactionTypes() :WS_TransactionTypeResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Mar 2009	#cnwdz2	PAR #17554 - Development of new RIA Web Service application 
                    PAR 19198
07/09/2009	cnwrl1	PAR 20198 - Now all cargo transactions are to be allowed.
*/

vars
	response			: WS_TransactionTypeResponse;
	completedOK			: Boolean;
	ws_TransactionType	: WS_TransactionType;
	cm_TransactionType	: CM_TransactionType;
	aClass				: Class;
	iter1				: Iterator;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate response with all of the allowed transaction types
	iter1	:= app.myRoot.allTransactionTypesByDesc.createIterator;
	while iter1.next( cm_TransactionType ) do : cond_loop
		if cm_TransactionType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI then		// ie not Cargo
			continue cond_loop;
		endif;
		
		// do not include transaction types that do not have a classNameToCreate or the class is abstract.
		aClass	:= currentSchema.getClass( cm_TransactionType.classNameToCreate );
		if aClass = null or aClass.abstract then
			continue cond_loop;
		endif;
		
		create ws_TransactionType transient;
		ws_TransactionType.setFromTransactionType( cm_TransactionType.description );
		response.allTransactionTypes.add( ws_TransactionType );
	endwhile cond_loop;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete iter1;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getTransactionTypes</wsdlName>
        <ReturnType type="WS_TransactionTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTransferTerminals" id="8238f132-84e8-4764-9833-83f10c1f1f8d">
        <source>getTransferTerminals() : WS_TerminalsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2015	cnwmc5	Initial creation

*/

vars
	response		: WS_TerminalsResponse;
	wsTerminal		: WS_Terminal;
	completedOK		: Boolean;
	terminal,
	currentTerminal	: CM_Terminal;	
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	// Populate list of Terminals
	currentTerminal := app.getMyTerminalDO_NOT_USE();
	
	foreach terminal in currentTerminal.allTerminalsForRelease do
		create wsTerminal transient;
		wsTerminal.setProxyFromObject(terminal);
		response.allTerminals.add(wsTerminal);
	endforeach;
	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_TerminalsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTranshipPorts" id="171336db-1507-4349-96f1-e7519b54a3dd">
        <source>getTranshipPorts(_request : WS_TranshipPortsQueryRequest) : WS_PortsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2017	jlger1	Initial creation TFS 7750 for web portal
*/

vars
	response : WS_PortsResponse;
	completedOK : Boolean;
	voyage : CM_Voyage;
	port 	: CM_Port;
	transhipPort 	: CM_Port;
	portRotation 	: CM_PortRotation;
	ports 	: ObjectSet;
	wsPort  	: WS_Port;
begin	
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	voyage := app.myPassport.myTerminal.lookupVoyage(_request.voyageCode,null,false);
	
	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	
	port := app.myRoot.allPorts[_request.portCode];
	if port = null then
		completedOK := true;
		return response;
	endif;
	create ports transient;
	
	foreach portRotation in voyage.allPortRotations where (portRotation.allTranshipPorts.size() &gt; 0 ) do
		if not port.isActivePort then
			continue;
		endif;
		
		if (port &lt;&gt; null) then
			if portRotation.myPort &lt;&gt; port then
				continue;
			endif;
		endif;
		
		foreach transhipPort in portRotation.allTranshipPorts do
			if not ports.includes(transhipPort) then //cnwrd1 par 23033 10.3.2010
				ports.add(transhipPort);
			

				create wsPort transient;
				wsPort.setProxyFromObject(transhipPort);
				response.allPorts.add(wsPort);
			endif;
		endforeach;
	endforeach;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete ports;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_TranshipPortsQueryRequest"/>
        <ReturnType type="WS_PortsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTranslations" id="3def2f3a-1dd6-47cf-8323-b33a468ff785">
        <source>getTranslations(translationsRequest : WS_TranslationsRequest) : WS_TranslationsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	response		: WS_TranslationsResponse;
	translationRequest : WS_TranslationRequest;
	completedOK		: Boolean;
	currentLocale	: CM_Locale;
	translatedText  : XLAT_Translation;
	translation 	: String;
	translationResponse : WS_Translation;
	category : String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// if the request specifies a locale use that otherwise use the users locale
	
	if translationsRequest.localeID &lt;&gt; null then
		currentLocale:= app.myRoot.getLocale(translationsRequest.localeID, false);
	endif;
	
	// not found or specified get from user
	if currentLocale = null then
		currentLocale:= app.myCurrentLocale;
	endif;
	
	// should always have a locale
	foreach translationRequest in translationsRequest.allTranslationRequests do
		category:=translationRequest.category;
		// default to the exceptions if null
		if category = null then
			category := XLAT_Exceptions;
		endif;
		translatedText:=currentLocale.getTranslatedText(category, translationRequest.translationID);
		
		if translatedText = null then
			continue;
		endif;
		
		if translationRequest.allParams &lt;&gt; null and translationRequest.allParams.size &gt; 0 then
			translation:=translatedText.getTextWithSubstitutedParams(translationRequest.allParams);
		else
			translation:=translatedText.text;
		endif;
		
		create translationResponse transient;
		translationResponse.translationID:= translationRequest.translationID;
		translationResponse.translation:=translation;
		
		response.allTranslations.add(translationResponse);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="translationsRequest" type="WS_TranslationsRequest"/>
        <ReturnType type="WS_TranslationsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTransportModes" id="417775d9-144f-482f-af11-b3c1aaad75df">
