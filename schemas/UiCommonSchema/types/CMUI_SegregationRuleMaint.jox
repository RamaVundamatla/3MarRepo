    <JadeMethod name="doBaseFormSave" id="ce2beda3-83e5-40b7-9f7c-1e7f5d60a02a">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if (self.mode = Mode_UpdateCondition) or (self.mode = Mode_AddCondition) then
		self.doSaveCondition();
	else
		if self.mode = Mode_UpdateMatrix then
			self.doMatrixSave();
		endif;
	endif;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeRuleMode" id="4c8c3f6e-41f3-483b-ae94-350aebc8ecf3">
        <updating/>
        <source>doChangeRuleMode() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dataTblDef			: EntTableDef;
begin
	if self.grpCondEdit.enabled then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Became able to change modes whilst editing conditions.');
		return;
	endif;
	self.mySelectedCondition := null;
	dataTblDef := app.myController.getEntTableDef(ETDef_SegCondMaint);
	self.tblConditions.rows := self.tblConditions.fixedRows;
	self.tblConditions.setColumnHeadingsFromDef(ETDef_SegCondMaint, false);
	
	self.tblCondEdit.setEntTableDefByName(ETDef_SegCondMaint);
	self.tblCondEdit.adjustHeight(200);
	
	if self.ruleMode = Segregation_Type_Yard then
		self.tblConditions.setTblDataEntRowsFromView(dataTblDef, 'SegCondYard');
		self.tblCondEdit.showHideRowsByViewName('SegCondYard', CM_EntryTable.ShowHideRows, false);
	elseif self.ruleMode = Segregation_Type_Road then
		self.tblConditions.setTblDataEntRowsFromView(dataTblDef, 'SegCondRoad');
		self.tblCondEdit.showHideRowsByViewName('SegCondRoad', CM_EntryTable.ShowHideRows, false);
	elseif self.ruleMode = Segregation_Type_Rail then
		self.tblConditions.setTblDataEntRowsFromView(dataTblDef, 'SegCondRail');
		self.tblCondEdit.showHideRowsByViewName('SegCondRail', CM_EntryTable.ShowHideRows, false);
	elseif self.ruleMode = Segregation_Type_Ship then
		self.tblConditions.setTblDataEntRowsFromView(dataTblDef, 'SegCondShip');
		self.tblCondEdit.showHideRowsByViewName('SegCondShip', CM_EntryTable.ShowHideRows, false);
	elseif self.ruleMode = Segregation_Type_Warehouse then	//28 Jul 2015	NDL	Par 36660
		self.tblConditions.setTblDataEntRowsFromView(dataTblDef, 'SegCondWHouse');
		self.tblCondEdit.showHideRowsByViewName('SegCondWHouse', CM_EntryTable.ShowHideRows, false);
	endif;
	
	self.colorValueColumn := self.tblConditions.getColumnByRowName(ETRow_ConditionColour);
	self.loadConditions();
	self.loadSegregationMatrix(false);
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConditionAdd" id="a9c127c2-c8a8-4834-9de7-a6886b8c319d">
        <updating/>
        <source>doConditionAdd() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mode = self.Mode_UpdateMatrix then
		return;
	endif;
	
	self.mode := Mode_AddCondition;
	self.tblCondEdit.clearValues();
	self.tblCondEdit.setValueByName(ETRow_IsActive, true);
	self.tblCondEdit.setValueByName(ETRow_AllowedYardArea, true);
	self.tblCondEdit.setValueByName(ETRow_AllowedBay, true);
	self.tblCondEdit.setValueByName(ETRow_AllowedWagon, true);
	self.tblCondEdit.setValueByName(ETRow_AllowedVehicle, true);
	self.tblCondEdit.setValueByName(ETRow_AllowedLocation, true);	//28 Jul 2015	NDL	Par 36660
	delete self.myPxySegregationCond;
	create self.myPxySegregationCond as app.getSegCondClassForType(self.ruleMode) transient;
	
	self.doShowHideCondFrm(true);

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConditionDelete" id="42d51295-2bf9-4fcc-b635-f4dd7b27ece5">
        <updating/>
        <source>doConditionDelete() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	result					: Integer;
	
begin
	if self.mode = self.Mode_UpdateMatrix then
		return;
	endif;
	
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for delete operation');
		return;
	endif;
	
	if self.mySelectedCondition = null then
		app.msgBox('You must select a segregation condition to delete first.','Nothing selected',MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if app.msgBox('Are you sure you want to delete this segregation condition?','Are you sure?',MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteSegregationCond(self.mySelectedCondition, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.mySelectedCondition := null;
			self.doMatrixEdit(false);//refresh the matrix
			return;
		else
			result := app.showErrorWarningDialog('Segregation Condition Delete', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	
		return;
	endwhile;
	
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConditionEdit" id="bc8055f2-301d-433b-8af3-de4d744f798a">
        <updating/>
        <source>doConditionEdit() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cond			: CM_SegregationCondition;
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;



	if self.mode = self.Mode_UpdateMatrix then
		return;
	endif;
		
	if self.mySelectedCondition = null then
		app.msgBox('You must first select a segregation condition to update.','Nothing selected.', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.mode := self.Mode_UpdateCondition;
	delete self.myPxySegregationCond;
	self.myPxySegregationCond := app.createUpdateProxy(self.mySelectedCondition).CM_SegregationCondition;
	
	self.doShowHideCondFrm(true);
end;



</source>
        <access>protected</access>
