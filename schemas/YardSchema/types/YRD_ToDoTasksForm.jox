    <JadeMethod name="addToolbarControls" id="6d381610-bf76-4bd5-a2d5-c79ef853a6a6">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLegend, CMUI_Toolbar.Control_Alignment_Right);
	
	inheritMethod();
	
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	if app.getMyUser().canDo(self.myTerminal, PmAdmSelectorView) then
		frm.addButton(self.btnSelector, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAddComplete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRemoveTasks, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancel, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEnquire, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//02 Oct 2015	NDL	Par 37011
	frm.addButton(self.btnHideUnused, CMUI_Toolbar.Control_Alignment_Left);	//02 Oct 2015	NDL	Par 37011
	frm.addFrameAt(self.frmFilter, 0, CMUI_Toolbar.Control_Alignment_Left);	//02 Oct 2015	NDL	Par 37011

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="8980540e-e4fa-4f36-b921-331e0a91087b">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
