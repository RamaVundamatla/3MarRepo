    <JadeMethod name="doClickCalendarSave" id="1ab259be-7ce1-4f80-b982-60763ef37d8f">
        <updating/>
        <source>doClickCalendarSave() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	code : String;
	description : String;
	dayType : CM_DayType;
	hasStartTime : Boolean;
	hasEndTime : Boolean;
	hookCode : CM_HookCode;
	hookLink : CM_HookLink;
	selectedTerms : CM_TerminalByCodeDict;
	newCalendar : CM_Calendar;
	theReturn : Integer;
	
	user : CM_User;
	userTerminal : CM_UserTerminal;
	terminal : CM_Terminal;
	userVisibleTerminals : CM_TerminalSet;

begin

	code := txtCode.text;
	description := txtDescription.text;
	dayType := cmbDayType.listObject.CM_DayType;
	hasStartTime := chkHasStart.value;
	hasEndTime := chkHasEnd.value;
	
	hookCode := self.myProxyCalendar.myHookCode;
	hookLink := null;
	create selectedTerms transient;
	if not tblTerminal.allSelectedObjects.isEmpty then
		tblTerminal.allSelectedObjects.copy(selectedTerms);
	endif;
	
	//get a collection of the terms the user could maintain.
	create userVisibleTerminals transient;
	user := app.getMyUser();
	foreach userTerminal in user.allUserTerminals do
		terminal := userTerminal.getMyTerminal;
		userVisibleTerminals.add(terminal);
	endforeach; 
	
	// add in the ones they couldn't see that were already there, we don't want to kill someone elses selection by accident.
	foreach terminal in myProxyCalendar.allTerminals do
		if not userVisibleTerminals.includes(terminal) then
			selectedTerms.add(terminal);
		endif;
	endforeach;
	
	myProxyCalendar.setProxy(	code,	// _code : String;
								description,	// _decription : String;
								hasEndTime,	//_hasEndTime : Boolean;
								hasStartTime,	//_hasTime : Boolean;
								dayType,	//_myDayType : CM_DayType;
								hookCode,	//_myHookCode : CM_HookCode;
								hookLink,	//_myHookLink : CM_HookLink
								selectedTerms	//_allTerminals : CM_TerminalByCodeDict
								);
								
	if self.myRealCalendar = null then
		// creating a new one.
		while true do
			app.myTrxCA.trxCreateCalendar(myProxyCalendar, newCalendar, app.myPassport, false);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				self.populateCombos();
				self.cmbCalendar.listIndex := self.cmbCalendar.findObject( newCalendar );
				self.selectCalendar( newCalendar );
				
				self.btnNewCalendar.enabled := true;
				self.cmbCalendar.enabled := true;
				
				break;
				
			else
				theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			
			break;
			
		endwhile;
	
	else
		// updating an existing one.
		while true do
			app.myTrxUA.trxUpdateCalendar(myProxyCalendar, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				self.selectCalendar( self.myRealCalendar );
				break;
				
			else
				theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			
			break;
			
		endwhile;
	
	endif;
	
	
	
epilog

	delete userVisibleTerminals;

end;</source>
    </JadeMethod>
