    <JadeMethod name="resetTrxType" id="b7fb3d38-5018-4062-9715-8fbfa9307f35">
        <source>resetTrxType(_constant:Constant; _passport:CM_Passport);
// ---------------------------------------------------------------------------
// Created:		28 November 2005 by cnwdad1
//
// Purpose:     This is used as a "callBack" method from "resetTrxTypes".
//
// Parameters:	_constant - A reference to the Transaction Type global constant,
//					in the TransactionTypeConstant category.
//				_passport - A reference to the user passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyTrxTypeObj	: CM_TransactionType;
	realTrxTypeObj	: CM_TransactionType;
	
begin

	if _constant.name = 'TRANS_TYPE_MAX' or
	   _constant.valueAsInteger() &gt; TRANS_TYPE_MAX or
	   _constant.valueAsInteger &lt;= TRANS_TYPE_NULL then
	   	return;
	endif;
        write _constant.name;

        
    
	realTrxTypeObj	:=	self.allTransactionTypes[_constant.valueAsInteger()];
	
	if realTrxTypeObj = null then
		// Create a new object.
		create proxyTrxTypeObj transient;
		proxyTrxTypeObj.setProxyFromConstant(_constant, self);
		app.myTrxCA.trxCreateTransactionTypeSystem(proxyTrxTypeObj, realTrxTypeObj, app.myPassport);
	else
		// Update existing object.
		proxyTrxTypeObj	:=	app.createUpdateProxy(realTrxTypeObj).CM_TransactionType;
		proxyTrxTypeObj.setProxyFromConstant(_constant, self);
		app.myTrxUA.trxUpdateTransactionTypeSystem(proxyTrxTypeObj, app.myPassport);
	endif;

epilog
	delete proxyTrxTypeObj;
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
