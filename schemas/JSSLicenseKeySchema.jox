    <GlobalConstant name="JSS_EX_00017" id="4ae88076-62a7-4d63-a312-483a2977427f">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00017</source>
        <type name="Integer"/>
        <text>The License Key for %1/%2 expired on %3.</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00073" id="59a0d1d2-036d-4b2c-b818-7f614fb23ea7">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00073</source>
        <type name="Integer"/>
        <text>Invalid checksum for license key.</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00074" id="a859d8b0-f9b0-4df5-8ce0-c838fd4c758f">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00074</source>
        <type name="Integer"/>
        <text>The Customer name (%1) is not valid for this license.</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00075" id="68eb3888-4118-4f4e-b5e5-73511edc06d2">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00075</source>
        <type name="Integer"/>
        <text>The license key supplied expired on %1.</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00076" id="393c1d1f-954b-4c32-b861-fab2eccadf97">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00076</source>
        <type name="Integer"/>
        <text>Only one instance of the License Key root object is allowed.</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00077" id="5b57455f-6484-46ec-a9e8-83e84f5d1a18">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00077</source>
        <type name="Integer"/>
        <text>A License Key already exists for this Customer/Product name: %1/%2</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00079" id="eacedc57-6b9c-4024-b27c-3cd47b9a33fa">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00079</source>
        <type name="Integer"/>
        <text>No License Key exists for this Customer/Product name: %1/%2</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00080" id="18d09f26-ad2d-47d9-8170-2039628821cb">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00080</source>
        <type name="Integer"/>
        <text>The License Key details to delete do not exist (%1/%2).</text>
    </GlobalConstant>
    <GlobalConstant name="JSS_EX_00081" id="aba7e392-3384-499f-bb6a-ea2c05eb1393">
        <category name="JSS_EX_LICENSE_KEY"/>
        <source>00081</source>
        <type name="Integer"/>
        <text>The bit mask index (%1) is larger than the maximum possible index (%2).</text>
    </GlobalConstant>
