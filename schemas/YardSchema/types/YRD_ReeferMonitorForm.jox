    <JadeMethod name="tblReadings_displayRow" id="28b399d4-e758-45d9-8984-2f61f28d5152">
        <controlMethod name="CM_DataTable::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReadings_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:		05 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 11/12/2009	cnwdap1		CCMS MES 1007 Temperature readings now connected to reefer properties, not containers (any TI can be a reefer)
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added ventilation and humidity reading classes
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars
	tempReading		: CM_TempReading;
	ti 				: CM_TrackedItem;
	tCommodity		: CM_Commodity;
	tempMin,tempMax	: Real;
	humidReading	: CM_HumidReading;				// PAR #35874
	ventReading		: CM_VentReading;				// PAR #35874
	co2Reading		: CM_CO2Reading;		// MTN-36569
	o2Reading		: CM_O2Reading;			// MTN-36569
	
begin
	if obj.isKindOf(CM_TempReading) then
		tempReading := obj.CM_TempReading;
		
		if not tempReading.isValid then
			return null;
		endif;
		//ti := tempReading.myContainer;
		ti := tempReading.myReeferProperties.myParent.CM_TrackedItem;
		
		if ti &lt;&gt; null then
			tCommodity := app.myRoot.allCommodities[ti.commodity];
			
			if tCommodity &lt;&gt; null then
				tempMin := tCommodity.minTemp;
				tempMax := tCommodity.maxTemp;
				if tempReading.isDefrostTemp then
					table.accessRow(theRow).backColor := ColourVioletLight;//Aug 2007 cnwrs1 CCMS1551
				elseif tempReading.tempGreaterThan(tempMax) then
					table.accessRow(theRow).backColor := LightRed;
				elseif tempReading.tempLessThan(tempMin) then	
					table.accessRow(theRow).backColor := LightBlue;
				else
					table.accessRow(theRow).backColor := White;
				endif;

			endif;

		endif;
				
		return self.tblReadingsDisplayRow(tempReading);
	
	elseif obj.isKindOf(CM_HumidReading) then				// PAR #35874
		humidReading := obj.CM_HumidReading;				// PAR #35874
		table.accessRow(theRow).backColor := White;			// PAR #35874
		return self.tblReadingsDisplayRow(humidReading);	// PAR #35874
															// PAR #35874
	elseif obj.isKindOf(CM_VentReading) then				// PAR #35874
		ventReading := obj.CM_VentReading;					// PAR #35874
		table.accessRow(theRow).backColor := White;			// PAR #35874
		return self.tblReadingsDisplayRow(ventReading);		// PAR #35874
		
	// MTN-36569 CO2 and O2 readings
	elseif obj.isKindOf(CM_CO2Reading) then
		co2Reading := obj.CM_CO2Reading;
		table.accessRow(theRow).backColor := White;
		return self.tblReadingsDisplayRow(co2Reading);
	elseif obj.isKindOf(CM_O2Reading) then
		o2Reading := obj.CM_O2Reading;
		table.accessRow(theRow).backColor := White;
		return self.tblReadingsDisplayRow(o2Reading);
	// MTN-36569 end
	
	else
		return "Invalid object (" &amp; obj.class.name &amp; ")";
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
