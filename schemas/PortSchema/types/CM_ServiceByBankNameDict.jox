<CollClass name="CM_ServiceByBankNameDict" id="884f71d6-bf07-427d-8d23-ee8ead8219f3">
    <loadFactor>66</loadFactor>
    <memberType name="CM_Service"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_ServiceObject::bank"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_ServiceObject::name"/>
    </MemberKey>
    <JadeMethod name="getServiceList" id="84d67176-c074-417e-a75d-240920939519">
        <source>getServiceList() : String;
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
*/

vars
	calc : CM_Service;
	tmpStr : String;
begin
	foreach calc in self  discreteLock do
		if tmpStr = null then
			tmpStr := "'" &amp; calc.name &amp; "'";
		else
			tmpStr := tmpStr &amp; ", '" &amp; calc.name &amp; "'";
			endif;
	endforeach;
 
 
	return tmpStr &amp; ".";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
