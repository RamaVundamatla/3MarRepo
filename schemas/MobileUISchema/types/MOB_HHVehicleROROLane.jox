    <JadeMethod name="doCompleteBtn" id="d204e6be-2ae3-4972-921f-013653190474">
        <source>doCompleteBtn():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	roroLane : CM_RoRoController;
	swapAreaLC : CM_LocationsController;
	msg : String;
	matches : Boolean;
	ti : CM_TrackedItem;
	rowIndex : Integer;
	reversedArray : CM_TIArray;	//25 May 2016	NDL	TFS 1593
	theReturn : Integer;

begin

	foreach rowIndex in 1 to self.tblVehicles.rows do
		ti := self.tblVehicles.accessRow(rowIndex).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null then
			if not self.allConfirmedArray.includes( ti ) then
				msg := app.getErrorString3( Been_scann_not_confi_pleas_fir, ti.id, self.btnReset.caption, self.btnConfirm.caption);
				return false;
			endif;
		endif;
	endforeach;

	roroLane := self.myMobileGenericAgent.myLocationsController.CM_RoRoController;

	if roroLane = null then
		msg := app.getErrorString(NO_Location_selected);
		return false;
	endif;
	
	swapAreaLC := self.myMobileGenericAgent.myTerminalArea.swapStack.getLocationsController;
	if swapAreaLC = null then
		msg := app.getErrorString(Cargo_locat_swap_stack_found_a);
		return false;
	endif;
	
	if self.allConfirmedArray.isEmpty and not roroLane.allTrackedItems.isEmpty then
		msg := app.getErrorString1( Cargo_select_move_existi_items, swapAreaLC.getFullId );
		if self.msgBox(msg , app.getErrorString(Continue), MsgBox_Yes_No, false) = MsgBox_Return_No then
			msg := null;
			return false;
		endif;
		
	elseif self.allConfirmedArray.size &lt; roroLane.allTrackedItems.size then
		matches := false;
		
	else
		matches := true;
		foreach ti in roroLane.allTrackedItems do
			if not self.allConfirmedArray.includes(ti) then
				matches := false;
				break;
			endif;
		endforeach;

	endif;
	
	if not matches then
		msg := app.getErrorString2( Some_items_curre_recor_not_lis, roroLane.id, swapAreaLC.getFullId );
		if self.msgBox(msg , app.getErrorString(Continue), MsgBox_Yes_No, false) = MsgBox_Return_No then
			msg := null;
			return false;
		endif;
		msg := null;
	endif;
	
	//OK so we have either accounted for everything, or the the user is happy to move anything else to the IC area.
	if not self.myMobileGenericAgent.forward then
		create reversedArray transient;
		foreach ti in self.allConfirmedArray reversed do
			reversedArray.add(ti);
		endforeach;
	endif;
	
	while true do
	
		if self.myMobileGenericAgent.forward then
			app.myTrxUA.trxUpdateRoRoLaneCargo(roroLane, swapAreaLC, self.allConfirmedArray, app.myPassport );
		else	//25 May 2016	NDL	TFS 1593
			app.myTrxUA.trxUpdateRoRoLaneCargo(roroLane, swapAreaLC, reversedArray, app.myPassport );
		endif;
		
		//tfs 4907 24/7/17 
		if app.myPassport.trxCompletedOK then
			self.setVoyageCounts();
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
	
	endwhile;

	return false;

epilog

	if msg &lt;&gt; null then
		self.msgBox(msg , app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	delete reversedArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doConfirmBtn" id="0a9533a4-04a4-48ee-b698-86b7f01ef47e">
        <updating/>
        <source>doConfirmBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	index : Integer;
	ti : CM_TrackedItem;

begin
	//clear the array and rebuild it
	self.allConfirmedArray.clear();
	
	foreach index in 1 to self.tblVehicles.rows do
		ti := self.tblVehicles.accessRow(index).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null then
			if self.allConfirmedArray.includes(ti) then
				if self.myMobileGenericAgent.forward then
					self.allConfirmedArray.remove(ti); // from its old position
					self.allConfirmedArray.add(ti); // add into its latest position
				else
					//don't add it again this was the old position.
					continue;
				endif;
			else
				self.allConfirmedArray.add(ti);
			endif;
		endif;
	endforeach;
	
	self.setVoyageCounts();	//13 Sep 2016	NDL	TFS 2246 / 2680
	
	self.setMyTrackedItem(null);
	self.txtCargoId_lostFocus(self.txtCargoId);
	self.txtCargoId.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDamageBtn" id="19b1a3b9-74d2-4c41-8245-ac86b3c8e500">
        <updating/>
        <source>doDamageBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.btnDamage.caption = app.getErrorString(Cancel) then
		self.btnLabel.caption := app.getErrorString(Heading_Label);
		self.btnDamage.caption := app.getErrorString(Damage);
		self.btnOne.enabled := true;
		self.btnConfirm.enabled := self.myTrackedItem &lt;&gt; null;
		
		self.doDisableDamageTable();
			
		return;
	endif;
	

	//need to add the table and the label and resize...
	if not self.tblDamage.visible then
		self.tblDamage.visible := true;
		self.lblNoDamage.visible := false;
	endif;
	
	self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
	self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
	
	if not self.myTrackedItem.allDamageInstances.isEmpty then
		self.tblDamage.addNewRow();
	endif;
	
	self.btnOne.enabled := false; // Disable the Complete button.  
	self.btnLabel.caption := app.getErrorString(Save);
	self.btnDamage.caption := app.getErrorString(Cancel);
	self.btnConfirm.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisableDamageTable" id="c27e7d6c-2232-4e94-a2ee-18df4eec8f79">
        <updating/>
        <source>doDisableDamageTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	rowIndex : Integer;
	colIndex : Integer;

begin

	foreach rowIndex in 2 to self.tblDamage.rows do
		foreach colIndex in 1 to self.tblDamage.columns do
			self.tblDamage.accessCell(rowIndex,colIndex).enabled := false;
		endforeach;
	endforeach;
	
	self.doResizeControls(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLabelBtn" id="73dbaf34-bd7e-4070-8613-1381d30a8d2b">
        <updating/>
        <source>doLabelBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin
	if self.myTrackedItem = null then
		return;
	endif;

	if self.btnLabel.caption = app.getErrorString(Save) then
		if self.doSaveDamage() then
			self.btnLabel.caption := app.getErrorString(Heading_Label);
			self.btnDamage.caption := app.getErrorString(Damage);
			self.btnOne.enabled := true;
			self.btnConfirm.enabled := true;
			
			if self.myTrackedItem.allDamageInstances.isEmpty then
				self.lblNoDamage.visible := true;
				self.tblDamage.visible := false;
			else
				self.lblNoDamage.visible := false;
				self.tblDamage.visible := true;
				self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
				self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
				self.doDisableDamageTable();
			endif;
			
		endif;
		
	else
		self.doPrintCargoLabel( self.myTrackedItem );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResetBtn" id="67a4a33a-9334-486d-b866-e020f0220897">
        <updating/>
        <source>doResetBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	self.setMyTrackedItem(null);
	self.txtCargoId_lostFocus(self.txtCargoId);
	self.txtCargoId.setFocus();
	
	self.setVoyageCounts();	//13 Sep 2016	NDL	TFS 2246 / 2680
	
	self.doResizeControls(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="859ec94d-c7d2-424c-8c74-9b5d09002ca0">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2016	cnwndl1	Initial creation		TFS 1593

*/

vars

	top : Real;
	stdHeight : Real;
	stdWidth : Real;
	tabIndex : Integer;
	tableHeight : Real;
	tableBottom: Real;
	btnWidth : Real;
	btnLeft : Real;
	damCount : Integer;
	maxHeightUnits : Integer;
	idealDamUnits : Integer;
	setUnits : Integer;
	cusWidth : Real;
	cusHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	self.resizeCmdButtons();
	
	top := self.resizedMargin;
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move(self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
						 
	top := top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move(self.resizedMargin,
						 top,
						 stdWidth / 2,
						 stdHeight );
						 
	if _initialSetup then
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
		self.lblCargoDesc.visible := true;
	endif;
	self.lblCargoDesc.move( (self.resizedMargin * 2 ) + stdWidth / 2,
							 top,
							 stdWidth / 2,
							 stdHeight );
						 
	top := top + self.lblCargoDesc.height + self.resizedMargin;
	tableHeight := stdHeight * 3; //default height
	if self.myTrackedItem &lt;&gt; null then
		damCount := self.myTrackedItem.allDamageInstances.size;
		if damCount &gt; 1 then
			maxHeightUnits := (self.clientHeight / stdHeight).Integer;
			idealDamUnits := damCount + 3; 
			setUnits := idealDamUnits;
			while maxHeightUnits - setUnits &lt; 9 do
				setUnits := setUnits - 1;
			endwhile;
			if setUnits &gt; 3 then
				tableHeight := stdHeight * setUnits;
			endif;
		endif;
	endif;
	if _initialSetup then
		self.tblDamage.visible := true;
		self.tblDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.tblDamage.move(	self.resizedMargin,
							top,
							stdWidth,
							tableHeight );
							
	if _initialSetup then
		self.lblNoDamage.visible := false;
		self.lblNoDamage.enabled := false;
		self.lblNoDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblNoDamage.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
	
	top := top + self.tblDamage.height + self.resizedMargin;
	btnWidth := self.btnOne.width;
	while true do
		if (( btnWidth * 4 ) + ( self.resizedMargin * 5 )) &gt; clientWidth then
			btnWidth := btnWidth - 1;
			continue;
		endif;
		break;
	endwhile;
	
	if _initialSetup then
		self.btnDamage.visible := true;
		self.btnDamage.enabled := false;
		self.btnDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnDamage.move(	self.resizedMargin,
							top,
							btnWidth,
							self.btnTwo.height ); 
						
	btnLeft := btnWidth + ( self.resizedMargin * 2);
	if _initialSetup then
		self.btnLabel.visible := true;
		self.btnLabel.enabled := false;
		self.btnLabel.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnLabel.move(	btnLeft,
						top,
						btnWidth,
						self.btnOne.height );
	
	btnLeft := ( btnWidth * 2 ) + ( self.resizedMargin * 3);
	if _initialSetup then
		self.btnReset.visible := true;
		self.btnReset.enabled := false;
		self.btnReset.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnReset.move(	btnLeft,
							top,
							btnWidth,
							self.btnOne.height );
							
	btnLeft := ( btnWidth * 3 ) + ( self.resizedMargin * 4);
	if _initialSetup then
		self.btnConfirm.visible := true;
		self.btnConfirm.enabled := false;
		self.btnConfirm.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnConfirm.move(	btnLeft,
							top,
							btnWidth,
							self.btnOne.height );
	
	top := top + self.btnDamage.height + self.resizedMargin;
	tableBottom := self.clientHeight - (self.btnOne.height + ( self.resizedMargin * 2 ));
	tableHeight := tableBottom - top;
	if _initialSetup then
		self.tblVehicles.setAndIncrementTabIndex( tabIndex );
		self.tblVehicles.visible := true;
	endif;
	self.tblVehicles.move(self.resizedMargin,
						 top,
						 stdWidth,
						 tableHeight );
						 
	top := top + self.tblVehicles.height + self.resizedMargin;
	cusWidth := self.btnTwo.left - self.resizedMargin - 1;
	cusHeight := self.btnTwo.height;
	if _initialSetup then
		self.lblShipCounts.setAndIncrementTabIndex( tabIndex );
		self.lblShipCounts.visible := true;
	endif;
	self.lblShipCounts.move(self.resizedMargin,
						 top,
						 cusWidth,
						 cusHeight );					
						

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDamage" id="e8c4c87b-6e9a-4137-9120-455cf38ca3bc">
        <source>doSaveDamage():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation

*/

vars

	errors : String;
	sessionAgent : CM_MobileAgent;
	damageInterface : IF_DamageDetails;
	damageLC : String; // The location the cargo was in when the damage was noted.
	damageInstance : CM_DamageInstance;

begin

	damageLC := self.myMobileGenericAgent.myLocationsController.CM_RoRoController.getFullId;

	app.mousePointer := self.MousePointer_HourGlass;
	sessionAgent := self.getSessionAgent();
	sessionAgent.setMyProxy( self.myTrackedItem );
	
	damageInterface:=sessionAgent.getMyProxyObject.IF_DamageDetails;
	
	self.tblDamage.setProxyFromTable( damageInterface, errors, damageLC );
	
	if sessionAgent.updateDamages(damageInterface, null, 3) then
		return true;
	endif;
	
	if errors &lt;&gt; null then
		self.msgBox(errors,app.getErrorString(Error),MsgBox_OK_Only, false);
	endif; 
	
	return false;
	
epilog

	sessionAgent.setMyProxy(null);
	app.mousePointer := self.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="ad2d79bb-e8b1-4f36-81ac-e035d571efbf">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin
	if doCompleteBtn() then
		self.myMobileGenericAgent.setMyLocationsController(null);
		self.myMobileGenericAgent.setForward( true );
	
		self.doBackButtonClick();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="9c3a7854-32a2-4ace-b984-032e8bba10b6">
        <updating/>
