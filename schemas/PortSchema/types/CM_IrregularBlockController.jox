    <JadeMethod name="getCurrentCapacity" id="b717ff22-ea5c-4e42-afee-3712872eb1c6">
        <source>getCurrentCapacity() : Integer;
/*
Purpose:			
Date		Who		Reason
04 September 2013	cnwab1	Initial creation
*/

vars

	tot : Integer;
	shelf : CM_RackShelfController;
	
	minMax : CM_TerminalAreaProductMinMax;
	footPrint : Decimal [16,4];
	
begin

	//22 Jun 2016	NDL	TFS 1752
	// capacity is now relative to cargo type of the first item in the area, if there is one, or alternatively
	// if the area is empty then the first cargotype that a 'CM_TerminalAreaProductMinMax' is found for.
	if self.isGroundLocation then
		minMax := self.getMinMaxForFirstTI();
		if minMax &lt;&gt; null and minMax.maxQuantity &gt; 0 then
			footPrint := self.getFootPrintInMetres();
			tot := (minMax.maxQuantity * footPrint).truncated;
			if tot &gt; 0 then
				return tot;
			endif;
		endif;
	endif;
			
	if self.isRack then
		foreach shelf in self.allSubLocations do
			tot := tot + shelf.getCurrentCapacity();
		endforeach;
	else	//02 May 2014	NDL	Par 33936
		tot := self.maxCapacity;
		if tot &lt; 1 then
			tot := self.defaultCapacity;
		endif;
	endif;
	
	return tot;
	
epilog


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentCapacityAsStr" id="3d42d880-4cb9-4205-941e-5216c04d29bc">
        <source>getCurrentCapacityAsStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	currentCap : String;
	shelf : CM_RackShelfController;
	minMax : CM_TerminalAreaProductMinMax;
	footPrint : Decimal [16,4];
	tot : Integer;
	
begin

	if self.isRack then
		foreach shelf in self.allSubLocations do
			if currentCap &lt;&gt; null then
				currentCap := currentCap &amp; ", ";
			endif;
			currentCap := currentCap &amp; shelf.getCurrentCapacity().asStringJMT;
		endforeach;
		
	else	//Only for Ground locations
		minMax := self.getMinMaxForFirstTI();
		if minMax &lt;&gt; null and minMax.maxQuantity &gt; 0 then
			footPrint := self.getFootPrintInMetres();
			tot := (minMax.maxQuantity * footPrint).truncated;
			if tot &gt; 0 then
				currentCap := tot.asStringJMT;
			endif;
		endif;
	
	endif;
	
	if currentCap &lt;&gt; null then
		return currentCap;
	endif;

	tot := self.maxCapacity;	//YA capacity
	if tot &lt; 1 then
		tot := self.defaultCapacity;	// default capacity
	endif;
	currentCap := tot.asStringJMT;
	
	return currentCap;
	
epilog


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultCapacityAsStr" id="3f02bf26-7c03-4617-96e6-ac93ab6edd53">
        <source>getDefaultCapacityAsStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	defCapacity : String;
	subLoc : CM_RackShelfController;
	
begin

	if self.allSubLocations.isEmpty then
		defCapacity := self.defaultCapacity.asStringJMT;
	
	else
		foreach subLoc in self.allSubLocations do
			if defCapacity &lt;&gt; null then
				defCapacity := defCapacity &amp; ", ";
			endif;
			defCapacity := defCapacity &amp; subLoc.defaultCapacity.asStringJMT;
		endforeach;
	
	endif;
	
	return defCapacity;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultCapacityForTADef" id="d7c55d4e-d2b3-4e2f-ade2-f4fa5f7b36bb">
        <source>getDefaultCapacityForTADef():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	defCapacity : Integer;
	subLoc : CM_RackShelfController;
	
begin

	if self.allSubLocations.isEmpty then
		defCapacity := self.defaultCapacity;
	
	else
		foreach subLoc in self.allSubLocations do
			defCapacity := defCapacity + subLoc.getDefaultCapacityForTADef;
		endforeach;
	
	endif;
	
	return defCapacity;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3b261198-4f00-4a96-9aa5-ee7e1265a03a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
04 January 2024	navab1	CR 58499 TASK 61459
*/

vars

begin
	if _attrName = ETRow_Location then
		return self.getFullId();
	elseif _attrName = ETRow_RailTransferArea then
		if self.myAssociatedInterchangeArea &lt;&gt; null then
			return self.myAssociatedInterchangeArea.id;
		endif;
		return "";
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForDefnList" id="b95e1ba7-a0a1-4bc4-9adc-120425c226c2">
        <source>getDisplayStringForDefnList() : String;
/*
Purpose:			
Date		Who		Reason
19 September 2013	cnwab1	Initial creation
*/

vars
	ica, tmp : String;
begin
	if self.myAssociatedInterchangeArea &lt;&gt; null then
		ica := self.myAssociatedInterchangeArea.id;
	endif;
	
	tmp := self.ident &amp; Tab &amp; self.defaultCapacity.String
						&amp; Tab &amp; self.getYACapacity.asStringJMT	//22 Jul 2020	NDL	TFS 49775
						&amp; Tab &amp; app.getWeightForDefaultDisplay(self.maximumWeight)
						&amp; Tab &amp; ica;
	
	return tmp;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="b0979fa5-26e9-4d1f-94ed-549921872cb9">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*
Purpose:			Add extra block details to the passed in Data Container
Parameters:			Data Container to be populated
Return Value:		None

Date		Who		Reason
29 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
09 Jul 2008	cnwkpd1	PAR #17407 - Don't display Totals if the TA is not "Stock Controlled"
07/11/2012	cnwcs5	par 30475 - remove references to location restrictions - they are obsolete
*/

vars

	blockObj			: CM_DataContainerBlock;
	passportObj			: CM_Passport;
	allBlocksArray		: CM_DataContainerBlockArray;
	quantityTotal		: Integer;
	qdQuantityTotal		: Integer;
	pdQuantityTotal		: Integer;
	idx, idxSt, idxEnd : Integer;
	cargoSort, lastCargoSort : String;
	sohCargoS : StringArray;
	sohVolumeS			: DecimalArray;
	sohWeightS			: DecimalArray;
	sohItemS : IntegerArray;
	sohQuantityS : IntegerArray;
	totVolume			: Decimal[16,4];
	totWeight			: Decimal[14,4];
	failedDAC  :CM_DataAccessController;
	sortTIs : CM_TIByCargoTypeDict;
	allTIs : CM_TIArray;
	ti : CM_TrackedItem;
begin

	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Location), DC_Label, 1, null);
	blockObj.addNewItem(self.getFullId(), DC_Data, 1, null);

	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Status), DC_Label, 1, null);
	blockObj.addNewItem(self.getStatusDescription(), DC_Data, 1, null);
	
	
	//22 Jul 2020	NDL	TFS 49775
	if self.isGroundLocation then
		blockObj := _dataContainer.addNewBlock;
		blockObj.addNewItem(app.getErrorString(Cargo_type_capacities), DC_Label, 1, null);
		if self.myTerminalArea.allProductMinMax.isEmpty then
			blockObj.addNewItem( app.getErrorString(None), DC_Data, 1, null);
		else
			blockObj.addNewItem(self.myTerminalArea.allProductMinMax.size.asStringJMT, DC_Data, 1, null);
		endif;
	endif;

	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(Current_capacity), DC_Label, 1, null);	//22 Jul 2020	NDL	TFS 49775
	blockObj.addNewItem(self.getCurrentCapacityAsStr, DC_Data, 1, null);
	
	//22 Jul 2020	NDL	TFS 49775
	blockObj := _dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(Default_max_capcity), DC_Label, 1, null);
	blockObj.addNewItem(self.getDefaultCapacityAsStr, DC_Data, 1, null);
	
	//22 Jul 2020	NDL	TFS 49775
	blockObj := _dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(Maximum_Weight), DC_Label, 1, null);
	blockObj.addNewItem(self.getMaxWeightDisplayAsStr.asStringJMT, DC_Data, 1, null);
	
	//22 Jul 2020	NDL	TFS 49775
	blockObj := _dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(YAMaxCapacity), DC_Label, 1, null);
	blockObj.addNewItem(self.getYACapacityStr, DC_Data, 1, null);

	create allBlocksArray transient;
	
	passportObj	:=	app.myPassport;
	
	if (not self.canUserAccessSelf(null, failedDAC, passportObj)) then
		blockObj	:=	_dataContainer.addNewBlock;
		blockObj.addNewItem(app.getErrorString(CM_You_Do_Not_Have_Access), DC_Header, 1, null);
		return;
	endif;
		
	create sortTIs transient;
	create allTIs transient;
	create sohVolumeS transient; sohVolumeS[10] := 0;
	create sohWeightS transient; sohWeightS[10] := 0;
	create sohCargoS transient; sohCargoS[10] := "";
	create sohItemS transient; sohItemS[10] := 0;
	create sohQuantityS transient; sohQuantityS[10] := 0;
	
	self.getTIs(allTIs,REAL_MODE, true);
	allTIs.copy(sortTIs);
	self.getTotalsByMode(REAL_MODE, totVolume, totWeight, quantityTotal);
	qdQuantityTotal := self.getNumTIs(QUEUE_MODE);
	pdQuantityTotal := self.getNumTIs(PLANNING_MODE);
	idx := 1;
	cargoSort := "";

	
	foreach ti in sortTIs discreteLock do
		//epr par 35905 26/3/15
		cargoSort :=ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoS.size &lt; idx then
			sohCargoS.add(null);
			sohVolumeS.add(null);
			sohWeightS.add(null);
			sohQuantityS.add(null);
			sohItemS.add(null);
		endif;
		
		if sohCargoS[idx] = "" then
			sohCargoS[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeS[idx] := sohVolumeS[idx] + ti.totalVolume;
		sohWeightS[idx] := sohWeightS[idx] + ti.totalWeight;
		sohQuantityS[idx] := sohQuantityS[idx] + ti.totalQuantity;
		sohItemS[idx] := sohItemS[idx] + 1;
	endforeach;	
	
	if sohCargoS.size &gt; 0 then
		idxEnd := sohCargoS.size;
		idxSt := 1;
		foreach idx  in idxSt to idxEnd discreteLock do
			if sohCargoS[idx] = "" then
				break;
			endif;
			create blockObj transient;
			allBlocksArray.add(blockObj);
			blockObj.addNewItem(sohCargoS[idx], DC_Data, 1, null);
			blockObj.addNewItem(sohQuantityS[idx].String, DC_Data, 1, null); // ACTUAL
			blockObj.addNewItem("-", DC_Data, 1, null); // PLANNED
			blockObj.addNewItem("-", DC_Data, 1, null); // QUEUED
			blockObj.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeS[idx]), DC_Data, 1, null);
			blockObj.addNewItem(app.getWeightForDefaultDisplay(sohWeightS[idx]), DC_Data, 1, null);		

		endforeach;
	endif;
		
	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem("", DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(Actual), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(Queued), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(Planned), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	
	blockObj	:=	_dataContainer.addNewBlock();
	blockObj.addNewItem(app.getErrorString(Total).toUpper &amp; "   ", DC_Data, 1, null);
	blockObj.addNewItem(quantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	blockObj.addNewItem(qdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	blockObj.addNewItem(pdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	blockObj.addNewItem(app.getVolumeForDefaultDisplay(totVolume), DC_Data, 1, null);
	blockObj.addNewItem(app.getWeightForDefaultDisplay(totWeight), DC_Data, 1, null);
	
	if app.isSpecial() then
	
	blockObj	:=	_dataContainer.addNewBlock();
	blockObj.addNewItem("GC Controller", DC_MoreInfo, 2, self);
	blockObj.addNewItem(self.String, DC_Data, 2, self);
	blockObj.addNewItem("GC Area", DC_MoreInfo, 2, self.myTerminalArea);
	blockObj.addNewItem(self.myTerminalArea.String, DC_Data, 2, self.myTerminalArea);
	
	endif;
	
	// Add the spec details after the summary details.
	_dataContainer.addMultipleBlocks(allBlocksArray);

	
epilog
	delete allBlocksArray;
	delete sortTIs;
	delete sohVolumeS;
	delete sohWeightS;
	delete sohCargoS;
	delete sohItemS;
	delete sohQuantityS;
	delete allTIs;
end;

</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFootPrintInMetres" id="1f662c9f-9d4a-4b7e-9c3b-4c08b699d1d0">
        <source>getFootPrintInMetres():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

	firstPoint : Point;
	lastPoint : Point;
	xSpan : Integer;
	ySpan : Integer;
	numUnits : Integer;
	unitLength : Decimal [12,4];
	unitSquare : Decimal [12,4];
	footPrint : Decimal [12,4];

begin

	firstPoint := region.first;
	lastPoint := region.last;
	
	xSpan := (lastPoint.x - firstPoint.x) + 1;
	ySpan := (lastPoint.y - firstPoint.y) + 1;
	
	numUnits := ( xSpan * ySpan );
	
	unitLength := self.myTerminalArea.CM_IrregularBlockArea.unit;
	unitSquare := unitLength * unitLength;
	
	footPrint := (numUnits * unitSquare).max(1);
	
	return footPrint;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="1ffbe1ff-200e-4e70-b06f-6b17d8208b5e">
