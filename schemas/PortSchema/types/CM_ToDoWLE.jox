    <JadeMethod name="isCompleteForJob" id="3016b391-0ec9-4018-b48a-99c79aae600b">
        <source>isCompleteForJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwer1	Initial creation

*/

vars

	tmpReq : CM_Request;
begin

	tmpReq := self.myRequest;

	if tmpReq = null or (not tmpReq.isKindOf(CM_ToDoRequest)) then
		return false;
	endif;
	
	if tmpReq.CM_ToDoRequest.isComplete then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
