    <JadeMethod name="buildContextMenu" id="fc758bf6-efe9-4d8f-80fd-37a2797ed064">
        <updating/>
        <source>buildContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
/*
Date		Who		Reason
26 January 2009	cnwcp2	Initial creation
*/

vars

begin
	if not self.isMenuBuilt then
		self.setupMenu();
		self.isMenuBuilt := true;
	endif;
	
	if isMenuItemsVisible then
		return self.showContextMenu( self.mPopupMenu, table, conwin, mouse, x, y);
	endif;
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplay" id="09deb830-c2d7-4380-a49c-471185b6c4e7">
        <source>doDisplay()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2013	cnwndl1	Initial creation

*/

vars
	connected, controlled : Boolean;
begin
	// fast way of clearing the column
	tblResults.columns := 1;
	tblResults.columns := 2;
		
	if self.myTrackedItem &lt;&gt; null then
		connected := self.myTrackedItem.isConnected;
		controlled := self.myTrackedItem.isControlledAtmosphere;
		
		self.tblResults.accessCell(1,2).text := self.myTrackedItem.alternativeId;
		self.tblResults.accessCell(2,2).text := self.myTrackedItem.locationId;
		if self.myTrackedItem.getTemperature &lt;&gt; NULL_TEMPERATURE then
			self.tblResults.accessCell(3,2).text := app.temperatureDisplayString(self.myTrackedItem.getTemperature) &amp; Degrees_C;
		else
			self.tblResults.accessCell(3,2).text := "Not set";
		endif;
		self.tblResults.accessCell(4,2).text := self.myTrackedItem.commodity;	
		self.tblResults.accessCell(5,2).text := controlled.getYesNo;
		if self.myTrackedItem.getOxygen &lt;&gt; NULL_OXYGEN then
			self.tblResults.accessCell(6,2).text := self.myTrackedItem.getOxygen.asStringJMT;
		else
			self.tblResults.accessCell(6,2).text := "";
		endif;
		if self.myTrackedItem.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
			self.tblResults.accessCell(7,2).text := self.myTrackedItem.getCarbonDioxide.asStringJMT;
		else
			self.tblResults.accessCell(7,2).text := "";
		endif;
		self.tblResults.accessCell(8,2).text := self.myTrackedItem.ventilationString;
		
		self.tblResults.accessCell(9,2).text := self.systemToLocalTime(self.myTrackedItem.getLastConnectDT).asStringJMT;	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
		self.tblResults.accessCell(10,2).text := self.systemToLocalTime(self.myTrackedItem.getLastDisconnectDT).asStringJMT;	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
		self.tblResults.accessCell(11,2).text :=self.myTrackedItem.voyageCode;
		self.tblResults.accessCell(12,2).text := self.myTrackedItem.consignor;
		if self.myTrackedItem.getHumidity &gt; NULL_HUMIDITY then
			self.tblResults.accessCell(13,2).text := self.myTrackedItem.getHumidity.asStringJMT;
		else
			self.tblResults.accessCell(13,2).text := "";
		endif;
		self.tblResults.accessCell(14,2).text := self.myTrackedItem.operatorCode;
		self.tblResults.accessCell(15,2).text := self.myTrackedItem.bookingReference;
		self.tblResults.accessCell(16,2).text := self.myTrackedItem.dischargePort;
		self.tblResults.accessCell(17,2).text := self.myTrackedItem.getAvailGradeCodeAndDesc;	//24 Mar 2011	NDl	Par 27277
		self.tblResults.accessCell(18,2).text := self.myTrackedItem.getReeferRemarks;
		
		if not connected then
			if self.myTrackedItem.getFirstConnectDT = null then
				self.tblResults.accessColumn(2).backColor := LightRed;//#FF99FF - Pink
			else
				self.tblResults.accessColumn(2).backColor := LightGreen;
			endif;
		else
			self.tblResults.accessColumn(2).backColor := White;
		endif;		
		
		if controlled then
			self.tblResults.accessCell(6,2).backColor := Yellow;
			self.tblResults.accessCell(7,2).backColor := Yellow;
		else
			self.tblResults.accessCell(6,2).backColor := self.tblResults.accessCell(1,2).backColor;
			self.tblResults.accessCell(7,2).backColor := self.tblResults.accessCell(1,2).backColor;
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="d13db08a-877c-49ea-b422-26308ff3780d">
