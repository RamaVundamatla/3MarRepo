    <JadeMethod name="getDisplayStringForAttribute" id="1fbe1dc3-db0b-4868-9e97-8b2c45ba6c92">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_Description then
		return self.description;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasMatchingDate" id="7b4f86d6-8efa-42cb-aea3-737ade7aecc2">
        <source>hasMatchingDate(_date : Date) : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDateTime : CM_FinancialPeriodDateTime;
begin
	foreach aDateTime in self.allFinancialPeriodEndDates reversed do
		if aDateTime.dateTime.date = _date then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a33f03ab-67a4-40e2-bcf2-d8a5af8741e1">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : CM_FinancialPeriodEnd;
	pxyDateTime,aDateTime : CM_FinancialPeriodDateTime;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	foreach aDateTime in self.allFinancialPeriodEndDates do
		pxyDateTime := app.createUpdateProxy(aDateTime).CM_FinancialPeriodDateTime;
		pxyDateTime.setProxyFPE(pxyMe);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
