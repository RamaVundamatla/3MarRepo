    <JadeMethod name="pxyCreateUpdateProxy" id="9d4b8e86-6678-4925-90d7-d99db3dff108">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars

	proxyDeckItem	: CM_DeckItem;
	deckItemLayout : CM_DeckItemLayout;
	completedOK		: Boolean;
begin
	proxyDeckItem := inheritMethod();
	proxyDeckItem.setCode( self.code, false );
	proxyDeckItem.description := self.description;
	proxyDeckItem.remarks := self.remarks;

	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyDeckItem;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyDeckItem;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
