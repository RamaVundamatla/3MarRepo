    <JadeMethod name="addClonedQryCriteria" id="c221e7bd-c93d-47ba-8d3a-be8d90eefb79">
        <updating/>
        <source>addClonedQryCriteria( _realCritHolder : CM_QueryCriteriaLineHolder; _transient : Boolean ):CM_QueryCriteriaLineHolder updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	clonedCritHolder	: CM_QueryCriteriaLineHolder;

begin

	clonedCritHolder := _realCritHolder.cloneSelf(_transient);
	self.allQueryCriteriaHolders.add( clonedCritHolder );
	
	return clonedCritHolder;

epilog

end;</source>
        <Parameter name="_realCritHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_QueryCriteriaLineHolder"/>
    </JadeMethod>
    <JadeMethod name="canUserRunReport" id="0f0cf080-b4fb-4911-a4fc-081a45f8f316">
        <source>canUserRunReport(_user : CM_User) : Class;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if not _user.canUserAccessObj(self.myOperator, CM_Operator) then
		return CM_Operator;
	endif;
	
	return null;



end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="checkStatusIncludesObject" id="7903de97-44d8-475b-a3ba-54e0b46f9007">
        <updating/>
        <source>checkStatusIncludesObject(_obj : CM_Object; _passport : CM_Passport; _breakOut : Boolean output) : Boolean updating;
// -------------------------------------------
// Created 22 February 2005 by cnwdvb1
// -------------------------------------------
// Break out is just here to satisfy requirement for sendMsg calls without having to re work every call.
/*

Date		Who		Reason
10 Mar 2015	cnwkpd1	PAR #35843 - Change check for callout to be time-based, not record count, 
					to cater for high-latency thin client connections

*/

vars
	querySelf			: CMQF_FilterReports;
	cmifMonitor			: CMIF_Monitor;
	
begin

	querySelf := self;
//	querySelf.numSearched := querySelf.numSearched + 1;
	
//	if (querySelf.numSearched mod self.NUM_ITEMS_TO_SEARCH) = 0 then

	if (app.relativeMachineTime() - querySelf.lastStatusCheck) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
		cmifMonitor := app.myPassport.myCMIFMonitor;
		if cmifMonitor &lt;&gt; null then
			cmifMonitor.updateProgress(null, querySelf.numSearched, querySelf.numFound);
			querySelf.lastStatusCheck := app.relativeMachineTime();
			
			if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				CM_BreakOutException.raise_(cmifMonitor.monitorReturnValue, 'Breaking Out');
				return false;
			endif;
		endif;
	endif;
	
	// So we can just do the earlier check.
	if _obj &lt;&gt; null then
		return self.includesObject(_obj, _passport, _breakOut);
	endif;


end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="25524fbd-5115-425c-a7ac-768f08c0864b">
        <updating/>
        <source>cloneReferences(_obj : CMQF_FilterReports; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     Called when a report definition is added or updated in report maintenance, to complete a cloneSelf
//					and save the non-primitive default values.  Also called when the report is run.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
///21/06/2016   cnwma1 	    PAR #37960 TFS #2187 PEN - Report Maintenance Set and Save Default Value
// ---------------------------------------------------------------------------
vars
	clonedParam,
	pxyParam			: CM_QueryReportParam;
	critHolder,
	clonedCritHolder	: CM_QueryCriteriaLineHolder;
	critLine,
	clonedCritLine		: CM_SelectorCriteriaLine;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
begin
	self.allTerminals.clear();
	_obj.allTerminals.copy(self.allTerminals);
	
	self.allQryTerminalAreas.clear();
	_obj.allQryTerminalAreas.copy(self.allQryTerminalAreas);
	
	self.allQueryReportParams.clear();
	on Exception do app.handleDeletedObject( exception, pxyParam, invalid );	//18 July 2016	NDL	TFS 2329
	foreach pxyParam in _obj.allQueryReportParams do
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := pxyParam.edition;
		if invalid then
			continue;
		endif;
		clonedParam := pxyParam.cloneSelf(_transient);
		self.allQueryReportParams.add(clonedParam);
	endforeach;	
	
	foreach critHolder in _obj.allQueryCriteriaHolders do
	//	clonedCritHolder := critHolder.cloneSelf(_transient);
	//	self.allQueryCriteriaHolders.add(clonedCritHolder);
		clonedCritHolder := self.addClonedQryCriteria( critHolder, _transient );	//18 July 2016	NDL	TFS 2329
		foreach critLine in critHolder.allCriteriaByPropertyName do
			clonedCritLine := critLine.cloneSelf(_transient);
			clonedCritLine.setMyCriteriaLineHolder(clonedCritHolder);
		endforeach;
	endforeach;
	
	self.setMyLocationsController( _obj.getMyLocationsController );
	self.myOperator					:= _obj.myOperator;
	self.setMyCargoType( _obj.getMyCargoType ); //21/06/2016 cnwma1 PAR #37960 TFS #2187
	self.setMyProduct( _obj.getMyProduct );	//18 May 2021	NDL	TFS 51203
	self.setMyTerminalArea( _obj.getMyTerminalArea );
	self.setMySubTerminal( _obj.getMySubTerminal );//27/04/2009 cnwdz2 ccms1735
end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesObjectMatchQuery" id="d793fe38-04fd-4a8a-86fc-65d1aca5d586">
        <updating/>
        <source>doesObjectMatchQuery(_obj : CM_Object) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		02 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	breakOut : Boolean;
begin
	return self.includesObject(_obj, app.myPassport, breakOut);
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
