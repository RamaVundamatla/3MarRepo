      &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;/CargoOnSite&gt;
    &lt;CargoOnSite Terminal="TT1"&gt;
      &lt;TestCases&gt;37279&lt;/TestCases&gt;
      &lt;cargoTypeDescr&gt;Motor Vehicle&lt;/cargoTypeDescr&gt;
      &lt;id&gt;JLG37279W7UA09&lt;/id&gt;
      &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
      &lt;locationId&gt;GCVH01 CARS&lt;/locationId&gt;
      &lt;weight&gt;5000.0000&lt;/weight&gt;
      &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
      &lt;commodity&gt;MCAR&lt;/commodity&gt;
      &lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
      &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;/CargoOnSite&gt;
  &lt;/AllCargoOnSite&gt;
&lt;/JMTInternalCargoOnSite&gt;';

	dsl.ediLoadVerifyDBLoadActualSetup(ediData, null, method.name, EDIFileType_JMTInternal, false, true, false, false, null);
		
	// add release requests
	dsl.opts.purge();
	dsl.opts.addAssoc("Number", 3);
	dsl.opts.addAssoc("Voyage", dsl.getVoyage("MSCK000002").CM_Voyage);
	dsl.opts.addAssoc("Operator", app.myRoot.allOperators["MSL"].CM_Operator);
	dsl.opts.addAssoc("FullRelease", true);
	
	release := dsl.addReleaseByTypeRequestOpts("JLG37279ROAD001", 1, 7);
	
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA01").CM_TrackedItem);
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA02").CM_TrackedItem);
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA03").CM_TrackedItem);
	
	release := dsl.addReleaseByTypeRequestOpts("JLG37279ROAD002", 1, 7);
	
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA04").CM_TrackedItem);
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA05").CM_TrackedItem);
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA06").CM_TrackedItem);
	
	release := dsl.addReleaseByTypeRequestOpts("JLG37279ROAD003", 1, 7);
	
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA07").CM_TrackedItem);
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA08").CM_TrackedItem);
	dsl.releaseAssignCargo(release, null, dsl.getTrackedItem("JLG37279W7UA09").CM_TrackedItem);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	delete pinsStrDict;
	
end;
