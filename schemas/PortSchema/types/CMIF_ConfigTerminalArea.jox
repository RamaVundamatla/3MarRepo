    <JadeMethod name="setXMLTagForType" id="111ae917-3526-4aa0-9de1-6a33be6e66b3">
        <updating/>
        <source>setXMLTagForType() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.xmlTagForType := self.XMLTag_LvlTerminal;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updatePersistentObject" id="acb9d12d-d52c-480a-9c53-6bbdc08b0559">
        <source>updatePersistentObject(_terminalArea : CM_TerminalArea input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propCol	: PropertyColl;
	prop	: Property;
	keyStr	: String;
	
begin

//	inheritMethod(_terminalArea);

	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		keyStr := self.getKeyStringForProperty(prop.name);

		if keyStr &lt;&gt; null then
			_terminalArea.setConfig(keyStr, self.getPropertyValue(prop.name));
		else
			// need to handle as a special
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special ' &amp; prop.name);
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
