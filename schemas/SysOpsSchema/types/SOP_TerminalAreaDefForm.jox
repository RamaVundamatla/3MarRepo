Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tbl		: CM_DataTable;
	jCell	: JadeTableCell;
begin
	tbl := self.tblGateLanes;
	if tbl.row &lt; tbl.fixedRows + 1 or tbl.column &lt;&gt; tbl.getColumnByRowName(ETRow_Printer) then
		return;
	endif;
	
	jCell := tbl.accessCell(tbl.row, tbl.column);
	jCell.text := combobox.text;
	jCell.itemObject := combobox.listObject;//the selected printer
end;

</source>
