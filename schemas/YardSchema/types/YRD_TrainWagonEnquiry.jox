    <JadeMethod name="assignTIToTransport" id="0046efc1-6145-4e26-808b-2dfd96de2744">
        <updating/>
        <source>assignTIToTransport(_toLocationsController : CM_LocationsController)updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	tmpTi : CM_TrackedItem;
	result : Integer;
	moveController : CMIF_MoveController;
	tranArea : String;
begin

	if _toLocationsController = null then
		return;
	endif;
	
	if app.myMoveController = null then
		return;
	endif;
	
	if not _toLocationsController.isWagon() then
		app.raiseCMException(VB_MOVE_INVALID, null, null);
		return;
	
	endif;
	
	moveController := app.myMoveController;
	moveController.setMyToPrimaryLocation(_toLocationsController);
	
	tmpTi := moveController.myTrackedItem;
	if tmpTi = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Assign_Transport), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		break;
	endwhile;
	
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;		
end;</source>
        <Parameter name="_toLocationsController" type="CM_LocationsController"/>
    </JadeMethod>
