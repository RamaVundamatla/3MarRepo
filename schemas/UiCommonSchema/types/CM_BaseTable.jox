    <JadeMethod name="optimiseColumnWidths" id="c513044a-9398-408a-98cb-7ed4af7e8d88">
        <updating/>
        <source>optimiseColumnWidths(minTableWidth,
					 maxTableWidth,
					 defaultColumnWidth : Integer;
					 criticalColumns : String) updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// sample call :: tblResults.optimiseColumnWidths(form.width - 20,form.width,50,"1,2,5");

vars
	numRows,
	numColumns,
	xWidth,
	xHeadSum,
	xBodySum,
	xMaxSum,
	xDiff,
	xCrit,
	xNonCrit,
	xCritDiff	: Integer;
	widthHead,
	widthBody,
	widths,
	shortfalls	: IntegerArray;
	rowHasVisibleCell : Boolean;
	r, c : Integer;

begin


return;

	create widthHead transient;
	create widthBody transient;
	create shortfalls transient;

	widthHead[self.columns] := 0;
	widthBody[self.columns] := 0;

	// KPD - Split sizing code into 2 parts, one for the fixed part, and one for the
	//  rest, to handle fixed3D, and to check only visible rows
	numColumns := self.columns;

	// First do fixed header rows
	numRows := self.fixedRows;
	foreach r in 1 to numRows do
		self.row := r;
		foreach c in 1 to numColumns do
			self.column := c;

			xWidth := self.getTextExtent(self.getCellText(self.row, self.column));
			if fontItalic then
				xWidth := xWidth + 4;
			endif;
			if fontBold then
				xWidth := (xWidth * 1.2).rounded;
			endif;
			if self.fixed3D then
				xWidth := xWidth + 1;
			endif;
			widthHead[self.column] := widthHead[self.column].max(xWidth);

		endforeach;
	endforeach;

	numRows := self.rows;
	// Now do visible rows
	foreach r in self.topRow to numRows do
		self.row := r;
		if self.rowVisible[self.row] then		// ignore invisible rows
			rowHasVisibleCell := false;

			foreach c in 1 to numColumns do
				self.column := c;
				xWidth := self.getTextExtent(self.getCellText(self.row, self.column));
				if fontItalic then
					xWidth := xWidth + 4;
				endif;
				if fontBold then
					xWidth := (xWidth * 1.2).rounded;
				endif;
				widthBody[self.column] := widthBody[self.column].max(xWidth);

				if not (self.positionTop = -1 or self.positionLeft = -1) then
					rowHasVisibleCell := true;
				endif;

			endforeach;

			// Break out when no cells in the current row are visible, because we
			//  must have passed the last row in the visible window
			if not rowHasVisibleCell then
				break;
			endif;
		endif;
	endforeach;

	self.column := 1;
	while self.column &lt;= numColumns do
		widthHead[self.column] := widthHead[self.column] + 4; // extra pixels
		widthBody[self.column] := widthBody[self.column] + 4; // extra pixels
		if self.columnWidth[self.column] = 0 or not columnVisible[self.column] then
			widthHead[self.column] := 0;
			widthBody[self.column] := 0;
		endif;
		if criticalColumns.pos(column.String,1) &gt; 0 then // it is critical
			xCrit := xCrit + widthHead[self.column].max(widthBody[self.column]);
		else
			xNonCrit := xNonCrit + widthHead[self.column];
			xCritDiff := xCritDiff + (widthBody[self.column] - widthHead[self.column]).max(0);
		endif;
		xHeadSum := xHeadSum + widthHead[self.column];
		xBodySum := xBodySum + widthBody[self.column];
		xMaxSum := xMaxSum + widthHead[self.column].max(widthBody[self.column]);
		shortfalls[self.column] := (widthBody[self.column] - widthHead[self.column]).max(0);
		xDiff := xDiff + shortfalls[self.column];
		if self.column = numColumns then
			break;
		endif;
		self.column := self.column + 1;
	endwhile;

	self.column := 1;
	xWidth := 0;
	while self.column &lt;= numColumns do
		if self.columnWidth[self.column] &gt; 0 and columnVisible[self.column] then
			if xMaxSum &lt;= maxTableWidth or maxTableWidth = 0 then
				self.columnWidth[self.column] := widthHead[self.column].max(widthBody[self.column]) +
											((minTableWidth - xMaxSum).max(0) * 
											 (widthHead[self.column].max(widthBody[self.column]) / xMaxSum)).truncated;
			elseif xCrit + xNonCrit &lt;= maxTableWidth then
				if criticalColumns.pos(column.String,1) &gt; 0 then // it is critical
					self.columnWidth[self.column] := widthHead[self.column].max(widthBody[self.column]);
				else
					self.columnWidth[self.column] := widthHead[self.column] + 
											((maxTableWidth - (xCrit + xNonCrit)).max(0) * (shortfalls[self.column]/xCritDiff)).truncated;
				endif;
			elseif xHeadSum &lt;= maxTableWidth then
				if xDiff &gt; 0 then
					self.columnWidth[self.column] := widthHead[self.column] + 
											((maxTableWidth - xHeadSum) * (shortfalls[self.column]/xDiff)).truncated;
				else
					self.columnWidth[self.column] := widthHead[self.column];
				endif;
			elseif defaultColumnWidth &gt; 0 then
				self.columnWidth[self.column] := defaultColumnWidth;
			endif;
			xWidth := xWidth + self.columnWidth[self.column];
		endif;
		if self.column = numColumns then
			break;
		endif;
		self.column := self.column + 1;
	endwhile;

	// KPD 25/1/00 - don't resize the table itself
//	if minTableWidth &lt;&gt; maxTableWidth then 
//		self.width := xWidth + 3;
//	endif;
	if numColumns &gt; 0 then
		self.column := 1;
	endif;
	if numRows &gt; 0 then
		self.row := 1;
	endif;

epilog
	if widthHead &lt;&gt; null then
		delete widthHead;
	endif;	
	if widthBody &lt;&gt; null then
		delete widthBody;
	endif;	
	if shortfalls &lt;&gt; null then
		delete shortfalls;
	endif;
end;</source>
        <Parameter name="minTableWidth" type="Integer"/>
        <Parameter name="maxTableWidth" type="Integer"/>
        <Parameter name="defaultColumnWidth" type="Integer"/>
        <Parameter name="criticalColumns" type="String"/>
    </JadeMethod>
    <JadeMethod name="optimiseHeightForRow" id="15158b8a-a49f-426a-9a7c-b3d6fb7fe4da">
        <updating/>
        <source>optimiseHeightForRow(_cellInputType: Integer; _row: Integer; _inputText: String) updating;
//--------------------------------------------------
// Created:	19 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	newRowHeight : Integer;
begin

	if _cellInputType &lt;&gt; InputType_None and
	   _cellInputType &lt;&gt; InputType_TextBox then
		return;
	endif;
	
	if _row &gt; self.rows then
		return;
	endif;

	if (not self.optimiseRowHeight) then
		return;
	endif;
	if _inputText &lt;&gt; null then
		newRowHeight := (self.getTextHeight(_inputText) + 5);
		if self.defaultRowHeight &gt; newRowHeight then
			newRowHeight:=self.defaultRowHeight;
		endif;
	endif;

	if newRowHeight &lt;&gt; self.rowHeight[_row] then
		self.rowHeight[_row] := newRowHeight;
	endif;

end;</source>
        <Parameter name="_cellInputType" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_inputText" type="String"/>
    </JadeMethod>
    <JadeMethod name="outputAsCSV" id="fc3e8412-17e1-4175-aedb-3e384f527091">
        <updating/>
        <source>outputAsCSV(_defaultFileName : String) updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	filePath	: String;
	file		: File;

begin

	// pass null path so opens where last open at
	filePath := app.getFilePath(null, '*.csv', _defaultFileName, false);
		
	if filePath = null then
		return;
	endif;	
	
	if filePath.toLower.pos('.csv', 1) &lt;= 0 then
		filePath := filePath &amp; '.csv';
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
		
	self.outputCSVToFile(file, app.myPassport);
	
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;

end;</source>
        <Parameter name="_defaultFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="outputCSVToFile" id="c6f40a37-2300-4a10-b5e7-c817df99e46b">
        <updating/>
        <source>outputCSVToFile(_file : File input; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	25 May 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
01 Apr 2008	cnwkpd1	PAR #16405 - Remove space from between fields in a line, otherwise these become part of the data
05/07/2010	cnwrl1	PAR 24606 - System Admin Export option does not export the colour values.
31/03/2016	cnwdap1	PAR #35843 Make monitor time based rather than object-count based
03 Mar 2025	navbs1	Bug MTN-34028: Cargo Enquiry Tab Export Issue
29 Apr 2025	navnk30	JIRA 34687: Extend the export functionality to work with TableViewForms that implement Pagination on their DataTables
*/

vars
	colourColumn,										// cnwrl1 05/07/2010 PAR 24606
	numDone,
	updateProgressAfter,
	totalParts,
	idx,
	col,
	numCols,
	numRows : Integer;
	cellText,
	longStr : String;
	tmpRow : JadeTableRow;
	cmifMonitor : CMIF_Monitor;
	lastUpdated : Decimal [20];							// PAR #35843
	hiddenFirstColumn : Boolean;
	
begin
	if _file = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'File', null, null);
		app.raiseCMException(Input_required_field_file, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if (not _file.isAvailable()) then
		app.raiseCMException1(FileUnavailable, _file.fileName, null, null);	
		return;
	endif;
	
	_file.purge();	
	
	colourColumn	:= self.getColourColumnNumber();	// cnwrl1 05/07/2010 PAR 24606
	
	idx := 1;
	/**
	 * Exporting data rows for paginated tables is handled in CM_DataTable::outputCSVToFile().
	 */
	if CM_DataTable.hasInstance(self) and self.CM_DataTable.isPaginated() then	//29.04.2025 navnk30 JIRA 34157
		numRows := self.fixedRows;
	else
		numRows := self.rows;
	endif;
	numCols := self.columns;

	if _passport.myCMIFMonitor &lt;&gt; null then
		totalParts := numRows;
		cmifMonitor := _passport.myCMIFMonitor;
		cmifMonitor.updateProgress(cmifMonitor.message, totalParts, 0);
		updateProgressAfter := (totalParts / 20).roundedUp; // update after every 5%
	endif;	
	
	while idx &lt;= numRows do
		numDone := numDone + 1;
		//if cmifMonitor &lt;&gt; null and numDone mod updateProgressAfter = 0 then							// PAR #35843
		if cmifMonitor &lt;&gt; null																			// PAR #35843
		and (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsInJob, numDone);
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;	
		tmpRow := self.accessRow(idx);
		if (not tmpRow.visible) then
			idx := idx+1; // loop do loop forever if it hit an invisible row...  Found while implementing Par 28889 NDL 05 Jan 2012
			continue;
		endif;
		col := 0;
		foreach col in 1 to numCols do
			if (not self.accessColumn(col).visible) then
				if col = 1 then								//03.03.2025 navbs1 #34028
					hiddenFirstColumn := true;
				endif;
				continue;
			endif;
			cellText := self.accessCell(idx, col).text;
			
			// cnwrl1 05/07/2010 PAR 24606 - start of coding
			// if the column data being extracted is for "colour" then get the actual colour value from the back colour.
			if idx &gt; 1 and							// ignore headings
			   colourColumn &lt;&gt; null and				// have a column for colours
			   col = colourColumn then				// have required column
				cellText	:= self.accessCell(idx, col).backColor.display;
			endif;
			// cnwrl1 05/07/2010 PAR 24606 - end of coding
			
			if (not cellText.isReal) then
				cellText := cellText.csvFormat();
			endif;
			//if col = 1 then								//03.03.2025 navbs1 #34028
			if col = 1	or hiddenFirstColumn then			//03.03.2025 navbs1 #34028
				longStr	:= cellText;
				hiddenFirstColumn := false;					//03.03.2025 navbs1 #34028
			else
				longStr	:= longStr &amp; ',' &amp; cellText;		// PAR #16409 - was using ', '
			endif;
		endforeach;
		_file.writeLine(longStr);
		idx := idx+1;
		longStr := null;									//14.02.2025 navbs1 #34028
	endwhile;
	
end;
</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeItem" id="04f00c47-647c-4542-9ebd-7f71024db2c1">
        <updating/>
        <source>removeItem(index: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     10 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theObject	: Object;
begin

	if (not self.allSelectedObjects.isEmpty) then
		theObject := self.accessRow(index).itemObject;
		if theObject &lt;&gt; null and self.allSelectedObjects.includes(theObject) then
			self.allSelectedObjects.remove(theObject);
		endif;
	endif;
	
	inheritMethod(index);

end;</source>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="ebc0384c-f5c4-4d91-abd4-d269e987a4c7">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin

	inheritMethod();

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	if self.stretchToParent then
		newLeft	:= 0;
		newTop 	:= 0;
		newWidth 	:= parentWidth;
		newHeight	:= parentHeight;
	else
		newLeft := self.left;
		newTop := self.top;
		newWidth := self.width;
		newHeight := self.height;
	
		if lockRight then
			newLeft := (parentWidth - newWidth - distanceFromRight).max(0);
		endif;
		if lockBottom then
			newTop := (parentHeight - newHeight - distanceFromBottom).max(0);
		endif;
		if stretchWidth then
			newWidth := (parentWidth - newLeft - distanceFromRight).max(0);
		endif;
		if stretchHeight then
			newHeight := (parentHeight - newTop - distanceFromBottom).max(0);
		endif;
	endif;
		
	if newLeft &lt;&gt; self.left or 
	   newTop &lt;&gt; self.top or 
	   newWidth &lt;&gt; self.width or 
	   newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.cnEcResizeContents;
	endif;

//if app.getMyUserCode = 'CNWRS2' and self.name = 'tblSearch' then
//	process.debug;
//endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetRowHeightForText" id="b051c7e8-5239-44a1-b716-ec6c634f28ac">
        <updating/>
        <source>resetRowHeightForText(_column: Integer) updating;
/*
Date		Who		Reason
25 September 2006	cnwer1	Initial creation - PAR#xxxx
*/
vars
	numRows, tmpWidth, tmpHeight, idx	: Integer;
	tmpStr								: String;
begin

	numRows 	:= self.rows;
	tmpWidth 	:= self.accessColumn(_column).width;
	
	foreach idx in self.fixedRows to numRows do
		if idx = 0 then
			continue;
		endif;
		
		tmpStr := self.accessCell(idx, _column).text;
		
		if tmpStr = null then
			continue;
		endif;
		
		tmpHeight	:= self.getTextHeightForWidth(tmpStr, tmpWidth);
		
		self.accessRow(idx).height := tmpHeight + 4;
	endforeach;
epilog

end;</source>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="7c9305aa-5f35-4d78-80d2-732f054c9239">
        <controlMethod name="Table::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>scrolled(table: Table input; scrollBar: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 March 2021		navndl1	Initial creation	TFS	50935
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form

*/

vars
	timerType,
	remaining		: Integer;
begin

	if scrollBar = ScrollBar_Vertical then
		//self.setCurrentViewObjects();		// Give the user(/JADE) a second to finish scrolling
		
		if self.getTimerStatus(CM_BaseTable.Timer_UpdateCurrentViewObjects, timerType, remaining) then
			self.endTimer(CM_BaseTable.Timer_UpdateCurrentViewObjects);
		endif;
		self.beginTimer(1000, Timer_OneShot, CM_BaseTable.Timer_UpdateCurrentViewObjects);
	endif;

	inheritMethod(table, scrollBar);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectionType" id="cbb804a5-21e9-4049-b120-4eb48520c22c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>selectionType(set: Boolean; _value: Integer io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     22 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.selectionType := _value;
		if _value = self.SelectionType_Cell then
			self.selectMode := SelectMode_Multiple;
		elseif _value &lt;&gt; self.SelectionType_None then
			self.selectMode := SelectMode_None;
		endif;
	else
		_value := self.selectionType;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setColumnHeadingsFromDef" id="4d9f18f6-1c08-41a2-bd51-973297f8f998">
        <updating/>
        <source>setColumnHeadingsFromDef(_defName : String; _isTextEditable : Boolean) updating;


begin
	setColumnHeadingsFromView(_defName, null,  _isTextEditable); // Refactored cnwgb1 15 May 2008 for PAR 16483
end;</source>
        <Parameter name="_defName" type="String"/>
        <Parameter name="_isTextEditable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColumnHeadingsFromView" id="3ab647fe-246e-4d19-aba7-5dd342a37f96">
        <updating/>
        <source>setColumnHeadingsFromView(_defName : String; _viewName : String; _isTextEditable : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:	15 May 2008 By Graeme Black cnwgb1 for PAR 16483
//
// Most of this code was previously in setColumnHeadingsFromDef() and has
// been refactored here to avoid duplicate code.
// This version will only set the coumn headings that are in the view.
//
// If the _viewName parameter is null or invalid, all the headings 
// in the table will be used.
// ---------------------------------------------------------------------------
// 07 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094 - performance loading view

vars
	entTableDef 	: EntTableDef;
	entTableView	: EntTableView;
	entRow			: EntTableRow;
	theInputType	: Integer;
	numCols,
	idx				: Integer;
	col				: JadeTableColumn;
	fullHeading,
	headingStr		: String;
	coll			: EntTableRowArray;
	
begin
	entTableDef := app.myController.getEntTableDef(_defName);
	
	if entTableDef &lt;&gt; null then
		entTableView := entTableDef.allEntTableViews[_viewName];
		
		if entTableView &lt;&gt; null then
			coll	:= entTableView.allEntTableRows;
		else
			coll := entTableDef.allEntTableRows;
		endif;
		
		numCols := coll.size;
		
		self.clear;
		self.columns 		:= numCols;
		self.rows 			:= 1;
		self.fixedRows 		:= 1;
		self.fixedColumns 	:= 0;
		
		foreach entRow in coll do
			idx := idx + 1;
			
			if entRow.inputType = Table.InputType_CheckBox or (entRow.inputType = Table.InputType_TextBox and _isTextEditable )then	
				theInputType := entRow.inputType;
			else 
				theInputType := Table.InputType_None;
			endif;
			
			headingStr := entRow.shortHeading;
			
			if headingStr = null then
				headingStr := entRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
			endif;
			
			if fullHeading = null then
				fullHeading := headingStr;
			else
				fullHeading := fullHeading &amp; Tab &amp; headingStr;
			endif;
			// now done at end
			//self.accessCell(1, idx).text := headingStr;

			col := self.accessColumn(idx);
			col.inputType := theInputType;
			
			if entRow.myEntTableCellControl &lt;&gt; null then
				if EntTableTextBox.hasInstance(entRow.myEntTableCellControl) then
					col.width := (entRow.myEntTableCellControl.EntTableTextBox.maxLength * 5);
				endif;
			endif;
			
			if entRow.sortFieldName &lt;&gt; null then
				numCols := numCols + 1;
				self.columns := numCols;
				idx := idx + 1;
				fullHeading := fullHeading &amp; Tab &amp; entRow.sortFieldName;
				self.accessColumn(idx).visible := false;
			endif;
		endforeach;
		
		self.accessCell(1, 1).text := fullHeading;
		
		self.userInputEnabled := false;
	endif;

end;</source>
        <Parameter name="_defName" type="String"/>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_isTextEditable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCurrentViewObjects" id="9707c55c-eff9-4f94-8c6e-1064a7bc331e">
        <updating/>
        <source>setCurrentViewObjects()updating;
/*

Purpose:			Reset the collection of visible cargo items so that we know which ones
					to update with notifications.  AND refresh the column content for the lines that have just come into view.
					
					Call after table first populated, and after any complete refresh
					Call after the user scrolls the table. 
					Call when the table is made visible.
					Call when a noticiation deletes an item in the 'allCurrentViewObjects' collection
					Call when a notification would add an item within the range - if we know

Parameters:			

Return Value:		

Date				Who		Reason
12 March 2021		navndl1	Initial creation	TFS 50935
08 November 2022	navmd1	TFS 55379 Only set the row text when we have a valid object

*/

vars

	previousViewObjects : ObjectArray;
	rowIndex : Integer;
	startIndex : Integer;
	endIndex : Integer;
	obj : Object;
	maxHeight : Integer;
	runningOffset : Integer;
	baseForm : CM_BaseForm;
	rowStr : String;
	row : JadeTableRow;
	rowHeight : Integer;
begin
	
	//23/06/2025	navkc1 JIRA MTN 34973
	if self.rows &lt;= null then
		return;
	endif;
	
	if self.form &lt;&gt; null and self.form.isKindOf( CM_BaseForm ) then
		baseForm := self.form.CM_BaseForm;
	endif;
	
	if baseForm = null or not baseForm.isCurrentViewNotesFor( self ) then
		self.allCurrentViewObjects.clear();
		return;
	endif;
	
	create previousViewObjects transient;
	self.allCurrentViewObjects.copy( previousViewObjects );
	self.allCurrentViewObjects.clear();
	
	if self.visible then
		maxHeight := self.clientHeight;
		startIndex := self.topRow;
		endIndex := self.rows;
		rowHeight := self.rowHeight[1];
		
		foreach rowIndex in startIndex to endIndex do
			row := self.accessRow( rowIndex );
			if not row.visible then
				// Can't very well add an invisible row to the current *view* objects now can we ;)
				continue;
			endif;
			
			obj := row.itemObject;
			if obj &lt;&gt; null then
				self.allCurrentViewObjects.addNoDuplicates( obj, false );
				if not previousViewObjects.includes( obj ) then
					//Refresh the row, it hasn't had notes processed previously, so might be out of date.
					rowStr := baseForm.getCurrentTableLineForObject( self, obj, rowIndex );
					self.setCellText( rowIndex, 1, rowStr );
				endif;
			endif;
			runningOffset := runningOffset + rowHeight;
			if runningOffset &gt; maxHeight then
				break;
			endif;
		endforeach;	
	endif;
		
epilog

	delete previousViewObjects;

end;</source>
    </JadeMethod>
