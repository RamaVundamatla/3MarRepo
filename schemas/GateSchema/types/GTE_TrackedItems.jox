        <source>unload() updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	if self.myParentForm &lt;&gt; null then
		self.myParentForm.GTE_ReleaseRequests.myAddItemsForm := null;
	endif;
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="updateNumSelectedLabel" id="8a84ae74-29d3-4241-96d3-e85565c7d4c5">
        <source>updateNumSelectedLabel() protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 August 2007 By cnwth2

Purpose:	PAR 14758

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	releaseNoStr			: String;
	numSelected				: Integer;
	parentReleaseRequest		: CM_BulkRelease;
begin

	if self.myParentForm &lt;&gt; null and self.myParentForm.GTE_ReleaseRequests.mode &lt;&gt; CMUI_TreeViewForm.Mode_View then
		parentReleaseRequest := self.myParentForm.GTE_ReleaseRequests.myMasterProxyObject.CM_BulkRelease;
		if parentReleaseRequest &lt;&gt; null then
			releaseNoStr := ' for release "' &amp; parentReleaseRequest.code &amp; '"';
		endif;
	endif;
	
	
	numSelected := self.tblListAll.allSelectedObjects.size();
	
	self.lblNoSelected.caption := numSelected.String &amp; ' items selected' &amp; releaseNoStr;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
