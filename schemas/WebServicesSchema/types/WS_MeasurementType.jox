    <JadeMethod name="setProxyFromObject" id="8b02a81f-6e41-4b89-9522-895e48d352b0">
        <updating/>
        <source>setProxyFromObject(_measureType: CM_MeasurementType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwmc5	Initial creation

*/

vars

begin
	inheritMethod(_measureType);
	
	self.name := _measureType.name;
	self.shortName := _measureType.shortName;
	self.default := _measureType.isDefault;
	self.unit := _measureType.measurementType;
	self.format := _measureType.format;
	self.conversionRate := _measureType.conversionRate;

epilog

end;</source>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
    </JadeMethod>
