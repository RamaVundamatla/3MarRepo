    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getFirstChild" id="c99e2845-3261-4ba6-915c-466fff04a284">
        <source>getFirstChild(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jul 2023 navma1 ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation

*/

vars
	ti ,	 
	child  : CM_TrackedItem;
	trans : CM_TITransaction;
begin
	
	ti := self.getTi();
	if ti &lt;&gt; null then
		if ti.hasChildren then
			child := ti.getFirstChild();
			
		else
			if self.status = WLE_COMPLETED then
				trans :=  ti.getLastTransOfClass(CM_Unpack);
				if trans &lt;&gt; null then
					child :=  trans.CM_Unpack.getOtherTrackedItem;
				endif;
			endif;
		endif;
	endif;

	return child;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getQuantity" id="fd89752d-115e-4658-a25b-487867504ed0">
