    <JadeMethod name="getClassForTransType" id="b9802c74-4952-451d-baf5-936af813b43f">
        <source>getClassForTransType(_transType : Integer) : Class;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/06/2018	jlgdap1		Initial creation TFS 39165 PEL1 Voyage Work Order Transactions
// 19/06/2018	jlgdap1		TFS 39302 Work Order Cancellation 1090
//
vars

begin
	if _transType = TRANS_TYPE_WO_CANCEL then						// TFS 39302
		return CM_WOCancel;										// TFS 39302
	elseif _transType = TRANS_TYPE_WO_CARGOADDITIONAL then
		return CM_WOCargoRequest;
	elseif _transType = TRANS_TYPE_WO_CARGOINITIAL then
		return CM_WOCargoRequestInitial;
	elseif _transType = TRANS_TYPE_WO_EXTENSION then
		return CM_WOExtension;
	elseif _transType = TRANS_TYPE_WO_MARINESERVICEDEP then
		return CM_WOMarineServiceDepart;
	elseif _transType = TRANS_TYPE_WO_MARINESERVICEARR then
		return CM_WOMarineServicesInitial;
	elseif _transType = TRANS_TYPE_WO_SHIFT then
		return CM_WOShift;
	elseif _transType = TRANS_TYPE_WO_TIMECHANGE then
		return CM_WOTimeChange;
	elseif _transType = TRANS_TYPE_WO_VOYAGEREQUEST then
		return CM_WOVoyageRequest;
	elseif _transType = TRANS_TYPE_WO_WATERREQUEST then
		return CM_WOWaterRequest;
	elseif _transType = TRANS_TYPE_WO_BILLINGADJ then // TFS 42241
		return CM_WOBillingAdjustment; // TFS 42241
	endif;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getCurrentLengthOfTime" id="ec9fc398-f435-4394-acdb-1eb4d58d47b6">
        <source>getCurrentLengthOfTime():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgndl1	Initial creation	TFS 39167

*/

vars

begin

	if self.getMyParent &lt;&gt; null then
