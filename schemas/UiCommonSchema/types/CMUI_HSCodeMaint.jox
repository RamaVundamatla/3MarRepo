    <JadeMethod name="translateForm" id="86c1aacd-7576-4561-a6c2-ed109650f4dc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 January 2023 08:32:39.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025308, locale);
	btnAdd.translateCaption(Xlat_0025309, locale);
	btnClose.translateCaption(Xlat_0025310, locale);
	btnLoadFile.translateCaption(Xlat_0025311, locale);
	btnRemove.translateCaption(Xlat_0025312, locale);
	btnSearch.translateCaption(Xlat_0025313, locale);
	grpLoadFile.translateCaption(Xlat_0025314, locale);
	lblActiveCodes.translateCaption(Xlat_0025315, locale);
	lblChapter.translateCaption(Xlat_0025316, locale);
	lblFilter.translateCaption(Xlat_0025317, locale);
	lblHeading.translateCaption(Xlat_0025318, locale);
	lblSection.translateCaption(Xlat_0025319, locale);
	optCreates.translateCaption(Xlat_0025320, locale);
	optPurge.translateCaption(Xlat_0025321, locale);
	optUpdates.translateCaption(Xlat_0025322, locale);
	optUpdatesCreates.translateCaption(Xlat_0025323, locale);
end;</source>
    </JadeMethod>
