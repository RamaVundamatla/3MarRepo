    <JadeMethod name="doFindImex" id="fc3124be-9178-4921-96e4-74b638e563cf">
        <updating/>
        <source>doFindImex() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2009	cnwas3	Initial creation

*/

vars
	theForm 		: CMUI_YACriteriaSelectForm;
	imexStatus: CM_IMEXStatus;
	value: String;
	voySet : CM_VoyageSet;
begin
	theForm := app.loadForm(CMUI_YACriteriaSelectForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YACriteriaSelectForm;
	if theForm = null then
		return;
	endif;

	imexStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
	if imexStatus &lt;&gt; null then
		value := imexStatus.abbreviation;
	endif;
	voySet.add(self.myVoyage);
	theForm.set(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], value, voySet, 0,  self.frmCriteria);	//cnwmc5 - PAR 32155
	theForm.setParentForm(self);
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		if theForm.criteriaValue.pos(",", 1) &gt; 0 then
			// Multiple Imex status selected
			self.txtImex.visible := true;
			self.txtImex.text := theForm.criteriaValue;
			self.cmbIMEX.visible := false;
			self.cmbIMEX.setIndexFromObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_NULL]);
		else
			foreach imexStatus in app.myRoot.allImexStatuses do
				if theForm.criteriaValue = imexStatus.abbreviation then
					self.cmbIMEX.setIndexFromObject(imexStatus);
					self.cmbIMEX.visible := true;
					self.txtImex.visible := false;
				endif;
			endforeach;
		endif;
		self.doIMEXSelected();
	endif;

epilog
	delete theForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doIMEXSelected" id="d6f95525-d910-433c-8276-50dc1fefe230">
        <updating/>
        <source>doIMEXSelected() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwas3	Initial creation

*/
vars
	imex : CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
	criteria, proxyCriteria: CM_YACriteria;
	allCriteria				: CMIF_Array;
	tmpObjectSet			: ObjectSet;
	transientObj			: CMIF_YACriteriaPriority;
	localAssistant : CMUI_Assistant;
	voyage : CM_Voyage;
	caption : String;
begin
	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	self.cmbIMEX.setIndexFromObject(imex);
	voyage := self.myVoyage;
	
	if imex &lt;&gt; null and voyage &lt;&gt; null and voyage.allVoyageAllocationConfigs.size &gt; 0 then
		yaIMEXConfig := voyage.allVoyageAllocationConfigs[TI_IMEX_STATUS_EXPORT];
		self.myYAVoyageConfig := yaIMEXConfig.CM_VoyageAllocationConfig;
		//yaIMEXConfig := self.myTerminal.myYAConfig.allYAVoyageConfigs[imex.code];
		//self.myYAVoyageConfig := yaIMEXConfig.CM_YAVoyageConfig;
		create opCriteria transient;
		if yaIMEXConfig &lt;&gt; null then
		
			if yaIMEXConfig.allOpCriteria.isEmpty then
				app.msgBox(app.getErrorString(Please_voyage_config_color_cod), app.getErrorString(Problem), MsgBox_OK_Only);
				localAssistant := self.myAssistant;
				self.unloadForm();
//				localAssistant.showYAMaintRailForm(null, self.myMasterMenuAction, self);
			else
				foreach criteriaType in yaIMEXConfig.allOpCriteria do
					if self.myYardAllocation &lt;&gt; null then
						criteria := self.myYardAllocation.getCriteriaOfTypeValue(criteriaType.type);
					else
						//epr par 19078 19/3/09
						if allCriteria &lt;&gt; null and allCriteria.size &gt; 0 then
							criteria:=self.getCriteriaOfTypeFromTI(allCriteria,criteriaType.type);
						endif;
					endif;
					create proxyCriteria transient;
					if criteria = null then
						proxyCriteria.setProxy(criteriaType, "", "");			
					else
						proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
						opCriteria.add(criteria);
					endif;
					self.allOperationalCriteria.add( proxyCriteria.getTransient());
				endforeach;
			endif;
		endif;
		
		
		if self.myYardAllocation &lt;&gt; null then
			foreach criteria in self.myYardAllocation.allCriteria do
				if not opCriteria.includes(criteria) and criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
				//if criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
					create proxyCriteria transient;
					proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
					self.allTemplateCriteria.add( proxyCriteria.getTransient() );
				endif;
			endforeach; 
		else
			// PAR 19421 no extra template criteria are defaulted
		endif;
		self.populateCriteriaFrames(false);
		self.setIMEXDefaultColour();
	endif;
	
	if not self.isExport then
		self.updateMode := true;
	endif;
	
	self.formatCaption();
	
	if not self.updateMode then
		self.formatDescription();
	endif;
epilog
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	if tmpObjectSet &lt;&gt; null then
		delete tmpObjectSet;
	endif;
	delete opCriteria;
end;</source>
    </JadeMethod>
