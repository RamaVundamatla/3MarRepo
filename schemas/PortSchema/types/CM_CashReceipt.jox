    <JadeMethod name="getExportSequence" id="91f4e041-f250-4e75-8af2-9084130998a6">
        <source>getExportSequence() : Integer;
// Feb 2016 TFS 985 if the external id is in the Milaha format, return the
//	otherwise return the internal sequenceNum value.  Used to build the export extract file name.
vars
	id		: String;
	pos		: Integer;
	seq		: Integer;
begin
	// Milaha external sequence is 'JMT/RCT/nnnnnn/yyyy' - return the nnnnnn portion if so
	id := self.externalInvoiceNumber;
	if id.length &gt; 18 and 
	   id[1:8] = "JMT/RCT/" then
		seq := id[9:6].Integer;
	endif;
	// default value
	if seq = 0 then
		seq := self.sequenceNum;
	endif;
	return seq;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExternalInvoiceNumber" id="3ade3b52-d0ce-4cc1-89bf-48f3522089ce">
        <source>getExternalInvoiceNumber() : String;
// reporting
vars
	invNumber	: String;
begin

	if self.isDraftReceipt() or self.isHoldReceipt() or self.isCancelled() then //20/08/2025	navkc1 JIRA MTN 35791
		return null;
	endif;
	
	// 36355 ADP external reference is on the associated invoice
	invNumber := self.externalInvoiceNumber;
	if invNumber = null and
	   self.myCashInvoice &lt;&gt; null then
		invNumber := self.myCashInvoice.getExternalInvoiceNumber;
	endif;
	
	// TFS 38524 
	if invNumber = null then
		invNumber := self.sequenceNum.String;
	endif;

	return invNumber;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstLastRelatedDates" id="b1f3fec9-bbd5-456e-aed3-7fc6cdff527f">
        <source>getFirstLastRelatedDates( _startDate, _endDate : Date output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgndl1	Initial creation	TFS 45296

*/

vars

	cashPayment : CM_CashPayment;
	cashCredit : CM_CashCredit;

begin

	_startDate := self.getEffectiveDate;
	_endDate := self.getEffectiveDate;
	
	if self.dateTime.date &lt; _startDate then
		_startDate := self.dateTime.date;
	endif;
	
	if self.dateTime.date &gt; _endDate then
		_endDate := self.dateTime.date;
	endif;
	
	foreach cashPayment in self.allCashPayments discreteLock do
		if cashPayment.dateTime.date &lt; _startDate then
			_startDate := cashPayment.dateTime.date;
		endif;
		if cashPayment.dateTime.date &gt; _endDate then
			_endDate := cashPayment.dateTime.date;
		endif;
	endforeach;
	
	foreach cashCredit in self.allDerivedFromCashCredits do
		if cashCredit.dateTime.date &lt; _startDate then
			_startDate := cashCredit.dateTime.date;
		endif;
		if cashCredit.dateTime.date &gt; _endDate then
			_endDate := cashCredit.dateTime.date;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_startDate" type="Date" usage="output"/>
        <Parameter name="_endDate" type="Date" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatsByIdILD" id="117c3ad0-9e58-4985-b657-6613336633a2">
        <source>getInvoiceStatsByIdILD(_dict : DynaDictionary input);
/*
Purpose:			Builds a consolidated invoice line dict based on container id, parent/child and invoice line description


Parameters:			Dictionary to populate with JadeDynamicObjects for reporting

Return Value:		None

Date		Who		Reason
24/8/2015	cnwjre1	Initial creation par 36704 GPHA TFS 108 Ghana cash receipt print
*/
vars
	isContainer			: Boolean;
	parentKey			: Integer;
	pos					: Integer;
	quantity			: Real;
	cargoWeight			: Decimal[12, 3];
//	lineTotal			: Decimal[16, 6];
	cargoId				: String;
	remarks				: String;
	narration			: String;
	invoiceLine 		: CM_InvoiceLine;
	proformaDetails		: CM_ProformaDetails;
	ild					: CM_InvoiceLineDesc;
	jdo					: JadeDynamicObject;
	parent				: CM_TrackedItem;
	ti					: CM_TrackedItem;
	isoGroup			: CM_ISOTypeGroup;
	oa					: ObjectArray;
	obj					: Object;
	lineTotal			: Decimal[23, 6];	//10 May 2018	NDL	TFS 38523
	isManual : Boolean;
begin
	
	create oa transient;
	// combine actual and proforma invoice lines, skipping actual lines after the receipt (so that a reprint shows the same as the original)
	foreach invoiceLine in self.allInvoiceLines where invoiceLine.chargeTime &lt;= self.dateTime do
		if invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED then
			oa.add(invoiceLine);
		endif;
	endforeach;
	foreach proformaDetails in self.allProformaDetails do
		oa.add(proformaDetails);
	endforeach;

	foreach obj in oa do
		narration := null;
		ild := null;
		ti := null;
		isManual := false;
		if obj.isKindOf(CM_InvoiceLine) then
			invoiceLine := obj.CM_InvoiceLine;
			lineTotal := invoiceLine.lineTotal;
			quantity := invoiceLine.quantity;
			remarks := invoiceLine.remarks;
			ild := invoiceLine.invoiceLineDesc;
			ti := invoiceLine.trackedItem;
		elseif obj.isKindOf(CM_ProformaDetails) then
			proformaDetails := obj.CM_ProformaDetails;
			isManual := proformaDetails.isManual(); // TFS 45953
			lineTotal := proformaDetails.lineTotal;
			quantity := proformaDetails.quantity;
			remarks := proformaDetails.remarks;
			ild := proformaDetails.myInvoiceLineType;
			ti := proformaDetails.myTrackedItem;
		endif;
	
		if ti = null then	// don't expect this of course
			continue;
		endif;
		// feedback from Ghana 5/04/2016 this is number of days for Storage, 1 or TEU for regular charges
		//  use the invoice line quantity as the default value
		cargoWeight := quantity;
		isContainer := ti.isContainer();
		// child cargo is reported under the parent as this is what the example cash receipts seem to show.
		// NOTE that this code deliberately reports the parent whether or not it is part of the receipt tracked items
		//  It also uses the cargo type if the parent happens to be other than a container - not expected but coded for just in case.
		parent := ti.myParent;
		if parent = null then
			parent := ti.getMyUnpackedFromContainer();
		endif;
		if parent = null then
			cargoId := ti.id;
			if isContainer then
				isoGroup := ti.getISOTypeGroup();
				if isoGroup &lt;&gt; null then
					cargoId := cargoId &amp; CrLf &amp; isoGroup.description;
				endif;
			else
				cargoId := cargoId &amp; CrLf &amp; ti.cargoTypeDescr;
			endif;
			parentKey := 0;
		else
			cargoId := parent.id;
			if parent.isContainer then
				isoGroup := parent.getISOTypeGroup();
				if isoGroup &lt;&gt; null then
					cargoId := cargoId &amp; CrLf &amp; isoGroup.description;
				endif;
			else
				cargoId := cargoId &amp; CrLf &amp; parent.cargoTypeDescr;
			endif;
			parentKey := 1;
		endif;

		// handle manual charges, which end up with VOID invoice line type
		if ild &lt;&gt; null then
			if isManual then // TFS 45953
				// strip any quantity at end
				pos := remarks.pos(" (x", 1);
				if pos &gt; 1 then
					narration := remarks[1:pos-1];
				else
					narration := remarks;
				endif;
			else
				narration := ild.narration;
			endif;
			// from TFS 2003 testing add null test (is null for VOID invoice line type)
			if ild.myCalculationType &lt;&gt; null and
		      ild.myCalculationType.isWeightBased then
				cargoWeight := ti.totalWeight / 1000;	// in tonnes, weight is in kg
			endif;
		else		// manual charge
			narration := remarks;
		endif;
		
		jdo := _dict.getAtKey(cargoId, parentKey, narration).JadeDynamicObject;
		if jdo = null then
			create jdo transient;
			jdo.addProperty("cargoId", String);
			jdo.addProperty("lineDescription", String);
			jdo.addProperty("cargoWeight", Decimal);
			jdo.addProperty("lineTotal", Decimal);
			jdo.addProperty("quantity", Real);
			jdo.addProperty("parentKey", Integer);
			
			jdo.setPropertyValue("cargoId", cargoId);
			jdo.setPropertyValue("lineDescription", narration[1:100]);	// length limit added from TFS 2003 24/05/2016
			jdo.setPropertyValue("parentKey", parentKey);
			
			_dict.putAtKey(cargoId, parentKey, narration, jdo);
		endif;
		// accumulate value and quantity (both as cargoWeight to print and quantity for the rate
		jdo.setPropertyValue("lineTotal", jdo.getPropertyValue("lineTotal").Decimal + lineTotal);
		jdo.setPropertyValue("cargoWeight", jdo.getPropertyValue("cargoWeight").Decimal + cargoWeight);
		jdo.setPropertyValue("quantity", jdo.getPropertyValue("quantity").Real + quantity);

	endforeach;
	
epilog
	delete oa;

end;</source>
        <Parameter name="_dict" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatsForQUC" id="020b0655-99ee-44cc-af78-ad03f0d5fe6e">
        <source>getInvoiceStatsForQUC(_dict : DynaDictionary input) protected;
/*
Purpose:			Builds a consolidated invoice line dict based on delivery release, invoice line type and container size
					taking prior payments into account.  For Gulftainer cash receipt report.

Parameters:			

Return Value:		None

Date		Who		Reason
4/3/2013	cnwjre1	Initial creation par 34755 Gulftainer Umm Qasr cash receipt, revised to report subsequent payments correctly
17/05/2016	cnwjre1	37864 fix rate and storage quantity, do a separate jdo and hence line for each different number of storage days so they get reported separately
21/11/2017 - jlgab1 - TFS 7611 copy of getInvoicestatsByILDSize
2AUG19 TFS 45894 lots of changes. When printing GUQ want to see all previous payments for other cash receipts on this cash receipt's print.
												The original GUQ cash collection saved all previous invoic elines and proformas on ot the 'new' cash receipts!!!
												This meant that the printing had all it neded on the one cash receipt.
												On subsequent cash collections we only save the invoice lines and payments for the 'new' cash receipt on the receipt
												We do not save previous receitps data on the new receipt.
												SO in this new method for GUQ we have to look at previous payments
25/11/2019  cnwma1	Bug 47640: GUQ - New Cash Report Proforma / Cash Receipt are not working correctly

*/
vars
	lineRate			: Decimal[23, 6];	//10 May 2018	NDL	TFS 38523
	lineTotal			: Decimal[23, 6];	//10 May 2018	NDL	TFS 38523
	quantity			: Real;
	paidCRN				: String;
	remarks				: String;
	narration			: String;
	isCredit			: Boolean;
	days				: Integer;
	transactionType		: Integer;
	deliveryRelease		: String;
	cp					: CM_CashPayment;
	invoiceLine 		: CM_InvoiceLine;
	proformaDetails		: CM_ProformaDetails;
	ild					: CM_InvoiceLineDesc;
	transaction			: CM_TITransaction;
	jdo					: JadeDynamicObject;
	ti					: CM_TrackedItem;
	cmif_length			: CMIF_ContainerLength;
	tiArray				: CM_TIArray;
	containerLength		: Integer;
	oa					: ObjectArray;
	obj					: Object;
	localTiArray		: CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin
	
	create oa transient;
	create cmif_length transient;
	
	//25.11.2019 cnwma1 #47640
	if self.isTransient then
		//This will be used by "Print Performa Invoice" Report
		foreach cp in self.allCashPayments discreteLock do 
					
			if cp.status &lt;&gt; CM_CashPayment.Status_Normal then  //Only  Selected
				continue;
			endif;
			
			if cp.myProformaDetail &lt;&gt; null then
				oa.addExclusive(cp.myProformaDetail);
			elseif cp.myInvoiceLine &lt;&gt; null then
				oa.addExclusive(cp.myInvoiceLine);
			endif;
			
		endforeach;
	endif;
	// 34755 get the prior payments and print these as well to get the detail correct
	// all payments - skip any after this receipt
	create localTiArray transient;						//30 Mar 2016	NDL	TFS 1726
	self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		
	/*
	25.11.2019 cnwma1 #47640
	foreach ti in localTiArray do						//30 Mar 2016	NDL	TFS 1726
		foreach cp in ti.allCashPayments do
			// 35232 skip voided payments
			if cp.voided then
				continue;
			endif;
			if cp.myCashPaymentForInvoice &lt;&gt; null then  // TFS 7357 tax payment ignore
				continue; 								// TFS 7357
			endif; 										// TFS 7357

			if cp.dateTime &lt;= self.dateTime 
			and cp.myCashReceipt &lt;&gt; self  then
				oa.add(cp);
			endif;
			
			if cp.myInvoiceLine &lt;&gt; null 
			//and cp.manual = false
			and cp.myInvoiceLine .chargeTime. &lt;= self.dateTime then
				if cp.myInvoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED then
					oa.add(cp.myInvoiceLine);
				endif;
			endif;
			
			if cp.myProformaDetail &lt;&gt; null
			
			and cp.dateTime &lt;= self.dateTime then
				oa.add(cp.myProformaDetail);
			
			endif;
		endforeach;
	endforeach;
	*/
	
	//25.11.2019 cnwma1 #47640
	foreach ti in localTiArray  discreteLock  do		
		foreach cp in ti.allCashPayments do
			
			if cp.voided then
				continue;
			endif;
			if cp.isTaxPayment &lt;&gt; null then
				continue; 
			endif; 	
			
			if cp.myCashReceipt &lt;&gt; self then  												 // Already been paid in prev receipt 
				if cp.dateTime.truncateToMinute() &gt; self.dateTime.truncateToMinute() then    // Exclude any payment created after this one
					continue;
				endif;
				oa.addExclusive(cp);
			endif;		
			
			if cp.myInvoiceLine &lt;&gt; null then
				if cp.myInvoiceLine.voided then
					continue;
				endif;
				oa.addExclusive( cp.myInvoiceLine);
			
			elseif cp.myProformaDetail &lt;&gt; null then
				oa.addExclusive(  cp.myProformaDetail);
			endif;
			
		
		endforeach;
	endforeach;
	
	foreach obj in oa discreteLock do
		//25.11.2019 cnwma1 #47640
		cp      	    := null; 
		days 			:= 0;
		quantity        := 0;
		invoiceLine     := null;
		proformaDetails := null;
		paidCRN         := null;
		transaction 	:= null;
		containerLength := 0;
		lineTotal       := 0;
		lineRate		:= 0;
		remarks         := null;
		ild             := null;
		ti              := null;
		narration       := null;
		deliveryRelease := null;
		isCredit        := false;
		transactionType := 0;
		//25.11.2019 cnwma1 #47640
		
		if obj.isKindOf(CM_InvoiceLine) then
			invoiceLine	 	:= obj.CM_InvoiceLine;
			lineTotal   	:= invoiceLine.lineTotal;
			quantity    	:= invoiceLine.quantity;
			lineRate    	:= invoiceLine.getRate();
			remarks     	:= invoiceLine.remarks;
			ild 			:= invoiceLine.invoiceLineDesc;
			ti 				:= invoiceLine.trackedItem;
			transaction 	:= invoiceLine.myTransactionTI;
			
			if transaction &lt;&gt; null then
				transactionType := transaction.type;
			endif;
						
			foreach cp in invoiceLine.allCashPayments discreteLock do
				if cp.cashValue = invoiceLine.lineTotal then
					paidCRN   	:= cp.myCashReceipt.getExternalInvoiceNumber();
					break;
				endif;
			endforeach;
			
		elseif obj.isKindOf(CM_ProformaDetails) then
			proformaDetails := obj.CM_ProformaDetails;
			lineTotal 		:= proformaDetails.lineTotal;
			quantity 		:= proformaDetails.quantity;
			lineRate 		:= proformaDetails.rate;
			remarks 		:= proformaDetails.remarks;
			ild 			:= proformaDetails.myInvoiceLineType;
			ti 				:= proformaDetails.myTrackedItem;
			transactionType := proformaDetails.transactionType;
			
			foreach cp in proformaDetails.allCashPayments discreteLock do
				if cp.cashValue = proformaDetails.lineTotal then
					paidCRN   	:= cp.myCashReceipt.getExternalInvoiceNumber();
					break;
				endif;
			endforeach;
			
		elseif obj.isKindOf(CM_CashPayment) then
		
			cp		 	 	:= obj.CM_CashPayment;
			paidCRN   		:= cp.myCashReceipt.getExternalInvoiceNumber();
			lineTotal	 	:= cp.cashValue * -1;
			remarks   		:= cp.proformaDesc;
			ti 		 		:= cp.myTrackedItem;
			isCredit		:= (lineTotal &lt; 0);

			if cp.myProformaDetail &lt;&gt; null then
				ild      		:= cp.myProformaDetail.myInvoiceLineType;
				quantity 		:= cp.myProformaDetail.quantity;
				lineRate	    := cp.myProformaDetail.rate;
				transactionType := cp.myProformaDetail.transactionType;
				
				/* TFS 45953		CM_CashPayment.proformaLineDescriptions not used	
				else
				if cp.proformaLineDescriptions.size &gt; 0 then
					// May 2016 NOTE: this code has been superceded by the use of CM_ProformaDetails which holds the same data but one per object,
					//	and are printed here anyway, and payments are no longer created with any of this populated
					//	so this code is only needed for reprinting old receipts and should be removed at some point.
					//get an array of the various lines..
					proformaDescArray.clear();
					cp.proformaDesc.getTokensForDelimiter( CM_CashPayment.ProformaLineSep, proformaDescArray );
					// 34990 output a payment entry for each individual proforma line to get the reporting correct
					index := 0;
					foreach narration in cp.proformaLineDescriptions do
						index := index + 1;
						lineType := null;
						if index &lt;= proformaDescArray.size then
							lineType := proformaDescArray[index];
						endif;
						narration := narration &amp; " - Paid " &amp; paidCRN;
						lineTotal := - cp.proformaLineTotals[index];
						quantity := cp.proformaLineQuantities[index];
						// handle multiple pro forma payments with manual payments
						if cp.manual and
						   index = cp.proformaLineDescriptions.size then	// last entry is the manual one
							if manualCharge = lineTotal then
								continue;
							endif;
							if manualCharge = 0 then
								manualCharge := lineTotal;
							endif;
						endif;
						ti := cp.myTrackedItem;
						transaction := null;
						containerLength := 0;
						deliveryRelease := null;
						if ti &lt;&gt; null then
							ti.getContainerLength(cmif_length);
							containerLength := cmif_length.length;
							deliveryRelease := ti.deliveryRelease;
						endif;
						isCredit := (lineTotal &lt; 0);
		
						jdo := _dict.getAtKey(deliveryRelease, narration, containerLength, isCredit, days).JadeDynamicObject;
						if jdo = null then
							create jdo transient;
							jdo.addProperty("containerSize", Integer);
							jdo.addProperty("deliveryRelease", String);
							jdo.addProperty("lineAmount", Decimal);
							jdo.addProperty("lineDescription", String);
							jdo.addProperty("quantity", Real);
							jdo.addProperty("lineRate", Decimal);
							jdo.addProperty("numberOfDays", Integer);
							jdo.addProperty("trackedItems", CM_TIArray);
			
							create tiArray transient;
							jdo.setPropertyValue("deliveryRelease", deliveryRelease);
							jdo.setPropertyValue("lineDescription", narration);
							jdo.setPropertyValue("containerSize", containerLength);
							jdo.setPropertyValue("trackedItems", tiArray);
	
							_dict.putAtKey(deliveryRelease, narration, containerLength, isCredit, days, jdo);
						endif;
						jdo.setPropertyValue("quantity", jdo.getPropertyValue("quantity").Integer + quantity);
						jdo.setPropertyValue("lineAmount", jdo.getPropertyValue("lineAmount").Decimal + lineTotal);
						isStorage := false;
						if transaction = null and
						   lineType &lt;&gt; null then
							if (lineType.length &gt; 7 and
							lineType[1:8] = "Storage ") or
							(lineType.length &gt; 12 and
							lineType[1:13] = "Reefer Daily ") then	// 34990
								isStorage := true;
							endif;
						endif;
						if isStorage then
							jdo.setPropertyValue("numberOfDays", quantity.Integer);
						endif;
						tiArray := jdo.getPropertyValue("trackedItems").CM_TIArray;
						if ti &lt;&gt; null and not tiArray.includes(ti) then
							tiArray.add(ti);
							jdo.setPropertyValue("trackedItems", tiArray);
						endif;
					
					endforeach;
					continue;
				endif;
				*/
			elseif cp.myInvoiceLine &lt;&gt; null then
				ild 	    := cp.myInvoiceLine.invoiceLineDesc;
				quantity    := cp.myInvoiceLine.quantity;	
				lineRate    := cp.myInvoiceLine.getRate();
				ti 			:= cp.myTrackedItem;
				transaction := cp.myInvoiceLine.myTransactionTI;
				if transaction &lt;&gt; null then
					transactionType := transaction.type;
				endif;
			endif;
		endif;

		if ti &lt;&gt; null then
			ti.getContainerLength(cmif_length);
			containerLength := cmif_length.length;
			deliveryRelease := ti.deliveryRelease;
		endif;
		
		
		isCredit := (lineTotal &lt; 0);

		if ild &lt;&gt; null then
			narration := ild.narration;
			if isCredit then
				narration := narration &amp; " - Paid ";
				if cp &lt;&gt; null and cp.myCashReceipt &lt;&gt; self then
					if paidCRN &lt;&gt; null then
						narration := narration &amp;  paidCRN;
					endif;
				endif;
			endif;
		endif;
	
		
		if transactionType = TRANS_TYPE_STORAGE       or
		   transactionType = TRANS_TYPE_ReeferMonitor or	// 34990
		   transactionType = TRANS_TYPE_ReeferDaily then	// 37864
		   days := quantity.Integer;
		endif;

		//jdo := _dict.getAtKey(deliveryRelease, narration, containerLength, isCredit, days,paidCRN).JadeDynamicObject;       //25.11.2019 cnwma1 #47640
// TFS 47847		jdo := _dict.getAtKey(paidCRN,deliveryRelease, narration, containerLength, isCredit, days).JadeDynamicObject;         //25.11.2019 cnwma1 #47640
		jdo := _dict.getAtKey(paidCRN,deliveryRelease, narration,lineRate, containerLength, isCredit, days).JadeDynamicObject;  // TFS 47847
		
		if jdo = null then
			create jdo transient;
			jdo.addProperty("paidCRN"		 , String);                 //25.11.2019 cnwma1 #47640
			jdo.addProperty("containerSize"  , Integer);
			jdo.addProperty("deliveryRelease", String);
			jdo.addProperty("lineAmount"	 , Decimal);
			jdo.addProperty("lineDescription", String);
			jdo.addProperty("quantity"		 , Real);
			jdo.addProperty("lineRate"		 , Decimal);
			jdo.addProperty("numberOfDays"	 , Integer);
			jdo.addProperty("trackedItems"	 , CM_TIArray);
			
			
			create tiArray transient;
			jdo.setPropertyValue("paidCRN"         , paidCRN);          //25.11.2019 cnwma1 #47640
			jdo.setPropertyValue("deliveryRelease" , deliveryRelease);
			jdo.setPropertyValue("lineDescription" , narration);
			jdo.setPropertyValue("containerSize"   , containerLength);
			jdo.setPropertyValue("lineRate"        , lineRate);
			jdo.setPropertyValue("trackedItems"    , tiArray);
			jdo.setPropertyValue("numberOfDays"    , days);
					
			//_dict.putAtKey(deliveryRelease, narration, containerLength, isCredit, days,paidCRN,jdo);       //25.11.2019 cnwma1 #47640
// TFS 47847			_dict.putAtKey(paidCRN,deliveryRelease, narration, containerLength, isCredit, days,jdo);         //25.11.2019 cnwma1 #47640
			_dict.putAtKey(paidCRN,deliveryRelease, narration,lineRate, containerLength, isCredit, days,jdo);  // TFS 47847
		endif;
		jdo.setPropertyValue("quantity"   , jdo.getPropertyValue("quantity").Integer   + quantity);
		jdo.setPropertyValue("lineAmount" , jdo.getPropertyValue("lineAmount").Decimal + lineTotal);
		
		tiArray := jdo.getPropertyValue("trackedItems").CM_TIArray;
		if ti &lt;&gt; null and not tiArray.includes(ti) then
			tiArray.add(ti);
			jdo.setPropertyValue("trackedItems", tiArray);
		endif;

	endforeach;
	
epilog
	delete oa;
	delete cmif_length;
	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726;
end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceType" id="65055fe5-9d92-473e-8253-aae57f381e7a">
        <source>getInvoiceType(): CM_InvoiceDesc;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01/01/2019  cnwma1	TFS 40202 PEL1 Estimation SAP Integration

*/

vars
	invType : CM_InvoiceDesc;
	proforma : CM_ProformaDetails;
begin
	foreach proforma in self.allProformaDetails discreteLock do
		if proforma.transactionType = 0 then
			continue;
		endif;
		
		if proforma.myInvoiceLineType &lt;&gt; null then
			if proforma.myInvoiceLineType.invoiceType &lt;&gt; null then
				invType := proforma.myInvoiceLineType.invoiceType ;
				break;
			endif;
		endif;
	endforeach;
	
	return invType;
epilog
	
end;
</source>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceTypeDesc" id="37629373-ba60-42e2-a577-8788ece48e42">
        <source>getInvoiceTypeDesc():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08/12/2018	jlgma1	Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
06/08/2019	jlgdap1	TFS 45853 PEL1 Additional Fees Cash Receipt doesn't show correct invoice type
*/

vars
	desc : String;
	proforma : CM_ProformaDetails;
	invalidObj : Boolean;
	edition : Integer;
	surChargeExempt : CM_InvoiceTypeSurchargeExempt;
begin
	on Exception do app.handleDeletedObject(exception,proforma,invalidObj);
	
	foreach proforma in self.allProformaDetails discreteLock do
		if proforma.transactionType = 0 then
			continue;
		endif;
		
		if invalidObj  then
			invalidObj:=false;
			continue;
		endif;
			
		
		if proforma.myInvoiceLineType &lt;&gt; null then
			if proforma.myInvoiceLineType.invoiceType &lt;&gt; null then
				desc := proforma.myInvoiceLineType.invoiceType.description ;
				return desc;
			endif;
		endif;
	endforeach;
	
	//20 May 2019	NDL	TFS 44651 - If we get to here assume its the result of a split off tax invoice... (i.e. no transaction)
	foreach proforma in self.allProformaDetails discreteLock do
		edition := proforma.edition;
		if invalidObj  then
			invalidObj:=false;
			continue;
		endif;
			
		if proforma.myInvoiceLineType &lt;&gt; null then
			if proforma.myInvoiceLineType.invoiceType &lt;&gt; null then
				surChargeExempt := proforma.myInvoiceLineType.invoiceType.mySurchargeAndExemptions;
				if surChargeExempt &lt;&gt; null and surChargeExempt.myInvoiceDescForSeperateTax &lt;&gt; null then
					desc := surChargeExempt.myInvoiceDescForSeperateTax.description ;
					return desc;
				endif;
			endif;
		endif;
	endforeach;
	
	if self.cashId4 &lt;&gt; null then			// TFS 45853
		return self.cashId4;				// TFS 45853
	endif;									// TFS 45853
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyMatchingInvoice" id="7a1540da-b919-462b-a1f0-c89456f66713">
