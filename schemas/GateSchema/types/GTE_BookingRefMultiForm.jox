    <JadeMethod name="translateForm" id="48150d57-fd34-4d6b-a77b-8120e0683b3c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 November 2022 09:19:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014317, locale);
	btnBookingRefDis.translateBubbleHelp(Xlat_0014318, locale);
	btnBookingRefDis.translateCaption(Xlat_0011305, locale);
	btnCancelItem.translateCaption(Xlat_0005422, locale);
	btnDeleteItem.translateCaption(Xlat_0005423, locale);
