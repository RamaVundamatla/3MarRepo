    <JadeMethod name="setPriorLiftHistory" id="162d644a-a950-4c50-83a8-dbe73b002ab1">
        <updating/>
        <source>setPriorLiftHistory(_machine :CM_Machine) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/10/2012	cnwcs5		par 30382 - Removed _task parameter
// ---------------------------------------------------------------------------
constants
	MAGIC_NUMBER = 1000;
vars
	history		:CM_MachineHistory;
	historyType,
	count		:Integer;
begin
	if self.isStartOfLift then
		// machine doing nothing - have not started a lift
		return;
	endif;

	// assumption is that the collection will NEVER contain receiver
	// i.e method is only used B4 receiver is added to the history collection
	foreach history in _machine.history reversed do
		historyType := history.type;
		// hopefully we find a set-down
		if historyType = CM_MachineHistory.Type_AcceptMove or
			historyType = CM_MachineHistory.Type_PickUp or
			historyType = CM_MachineHistory.Type_SetDown  then
			
			//stop duplicate dictionary errors  - suspect the history will be incorrect but atleast the machine can complete the move
			if history.CM_MachineMoveHistory.myNextLiftHistory = null then
			
				self.myPriorLiftHistory := history.CM_MachineMoveHistory;
			endif;
			break;
		endif;
		
		// we need to stop B4 we troll through the entire history - probably won't happen as we would find a move somewhere
		count := count + 1;
		
		if count &gt;= MAGIC_NUMBER then
			break;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
