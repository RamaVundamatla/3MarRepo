    <JadeMethod name="getTimeStamp" id="3741c509-c190-4e73-bff7-cdfc21a686f3">
        <source>getTimeStamp() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if self.modifiedTimeStamp.time.milliSecond.String.padZeros(3) = "000" then
		return self.modifiedTimeStamp.date.format("yyyy:MM:dd") &amp; ":" &amp; self.modifiedTimeStamp.time.format("HH:mm:ss");
	else
		return self.modifiedTimeStamp.date.format("yyyy:MM:dd") &amp; ":" &amp; self.modifiedTimeStamp.time.format("HH:mm:ss") &amp; "." &amp; self.modifiedTimeStamp.time.milliSecond.String.padZeros(3);
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasTimeStamp" id="fea21715-4232-4e41-b6ac-9a395e35e1b3">
        <source>hasTimeStamp() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if self.modifiedTimeStamp &lt;&gt; null then
		return true;
	else
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
