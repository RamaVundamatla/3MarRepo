    <JadeMethod name="addCargoToTable" id="6d4a2381-b0f4-42c0-bf0d-62ccd75211c3">
        <source>addCargoToTable( _cargo : CM_TrackedItem; _addLocationColour : Boolean ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	str : String;
	rowIndex : Integer;
	columnIndex : Integer;

begin

	if _cargo &lt;&gt; null then
		self.tblCargo.findObjectInRow( _cargo, rowIndex );
		if rowIndex &lt; 1 then
			str := _cargo.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
			if str &lt;&gt; null then
				rowIndex := self.tblCargo.addItemObject( _cargo, str );
				if rowIndex &gt; 0 and _addLocationColour then
					columnIndex := self.tblCargo.getColumnByRowName(ETRow_LocationId);
					if columnIndex &gt; 0 then
						self.tblCargo.accessCell( rowIndex, columnIndex ).backColor := Red;
					endif;
				endif;
				return rowIndex;
			endif;
		endif;
	endif;
	
	return 0;

epilog

end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_addLocationColour" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="beginNotes" id="b237674b-c6ca-4503-bad5-af6e5411e2f8">
        <source>beginNotes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation

*/

vars

begin

	self.beginClassNotification(CM_VehicleVisitRecordDetail, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_VehicleVisitRecordDetail, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_VehicleVisitRecordDetail, false, Object_Create_Event, Response_Continuous, 0);

epilog

end;</source>
    </JadeMethod>
