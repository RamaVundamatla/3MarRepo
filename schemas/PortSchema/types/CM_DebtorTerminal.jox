    <JadeMethod name="setDetails" id="9796f8d6-92ea-489a-b33b-0b3efc60f12b">
        <updating/>
        <source>setDetails(	_myTerminal : CM_Terminal;
			_myDebtor : CM_Debtor;
			_isCashOnly : Boolean;
			_paymentType: Integer;
			_currencyType: CM_CurrencyType;
			_locale: CM_Locale;
			_defaultInvoiceJRW: String;
			_orgCode: String;
			_interterminalCode: String
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2012	cnwndl1	Initial creation	Par 29968
17 August 2022	navpw1	TFS: 54564 (54374) - EUP - Inv Config - DB Changes
28 Apr 2023		navra1	TFS 57086 -  EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
*/

vars

begin

	self.setCashOnly( _isCashOnly );
	self.setPaymentType(_paymentType);				// 10/4/18 MAP TFS37731
	self.setMyCurrencyType(_currencyType);			// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	self.setMyLocale(_locale);						// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	self.setDefaultInvoiceJRW(_defaultInvoiceJRW);	// ### TFS 54564 (54374) 17Aug2022 NAVPW1
	self.setOrgCode(_orgCode);											//navra1 - TFS 57086 - 28th Apr2023
	self.setInterTerminalCode(_interterminalCode);						//navra1 - TFS 57086 - 28th Apr2023	
	
	self.myTerminal := _myTerminal;
	self.myDebtor := _myDebtor;

epilog

end;</source>
