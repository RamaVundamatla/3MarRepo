        <source>setYAAutoPlanToNull() updating;
// Set YAAutoPlan cmif to null and do not delete an existing value 
// PAR 26671
begin
	self.myCMIFYAAutoPlan := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="sourceTIForBestPickDirector" id="c31a9de8-762f-43f0-bd55-6a5ef40e6ba5">
        <updating/>
        <source>sourceTIForBestPickDirector( _task : CM_RTQueueTask) : CM_TrackedItem updating ; 

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2011	cnwrd1	Initial creation

*/

vars
	foundTI : CM_TrackedItem;
	cmifRequest: CMIF_YAAutoPlan;
	strategy: Integer;
	request : CM_Request;
	terminal : CM_Terminal;
	aTA 	: CM_TerminalArea;
	sourceLocn : CM_LocationsController;
begin

	request := _task.myEntry.myWorkListEntry.myRequest;
	
	terminal := request.myTerminal;
	
	sourceLocn := _task.getSourceLocation();
	aTA := sourceLocn.getMyTerminalArea();
	
	//we should have a TA here now.
	
	//if it is a non gridded:
	//check for a free TI
	//if gridded
	//check though rows/colums
	
	if request = null then
		app.raiseCMException2(AutoPlanningYAError, null, 'request has not been specified', null, null);
		return null;
	endif;

	self.sharedLock(request);
	
	self.initialiseForRequest(terminal, request.myJob);
	
	cmifRequest := self.myCurrentCMIFYAAutoPlan;
	if request.isKindOf(CM_DeliveryRequest) then
		cmifRequest.CMIF_YARequest.initializeFromDeliveryRequest(terminal, request.CM_DeliveryRequest);
	elseif request.isBulkRelease then
		cmifRequest.CMIF_YARequest.initializeFromBulkRelease(terminal, request);
	endif;
	
	
	foundTI := aTA.getAvailableMatchingTI(cmifRequest.CMIF_YARequest, _task, null);
	//jlier1 tfs 51580 16/9/21
	if foundTI &lt;&gt; null then
		cmifRequest.allFoundTis.add(foundTI);
	endif;
	
	return foundTI;

epilog
	delete cmifRequest;
end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="sourceTisForRequestYA" id="d6e95efa-f73b-4309-a5f3-c1a0ead4bdf7">
        <updating/>
        <source>sourceTisForRequestYA(_terminal : CM_Terminal; _request : CM_Request) : Boolean updating;
// -------------------------------------------
// Created 01 April 2005 by cnwdvb1
// -------------------------------------------
// This method should be called from the Portschema method sourceTisForRequestYA
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 07/04/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - stop bulk planning from using best pick
// 06/11/2014	cnwdap1		PAR #35092 Should not be doing best pick when we're uaot planning, this should only
// 							be done from the "Accept" in the vehicle mounted app
vars
	result: Boolean;
	cmifRequest: CMIF_YAAutoPlan;
	strategy: Integer;
	cargoType : CM_CargoType;
	isNonContainer : Boolean;
	isBulk : Boolean;							// PAR #33606
begin

	if _request = null then
		app.raiseCMException2(AutoPlanningYAError, null, 'request has not been specified', null, null);
		return false;
	endif;

	self.sharedLock(_request);
	
	self.initialiseForRequest(_terminal, _request.myJob);
	
	cmifRequest := self.myCurrentCMIFYAAutoPlan;
	if _request.isVoyageAllocDirector() then //cnwrd1 ccms 1303 14.11.2012
		cmifRequest.CMIF_YARequest.setMyAllocation(_terminal, _request.getFirstAllocation() );
		cargoType := cmifRequest.CMIF_YARequest.myCargoType;			
	elseif _request.isKindOf(CM_DeliveryRequest) then
		cmifRequest.CMIF_YARequest.initializeFromDeliveryRequest(_terminal, _request.CM_DeliveryRequest);
		cargoType := cmifRequest.CMIF_YARequest.myCargoType;	//02 Jul 2012	NDL	Par 29660
	elseif _request.isBulkRelease then
		cmifRequest.CMIF_YARequest.initializeFromBulkRelease(_terminal, _request);
		cargoType := cmifRequest.CMIF_YARequest.myCargoType;	//02 Jul 2012	NDL	Par 29660
	endif;
	
	//02 Jul 2012	NDL	Par 29660
	if cargoType &lt;&gt; null then
		isNonContainer := not ( cargoType = app.myRoot.allCargoTypesById[TI_CargoType_Container] );
		isBulk := cargoType.isBulkProduct;																// PAR #33606
	endif;
	
	//cnwrd1 par 32041 bulk release by type with assigned cargo should go here
	if self.isBulkReleaseBTAssignedCargo(_request) then
		self.addLogEntry(AP_Log_YA_Default,'Using Cargo assigned to Bulk Release only', false); // 02 Sep 2014	NDL
		result := self.searchOnsiteBulkReleaseAlloc(_request);	//cnwrd1 par 33213
	endif;	
	//elseif _terminal.isAutoPlanUseBestPickDirector then												// PAR #33606
	//elseif _terminal.isAutoPlanUseBestPickDirector and not isBulk then								// PAR #33606	// PAR #35092
	// need to do the onsite search here																				// PAR #35092
	// but make sur we either use a specified TA if we have one or down to the bay/row if specified						// PAR #35092
	//	self.addLogEntry(AP_Log_YA_Default,'Use Best Pick for director task (Terminal Config)', false);					// PAR #35092
	//	//we may have a CM_GridObject attached to the request via the sourceLocation we need to look at that			// PAR #35092
	//	result := self.searchOnsiteBestPick(_terminal);																	// PAR #35092
	if not result then
//		elseif 
		if	cmifRequest.isFull or isNonContainer then	//02 Jul 2012	NDL	Par 29660
			if isNonContainer then//02 Jul 2012	NDL	Par 29660
				self.addLogEntry(AP_Log_YA_Default,'NON Container - YA', false);
			else
				self.addLogEntry(AP_Log_YA_Default,'Full Release Strategy - YA', false);
			endif;
			result := self.searchAllocationsOut(_terminal, cmifRequest.CMIF_YARequest.allTerminalAreas.first);
		else
			// PAR 23677 Use YA or Onsite Mt Dict depending on config setting
			strategy := _terminal.getAutoPlanMTReleaseStrategy;
			if strategy = AutoPlanMTRelStrategyYA or strategy = AutoPlanMTRelStrategyBoth then
				self.addLogEntry(AP_Log_YA_Default,'Use Mt Release Strategy - YA', false);
				result := self.searchAllocationsOut(_terminal, cmifRequest.CMIF_YARequest.allTerminalAreas.first);
			endif;
			
			if strategy = AutoPlanMTRelStrategyTerminal or (strategy = AutoPlanMTRelStrategyBoth and not result) then
				// Use the onsite dict to find area
				self.addLogEntry(AP_Log_YA_Default,'Use Mt Release Strategy - Terminal', false);
				result := self.searchOnsite(_terminal);
			endif;

		endif;
	endif;
	
	//11 Jan 2012	NDL	Par 28953
	if not result and not _request.isTransient then
		self.alertOverride := true;
		self.setHadError(true);
		self.createLoggingAlert();
	endif;
	
	return result;
	
epilog
	executeWhen JMTDevelopmentEnvironment;
		if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
			app.writeStatement(self.getLoggingString);
		else
			app.writeStatement("self.myCurrentCMIFYAAutoPlan = null, nothing found.");
		endif;
	endExecuteWhen;

	if _request &lt;&gt; null then
		self.unlock(_request);
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testAutoplanForDeliverReqYA" id="04bf877e-c40a-4e4e-8065-25813609fdd5">
        <updating/>
        <source>testAutoplanForDeliverReqYA( _terminal : CM_Terminal; _reserve : CM_DeliveryRequest ) :Boolean updating;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/

vars

	result: Boolean;
	cmifRequest: CMIF_YAAutoPlan;
	strategy: Integer;
	cargoType : CM_CargoType;
	isNonContainer : Boolean;
	isBulk : Boolean;

begin

	if _reserve = null then
		app.raiseCMException2(AutoPlanningYAError, null, 'reserve details has not been specified', null, null);
		return false;
	endif;
	
	self.sharedLock(_reserve);
	
	self.initialiseForRequest(_terminal, null);
	
	cmifRequest := self.myCurrentCMIFYAAutoPlan;
	cmifRequest.CMIF_YARequest.initializeFromDeliveryRequest(_terminal, _reserve);
	cargoType := cmifRequest.CMIF_YARequest.myCargoType;
	
	if cargoType &lt;&gt; null then
		isNonContainer := not ( cargoType = app.myRoot.allCargoTypesById[TI_CargoType_Container] );
		isBulk := cargoType.isBulkProduct;															
	endif;
	
	if	cmifRequest.isFull or isNonContainer then	
		if isNonContainer then
			self.addLogEntry(AP_Log_YA_Default,'NON Container - YA', false);
		else
			self.addLogEntry(AP_Log_YA_Default,'Full Release Strategy - YA', false);
		endif;
		result := self.searchAllocationsOut(_terminal, cmifRequest.CMIF_YARequest.allTerminalAreas.first);
	else
		// PAR 23677 Use YA or Onsite Mt Dict depending on config setting
		strategy := _terminal.getAutoPlanMTReleaseStrategy;
		if strategy = AutoPlanMTRelStrategyYA or strategy = AutoPlanMTRelStrategyBoth then
			self.addLogEntry(AP_Log_YA_Default,'Use Mt Release Strategy - YA', false);
			result := self.searchAllocationsOut(_terminal, cmifRequest.CMIF_YARequest.allTerminalAreas.first);
		endif;
		
		if strategy = AutoPlanMTRelStrategyTerminal or (strategy = AutoPlanMTRelStrategyBoth and not result) then
			// Use the onsite dict to find area
			self.addLogEntry(AP_Log_YA_Default,'Use Mt Release Strategy - Terminal', false);
			result := self.searchOnsite(_terminal);
		endif;
	endif;

	self.createLoggingAlert();	//	TFS 3172 12/1/17 moved from separate calls in searchAllocationsOut and searchOnsite
	
	return result;

epilog

	executeWhen JMTDevelopmentEnvironment;
		if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
			app.writeStatement(self.getLoggingString);
		else
			app.writeStatement("self.myCurrentCMIFYAAutoPlan = null, nothing found.");
		endif;
	endExecuteWhen;

	if _reserve &lt;&gt; null then
		self.unlock(_reserve);
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reserve" type="CM_DeliveryRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testAutoplanForReserveYA" id="e0e5b771-86e0-42bc-b6d1-d33e160eeb57">
        <updating/>
        <source>testAutoplanForReserveYA( _terminal : CM_Terminal; _reserve : CM_ReserveSelection ) :Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	result: Boolean;
	cmifRequest: CMIF_YAAutoPlan;
	strategy: Integer;
	cargoType : CM_CargoType;
	isNonContainer : Boolean;
	isBulk : Boolean;

begin

	if _reserve = null then
		app.raiseCMException2(AutoPlanningYAError, null, 'reserve details has not been specified', null, null);
		return false;
	endif;
	
	self.sharedLock(_reserve);
	
	self.initialiseForRequest(_terminal, null);
	
	cmifRequest := self.myCurrentCMIFYAAutoPlan;
	cmifRequest.CMIF_YARequest.initializeFromReserveDetails(_terminal, _reserve);
	cargoType := cmifRequest.CMIF_YARequest.myCargoType;
	
	if cargoType &lt;&gt; null then
		isNonContainer := not ( cargoType = app.myRoot.allCargoTypesById[TI_CargoType_Container] );
		isBulk := cargoType.isBulkProduct;															
	endif;
	
	if	cmifRequest.isFull or isNonContainer then	
		if isNonContainer then
			self.addLogEntry(AP_Log_YA_Default,'NON Container - YA', false);
		else
			self.addLogEntry(AP_Log_YA_Default,'Full Release Strategy - YA', false);
		endif;
		result := self.searchAllocationsOut(_terminal, cmifRequest.CMIF_YARequest.allTerminalAreas.first);
	else
		// PAR 23677 Use YA or Onsite Mt Dict depending on config setting
		strategy := _terminal.getAutoPlanMTReleaseStrategy;
		if strategy = AutoPlanMTRelStrategyYA or strategy = AutoPlanMTRelStrategyBoth then
			self.addLogEntry(AP_Log_YA_Default,'Use Mt Release Strategy - YA', false);
			result := self.searchAllocationsOut(_terminal, cmifRequest.CMIF_YARequest.allTerminalAreas.first);
		endif;
		
		if strategy = AutoPlanMTRelStrategyTerminal or (strategy = AutoPlanMTRelStrategyBoth and not result) then
			// Use the onsite dict to find area
			self.addLogEntry(AP_Log_YA_Default,'Use Mt Release Strategy - Terminal', false);
			result := self.searchOnsite(_terminal);
		endif;
	endif;

	self.createLoggingAlert();	//	TFS 3172 12/1/17 moved from separate calls in searchAllocationsOut and searchOnsite
	
	return result;

epilog

	executeWhen JMTDevelopmentEnvironment;
		if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
			app.writeStatement(self.getLoggingString);
		else
			app.writeStatement("self.myCurrentCMIFYAAutoPlan = null, nothing found.");
		endif;
	endExecuteWhen;

	if _reserve &lt;&gt; null then
		self.unlock(_reserve);
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reserve" type="CM_ReserveSelection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testCellSuitabilityForTI" id="cabb1d79-a35a-420d-89ab-8522b9847469">
        <updating/>
        <source>testCellSuitabilityForTI(_locationCell :  CM_YALocationCell; _yaBlock : CM_YABlock ) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars
	yardController,
	nextYardController : CM_YardController;
	rtnValue : Boolean;
	nextLocationCell 	: CM_YALocationCell;
	isLastCell			: Boolean;
	posTICurrentYard,
	posTIsNextYard 	: Integer;
	twinFoundAllocation : CM_YardAllocation;
	gridController	: CM_GridController;
begin

	yardController := _locationCell.myYardController;
	isLastCell:= _locationCell.height = yardController.allYAYardLocationCells.size;
	rtnValue:=false;
	if _locationCell.testCellSuitabilityForTi(self,_yaBlock) then
		if self.isForTwinDeck() or self.agentUsage = self.Scenario_Twin then
			if yardController.isKindOf(CM_GridController) then

				nextYardController:=yardController.CM_GridController.myNextController;
				if nextYardController = null then
					self.addToFailedLocations(yardController);
					return false;
				endif;
				
				nextLocationCell:=nextYardController.allYAYardLocationCells[_locationCell.height];
				// question is how to test this 
				if nextLocationCell = null then	
					self.addLogEntry(AP_Log_YA_Default,"No next location at stack height " &amp; _locationCell.height.asStringJMT,true);
					self.addToFailedLocations(yardController);	
					return false;
				endif;	
			

				posTICurrentYard:=yardController.numTIs + yardController.getAllPickedUpQueuedMoves(null);
				//oops 
				if posTICurrentYard &lt;&gt; _locationCell.height - 1 then
					if isLastCell then
						self.addToFailedLocations(yardController);
					endif;
					return false;
				endif;
				
				posTIsNextYard:=nextYardController.numTIs + nextYardController.getAllPickedUpQueuedMoves(null);
				if posTIsNextYard &lt;&gt; _locationCell.height - 1 then
					if isLastCell then
						self.addToFailedLocations(yardController);
					endif;
					return false;
				endif;				
						
				
				
				if  self.agentUsage = self.Scenario_Twin then
					rtnValue:=true;
				else
					//self.setCurrentYAAutoPlan(self.myLinkedYAAutoPlan);
					self.useLinkedYAAutoPlan(true);    // PAR 26856
					if not nextLocationCell.testCellSuitabilityForTi(self,_yaBlock) then
						if isLastCell then
							self.addToFailedLocations(yardController);
						endif;
						//self.setCurrentYAAutoPlan(self.myCMIFYAAutoPlan);
						self.useLinkedYAAutoPlan(false);    // PAR 26856
						if isLastCell then
							self.removeFromPassedLocations(yardController);
							self.addToFailedLocations(yardController);
						endif;
					else
						rtnValue:=true;
					endif;
				endif;
			else
				return true;
			endif;
		else
			//ccms 1025 epr 22/12/09
			if _yaBlock.useSideAccessRules then
		
				if yardController.isKindOf(CM_GridController) then
					gridController:=yardController.CM_GridController;
					if 	_yaBlock.isSideAccessRestricted(gridController,self.myCurrentCMIFYAAutoPlan.getMyTrackedItem, self.isOnlyCheckRealCargo) then   // 25813
						self.addLogEntry(AP_Log_YA_Default,"Side Access is restricted",true);
						return false;
					endif;
				endif;
			endif;
			rtnValue:= true;
		endif;		
	endif;	
	
	return rtnValue;
epilog
	//self.setCurrentYAAutoPlan(self.myCMIFYAAutoPlan);
	self.useLinkedYAAutoPlan(false);    // PAR 26856
end;</source>
        <Parameter name="_locationCell" type="CM_YALocationCell"/>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testPlanLockException" id="9fd1027f-a798-4891-af99-91cfb398771d">
        <source>testPlanLockException( _exc : Exception ) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwndl1	Initial creation	Par 27362

*/

vars

begin

	if LockException.hasInstance( _exc ) or DeadlockException.hasInstance( _exc ) then
		abortTransientTransaction;
		abortTransaction;
		app.msgBox(app.getErrorString(Objects_locked) &amp; CrLf
					&amp; app.getErrorString(Test_auto_plan_aborted), app.getErrorString(Warning), MsgBox_OK_Only);
		return Ex_Abort_Action;
	endif;
	
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testYardLocation" id="07031b78-83b1-4f9d-8076-c874c1710d69">
        <updating/>
        <source>testYardLocation(_locationCell : CM_YALocationCell) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars
	nextYardController,
	yardController 		: CM_YardController;
	rtnValue 			: Boolean;
	heightTICurrentYard,
	heightTINextYard 	: Real;
	ycFullId			: String;
begin
	yardController := _locationCell.myYardController;
	rtnValue 		:= false;
	
	if not yardController.testLocationYA(self, true) then
		// This is because some methods now add locations to failed set inside test.
		self.addToFailedLocations(yardController);
		
	else
		ycFullId := yardController.getFullId();
		
		if self.isForTwinDeck or self.agentUsage = self.Scenario_Twin then
			if yardController.isKindOf(CM_GridController) then
				//need to test if this yard controller can be twin carried to
				if not yardController.CM_GridController.canTwinLiftWithNextController then
					self.addLogEntry(AP_Log_YA_Default,ycFullId &amp;  " can not twin lift with next location", true);
					self.addToFailedLocations(yardController);
					return false;
				endif;
			
				nextYardController:=yardController.CM_GridController.myNextController;
				if nextYardController = null then
					self.addLogEntry(AP_Log_YA_Default,ycFullId &amp;  " can not twin lift because next location is null", true);
				
					self.addToFailedLocations(yardController);
					return false;
				else					
					if not nextYardController.CM_GridController.canTwinLiftWithPrevController then
						self.addLogEntry(AP_Log_YA_Default,"Next location " &amp; ycFullId &amp;  " can not twin lift with previous location", true);
				
						self.addToFailedLocations(yardController);
						return false;
					endif;
				
					heightTICurrentYard:=yardController.CM_GridController.getActualHeight  + yardController.getActualHeightOfPickupQdMoves(null);
					heightTINextYard:=nextYardController.CM_GridController.getActualHeight + nextYardController.getActualHeightOfPickupQdMoves(null);
				
					if heightTICurrentYard &lt;&gt;  heightTINextYard then
						self.addLogEntry(AP_Log_YA_Default,"Height of  " &amp; ycFullId &amp;  " " &amp; heightTICurrentYard.asStringJMT  &amp;" is different to the next locations height of " &amp; heightTINextYard.asStringJMT, true);
						self.addToFailedLocations(yardController);
						return false;	
					endif;
					//epr par 20017 19/6
					if  self.agentUsage &lt;&gt; self.Scenario_Twin then
						self.useLinkedYAAutoPlan(true);    // PAR 26856
						self.addLogEntry(AP_Log_YA_Default,'Testing location for twin container ' &amp; nextYardController.getFullId(), true);
						if not nextYardController.testLocationYA(self, true) then
							// This is because some methods now add locations to failed set inside test.
							self.addToFailedLocations(yardController);
							return false;
						endif;
					endif;
					
				endif;						
			endif;	
		
		endif;
		
		self.myCMIFYAAutoPlan.allPassedLocations.add(yardController);
		rtnValue:=true;
	endif;
	
	return rtnValue;
epilog
	//make sure  this is the first tracked item;
	self.useLinkedYAAutoPlan(false);    // PAR 26856
end;</source>
        <Parameter name="_locationCell" type="CM_YALocationCell"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="useLinkedYAAutoPlan" id="340df690-b2a0-42d8-9555-a3c5eefe0e5b">
        <updating/>
        <source>useLinkedYAAutoPlan(mode: Boolean) updating;
//03 February 2011	cnwdw1	
//
begin
	if mode then
		self.myCurrentCMIFYAAutoPlan := self.myLinkedYAAutoPlan;
	else
		self.myCurrentCMIFYAAutoPlan := self.myCMIFYAAutoPlan;
	endif;
end;</source>
        <Parameter name="mode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="7fced2ba-093f-4e70-93b1-76161c97283e">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -------------------------------------------
// Created 15 March 2005 by cnwdvb1
// -------------------------------------------
vars

	termEvent		: Integer;
	term			: CM_Terminal;
	cmifTerminal	: CMIF_YATerminal;

begin

	if not theObject.isKindOf(CM_Terminal) then
		return;
	endif;
	
	term := theObject.CM_Terminal;
		
	termEvent := term.getEventFromTerminalEvent(eventType);
	if termEvent = EVENT_YA_CP_UPDATE  then
		cmifTerminal := self.getCMIFTerminal(term);
		if cmifTerminal = null then
			self.initTerminal(term);
		else
			self.resetCMIFTerminal(cmifTerminal);
		endif;
	endif;


end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateTiForLocation" id="15440f14-1efb-4864-a331-88004455ae4e">
        <updating/>
        <source>validateTiForLocation(_yardController : CM_YardController; _ti : CM_TrackedItem) : Boolean updating;
// -------------------------------------------
// Created 10 June 2005 by cnwdvb1
// -------------------------------------------
/*
Date		Who		Reason
29 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
03 Jun 2025 navhl20	Bug MTN-34993 - HAT - Error 1081 when Updating RTQ Task Target Location
*/
vars

	allocation 			: CM_YardAllocation;
	rtnValue			: Boolean;
	tiId 				: String;
	yaFullId 			: String;
	warning_allocation 	: CM_YardAllocation;
	noMatchCount 		: Integer;
	matchFound 			: Boolean;
	toHeightPosition 	: Integer;
	maxHeight 			: Integer;
	minHeight 			: Integer;
	isBlockStack 		: Boolean;	//27 Mar 2012	NDL	Par 29340
	
begin
	matchFound := false;
	noMatchCount := 0;
	rtnValue := true;
	// Put this on the agent for reuse.
	if self.myCMIFValidateMove = null then
		create self.myCMIFValidateMove transient;
		self.myCMIFValidateMove.raiseWarning := true;
	endif;
	self.myCMIFValidateMove.attachTI(_ti);
	
	//par 19460 cnwjo3
	//as containers are stack onto a location TIs are added to the LocationController so
	//the next height location is TIs+1
	toHeightPosition := _yardController.allTrackedItems.size() + 1;
	
	//par 19460 cnwjo3
	//the min/max heights dictate where on the vertical axis the Yard Allocation applies
	//since the current rules is that even though multiple YAs may overlap the same location
	//one YA can not overlap the same location in a Stack Controller.  I believe
	if _yardController.allYABlocks.first().isKindOf(CM_YABlockGridArea) then
		minHeight := _yardController.allYABlocks.first().CM_YABlockGridArea.minHeight;
		maxHeight := _yardController.allYABlocks.first().CM_YABlockGridArea.maxHeight;
		
		//if 0 then its the default, ie: not set, so set to the max height of cell
		if maxHeight = 0 then
			maxHeight := _yardController.allYAYardLocationCells.size();
		endif;
	else
		isBlockStack := _yardController.isKindOf(CM_BlockController);	//27 Mar 2012	NDL	Par 29340
		if not isBlockStack then	//04 Sep 2012	NDL	Par 30192
			isBlockStack := _yardController.isKindOf(CM_IrregularBlockController);	
		endif;
	endif;
	
	//par 18834 cnwjo3
	//if any allocation or any overlapped allocation have 'allow other' == Never then ERROR and abort warning check
	//i could nest this inside the below code but might actually make it hard to debug.  so won't be
	
	self.myCMIFValidateMove.raiseWarning := false;  //don't raise warning in compareCriteriaToCMIF
	
	foreach allocation in _yardController.allYardAllocations discreteLock where (not allocation.isDisabled and allocation.includeInYardDisplays()) do
	
		//is the position we are placing TI relevant to this YA
	//	if toHeightPosition &gt;= minHeight and toHeightPosition &lt;= maxHeight then
		if isBlockStack or ( toHeightPosition &gt;= minHeight and toHeightPosition &lt;= maxHeight ) then	//27 Mar 2012	NDL	Par 29340
		
			//if height of primary location is in range of block min/max height check criteria,
			//else ignore because we moving to place where allocation is not set.  kind of
			// MTN - 34993 Changes the order to improve performance
			if allocation.allowOthersOption = YAOverlap_Never then																	//03.06.2025 navhl20 #34993
				if not allocation.compareCriteriaToCMIF(null, self.myCMIFValidateMove) then											//03.06.2025 navhl20 #34993
					app.raiseCMException3(WARN_TI_NOTMATCH_ALLOCATION_AT, _ti.id, allocation.code, _yardController.getFullId(), null, allocation);
					rtnValue := false;
				endif;
			endif;
		endif;
	endforeach;
	
	// CCMS 1013
	//foreach allocation in _yardController.allYardAllocations discreteLock where not allocation.isDisabled do
	if not app.myPassport.hasErrors()then
		foreach allocation in _yardController.allYardAllocations discreteLock where (not allocation.isDisabled and allocation.includeInYardDisplays()) do
			//is the position we are placing TI relevant to this YA
			//if toHeightPosition &gt;= minHeight and toHeightPosition &lt;= maxHeight then
			if isBlockStack or ( toHeightPosition &gt;= minHeight and toHeightPosition &lt;= maxHeight ) then	//27 Mar 2012	NDL	Par 29340
				if not allocation.compareCriteriaToCMIF(null, self.myCMIFValidateMove) then
				
					//no need to display warning on every invalid match since we are only going to display 1 warning
					//and only if there are no matching allocations to the TI
					//app.raiseCMWarning3(WARN_TI_NOTMATCH_ALLOCATION_AT, _ti.id, allocation.code, _yardController.getFullId(), null, null, allocation);
					
					rtnValue := false;
					
					//setup for 1 warning
					tiId := _ti.id;
					yaFullId := _yardController.getFullId();
					warning_allocation := allocation;
					noMatchCount := noMatchCount + 1;
				else
					matchFound := true;
				endif;
			endif;
		endforeach;
		
		if rtnValue = false and not matchFound then
			app.raiseCMWarning3(WARN_TI_NOTMATCH_ALLOCATION_AT, _ti.id, warning_allocation.code, yaFullId, null, null, warning_allocation);
		endif;
	endif;
	
	return rtnValue;

end;</source>
        <Parameter name="_yardController" type="CM_YardController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTwins" id="1fb240d2-37b9-4d5b-af12-5add3fffa2d4">
        <source>validateTwins(  _ti, _twinTi : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2011	cnwndl1	Initial creation	Par 28112

*/

vars

begin

		//do some basic checks before we start the overhead of auto planning
	if _ti = null or _twinTi = null then
		// Raise exception.
		app.raiseCMException(AutoPlanningYAError_NULL, null, null);//11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	//check both tis iso types are twin lift capable
	if not _ti.isTwinLiftCapable then
		// Raise exception.
		app.raiseCMException1(ERR_Failed_Autoplan_ISOType, _ti.id, null, null);//11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	if not _twinTi.isTwinLiftCapable then
		app.raiseCMException1(ERR_Failed_Autoplan_ISOType, _twinTi.id, null, null);//11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	//check if one is overDimension then can not be twin lifted
	
	if _ti.isOverDimensions  then
		app.raiseCMException1(ERR_Failed_Autoplan_Dimension, _ti.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	if _twinTi.isOverDimensions  then
		app.raiseCMException1(ERR_Failed_Autoplan_Dimension, _twinTi.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	//check the physical height PAR 19140
	
	if _ti.getActualHeight &lt;&gt; _twinTi.getActualHeight then
		app.raiseCMException2(ERR_Failed_Autoplan_Height, _ti.id, _twinTi.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;
	
	
	//check the hazardous details
	
	//we can assume that if one of the containers have haz that are required to be in a seperate ta to the other then return
	
	//like wise if both have any seperation defined then abort since they will be next to each other
	
	if not _ti.valHazSegregation(_twinTi,Segregation_Type_Yard,1,1,0,true,true,true) then
		app.raiseCMException2(ERR_Failed_Autoplan_Hazardous, _ti.id, _twinTi.id, null, null); //11/09/2009 cnwdz2 par20436
		return false;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_twinTi" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xLockHandler" id="7af9db52-baa6-47a9-ac8e-1461143f0fd1">
        <source>xLockHandler(le :LockException) : Integer protected;
// -------------------------------------------
// Created 15 March 2005 by cnwdvb1
// -------------------------------------------
vars

	lockedByUserCode	: String;
 	retryCount			: Integer;
 	
begin
 	if global.isValidObject(le.targetLockedBy) then	// locking process could have gone away  
 		lockedByUserCode := le.targetLockedBy.userCode;
 		if lockedByUserCode = '' then
 			lockedByUserCode := 'not available';
 		endif;
 	endif;

 	while not tryLock(le.lockTarget, le.lockType, le.lockDuration, 1000) do
 		retryCount := retryCount + 1;
 		if retryCount &gt; 10 then	
 			app.writeLog('INFO &gt;&gt; Alert lock exception generated (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
			app.writeLogLockException(le);
 			return Ex_Pass_Back;	// let another handler deal with it
 		endif;
 	endwhile;

 	return Ex_Continue;				// must have the lock if we get to here

end;</source>
        <access>protected</access>
        <Parameter name="le" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
