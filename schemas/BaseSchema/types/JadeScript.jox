    <JadeMethod name="cnwdad1_List_Property_Values" id="19c455b5-bbf2-4a4d-b21d-06129bc384b1">
        <source>cnwdad1_List_Property_Values(pObject:Object);
// --------------------------------------------------------------------------------
// Created:		25 February 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyObj			: Property;
	allPropertiesObj	: PropertyColl;
	propValue			: Any;
	
begin
	allPropertiesObj	:=	pObject.class.allProperties();
	
	foreach propertyObj in allPropertiesObj do
		propValue	:=	pObject.getPropertyValue(propertyObj.name);
		write propValue;
	endforeach;
epilog
	delete allPropertiesObj;
end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
