    <JadeMethod name="doResizeControls" id="6cbbcc07-b6f0-452f-a449-d95df26a1fd3">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/


vars

	
	stdLeft : Real;
	cTop : Real;
	stdWidth : Real;
	stdHeight : Real;
	
	tblLeft : Real;
	tblHeight : Real;
	
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	cTop := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.lblDamageFor.setAndIncrementTabIndex( tabIndex );
		self.lblDamageFor.visible := true;
	endif;
	self.lblDamageFor.move(	stdLeft,
							cTop,
							stdWidth,
							stdHeight );
	
	cTop := self.lblDamageFor.top + lblDamageFor.height + self.resizedMargin;
	tblHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	tblLeft := 1;
	
	if _initialSetup then
		self.tblDamage.setAndIncrementTabIndex( tabIndex );
		self.tblDamage.visible := true;
	endif;
	self.tblDamage.move(	tblLeft,
							cTop,
							stdWidth,
							tblHeight );
	
							
	if _initialSetup then
		self.tblDamage.parentAspect:=Table.ParentAspect_StretchBoth;
		self.tblDamage.init;
	endif;
	
	self.tblDamage.cnAdjustColumnWidths();

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="50413dca-0e72-46cb-954a-cab9941ceae4">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwndl1	Initial creation

*/

constants
	Bullet = 149;
vars
	itemID : String;
	itemType : String;
begin

	itemID := self.myMobileGenericAgent.myCurrentWagon.id;
	itemType := app.getErrorString(RAILHHHELP_WAGON);

	return app.getErrorString2(RAILHHHELP_DAM001, itemType, itemID) &amp; CrLf  &amp; CrLf &amp; 
			//Enter damage details for %1 %2.
			Bullet.Character &amp; " " &amp; app.getErrorString1(RAILHHHELP_DAM002, itemType)   &amp; CrLf  &amp; 
			// Pos. This is the damage position on the %1.
			Bullet.Character &amp; " " &amp; app.getErrorString1(RAILHHHELP_DAM003, itemType) &amp; CrLf  &amp; 
			// Damage. This is the damage type for the %1.
			Bullet.Character &amp; " " &amp; app.getErrorString1(RAILHHHELP_DAM004, itemType);
			// Severity. This how bad the damage is on the %1.
			

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
