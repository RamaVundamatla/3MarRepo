/*
Purpose:			

Date		Who		Reason
05 July 2023	navab1	 
*/

vars

	type,
	remaining		: Integer;
	
begin
	if self.getTimerStatus(self.Timer_TableData_Filter, type, remaining) then
		self.endTimer(self.Timer_TableData_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_TableData_Filter);


epilog

end;</source>
