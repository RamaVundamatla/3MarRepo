    <JadeMethod name="getAllPackingText" id="dd447267-d4f0-47e9-a3fd-2b3eb7332ffa">
        <source>getAllPackingText(_packingCodes: StringArray io);

vars

begin
	_packingCodes.add(BAGS);
	_packingCodes.add(BALES);
	_packingCodes.add(BARREL);
	_packingCodes.add(BOX);
	_packingCodes.add(BULK);
	_packingCodes.add(BUNDELS);
	_packingCodes.add(CANS);
	_packingCodes.add(CARTONS);
	_packingCodes.add(CASES);
	_packingCodes.add(COILS);
	_packingCodes.add(CRATES);
	_packingCodes.add(CYLINDER);
	_packingCodes.add(DRUMS);
	_packingCodes.add(KEGS);
	_packingCodes.add(LOTS);
	_packingCodes.add(NUMBERS);
	_packingCodes.add(PACKAGE);
	_packingCodes.add(PALETS);
	_packingCodes.add(PARCEL);
	_packingCodes.add(PIECES);
	_packingCodes.add(REEL);
	_packingCodes.add(ROLLS);
	_packingCodes.add(SET);
	_packingCodes.add(SHEETS);
	_packingCodes.add(SKD);
	_packingCodes.add(SKIP);
	_packingCodes.add(UNITS);
	_packingCodes.add(VARIOUS);
	_packingCodes.add(WOODENBOX);

epilog

end;</source>
        <Parameter name="_packingCodes" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllUnassignedTis" id="29457bbc-b0c1-4dca-90c4-4582a97954a7">
        <source>getAllUnassignedTis(_terminal: CM_Terminal; _tis: CM_TISet input);
/*
	Return a list of all Duty Doc Items Tis that are not assigned to a Duty Doc (32036)	
*/
vars
	dutyDocRoot			: CM_DutyDocRoot;
	dutyDocTerminalRoot :CM_DutyDocTerminalRoot;
	dutyDocItem 	: CM_DutyDocItem;
begin
	dutyDocRoot:=app.myDutyDocRoot;
	if dutyDocRoot = null then
		return;
	endif;
	
	dutyDocTerminalRoot:=dutyDocRoot.allDutyDocTerminalRoots[_terminal];
	if dutyDocTerminalRoot  = null then
		return;
	endif;

	foreach dutyDocItem in dutyDocTerminalRoot.allDutyDocItems do
		if dutyDocItem.isUnassigned and dutyDocItem.getMyTrackedItem &lt;&gt; null then
			if not _tis.includes(dutyDocItem.getMyTrackedItem) then
				_tis.add(dutyDocItem.getMyTrackedItem);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDutyDocItemsUnassigned" id="2a9e5595-31c7-4de9-ae58-68fd8a8e7c11">
        <updating/>
        <source>getDutyDocItemsUnassigned(_ti: CM_TrackedItem; _dutyDocItems: CM_DutyDocItemSet input) updating;
// Get a set of duty doc items that have not been assigned
vars
	dutyDocRoot			: CM_DutyDocRoot;
	dutyDocTerminalRoot :CM_DutyDocTerminalRoot;
	dutyDocItem 	: CM_DutyDocItem;
	iter 			: Iterator;
begin

	dutyDocRoot:=app.myDutyDocRoot;
	if dutyDocRoot = null then
		return;
	endif;
	
	dutyDocTerminalRoot:=dutyDocRoot.allDutyDocTerminalRoots[_ti.myTerminal];
	if dutyDocTerminalRoot  = null then
		return;
	endif;
	
	iter:=dutyDocTerminalRoot.allDutyDocItemsByTI.createIterator;
	
	dutyDocTerminalRoot.allDutyDocItemsByTI.startKeyGeq(_ti,iter);
	while iter.next(dutyDocItem) do
		if dutyDocItem.getMyTrackedItem &lt;&gt; _ti then
			break;
		endif;
		if dutyDocItem.myDutyDoc &lt;&gt; null then
			continue;
		endif;
		_dutyDocItems.add(dutyDocItem);
	endwhile;
	
	return;
epilog
	delete iter;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_dutyDocItems" type="CM_DutyDocItemSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPackingCode" id="9f4a6f17-585a-4de9-b346-1414a5d59294">
        <source>getPackingCode(_id: Integer): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2013	cnwdw1	Initial creation
*/
vars
	text: String;
	pos: Integer;
begin
	text := self.getPackingText(_id);
	if text &lt;&gt; null then
		pos := text.pos(" - ", 1);
		return text[pos+3:end];
	endif;
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPackingId" id="47fedc63-cb8e-4887-905a-394de9fdf51d">
        <source>getPackingId(_code: String) : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2013	cnwdw1	Initial creation
*/
vars

begin
	if _code = BAGS then
		return 1;
	endif;
	if _code = BALES then
		return 2;
	endif;
	if _code = BULK then
