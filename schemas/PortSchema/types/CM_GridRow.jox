    <JadeMethod name="isGap" id="4eddca16-399b-40fc-81f1-e48a195e3005">
        <source>isGap() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpGridController : CM_GridController;
begin
	
	
	foreach tmpGridController in self.allControllersByColumn do
		if (not CM_GapController.hasInstance(tmpGridController)) then
			return false;
		endif;
	endforeach;

	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInUse" id="508c5aa8-6b42-4106-a4e9-ae6fcbb94eca">
        <source>isInUse(): Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aGridController : CM_GridController;
begin

	foreach aGridController in self.allControllersByColumn do
		if aGridController.hasTIs() then
			return true;
		elseif aGridController.hasRestrictions(LOCATION_RESTRICTION) then
			return true;
		elseif aGridController.hasRestrictions(LABOUR_RESTRICTION) then
			return true;
		endif;
	endforeach;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLcOnLeftEndOfRow" id="9c6e63a6-6243-4856-ad7b-cb6ad37b573e">
        <source>isLcOnLeftEndOfRow(_gc : CM_GridController) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	iter : Iterator;
	tmpDPort : String;
	tmpVoy : CM_Voyage;
	tmpGC : CM_GridController;
	tmpTI : CM_TrackedItem;
begin
	if _gc.column = 1 then
		return true;
	endif;
	
	if _gc.allTrackedItems.size = 3 then
		tmpTI := _gc.allTrackedItems[3];
		tmpDPort := tmpTI.dischargePort;
		tmpVoy := tmpTI.myVoyage;
	endif;
	
	iter := self.allControllersByColumn.createIterator();
	
	iter.startAtObject(_gc);
	
	while iter.back(tmpGC) do
		if tmpGC.allTrackedItems.size = 3 then
			tmpTI := tmpGC.allTrackedItems[3];
			if tmpTI &lt;&gt; null then
				if (tmpDPort &lt;&gt; null and tmpDPort &lt;&gt; tmpTI.dischargePort) 
				or (tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; tmpTI.myVoyage) then
					return false;
				endif;
			endif;
		endif;
	endwhile;
	
	return true;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_gc" type="CM_GridController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
