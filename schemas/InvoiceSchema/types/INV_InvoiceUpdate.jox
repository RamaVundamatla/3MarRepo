    <JadeMethod name="doCmbTermsTradeBuild" id="bcadc900-06de-4458-8075-f0a1a3f11404">
        <source>doCmbTermsTradeBuild(_debtor: CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	invTerm		: CM_InvoiceTermsOfTrade;
	rootCompany	: CM_Bank;
	
begin
	
	self.cmbTermsTrade.clear();
	
	rootCompany := app.myRoot.myRootCompany;
	
	foreach invTerm in rootCompany.allInvoiceTermsOfTrade discreteLock do
		self.cmbTermsTrade.addItemObject(invTerm.description, invTerm);
	endforeach;
	
	if _debtor &lt;&gt; null then	
		invTerm := rootCompany.allInvoiceTermsOfTrade[self.myCurrentInvoice.termsOfTradeCode];
		
		if _debtor = self.myCurrentInvoice.debtor then
			if invTerm &lt;&gt; null then
				self.cmbTermsTrade.listObject := invTerm;
				self.cmbTermsTrade.listIndex := self.cmbTermsTrade.findObject(invTerm);
			endif;
		elseif _debtor.myTermsOfTrade &lt;&gt; null then
			self.cmbTermsTrade.listObject := _debtor.myTermsOfTrade;
			self.cmbTermsTrade.listIndex := self.cmbTermsTrade.findObject(_debtor.myTermsOfTrade);
		endif;
	endif;
	self.tblInvProperties.setValueByControlName(self.cmbTermsTrade.name, self.cmbTermsTrade.text);
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="217370f5-5495-487f-9240-1dba9c5cbcd5">
        <source>doCmbVoyageBuild(_combo: CMUI_ComboBox input; _archive: Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023 navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
12 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
*/

vars
	index	: Integer;
	str		: String;
	voyage	: CM_Voyage;
begin
	inheritMethod(_combo, _archive);
	voyage	:= self.myCurrentInvoice.myVoyage;		//12.9.2023 navhl20 #59376
	if voyage &lt;&gt; null								//12.9.2023 navhl20 #59376
		and not _archive 
		and voyage.archived then
		str		:= voyage.code.trimBlanks &amp; " - " &amp; voyage.description;
		index	:= _combo.addItem(str);
		_combo.itemObject[index] := voyage;
	endif;
	_combo.listIndex	:= _combo.findObject(self.myCurrentInvoice.myVoyage); // 10/11/2023	navkc1 Bug 61004
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_archive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="a5cdb896-9031-41e8-994b-1d84d7cd520e">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
10/11/2023	navkc1 	Bug 61004: LNX - New Invoice Creation screen is multi tabbed
17/01/2023	navkc1 	Bug 61503: FR| 54086 - EUP - Invoice Maintenance - Debtor update.
*/

vars
	debtorInvType	: CM_DebtorInvType;
	pxyInvoice,
	realInvoice 	: CM_Invoice;
	theReturn 			: Integer;
	package			: CM_PackageInvoice;
	runPackage 		: Boolean;
	task			: CM_AutoTask;
	schedule		: CM_AutoSchedule;
	debtorAddress,debtorAddressAlt   : CM_Address;
	allWorkOrders	: CM_WorkOrderSet;
	ts				: TimeStamp;
	endDate			: Date;
	voyage			: CM_Voyage;
	bol				: CM_BOL;
	extFinancialID,
	extTaxNumber,
	extNumber		: String; //08/12/2025	navkc1 JIRA 36262
	
begin
	realInvoice := self.myCurrentInvoice;
	
	if realInvoice = null then 
		app.msgBox("Please select an invoice.","Invoice Update",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;
	
	// 10/11/2023	navkc1 Bug 61004
	//if self.cmbDebtorAddressProp.listObject.CM_Address &lt;&gt; null then
		debtorAddress := self.cmbDebtorAddressProp.listObject.CM_Address;
	//else
	//	debtorAddress := pxyInvoice.myBillingAddress;
	//endif;
	// 10/11/2023	navkc1 Bug 61004
	//if self.cmbDebtorAltAddrProp.listObject.CM_Address &lt;&gt; null then
		debtorAddressAlt := self.cmbDebtorAltAddrProp.listObject.CM_Address;
	//else
	//	debtorAddressAlt := pxyInvoice.myAlternativeAddress;
	//endif;
	create allWorkOrders transient;
	self.mulWorkOrder.getSelected(allWorkOrders);
	self.setMyCurrentCG();
	self.setMyCurrentTI();
	
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		endDate := self.mskCNEndDate.getDate();
	else
		endDate := self.tblInvProperties.getValueAsDate(ETRow_EndDate);
	endif;
	
	// 10/11/2023	navkc1 Bug 61004
	if self.isUsingGeneralTab then
		voyage := self.cmbVoyageGen.listObject.CM_Voyage;
		bol := self.cmbBillOfLadingGen.listObject.CM_BOL;
	else
		voyage := self.cmbVoyageInvProp.listObject.CM_Voyage;
		bol := self.cmbBillOfLading.listObject.CM_BOL;
	endif;
	
	pxyInvoice.setProxyForUpdate(	self.txtNarr.text,
									self.tblInvProperties.getValueByName(ETRow_IsZeroRated).Boolean, 
									endDate,
									self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String,
									self.tblInvProperties.getValueByName(ETRow_DebtorReference).String,
									debtorAddress,debtorAddressAlt,	//navtnr20 09-06-2023 Bug 58472
									self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade,	//14/08/2023	navkc1	Bug 59803
									self.cmbCurrencyType.listObject.CM_CurrencyType,	//14/08/2023	navkc1	Bug 59803
									self.cmbLocale.listObject.CM_Locale				//14/08/2023	navkc1	Bug 59803
									);
	
	pxyInvoice.setProxyForSeparations(voyage, // 10/11/2023	navkc1 Bug 61004
									  self.myCurrentTI,
									  bol, // 10/11/2023	navkc1 Bug 61004
									  self.myBookingRef,
									  self.myCurrentCargoGroup,
									  self.myReleaseRequest,
									  //self.cmbWorkOrder.listObject.CM_WorkOrder
									  allWorkOrders	//navtnr20 31-05-2023 TFS 58089
									  );
	
	extFinancialID := self.tblInvProperties.getValueByName(ETRow_ExternalFinancialID).String; //08/12/2025	navkc1 JIRA 36262
	extTaxNumber := self.tblInvProperties.getValueByName(ETRow_ExternalTaxNumber).String; //08/12/2025	navkc1 JIRA 36262
	extNumber := self.tblInvProperties.getValueByName(ETRow_ExternalNumber).String; //08/12/2025	navkc1 JIRA 36262
	
	pxyInvoice.setExternalRefFields(extFinancialID, extTaxNumber, extNumber); //08/12/2025	navkc1 JIRA 36262
	
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		//pxyInvoice.debtor := self.cmbDebtorInvProp.listObject.CM_Debtor; //17/01/2023	navkc1 Bug 61503
		pxyInvoice.setInvoiceType(self.cmbInvTypeInv.listObject.CM_InvoiceDesc);
		//pxyInvoice.status := self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.listIndex];
		ts.setDate(self.mskCNStartDate.getDate());
		ts.setTime(self.mskCNStartTime.getTime());
		pxyInvoice.fromDT := self.localToSystemTime(ts);
	endif;
	
	pxyInvoice.debtor := self.cmbDebtorInvProp.listObject.CM_Debtor; //17/01/2023	navkc1 Bug 61503
	
	runPackage := self.tblInvProperties.getValueByName(ETRow_RunPackage).Boolean;

	while true do
		//20/07/2023	navkc1	Bug 58995
		if self.isCreditNote then
			app.myTrxUA.trxUpdateCreditNote(self.allInvoicesToLink, pxyInvoice, realInvoice, app.myPassport);
		else
			app.myTrxUA.trxUpdateInvoice(pxyInvoice,app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			//20/07/2023	navkc1	Bug 58995
			if realInvoice.isCreditNote() then
				if realInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Credit_note_update_success, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Credit_note_ext_update_success, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			else
				if realInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Invoice_updated_successful, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Invoice_ext_updated_successful, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			endif;
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
	if realInvoice.isPosted
		and  runPackage then
		app.mousePointer := MousePointer_HourGlass;
		
		debtorInvType := realInvoice.debtor.allDebtorInvTypes[realInvoice.invoiceType];
		
		if debtorInvType &lt;&gt; null then
			foreach package in debtorInvType.allPackageInvoices do
				foreach task in package.allTasks do
					schedule := task.allAutoSchedules.first;
					app.runEventScheduleInvoice(schedule, realInvoice, null);
				endforeach;
			endforeach;
		endif;
	endif;
epilog
	app.mousePointer := MousePointer_Default;
	delete pxyInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHideRows" id="53ade5ba-e431-430f-aab0-30d95b87994d">
        <source>doShowHideRows();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//23/01/2026	navkc1 JIRA MTN 37058

*/

vars

begin
	
	self.tblInvProperties.hideRowByName(ETRow_ExternalNumber, false);
	self.tblInvProperties.hideRowByName(ETRow_ExternalFinancialID, false); 
	self.tblInvProperties.hideRowByName(ETRow_ExternalTaxNumber, false);
	
	if self.canViewExtRefFields() then
		self.tblInvProperties.showRowByName(ETRow_ExternalNumber, false);
		self.tblInvProperties.showRowByName(ETRow_ExternalFinancialID, false); 
		self.tblInvProperties.showRowByName(ETRow_ExternalTaxNumber, false);
	endif;
	
	self.tblInvProperties.cnEcResizeContents();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initEntTables" id="70e61f79-cdd4-4764-b3d7-537397dcdf8d">
        <updating/>
        <source>initEntTables() protected, updating;
/*

Purpose:			Initializes all the Ent Tables on the form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
17/01/2023	navkc1 	Bug 61503: FR| 54086 - EUP - Invoice Maintenance - Debtor update.
*/
vars	
	bank : CM_Bank; //08/12/2025	navkc1 JIRA 36262
	canViewExtRef,
	canMaintExtRef	: Boolean; //23/01/2026	navkc1 JIRA MTN 37058
begin
	
	bank := self.myCurrentBank; //08/12/2025	navkc1 JIRA 36262
	
	// 10/11/2023	navkc1 Bug 61004
	//self.initEntTable(self.tblInvProperties, ETDef_InvListInvProperties, ETView_InvListInvPropUpdate); 
	
	self.initEntTable(self.tblInvProperties, ETDef_InvListInvProperties, null);
	if self.isCreditNote then
		self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdCNDef, CM_EntryTable.ShowHideRows, true);
	else
		self.tblInvProperties.showHideRowsByViewName(ETView_InvListUpdInvDef, CM_EntryTable.ShowHideRows, true);
		// 10/11/2023	navkc1 Bug 61004 - Since we are not updating Debtor for Invoices, disable the row
		//self.tblInvProperties.disableRowByName(ETRow_Debtor);
	endif;
	
	// Disable by default //17/01/2023	navkc1 Bug 61503
	self.tblInvProperties.disableRowByName(ETRow_Debtor);
	
	self.tblInvProperties.disableRowByName(ETRow_ExternalNumber); //08/12/2025	navkc1 JIRA 36262
	self.tblInvProperties.disableRowByName(ETRow_ExternalFinancialID); //08/12/2025	navkc1 JIRA 36262
	self.tblInvProperties.disableRowByName(ETRow_ExternalTaxNumber); //08/12/2025	navkc1 JIRA 36262
	
	//17/01/2023	navkc1 Bug 61503 - Enable if user has permission and invoice/CN is NOT posted
	if app.myCurrentUserCan(self.myTerminal, PmAdmInvDebtorUpdatePrePost) then
		if self.myCurrentInvoice &lt;&gt; null and not self.myCurrentInvoice.isPosted() then
			self.tblInvProperties.enableRowByName(ETRow_Debtor);
		endif;
	endif;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.canUpdateExtRefFields() then
		// If bank is NOT using Auto ID for External Number, enable this field and allow user to edit
		if bank &lt;&gt; null and bank.allAutoIdGenerators[CM_AutoIdGenerator.InvExtNumberType] = null then
			self.tblInvProperties.enableRowByName(ETRow_ExternalNumber);
		endif;
		
		self.tblInvProperties.enableRowByName(ETRow_ExternalFinancialID);
		self.tblInvProperties.enableRowByName(ETRow_ExternalTaxNumber);
	endif;
	
	//Initialize Other CM_EntryTables
	self.initEntTable(self.tblBOL, ETDef_InvListInvProperties, ETView_InvListInvPropBOL);
	self.initEntTable(self.tblBooking, ETDef_InvListInvProperties, ETView_InvListInvPropBooking);
	self.initEntTable(self.tblCargo, ETDef_InvListInvProperties, ETView_InvListInvPropCargo);
	self.initEntTable(self.tblCargoGroup, ETDef_InvListInvProperties, ETView_InvListInvPropCG);
	self.initEntTable(self.tblRelease, ETDef_InvListInvProperties, ETView_InvListInvPropRelease);
	self.initEntTable(self.tblVoyage, ETDef_InvListInvProperties, ETView_InvListInvPropVoyage);
	
	//14/08/2023	navkc1	Bug 59803
	//self.initEntTable(self.tblInvProperties, ETDef_InvListInvProperties, ETView_InvListInvPropCreate);//20/07/2023	navkc1	Bug 58995
	
	// 10/11/2023	navkc1 Bug 61004
	/*
	//14/08/2023	navkc1	Bug 59803
	if not self.myCurrentInvoice.isCreditNote() then
		self.tblInvProperties.hideRowByName(ETRow_StatusInvoiceManual, false);
		self.tblInvProperties.hideRowByName(ETRow_CreditNoteStartDate, false);
		self.tblInvProperties.hideRowByName(ETRow_CreditNoteStartTime, false);
		self.tblInvProperties.hideRowByName(ETRow_CreditNoteEndDate, false);
		self.tblInvProperties.hideRowByName(ETRow_InvoiceTypeCode, false);
	endif;
	*/
	self.displayInvoice();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initInvoiceSheet" id="491dd68d-b0ee-4f9c-9597-683fc9c4814c">
        <updating/>
        <source>initInvoiceSheet() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	theTable 		: CM_EntryTable;
	finIO			: CM_ExtFinanceIO;
	textHeight,
	narrHeight		: Integer;
	packageNames	: String;
	theNarrRow 		: Integer;
	isASPAInterface : Boolean;
	theInvoice		: CM_Invoice;
	debtor			: CM_Debtor;
	debtorSep 		: CM_InvTypeDebtorSeparation;
	invoiceDesc		: CM_InvoiceDesc;
begin

	theTable := self.tblInvProperties;
	
	theInvoice := self.myCurrentInvoice;
	if theInvoice = null then
		return;
	endif;
	
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;	
	if finIO &lt;&gt; null and finIO.isKindOf(CM_SALInterface) then
		theTable.hideRowByName(ETRow_Export,false);
	endif;
	
	/* // 10/11/2023	navkc1 Bug 61004
	theTable.hideRowByName(ETRow_ArrivalTS,false);
	theTable.hideRowByName(ETRow_DepartureTS,false);
	theTable.hideRowByName(ETRow_VoyageDesc,false);
	theTable.hideRowByName(ETRow_Voyage,false);
	*/
	
	if isASPAInterface then
		theTable.hideRowByName(ETRow_IsZeroRated,false);
	endif;
	
	theNarrRow := theTable.getRowByName(ETRow_Narration);
	if theNarrRow &gt; 0 then
		theTable.accessCell(theNarrRow,CM_EntryTable.ColumnValue).wordWrap := true;
	endif;
	
	//theTable.setTableFromCM_Object(theInvoice,null);
	theTable.setTableFromCM_Object(theInvoice, INV_InvoiceUpdate::setEntTableGeneral.name);
	theTable.disableRowByName(ETRow_SequenceNum);	
	
	self.txtNarr.text := theInvoice.narration;
		
	if theInvoice.debtor.myTermsOfTrade &lt;&gt; null then
		theTable.setValueByName(ETRow_Terms,theInvoice.debtor.myTermsOfTrade.description);
	endif;
	/*
	theTable.hideRowByName(ETRow_RunPackage, false); //14/08/2023	navkc1	Bug 59803
	theTable.hideRowByName(ETRow_Packages, false); //14/08/2023	navkc1	Bug 59803
	*/
	if theInvoice.isPosted() then
		//theTable.hideRowByName(ETRow_DebtorAddress,false);	 //14/08/2023	navkc1	Bug 59803
		theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
		theTable.disableRowByName(ETRow_EndDate);
		
		packageNames:=theInvoice.getDisplayStringForAttribute(ETRow_Packages,false);
		if packageNames &lt;&gt; null then
			//theTable.showRowByName(ETRow_RunPackage, false); //14/08/2023	navkc1	Bug 59803
			theTable.showRowByName(ETRow_Packages, false);
			theTable.setValueByName(ETRow_Packages, packageNames);
		endif;	
	endif;
	
	if theInvoice.invoiceType.accrualType = CM_InvoiceDesc.Accrue_Until_Manually_Closed then
		if theInvoice.status = CM_Invoice.INVOICE_PENDING then
			theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
			theTable.enableRowByName(ETRow_EndDate);
			if self.isCreditNote then
				self.tblInvProperties.showRowByName(ETRow_CreditNoteEndDate, false);
			endif;
		else
			theTable.setValueByName(ETRow_EndDate, null);
		//	theTable.hideRowByName(ETRow_EndDate,false); // 10/11/2023	navkc1 Bug 61004
			/* // 10/11/2023	navkc1 Bug 61004
			if self.isCreditNote then
				self.tblInvProperties.hideRowByName(ETRow_CreditNoteEndDate, false);
			endif;
			*/
		endif;
	else
		theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
		theTable.enableRowByName(ETRow_EndDate);
	endif;
	
	if not theInvoice.isPostedOrReversal then
		theTable.showRowByName(ETRow_DebtorAddress,false);
	endif;
	
	if  theNarrRow &gt; 0 then
		textHeight := self.txtNarr.getTextHeightForWidth(self.txtNarr.text, self.txtNarr.width.Integer) + 10;
		narrHeight := textHeight;
		if textHeight &lt; 50 then
			narrHeight := 50;
		elseif textHeight &gt; 150 then
			narrHeight := 150;
		endif;
		theTable.accessRow(theNarrRow).height := narrHeight;
		self.txtNarr.height := narrHeight;
	endif;
	/*// 10/11/2023	navkc1 Bug 61004
	//14/08/2023	navkc1	Bug 59803
	if self.myCurrentInvoice.isCreditNote() then
		theTable.hideRowByName(ETRow_EndDate, false);
	endif;
	*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="invTypeClick" id="47a2cb17-2f29-4f22-a308-b2aae494455e">
        <updating/>
        <source>invTypeClick(combobox: ComboBox input) protected, updating;
/*

Purpose:

Parameters:

Return Value:

Date		  Who		Reason 
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed
*/

vars 
	invoiceProcess	: CM_InvoiceProcess;
	invoiceStatus	: String;
	theTable 		: CM_EntryTable;
	theInvoice		: CM_Invoice;
	packageNames	: String;
begin
	theInvoice := self.myCurrentInvoice;
	theTable := self.tblInvProperties;
	
	inheritMethod(combobox); 
	
	invoiceProcess := self.myCurrentInvoice.myInvoiceProcess;
	invoiceStatus  := app.getInvoiceStatusString(invoiceProcess, self.myCurrentInvoice.status);
	/* // 10/11/2023	navkc1 Bug 61004
	if not self.isCreditNote then
		self.tblInvProperties.hideRowByName(ETRow_StatusInvoiceManual, false); //14/08/2023	navkc1	Bug 59803
	endif;
	*/
	self.cmbStatusInvProp.listIndex	:= self.cmbStatusInvProp.findStringExact(1, invoiceStatus);
	self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, invoiceStatus);
	
	theTable.hideRowByName(ETRow_RunPackage, false);
	theTable.hideRowByName(ETRow_Packages, false);
	
	if theInvoice.isPosted() then
		theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
		theTable.disableRowByName(ETRow_EndDate);
		
		packageNames:=theInvoice.getDisplayStringForAttribute(ETRow_Packages,false);
		if packageNames &lt;&gt; null then
			theTable.showRowByName(ETRow_Packages, false);
			theTable.setValueByName(ETRow_Packages, packageNames);
		endif;	
	endif;
epilog 

end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isNew" id="db09c7a8-1818-4cf7-896e-b98298272731">
        <source>isNew(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed

*/

vars

begin
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUpdate" id="a53c8821-6da6-420d-bf73-54180f1c2c19">
        <source>isUpdate(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed

*/

vars

begin
	return true;

epilog

end;</source>
