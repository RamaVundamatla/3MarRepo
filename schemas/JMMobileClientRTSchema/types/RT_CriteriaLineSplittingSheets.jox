    <JadeMethod name="setForCreate" id="8837c9d1-d7d7-4876-bbf9-ea300a71009f">
        <updating/>
        <source>setForCreate( _form : RadioTelemetryMainForm; 
				_propClassName, _propName, _queryOperatorOid : String;
				_lblCriteriaCaption, _searchValueA, _searchValueB : String; 
				_optBtnValue : Boolean;
				_slip : Real; _tabIndex : Integer ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	inheritMethod(_form, _propClassName, _propName, _queryOperatorOid, _lblCriteriaCaption, _searchValueA, _searchValueB, _optBtnValue, _slip, _tabIndex );
	
	self.myLblCriteria.caption	:= self.CaptionSplittingQuerySheets;
	
end;
</source>
