    <JadeMethod name="setCurrentValues" id="7424c81e-e49f-4a90-86af-c7a9c45dcf61">
        <updating/>
        <source>setCurrentValues(_product : CM_Product) protected, updating;

// Created by cnwdvb1 on 09 November 2006
/*

Date		Who		Reason
16 Jun 2008	cnwkpd1	PAR #17013 - Rounded calculated values to correct number of decimal places 
					before loading into textboxes

*/

vars
	volume,
	quantity,
	weight		: Real;
	bulkTI		: CM_Bulk;
	
begin
	self.myTrackedItem := self.myLocationsController.getMatchingTrackedItem(_product);
	
	if self.myTrackedItem = null then
		self.fieldCurrentV.setValue(0);
		self.fieldCurrentQ.setValue(0);
		self.fieldCurrentW.setValue(0);
		return;
	endif;
	
	bulkTI	:= self.myTrackedItem.CM_Bulk;
	
	if self.showVolume then
		volume		:= _product.myVolume.multiplyValue(bulkTI.getMyTotalVolume);
	endif;
	
	if self.showQuantity then
		quantity	:= _product.myQuantity.multiplyValue(bulkTI.quantity);
	endif;
	
	if self.showWeight then
		weight		:= _product.getMyWeightDisplayValue(bulkTI.totalWeight);   //myWeight.multiplyValue(bulkTI.totalWeight);   //30.1.09 cnwrd1 par #18821 
	endif;
	
	self.fieldCurrentV.setValue(volume.roundedTo(2));			// PAR #17013
	self.fieldCurrentQ.setValue(quantity.roundedTo(0));			// PAR #17013
	self.fieldCurrentW.setValue(weight.roundedTo(2));			// PAR #17013
	
	self.fieldNewV.setValue(0);
	self.fieldNewQ.setValue(0);
	self.fieldNewW.setValue(0);
	self.fieldComment.setValue(null);
end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="66894a13-9745-4aca-9ed0-5e344b940e92">
        <updating/>
        <source>setupForm() updating;

// Created by cnwdvb1 on 26 October 2006

vars
	ti			: CM_TrackedItem;	
	cargoType	: CM_CargoType;
	product		: CM_Product;

begin
	inheritMethod();
	
	if self.myLocationsController = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Location is null', null, null);
		return;
	endif;
	
	self.caption := self.caption &amp; ' ' &amp; self.myLocationsController.getFullId();
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top
	self.frmToolbar.alignContainer := Frame.AlignContainer_None; 

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	ti := self.myLocationsController.allTrackedItemsById.first();
	
	if ti &lt;&gt; null then
		product := ti.myProduct;
		
		if product &lt;&gt; null then
			cargoType := product.myCargoType;
		endif;
	endif;
	
	self.cmbCargoType.showBulk := CMUI_ComboCargoGeneral.Display_BulkOnly;
	self.cmbCargoType.setObject(cargoType);
	self.cmbProduct.setCargoType(cargoType);
	
	if cargoType &lt;&gt; null then
		self.cmbProduct.setObject(product);
	endif;
	
	self.showHideFields();
	self.fieldComment.setTextboxHeight(40);
	self.fieldComment.setMaxLength(50);
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideFields" id="7d5b3dff-ffa7-473e-82a7-6a9e3f7345d2">
        <updating/>
        <source>showHideFields() protected, updating;

// Created by cnwdvb1 on 26 October 2006

vars
	product			: CM_Product;
	fieldFrameObj	: CMUI_FieldFrame;
	nextTop			: Real;

begin
	foreach fieldFrameObj in self.allFieldFrames do
		fieldFrameObj.visible := false;
	endforeach;
	
	self.allFieldFrames.clear();
	self.showVolume 	:= false;
	self.showQuantity	:= false;
	self.showWeight		:= false;
	
	self.allFieldFrames.add(self.fieldCargoType);
	self.allFieldFrames.add(self.fieldProduct);
	
	product := self.cmbProduct.myObject.CM_Product;
	
	if product &lt;&gt; null then
		if product.isAttributeValidForCargoType(ETRow_MyVolume) then
			self.showVolume := true;
			self.fieldCurrentV.myLabel.caption := 'Current ' &amp; product.myVolume.displayName;
			self.fieldNewV.myLabel.caption := 'New ' &amp; product.myVolume.displayName;
			self.allFieldFrames.add(self.fieldCurrentV);
			self.allFieldFrames.add(self.fieldNewV);
		endif;
	
		if product.isAttributeValidForCargoType(ETRow_MyQuantity) then
			self.showQuantity := true;
			self.fieldCurrentQ.myLabel.caption := 'Current ' &amp; product.myQuantity.displayName;
			self.fieldNewQ.myLabel.caption := 'New ' &amp; product.myQuantity.displayName;
			self.allFieldFrames.add(self.fieldCurrentQ);
			self.allFieldFrames.add(self.fieldNewQ);
		endif;
		
		if product.isAttributeValidForCargoType(ETRow_MyWeight) then
			self.showWeight := true; 
			self.fieldCurrentW.myLabel.caption := 'Current ' &amp; product.getMyWeightDisplayName(); //  myWeight.displayName;//30.1.09 cnwrd1 par #18821 
			self.fieldNewW.myLabel.caption := 'New ' &amp; product.getMyWeightDisplayName();     //myWeight.displayName; //30.1.09 cnwrd1 par #18821 
			self.allFieldFrames.add(self.fieldCurrentW);
			self.allFieldFrames.add(self.fieldNewW);
		endif;
		
		self.allFieldFrames.add(self.fieldComment);
		self.setCurrentValues(product);
	endif;
		
	self.allFieldFrames.alignFields(self.DEFAULT_LEFT, self.DEFAULT_TOP, self.DEFAULT_WIDTH, false);
	
	self.fieldCurrentQ.setIsEnabled(false);
	self.fieldCurrentV.setIsEnabled(false);
	self.fieldCurrentW.setIsEnabled(false);
//	nextTop	:=	self.aAllFieldFrames.alignFields(0, self.DEFAULT_TOP, self.DEFAULT_WIDTH, isViewOnly);
	self.allFieldFrames.doTabOrders(10000);
	
	fieldFrameObj	:=	self.allFieldFrames.last();
	nextTop			:=	fieldFrameObj.top + fieldFrameObj.height;
	
	if nextTop &lt;&gt; 0 then	
		self.height	:=	nextTop + self.DEFAULT_HEIGHT_EXTENSION;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a87fd987-67a5-46e2-8474-f1f7996824b5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007795, locale);
	fieldCargoType.translateCaption(Xlat_0005090, locale);
	fieldComment.translateCaption(Xlat_0005091, locale);
	fieldCurrentQ.translateCaption(Xlat_0005092, locale);
	fieldCurrentV.translateCaption(Xlat_0005093, locale);
	fieldCurrentW.translateCaption(Xlat_0005094, locale);
	fieldNewQ.translateCaption(Xlat_0005095, locale);
	fieldNewV.translateCaption(Xlat_0005096, locale);
	fieldNewW.translateCaption(Xlat_0005097, locale);
	fieldProduct.translateCaption(Xlat_0005098, locale);
	lblInfo.translateCaption(Xlat_0005099, locale);
end;</source>
    </JadeMethod>
</GUIClass>
