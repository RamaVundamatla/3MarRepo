    <JadeMethod name="initializeForActivity" id="09f58365-a5ae-42dd-8b64-9bc09baeb870">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	n4Che	: CMIF_XpsChe;
	machine : CM_Machine;
begin
	if _opsViewTable.isKindOf(CMIF_XpsChe) then
		n4Che							:= _opsViewTable.CMIF_XpsChe;
		n4Che.gkey                   	:= n4Che.generateFullGKey(self, "");
		n4Che.id					 	:= self.code.getStringValueAsInteger64();
		n4Che.kind_enum   				:= "QC";
		n4Che.job_step_state_enum   	:= "";
		n4Che.life_cycle_state			:= n4Che.n4LifeCycleState(self);
		n4Che.short_name   				:= self.description;
		n4Che.status_enum   			:= CM_MachineStatus.STATUS_WORKING_STR;	
	endif;
epilog

end;</source>
