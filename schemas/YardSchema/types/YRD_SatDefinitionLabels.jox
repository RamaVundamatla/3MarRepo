    <JadeMethod name="doOK" id="06b9a5f0-cd74-40ce-9cea-ab9be1b722aa">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars

begin
	self.myPxyTAViewPosition.setLabelDisplays(	self.chkShowColTop.value,
												self.chkShowColBottom.value,
												self.chkShowLeftRow.value,
												self.chkShowRightRow.value,
												self.chkShowCapItems.value,
												self.chkShowCapFree.value
												);

		
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyPxyTAViewPosition" id="305bfb05-04a3-4883-9185-4eb70e512eeb">
        <updating/>
        <source>setMyPxyTAViewPosition(_value : CM_TerminalAreaViewPosition) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwer1	Initial creation

*/

vars

begin
	self.myPxyTAViewPosition:=_value;
//	self.caption:=self.caption &amp; " "  &amp; self.myPxyTAViewPosition.myTerminalArea.id;
	
	self.chkShowColBottom.value:=self.myPxyTAViewPosition.displayBottomColumnLabels;
	self.chkShowColTop.value:=self.myPxyTAViewPosition.displayTopColumnLabels;
	self.chkShowLeftRow.value:=self.myPxyTAViewPosition.displayLeftRowLabels;
	self.chkShowRightRow.value:=self.myPxyTAViewPosition.displayRightRowLabels;
	
	//21 Sep 2011	NDL	Par 28076
	self.chkShowCapItems.value := self.myPxyTAViewPosition.displayItemCount;
	self.chkShowCapFree.value := self.myPxyTAViewPosition.displayFreeCount;
	
	//21 Sep 2011	NDL	Par 28076
	if self.myPxyTAViewPosition.isBlockStack or self.myPxyTAViewPosition.isICArea then
		self.chkShowColBottom.visible := false;
		self.chkShowColTop.visible := false;
		self.chkShowLeftRow.visible := false;
		self.chkShowRightRow.visible := false;
		self.chkShowCapItems.visible := true;
		self.chkShowCapFree.visible := true;
		if self.myPxyTAViewPosition.isSubBlockStack or self.myPxyTAViewPosition.isICArea then
			self.chkShowCapFree.visible := false;
			self.chkShowCapFree.value := false;
		endif;
	else
		self.chkShowColBottom.visible := true;
		self.chkShowColTop.visible := true;
		self.chkShowLeftRow.visible := true;
		self.chkShowRightRow.visible := true;
		self.chkShowCapItems.visible := false;
		self.chkShowCapFree.visible := false;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3e9fdd36-6eda-46a3-98b6-4036ba0be4be">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	28076

*/

vars

begin
	inheritMethod();
	
	if self.myPxyTAViewPosition &lt;&gt; null and self.myPxyTAViewPosition.myTerminalArea &lt;&gt; null then
		if self.myPxyTAViewPosition.myTerminalArea.isKindOf(CM_SubBlockStack) then
			self.caption := app.getErrorString(SubBlock_stack) &amp; " " &amp; self.myPxyTAViewPosition.myTerminalArea.id &amp; " " &amp; self.caption;
		elseif self.myPxyTAViewPosition.myTerminalArea.isKindOf(CM_BlockStack) then
			self.caption := app.getErrorString(Block_stack) &amp; " " &amp; self.myPxyTAViewPosition.myTerminalArea.id &amp; " " &amp; self.caption;
		elseif self.myPxyTAViewPosition.myTerminalArea.isKindOf(CM_InterchangeArea) then
			self.caption := app.getErrorString(Interchange_area) &amp; " " &amp; self.myPxyTAViewPosition.myTerminalArea.id &amp; " " &amp; self.caption;
		else
			self.caption := self.myPxyTAViewPosition.myTerminalArea.id &amp; " " &amp; self.caption;
		endif;
	endif;
	self.height := 167;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="76415ea8-6144-49aa-a451-d82ca4885e4b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012439, locale);
	chkShowCapFree.translateCaption(Xlat_0017164, locale);
	chkShowCapItems.translateCaption(Xlat_0017165, locale);
	chkShowColBottom.translateCaption(Xlat_0012440, locale);
	chkShowColTop.translateCaption(Xlat_0012441, locale);
	chkShowLeftRow.translateCaption(Xlat_0012442, locale);
	chkShowRightRow.translateCaption(Xlat_0012443, locale);
end;</source>
    </JadeMethod>
</GUIClass>
