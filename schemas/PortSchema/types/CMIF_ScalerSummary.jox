<Class name="CMIF_ScalerSummary" id="b6d7259d-9c6b-4f85-aa96-9ff565b43919">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="numLogsScaled" id="1a3273c3-7522-40d6-9a19-4aefdfb7d307">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numOver" id="036385c1-6752-4192-aeac-1c5e96b6638e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numScaledCorrectly" id="1e532d56-f02f-4bbe-b12e-791bc559109a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numScaledIncorrectly" id="de4b4f64-f3aa-4dea-b1c8-639aecadbcd6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numUnder" id="9814f7b7-55f9-4dad-a8f2-ae8324a4ad01">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="percentAccuracy" id="2daa155f-267c-4c0a-a2d7-734e624e9050">
        <precision>4</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="percentUnderOver" id="5f4de1ee-e78f-4d0c-a7ae-6624ed7c736d">
        <precision>5</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="scalerCode" id="ec05a8e8-7698-4c90-bff5-92d47e9d47ff">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="totalCheckedVolume" id="48954556-b467-4d04-b20c-b43314010a0d">
        <precision>12</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="totalDifference" id="7053ee71-beb8-49a2-8dd0-610052bbea2a">
        <precision>12</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="totalScalerVolume" id="2ed5feb3-6326-4c50-9731-df0ecaae358f">
        <precision>12</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="totalSelf" id="9ce202d8-81f6-4404-aff1-6ee10beae1a6">
        <updating/>
        <source>totalSelf(_scaleDtl : CM_LogCheckScaleDtl) updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.numLogsScaled := self.numLogsScaled + 1;
 	
 	self.totalScalerVolume := self.totalScalerVolume + _scaleDtl.logJASVolume;
	self.totalCheckedVolume := self.totalCheckedVolume + _scaleDtl.calcJASVolume;
	
	self.totalDifference := self.totalScalerVolume - self.totalCheckedVolume;
	
	if _scaleDtl.logJASVolume &gt; _scaleDtl.calcJASVolume + 2 then
		self.numScaledIncorrectly := self.numScaledIncorrectly + 1;
		self.numOver := self.numOver + 1;
	elseif _scaleDtl.calcJASVolume &lt; _scaleDtl.logJASVolume - 2 then
		self.numScaledIncorrectly := self.numScaledIncorrectly + 1;
		self.numUnder := self.numUnder + 1;
	else
		self.numScaledCorrectly := self.numScaledCorrectly + 1;
	endif;
	
	if self.numScaledCorrectly &lt;&gt; 0 then
		self.percentAccuracy := (self.numLogsScaled / self.numScaledCorrectly) * 100;
	endif;
	
	if self.totalScalerVolume &lt;&gt; 0 then
		self.percentUnderOver := (self.totalCheckedVolume / self.totalScalerVolume) * 100;
	endif;
end;</source>
        <Parameter name="_scaleDtl" type="CM_LogCheckScaleDtl"/>
    </JadeMethod>
</Class>
