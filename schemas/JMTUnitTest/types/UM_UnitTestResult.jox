vars

begin
	self.methodRunStartTS := _ts;
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateUsedByDetails" id="acfcfa62-d859-4f11-b858-d4add1832d8c">
        <updating/>
        <source>updateUsedByDetails(_methodsCalled : StringArray) updating;

/*

Purpose:		Update the used by details

Date			Who		Reason
06/09/2013		cnwmh5	Initial creation

*/

vars

	classMethod						: UM_UnitTestClassMethod;
	root							: UM_Root;
	
	strValue						: String;
	className						: String;
	methodName						: String;
	pos								: Integer;
	
begin

	if _methodsCalled = null or _methodsCalled.isEmpty() then
		return;
	endif;
	
	root := UM_Root.firstInstance();
	if root = null then
		return;
	endif;
	
	foreach strValue in _methodsCalled do
	
		if strValue = null then
			continue;
		endif;
		
		pos := strValue.pos("::",1);
		if pos &lt; 2 or pos+2 &gt; strValue.length then
			continue;
		endif;
		
		className := strValue[1:pos-1];
		methodName := strValue[pos+2:end];
		
		// check to see if the method / class record already exists
		classMethod := root.allClassMethodsUsedBy[className, methodName];
		
		beginTransaction;
		if classMethod = null then
			create classMethod persistent;
			classMethod.updateDetails(className, methodName);
		endif;
		commitTransaction;
		
		classMethod.updateUsedBy(self);
		
	endforeach;

epilog
	
end;</source>
        <Parameter name="_methodsCalled" type="StringArray"/>
    </JadeMethod>
</Class>
