    <JadeMethod name="addToolbarControls" id="fc310732-d922-4f28-98a7-284d890e7320">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295
18 May 2023	navmk20	Task 58021: UI - Storage Config - Storage Detail List

*/

vars
	frm				: CMUI_Toolbar;
begin	
	inheritMethod();
	frm := self.frmToolbar;

	// 34917 add config button to detail
	frm.addButton(self.btnConfig, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);	// from TFS 2056 add an explicit refresh for after change to attributes
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnFindLost, CMUI_Toolbar.Control_Alignment_Left);	//17 May 2016	NDL TFS 1981
	
/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						// 18.5.2023 navmk20 TFS 58021
	frm.addFrame(self.frmFilterBox, CMUI_Toolbar.Control_Alignment_Left);		// 18.5.2023 navmk20 TFS 58021
	frm.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);	// 18.5.2023 navmk20 TFS 58021
*/
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					//05/06/2024	navkc1 CR 63736 Task 63770
	frm.addFrame(self.frmTblFilter, CMUI_Toolbar.Control_Alignment_Left); 	//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTblFilter.visible := true;										//05/06/2024	navkc1 CR 63736 Task 63770
	
	frm.positionToolbarControls();
	frm.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
