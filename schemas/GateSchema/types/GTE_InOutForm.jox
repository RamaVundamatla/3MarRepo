    <JadeMethod name="handleBRUpdate" id="1c131c87-96ea-4c21-a575-6d5a3b707b28">
        <source>handleBRUpdate(theObject: Object; userInfo: Any) protected;
//----------------------------------------------------------------
//	Created:	31 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 24/02/2010	cnwmh5		Par22263 - Need to set table object to CM_ReserveDetails
//							rather than CM_BulkRelease to stop 1086 error
vars
	br			: CM_BulkRelease;
	carrier		: CM_Carrier;
	rowIdx		: Integer;
	tmpTable	: CM_DataTable;
	reserve		: CM_ReserveDetail;
	str : String;
begin

	if self.cmbCarrier.listObject = null then
		//this note is solely for keeping the carrier release table up-to-date
		return;
	endif;
	if userInfo = null then
		return;
	endif;
	
	if not userInfo.isKindOf(CM_BulkRelease) then
		return;
	endif;

	br := userInfo.CM_BulkRelease;
	if br.type &lt;&gt; BR_TYPE_ROAD
	or br.status &lt;&gt; BR_ACTIVE then
		return;
	endif; 
	
	carrier := self.cmbCarrier.listObject.CM_Carrier;
	tmpTable := self.tblBulkRelease;
	
	if br.carrierId &lt;&gt; carrier.code then
		//check for removal
		if tmpTable.findObjectInRow(br, rowIdx) then
			tmpTable.removeItem(rowIdx);
		endif;
	else
		//check for add
		/*PAR18437 I believe this is the fix for this as per method setValuesFromReserveDetail
		Reckon this could be moved to a new method as it is has been duplicated from setValuesFromReserveDetail
		foreach reserve in br.allReserveDetails discreteLock do
			str := reserve.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
			if not tmpTable.findObjectInRow(reserve, rowIdx) then
				tmpTable.addItemObject(reserve, str);
			endif;
		endforeach;
	*/
		self.addToTblBulkRelease(br, tmpTable);				// 24/02/2010 cnwmh5 #22263
		/*
		// 24/02/2010 cnwmh5 #22263 - Replaced
		if not tmpTable.findObjectInRow(br, rowIdx) then
			rowIdx := tmpTable.addItem(br.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));
			tmpTable.accessRow(rowIdx).itemObject := br;
		endif; 
		*/
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
