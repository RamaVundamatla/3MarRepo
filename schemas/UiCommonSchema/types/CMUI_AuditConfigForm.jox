    <JadeMethod name="addOrUpdateRow" id="d2a92d29-e2f2-4db4-8bb0-9847456725e6">
        <source>addOrUpdateRow( _auditConfig : CM_AuditConfig; _updateRowIndex : Integer; _enabledColumn : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation

*/

vars

	
	str : String;
	index : Integer;
	

begin

	str := _auditConfig.getAttributeStringForDefArray(self.tblAuditConfigs.allTblDataEntRows);
	if _updateRowIndex = 0 then
		index := self.tblAuditConfigs.addItemObject( _auditConfig, str );
	else
		index := _updateRowIndex;
		self.tblAuditConfigs.setCellText( index, 1, str );
	endif;
	
	if _auditConfig.canBeUserDisabled then
		if not _auditConfig.isEnabled then
			self.tblAuditConfigs.accessCell( index, _enabledColumn ).backColor := Red;
		else
			self.tblAuditConfigs.accessCell( index, _enabledColumn ).backColor := LightGreen;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_auditConfig" type="CM_AuditConfig"/>
        <Parameter name="_updateRowIndex" type="Integer"/>
        <Parameter name="_enabledColumn" type="Integer"/>
    </JadeMethod>
