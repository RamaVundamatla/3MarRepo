    <JadeMethod name="frmBlkArea_contextMenu" id="0b329f68-df71-43dd-943b-685a5d1ff7c4">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBlkArea_contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 June 2008	cnwrd1	Initial creation par #17137	
04 Aug 2022 	navhl20 ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.
*/

vars

	obj : Object;
	irrBlkCont : CM_IrregularBlockController;
	location: CM_LocationsController;
	
begin

	//21 Aug 2013	NDL	Par 32308
	self.mnuCopy.enabled := false;
	self.mnuPaste.enabled := false;
	self.mnuPaste.caption := app.getErrorString(Paste);
	self.mnuClearClip.enabled := false;
	self.mnuGCSetCapacity.enabled := false; // PAR 32886
	self.mnuGCSetWeight.enabled := false; // PAR 32886
	self.mnuSetTerminal.enabled := false;		//04 Aug 2022 navhl20 TFS 53921
	
	self.mnuGCSetCapacity.visible := true; // PAR 32308
	self.mnuGCSetWeight.visible := true; // PAR 32308
	
	//22 July 2020	NDL	TFS 49775
	obj := self.myCurrentObject;
	if obj &lt;&gt; null and obj.isKindOf( CM_IrregularBlockArea ) then
		self.mnuShowLCMaxCap.visible := true;	
		self.mnuShowLCMaxWt.visible := true;	
		self.mnuShowLCName.visible := true;
		self.mnuShowYAMaxCap.visible := true;
		self.mnuShowLCMaxCap.enabled := self.labelContents &lt;&gt; 1;	
		self.mnuShowLCMaxWt.enabled := self.labelContents &lt;&gt; 2;	
		self.mnuShowLCName.enabled := self.labelContents &lt;&gt; 0;
		self.mnuShowYAMaxCap.enabled := self.labelContents &lt;&gt; 3;	
	else
		self.mnuShowLCMaxCap.visible := false;	
		self.mnuShowLCMaxWt.visible := false;	
		self.mnuShowLCName.visible := false;
		self.mnuShowYAMaxCap.visible := false;
	endif;
	
	if self.frmBlkArea.myDrawingController.allSelectedObjects.isEmpty then
		self.mnuClearClip.caption := app.getErrorString(Clear_Clip_board);
	else
		self.mnuClearClip.caption := app.getErrorString(Clear_clip_borad_select_items);
	endif;
	self.mnuSepCopyPaste.visible := false;
	
	if self.mode = Mode_Update then
		obj := self.frmBlkArea.myDrawingController.getSelectedLocation();
		if obj &lt;&gt; null and obj.isKindOf( CM_IrregularBlockController ) then
			irrBlkCont := obj.CM_IrregularBlockController;
			self.mnuGCSetCapacity.enabled := true; // PAR 32886
			self.mnuGCSetWeight.enabled := true; // PAR 32886
			self.mnuSepCopyPaste.visible := true;
			self.mnuCopy.enabled := true;
			self.mnuCopy.userObject := irrBlkCont;
		endif;
		self.mnuSetTerminal.enabled := true;		//04 Aug 2022 navhl20 TFS 53921
		location :=  self.frmBlkArea.getLocationAt(x, y);
		//if not self.frmBlkArea.myDrawingController.allSelectedObjects.isEmpty then
		if  not self.frmBlkArea.myDrawingController.allCopiedItems.isEmpty then
			self.mnuSepCopyPaste.visible := true;
			if location = null then
			
				self.mnuPaste.enabled := true;
				self.mnuPaste.caption := app.getErrorString2(	Paste_items_from,
																self.frmBlkArea.myDrawingController.allCopiedItems.size.String,
																self.frmBlkArea.getPositionStringOfCell(x,y)
																);
			endif;
			self.mnuClearClip.enabled := true;
		endif;	
	endif;

	return self.showContextMenu(mnuNoEdit2, cntrl, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
