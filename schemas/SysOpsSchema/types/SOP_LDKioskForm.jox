<GUIClass name="SOP_LDKioskForm" id="1bf8c9b7-8d19-4641-af56-30b1b3658b95">
    <superclass name="SOP_LaneDeviceDefinitionForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblCode" id="a2de74f7-07e4-44a2-b178-f278c072973c">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblDescription" id="592845c3-df56-40fd-a494-405f65605525">
