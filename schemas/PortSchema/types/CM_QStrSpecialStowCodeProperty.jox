    <JadeMethod name="setComboValues" id="9b0e0b62-cd88-4d9f-8f44-d2f4a115b2ad">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		Set up combo box values in selector screen
//
vars
	specialStow			: CM_SpecialStow;
	specialStowDict		: CM_SpecialStowByCodeDict;
begin
	_combo.clear();
	specialStowDict := app.myRoot.allSpecialStows;
	
	foreach specialStow in specialStowDict do
		_combo.itemObject[_combo.addItem(specialStow.code &amp; '   ' &amp; specialStow.description)] := specialStow;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := specialStowDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := specialStowDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="3f4cfba4-7df9-40c5-8177-01a8ff443e41">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwma1	Initial creation

*/

vars
	specialStow 		: CM_SpecialStow;
	specialStowDict 	: CM_SpecialStowByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	specialStowDict := app.myRoot.allSpecialStows;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach specialStow in specialStowDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(specialStow.code) then
			selectionValue := 1;
			array.add(specialStow);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; specialStow.code &amp; ' (' &amp; specialStow.description&amp; ')');
		_tbl.accessRow(idx).itemObject := specialStow;
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="8677f409-c287-4458-8d46-20d12024f447">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwma1	Initial creation

*/

vars
	specialStow : CM_SpecialStow;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			specialStow := _tbl.accessRow(idx).itemObject.CM_SpecialStow;
			sa.add(specialStow.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="99d28bbf-5b75-4cea-bd5f-e77ee958bcf8">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwma1	Initial creation

*/

vars

begin
	if _value.isKindOf(CM_SpecialStow) then
		if _value &lt;&gt; null then
			return _value.CM_SpecialStow.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="8790d32b-8f4a-456e-8069-b1181bafbfb9">
        <source>translateToSearchValue(_value: Any): Any;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		Return the string value (SpecialStow.code) from the object.  For searching
//
vars
	invalidObj 		: Boolean;
	object			: CM_SpecialStow;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_SpecialStow) then
			object := _value.CM_SpecialStow;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.code;
	endif;
	
	return returnVal;
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="f679a434-e62c-470b-93e6-2345daa589fc">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	returnVal : String;
	str : String;
	stow : CM_SpecialStow;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			stow := app.myRoot.allSpecialStows[str];
			if stow &lt;&gt; null then
				returnVal := returnVal &amp; stow.code &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		if returnVal &lt;&gt; null then
			return returnVal[1:returnVal.length-2];
		endif;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		stow := app.myRoot.allSpecialStows[_value.String];
		if stow &lt;&gt; null then
			return stow.code;
		endif;
		
	elseif _value.isKindOf(CM_SpecialStow) then
		return _value.CM_SpecialStow.code;
		
	endif;
	
	return inheritMethod(_value, _sending);
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
