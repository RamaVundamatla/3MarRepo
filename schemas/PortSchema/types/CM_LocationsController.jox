    <JadeMethod name="canTwinLiftWithLocation" id="559f5d6f-ca6b-409d-8627-86e5962fc522">
        <source>canTwinLiftWithLocation(	_nextLocation : CM_LocationsController;
							_myTrackedItem,
							_nextLocationTrackedItem : CM_TrackedItem;
							_mode		: Integer;
							_direction  : Integer output;
							_errorString : String io	) : Boolean;
/*	

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwer1	Initial creation

*/

vars
	edition : Integer;
	invalid : Boolean;
begin

	_direction:=CM_RTQueueEntry.TWIN_NONE;
	if _nextLocation = null then
	//	write " next Loc = null";
		_errorString := app.getErrorString(Next_location_null);
		return false;
	endif;
	
	//08 Jan 2020	NDL	TFS 48204
	on Exception do app.handleDeletedObject( exception, _nextLocation, invalid );
	edition := _nextLocation.edition;
	if invalid then
		_errorString := app.getErrorString(Targe_locat_move_this_item_inv);
		return false;
	endif;
	
	if self.myTerminalArea &lt;&gt; _nextLocation.myTerminalArea then
		_errorString:= app.getErrorString(Next_locati_termin_area_differ);
		return false;
	endif;
	
	if _myTrackedItem &lt;&gt; null then
		if not _myTrackedItem.isTwinLiftCapable then
			_errorString:= app.getErrorString1(Conta_does_have_twin_lifta_typ, _myTrackedItem.id);
			return false;
		endif;
	endif;
	
	if _nextLocationTrackedItem &lt;&gt; null then
		if not _nextLocationTrackedItem.isTwinLiftCapable then
			_errorString:=app.getErrorString1(Conta_does_have_twin_lifta_typ, _nextLocationTrackedItem.id);
			return false;
		endif;
	endif;
	
	//epr CCMS 1099 container heights need to be the same - this is validated on setdown needs to be on pickup aswell
	if _myTrackedItem &lt;&gt; null and _nextLocationTrackedItem &lt;&gt; null then
		if _myTrackedItem.getActualHeight &lt;&gt; _nextLocationTrackedItem.getActualHeight then
			_errorString:=app.getErrorString(Container_heights_different);
			return false;
		endif;		
	endif;
	_direction:=CM_RTQueueEntry.TWIN_BOTH;
	return true;
epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="5133c6cd-08b2-417a-b192-7112bd8514fb">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport : CM_Passport) : Boolean;
// ---------------------------------------------------------------------------
// Created:      22 May 2003 by cnwsgp1
//
// Passport is passed in instead of user for performance reasons.  The data
// data access controllers for the current user are set on passport on startup.
// 15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
// 18 Oct 2017	   cnwma1  TFS #7242 PNL - Cargo Enquiry screen slow to open since 851 upgrade
// ---------------------------------------------------------------------------
vars
	sohLocn : CM_SOHLocation;
	dac :  CM_DataAccessController;
	hasProducts : Boolean;
	hasRestrictOperator : Boolean;
	locnRestriction : CM_LocationRestriction;
	operator : CM_Operator;

begin

	if app.isSpecial() then
		return true;
	endif;
	
	/*  //18.10.2017	cnwma1  TFS #7242
	if self.myTerminal &lt;&gt; null and not self.myTerminal.canUserAccessSelf(_user, _failedDAC, _passport) then   // 15/10/2015 cnwma1	PAR #36606
		return false;
	endif;
	*/
	// Changed to bring in line check for user (refer PAR 14106) - RJS 29/12/2009
	//dac := passport.allDataAccessControllers[CM_Operator.name];
	if _user &lt;&gt; null then
		dac := _user.allDataAccessControllers[CM_Operator.name];
	else
		dac := _passport.allDataAccessControllers[CM_Operator.name];
	endif;

	if dac = null then
		// no Operator Data Access Group so view all
		return true;
	endif;

	// does user have access to any of the restriction operators

	locnRestriction := self.getLocationRestriction();
	if locnRestriction &lt;&gt; null then
		foreach operator in locnRestriction.allOperators do
			hasRestrictOperator := true;
			if dac.canAccess(operator) then
				return true;
			endif;
		endforeach;
	endif;

	// does user have access to the operator for any of the SOHLocations
	foreach sohLocn in self.allProductLocations do
		if sohLocn.numTIs &gt; 0 then
			hasProducts := true;
			if dac.canAccess(sohLocn.myOperator) then
				return true;
			endif;
		endif;
	endforeach;

	if (not hasProducts) and (not hasRestrictOperator) then
		return true;
	endif;
	
	_failedDAC := dac;
	return false;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeTrackedItemSize" id="006e6961-63ff-4eb1-8d58-c814e55d647b">
        <updating/>
        <source>changeTrackedItemSize(moveMode : Integer; ti : CM_TrackedItem input; 
					originalHeight, originalLength : Integer;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwdwq1
// Purpose: 		Called whenever a TI has its size altered.
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin

	exclusiveLock(self);
	if ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Tracked Item", null, null);
		return;	
	endif;
	if not self.includesTI(ti, moveMode) then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_TI_NOTIN_COLL, self.getID ,null, null);
		return;		
	endif;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="originalHeight" type="Integer"/>
        <Parameter name="originalLength" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkControllerFullTAMax" id="9946b5d7-d785-4b1f-bb2e-06167456fa0b">
        <source>checkControllerFullTAMax(	_ti : CM_TrackedItem;
							_quantity : Integer;
							_weight : Decimal;
							_errorMsg : String output;
							_errorNum : Integer output;
							_availableQuantity : Integer output;	//16 June 2016	NDL	TFS 2172
							_availableWeight : Decimal output;	//16 June 2016	NDL	TFS 2172
							_availableVolume : Decimal output	//16 June 2016	NDL	TFS 2172
							) : Boolean;
/*

Date		Who		Reason
02 Apr 2014	cnwer1	Initial creation PAR
29 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite view Screen for Flexible Terminal Areas
29 Apr 2021	navdap1	TFS 49858 PRP Default Capacity per Location for GC Area
17 May 2021	navdap1	TFS 51093 MTN GC Row Capacity Issue
12 Jun 2024	navbs1	Bug 64443: MTN - 1090 error in road gate.
*/

vars
	tmpTI : CM_TrackedItem;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	productMinMax : CM_TerminalAreaProductMinMax;
	allTisByCargoType : DynaDictionary;
	iter : Iterator;
	checkVolume,
	checkWeight,
	checkQuantity: Boolean;
	areaQuantity : Integer;
	moveAmount,
	numPlanned,
	numQueued,
	areaVolume	: Decimal [18,4];			//navsp1 13MAY2022 TFS#53529
	areaWeight : Decimal [18,4];			//navsp1 13MAY2022 TFS#53529
	cargoTypeDesc,unit,amount : String;
	
	prodAreaMaxQty : Integer;	//20 Jun 2016	NDL	TFS 1752
	prodAreaMaxVol : Decimal [18,4];	//20 Jun 2016	NDL	TFS 1752	//navsp1 13MAY2022 TFS#53529
	prodAreaMaxWt : Decimal [18,4];	//20 Jun 2016	NDL	TFS 1752		//navsp1 13MAY2022 TFS#53529
	footPrint : Decimal [14,4];	//20 Jun 2016	NDL	TFS 1752
	
	isPerColumn, isPerGroup : Boolean;			// TFS 51093
	
begin

	if _ti = null then
		return false;
	endif;
	
	cargoType:= _ti.myCargoType;
	cargoSubType:= _ti.myProduct;
	
	productMinMax := self.allProductMinMax[self,cargoType,cargoSubType];	//29 Mar 2021	NDL	tFS 49912
	if productMinMax &lt;&gt; null then			// TFS 51093
		isPerGroup := true;					// TFS 51093
	endif;									// TFS 51093
	
	if productMinMax = null then	//29 Mar 2021	NDL	tFS 49912
		productMinMax:=self.myTerminalArea.allProductMinMax[null,cargoType,cargoSubType];
		if productMinMax &lt;&gt; null then		// TFS 51093
			isPerColumn := true;			// TFS 51093
		endif;								// TFS 51093
	endif;
	
	// TFS 49858 also check group for GC allocation row locations
	if productMinMax = null then
		if self.isKindOf(CM_GeneralCargoAllocController) then
			productMinMax := self.myTerminalArea.allProductMinMax[self.CM_GeneralCargoAllocController.myGroup, cargoType, cargoSubType];
			if productMinMax &lt;&gt; null then	// TFS 51093
				isPerGroup := true;			// TFS 51093
			endif;							// TFS 51093
		endif;
	endif;
	// TFS 49858 end of this bit
	
	if productMinMax &lt;&gt; null then
		
		checkWeight :=productMinMax.isCheckMaxWeight;
		checkVolume:=productMinMax.isCheckMaxVolume;
		checkQuantity:=productMinMax.isCheckMaxQuantity;
		
		//21 Jun 2016	NDL	TFS 1752
		prodAreaMaxQty := productMinMax.maxQuantity;
		prodAreaMaxVol := productMinMax.maxVolume;	
		prodAreaMaxWt := productMinMax.maxWeight;
		if self.isKindOf(CM_IrregularBlockController) then
			// the values above are a per sq metre for these controllers, so multiple by the footprint
			footPrint := self.CM_IrregularBlockController.getFootPrintInMetres();
			prodAreaMaxQty := ( prodAreaMaxQty * footPrint ).truncated();
			prodAreaMaxVol := prodAreaMaxVol * footPrint;	
			prodAreaMaxWt := prodAreaMaxWt * footPrint;
		// TFS 49453 start, TFS 51093 rewritten
		/*elseif self.isKindOf(CM_GeneralCargoAllocController) then
			// the values above are per column for these controllers, and each column is checked independently
			//footPrint := self.CM_GeneralCargoAllocController.getColumnsInAllocation();		// TFS 49858
			footPrint := 1;																		// TFS 49858
			prodAreaMaxQty := ( prodAreaMaxQty * footPrint ).truncated();
			prodAreaMaxVol := prodAreaMaxVol * footPrint;	
			prodAreaMaxWt := prodAreaMaxWt * footPrint;
		elseif self.isKindOf(CM_GeneralCargoAllocGroup) then
			// the values above are per column for these controllers, but only the group is checked
			footPrint := self.CM_GeneralCargoAllocGroup.allLocations.size;
			prodAreaMaxQty := ( prodAreaMaxQty * footPrint ).truncated();
			prodAreaMaxVol := prodAreaMaxVol * footPrint;	
			prodAreaMaxWt := prodAreaMaxWt * footPrint;*/
		elseif self.isKindOf(CM_GeneralCargoAllocController) or self.isKindOf(CM_GeneralCargoAllocGroup) then
			if isPerGroup then
				footPrint := 1;
			elseif isPerColumn and self.isKindOf(CM_GeneralCargoAllocController) then
				footPrint := 1;
			elseif isPerColumn and self.isKindOf(CM_GeneralCargoAllocGroup) then
				footPrint := self.CM_GeneralCargoAllocGroup.allLocations.size;
			else
				footPrint := 1;
			endif;
			prodAreaMaxQty := ( prodAreaMaxQty * footPrint ).truncated();
			prodAreaMaxVol := prodAreaMaxVol * footPrint;	
			prodAreaMaxWt := prodAreaMaxWt * footPrint;
		// TFS 49453 end, TFS 51093 rewritten end
		endif;
	

		if checkQuantity or checkVolume or checkWeight then
			if productMinMax.myProduct &lt;&gt; null then
				cargoTypeDesc:=productMinMax.myProduct.description;
			else
				cargoTypeDesc:=productMinMax.myCargoType.description;
			endif;
		
		
			create allTisByCargoType transient;
			allTisByCargoType.setMembership(CM_TrackedItem);
			allTisByCargoType.addMemberKey(CM_TrackedItem::myCargoType.name,false,false);
			allTisByCargoType.addMemberKey(CM_TrackedItem::myProduct.name,false,false);
			allTisByCargoType.endKeys(true);
			
			self.allTrackedItems.copy(allTisByCargoType);
			iter := allTisByCargoType.createIterator;
			allTisByCargoType.startKeyGeq(cargoType,cargoSubType,iter);
			while iter.next(tmpTI) do
				if tmpTI.myCargoType &lt;&gt; cargoType then
					break;
				endif;
				
				if tmpTI.myProduct &lt;&gt; cargoSubType then
					break;
				endif;
				
				if checkQuantity then
					areaQuantity:= areaQuantity + tmpTI.totalQuantity;
				elseif checkVolume then
					areaVolume:= areaVolume + tmpTI.totalVolume;
				elseif checkWeight then
					areaWeight:= areaWeight + tmpTI.totalWeight;
				endif;
			endwhile;
			//epr par 37074 17/11/15 have to exclude the move ti from the count of planned and queued otherwise double counting
			numPlanned := self.getNumPlannedForTAProductMax(productMinMax,_ti);
			numQueued := self.getNumQueuedForTAProductMax(productMinMax,_ti);
			if checkQuantity then
				moveAmount:=_quantity;
				if moveAmount = 0 then
					moveAmount:=_ti.totalQuantity ;
				endif;
				//16 Jun 2016	NDL	TFS 2172
				if (areaQuantity + numPlanned.Integer + numQueued.Integer) &lt; prodAreaMaxQty  then
					_availableQuantity := prodAreaMaxQty - (areaQuantity + numPlanned.Integer + numQueued.Integer);
				endif;
				
				if (areaQuantity + moveAmount.Integer + numPlanned.Integer + numQueued.Integer) &gt; prodAreaMaxQty  then
					
					_errorMsg:=	app.getErrorString1(Area_only_capac_will_excee_thi,prodAreaMaxQty.asStringJMT &amp; "  " &amp; cargoTypeDesc);
					_errorNum:=Area_only_capac_will_excee_thi;
					return true;
				endif;
			elseif checkVolume then
				moveAmount:=_weight/ _ti.getDensity;
				if moveAmount = 0 then
					moveAmount:=_ti.totalVolume ;
				endif;
				//16 Jun 2016	NDL	TFS 2172
				if (areaVolume + numPlanned + numQueued) &lt; prodAreaMaxVol  then
					_availableVolume := prodAreaMaxVol - (areaVolume + numPlanned + numQueued);
				endif;
				
				if (areaVolume + moveAmount + numPlanned + numQueued) &gt; prodAreaMaxVol  then
					unit :=  _ti.getDefaultMeasurementForType(Type_Volume).shortName;		//21.06.2024 navbs1 #64443;
					amount:=app.convertMeasurementForDisplay(unit, prodAreaMaxVol);		
					_errorMsg:=	app.getErrorString1(Area_only_capac_will_excee_thi, amount &amp; Space &amp; unit &amp; Space &amp; cargoTypeDesc);
					_errorNum:=Area_only_capac_will_excee_thi;
					return true;
				endif;
				
			elseif checkWeight then
				moveAmount:=_weight;
				if moveAmount = 0 then
					moveAmount:=_ti.totalWeight ;
				endif;
				//16 Jun 2016	NDL	TFS 2172
				if (areaWeight + numPlanned + numQueued) &lt; prodAreaMaxWt  then
					_availableWeight := prodAreaMaxWt - (areaWeight + numPlanned + numQueued);
				endif;
				
				if (areaWeight + moveAmount + numPlanned + numQueued) &gt; prodAreaMaxWt  then
					unit :=	_ti.getDefaultMeasurementForType(Type_Weight).shortName;		//21.06.2024 navbs1 #64443
					amount:=app.convertMeasurementForDisplay(unit, prodAreaMaxWt);	
					_errorMsg:=	app.getErrorString1(Area_only_capac_will_excee_thi,amount &amp; Space &amp; unit &amp; Space &amp; cargoTypeDesc);
					_errorNum:=Area_only_capac_will_excee_thi;
					return true;
				endif;
				
			endif;
			
		endif;
		
	else
		// TFS 49858 start
		if self.isKindOf(CM_IrregularBlockController) and _availableQuantity = 0 and _availableWeight = 0 then
			// if max weight/quantity is set on this location, set available quantity or weight from (max - actual)
			if self.CM_IrregularBlockController.defaultCapacity &lt;&gt; null or self.CM_IrregularBlockController.maximumWeight &lt;&gt; null then
				checkQuantity := self.CM_IrregularBlockController.defaultCapacity &lt;&gt; null;
				checkWeight := self.CM_IrregularBlockController.maximumWeight &lt;&gt; null;
				prodAreaMaxQty := self.CM_IrregularBlockController.defaultCapacity;
				prodAreaMaxWt := self.CM_IrregularBlockController.maximumWeight;
				
				iter := self.allTrackedItems.createIterator;
				while iter.next(tmpTI) do
					if checkQuantity then
						areaQuantity := areaQuantity + tmpTI.totalQuantity;
					elseif checkWeight then
						areaWeight := areaWeight + tmpTI.totalWeight;
					endif;
				endwhile;
				
				numPlanned := self.getNumPlannedForLocation(checkQuantity, checkWeight,_ti);
				numQueued := self.getNumQueuedForLocation(checkQuantity, checkWeight,_ti);
				if checkQuantity then
					moveAmount := _quantity;
					if moveAmount = null then
						moveAmount := _ti.totalQuantity;
					endif;
					if (areaQuantity + numPlanned.Integer + numQueued.Integer) &lt; prodAreaMaxQty then
						_availableQuantity := prodAreaMaxQty - (areaQuantity + numPlanned.Integer + numQueued.Integer);
					endif;
					if (areaQuantity + moveAmount.Integer + numPlanned.Integer + numQueued.Integer) &gt; prodAreaMaxQty  then
						_errorMsg := app.getErrorString1(Area_only_capac_will_excee_thi, prodAreaMaxQty.asStringJMT);
						_errorNum := Area_only_capac_will_excee_thi;
						return true;
					endif;
				elseif checkWeight then
					moveAmount:=_weight;
					if moveAmount = null then
						moveAmount:=_ti.totalWeight ;
					endif;
					if (areaWeight + numPlanned + numQueued) &lt; prodAreaMaxWt  then
						_availableWeight := prodAreaMaxWt - (areaWeight + numPlanned + numQueued);
					endif;
					if (areaWeight + moveAmount + numPlanned + numQueued) &gt; prodAreaMaxWt  then
						unit:= _ti.getDefaultMeasurementForType(Type_Weight).shortName;		//12.06.2024 navbs1 #64443
						amount := app.convertMeasurementForDisplay(unit, prodAreaMaxWt);	
						_errorMsg := app.getErrorString1(Area_only_capac_will_excee_thi, amount &amp; Space &amp; unit &amp; Space);
						_errorNum := Area_only_capac_will_excee_thi;
						return true;
					endif;
				endif;
			endif;
		endif;
		// TFS 49858 end
	endif;
	
	
	return false;
epilog
	delete allTisByCargoType;
	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <Parameter name="_errorNum" type="Integer" usage="output"/>
        <Parameter name="_availableQuantity" type="Integer" usage="output"/>
        <Parameter name="_availableWeight" type="Decimal" usage="output"/>
        <Parameter name="_availableVolume" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearOffsetFlexi" id="901be984-b0d0-4a6a-9ae3-238089dce98e">
        <updating/>
        <source>clearOffsetFlexi(_control : CMIF_MoveController;
				_ignoreFutureMove : CM_FutureMove) updating;
/* ---------------------------------------------------------------------------
// Created:     18 December 2008 by cnwab1
//
//					PAR 18682 CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
19 Oct 2012			cnwer1			PAR 30524 - the _ignoreFutureMove is passed in when a queued/planned future move is unplanned/unqueued 

*/
vars
	canClear : Boolean;
	theTI : CM_TrackedItem;
	oldOffset : Integer;
begin
//if self.getFullId() = "RIGHT C08" then
//write "";
//endif;
	oldOffset:=self.offsetFlexi;
	theTI := _control.myTrackedItem;
	
	canClear := (self.allTrackedItemOSBackEnds.isEmpty()  and self.allTrackedItems.isEmpty()
			and self.allTrackedItemOSBackEndsQd.isEmpty()  and (self.allQueuedFutureMoves.isEmpty() or (self.allQueuedFutureMoves.size = 1 and self.allQueuedFutureMoves.first = _ignoreFutureMove))
			and self.allTrackedItemOSBackEndsPd.isEmpty() and (self.allPlannedFutureMoves.isEmpty  or (self.allPlannedFutureMoves.size = 1 and self.allPlannedFutureMoves.first =_ignoreFutureMove)));
			
	if not canClear and self.isRightAligned() then
		canClear := (self.allTrackedItemOSBackEnds.size = 1 and self.allTrackedItemOSBackEnds.includes(theTI))
		or (self.allTrackedItems.size = 1 and self.allTrackedItems.includes(theTI));
	endif;
	
	if _control.moveMode = REAL_MODE then
		if canClear then
//		if self.allTrackedItemOSBackEnds.isEmpty()  and self.allTrackedItems.isEmpty() then
			self.offsetFlexi := 0;
		elseif not self.allTrackedItemOSBackEnds.isEmpty() and self.allTrackedItems.isEmpty() then
			// added this in incase have a 53 and then another container, butted up together.
			// the other container has an offset of 13 foot. When the 53 is moved away the offset stays at 13
			// if a 45 is placed where the 53 had been and had started, the offset still stays as 13.
			// If the other container is then moved away this code changes the 13 offset to be 5
			self.setOffsetFlexi(self.allTrackedItemOSBackEnds.first, _control, false);
		endif;
	elseif _control.moveMode = QUEUE_MODE then
		// no Qd backends or  Qd front ends
		if canClear then
//		if self.allTrackedItemOSBackEndsQd.isEmpty()  and self.allQueuedFutureMoves.isEmpty() then 
			self.offsetFlexi := 0;
		// no Qd front ends
		elseif not self.allTrackedItemOSBackEndsQd.isEmpty() and self.allQueuedFutureMoves.isEmpty() then
			self.setOffsetFlexi(self.allTrackedItemOSBackEndsQd.first, _control, false);
		endif;
	elseif _control.moveMode = PLANNING_MODE then
		// no Pd backends or  Pd front ends
		if canClear then
//		if self.allTrackedItemOSBackEndsPd.isEmpty()  and self.allPlannedFutureMoves.isEmpty() then 
			self.offsetFlexi := 0;
		// no Pd front ends
		elseif self.allPlannedFutureMoves.isEmpty() then
			self.setOffsetFlexi(self.allTrackedItemOSBackEndsPd.first, _control, false);
		endif;

	
	endif;
epilog
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_ignoreFutureMove" type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="containsCargoForAnotherRelease" id="d31d986d-c0ba-43d6-8daf-57a65e1ecc4d">
        <source>containsCargoForAnotherRelease(_release : CM_BulkRelease input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	ti : CM_TrackedItem; 
	futureMove : CM_FutureMove;
begin
	if _release = null then
		return false;
	endif;

	foreach ti in self.allTrackedItems  discreteLock do
		if not _release.allTrackedItemsAssigned.includes(ti) then
			return true;
		endif;
	endforeach;
	
	foreach futureMove in self.allQueuedFutureMoves discreteLock do
		ti := futureMove.getTrackedItem;
		if ti &lt;&gt; null then
			if not _release.allTrackedItemsAssigned.includes(ti) then
				return true;
			endif;
		endif;
	endforeach;

	return false;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
