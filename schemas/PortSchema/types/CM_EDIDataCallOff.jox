    <JadeMethod name="canBeDBLoaded" id="53011a62-7dc9-4ffc-9cba-f8272cfcffa1">
        <source>canBeDBLoaded(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
//
vars

begin
	if self.myRequestMultiLine &lt;&gt; null then
		return self.myRequestMultiLine.canBeDBLoaded();
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeDBLoadedAutomatic" id="2e384366-1024-4035-9f90-e557b977ae66">
        <source>canBeDBLoadedAutomatic(_agent: CM_EDIControllerAgent): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
// 11/08/2023   navsp1      ChangeRequest 59751: EUP | Manifest and Calloff - AutoDB Load config
// 28/08/2023	navdap1		TFS 60115 EUP FR CallOff
// 15 Nov 2023	navsaa30 	Bug 61174: EUP | Issues reprocessing EDI files with errors and warnings
vars
	result	: Boolean;
	msgType	: String;
	canLoad	 : CM_NameValuePair;
    configValue : String;
	error 	: CM_EDIError;
	count 	: Integer;
begin
	result	:= inheritMethod(_agent);
	count 	:= 0;								// 15.Nov.23  navsaa30 #61174
	// are we running automatically from a BGP or from a web synchronous call
	// if so, we need to check whether auto DB loading is supressed for this 
	// transport mode
	if _agent.isBGPAuto or app.isFromEDIviaWeb then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "_agent.isBGPAuto is " &amp; _agent.isBGPAuto.String &amp; ", app.isFromEDIviaWeb is " &amp; app.isFromEDIviaWeb.String, LogDEBUG);
		msgType := "CallOff|" &amp; self.type &amp; "|" &amp; self.transportationMode;		// TFS 60115
		canLoad := self.getMyTerminal.allDBLoadOptions[msgType];
		if canLoad &lt;&gt; null then
            configValue := canLoad.value;       //11.Aug.2023 navsp1 TFS 59751 &gt;&gt;&gt;&gt;
            if configValue.length = 3 then        
                
                if self.statusString = CMIF_JsonHeaderEUP.Status_Create and configValue[1:1] = "0" then
                    result := false;
                elseif self.statusString = CMIF_JsonHeaderEUP.Status_Replace and configValue[2:1] = "0" then
                    result := false;
                elseif self.statusString = CMIF_JsonHeaderEUP.Status_Cancel and configValue[3:1] = "0" then
                    result := false;
                endif;                          //11.Aug.2023 navsp1 TFS 59751 &lt;&lt;&lt;&lt;
                
            elseif configValue = "0" then
                result := false;
            endif;
			
			foreach error in self.allErrorWarnings do						// 15.11.23 navsaa30 #61174
				if error.errorCode = 1027 or error.errorCode = 1081 then 	//lock or deadlock
						count := count + 1;
				endif;
			endforeach;
			//Prevent automatic DB Load if any Errors or warnings				//21.Sep.2023 navsp1 TFS 60473
			if self.allErrorWarnings.size &lt;&gt; count then							// 15.11.23 navsaa30 #61174
				result := false;
				app.writeLog(method.qualifiedName &amp; Tab &amp; msgType &amp; " is unable to be loaded using automatic DB loading due to warnings", LogINFO);
			endif;
			
            if result = false then
				app.writeLog(method.qualifiedName &amp; Tab &amp; msgType &amp; " is not set for automatic DB Load", LogDEBUG);
			else
				app.writeLog(method.qualifiedName &amp; Tab &amp; msgType &amp; " is set for automatic DB Load", LogDEBUG);
			endif;
        else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "canLoad value is null", LogDEBUG);
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_agent" type="CM_EDIControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="70ddaa34-c5c1-40d0-a506-4b124c38eb8b">
