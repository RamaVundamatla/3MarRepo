<Class name="CM_DataContainerBlock" id="68fadfad-ba8a-45e1-805c-5d50fe69cd1e">
    <superclass name="CM_DataContainerEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allItems" id="2584ffa1-99dc-4110-af38-5105b984a378">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_DataContainerItemArray"/>
        <access>readonly</access>
        <Inverse name="CM_DataContainerItem::myBlock"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myDataContainer" id="9e2dab22-11e9-47d9-8354-2edf8a8d080f">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_DataContainer"/>
        <access>readonly</access>
        <Inverse name="CM_DataContainer::allBlocks"/>
    </ExplicitInverseRef>
    <JadeMethod name="addNewIcon" id="afcc2ef2-074f-4436-9362-689445a88e5f">
        <source>addNewIcon(_character : Character; _scaleFactor : Integer; _obj : Object;
		_font : String; _colour : Integer) : CM_DataContainerItem;
// ---------------------------------------------------------------------------
// Created:      03 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	icon : CM_DataContainerIcon;
	
begin
	create icon transient;
	icon.setForCreateIcon(_character, _scaleFactor, _obj, _font, _colour);
	self.allItems.add(icon);
	return icon;
end;</source>
        <Parameter name="_character" type="Character"/>
        <Parameter name="_scaleFactor" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_font" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <ReturnType type="CM_DataContainerItem"/>
    </JadeMethod>
    <JadeMethod name="addNewItem" id="f3f8eec9-fd8f-48f0-981c-2a6d05df0833">
        <source>addNewItem(_text : String; _type : Integer; _scaleFactor : Integer; _obj : Object) : CM_DataContainerItem;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;

begin
	create item transient;
	item.setForCreate(_text, _type, _scaleFactor, _obj);
	self.allItems.add(item);
	return item;
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scaleFactor" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="CM_DataContainerItem"/>
    </JadeMethod>
    <JadeMethod name="hasAllData" id="74d595d1-a35f-45ee-bc56-b9cec0362218">
        <source>hasAllData() : Boolean;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;

begin
	foreach item in self.allItems do
		if not item.isData then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasAllHeaders" id="9e55cdd8-9082-4118-9c99-e620b080b6bf">
        <source>hasAllHeaders() : Boolean;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;

begin
	foreach item in self.allItems do
		if not item.isHeader then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasAllIcons" id="fb8fbd4d-a967-4e74-b621-8f528c6b59b2">
        <source>hasAllIcons() : Boolean;
// ---------------------------------------------------------------------------
// Created:      03 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;

begin
	foreach item in self.allItems do
		if not item.isIcon and not item.isIconLabel then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasAllLabelHeaders" id="571787b0-aac7-4034-8e0a-1ed9cf6d1f5b">
        <source>hasAllLabelHeaders() : Boolean;
// ---------------------------------------------------------------------------
// Created:      25 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;

begin
	foreach item in self.allItems do
		if not item.isLabelHeader then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
