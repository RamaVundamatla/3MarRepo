    <JadeMethod name="validateMe" id="d7d9bc0f-058d-4cdb-9b4f-e19bec4d8e53">
        <source>validateMe();
/*

Purpose:			Validates the Creation, Updating and Deleting of Cargo Surcharges fitting a certain criteria

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
19 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	realForCheck,
	existing		: CM_InvTypeCargoMultiSurcharge;
	commodity		: CM_Commodity;
	cargoSubType	: CM_Product;
	cargoType		: CM_CargoType;
	found			: Boolean;
	
begin
	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;
	
	if self.getCargoSurchargeInvLineType = null then
		app.raiseCMException(Surcha_invoic_line_type_select, null,null);
		return;
	endif;
	
	//20 Jun 2018	NDL	TFS 39305
	if self.allSelectedInvLineTypes.isEmpty then
		app.raiseCMException(Must_have_least_selec_invoi_li,null,null);
		return;
	elseif self.allSelectedInvLineTypes.includes( self.getCargoSurchargeInvLineType ) then
		app.raiseCMException(Select_not_incl_Inv_Line, null, null );
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	foreach cargoSubType in self.allCargoSubTypes do
		if not self.allCargoTypes.includes(cargoSubType.myCargoType) then
			app.raiseCMException(Combi_cargo_types_types_commo_, null, null );
			break; //On first error break we do not want too errors that are the same displayed
		endif;
	endforeach;
	
	foreach commodity in self.allCommodities do
		found := false;
		foreach cargoType in self.allCargoTypes do
			if commodity.allCargoTypes.includes(cargoType) then
				found := true;
			endif;
		endforeach;
		if not found then
			app.raiseCMException(Combi_cargo_types_types_commo_, null, null );
			break; //On first error break we do not want too errors that are the same displayed
		endif;
	endforeach;
	
	if self.validFrom = null then
		app.raiseCMException(Valid_from_date_must_entere, null, null );
	endif;
	
	if self.validTo &lt;&gt; null and self.validTo &lt; self.validFrom then
		app.raiseCMException(Valid_cannot_before_valid_from, null, null );
	endif;
	
	if self.surchargeAmount &lt;&gt; null and self.surchargeRate &lt;&gt; null then
		app.raiseCMException(Eithe_surch_rate_surch_amoun_m, null, null );
	endif;
	
end;</source>
    </JadeMethod>
