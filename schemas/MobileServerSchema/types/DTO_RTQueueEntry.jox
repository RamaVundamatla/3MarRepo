/*

Date		Who		Reason
27 January 2015	cnwer1	Initial creation PAR 35702

*/


vars
	rtTask ,setdownRTTask: CM_RTQueueTask;

begin
	if self.myRealQueueEntry = null then
		return null;
	endif;
	rtTask := self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrPickupTask;
	if rtTask = null then
		return null;
	endif;
	if rtTask.isPickUp then
		setdownRTTask:=self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrSetDownTask(); 
	else
		setdownRTTask:=	rtTask;
	endif;
	
	if setdownRTTask = null then
		// occurred in DMAST. 06 Sep 2012	NDL
		return null;
	endif;

	return setdownRTTask.getTargetLocationForDisplay();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveExtraDetailsFromTI" id="188cb859-9dbb-4921-b099-3a0512511984">
        <source>getMoveExtraDetailsFromTI(_vmAgent : VehicleMountedGenericAgent input) : String;
// ---------------------------------------------------------------------------
// Created:     23 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tlTI, theTI : CM_TrackedItem;
	moveState : Integer;
	tmpLC : CM_LocationsController;
	yrdLC : CM_YardController;
	rtTask: CM_RTQueueTask;
	rtQueueEntry,tlRTQueueEntry    :  CM_RTQueueEntry;
	tmpString : String;
begin
	// ### JOB DETAILS
	if self.doorDirection &lt;&gt; null then
		tmpString := tmpString &amp; "DOOR DIR: " &amp;  self.doorDirection &amp; CrLf;
	
	endif;
	
	rtQueueEntry:=self.myRealQueueEntry.CM_RTQueueEntry;
	if rtQueueEntry = null then
		if app.isSpecial() then
			tmpString := tmpString &amp; "NO QUEUE ENTRY" &amp; CrLf;
		endif;
		return tmpString;
	endif;

	
	// ### CARGO DETAILS
	theTI := self.getTI();
	
	if theTI = null then
		if app.isSpecial() then
			tmpString := tmpString &amp; "NO TI" &amp; CrLf;
		endif;
		return tmpString;
	endif;
	if theTI.isOverDimensions then
		tmpString := tmpString  &amp;  "OVER DIMENSIONS" &amp; CrLf;
		tmpString := tmpString &amp;  theTI.getODDescription() &amp; CrLf;
	endif;
	//epr TFS 37584 10/5/18
	if theTI.isOverStowedRTQueue(_vmAgent.myMachine) then
		tmpString := tmpString &amp; "IS OVERSTOWED" &amp; CrLf;
	endif;


	// ### LOCATION DETAILS
	moveState:=_vmAgent.getNextMoveState;
	if moveState =  VehicleMountedGenericAgent.PICKUP_TASK  then
		rtTask := rtQueueEntry.getTaskOfType(TASK_PICKUP,TASK_ACCEPTED);
		if rtTask = null then
			if app.isSpecial() then
				tmpString := tmpString &amp; "NO PICKUP TASK" &amp; CrLf;
			endif;
			return tmpString;
		endif;
		tmpLC := rtTask.getSourceLocation();

	elseif moveState = VehicleMountedGenericAgent.SETDOWN_TASK  then
		rtTask := rtQueueEntry.getTaskOfType(TASK_SETDOWN,TASK_WORKING);
		if rtTask = null then
			if app.isSpecial() then
				tmpString := tmpString &amp; "NO SETDOWN TASK" &amp; CrLf;
			endif;
			return tmpString;
		endif;
		tmpLC := rtTask.targetLocation;
	endif;
	
	if tmpLC = null then
		return tmpString;
	endif;
	
	tmpString := tmpString &amp; tmpLC.getVMRTMoveExtraDetails(theTI);
	
	return tmpString;
epilog

end;</source>
        <Parameter name="_vmAgent" type="VehicleMountedGenericAgent" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRfidCode" id="213b454d-3957-411f-855e-70d09ff31c0f">
        <source>getRfidCode():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 April 2012	cnwndl1	Initial creation	Par 29417

*/

vars

	wle : CM_WorkListEntry;
	rfid : CM_RFIDTag;

begin

	if self.myRealQueueEntry = null then
		return null;
	endif;

	wle := self.myRealQueueEntry.CM_RTQueueEntry.myWorkListEntry;
	if wle = null then
		return null;
	endif;
	
	rfid := wle.getMyRFIDTag();
	if rfid = null then
		return null;
	endif;

	return rfid.code;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="4de03245-2589-4179-b902-b102ca764b44">
        <source>getTI() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2010	cnwer1	Initial creation

*/

vars
	qEntry : CM_RTQueueEntry;
	task 	: CM_RTQueueTask;
begin
	qEntry:=self.myRealQueueEntry.CM_RTQueueEntry;
	if qEntry = null then
		return null;
	endif;
	
	//33384 qEntry.getTrackedItem does not work for auto overstow tasks
	task:=qEntry.getFirstUncompletedTask();
	if task &lt;&gt; null then
		if task.ti &lt;&gt; null then
			return task.ti;
		endif;
	endif;
	
	
	return qEntry.getTrackedItem;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="14d28bea-1789-4c2d-957b-9d9749b4278d">
        <source>getVoyageCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2013	cnwmc5	Initial creation		PAR 31550

*/

vars
	ti : CM_TrackedItem;

begin
	ti := self.getTI();
	if ti = null then
		return null;
	else
		return ti.getDisplayStringForAttribute(ETRow_Voyage, false);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
