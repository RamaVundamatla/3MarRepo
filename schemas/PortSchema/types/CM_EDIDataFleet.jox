    <JadeMethod name="verifyEDIData" id="dd816350-ed87-496b-b353-7e470bfa7ebf">
        <updating/>
        <source>verifyEDIData(): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2008	cnwrd1	Initial creation

*/

vars
	site 	:	Integer;
begin

	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	
	if self.myOperator = null then
//		app.raiseCMException1(ERR_INVALID_OPERATOR, 'Operator',  'Operator', null);
	endif;

epilog	
	return app.myPassport.allErrorWarnings.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="0f1afac4-863e-493f-9862-faacaf01b828">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2008	cnwrd1	Initial creation

*/

vars
	ediTI			: CM_EDITrackedItem;	
	ediUserTI		: CM_EDIFleetTI;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	/*
	if self.createToSite &lt; TI_SITE_UNDEFINED or self.createToSite &gt; TI_SITE_MAX then
		app.raiseCMException2(ERR_FIELD_VALUE,app.siteEnumToString(self.createToSite), 'site', self.createToSite.String, null);
	endif;
	*/
	beginTransaction;
	
	foreach ediTI in self.allEDITrackedItems discreteLock do
		ediUserTI := ediTI.CM_EDIFleetTI;
		ediUserTI.verifySelf();
	endforeach;
	app.cmsCommitTransaction(app.myPassport);
		
	return app.myPassport.allErrorWarnings.size;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
