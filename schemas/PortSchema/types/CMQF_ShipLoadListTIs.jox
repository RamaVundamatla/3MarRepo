    <JadeMethod name="filterObjects" id="ccd4cf35-57e2-47e3-865d-001b21866b89">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		04 February 2003  by Jason Chapman  (cnwjc2)
//				CNWTH2 changed to use the voyage.allOnsiteTIs dict instead of terminals
//				lots quicker - 
//				This method now assumes there will only be one voyage in the allVoyages collection
//				as will always be the case from the load list screen
// 11.7.2018	cnwma1	Bug 39371: SNO - RTS flag issue on TS containers
// ---------------------------------------------------------------------------
vars
	theTI 			: CM_TrackedItem;
	theTermArea 	: CM_TerminalArea;
	theLocation 	: CM_LocationsController;
	aTaskDesc 		: CM_ToDoTaskDesc;
	aTask 			: CM_ToDoTask;
	aOK 			: Boolean;
	loadStateSet 	: Boolean;
	theDischargePort : CM_Port;
	theRoot 		: CM_Root;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
	querySelf		: CMQF_ShipLoadListTIs;
	voyage			: CM_Voyage;
begin
	
	querySelf := self;
	//app.cmsBeginLoad(loadStateSet);
	// Par 15247
	endLoad;
	voyage := self.allVoyages.first;
	if voyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No voyage object passed into query!');
		return;
	endif;
	terminal := self.allTerminals.first;
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No terminal object passed into query!');
		return;
	endif;
	
	self.allQryTrackedItems.clear;
	theRoot := app.myRoot;

	if self.plannedToShip and not self.onSiteOnly then
		// ### include on ship stuff cos of DLR loads that have been planned  whilst still on ship
		foreach theTI in voyage.allOnshipTIsByCargoTypeId discreteLock do : tiLoop
			if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
			   (not querySelf.allQryTrackedItems.includes(theTI)) then
				querySelf.allQryTrackedItems.add(theTI);
			endif;
			
		endforeach;

	endif;

	if not self.transhipOnly // CCMS 1011		
	and not self.tbaOnly then // TFS 45590
		foreach theTI in voyage.allOnsiteTIsByCargoTypeId discreteLock do : tiLoop
			if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
			   (not querySelf.allQryTrackedItems.includes(theTI)) then
				querySelf.allQryTrackedItems.add(theTI);
			endif;
			
		endforeach;
		if self.onSiteOnly then
			return;
		endif;
		
		foreach theTI in terminal.allNotifiedTIsByCargoTypeId discreteLock do : tiLoop
			if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
			   (not querySelf.allQryTrackedItems.includes(theTI)) then
				querySelf.allQryTrackedItems.add(theTI);
			endif;
			
		endforeach;
	endif;

	// TFS 45590	
	foreach theTI in voyage.allTbaTIsByCargoTypeId discreteLock do : tiLoop
		if self.checkStatusIncludesObject(theTI, _passport, breakOut) 
		and (not querySelf.allQryTrackedItems.includes(theTI)) then
			querySelf.allQryTrackedItems.add(theTI);
		endif;
		
	endforeach;
	
	if not self.tbaOnly then	//30 Apr 2020	NDL	TFS 49219
		//23 Mar 2020	NDL	TFS 47004
		foreach theTI in voyage.allRRPTIsByCargoTypeId discreteLock do	
			if self.checkStatusIncludesObject(theTI, _passport, breakOut) 
			and (not querySelf.allQryTrackedItems.includes(theTI)) then
				querySelf.allQryTrackedItems.add(theTI);
			endif;
			
		endforeach;
	endif;
	
	// CCMS 1011
	foreach theTI in voyage.allTranshipTIsExport discreteLock do : tiLoop
		if self.checkStatusIncludesObject(theTI, _passport, breakOut) 
		and  (not querySelf.allQryTrackedItems.includes(theTI)) then
			if theTI.site = TI_SITE_ONSHIP 
			and theTI.myPrimaryActualLocation.CM_VoyageController.myVoyage = voyage then
				continue;
			endif;
			if self.transhipOnly = true             //11.7.2018 cnwma1 Bug 39371
			or theTI.planningState = PLANNED_LOAD_STATE then // TFS 45590
				querySelf.allQryTrackedItems.add(theTI);
			endif;
		endif;
		
	endforeach;

epilog
	//	app.cmsEndLoad(loadStateSet);
	// Par 15247
	endLoad;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="021f8d03-87b5-47c1-a0ff-4e35061ddb30">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 29/07/2010	cnwdap1		PAR #25232 Display tranships for Export voyage when the TI is still on the Import voyage
vars
	theDischargePort 	: CM_Port;
	querySelf			: CMQF_ShipLoadListTIs;
	plannedToShip, tiIsTSExport, includeIn		: Boolean;
	failedDAC  :CM_DataAccessController;
	queryVoyage			: CM_Voyage;			// PAR #25232
	transhipVoyageMatch	: Boolean;				// PAR #25232
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	

	if (not (_ti.canUserAccessSelf(null, failedDAC, _passport))) then
		return false;
	endif;

	if _ti.isChild then // PAR 8655
		return false;
	endif;
//if _ti.id = "KNLV3319820" then

//endif;
	queryVoyage := querySelf.allVoyages.first;																// PAR #25232
	//plannedToShip := _ti.hasFutureMoveLoad(PLANNING_MODE); // PAR 8061 added
	//cnwjo3 par 26028
	plannedToShip := _ti.hasFutureMoveLoadForVoyage(PLANNING_MODE,queryVoyage);
	//tiIsTSExport := _ti.isTranshipExport();																// PAR #25232
	tiIsTSExport := _ti.isTranshipExport() or (_ti.isTranshipItem and _ti.myExportVoyage = queryVoyage);	// PAR #25232

	includeIn := false;
//	if self.transhipOnly then
//		if tiIsTSExport then
//			includeIn := true;
//		endif; 
//	elseif (plannedToShip = self.plannedToShip) then
//		includeIn := true;
//	endif;
	// 27/9/19 MAP TFS 45590
	if (plannedToShip = self.plannedToShip) then
		if self.transhipOnly then
			if tiIsTSExport then
				includeIn := true;
			endif;
		elseif _ti.isTBAorIsRRP then // TFS 45590
			if self.plannedToShip then // The query is for the main NON PLANNED table
				includeIn := plannedToShip;
			else
				includeIn := self.tbaOnly; // TFS 45590
			endif;
		else
			includeIn := true;
		endif;
	endif;
	
	transhipVoyageMatch := false;																			// PAR #25232
	if _ti.isTranshipItem and (queryVoyage = _ti.myImportVoyage or queryVoyage = _ti.myExportVoyage) then	// PAR #25232
		transhipVoyageMatch := true;																		// PAR #25232
	endif;																									// PAR #25232
	
	//theDischargePort := app.myRoot.allPorts[_ti.dischargePort.trimBlanks];
	theDischargePort := app.myRoot.allPorts[_ti.dischargePort.trimBlanks];
	if (querySelf.allCargoTypes.isEmpty or querySelf.allCargoTypes.includes(_ti.myCargoType)) and
	   (querySelf.allPortsDischarge.isEmpty or (theDischargePort &lt;&gt; null and querySelf.allPortsDischarge.includes(theDischargePort))) and
	   (querySelf.allOperators.isEmpty or querySelf.allOperators.includes(_ti.myOperator)) and
	   //(querySelf.allVoyages.isEmpty or querySelf.allVoyages.includes(_ti.myVoyage)) and					// PAR #25232
	   (querySelf.allVoyages.isEmpty or querySelf.allVoyages.includes(_ti.myVoyage) or transhipVoyageMatch) and			// PAR #25232
	   //(_ti.isExport or _ti.isRehandle) and							// PAR #25021
	   //(_ti.isExport or _ti.isTranshipOutbound or _ti.isRehandle) and	// PAR #25021						// PAR #25232
	   (_ti.isExport or (_ti.isTranshipItem and querySelf.allVoyages.includes(_ti.myExportVoyage)) or _ti.isRehandle) and	// PAR #25232
	   includeIn and
//	   ((tiIsTSExport = self.transhipOnly) or (plannedToShip = self.plannedToShip)) and// PAR 7212 AKB2003DEC
	   (not querySelf.isGroundPos or querySelf.isGroundPos = _ti.isGroundPosNoOverstow) and
	   (not querySelf.isOverDiffVoy or querySelf.isOverDiffVoy = _ti.isOverStowing) and
	   (not querySelf.isOverstowed or querySelf.isOverstowed = _ti.isOverStowed(REAL_MODE)) and
	   (not querySelf.useTopPosition or (_ti.isTopPositionCargo(querySelf.topPosition))) then
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
