    <JadeMethod name="doClearFilter" id="3b67c3a9-710b-4b45-b6e2-089efaa543e1">
        <updating/>
        <source>doClearFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 October 2022	navgm20	ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS
27/07/2023	navkc1	Bug 57701: FR | 54538 - EUP - Filtered Drop-downs and Lists - Find lists filter
*/

vars
	txtFilter	:	CMUI_TextBox;
begin
	txtFilter := self.txtFind;
	
	if txtFilter.text &lt;&gt; "" then
		txtFilter.text := "";
		//self.btnClear.enabled := true; 	//27/07/2023	navkc1	Bug 57701 keep the button enabled
	//elseif txtFilter.text = "" then		//27/07/2023	navkc1	Bug 57701
		//self.btnClear.enabled := false; 	//27/07/2023	navkc1	Bug 57701
	endif;
	self.populateTable();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageLostFocus" id="99a6b3ea-97ef-4f1e-926d-6a6957c16995">
        <source>doCmbVoyageLostFocus();
//08 June 2010	cnwml2

vars
	bol : CM_BOLIn;
	row : Integer;
	voyage : CM_Voyage;
	altColour : Boolean;
	rowMax : Integer;
	
	selectedColl : ObjectSet;
	criteriaColl : ObjectSet;
	obj : Object;
	strArray : StringArray;
	str : String;
	pattern : CMIF_YAPattern;
begin
	self.tblAvailable.clearTable();
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if voyage = null then
		return;
	endif;
	
	
	self.tblAvailable.rows := 0;	
	self.tblAvailable.columns := 3;
	self.tblAvailable.fixedColumns := 0;
	self.tblAvailable.gridLines := false;
	self.tblAvailable.accessColumn(1).alignment := Table.Alignment_Center_Middle;

	self.tblAvailable.accessColumn(1).width := 25;
	//self.tblAvailable.accessColumn(2).width := 120;
	self.tblAvailable.accessColumn(2).width := 250;		// TFS 2479 02/08/2016 make it wider for the BOL number

	self.setSortOrder();
	
	create criteriaColl transient;
	create selectedColl transient;
	foreach bol in voyage.allBOLInByTypeStatusNumDT do
		row := tblAvailable.addItemObject( bol.number, bol);
		criteriaColl.add(bol);
	endforeach;
	
	//colour row etc
	rowMax := tblAvailable.rows;
	foreach row in tblAvailable.fixedRows + 1 to rowMax do
		altColour := not altColour;
		if altColour then
			tblAvailable.accessRow(row).backColor := self.colorRow1;
		else
			tblAvailable.accessRow(row).backColor := self.colorRow2;
		endif;
	endforeach;
	
	if not self.tblAvailable.allSelectedObjects.isEmpty then
		tblAvailable.findObjectInRow(self.tblAvailable.allSelectedObjects.first, tblAvailable.row);
		self.positionDisplay();
	endif;
	
	create strArray transient;
	
	foreach obj in criteriaColl do
		bol := obj.CM_BOLIn;
		if strArray.isEmpty then
			if self.txtFind.text &lt;&gt; null then
				if self.txtFind.text.containsOneOf(",") then
					create pattern transient;
					pattern.getTokens(self.txtFind.text, strArray);
				else
					strArray.add(self.txtFind.text);
				endif;
			endif;
		endif;
		foreach str in strArray do
			if bol.number = str then
				selectedColl.add(bol);
				break;
			endif;
		endforeach;
	endforeach;
	
	self.tblAvailable.setSelected(selectedColl);
	self.doFind();
	self.txtFind.setFocus();
		

epilog
	delete selectedColl;
	delete criteriaColl;
	delete strArray;
	delete pattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbWeightLostFocus" id="bfa6d77b-63cc-4ac2-ad76-251309dce369">
        <source>doCmbWeightLostFocus();
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
01/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	measure			: CM_MeasurementType;
	range			: CM_WeightRange;
	criteriaColl	: ObjectSet;
	selectedColl	: ObjectSet;
	row, rowMax		: Integer;
	altColour		: Boolean;
	strArray		: StringArray;
	str				: String;
	pattern			: CMIF_YAPattern;
	obj				: Object;

begin
	self.tblAvailable.clearTable;
	measure := self.cmbWeight.listObject.CM_MeasurementType;
	if measure = null then
		return;
	endif;
	
	self.tblAvailable.rows := 0;	
	self.tblAvailable.columns := 3;
	self.tblAvailable.fixedColumns := 0;
	self.tblAvailable.gridLines := false;
	self.tblAvailable.accessColumn(1).alignment := Table.Alignment_Center_Middle;

	self.tblAvailable.accessColumn(1).width := 25;
	self.tblAvailable.accessColumn(2).width := 120;
	
	//self.setSortOrder();
	
	create criteriaColl transient;
	create selectedColl transient;
	foreach range in measure.allWeightRanges discreteLock do
		row := self.tblAvailable.addItemObject(range.getYAIdentifier, range);
		criteriaColl.add(range);
	endforeach;
	
	// colour the rows, etc
	rowMax := tblAvailable.rows;
	foreach row in tblAvailable.fixedRows + 1 to rowMax do
		altColour := not altColour;
		if altColour then
			tblAvailable.accessRow(row).backColor := self.colorRow1;
		else
			tblAvailable.accessRow(row).backColor := self.colorRow2;
		endif;
	endforeach;
	
	if not self.tblAvailable.allSelectedObjects.isEmpty then
		self.tblAvailable.findObjectInRow(self.tblAvailable.allSelectedObjects.first, self.tblAvailable.row);
		self.positionDisplay();
	endif;
	
	create strArray transient;
	foreach obj in criteriaColl do
		range := obj.CM_WeightRange;
		if strArray.isEmpty then
			if self.txtFind.text &lt;&gt; null then
				if self.txtFind.text.containsOneOf(",") then
					create pattern transient;
					pattern.getTokens(self.txtFind.text, strArray);
					delete pattern;
				else
					strArray.add(self.txtFind.text);
				endif;
			endif;
		endif;
		foreach str in strArray do
			if range.getYAIdentifier = str then
				selectedColl.add(range);
				break;
			endif;
		endforeach;
	endforeach;
	
	self.tblAvailable.setSelected(selectedColl);
	self.doFind();
	self.txtFind.setFocus();
	
epilog
	delete selectedColl;
	delete criteriaColl;
	delete strArray;
	delete pattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilter" id="cd13430f-fd4a-4802-8c35-ee536f3905c4">
        <updating/>
        <source>doFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 October 2022	navgm20	ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS

*/

vars
	column		: Integer;
	findText,
	checkText	: String;
	idx			: Integer;
	startRow	: Integer;
begin
	findText := self.txtFind.text.trimBlanks;
	
	if findText = null then
		self.doClearFilter();
		if self.tblAvailable.rows &gt; self.tblAvailable.fixedRows then
			self.tblAvailable.row := self.tblAvailable.fixedRows + 1;
			self.tblAvailable.topRow := self.tblAvailable.fixedRows + 1;
		endif;
		return;
	else
		self.btnClear.enabled := true;
	endif;
	
	column := 2;
	if self.chkByDescription.visible and self.chkByDescription.value then
		column := 3;
	endif;
	
	startRow := self.tblAvailable.fixedRows + 1;
	
	if self.tblAvailable.row &gt;= self.tblAvailable.fixedRows and findText = self.tblAvailable.accessCell( self.tblAvailable.row, column ).text.toUpper() then
		startRow := self.tblAvailable.row;
	endif;

	foreach idx	in startRow to self.tblAvailable.rows do
		checkText := self.tblAvailable.accessCell( idx, column ).text.toUpper();
		if checkText.pos(findText,1)&gt; 0 then
			self.tblAvailable.accessRow(idx).visible	:= true;
		else
			self.tblAvailable.accessRow(idx).visible	:= false;		
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFind" id="864de1f8-4d0d-4752-a63d-cea225c5e062">
        <source>doFind();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 December 2008	consw1	Initial creation

*/

vars
	column		: Integer;
	findText	: String;
	idx			: Integer;
	startRow	: Integer;
	
begin
	findText := txtFind.text.trimBlanks;
	
	if findText = null then
		if tblAvailable.rows &gt; tblAvailable.fixedRows then
			tblAvailable.row := tblAvailable.fixedRows + 1;
			tblAvailable.topRow := tblAvailable.fixedRows + 1;
		endif;
		return;
	endif;
	
	column := 2;
	if self.chkByDescription.visible and self.chkByDescription.value then
		column := 3;
	endif;
	
	startRow := tblAvailable.fixedRows + 1;

	if tblAvailable.row &gt; tblAvailable.fixedRows and findText &gt;= tblAvailable.accessCell( tblAvailable.row, column ).text.toUpper() then
		startRow := tblAvailable.row;
	endif;

	foreach idx	in startRow to tblAvailable.rows do
		if findText &lt;= tblAvailable.accessCell( idx, column ).text.toUpper() then
			tblAvailable.row := idx;
			tblAvailable.topRow := idx;
			break;
		endif;
	endforeach;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="f5026def-6f02-4731-8244-b730bb3e2e47">
