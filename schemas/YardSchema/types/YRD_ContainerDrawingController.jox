    <JadeMethod name="filterYardAllocationLines" id="329b5cab-41b1-4a6e-ab9a-ccd07d3fe017">
        <updating/>
        <source>filterYardAllocationLines( _filter : CM_YardAllocationSet ) updating;
/*

Purpose:		Filter the Yard Allocations lines displayed on the frame

Parameters:		Collection of Yard Allocations for filter.  Null/none means no filtering to be applied.

Return Value:	None

Date				Who		Reason
12 November 2008	consw1	Initial creation

*/
begin
	if _filter = null then
		if self.allYardAllocationsFilter.isEmpty() then
			return;
		endif;
	elseif _filter.membersSame(self.allYardAllocationsFilter) then
		return;
	endif;

	self.allYardAllocationsFilter.clear();
	_filter.copy(self.allYardAllocationsFilter);
	
	self.refreshYardAllocationLines();
end;</source>
        <Parameter name="_filter" type="CM_YardAllocationSet"/>
    </JadeMethod>
    <JadeMethod name="get40FooterFromBackEnd" id="3afa2c6f-be5c-435f-a952-87c3cdbe386c">
        <updating/>
        <source>get40FooterFromBackEnd(y : Real; _lc : CM_LocationsController; _mode : Integer) : CM_TrackedItem updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cellHeight, y1,y2,tiIndex : Integer;
	theTI : CM_TrackedItem;
	tis : CM_TIArray;
begin
	cellHeight := self.getCellHeight();
	if cellHeight = 0 then // PAR 14680  DCT Stack Dump
		return null;
	endif;
	
	self.myDockBar.myDrawingController.allGridObjects.getYRange(y.Integer,y1,y2);

	tiIndex := ((y2-y) / cellHeight).roundedUp.Integer;
	if tiIndex = 0 then
		return null;
	endif;

	create tis transient;

	if tiIndex &gt; 0 then
		if _mode = REAL_MODE then
			_lc.allTrackedItems.copy(tis);
		elseif _mode = QUEUE_MODE then
			_lc.getAllQueuedTrackedItems(tis, true);
		elseif _mode = PLANNING_MODE then
			_lc.getAllPlannedTrackedItems(tis, true, false);
		endif;
	endif;
	
	if  tis.size &gt;= tiIndex then
		theTI := tis[tiIndex];
	endif;
	
	return theTI;
epilog

	delete tis;

end;</source>
        <Parameter name="y" type="Real"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTis" id="2f5b155b-7d34-4b82-bc26-058028cf08b2">
        <source>getAllSelectedTis( _tiColl : Collection input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwndl1	Initial creation	Par 20514

*/

vars
	obj : Object;
	iter : Iterator;
	invalidObject : Boolean;
begin
	//16/02/2011 cnwdz2 par26991
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	
	iter := self.allSelectedObjects.createIterator;
	while iter.next(obj) do
	
		//16/02/2011 cnwdz2 par27020 start
		invalidObject := false;
		// dereference obj to check it is still valid
		obj.edition();
		if invalidObject then
			continue;
		endif;
		//16/02/2011 cnwdz2 par27020 end
		
		if obj.isKindOf(CM_TrackedItem) then
			_tiColl.add(obj.CM_TrackedItem);
		elseif obj.isKindOf(CM_FutureMoveQueued) then
			_tiColl.add(obj.CM_FutureMoveQueued.myTrackedItem);
		elseif obj.isKindOf(CM_FutureMovePlanned) then
			_tiColl.add(obj.CM_FutureMovePlanned.myTrackedItem);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_tiColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAutoMaskTIs" id="d31ed3d3-2de1-4dc4-8fbe-f59278335d43">
        <updating/>
        <source>getAutoMaskTIs(_mode: Integer; _dischargePort: String; _commodityGroup: String; _voyageCode: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObj : Object;
	aTI : CM_TrackedItem;
	x1, y1, x2, y2 : Integer;
//	tmpObj		: Object;
	tmpIterator	: Iterator;
begin

	if _dischargePort = null 
	and _commodityGroup = null 
	and _voyageCode = null then
		return;
	endif;

	tmpIterator := self.allGridObjects.createIterator();
	tmpIterator.reset();
	while tmpIterator.next(anObj) do

		if not anObj.isKindOf(CM_TrackedItem) then
			continue;
		endif;
		
		aTI := anObj.CM_TrackedItem;
		
		// must match discharge port, voyage and commodity
		if aTI.dischargePort = _dischargePort 
		and aTI.voyageCode = _voyageCode
		and aTI.commodityGroup =_commodityGroup then
			if not self.allSelectorTIs.includes(aTI) then
				self.allSelectorTIs.add(aTI);
			endif;
		endif;		
		
		self.allGridObjects.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		
		self.setForRedraw(anObj,x1,y1,x2,y2);
		self.setMyCurrentObject(anObj);
		self.drawCurrentObject(self.myDrawingFrame);
	endwhile;
epilog
	self.myDrawingFrame.refreshNow();
	delete tmpIterator;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_commodityGroup" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAutoMasked" id="f8194bfc-7f95-4d3d-a96e-31969f444a1f">
        <source>getAutoMasked(): Boolean;
// ---------------------------------------------------------------------------
// Created:     22 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.autoMask;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBestObjectForPosition" id="08fdbd68-6632-4540-9d8a-6ad9dd6f055e">
        <source>getBestObjectForPosition(_x, _y : Integer) : Object ;
/*

Purpose:	at point return the best object.
					Best is really just the object that is most important
						1. TI
						2. Future Move
						3. Restriction
						4. LC
						5. CMIF_YardHeightExceeded
						6. whatever is left

Parameters:			
Return Value:		


Date		Who		Reason
16 December 2010	cnwer1	Initial creation

*/

vars
	foundObjects : ObjectArray;
	ti 				: CM_TrackedItem;
	fm 				: CM_FutureMove;
	restriction 	: CM_Restriction;
	lc 				: CM_LocationsController;
	heightExceed	: CMIF_YardHeightExceeded;
	obj, theObj			: Object;
begin
	
	create foundObjects transient;
	//max containers are 53 ft soo search from 2 container lengths before hand
	self.allGridObjects.findObjectsInDictAtPoint(_x, _y,foundObjects,(self.getColumnWidthForScale *2.5).Integer );
	
	
	foreach obj in foundObjects do
		if obj.isKindOf(CM_TrackedItem) then
			return obj.CM_TrackedItem;
		endif;
		
		if obj.isKindOf(CM_FutureMove)and fm = null then
			fm:=obj.CM_FutureMove;
		elseif obj.isKindOf(CM_Restriction) and restriction = null then
			restriction:=obj.CM_Restriction;
		elseif obj.isKindOf(CM_LocationsController) and lc = null then
			lc :=obj.CM_LocationsController;
		elseif obj.isKindOf(CMIF_YardHeightExceeded) and heightExceed = null then
			heightExceed:=obj.CMIF_YardHeightExceeded;
		endif;
	endforeach;
	
	
	if fm &lt;&gt; null then
		return fm;
	endif;
	
	if restriction &lt;&gt; null then
		return restriction;
	endif;
	
	if lc &lt;&gt; null then	
		return lc;
	endif;
	
	if heightExceed &lt;&gt; null then
		return heightExceed;
	endif;
	
	return foundObjects.first;
epilog
	delete foundObjects;
end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getColumnWidthForScale" id="7c86b219-44e8-4ae9-8e88-1d72d3e7c59f">
