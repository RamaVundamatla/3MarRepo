    <JadeMethod name="txtGenerator_lostFocus" id="4182841c-50db-45c5-8cdd-a002b956504c">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtGenerator_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	gen : CM_TrackedItem;
	errorMsg : String;

begin
	if self.txtGenerator.text &lt;&gt; null then
	
		gen := self.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Generator,self.txtGenerator.text.trimBlanks];
		if gen &lt;&gt; null then
			self.setMyGenerator(gen);
		endif;
		
	endif;
epilog

end;</source>
