    <JadeMethod name="createAuditObjectInformation" id="f30f33ba-16de-4cf3-9852-5013d7f727e9">
        <updating/>
        <source>createAuditObjectInformation( _info : String ) updating;
/* ---------------------------------------------------------------------------
Created:	05 February 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	audObjInfo	: CM_AuditObjectInformation;
	tmpAuditAgent	: CM_AuditAgent;
	tmpAuditConfig	: CM_AuditConfig;
	
begin
	
	create tmpAuditAgent transient;
	create audObjInfo persistent;
	
	if not tmpAuditAgent.getAuditConfigForClass( self, self.class, tmpAuditConfig) then
		return;
	endif;
	
	audObjInfo.setForCreate( self, _info, tmpAuditConfig);
	
epilog
	delete tmpAuditAgent;

end;</source>
        <Parameter name="_info" type="String"/>
    </JadeMethod>
    <JadeMethod name="createCriteria" id="d7014494-b023-4890-981e-cb89e7a2ad80">
        <source>createCriteria(_item: Any; _criteriaType: Integer): CM_YACriteria protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwas3	Initial creation

*/

vars
	criteria		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
//	criteriaData	: CM_YADataObjects;
begin
	criteriaType := app.myRoot.allYACriteriaTypes[_criteriaType];
	if criteriaType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Voyage Allocation criteria type (' &amp; _criteriaType.String &amp; ') not present');
		return null;
	endif;
	
	create criteria transient;
	criteria.setProxy(criteriaType, _item, null);

	return criteria;

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Any"/>
        <Parameter name="_criteriaType" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="createOpsViewEWSActivity" id="cb12e3b3-73ae-4fd0-9ace-e0c1d40026a7">
        <updating/>
        <source>createOpsViewEWSActivity(_updateAction : Character;
						_updateType   : String;
						_objectInfo   : Any) : CM_ExternalWebServiceActivity updating;
/*
Purpose:			

Date		Who		Reason
03AUG2021	NAVAB1	TFS 50669
*/


vars

	proxyActHistory : CM_EWSActivityOpsview;
	activityHistory : CM_ExternalWebServiceActivity;
	desc, oid : String;
begin	

	
	if self.isTransient then
		return null;
	endif;
	
	if not self.isOpsViewData() then
		return null;
	endif;
	
	if _objectInfo.isKindOf(CM_Object) then
		oid 		:= _objectInfo.CM_Object.getOidString;
	elseif _objectInfo.isKindOf(String) then
		oid := _objectInfo.String;
	endif;

	desc := "OpsView POST (" &amp; _updateAction &amp; " - " &amp; _updateType &amp; ")";
	create proxyActHistory transient;
	proxyActHistory.initialiseActivity(desc, "OpsView",self.getMyTerminal(), self, _updateAction,_updateType, false, oid );
	
	activityHistory := app.myUtilityCA.utlCreateEWSActivityHistory(proxyActHistory, app.myPassport);

	return activityHistory;
	
epilog
	delete proxyActHistory;

	
end;</source>
        <Parameter name="_updateAction" type="Character"/>
        <Parameter name="_updateType" type="String"/>
        <Parameter name="_objectInfo" type="Any"/>
        <ReturnType type="CM_ExternalWebServiceActivity"/>
    </JadeMethod>
