    <JadeMethod name="zDoThumbnailDClick" id="4bdf14a6-7ee5-465f-adcd-1bf90e397257">
        <updating/>
        <source>zDoThumbnailDClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
