    <JadeMethod name="doROROPrint" id="e651f665-e95a-45ed-9304-18f480d0c386">
        <updating/>
        <source>doROROPrint() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031
20/04/2016	cnwma1  PAR #37720 impossible to Print Deck Details of Upper Deck

*/

vars
	selectedDecks : CM_ObjectArray;
	obj			 : Object;
	deck, firstDeck: CM_Deck;
	tmpJadeReport  : JadeReport;
	headerForm : CMUI_ReportLine;
	footerForm 	: CM_GenericTablePrint;
	x1, y1, x2, y2   :Integer;
	xScale,
	yScale,
	scale, minScale ,theScale: Decimal[12,2];
	thePageWidth, thePageHeight : Integer;
	selectedDeckSize : Integer;

begin

	create selectedDecks  transient;
	
	self.getSelectedDecks(selectedDecks);
	
	selectedDeckSize:=selectedDecks.size;
	if selectedDeckSize = 0 then
		app.msgBox(app.getErrorString(Select_deck_print),app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	//app.printer.close;      //20/04/2016 cnwma1 PAR #37720 
	
	create headerForm transient;
	create footerForm transient;
	firstDeck:=selectedDecks.first.CM_Deck;
	self.setupHeaderFooter(headerForm,footerForm,firstDeck);
	
	create tmpJadeReport transient;
	tmpJadeReport.description := app.getErrorString(Deck_definition);
	app.printer.setReport(tmpJadeReport);
	
	//width printable page width less the margins
	thePageWidth:= app.printer.pageWidth  ;
	//page height less the print position which at this stage is just the header frame
	
	self.doROROPrintDeckDataDetails(firstDeck,selectedDeckSize &gt; 1);
	//less 30 for a deck code &amp; description printed what we have to draw in 
	thePageHeight:= app.printer.pageHeight - app.printer.getPrintPosition ;
	
	//get a minimum scale to draw 2  decks in 
	if selectedDeckSize &gt; 1 then
		minScale:=(thePageHeight-Margin) / (thePageHeight-Margin/2);
	else
		minScale:=(thePageHeight-Margin) / thePageHeight;
	endif;
	//check if multi select
	
	// if multi select need to get the scale based on the biggest deck
	theScale:=minScale;
	//if it has to take up the entire page its a square shape make the scale so it fits half the height
	//unfortunately this means iterating through the selected decks collection twice
	foreach obj in selectedDecks do 
		deck:=obj.CM_Deck;
		
		if deck.myDeckLayout =null then
			continue;
		endif;
		
		x1:=0;
		y1:=0;
		x2:=0;
		y2:=0;
		x1 := 9999999;
		y1 := 9999999;
	
		deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
		if x1 = 0 and x2 = 0 then
			// no graphics set to draw
			continue;
		endif;
		xScale:=(thePageWidth-Margin)/(x2-x1);
		yScale:=(thePageHeight-Margin)/(y2-y1);
		//want the whole drawing to fit the page
		scale:=xScale.min(yScale);
		
		//get the minimum from the previous decks scale
		if selectedDeckSize &gt; 1 then
			theScale:=theScale.min(scale);
		else
			theScale:=scale;
		endif;
	endforeach;
 
	
	foreach obj in selectedDecks do 
		deck:=obj.CM_Deck;
		if deck.myDeckLayout =null then
			continue;
		endif;
		
		self.doROROPrintDeck(deck,theScale,thePageHeight,deck &lt;&gt; firstDeck,selectedDeckSize &gt; 1);
		
	endforeach;
	
	if self.chkPrintPreview.value then
		app.printPreview(tmpJadeReport, true);
	else
		app.printer.printReport(tmpJadeReport);
	endif;
	//app.printer.close();    							//20/04/2016 cnwma1 PAR #37720 

	return true;
epilog
	app.printer.close();  								//20/04/2016 cnwma1 PAR #37720 
	delete headerForm;
	delete selectedDecks;
	delete footerForm;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doROROPrintDeck" id="5be75faa-9841-45f9-bd4c-82d6191ace5c">
        <updating/>
        <source>doROROPrintDeck(	_deck : CM_Deck; 
				_scale : Decimal;
				_thePageHeight : Integer;
				_printDataDetails : Boolean;
				_shortDetails : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	
	pageHeight : Real;
	deckImage 	: Binary;
begin
	
	
	if _printDataDetails then
		app.printer.drawLine(0,app.printer.getPrintPosition,app.printer.pageWidth,app.printer.getPrintPosition,Black);
		self.doROROPrintDeckDataDetails(_deck,_shortDetails);
	endif;
	
	
	if self.modeView = null then
		deckImage:=self.getRORODeckImage(_deck,_scale,pageHeight);
	else
		deckImage:=self.getRORODeckImageForMode(_deck,_scale,pageHeight);
	endif;
	if deckImage = null then
		return;
	endif;
	
	self.picPrint.visible:=true;
	
	self.picPrint.zOrder(1);
	self.picPrint.autoRedraw:=true;
	self.picPrint.transparent:=false;
	self.picPrint.backColor:=White;
	self.picPrint.borderStyle:=Window.BorderStyle_None;
	self.picPrint.move(0,0,app.printer.pageWidth,pageHeight);
	self.picPrint.useImage(deckImage);

	app.printer.printActive( self.picPrint);
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_thePageHeight" type="Integer"/>
        <Parameter name="_printDataDetails" type="Boolean"/>
        <Parameter name="_shortDetails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doROROPrintDeckDataDetails" id="69e8dd09-7db0-4ed1-870c-8278ae3c4429">
        <source>doROROPrintDeckDataDetails(_deck : CM_Deck; _shortDetails : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	dataContainer : CM_DataContainer;
	value  : String;
	heading : String;
	block : CM_DataContainerBlock;
begin
	entTableDef := app.myController.getEntTableDef(ETDef_RoRoDeckEnquiry);
	
	create dataContainer transient;	
	dataContainer.headerColour := White;
	dataContainer.valueColour := White;
	
	if not _shortDetails then
		_deck.getExtraInfoForEntDef(dataContainer,entTableDef);
	else
		entTableRow:=entTableDef.getEntTableRow(ETRow_Code);
		heading:=entTableRow.getHeading(null,null,app.myCurrentLocale);
		value:=_deck.getDisplayStringForAttribute(ETRow_Code,true);
		block := dataContainer.addNewBlock;
		block.addNewItem(heading, DC_Label, 1, self);
		block.addNewItem(value, DC_Data, 1, self);
		
		entTableRow:=entTableDef.getEntTableRow(ETRow_Description);
		heading:=entTableRow.getHeading(null,null,app.myCurrentLocale);
		value:=_deck.getDisplayStringForAttribute(ETRow_Description,true);
		block := dataContainer.addNewBlock;
		block.addNewItem(heading, DC_Label, 1, self);
		block.addNewItem(value, DC_Data, 1, self);
	endif;
	
	
	self.tblPrint.userObject	:=	_deck; 
	self.tblPrint.left:=10;
	self.tblPrint.width:=600;
	self.tblPrint.gridLines:=false;
	self.showExtraInformation(dataContainer, self.tblPrint, true,true,4,1,4,1,1);
	
	self.tblPrint.resetHeight;
	self.tblPrint.height:=self.tblPrint.clientHeight + Margin;
	
	
	app.printer.printActive(self.tblPrint); 
epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_shortDetails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getModeString" id="634bfc3f-a27c-4eba-933b-954018cf7e65">
        <source>getModeString() : String protected;
/*
Date		Who		Reason
21 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if self.modeView = ShpDisplayMode_Actual then
		return app.getErrorString1(DeckView_Actual, app.getViewModeString(VIEW_DISPORT));
		
	elseif  self.modeView = ShpDisplayMode_Defn then
		return app.getErrorString(DeckView_Definition);
		
	elseif self.modeView = ShpDisplayMode_Proposed then
		return app.getErrorString1(DeckView_Proposed, app.getViewModeString(VIEW_DISPORT)) ;
		
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		return  $SHP_DISCHARGE &amp; $SHP_COLOUR_CODING &amp; $SHP_Mode &amp;  $SHP_By_Discharge_Port;
		
	elseif self.modeView = ShpDisplayMode_ColCodeLoad then
		return $SHP_LOAD &amp; $SHP_COLOUR_CODING &amp; $SHP_Mode &amp; $SHP_By_Discharge_Port;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRORODeckImage" id="e6c919ec-1a00-4e2c-9fb5-602c7490fd22">
        <updating/>
        <source>getRORODeckImage(	_deck : CM_Deck;
					_scale : Decimal;
					_imageHeight : Integer output) : Binary updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	x1, y1, x2, y2 : Integer;
	printFrame : CMUI_PointDrawingFrame;
	viewPort	: CMUI_Frame;
	layerLayout : CM_DeckLayerLayout;
	deckItemLayout : CM_DeckItemLayout;
	offsetLeft	, offsetTop	: Real;
	pageHeight , imageWidth: Real;
	deckImage 	: Binary;
begin

	x1 := 9999999;
	y1 := 9999999;
	
	_deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
	
	if x1 = null and  x2 = null then
		return null;
	endif;
	
	viewPort := self.frmPrint.cloneSelf(true);
	self.addControl(viewPort);
	viewPort.transparent:=false;
	viewPort.backColor:=White;
	viewPort.borderStyle:=Control.BorderStyle_None;
	viewPort.visible := true;
	viewPort.autoRedraw := true;
	viewPort.left:=0;
	viewPort.top:=0;
	
	printFrame := self.frmDeckPrint.cloneSelf(true);
	printFrame.parent:=viewPort;
	printFrame.left:=0;
	printFrame.top:=0;
	self.addControl(printFrame);	
	printFrame.borderStyle:=Control.BorderStyle_None;
	printFrame.transparent := true;
	printFrame.visible := true;
	printFrame.autoRedraw := true;
	printFrame.scaleFactor := _scale;
	printFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
	
	pageHeight:=(y2-y1 ) * _scale; //10 is just margin of error
	imageWidth:=(x2-x1) *_scale;
	printFrame.height:=pageHeight;
	
	//epr par 27495 make sure we only print visible layers and layer items
	foreach layerLayout in _deck.myDeckLayout.allDeckLayerLayouts reversed where layerLayout.isVisible do // PAR 27595 added reversed
		// do not show the colour coding and general cargo layers
		//if layerLayout.type &lt;&gt; ROROLayerType_Structure and layerLayout.type &lt;&gt; ROROLayerType_Cargo and layerLayout.type &lt;&gt; ROROLayerType_Lanes then
		if not layerLayout.isDefinable() then
			continue;
		endif;
		foreach deckItemLayout in layerLayout.allDeckItemLayouts reversed where deckItemLayout.isVisible  do 
			//printFrame.doAddToArraysForProxy(deckItemLayout);
			// do this so that the lines are thickness of one.
			printFrame.doPointArrayAdd(deckItemLayout.drawLineColour, true, deckItemLayout.drawFillStyle, 1, deckItemLayout.drawFillColour, deckItemLayout);
		endforeach;
	endforeach;
	
	printFrame.showText:=self.chkPrintLabels.value;
	printFrame.showColour:=self.chkPrintColour.value;
	printFrame.drawAllPolygons(White);
	//move the view port so it can only see the drawn deck and not all the white space

	offsetLeft:=-(x1 * _scale);
	printFrame.width:=printFrame.clientWidth + offsetLeft.abs; 
	printFrame.left:=offsetLeft;
	
	offsetTop:=-y1* _scale;
	printFrame.height:=(printFrame.clientHeight + offsetTop.abs + Margin);
	printFrame.top:=offsetTop;
	viewPort.move(0,0,imageWidth + 1.5,pageHeight+1.5);

	viewPort.zOrder(1);
	
	_imageHeight:=viewPort.clientHeight;
	deckImage:=viewPort.createPictureAsType(false,true,24,Window.PictureType_Png);
	
	return deckImage;
	
epilog
	delete printFrame;
	delete viewPort;

end;</source>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_imageHeight" type="Integer" usage="output"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getRORODeckImageForMode" id="93cd9e65-b7a6-4876-a7ae-ec2986dceb6c">
        <updating/>
        <source>getRORODeckImageForMode( _deck : CM_Deck;
						_scale : Decimal;
						_imageHeight : Integer output) : Binary updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	x1, y1, x2, y2 : Integer;
	printFrame : CMUI_PointDrawingFrame;
	viewPort	: CMUI_Frame;
	layerLayout : CM_DeckLayerLayout;
	deckItemLayout : CM_DeckItemLayout;
	offsetLeft	, offsetTop	: Real;
	pageHeight , imageWidth: Real;
	deckImage 	: Binary;
	deck  		: CM_Deck;
	planController : SHP_ROROPlanDrawingController;
begin

	x1 := 9999999;
	y1 := 9999999;
	
	deck:=_deck;
	
	if deck = null then
		return null;
	endif;
	
	deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
	
	if x1 = null and  x2 = null then
		return null;
	endif;
	
	viewPort := self.frmPrint.cloneSelf(true);
	self.addControl(viewPort);
	viewPort.transparent:=false;
	viewPort.backColor:=White;
	viewPort.borderStyle:=Control.BorderStyle_None;
	viewPort.visible := true;
	viewPort.autoRedraw := true;
	viewPort.left:=0;
	viewPort.top:=0;
	
	printFrame := self.frmDeckPrint.cloneSelf(true);
	printFrame.parent:=viewPort;
	printFrame.left:=0;
	printFrame.top:=0;
	self.addControl(printFrame);	

	printFrame.borderStyle:=Control.BorderStyle_None;
	printFrame.transparent := true;
	printFrame.visible := true;
	printFrame.autoRedraw := true;
	printFrame.scaleFactor := _scale;
	printFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
	//printFrame.drawFontSize:=10;
	
	printFrame.setModeView(self.modeView);

	pageHeight:=(y2-y1 ) * _scale;
	pageHeight:=pageHeight + 10;
	imageWidth:=(x2-x1) *_scale;
	imageWidth:=imageWidth + 10; //10 is just margin of error
	printFrame.height:=pageHeight;
	
	//epr make sure we only print visible STRUCTURAL layers and layer items
	foreach layerLayout in deck.myDeckLayout.allDeckLayerLayouts reversed where layerLayout.isVisible and  layerLayout.type = ROROLayerType_Structure do // PAR 27595 added reversed
		foreach deckItemLayout in layerLayout.allDeckItemLayouts where deckItemLayout.isVisible do
			// do this so that the lines are thickness of one.
			printFrame.doPointArrayAdd(deckItemLayout.drawLineColour, true, deckItemLayout.drawFillStyle, 1, deckItemLayout.drawFillColour, deckItemLayout);
		endforeach;
	endforeach;
	
	printFrame.showText:=false;//self.chkPrintLabels.value;
	printFrame.showColour:=self.chkPrintColour.value;
	
	printFrame.drawAllPolygons(White);
	printFrame.allPointGraphics.clear;

	create planController transient;
	planController.scaleFactor:=_scale;
	planController.modeViewSub:=self.modeViewSub;
	planController.modeView :=self.modeView;
	
	planController.myPointDrawingFrame:=printFrame;
	planController.modeWork:=SHP_ROROPlanningForm.WorkMode_Job;//WorkMode_Plan;
	
	
	foreach layerLayout in deck.myDeckLayout.allDeckLayerLayouts reversed where layerLayout.isVisible and  layerLayout.type &lt;&gt; ROROLayerType_Structure do // PAR 27595 added reversed
		planController.doDrawLayer(printFrame,layerLayout,null);
	endforeach;
	
	//move the view port so it can only see the drawn deck and not all the white space

	offsetLeft:=-(x1 * _scale);
	printFrame.width:=printFrame.clientWidth + offsetLeft.abs; 
	printFrame.left:=offsetLeft;
	
	offsetTop:=-y1* _scale;
	printFrame.height:=(printFrame.clientHeight + offsetTop.abs + Margin);
	printFrame.top:=offsetTop;
	viewPort.move(0,0,imageWidth + 1.5,pageHeight+1.5);

	viewPort.zOrder(1);
	
	_imageHeight:=viewPort.clientHeight;
	deckImage:=viewPort.createPictureAsType(false,true,24,Window.PictureType_Jpeg);
	
	return deckImage;
epilog
	delete printFrame;
	delete viewPort;
	delete planController;

end;</source>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_imageHeight" type="Integer" usage="output"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getROROJobImageDetailed" id="27ada3fa-8a25-419a-9fe2-9e8a784a9305">
        <updating/>
        <source>getROROJobImageDetailed(	_job : CM_VoyageDeckJob;
						_imageWidth,
						_imageHeight : Integer) : Binary updating;
/*
DO NOT DELETE OR RENAME - called from CM_VoyageDeckJob::getJobDetailImage which is used in report writer
		
Date		Who		Reason
24 August 2011	cnwer1	Initial creation CCMS MES 2265

*/

vars
	jx1, jy1, jx2, jy2 : Integer; //job points
	x1, y1, x2, y2 : Integer;
	sx1,sy1,sx2,sy2 : Real;
	printFrame : CMUI_PointDrawingFrame;
	viewPort	: CMUI_Frame;
	layerLayout : CM_DeckLayerLayout;
	allJobLayouts, allSlotRequests: ObjectArray;
	deckItemLayout : CM_DeckItemLayout;
	offsetLeft	, offsetTop	: Real;
	deckImage 	: Binary;
	deck  		: CM_DeckVoyage;
	request 	 : CM_Request;
	roroRequest  : CM_RORORequest;
	planController : SHP_ROROPlanDrawingController;
	scale,scaleY,
	scaleX,xSect: Decimal[12,2];
	dischargeVisible : Boolean; 
	loadVisible: Boolean; 
	obj : Object;
	requestCodes : StringArray;
	allJobRequests : DynaDictionary;
	iter : Iterator;
	voyage : CM_Voyage;
	cellVoyage : CM_CellularVoyageStructure;
	section : CM_VesselSection;
	imageHeight, imageWidth : Integer;
	deckLayouts : CM_DeckLayerLayoutArray;
	tmpDeckItem : CM_DeckItem;
begin
	if _job  = null then
		return null;
	endif;
	imageHeight := _imageHeight;
	if imageHeight = 0 then
		imageHeight:=266;
	endif;

	imageWidth:=_imageWidth;
	if imageWidth = 0 then
		imageWidth:=app.printer.pageWidth;
	endif;	
	
	deck:=_job.myDeck;
	
	if deck = null then
		return null;
	endif;
	
	self.frmDeckPrint.width:=3000;
	
	jx1 := 9999999;
	jy1 := 9999999;
	x1 := 9999999;
	y1 := 9999999;
	
	foreach request in _job.allRequests do
		if not request.isKindOf(CM_RORORequest) then
			continue;
		endif;
		roroRequest:=request.CM_RORORequest;
		deckItemLayout:=roroRequest.myLayout;
		if deckItemLayout = null then
			continue;
		endif;
		
		deckItemLayout.getExtremePoints(jx1, jy1, jx2,jy2 );	
		if roroRequest.getAttrIsNOT20() then
			if roroRequest.isKindOf(CM_ROROSlotRequest) then
				if roroRequest.CM_ROROSlotRequest.mySlotRequestAft &lt;&gt; null then
					roroRequest.CM_ROROSlotRequest.mySlotRequestAft.myLayout.getExtremePoints(jx1, jy1, jx2,jy2 );
				elseif  roroRequest.CM_ROROSlotRequest.mySlotRequestForward &lt;&gt; null then
					roroRequest.CM_ROROSlotRequest.mySlotRequestForward.myLayout.getExtremePoints(jx1, jy1, jx2,jy2 );
				endif;
			endif;
		endif;
		
	endforeach;

	scaleY:= imageHeight/(jy2 - jy1 + Margin + Margin + Margin);
	scaleX:=imageWidth/(jx2-jx1+ Margin + Margin);

	deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
	scale:=scaleX.min(scaleY);

	if scale  &gt; 2.8 then
		scale:=2.8;
	endif;
	if x1 = null and  x2 = null then
		return null;
	endif;
	
	self.setupPrintViewPortFrames(printFrame,viewPort);
	printFrame.scaleFactor:=scale;
		
	if _job.isDischarge then
		printFrame.setModeView(ShpDisplayMode_ColCodeDisch);
	else
		printFrame.setModeView(ShpDisplayMode_ColCodeLoad) ;
	endif;

	self.printDeckStructure(printFrame,deck);
	
	create allJobLayouts transient;
	create requestCodes transient;
	create allJobRequests transient;
	allJobRequests.setMembership(CM_RORORequest);
	allJobRequests.addExternalKey(String,30,false,false);
	allJobRequests.endKeys(true);

	//epr par 32488 19/913
	create deckLayouts transient;
	deckLayouts[6]:=null;
	

	foreach layerLayout in deck.myDeckLayout.allDeckLayerLayouts  where layerLayout.isVisible and  layerLayout.type &lt;&gt; ROROLayerType_Structure do 
		if layerLayout.type = ROROLayerType_CCLoad then
			deckLayouts[1]:=layerLayout;
		elseif layerLayout.type = ROROLayerType_CCDischarge then
			deckLayouts[2]:=layerLayout;
		elseif layerLayout.type = ROROLayerType_OOTL then
			deckLayouts[3]:=layerLayout;
		elseif layerLayout.type = ROROLayerType_GC then
			deckLayouts[4]:=layerLayout;
		elseif layerLayout.type = ROROLayerType_Lanes then	
			deckLayouts[5]:=layerLayout;
		elseif layerLayout.type = ROROLayerType_Cargo then
			deckLayouts[6]:=layerLayout;
		endif;
	endforeach;	
		
	//epr now printing all the jobs and slots 
	foreach layerLayout in deckLayouts where layerLayout &lt;&gt; null do
		foreach deckItemLayout in layerLayout.allDeckItemLayouts do
			if deckItemLayout.pointsPolygon.size = 0 then
				continue;
			endif;
			if deckItemLayout.isKindOf(CM_RORORequestLayout) then
				if deckItemLayout.CM_RORORequestLayout.myRequest &lt;&gt; null and deckItemLayout.CM_RORORequestLayout.myRequest.myJob = _job then
					allJobRequests.putAtKey(deckItemLayout.code, deckItemLayout.CM_RORORequestLayout.myRequest);
					requestCodes.add(deckItemLayout.code);
				endif;
				continue;
			endif;
			
			dischargeVisible:=false;
			loadVisible:=false;
				
			if not deckItemLayout.getVisibilityTallyman(dischargeVisible,loadVisible) then
				continue;
			endif;
			// do this so that the lines are thickness of one.
			if _job.isDischarge then
				if not dischargeVisible then
					continue;
				endif;
			else
				if not loadVisible then
					continue;
				endif;
			endif;
			
			if requestCodes.includes(deckItemLayout.code) then
				allJobLayouts.add(deckItemLayout);
			else
				//epr par 32929
				roroRequest:=deckItemLayout.myDeckItem.getFirstRequest(not _job.isDischarge);
				if roroRequest &lt;&gt; null and roroRequest.myLayout &lt;&gt; null then
					if  requestCodes.includes(roroRequest.myLayout.code) then
						allJobLayouts.add(deckItemLayout);
					endif;
				endif;
			endif;
			
			
			printFrame.doPointArrayAdd(deckItemLayout.drawLineColour, true, Frame.DrawFillStyle_Solid,1, White,deckItemLayout);//  deckItemLayout.drawFillStyle, 1, White, deckItemLayout);
		endforeach;
	endforeach;
	
	printFrame.showText:=scale &gt; 1;//self.chkPrintLabels.value;
	printFrame.showColour:=self.chkPrintColour.value;
	
	printFrame.drawAllPolygons(White);
	
	printFrame.doBtnClearClickArrays;
	printFrame.allPointGraphics.clear;
	
	create planController transient;
	planController.scaleFactor:=scale;
	//planController.modeViewSub:=ShpDisplayModeSub_Colour;
	planController.modeViewSub :=ShpDisplayModeSub_Text;
	if _job.isDischarge then
		planController.modeView := ShpDisplayMode_ColCodeDisch;
	else
		planController.modeView := ShpDisplayMode_ColCodeLoad;
	endif;
	printFrame.showText:=true;
	planController.myPointDrawingFrame:=printFrame;
	planController.modeWork:=SHP_ROROPlanningForm.WorkMode_Job; //WorkMode_Plan;
	
	
	create allSlotRequests transient;
	foreach obj in allJobLayouts do
		deckItemLayout:=obj.CM_DeckItemLayout;
		
		//allSlotRequests
		delete iter;
		allSlotRequests.clear;
		iter:=allJobRequests.createIterator;
		while iter.next(roroRequest) do
			tmpDeckItem := roroRequest.myROROController.getDefn();
			if tmpDeckItem.myLayout.code &lt;&gt; deckItemLayout.code then
				continue;
			endif;
			allSlotRequests.add(roroRequest);
		endwhile;
	
		if deckItemLayout.myDeckItem &lt;&gt; null then
			printFrame.doPointArrayAdd(deckItemLayout.drawLineColour, true, DrawFillStyle_Solid, 1, White, deckItemLayout);
			planController.drawPolygonsSequenceSheet(deckItemLayout,_job,allSlotRequests);
			
		endif;
	endforeach;
		
	//draw the sections	
	voyage := deck.myVoyageStructure.myVoyage;
	cellVoyage:=voyage.myCellularVoyageStructure;
	
	if cellVoyage &lt;&gt; null then
		printFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		printFrame.drawWidth := 2;
		printFrame.drawFontSize:=8;
		printFrame.drawStyle := Frame.DrawStyle_Solid;
		printFrame.drawFillColor := White;
		printFrame.drawTextRotation:=0;
		printFrame.drawTextCharRotation:=0;
		foreach section in voyage.myStructuralElements.allSectionsByPosition discreteLock do		
			xSect := (section.position * ROROStructurePixelsPerMetre) + ROROStructureRearLine;
			
			sx1 := (xSect * scale);
			sy1 := (jy1 * scale) - Margin - Margin; 
			sx2 := (xSect * scale);
			sy2 := sy1 + Margin; 
			printFrame.drawLine(sx1,sy1,sx2,sy2 ,Black);
			
			sx1 := ((xSect * scale) + 2);
			
			printFrame.drawFilledRectangle(sx1,sy1,sx1 + printFrame.drawTextWidth(section.code),sy2,White);
			printFrame.drawTextAt(section.code,sx1,sy1 - 3,Black);
			
		endforeach;	
	endif;
		
	offsetLeft:=-((jx1  ) * scale);
	printFrame.width:=((x2) * scale) + offsetLeft.abs +  Margin; 
	printFrame.left:=offsetLeft + Margin;
	
	offsetTop:=-((jy1 ) * scale);
	printFrame.height:=((y2)*scale) + offsetTop.abs + Margin + Margin;
	printFrame.top:=offsetTop + Margin + Margin;
	viewPort.move(0,0,imageWidth,imageHeight);

	viewPort.zOrder(1);
	
	//deckImage:=viewPort.createPictureAsType(false,true,24,Window.PictureType_Jpeg);
	deckImage:=viewPort.createPictureAsType(false,true,24,Window.PictureType_Png);
	return deckImage;
epilog
	delete printFrame;
	delete viewPort;
	delete planController;
	delete allJobLayouts;
	delete requestCodes;
	delete allJobRequests;
	delete iter;
	delete allSlotRequests;
	delete deckLayouts;
end;</source>
        <Parameter name="_job" type="CM_VoyageDeckJob"/>
        <Parameter name="_imageWidth" type="Integer"/>
        <Parameter name="_imageHeight" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getROROJobImagePosition" id="37fbb470-706a-4399-b708-f0b2ec1f5fee">
        <updating/>
        <source>getROROJobImagePosition(_job : CM_VoyageDeckJob) : Binary updating;
/*

Date		Who		Reason
24 Aug 2011	cnwer1	Initial creation CCMS MES 1033
01 Aug 2013 cnwer1	CCMS 2265 
26 Feb 2014 cnwer1	par 33066
*/

vars

	x1, y1, x2, y2 : Integer;
	printFrame : CMUI_PointDrawingFrame;
	viewPort	: CMUI_Frame;
	layerLayout : CM_DeckLayerLayout;
	deckItemLayout : CM_DeckItemLayout;
	offsetLeft	, offsetTop	: Real;
	pageHeight , imageWidth: Real;
	deckImage 	: Binary;
	deck  		: CM_Deck;
	request 	: CM_Request;
	roroRequest,aReq  : CM_RORORequest;
	planController : SHP_ROROPlanDrawingController;
	scale : Decimal[12,2];
	dischargeVisible : Boolean; 
	loadVisible: Boolean; 
	tmpDeckItem : CM_DeckItem;
	tmpLocnDefn : CM_ROROLocnDefn;
	obj : Object;
	deckItemsToRemove : ObjectArray;
begin

	x1 := 9999999;
	y1 := 9999999;
	self.frmDeckPrint.width:=3000;
	self.chkPrintLabels.value:=true;
	if _job  = null then
		return null;
	endif;
	
	deck:=_job.myDeck;
	
	if deck = null then
		return null;
	endif;
	
	deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
	
	if x1 = null and  x2 = null then
		return null;
	endif;
	scale:=(app.printer.pageWidth)/(x2-x1);
	
	self.setupPrintViewPortFrames(printFrame,viewPort);
	printFrame.scaleFactor:=scale;
	
	if _job.isDischarge then
		printFrame.setModeView(ShpDisplayMode_ColCodeDisch);
	else
		printFrame.setModeView(ShpDisplayMode_ColCodeLoad) ;
	endif;
	
	pageHeight:=(y2-y1 ) * scale; //10 is just margin of error
	imageWidth:=(x2-x1) *scale;
	printFrame.height:=pageHeight;
	
	self.printDeckStructure(printFrame,deck);
	
	foreach request in _job.allRequests reversed do
		if not request.isKindOf(CM_RORORequest) then
			continue;
		endif;
		roroRequest:=request.CM_RORORequest;
		deckItemLayout:=roroRequest.myLayout;
		//epr 33066 26/2/14 
		tmpDeckItem:=	roroRequest.myROROController.getDefn();
	
		dischargeVisible:=false;
		loadVisible:=false;
		if not tmpDeckItem.myLayout.getVisibilityTallyman(dischargeVisible,loadVisible) then
			continue;
		endif;
		// do this so that the lines are thickness of one.
		if _job.isDischarge and not _job.isSOB then
			if not dischargeVisible then
				continue;
			endif;
		else
			if not loadVisible then
				continue;
			endif;
		endif;
		
		//epr par 33066 26/2/14
		if tmpDeckItem.isKindOf(CM_ROROLocnDefn) then
			tmpLocnDefn := tmpDeckItem.CM_ROROLocnDefn;
			if tmpLocnDefn &lt;&gt; null then
				aReq := tmpLocnDefn.getFirst40Request(true);
				if aReq &lt;&gt; null then // We have a40 req in this location so use that
					if  aReq.isBackEndRequest() then
						// PAR 28883
						if not tmpLocnDefn.isOOTL() then
							continue;
						endif;
					endif;	
					deckItemLayout:=aReq.myLayout;
				endif;
			endif;
		endif;
		
		printFrame.doAddToArraysForProxy(deckItemLayout);
	endforeach;
	
	create planController transient;
	planController.scaleFactor:=scale;
	planController.modeViewSub:=ShpDisplayModeSub_Colour;
	
	//epr par 33066 26/2/14
	if _job.isDischarge and not _job.isSOB then
		planController.modeView := ShpDisplayMode_ColCodeDisch;
	else
		planController.modeView := ShpDisplayMode_ColCodeLoad;
	endif;
	
	planController.myPointDrawingFrame:=printFrame;
	planController.modeWork:=SHP_ROROPlanningForm.WorkMode_Job; //WorkMode_Plan;
	
	planController.getAllPolygonsColourCoding(printFrame,layerLayout,planController.modeView = ShpDisplayMode_ColCodeLoad,White);
	
	//epr par 33066 26/2/14
	// draw the discharge requests for the SOB job
	if _job.isSOB then
		create deckItemsToRemove transient;
		foreach obj in printFrame.allPointGraphics do
			deckItemLayout:=obj.CM_DeckItemLayout;
			if deckItemLayout.isKindOf(CM_RORORequestLayout) then
				request := deckItemLayout.CM_RORORequestLayout.myRequest;
				if request &lt;&gt; null and  not request.getIsDischarge then
					deckItemsToRemove.add(deckItemLayout);
				endif;
			endif;
		endforeach;
		
		foreach obj in deckItemsToRemove do
			printFrame.doRemoveGraphic(obj.CM_DeckItemLayout);
		endforeach;
		planController.modeView := ShpDisplayMode_ColCodeDisch;
		planController.getAllPolygonsColourCoding(printFrame,layerLayout,planController.modeView = ShpDisplayMode_ColCodeLoad,White);

	endif;
	
	//move the view port so it can only see the drawn deck and not all the white space

	offsetLeft:=-(x1 * scale);
	printFrame.width:=printFrame.clientWidth + offsetLeft.abs; 
	printFrame.left:=offsetLeft;
	
	offsetTop:=-y1* scale;
	printFrame.height:=(printFrame.clientHeight + offsetTop.abs + Margin);
	printFrame.top:=offsetTop;
	viewPort.move(0,0,imageWidth + 1.5,pageHeight+1.5);

	viewPort.zOrder(1);
	
	deckImage:=viewPort.createPictureAsType(false,true,24,Window.PictureType_Png);
	
	return deckImage;
epilog
	delete printFrame;
	delete viewPort;
	delete planController;
	delete deckItemsToRemove;
end;</source>
        <Parameter name="_job" type="CM_VoyageDeckJob"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDecks" id="38348d2b-0151-4f38-92b0-c1b89be273c8">
        <source>getSelectedDecks(_selectedDecks : CM_ObjectArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	idx : Integer;
begin
	idx := 1;
	
	if self.chkPrintAllDecks.value then
		
		while idx &lt;=  self.lstDecks.listCount do
			_selectedDecks.add(self.lstDecks.itemObject[idx]);
			idx:=idx + 1;
		endwhile;
	else
		while idx &lt;=  self.lstDecks.listCount do
			if self.lstDecks.itemSelected[idx] then
				
				_selectedDecks.add(self.lstDecks.itemObject[idx]);
			endif;
			idx:=idx + 1;
		endwhile;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_selectedDecks" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="f2f88646-440c-4ce7-9b72-e7ddc6f5a289">
        <source>getVoyageCode() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if self.myROROVessel.isKindOf(CM_ROROVesselStructure) then
		return  self.myROROVessel.CM_ROROVesselStructure.myVessel.code;
	elseif self.myROROVessel.isKindOf(CM_ROROVoyageStructure) then
		return  self.myROROVessel.CM_ROROVoyageStructure.myVoyage.code;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="bd38fe38-d9db-4f8c-85b3-b137288976aa">
        <updating/>
        <source>initDetails(_printObject : CM_Object;
			_modeView : Integer;
			_modeViewSub : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deck : CM_Deck;
	roroStructure : CM_Object;
begin

	self.chkPrintAllDecks.value:=false;
	if _printObject.isKindOf(CM_Deck) then
		deck:=_printObject.CM_Deck;
		roroStructure:=deck.getROROStructure;
	elseif _printObject.isKindOf(CM_ROROVesselStructure) or _printObject.isKindOf(CM_ROROVoyageStructure) then
		roroStructure:=_printObject;
		self.chkPrintAllDecks.value:=true;
	endif;
	
	self.myROROVessel:=roroStructure;

	
	self.myAssistant.listBoxRORODecks(self.lstDecks,self.myROROVessel,deck);
	
	if self.chkPrintAllDecks.value then
		self.lstDecks.enabled:=false;
	endif;

	self.modeView:=_modeView;
	self.modeViewSub:=_modeViewSub;
end;</source>
        <Parameter name="_printObject" type="CM_Object"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeViewSub" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="picPrinter_dblClick" id="570d15dc-32c7-4398-8591-56f96ab5b121">
        <controlMethod name="Picture::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>picPrinter_dblClick(pict: Picture input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.printerChoose();
	self.showPrinterName();
epilog

end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
