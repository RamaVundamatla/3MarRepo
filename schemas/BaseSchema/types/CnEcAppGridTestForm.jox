    <JadeMethod name="appGrid1_click" id="667796f6-9f64-4a46-9b56-92c88b9ed4c2">
        <controlMethod name="CnEcAppGrid::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>appGrid1_click(cntrl: CnEcAppGrid input) updating;

vars

begin
	lstEvents.addItem(cntrl.appLabel.String &amp; " Click! -&gt; ChangeType = " &amp; cntrl.changeType.String);
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
    </JadeMethod>
    <JadeMethod name="appGrid1_dblClick" id="d60aca0b-3b79-48fd-8014-9641b81ece81">
        <controlMethod name="CnEcAppGrid::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>appGrid1_dblClick(cntrl: CnEcAppGrid input) updating;

vars

begin
	lstEvents.addItem(cntrl.appLabel.String &amp; " DblClick! -&gt; ChangeType = " &amp; cntrl.changeType.String);
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
    </JadeMethod>
    <JadeMethod name="appGrid1_dragDrop" id="6716e7f4-f9ab-421d-a613-99f4848b87bb">
        <controlMethod name="CnEcAppGrid::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>appGrid1_dragDrop(cntrl: CnEcAppGrid input; win: Window input; x: Real; y: Real) updating;

vars

begin
	lstEvents.addItem(cntrl.appLabel.String &amp; " DragDrop! -&gt; ChangeType = " &amp; cntrl.changeType.String);
	if win.isKindOf(TextBox) then
		if txtAppDur.text.Integer &lt;= 0 then
			cntrl.addAppLabel(cntrl.getResource(x), cntrl.getTime(y), cntrl.timeGrid);
		else
			cntrl.addAppLabel(cntrl.getResource(x), cntrl.getTime(y), txtAppDur.text.Integer);
		endif;
		cntrl.appLabel.color := lblAppCol.backColor;
		cntrl.appLabel.caption := win.TextBox.text;
		cntrl.appLabel.status.caption := txtAppStat.text;
		cntrl.appLabel.status.color := lblAppStatCol.backColor;
		cntrl.appLabel.status.bitmap.picture := picAppStat.picture;
		cntrl.appLabel.status.visible := chkAppStat.value;
	endif;
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
