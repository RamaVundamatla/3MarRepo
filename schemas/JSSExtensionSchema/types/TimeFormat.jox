<Class name="TimeFormat">
    <JadeMethod name="jssCopyInfo" id="a7fc7f34-ea68-4c59-870f-dacd9c322b59">
        <updating/>
        <source>jssCopyInfo(pTheTimeFormat : TimeFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pTheTimeFormat);
	
	self.amText				:=	pTheTimeFormat.amText;
	self.ampmIsSuffix		:=	pTheTimeFormat.ampmIsSuffix;
	self.format				:=	pTheTimeFormat.format;
	self.is12HourFormat		:=	pTheTimeFormat.is12HourFormat;
	self.pmText				:=	pTheTimeFormat.pmText;
	self.separator			:=	pTheTimeFormat.separator;
	self.showLeadingZeros	:=	pTheTimeFormat.showLeadingZeros;
	self.showSeconds		:=	pTheTimeFormat.showSeconds;
end;</source>
        <Parameter name="pTheTimeFormat" type="TimeFormat"/>
    </JadeMethod>
</Class>
