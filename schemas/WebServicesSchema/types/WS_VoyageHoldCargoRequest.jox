<Class name="WS_VoyageHoldCargoRequest" id="bc8a3248-314b-4c96-8b01-14c0aba5d1e2">
    <superclass name="WS_UpdateRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allDocuments" id="a9b910e2-730d-4961-9ab5-1962f3c286c3">
        <memberTypeInverse/>
        <type name="WS_DocumentArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allHMSResourcesUsed" id="fbb5fee0-5c92-4d5f-bca1-ca1da5c4e6df">
        <memberTypeInverse/>
        <type name="WS_HMSResourceUsedArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allVoyageHoldCargo" id="a4ed6332-85c1-444c-92cc-82bbb87c94d9">
        <memberTypeInverse/>
        <type name="WS_VoyageHoldCargoArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="berthOid" id="3f7555ba-22f1-43a6-9e41-ba3873043018">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="occursOnDT" id="10f912d3-6f24-4ceb-8ff8-9e86f3b045ee">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="voyage" id="8805bd4e-25ef-4bbd-bf8b-6c81ca3e3f12">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="005f238e-a9e7-4a18-a5a2-b0bcf3789d95">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2018	jlger1	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin
	self.allDocuments.purge;
	self.allVoyageHoldCargo.purge;
	self.allHMSResourcesUsed.purge();		//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllProxyObjects" id="f3358610-b215-4e06-a3ca-1094549291ab">
        <source>setAllProxyObjects(	_allCargo 	: CMIF_TIObjectArray input;
					_allJobParams : ObjectArray input;
					_allDocuments : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2018	jlger1	Initial creation

*/

vars
	voyage : CM_Voyage;
	wsVoyageHoldCargo  : WS_VoyageHoldCargo;
	cmifPrenote : CMIF_PreNote;
	jobParam : CMIF_VoyageJobParams;
	wsDocument : WS_Document;
	documentHeader : CM_FileData;
	jobsSorted : DynaDictionary;
	lastJob 		: CM_VoyageJob;
begin
	voyage:=app.myPassport.getObjectOfTypeFromOid(self.voyage,CM_Voyage).CM_Voyage;
	
	create jobsSorted transient;
	jobsSorted.setMembership(CM_VoyageJob);
	jobsSorted.addMemberKey(CM_VoyageJob::craneId.name,false,false);
	jobsSorted.addMemberKey(CM_VoyageJob::id.name,false,false);
	jobsSorted.endKeys(false);
	
	
	
	foreach wsVoyageHoldCargo in self.allVoyageHoldCargo discreteLock do
		create cmifPrenote transient;
		wsVoyageHoldCargo.setCMIF_Prenote(voyage,cmifPrenote);
		_allCargo.add(cmifPrenote);
		
		create jobParam transient;
		wsVoyageHoldCargo.setProxyJobParams(voyage,jobParam);
		_allJobParams.add(jobParam);
		
		lastJob:=jobsSorted.getAtKey(jobParam.myWorkPoint.code,jobParam.myProxyJob.id).CM_VoyageJob;
		if lastJob &lt;&gt; null then		
			lastJob:=jobsSorted.getAtKeyLss(jobParam.myWorkPoint.code,"999999").CM_VoyageJob;		
			jobParam.myProxyJob.setJobNum((lastJob.id.Integer +1).asStringJMT);	
		endif;
		jobsSorted.add(jobParam.myProxyJob);
	endforeach;
	
	foreach wsDocument in self.allDocuments discreteLock do
		create documentHeader transient;
		wsDocument.setProxyFileData(documentHeader);
		_allDocuments.add(documentHeader);
	endforeach;
epilog
	delete jobsSorted;
end;</source>
        <Parameter name="_allCargo" type="CMIF_TIObjectArray" usage="input"/>
        <Parameter name="_allJobParams" type="ObjectArray" usage="input"/>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyDocuments" id="5612afd8-bb90-4da3-b8cc-24deca63f412">
        <source>setProxyDocuments(_allDocuments : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2018	jlger1	Initial creation

*/

vars
	wsDocument : WS_Document;
	documentHeader : CM_FileData;
	documentContent : CM_FileDataStorageDetail;
begin
	foreach wsDocument in self.allDocuments discreteLock do
		create documentHeader transient;
		wsDocument.setProxyFileData(documentHeader);
		_allDocuments.add(documentHeader);
	endforeach;
epilog

end;</source>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
    </JadeMethod>
</Class>
