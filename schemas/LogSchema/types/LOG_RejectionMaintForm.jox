    <JadeMethod name="create" id="b169f646-1d25-403b-b263-bd24cae6d62a">
        <updating/>
        <source>create() updating;

vars

begin

	self.permissionView  := PmLogRejectMaint;
	self.permissionMaint := PmLogRejectMaintMaint; // TFS 2198
	self.btnBackground.enabled := true;
	
	self.helpFileName := HelpFile_Logs;

end;</source>
