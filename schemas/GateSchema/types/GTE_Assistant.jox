    <JadeMethod name="showFlexiRoadExitCompleteForm" id="b35789a1-7b3d-4835-8f53-4812bff4bc84">
        <source>showFlexiRoadExitCompleteForm(_job : CM_RoadJob; _masterMenuAction : CMUI_MenuAction);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007
//
//----------------------------------------------------------------------

vars
	frm	: GTE_FlexiGateOutForm;
	job : CM_Job;
begin
	//DON'T HAVE A JOB SO NO POINT IN SHOWING THE FORM AT THIS STAGE.
	if _job = null then
		return;
	endif;
	
	frm := app.loadForm(GTE_FlexiGateOutForm,
									GTE_Assistant,
									false,
									false,
