    <JadeMethod name="addRow" id="9608d9e2-0ca3-4da3-8e0c-7bf2b828f347">
        <updating/>
        <source>addRow(pRow : EntTableRow) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	itemIdx	: Integer;

begin

	itemIdx := self.allEntTableRows.indexOf(pRow);
	
	if itemIdx = 0 then
		self.allEntTableRows.add(pRow);
		return true;
	else
		return false;
	endif;
	
end;</source>
        <Parameter name="pRow" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRowByName" id="2eea5b87-8721-49b8-b8cd-e5cfb799caf7">
        <updating/>
        <source>addRowByName(pName : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	
begin

	entTableRow := self.myEntTableDef.myEntTableGroup.allEntTableRowsByName[pName];
	if entTableRow = null then
		return false;
	endif;
	if self.allEntTableRows.includes(entTableRow) then
		return false;
	endif;
	
	return self.addRow(entTableRow);
	
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearRows" id="c10d431a-af12-47ce-9832-c0dcdb463f2e">
        <updating/>
        <source>clearRows() updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allEntTableRows.clear;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getEntTableRow" id="e99c6d5c-05e5-4aec-862e-a06e51713afa">
        <source>getEntTableRow(_rowName:String):EntTableRow;
/*

Date		Who		Reason
01 August 2014	cnwer1	Initial creation PAR 34682

*/


vars
	tableRowObj	: EntTableRow;
	
begin
	foreach tableRowObj in self.allEntTableRows do
		if tableRowObj.name = _rowName then
			return tableRowObj;
		endif;
	endforeach;
	
	return null;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getRowNameArray" id="7d5f438d-90a8-4c8d-87b8-09fbcef05bf6">
        <source>getRowNameArray(pArray : StringArray io);
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	
begin

	pArray.clear;
	
	foreach entTableRow in self.allEntTableRows do
		pArray.add(entTableRow.name);
	endforeach;
	
end;</source>
        <Parameter name="pArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="4d8b6427-0579-4324-960b-03a81d70b331">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlStr	: String;
	etRow	: EntTableRow;
		
begin

	xmlStr := self.formatAsXMLPrefix(XMLTag_EntTableView) &amp;
			  self.formatAsXML(XMLTag_ViewName, self.name.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXMLPrefix(XMLTag_Rows);
	
	foreach etRow in self.allEntTableRows do
		xmlStr := xmlStr &amp; self.formatAsXML(XMLTag_RowName, etRow.name.xmlReplaceReservedChars(true));
	endforeach;
	
	xmlStr := xmlStr &amp; 
			  self.formatAsXMLSuffix(XMLTag_Rows) &amp;
			  self.formatAsXMLSuffix(XMLTag_EntTableView);
			  
	return xmlStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="32f89e5d-e9cd-4ef9-8c12-ae170bb3b04d">
        <updating/>
        <source>set(pName, pDescr : String; pDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name		:= pName;
	self.description:= pDescr;

	self.myEntTableDef := pDef;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescr" type="String"/>
        <Parameter name="pDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setFromXMLElement" id="69856174-93f0-412f-ba24-644540d93912">
        <updating/>
        <source>setFromXMLElement(pName : String; _xmlElement : JadeXMLElement; pDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	group	: EntTableGroup;
	row		: EntTableRow;
	rowName	: String;
	theRows	: JadeXMLElementArray;
	tmpElement	: JadeXMLElement;
	
begin
	self.allEntTableRows.clear();
	self.name			:= pName;
	self.myEntTableDef	:= pDef;

	group := pDef.myEntTableGroup;
	
	create theRows transient;
	tmpElement := _xmlElement.getElementByTagName(XMLTag_Rows);
	if tmpElement = null then
		return;
	endif;

	tmpElement.getElementsByTagName(XMLTag_RowName, theRows);

	foreach tmpElement in theRows do
		rowName := tmpElement.textData.xmlReplaceReservedChars(false);
		if rowName &lt;&gt; null then
			row := group.allEntTableRowsByName[rowName];
			if row &lt;&gt; null 
			and pDef.allEntTableRows.includes(row) then
				self.allEntTableRows.add(row);
			else
				// need an error here
			endif;
		endif;
	endforeach;	

epilog
	delete theRows;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="pDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b45580f7-495a-4b3a-a1d7-aac43606f30a">
        <updating/>
        <source>setProxy(pName, pDescr : String) updating;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	
	self.name		:= pName;
	self.description:= pDescr;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTransientReferences" id="38ff8da3-2659-48d5-871a-7de51e90bca5">
        <updating/>
        <source>setTransientReferences(pPersistent : EntTableView; pDef : EntTableDef; pGroup : EntTableGroup) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tEntTableRow,
	entTableRow		: EntTableRow;
	
begin

	foreach entTableRow in pPersistent.allEntTableRows do
		tEntTableRow := pGroup.allEntTableRowsByName[entTableRow.name];
		if tEntTableRow &lt;&gt; null then
			self.allEntTableRows.add(tEntTableRow);
		else
			// need an exception here
		endif;
	endforeach;
	
	self.myEntTableDef := pDef;
	
end;</source>
        <Parameter name="pPersistent" type="EntTableView"/>
        <Parameter name="pDef" type="EntTableDef"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
    </JadeMethod>
</Class>
