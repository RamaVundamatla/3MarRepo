        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.copyCollectionToTable(app.myRoot.allHMSTidalModelDefinitions, _numItems);

	//self.resetNotifications(); ends the note therefore must reset it
