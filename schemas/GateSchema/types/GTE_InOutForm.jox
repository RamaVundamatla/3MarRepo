    <JadeMethod name="fillTblJobs" id="c0ad32b1-53d7-4a49-a403-2cc0a6994604">
        <source>fillTblJobs(pCarrier : CM_Carrier);
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/02/2010	cnwmh5		PAR22263 - Call new method to add items to tblBulkRelease
// ---------------------------------------------------------------------------
vars
	tmpTable	: CM_DataTable;
	bulkRelease	: CM_BulkRelease;
	consignee	: CM_ConsigneeConsignor;
	operCode,
	consigneeName,
	carrierCode,
	str			: String;
	theRow		: Integer;
	consignDict	: CM_ConsignByCodeDict;
	iter 		: Iterator;
	reserve : CM_ReserveDetail;
begin

	clearTblJobs();

	if pCarrier = null then
		return;
	endif;
	
	tmpTable := self.tblBulkRelease;			
	carrierCode := pCarrier.code.trimRight;
	consignDict	:= app.myRoot.allConsigneeConsignors;

//	iter := self.myTerminal.allBulkReleaseByStatusByCode.createIterator();
//	self.myTerminal.allBulkReleaseByStatusByCode.startKeyGeq(BR_ACTIVE, null, iter);
	iter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator(); // CCMS 1288 AKB2005APR
	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE, null, null, iter); // CCMS 1288 AKB2005APR
	
	while iter.next(bulkRelease) do
		if bulkRelease.type &lt;&gt; BR_TYPE_ROAD  // CCMS 1288 AKB2005APR
		or bulkRelease.status &lt;&gt; BR_ACTIVE then
			break;
		endif;
		if bulkRelease.carrierId.trimRight &lt;&gt; carrierCode then 
			continue;
		endif;
	/*	PAR 16242	WAS
		str := bulkRelease.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
		tmpTable.addItemObject(bulkRelease, str);
	 NOW PAR 16242 */	
		
		self.addToTblBulkRelease(bulkRelease, tmpTable);			// 24/02/2010 cnwmh5 #22263
		
		/*
		// 24/02/2010 cnwmh5 #22263 - Replaced
		foreach reserve in bulkRelease.allReserveDetails discreteLock do
			//PAR18485
			if reserve.isKindOf(CM_ReserveTI) and reserve.allTrackedItems.isNotEmpty() then
				if reserve.allTrackedItems.first().jobRoadRelease &lt;&gt; null then
					continue;
				endif;
			endif;
		
			if reserve.isKindOf(CM_ReserveTI) and reserve.allTrackedItemsReleased.isNotEmpty() then //cnwrd1 par 20833 09/10/09 if we are a reserve TI and already released we do not want to be put into this table
				continue;
			endif;
		
			str := reserve.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
			tmpTable.addItemObject(reserve, str);
//			adm 190608 Par 17131
			self.tblBulkRelease.beginNotification(reserve, Object_Delete_Event, Response_Cancel, 0);
		endforeach;
//		self.tblBulkRelease.beginNotification(bulkRelease, Object_Delete_Event, Response_Cancel, 0);
		*/

	endwhile;

epilog
	delete iter;		
end;</source>
        <Parameter name="pCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="fillTblTransfers" id="6346e4e1-e60c-400a-8b2f-0df9fec5e50a">
        <source>fillTblTransfers();
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti	: CM_TrackedItem;

begin

	// DVB changed to use new flags 05/04/05
	if not app.isInterTerminalTransferEnabled() then
	//sheet will be invisible anyway...
		return;
	endif;
	
	self.tblTransfers.rows := self.tblTransfers.fixedRows;
	foreach ti in self.myTerminal.allInTransitTIsToByFromTypeId do
		self.addTransferRow(ti);
	endforeach;
	
	self.tblTransfers.leftColumn := 1;
	
end;</source>
    </JadeMethod>
