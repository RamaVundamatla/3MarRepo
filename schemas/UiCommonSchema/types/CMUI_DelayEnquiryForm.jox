    <JadeMethod name="doResetSearch" id="d8ebef8e-835f-428c-bed2-2e22cbf6969d">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	now	: TimeStamp;
begin
	inheritMethod();
	
	if self.myFilterVoyage &lt;&gt; null then
		self.cmbVoyage.listIndex := self.cmbVoyage.findObject (self.myFilterVoyage);
	else
		self.cmbVoyage.listIndex := -1;
	endif;

	if self.myFilterMachine &lt;&gt; null then
		self.cmbMachine.listIndex := self.cmbMachine.findObject (self.myFilterMachine);
	else
		self.cmbMachine.listIndex := -1;
	endif;
	
	self.cmbDelayGroup.listIndex	:= -1;
	self.cmbDelayType.listIndex		:= -1;
	
	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	now := self.systemToLocalTime(app.actualTimeServer);
	self.txtStartDate.setDate (now.date - 7);
	self.txtEndDate.setDate (null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="6f618db6-d3ad-4ba0-974a-e31af7cba99c">
        <updating/>
        <source>doResize()updating;
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	status	:CMUI_StatusLine;
begin
	inheritMethod();

	// is the status bar is visible make sure it does not cover the horizontal scroll bar on the table
	status 	:= self.staStatusBar;
	table 	:= self.tblData;
	
	if status.visible then
		table.height := table.parent.Control.clientHeight - status.height;
	endif;
epilog

end;
</source>
    </JadeMethod>
