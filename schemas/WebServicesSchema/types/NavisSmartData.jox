<Class name="NavisSmartData" id="291518f3-014b-44f0-9937-9ea14c41b796">
    <superclass name="NavisSmartService"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="getComplexInfo" id="8a734793-cb74-4bdc-9b56-e044b0feaf46">
        <updating/>
        <source>getComplexInfo(): WS_NSDSResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Apr 2022 navra1	TFS 53407 Send the company code sent from MTN through to Kafka and use this for all subsequent messages
27 Apr 2022 navra1	TFS 53491 Complex gkey is not known to the Producer unless a snapshot is done. It should know it whether a snapshot is done or not.

*/

vars
	response 		 	: 	WS_NSDSResponse;	
	content				: 	WS_NSDSContentComplexInfo;
	argoComplex			:	CMIF_ArgoComplex;	//TFS 53491 - navra1	 - 27th Apr 2022
begin
	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " initializepassport failed, so returning", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;
	
	
	create response as WS_NSDS200Response transient;		
	create content transient;
	create argoComplex transient;	//TFS 53491 - navra1	 - 27th Apr 2022
	
	content.complexID := CM_Root.firstInstance.companyCode;
	content.gkey := argoComplex.generateCpxGKey();	//TFS 53491 - navra1	 - 27th Apr 2022
	
	response.setContent(content);
	
	return response;
	
epilog

	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="getSystemData" id="960fa8aa-f12b-4db2-97c7-56c7d0a2c8f3">
        <updating/>
        <source>getSystemData(): WS_NSDSResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	response 		: WS_NSDSResponse;
	content			: WS_NSDSContentSystemData;
	pxyTerm     	: WS_NSDSArgoFacility;
	pxyEnv      	: WS_NSDSArgoComplex;
	wsTerms     	: WS_NSDSArgoFacilityArray;
	pxyBizUnit     	: WS_NSDSRefBizunitScoped;
	wsOpers     	: WS_NSDSRefBizunitScopedArray;
	pxyCarrierService        : WS_NSDSRefCarrierService ;
	wsTrades        : WS_NSDSRefCarrierServiceArray;
	pxyVsl          : WS_NSDSVslVessels;
	wsVsls          : WS_NSDSVslVesselArray;
	pxyVslClasses          : WS_NSDSVslVesselClasses;
	wsVslsClassesArray          : WS_NSDSVslVesselClassesArray;
	isoType			: CM_ISOType;
	trade           : CM_Trade;
	term        	: CM_Terminal;
	operator    	: CM_Operator;
	carrier : CM_Carrier; 
	delayType       : CM_DelayType;
	vsl             : CM_Vessel;
	root        	: CM_Root;
	pxyEquipType	: WS_NSDSRefEquipType;
	pxyDelayType	: WS_NSDSRefCraneDelayTypes;
	wsEquipTypes    : WS_NSDSRefEquipTypeArray;
	wsDelayTypes    : WS_NSDSRefCraneDelayArray;
	wsDef			: CM_OpsViewServiceDef;
	
	wclass 			: CM_WagonClass;
	wwell 			: CM_WagonWellDefinition;
	pxyWclass 		: WS_NSDSRailCars;
	pxyWclasses 	: WS_NSDSRailCarArray;
	pxyWwell 		: WS_NSDSRailCarPlatforms;
	pxyWwells 		: WS_NSDSRailCarPlatformArray;

	spatialBin		: WS_NSDSSpatialBins;
	spatialBins		: WS_NSDSSpatialBinsArray;
	pxyComm			: WS_NSDSAuxRefCommodity;
	wsComms			: WS_NSDSAuxRefCommodityArray;
	cargoType		: CM_CargoType;
	handlingType	: CM_HandlingType;
	pxyPackage		: WS_NSDSAuxCrgPackageType;
	wsPackage		: WS_NSDSAuxCrgPackageTypeArray;
	measureType		: CM_MeasurementType;
	pxyMeasureUnit	: WS_NSDSAuxMeasurementUnit;
	wsMeasureUnits	: WS_NSDSAuxMeasurementUnitArray;
	productType		: CM_Product;
	pxyProduct		: WS_NSDSAuxCrgProductType;
	wsProduct		: WS_NSDSAuxCrgProductTypeArray;
begin
	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " initializepassport failed, so returning", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;
	
	
	create response as WS_NSDS200Response transient;	
	create content transient;	
	
	wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
	
	if wsDef = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " wsDef is null, so returning", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		self.httpStatusCode := HttpResponseUnauthorized;
		return response;
	endif;
	
	if wsDef.allTerminals.size = 0 then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " no terminals available", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		self.httpStatusCode := HttpResponseNoContent;
		return response;
	
	endif;

	//Terminals
	create wsTerms transient;
	create spatialBins transient;
	foreach  term in app.myRoot.allTerminals discreteLock do
		
		if not term.isOpsViewEnabled(wsDef) then
			continue;
		endif;
		
		create pxyTerm transient;
		pxyTerm.setProxyObject(term);
		wsTerms.add(pxyTerm);
		
		//TFS#53369 NAVSP1 27APR2022
 // ### TFS 53369 27APR2022 NAVAB1		create spatialBin transient; 		
 // ### TFS 53369 2712APR2022 NAVAB1		spatialBin.setProxyObject(term); 
 // ### TFS 53369 2712APR2022 NAVAB1		spatialBins.add(spatialBin);
	endforeach;
	content.argofacilities := wsTerms;
	content.spatialBins		:= spatialBins;//53369
	//Operator
	create wsOpers transient;
	foreach  operator in app.myRoot.allOperators discreteLock do
		create pxyBizUnit transient;
		pxyBizUnit.setProxyObject(operator);
		wsOpers.add(pxyBizUnit);
	endforeach;
	
	 // ### TFS 51853 09DEC2021 NAVAB1 Carriers 
	foreach carrier in app.myRoot.allCarriers discreteLock do
		create pxyBizUnit transient;
		pxyBizUnit.setProxyObject(carrier);
		wsOpers.add(pxyBizUnit);
	endforeach;
	
	// Carriers, operators
	content.refBizunitScopeds := wsOpers;

	
	//Delay Types
	create wsDelayTypes transient;
	foreach  delayType in app.myRoot.allDelayTypes discreteLock do
		create pxyDelayType transient;
		pxyDelayType.setProxyObject(delayType);
		wsDelayTypes.add(pxyDelayType);
	endforeach;
	content.refCraneDelayTypes := wsDelayTypes;
	
	//Equipment Types
	create wsEquipTypes transient;
	foreach  isoType in app.myRoot.allISOTypes discreteLock do
		create pxyEquipType transient;
		pxyEquipType.setProxyObject(isoType);
		wsEquipTypes.add(pxyEquipType);
	endforeach;
	content.refEquipTypes := wsEquipTypes;
	
	// Trades
	create wsTrades transient;
	foreach  trade in app.myRoot.allTradesByDescription  discreteLock   do
		create pxyCarrierService transient;
		pxyCarrierService.setProxyObject(trade); 
		wsTrades.add(pxyCarrierService);
	endforeach;
	
	 // ### TFS 51855 13DEC2021 NAVAB1 Rail Carriers 
	foreach carrier in app.myRoot.allCarriers discreteLock where carrier.isRail do
		create pxyCarrierService transient;
		pxyCarrierService.setProxyObject(carrier);
		wsTrades.add(pxyCarrierService);
	endforeach;
	content.refCarrierServices := wsTrades;
	
	// Vessels 
	create wsVsls transient;
	create wsVslsClassesArray transient;				//navra1 - 8th Sep 2022 - TFS 53105
	foreach  vsl in app.myRoot.allVessels  discreteLock   do
		
		if not vsl.isOpsViewData then
			continue;
		endif;
		
		create pxyVslClasses transient; 				//navra1 - 8th Sep 2022 - TFS 53105
		pxyVslClasses.setProxyObject(vsl);				//navra1 - 8th Sep 2022 - TFS 53105
		wsVslsClassesArray.add(pxyVslClasses);			//navra1 - 8th Sep 2022 - TFS 53105
				
		create pxyVsl transient;
		pxyVsl.setProxyObject(vsl);
		wsVsls.add(pxyVsl);
	endforeach;
	content.vslVesselClasses := wsVslsClassesArray;		//navra1 - 8th Sep 2022 - TFS 53105
	content.vslVessels := wsVsls;
	
	// Wagon Class TFS 51855 14DEC2021 NAVAB1
	/*  // ### TFS 52914 04MAR2022 NAVAB1 - These are not wagon classes, they are N4's wagon fleet file for wagons
	create pxyWclasses transient;
	create pxyWwells transient;
	
	foreach wclass in app.myRoot.allWagonClasses discreteLock do
	
		create pxyWclass transient;
		pxyWclass.setProxyObject(wclass);
		pxyWclasses.add(pxyWclass);
		
		if wclass.allWagonWellDefArray.isNotEmpty() then
			foreach wwell in wclass.allWagonWellDefArray discreteLock do
				create pxyWwell transient;
				pxyWwell.setProxyObject(wwell);
				pxyWwells.add(pxyWwell);
			
			
			endforeach;
		else
		endif;
	
	endforeach;
	content.railCarPlatforms := pxyWwells;
	content.railCars := pxyWclasses;
	*/
	
	//Environment
	root := app.myRoot;
	create pxyEnv transient;
	pxyEnv.setProxyObject(root);
	content.argoComplex := pxyEnv;
	
	//##----- GC ----##
	//navsp1 31MAY2022 TFS#53104 	
	create wsComms transient;
	foreach cargoType in app.myRoot.allCargoTypesById discreteLock do
		create pxyComm transient;
		pxyComm.setProxyObject(cargoType);
		wsComms.add(pxyComm);
	endforeach;
	content.refCommoditys	:= wsComms;
	
	//navsp1 01Jun 2022 TFS#53104
	create wsProduct transient;
	foreach cargoType in app.myRoot.allCargoTypesById discreteLock do
		foreach productType in cargoType.allProducts discreteLock do
			create pxyProduct transient;
			pxyProduct.setProxyObject(productType);
			wsProduct.add(pxyProduct);
		endforeach;
	endforeach;
	content.productTypes := wsProduct;
	
	create wsPackage transient;
	foreach handlingType in app.myRoot.allHandlingTypes discreteLock do
		create pxyPackage transient;
		pxyPackage.setProxyObject(handlingType);
		wsPackage.add(pxyPackage);
	endforeach;
	content.packageTypes	:= wsPackage;
	
	create wsMeasureUnits transient;
	foreach measureType in app.myRoot.allMeasurementTypesByShortName discreteLock do
		create pxyMeasureUnit transient;
		pxyMeasureUnit.setProxyObject(measureType);
		wsMeasureUnits.add(pxyMeasureUnit);
	endforeach;
	content.measurementUnits	:= wsMeasureUnits;
	
	/*------------------*/
	
	response.setContent(content);

	return response;
	
epilog

	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="getTerminalData" id="423d5795-ab9c-49dc-b707-1a28963ef5f5">
        <updating/>
        <source>getTerminalData(): WS_NSDSResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
05 Oct 2020 cnwma1 Bug 50143: Unable to send snapshot data when Opsview user has access to multiple terminals
15 Mar 2022	navra1	CR53028 - MTN - Navis Smart Data API - Snapshot Data - Changes for Waterside
*/
constants 

	TERMOID  = "TermOid";
vars
	response 				: WS_NSDSResponse;
	content					: WS_NSDSContentTerminalData;
	pxyMachine     			: WS_NSDSXpsChe;
	wsMachines     			: WS_NSDSXpsCheArray;
	machine		    		: CM_Machine;
	pxyBerth        		: WS_NSDSArgoQuay;
	wsBerths        		: WS_NSDSArgoQuayArray;
	berth           		: HMS_Berth;
	terminal        		: CM_Terminal;
	termOid         		: String;
	selectedVoyages			: CM_VoyageSet;
	pxycarriervisit 		: WS_NSDSArgoCarrierVisit;
	wsVisits       			: WS_NSDSArgoCarrierVisitArray;
	voyage					: CM_Voyage;
	wsDef					: CM_OpsViewServiceDef;
	train 					: CM_Train;
	wagon 					: CM_Wagon;
	wagonVisit 				: WS_NSDSRailCarVisits;
	wagonVisits 			: WS_NSDSRailCarVisitsArray;
	theVVRs 				: CM_VehicleVisitRecordSet;
	vvr 					: CM_VehicleVisitRecord;	
	voyageJobSheet			: CM_VoyageJobSheet;	
	wq						: WS_NSDSInvWq;
	wqs						: WS_NSDSInvWqArray;
	oneJob					: CM_VoyageJob;
	wi		 				: WS_NSDSInvWi;	
	wis 					: WS_NSDSInvWiArray;	
	oneWle					: CM_WorkListEntry;
	wleArray				: CM_WLEArray;
	moveEvent				: WS_NSDSInvMoveEvent;
	moveEvents				: WS_NSDSInvMoveEventArray;
	numWlesSent 			: Integer;
	numJobsSent 			: Integer;
	numMoveEventsSent		: Integer;
	xpsCraneShift			: WS_NSDSXpsCraneshift;
	xpsCraneShifts			: WS_NSDSXpsCraneshiftArray;
	xpsPointOfWork 			: WS_NSDSXpsPointOfWork;
	xpsPointOfWorks 		: WS_NSDSXpsPointOfWorkArray;
	unitYrdvisit			: WS_NSDSInvUnitYrdVisit;
	unitYrdvisits			: WS_NSDSInvUnitYrdVisitArray;	
	roadTruckTransaction 	: WS_NSDSRoadTruckTransactions;
	roadTruckTransactions 	: WS_NSDSRoadTruckTrxArray;
	
	unitFcyVisit			: WS_NSDSInvUnitFcyVisit;
	unitFcyVisits			: WS_NSDSInvUnitFcyVisitArray;
	invUnit					: WS_NSDSInvUnit;
	invUnits				: WS_NSDSInvUnitArray;
	refEquipment			: WS_NSDSRefEquipment;
	refEquipments			: WS_NSDSRefEquipmentArray;
	ti						: CM_TrackedItem;
	tis						: CM_TIArray;
	
	terminalArea			: CM_TerminalArea;
	spatialBin				: WS_NSDSSpatialBins;
	spatialBins				: WS_NSDSSpatialBinsArray;
	gridArea 				: CM_GridArea;
	gridCol					: CM_GridColumn;
	gridLC 					: CM_GridController;
	xpsStack				: WS_NSDSXpsStackStatus;
	xpsStacks				: WS_NSDSXpsStackStatusArray;
	
	argoYard 				: WS_NSDSArgoYard;
	argoYards 				: WS_NSDSArgoYardArray;
	blockArea				: CM_BlockStack;
	blockLC					: CM_BlockController;
	colGKey					: String;
	iter 					: Iterator;
	
	bol : CM_BOLIn;
	bolDetail : CM_BOLDtl;
	book : CM_BookingRef;
	bookDetail : CM_BookingRefItem;
	
	wsBOL : WS_NSDSCrgBillsOfLading;
	wsBOLItem : WS_NSDSCrgBlItem;
	wsBOLs : WS_NSDSCrgBillsOfLadingArray;
	wsBOLItems : WS_NSDSCrgBlItemArray;
	
	wsInvGood : WS_NSDSInvGoods;
	wsInvGoods : WS_NSDSInvGoodsArray;
	workPoint	: CM_WorkPoint;
begin
	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " initialisePassport failed", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;
	
	create response as WS_NSDS200Response transient;	
	create content transient;	
		
	termOid	:= self.qsData.getValue(TERMOID);	
	if termOid = null  then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " termOid is null", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		self.httpStatusCode := HttpResponseNoContent;
		return response;
	endif;
	
	//terminal	:= app.myPassport.getObjectOfTypeFromOid(termOid,CM_Terminal).CM_Terminal; //05.10.2020 cnwma1 #50143
	terminal    := termOid.asOid.CM_Terminal;                                              //05.10.2020 cnwma1 #50143	   //navsp1 31Aug2022 - uncommented

	if terminal = null
	or not global.isValidObject(terminal)  then // ### TFS 51853 08DEC2021 NAVAB1
		app.writeLog(method.qualifiedName &amp; Tab &amp; " terminal is not valid", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		self.httpStatusCode := HttpResponseNoContent;
		return response;
	endif;
	
	wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
	if wsDef = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " wsDef is null", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		self.httpStatusCode := HttpResponseUnauthorized;
		return response;
	endif;
	
	if not terminal.isOpsViewEnabled(wsDef) then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " terminal is not OpsView enabled", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		self.httpStatusCode := HttpResponseUnauthorized;
		return response;
	endif;
	
		
	//Machines
	create wsMachines transient;
	foreach  machine in terminal.machines discreteLock do
		if not machine.isOpsViewData() then
			continue;
		endif;
		
		create pxyMachine transient;
		pxyMachine.setProxyObject(machine);
		wsMachines.add(pxyMachine);
	endforeach;

	//navsp1 03Jun2022 TFS#53104
	//Machines - Work Point
	foreach  workPoint in terminal.allWorkPointsByCode discreteLock do
		if not workPoint.isOpsViewData() then
			continue;
		endif;		
		create pxyMachine transient;
		pxyMachine.setProxyObject(workPoint);
		wsMachines.add(pxyMachine);
	endforeach;
	content.xpsChes := wsMachines;
	
	
	//Berth 
	create wsBerths transient;
	if terminal.myHarbour &lt;&gt; null then
		foreach berth in terminal.myHarbour.allBerths discreteLock do 
			create pxyBerth transient;
			pxyBerth.setProxyObject(berth);
			wsBerths.add(pxyBerth);	
		endforeach;
	endif;
	content.argoQuays := wsBerths;
	

	
	// ### Current Yard Data
	//TFS#53369 08APR2022 NAVSP1
	create spatialBins transient;
	create xpsStacks transient;
	//TFS#53369 20APR2022 NAVSP1
	create invUnits transient; 		
	create unitFcyVisits transient; 
	create refEquipments transient; 
		
	create argoYards transient; // ### TFS 53369 28APR2022 NAVAB1
	
	//TFS#53369 NAVSP1 27APR2022
	create spatialBin transient; 		
	spatialBin.setProxyObject(terminal); 
	spatialBins.add(spatialBin);
	
	create argoYard transient; 		 // ### TFS 53369 28APR2022 NAVAB1
	argoYard.setProxyObject(terminal);  // ### TFS 53369 28APR2022 NAVAB1
	argoYards.add(argoYard); // ### TFS 53369 28APR2022 NAVAB1
	content.argoYards := argoYards; // ### TFS 53369 28APR2022 NAVAB1

	foreach terminalArea in terminal.allTerminalAreas discreteLock do
		if not terminalArea.isOpsViewData() then // ### TFS 53369 12APR2022 NAVAB1
			continue;
		endif;
		
		if terminalArea.isGridArea() then							//navsp1 25MAY2022 TFS#53700
			gridArea := terminalArea.CM_GridArea;
			create spatialBin transient; 
			spatialBin.setProxyObject(terminalArea); 
			spatialBins.add(spatialBin);
			foreach gridCol in gridArea.allGridColumns discreteLock do
				// ### Grid Column
				create spatialBin transient; 		
				spatialBin.setProxyObject(gridCol); 
				spatialBins.add(spatialBin);
				foreach gridLC in gridCol.allControllersByRow discreteLock do
					// ### Grid Location
					create spatialBin transient; 		
					spatialBin.setProxyObject(gridLC); 
					spatialBins.add(spatialBin);
					// ### Stack
					create xpsStack transient;
					xpsStack.setProxyObject(gridLC);
					xpsStacks.add(xpsStack);
				endforeach;
			endforeach;		
		/*navsp1 30MAY2022 - Commented as not used now but to use it in the future.
		elseif terminalArea.isBlockStack() then // ### TFS 53369 12APR2022 NAVAB1
			//navsp1 26MAY2022 TFS#53700
			blockArea := terminalArea.CM_BlockStack;
			create spatialBin transient; 
			spatialBin.setProxyObject(terminalArea); 
			spatialBins.add(spatialBin);			
			
			colGKey	:= spatialBin.gkey.String;			
			// ### Block Column
			create spatialBin transient; 		
			spatialBin.setProxyObjectCOL(blockArea,colGKey); 
			spatialBins.add(spatialBin);	
			
			colGKey	:= spatialBin.gkey.String;			
			// ### Block Location				
			blockLC	:= blockArea.myLocationsController;			
			create spatialBin transient; 		
			spatialBin.setProxyObjectCOL(blockLC,colGKey); 
			spatialBins.add(spatialBin);
			
			// ### Stack
			create xpsStack transient;
			xpsStack.setProxyObject(blockLC);
			xpsStacks.add(xpsStack);
		*/
		endif;		
	endforeach;
	content.spatialBins 	:= spatialBins;
	content.xpsStacks		:= xpsStacks;
	
	//TFS#53369 30MAY2022 NAVSP1
	iter := terminal.allOnsiteTIsByCargoTypeId.createIterator();
	terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container,"", iter);	
	while iter.next(ti) do
		if ti.myCargoType.id &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		create invUnit transient; 		
		invUnit.setProxyObject(ti); 
		invUnits.add(invUnit);
				
		create refEquipment transient; 		
		refEquipment.setProxyObject(ti); 
		refEquipments.add(refEquipment);
				
		create unitFcyVisit transient; 
		unitFcyVisit.setProxyObject(ti); 
		unitFcyVisits.add(unitFcyVisit);	
	endwhile;	
	
	
	create wsInvGoods transient; // ### TFS 53105 02JUN2022 NAVAB1
	
	// ### TFS 53105 31MAY2022 NAVAB1
	// ### SEND ALL ONSITE GENERAL CARGO - Bulk, Break Bulk, Vehicles etc.
	iter := terminal.allOnsiteTIsByCargoTypeId.createIterator();
	terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Null,"", iter);	
	while iter.next(ti) do
		if ti.myCargoType.id = TI_CargoType_Container then
			continue;
		endif;
		
		if not ti.isOpsViewData() then
			continue;
		endif;
		
		create invUnit transient; 		
		invUnit.setProxyObject(ti); 
		invUnits.add(invUnit);
				
		create refEquipment transient; 		
		refEquipment.setProxyObject(ti); 
		refEquipments.add(refEquipment);
				
		create unitFcyVisit transient; 
		unitFcyVisit.setProxyObject(ti); 
		unitFcyVisits.add(unitFcyVisit);	
		
		if not ti.isContainer() then
			create wsInvGood transient; // ### TFS 53105 02JUN2022 NAVAB1
			wsInvGood.setProxyObject(ti); 
			wsInvGoods.add(wsInvGood);	
		endif;
		
	endwhile;	
	
	content.invUnits		:= invUnits;
	content.refEquipments	:= refEquipments;
	content.invUnitFcyVisits:= unitFcyVisits;
	content.invGoods := wsInvGoods;  // ### TFS 53105 02JUN2022 NAVAB1
	
	create wsBOLItems transient;
	create wsBOLs transient;
	 // ### TFS 53105 31MAY2022 NAVAB1
	foreach bol in terminal.allBOLsReceivedByDTType as CM_BOLIn discreteLock do
		create wsBOL transient; 		
		wsBOL.setProxyObject(bol); 
		wsBOLs.add(wsBOL);
	
		foreach bolDetail in bol.allBOLDtls discreteLock do
			create wsBOLItem transient; 		
			wsBOLItem.setProxyObject(bolDetail); 
			wsBOLItems.add(wsBOLItem);
		
		
		endforeach;
	endforeach;
	
	 // ### TFS 53105 31MAY2022 NAVAB1
	foreach book in terminal.allBookingRefsByRef discreteLock do
		create wsBOL transient; 		
		wsBOL.setProxyObject(book); 
		wsBOLs.add(wsBOL);
	
		foreach bookDetail in book.allBookingRefItems discreteLock do
			create wsBOLItem transient; 		
			wsBOLItem.setProxyObject(bookDetail); 
			wsBOLItems.add(wsBOLItem);
		
		
		endforeach;
	
	endforeach;
	
	
	content.crgBillsOfLadings := wsBOLs;
	content.crgBlItems := wsBOLItems;
	
	// RESPOND WITH THE SNAPSHOT DATA
	response.setContent(content);
	

	return response;
	
epilog
	delete theVVRs;
	
	self.finaliseResponse(response);

end;


/* // ### TFS 53369 13APR2022 NAVAB1 do not send current voyages, trains trucks jobs etc.
	// ### CURRENT VOYAGES		
	create selectedVoyages transient;
	create wsVisits       transient;
	create voyageJobSheet transient;
	create oneJob transient;
	create wq transient;
	create wqs transient;
	create wi transient;
	create wleArray transient;	
	create wis transient;
	create xpsCraneShift transient;
	create xpsCraneShifts transient;
	create xpsPointOfWork transient;	
	create xpsPointOfWorks transient;
	create unitYrdvisit transient;
	create unitYrdvisits transient;
	create moveEvent transient;
	create moveEvents transient;
	create invUnit transient;
	create invUnits transient;
	create refEquipment transient;
	create refEquipments transient;
	create unitFcyVisit transient;
	create unitFcyVisits transient;
	
	terminal.getAllCurrentVoyages(selectedVoyages,true,true,false);     //Later Will check which voyages needed
	
	foreach voyage in selectedVoyages discreteLock do
		if voyage.isNullVoyage then
			continue;
		endif;
 		
		if not voyage.isOpsViewData then
			continue;
		endif;
		
		create pxycarriervisit transient; 
		
		pxycarriervisit.setProxyObjectPrefix(voyage,""); 
		wsVisits.add(pxycarriervisit); 
		

		//send the actioned jobs of this Voyage
		foreach voyageJobSheet in voyage.allJobSheets do				//go through all the jobsheets of the voyage
			foreach oneJob in voyageJobSheet.allJobsByJobNum do			//go through all the jobs of that sheet
				if not oneJob.isOpsViewData then
					continue;
				endif;
				
				numJobsSent := numJobsSent + 1;
				
				//create a proxy xpscraneshift, a proxy xpsPointOfWork and proxy wq 
				//and it to the respective lists to send for each Job				
				create xpsCraneShift transient;
				xpsCraneShift.setProxyObject(oneJob);
				xpsCraneShifts.add(xpsCraneShift);
				
				create xpsPointOfWork transient;
				xpsPointOfWork.setProxyObject(oneJob);
				xpsPointOfWorks.add(xpsPointOfWork);
				
				create wq transient;				
				wq.setProxyObject(oneJob);					
				wqs.add(wq);						
				
				//now go through the list of WLEs in that job that we just decided to send
				wleArray.clear();
				oneJob.getAllWLEs(wleArray);
				foreach oneWle in wleArray do	
					if not oneWle.isOpsViewData then
						continue;
					endif;
					
					numWlesSent := numWlesSent + 1;					
					
					//create a proxy yrdvisit, a proxy move event(for completed WLEs) and a proxy wi
					//and it to the respective lists to send for each WLE
					if oneWle.status = WLE_COMPLETED then
						create moveEvent transient;
						moveEvent.setProxyObject(oneWle);
						moveEvents.add(moveEvent);			
						numMoveEventsSent := numMoveEventsSent + 1;
					endif;
					
					tiOfWle	:= oneWle.myTrackedItem;
					
					create unitFcyVisit transient;
					unitFcyVisit.setProxyObject(tiOfWle);
					unitFcyVisits.add(unitFcyVisit);
					
					create invUnit transient;
					invUnit.setProxyObject(tiOfWle);
					invUnits.add(invUnit);
					
					create refEquipment transient;
					refEquipment.setProxyObject(tiOfWle);
					refEquipments.add(refEquipment);				
					
					create unitYrdvisit transient;
					unitYrdvisit.setProxyObject(oneWle);
					unitYrdvisits.add(unitYrdvisit);
					
					create wi transient;		
					wi.setProxyObject(oneWle);		
					wis.add(wi);					
					
				endforeach;
			endforeach;
		endforeach;

	endforeach;	
	
	app.writeLog('The number of Jobs sent in snapshot is =' &amp; numJobsSent.String, LogINFO);
	app.writeLog('The number of WLEs sent in snapshot is =' &amp; numWlesSent.String, LogINFO);
	app.writeLog('The number of MoveEvents sent in snapshot is =' &amp; numMoveEventsSent.String, LogINFO);
	content.invWqs := wqs;	
	content.xpsCraneshifts := xpsCraneShifts;
	content.xpsPointOfWorks := xpsPointOfWorks;
	content.invWis := wis;
	content.invUnitYrdVisits := unitYrdvisits;
	content.invMoveEvents := moveEvents;
	content.refEquipments := refEquipments;
	content.invUnits := invUnits;
	content.invUnitFcyVisits := unitFcyVisits;

	
	// ### TFS 51855 12JAN2022 NAVAB1		
	// ### CURRENT TRUCKS
	create theVVRs transient;
	terminal.getAllCurrentVehicleVisits(theVVRs);
	
	foreach vvr in theVVRs discreteLock do
	
		create pxycarriervisit transient; 
		
		pxycarriervisit.setProxyObjectPrefix(vvr,""); 
		wsVisits.add(pxycarriervisit); 
	
	
	endforeach;
	
	// ### TFS 51855 07JAN2022 NAVAB1
	// ### CURRENT TRAINS
	create wagonVisits transient; // ### TFS 51855 10JAN2022 NAVAB1
	
	foreach train in terminal.allTrainsArrival discreteLock do
		if train.isNullTrain then
			continue;
		endif;
 		
		if not train.isOpsViewData then
			continue;
		endif;
	
		if terminal.allTrainsDeparted.includes(train) then
			continue;
		endif;
		
		create pxycarriervisit transient; 
		pxycarriervisit.setProxyObjectPrefix(train, CMIF_OpsViewTables.Train_Direction_In); 
		wsVisits.add(pxycarriervisit); 
		
		create pxycarriervisit transient; 
		pxycarriervisit.setProxyObjectPrefix(train, CMIF_OpsViewTables.Train_Direction_Out); 
		wsVisits.add(pxycarriervisit); 
		
		
		foreach wagon in train.allWagonsByOrderInward discreteLock do
			create wagonVisit transient; 
			wagonVisit.setProxyObject(wagon); 
			wagonVisits.add(wagonVisit); 
		endforeach;
		
		// only send wagons not in the inward collection
		foreach wagon in train.allWagonsByOrderOutward discreteLock do
			if train.allWagonsByOrderInward.includes(wagon) then
				continue;
			endif;
			
			create wagonVisit transient; 
			wagonVisit.setProxyObject(wagon); 
			wagonVisits.add(wagonVisit); 
		endforeach;
		
	endforeach;
	
	content.argoCarrierVisits	:= wsVisits;
	content.railCarVisits := wagonVisits;

*/</source>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="getVesselVisit" id="8d8fcc34-fe01-41d7-8b2b-405482705c2e">
        <updating/>
        <source>getVesselVisit(): WS_NSDSResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/
constants 

	VoyageOid  = "VoyageOid";
vars
	response 		: WS_NSDSResponse;
	parameters 		: WS_QueryStringParamDict;
	content			: WS_NSDSContentVesselVisit;
	pxyVoyage       : WS_NSDSArgoCarrierVisit;
	voyageOid       : String;
	voyage          : CM_Voyage;
begin
	//==== Standard REST Method Processing ====
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
		
	// Set app.mypassport - user / terminal etc
	if self.initialisePassport() = false then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " initialisePassport failed", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365 
		create response as WS_NSDSErrResponse transient;
		return response;
	endif;
	
	create response as WS_NSDS200Response transient;	
	create content transient;	
		
	voyageOid := self.qsData.getValue(VoyageOid);

	if voyageOid = null  then		
		create response as WS_NSDSErrResponse transient;
		app.raiseCMException1(Input_required_field,"INVALID voyage", null, null);
		return response;
	endif;
	
	voyage := voyageOid.asOid.CM_Voyage;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if voyage = null  then
		create response as WS_NSDSErrResponse transient;
		app.raiseCMException1(Input_required_field,"INVALID voyage", null, null);
		return response;
	endif;
	
	create pxyVoyage transient;
	pxyVoyage.setProxyObjectPrefix(voyage,"");
	content.voyage := pxyVoyage;
	
	response.setContent(content);
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_NSDSResponse"/>
    </JadeMethod>
    <JadeMethod name="reply" id="5fd84cf2-9240-470b-9fbf-b50c2823688e">
        <source>reply(msg: String);
/*
Purpose:	RECORD SYSTEM DATA JSON in activity		

Date		Who		Reason
29 November 2021	navab1	TFS 52413
*/

vars
	pxyAct, ewsAct : CM_EWSActivityOpsview;
	wsDef			: CM_OpsViewServiceDef;

begin
	inheritMethod(msg);
	
	// RECORD SYSTEM DATA JSON in activity
	// ### TFS 52413 29NOV2021 NAVAB1
	if msg.pos("WS_NSDSContentSystemData",1) &gt; 0 then
		wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
		if wsDef &lt;&gt; null then
			create pxyAct transient;
			pxyAct.initialiseActivity("Navis Smart Data API - System",wsDef.name, null, null, "U", "System Data", true, null);
			ewsAct := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
			delete pxyAct;
			
			pxyAct := app.createUpdateProxy(ewsAct).CM_EWSActivityOpsview;
			pxyAct.setProxyRequestDetails(null,msg,HttpResponseOK); // ### TFS 51855 19MAY2022 NAVAB1
			pxyAct.initialiseStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS, null);
			app.myTrxUA.trxUpdateEWSActivity(pxyAct, app.myPassport);
			delete pxyAct;
			
		endif;
		
	endif;
	if msg.pos("WS_NSDSContentTerminalData",1) &gt; 0 then
		wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
		if wsDef &lt;&gt; null then
			create pxyAct transient;
			pxyAct.initialiseActivity("Navis Smart Data API - Terminal",wsDef.name, null, null, "U", "Terminal Data", true, null);
			ewsAct := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
			delete pxyAct;
			
			pxyAct := app.createUpdateProxy(ewsAct).CM_EWSActivityOpsview;
			
			pxyAct.setProxyRequestDetails(null,msg,HttpResponseOK); // ### TFS 51855 19MAY2022 NAVAB1
			pxyAct.initialiseStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS, null);
			app.myTrxUA.trxUpdateEWSActivity(pxyAct, app.myPassport);
			delete pxyAct;
			
		endif;
		
	endif;

epilog
	delete pxyAct;
end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="e358880f-8da1-4e27-986e-b6916d5bc895">
        <source>validateLicense(path : String) : Boolean;
/*

Purpose:			
	Checks the MTN_SERVICENAME header and validates that there is a valid license for this service.

Parameters:			

Return Value:		
	True if there is a valid license

Date		Who		Reason
09 July 2020	jlgrr1	Initial creation TFS 49632 

*/

vars
	servicename : String;
	root 		: CM_Root;
	validLicense : Boolean;
begin

	if path.toLower = "/ping" 
		or path.toLower = "/licensecheck" then
		return true;
	endif;
		
	// LICENSING
	// Confirm the system has an active subscription licence for this MicroService
	servicename := self.mtnServiceName();
	root := app.myRoot;
	
	if root = null or servicename = "" then
		app.writeLog("NAVIS SMART DATA: Header MTN-SERVICENAME not specified", LogERROR);
		return false;
	endif;

	if servicename = app.getErrorString(Navissmart_opsview) then
		if not root.canDo(Sub_OpsView) then
			app.writeLog("NAVIS SMART DATA: NavisSmart_OpsView Subscription not Active", LogERROR);
			return false;
		endif;
		return true;
	endif;
	// When other microservices are created, with new subscriptions, the equivalent check should be made here
	// e.g.
	// if servicename = "NavisSmart_Analytics" and not root.canDo(PmNavisSmartAnalyticsModule) then
	// 	return false;
	// endif;
	
	app.writeLog("NAVIS SMART DATA: Invalid service specified. [" &amp; servicename &amp; "]", LogERROR);
	return false;
epilog

end;</source>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
