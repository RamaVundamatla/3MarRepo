    <JadeMethod name="rel812_par30955" id="fe9c1966-74a4-4cdb-8bd5-0e4e0cd5ee33">
        <source>rel812_par30955();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 March 2013	cnwjre1	after CCMS QNS 2177 fix up invoice line mapping

*/

vars
	doCreate	: Boolean;
	isVTMIS		: Boolean;
	mapType	: CM_TranMapInvoiceLineGroupType;
	mapMapping	: CM_TranMapInvoiceLineMapping;
	mapDict	: CM_TMInvLineMapByCargoAttrDict;
	qrm		: CM_QuantityRangeMap;
	ild		: CM_InvoiceLineDesc;
	iter	: Iterator;
	key		: Integer;
	count		: Integer;
	ildInCount, ildOutCount,
	mapInCount, mapOutCount	: Integer;
begin
	app.initialize();
	
	// find the All map type to use for new line maps
	foreach mapType in CM_TranMapInvoiceLineGroupType.instances do
		if mapType.type = TranMapInvLineGroupTypeAll then
			break;
		endif;
	endforeach;
	
	// maintenance of quantity range was buggy - find missing stuff - dictionary itself and missing/wrong content
		/* TFS 40620 removing all references to qrm.allInvoiceLineMaps

	beginTransaction;
	foreach qrm in CM_QuantityRangeMap.instances do
		isVTMIS := (qrm.myQuantityMap.myParentFinancialObject.isKindOf(CM_ResourceServiceBroker));
		doCreate := false;
		mapDict := qrm.allTMInvoiceLineMappings;
		if mapDict.isEmpty() then
			doCreate := true;
			write qrm.String &amp; " empty mapDict";
		endif;
		if mapDict.size &lt;&gt; qrm.allInvoiceLineMaps.size then
			doCreate := true;
			write qrm.String &amp; " different dict sizes";
		else
			if isVTMIS then
				ildInCount := 0;
				ildOutCount := 0;
				mapInCount := 0;
				mapOutCount := 0;
				foreach mapMapping in mapDict do
					if mapMapping.mapValue = CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT then
						mapInCount := mapInCount + 1;
					elseif mapMapping.mapValue = CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT then
						mapOutCount := mapOutCount + 1;
					endif;
				endforeach;
				iter := qrm.allInvoiceLineMaps.createIterator();
				while iter.next(ild) do
					qrm.allInvoiceLineMaps.getIteratorKeys(key, iter);
					if key = CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT then
						ildInCount := ildInCount + 1;
					elseif key = CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT then
						ildOutCount := ildOutCount + 1;
					endif;
				endwhile;
				delete iter;
				if mapInCount &lt;&gt; ildInCount or mapOutCount &lt;&gt; ildOutCount then
					doCreate := true;
					write qrm.String &amp; " different In/OUT counts";
				endif;
			else
				foreach mapMapping in mapDict do
					if not qrm.allInvoiceLineMaps.includes(mapMapping.myTMInvoiceLineDesc) then
						doCreate := true;
						write qrm.String &amp; " different ILDs";
						break;
					endif;
				endforeach;
			endif;
		endif;

		if doCreate then	
			mapDict.purge();
			iter := qrm.allInvoiceLineMaps.createIterator();
			while iter.next(ild) do
				qrm.allInvoiceLineMaps.getIteratorKeys(key, iter);
				create mapMapping;
				mapMapping.update(key, ild, qrm, mapType, null, null);
			endwhile;
			delete iter;
		endif;
	endforeach;
	commitTransaction;
	*/
	write method.name &amp; " done";

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel812_par30990" id="2bcd4dd6-cb4e-4dc7-bf8e-920896629650">
        <source>rel812_par30990();

/*

Purpose:		Remove picTIIsRehandle object from CM_DrawingAttribute

Date			Who		Reason
09 January 2013	cnwmh5	Initial creation #30990

*/

vars

	obj					: Object;
	drawingAttribute	: CM_DrawingAttribute;

begin

	beginTransaction;
	foreach obj in CM_DrawingAttribute.instances discreteLock do
		drawingAttribute := obj.CM_DrawingAttribute;
		if drawingAttribute.code = "picTIIsRehandle" and drawingAttribute.fontName = "Helvetica" and 
				drawingAttribute.fontCharacter = 189 then
			delete drawingAttribute;
			break;
		endif;	
	endforeach;
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
