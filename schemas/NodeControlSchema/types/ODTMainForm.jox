    <JadeMethod name="createSession" id="3755b912-058b-4540-88dd-02a3eb730eef">
        <updating/>
        <source>createSession(ff:ODTSessionForm io) updating;
// If sessions[i]=0, session i is not active. If sessions[i]=i, session i is active.
vars
	i:Integer;
begin
	i:=sessions.indexOf(0);
	if i=0 then
		i:=sessions.size+1;
	endif;
	sessions[i]:=i;
	ff.sessionNumber:=i;
	ff.sessionName:="Session "&amp;i.String;
	ff.left:=((i-1) mod 5)*20;  // cascade new sessions
	ff.top:=ff.left;
	ff.caption:=ff.sessionName;
	currentForm:=ff;
end;</source>
        <Parameter name="ff" type="ODTSessionForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteSession" id="5ebad03a-4364-46b0-970c-d7b9667f2e1a">
        <updating/>
        <source>deleteSession(ff:ODTSessionForm) updating;

begin
	sessions[ff.sessionNumber]:=0;
	currentForm:=null;
end;</source>
        <Parameter name="ff" type="ODTSessionForm"/>
    </JadeMethod>
    <JadeMethod name="doLoad" id="1adf7969-4cb8-48aa-9d33-a0d124bb0f85">
        <updating/>
        <source>doLoad() updating;

vars
	logPath,latestFileName:String;
begin
	app.mdiFrame:=self.class;
	move(0,0,1024,680);
	create sessions transient;
	create folder;
	folder.fileName:=app.dbPath.toLower.replace("server\c_system","logs");
	findMappedDrive;
	logPath:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "c:\temp");
	caption:="ODT ("&amp;app.getEnvid&amp;" on "&amp;app.computerNameAppServer.toLower&amp;")";
	
	mnuWindowNew_click(mnuWindowNew);
	currentForm.windowState:=WindowState_Maximized;
	latestFileName:=currentForm.findLatestFile(logPath&amp;'\jommsg', '.log', 1);
	currentForm.addFile(latestFileName, true);
	
	mnuWindowNew_click(mnuWindowNew);
	currentForm.windowState:=WindowState_Maximized;
	latestFileName:=currentForm.findLatestFile(logPath&amp;'\msg', '.log', 1);
	currentForm.addFile(latestFileName, true);
end;</source>
    </JadeMethod>
