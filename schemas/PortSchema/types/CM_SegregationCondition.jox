    <JadeMethod name="validateForUpdate" id="255ad1b0-cefd-495a-a520-6207ae2c35c7">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
//14/06/2022 navds20 TFS 53760 DuplicateItem not Translatable	
----------   ----------  --------------------------------------------------
*/
vars
	realCondition,
	existingCondition			: CM_SegregationCondition;
	str							: String;
	segRule						: CM_SegregationRule;
	idx							: Integer;
begin
	if self.type = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Type is null. This is set in the creator method.');
		return;
	endif;
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Condition Code', ETRow_ConditionCode, null);
		app.raiseCMException(Input_required_field_condCode, ETRow_ConditionCode, null); // cnwdb2	PAR 35364
	endif;


	existingCondition	:= app.myPassport.myTerminal.allSegregationConditions[self.type, self.code];
	realCondition	:= self.pxyGetRealObject();
	
	if existingCondition &lt;&gt; null and
	   (realCondition = null or //in which case we are trying add a new one that is duplicate
	   existingCondition &lt;&gt; realCondition) //in which case we are trying update one to be same as another
	   then
		//app.raiseCMException2(DuplicateItem, "Segregation Condition", self.code, null, null); //14.06.2022 navds20 53760
		// Segregation Condition already exists for %1 : Segrega_conditi_already_exists
		app.raiseCMException1(Segrega_conditi_already_exists, self.code, null, null); //14.06.2022 navds20 53760
	endif;	
	
	if self.proximityHorizontal.String = null and
	   self.proximityVertical.String = null and
	   self.proximityDepth.String = null and
	   self.allowedSameArea then
		app.raiseCMException(Input_been_made_that_would_cau, null, null);
	endif;
	
	if (not self.allowedSameArea) and 
	   (self.proximityHorizontal &lt;&gt; null or
	   self.proximityVertical &lt;&gt; null or
	   self.proximityDepth &lt;&gt; null) then
		app.raiseCMException(Speci_allow_same_area_must_mak, null, null);
	endif;
	
	if realCondition &lt;&gt; null and realCondition.isActive and not self.isActive then
		if (not realCondition.allSegregationRules.isEmpty) then
		//epr par 15809 31/1/2008 this caused a string to long error most of the time, and the message really didn't mean much
			/*foreach segRule in realCondition.allSegregationRules do
				str := str &amp; segRule.getDisplayDescr() &amp; ', ';
				idx := idx + 1;
				if idx &gt; 10 then
					//str := str &amp; '...';
					//break;
				endif;
			endforeach;*/
			app.raiseCMWarning(Warni_deact_this_code_will_dis, null, null, self);
		
		endif;
	endif;
	
end;


</source>
    </JadeMethod>
</Class>
