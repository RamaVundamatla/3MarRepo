<Class name="LicenseInfo" id="f4532bda-ba96-462e-9823-284bd579c335">
    <superclass name="PersistentModel"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="license_test"/>
    <PrimAttribute name="customerName" id="f36bc790-e0f5-4a68-b074-d0fd54792d6f">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="licenseKey" id="3e4192a8-4f55-4e1d-9df4-1f6828b6734c">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTestData" id="b4bf0cf9-594c-4919-a26c-dcd9e238cfb2">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="TestData"/>
        <access>readonly</access>
        <Inverse name="TestData::allLicenseInfos"/>
    </ExplicitInverseRef>
    <PrimAttribute name="productCode" id="fec3fd07-6f20-4804-9859-f89e3d0d2a3b">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplay" id="7c2d5ffa-74c3-4562-b031-27f53a65fd32">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		Returns a display string of the receiver's details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.customerName &amp; Tab &amp; self.productCode &amp; Tab &amp; self.licenseKey;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="c6a18ba2-d74e-4a44-8afb-1349b9387e52">
        <updating/>
        <source>updateMe(pCustomerName:String; pProductCode:String; pLicenseKey:String; pTheTestData:TestData) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.licenseKey &lt;&gt; pLicenseKey then
		self.licenseKey		:=	pLicenseKey;
	endif;
		
	if self.customerName &lt;&gt; pCustomerName then
		self.customerName	:=	pCustomerName;
	endif;
	
	if self.productCode &lt;&gt; pProductCode then
		self.productCode	:=	pProductCode;
	endif;
	
	if self.myTestData &lt;&gt; pTheTestData then
		self.myTestData		:=	pTheTestData;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <Parameter name="pTheTestData" type="TestData"/>
    </JadeMethod>
</Class>
