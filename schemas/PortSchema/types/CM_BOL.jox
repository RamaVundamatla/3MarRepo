    <JadeMethod name="hasLoadedLogs" id="209278db-00e9-4287-b7bd-50d6c25ee47f">
        <source>hasLoadedLogs() : Boolean;
//	Sep 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes
//	Return true for Log Dockets with at least one log on a Loading Complete, Closed or Archived voyage
//	Used in docket maintenance to prevent edit in this case.
vars
	ti		: CM_TrackedItem;
	voyage	: CM_Voyage;
begin
	if self.bolType &lt;&gt; BOLType_Log then
		return false;
	endif;
	foreach ti in self.allTrackedItems do
		// 31785 June 2013 only if the log is still on-ship
		if ti.isOnShip() then
			voyage := ti.myVoyage;
			if  voyage &lt;&gt; null then
				if voyage.isClosedStatus() then
					return true;
				endif;
			endif;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasNonPlannedOnShipCargo" id="cf35ae3d-abc8-473c-881a-c0f7ceffa211">
        <source>hasNonPlannedOnShipCargo() : Boolean;
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin

	foreach tmpTI in self.allTrackedItems do
		if tmpTI.myPrimaryPlannedLocation = null
		and tmpTI.site = TI_SITE_ONSHIP then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
