    <JadeMethod name="setProxyPw" id="5e44deee-c746-4e84-b2a3-39d48a67af1e">
        <updating/>
        <source>setProxyPw(_str: String; _context: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin

	if _context = CM_KiwiRailCheckInWSDef::messagePassword.name then
		self.messagePassword := _str;
	else
		inheritMethod(_str, _context);
	endif;

epilog

end;</source>
