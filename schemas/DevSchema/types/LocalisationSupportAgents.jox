<Class name="LocalisationSupportAgents" id="86e57b47-b422-4f7c-99d1-e30f624fd99d">
    <superclass name="Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <subschemaFinal/>
    <abstract/>
    <text>


RBarr  22/6/2006

Utility methods for migration of various entities required for localisation.
See individual method text for details.</text>
    <DbClassMap file="dev"/>
    <ImplicitInverseRef name="allGlobalConstants" id="c5933a27-910e-4abb-8bd2-000fc84c5f5d">
        <memberTypeInverse/>
        <type name="ConstantNDict"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="allSchemas" id="b5db8cbf-02b9-4e21-812b-3550f9ad54d0">
        <kind>parent</kind>
        <type name="LSschemaByName"/>
        <Inverse name="LSschema::myAgent"/>
