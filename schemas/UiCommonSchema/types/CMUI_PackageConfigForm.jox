    <JadeMethod name="doBaseFormSave" id="f27bcfa6-bdfd-44f9-b5b8-c5e59bf32df4">
        <updating/>
        <source>doBaseFormSave() updating, protected;

// Created by cnwdvb1 on 26 June 2006

vars

	package 	: CM_Package;
	isCreate	: Boolean;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin
	inheritMethod();
	
	if self.myProxyObject = null then
		if not self.isEdit then
			self.createProxyObject();
			if self.myProxyObject = null then
				app.msgBox("Please select a package type before continuing.","Save", MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
		else
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'No proxy', null, null);
			return;
		endif;
	endif;

	self.setEmailTemplate();
	
	if self.packageType = PackageSailing then
		self.setProxyForSailing();
	elseif self.packageType = PackageReports then
		self.setProxyForReports();
	elseif self.packageType = PackageInvoicePost then
		self.setProxyForInvoice();
	elseif self.packageType = PackageVVR then		// 1/3/18 MAP TFS37340
		self.setProxyForVVR();
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if not self.isEdit then
			app.myTrxCA.trxCreatePackage(self.myTerminal, self.myProxyObject, package, app.myPassport);
		else
			app.myTrxUA.trxUpdatePackage(self.myProxyObject, self.myProxyAutoTask, self.myProxyAutoSchedule, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			theResult := app.showErrorWarningDialog('Auto Schedule', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChkBaplie" id="5ca0a4c4-0b94-4f87-a28a-e915a934974e">
        <source>doChkBaplie() protected;

// Created by cnwdvb1 on 21 June 2006
// 22/03/2012	cnwcs5	CCMS POL 2144 / par 29312 - Extract BAPLIE by Operator
