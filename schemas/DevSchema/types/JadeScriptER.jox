		write invoiceLine.quantity;
		write invoiceLine.totalAmount/invoiceLine.quantity;
		//write invoiceLine.getRate;
		write invoiceLine.taxValue;
		write invoiceLine.invoiceLineDesc.unitNarration;
	endforeach;
	
	
	delete transientInvoice;
	
	
	
epilog

	delete dynaDict;
	delete iter;
end;</source>
