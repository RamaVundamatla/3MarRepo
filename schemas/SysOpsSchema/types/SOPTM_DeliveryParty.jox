        <source>clearCurrentAddress() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;

	theForm.chkDefultAddess.value    := false;
	theForm.cmbAddrCountry.listIndex := -1;
	theForm.txtAddrCode.text         := null;
	theForm.txtAddrDescription.text  := null;
