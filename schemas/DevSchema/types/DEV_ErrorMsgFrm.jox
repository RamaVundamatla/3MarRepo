    </JadeMethod>
    <JadeMethod name="switchViewMode" id="dc7da80c-d99e-4b6a-b8f5-d05a8ce175f3">
        <updating/>
        <source>switchViewMode() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2004 by cnwrs2
//
// Purpose:     Hides/shows the columns that are not associated with the license dtls
//				which enables to see more easily
// ---------------------------------------------------------------------------
vars
	tmpBoolean	: Boolean;
	idx,
	numCols		: Integer;
begin
	if self.currentMode &lt;&gt; Mode_Permissions then
		app.msgBox('Invalid mode for switchViewMode', 'Error', 0);
		return;
	endif;
	
	if self.viewMode = self.View_Normal then
		self.viewMode := self.View_LicenseDtls;
		self.mnuLicenseColsView.caption := 'License Cols View';
		tmpBoolean := true;
	else
		self.viewMode := self.View_Normal;
		self.mnuLicenseColsView.caption := 'Normal View';
		tmpBoolean := false;
	endif;

//	self.tblData.accessColumn(1).visible := tmpBoolean;
	self.tblData.accessColumn(2).visible := tmpBoolean;
//	self.tblData.accessColumn(3).visible := tmpBoolean;
	self.tblData.accessColumn(4).visible := tmpBoolean;
	self.tblData.accessColumn(5).visible := tmpBoolean;
	self.tblData.accessColumn(6).visible := tmpBoolean;
	self.tblData.accessColumn(7).visible := tmpBoolean;
	self.tblData.accessColumn(8).visible := tmpBoolean;
	self.tblData.accessColumn(9).visible := tmpBoolean;
	self.tblData.accessColumn(10).visible := tmpBoolean;
	
	// make visible all additional columns that the
	// user may have hidden
	numCols := self.tblData.columns;
	foreach idx in 11 to numCols do
		self.tblData.accessColumn(idx).visible := true;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="fc0b1ed3-a9bf-473a-a9b5-000a8c719408">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars
	currentRow, currentColumn, row : Integer;

begin
	currentRow := tblData.row;
	currentColumn := tblData.column;
	
	if (eventType = Object_Update_Event or eventType = Object_Create_Event) and
			theObject.GlobalConstant.getPropertyValue("category").ConstantCategory.name = "Exceptions" then
		self.populateTableFromConstants();
	elseif eventType = Object_Delete_Event then
/*		tblErrorMsgs.column := 1;
		foreach row in 2 to tblErrorMsgs.rows do
			tblErrorMsgs.row := row;
			write tblErrorMsgs.itemObject.String &amp; tblErrorMsgs.row.String &amp; tblErrorMsgs.column.String;
			if tblErrorMsgs.itemObject = theObject then
*/				populateTableFromConstants;
				tblData.row := 4;


/*				break;
			endif;
		endforeach;	
*/	endif;
	
	tblData.row := currentRow;
	tblData.column := currentColumn;
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="8e8bc7e5-1644-47f5-93c4-bc710234a618">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;

vars
	sortType,
	tmpCol	: Integer;

begin

	if tblData.row &lt;&gt; 1 then	//or tblErrorMsgs.column = 3 then
		return;
	endif;

	tmpCol := tblData.column;
	if tmpCol = 2 then
		sortType := Table.SortType_Numeric;
	else
		sortType := Table.SortType_Alpha;
	endif;

	if tblData.sortColumn[1] = tmpCol then
		tblData.sortAsc[1] := (not tblData.sortAsc[1]);
	else
		tblData.sortAsc[1] := true;
	endif;
	tblData.sortColumn[1] := tmpCol;
	tblData.sortType[1] := sortType;

	tblData.resort;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
