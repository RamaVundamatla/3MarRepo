    <JadeMethod name="myTILCType" id="8c68a17f-4cf0-48aa-8f1a-e09629d4841a">
        <methodInvocation>mapping</methodInvocation>
        <source>myTILCType(_set : Boolean; _value : CM_TILCType io) mapping;
/*
Date		Who		Reason
06 Dec 2012	cnwcs5	Initial creation - par 30852
*/
vars
	type	:CM_TILCType;
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// new trailer type is null
		self.myTILCType = _value then	// not changing trailer type
		return;
	endif;
	
	_value.updateForNonInversedReference;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_TILCType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6231ab59-085a-4bb8-89f0-5abed4a9e74a">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2009	cnwjk3	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
*/

vars
	pxyGTE : CMGTE_TILC;
	completedOK		: Boolean;
begin
	pxyGTE := inheritMethod();
	pxyGTE.myTILCType := self.myTILCType;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGTE;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGTE;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="407f6aa6-9fd8-4551-b8ec-298ed7ee7249">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_TILC; _realVVR : CM_VehicleVisitRecord input) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realGTEGen : CMGTE_Entity;
begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	self.myTILCType := _pxyGTEEntity.myTILCType;
	
	if self.myParent = null then	// 24/03/2010 cnwar2 #21215 - if subitem, tranNumber set later (see CMGTE_Entity :: setForCreateIfSubItem)
		self.tranNumber := self.myVehicleVisitRecord.visitNumber; // removes suffix
	endif;
		
end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_TILC"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="58a31873-6d7d-4cbd-8ab5-3c48240bfd6d">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_TILC; _realVVR : CM_VehicleVisitRecord ) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realSub, pxySub : CMGTE_Entity;
begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	
	self.myTILCType := _pxyGTEEntity.myTILCType;
	
	realSub := self.includesSubItemByClass(CMGTE_Generator);
	pxySub := _pxyGTEEntity.includesSubItemByClass(CMGTE_Generator);
	
	// this is were there was a generator and now there is not.
	if realSub &lt;&gt; null and pxySub = null then
		delete realSub;
	else // is handled in TRX
	endif;

epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_TILC"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromController" id="7a4dc7b9-8ffc-4ea7-99e4-a1ac24bb8dce">
        <updating/>
        <source>setPXYFromController(_flexi : CMIF_FlexiGateController) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_flexi);

	self.cargoType 		:= _flexi.cargoType;
	self.id 			:= _flexi.id;
	self.operatorCode 	:= _flexi.operatorCode;
	
	//epr par 21011 7/10/09 - match with what happens when released
	if _flexi.myChassisType &lt;&gt; null then
		self.cargoType 	:= _flexi.myChassisType.myCargoType.id;
		self.myTILCType := _flexi.myChassisType;
	endif;
epilog

end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
    <JadeMethod name="setParamsOnJRWGateTicket1" id="d74af851-1e18-49f8-99c0-9dc6d12c18e4">
        <updating/>
        <source>setParamsOnJRWGateTicket1(_jrwReport	: JadeReportWriterReport) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	chasID,  chasLen, chasISO : String;

begin
	chasID := self.id;
	chasLen := self.getLength().String;
	chasISO := self.getISO();
	
	_jrwReport.setParameter('chassisID', chasID);
	_jrwReport.setParameter('chassisLen', chasLen);
	_jrwReport.setParameter('chassisISO', chasISO);
		

epilog

end;</source>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTI" id="af71865f-8ea1-4362-8cb3-2d56ce4f7f07">
        <updating/>
        <source>setPxyFromTI(_ti: CM_TILC) updating;
/*
Date		Who		Reason
01 March 2010	cnwjk3	Initial creation

*/
vars

begin
	inheritMethod(_ti);
	
	self.myTILCType := _ti.myTILCType;
	self.availabilityGrade 		:= _ti.availabilityGrade; //epr par32621 18/10/13
	
	
	
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="setPxyTiFromRealGTE" id="662a52de-1ffe-4cc7-993b-265e40c9f0cc">
        <updating/>
        <source>setPxyTiFromRealGTE(_pxyTI: CM_TrackedItem input; _passport: CM_Passport input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod(_pxyTI, _passport);
	_pxyTI.setPxyFromCMGTE_TILC(self, _passport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="05b0e160-1488-4663-9909-95962a1d48a0">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input; _pxyTI : CM_TrackedItem io): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti,
	pxyTI 		: CM_TrackedItem;
	theCargoType: CM_CargoType;
	tiUpdCntrl	: CMIF_TIUpdateController; 
	subItemError : Boolean;
begin
	inheritMethod(_passport, _pxyTI);	// cnwjk3 PAR 22754 11/03/2010
	
	/* cnwjk3 PAR 22754 11/03/2010
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', 'Cargo Type', null);
		return false;
	endif;

	pxyTI := self.myTerminal.createTI(theCargoType, true); // Use MASTER TI

	//Should be in validation agent methinks
	//ti := app.getMyTerminal().allOnsiteTIsByIdCargoType[self.id, self.cargoType];
	ti := self.myTerminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];
	if ti &lt;&gt; null then
		app.raiseCMException1(ERR_ALREADY_ONSITE, self.id,  null, null);
		return _passport.noErrors;
	endif;

	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, null);
	//pxyTI.setPxyFromCMGTE_TILC(self, _passport);
	pxyTI.setPxyFromCMGTE_Receival(self, _passport);
	pxyTI.validateTrackedItem(tiUpdCntrl, _passport);	
	
	_pxyTI := pxyTI; // return this.  Caller must destroy!
	*/
epilog
	//delete pxyTI; caller will delete
	delete tiUpdCntrl;
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
