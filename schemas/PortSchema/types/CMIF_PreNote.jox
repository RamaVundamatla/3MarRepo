    <JadeMethod name="testYardAllocations" id="91191486-6eaf-4b4d-96db-bc01961eb930">
        <source>testYardAllocations();
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwmo1

Purpose:	ccms 1035

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpLocn : CM_LocationsController;
	ti		: CM_TrackedItem;	
	locnStr	: String;
begin
	
	// PAR 19412 Need to use real TI so that if autoplan fails, the TI will get attached to alert
	ti  := self.myPersistentTrackedItem; 
	
	//PAR 19412 If AutoPlan fails then create an alert so it appeasr if Sat View FTA list
	tmpLocn := app.autoPlanTiYATest(self.myTerminal, null, ti, true);  

	if tmpLocn = null then
		self.sendNotificationEmail(ti);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="df50f931-3c7e-4060-8c8b-5f675aa7c694">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;
// 07/03/2012	cnwcs5	par 29158 - EDI cutoffs
// 08/12/2014   cnwdb2 PAR 35364
// 22/03/2016   cnwma1 PAR #37698 GUQ Error 14079
// 14/06/2016	cnwdap1	TFS #2122 prevent creation of on-ship Tranship items through useridefined EDI formats
// 06/06/2017	cnwdap1	TFS 4434 SNO COPARN Prenotes and VGM Updates
// 28/02/2018	jlgmd1	TFS 37320 CIG - Length in the ID Fields (Bumped validation to 30 to match field length)
// 28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
// 04/05/2022	jlizm1	TFS 53083 GPHA revceival/release of tranship cargo
//21/07/2022 	navds20 TFS  Bug 54000: EUP - Unable to create same Cargo Id with different Cargo Group Ids
// 02/05/2023	jlizm1	TFS 55453 Cargo uniqueness by subtype
//23/06/2023	navpw1	TFS: 57812 (58798) - Added warning for setting itemised when the numberOfItems of break bulk is greater than 1
// 14/12/2023	navcs2	ChangeRequest 57539: CUX | Multiple Prenotes Unique by Booking Reference
//14/05/2024	naviv1	Bug 64119 - CUX | POST/cargo API - Error Description
vars
	locn			: CM_LocationsController;
	foundHeight, matches		: Integer; // 21/07/2022 navds20 TFS  Bug 54000
	voyage			: CM_Voyage;
	ti,otherTI		: CM_TrackedItem; // 21/07/2022 navds20 TFS  Bug 54000
	locationString	: String;
	terminal		: CM_Terminal;	// par 29158
	carrier			: CM_Carrier;
	operator		: CM_Operator;
	dac				: CM_DataAccessController;
	wagon			: CM_Wagon;
	train			: CM_Train;
	operatorStr		: String;
begin
	inheritMethod(_passport);
	
	terminal 	:= self.myTerminal;				// par 29158
	
	self.checkEDIVoyageCutoff (self.myUserObject);	// par 29158
	
	if self.imExStatus = null then		// 26/03/2009 cnwar2 #19219
		app.raiseCMException(Input_required_field_IMEXStat, 'imExStatus', self.myUserObject); // cnwdb2	PAR 35364		
		return _passport.noErrors();
	endif;
	
	// ccms 1031 June 2006 warn about prenote on site or already notified tis
	if (not _passport.useTIDictDeferUpdate) then		// cnwdad1 23/02/2009 - PAR #18927.
		ti := terminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];
	endif;
/*	if ti &lt;&gt; null then
		if ti.myCargoType.allowDuplicates then
			if self.isChild then
				ti:=null;
			endif;
			
		endif;
		
		
	endif;*/
	
	//if ti &lt;&gt; null then									// TFS 4434
	if ti &lt;&gt; null and not self.updateVGMOnly then 			// TFS 4434
		locationString:= "Onsite at " &amp; ti.locationId;
		app.raiseCMWarning2(ERR_PRENOTE_ID_EXISTS, self.id, locationString,"", null, ti);
	endif;
	
	if (not _passport.useTIDictDeferUpdate) then		// cnwdad1 23/02/2009 - PAR #18927.
		ti := terminal.allNotifiedTIsByIdCargoType[self.id, self.cargoType];
	endif;

	/**
	14/12/2023	navcs2	ChangeRequest 57539 start
	**/
	if self.myTerminal.getConfig( PrenoteUniqBooking ).Boolean then		 
		if not self.myTerminal.noOnsiteDuplicate(self, self.cargoType, self.operatorCode, self.bookingReference, false, false) then
			app.raiseCMException2(Preno_with_same_booki_ref, self.id, locationString,"", null);
		elseif ti &lt;&gt; null and self.id = ti.id then
			app.raiseCMWarning2(ERR_PRENOTE_ID_EXISTS, self.id, locationString,"", null,null);		
		else
			// No error, do nothing
		endif;
	/**
	14/12/2023	navcs2	ChangeRequest 57539 End
	**/
	else
		//if ti &lt;&gt; null then									// TFS 4434
		if ti &lt;&gt; null and not self.updateVGMOnly then 			// TFS 4434
			if ti.locationId &lt;&gt; null then
				locationString:= "Notified at " &amp; ti.locationId;
			else
				locationString:= "Notified";
			endif;
			if (self.myTerminal.getConfig( AllowDuplicatePreNotes ).Boolean	//19 Sep 2016	NDL	TFS 2650 / 2001
			and ti.myCargoType.allowDuplicates)	//19 Sep 2016	NDL	TFS 2650 / 2001
			then	//19 Sep 2016	NDL	TFS 2650 / 2001
				app.raiseCMWarning2(ERR_PRENOTE_ID_EXISTS, self.id, locationString,"", null,null);	//19 Sep 2016	NDL	TFS 2650 / 2001
			else
				app.raiseCMException2(ERR_PRENOTE_ID_EXISTS, self.id, locationString,"", null); //cnwrd1 par 20481, 17.9.09 changed to exception from warning.
			endif;	//19 Sep 2016	NDL	TFS 2650 / 2001
		endif;
	endif;
	
	self.checkTIsExistOnship(_passport); //epr 17/7/06 ccms 1449 PAR 22396
	
	if self.myProxyTrackedItem &lt;&gt; null then
		self.myProxyTrackedItem.noPINforHazardousODProcess(true, true, null, _passport);	//ccms 1676. Par18864 Feb 2008
	endif;

	voyage := terminal.lookupVoyage(voyageCode, null, false);		
	//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
	if voyage &lt;&gt; null and voyage.hasDeparted  and  terminal.getConfig(EdiAddVoyageDepartError).Boolean then
		app.raiseCMException1(Voyage_departed,voyageCode,"Voyage Code", self);
	endif;
	
	transportMode := transportMode.trimBlanks;
	//epr TFS 2308 11/7/16
	if not self.isChild then
		if transportMode =  TI_TRANSMODE_SHIP_STR then
			//For ship items check that a valid stowage location was entered
			if stowageLocation &lt;&gt; null and stowageLocation.pos(voyageCode,1) = 1 then	//30 Jul 2013	NDL	Par 31702
				terminal.findLocationFromString(stowageLocation.trimBlanks, false, locn, foundHeight);
			else
				terminal.findLocationFromString(voyageCode.trimBlanks &amp; " " &amp; stowageLocation.trimBlanks, false, locn, foundHeight);
			endif;
			
			if locn = null or not locn.isKindOf(CM_VoyageController) then			//cnwas3 createnewcargoform
				
		
				if voyage &lt;&gt; null and voyage.myROROStructure &lt;&gt; null and voyage.myROROStructure.allDecksByCode[stowageLocation.trimBlanks] &lt;&gt; null then
				else
					app.raiseCMException1(ERR_INVALID_LOCN, voyageCode.trimBlanks &amp; " " &amp; stowageLocation.trimBlanks, "", null);
				endif;
			endif;
			
			if self.myProxyTrackedItem &lt;&gt; null then
				voyage := self.myProxyTrackedItem.myVoyage;
				//start 21/07/2022 navds20 TFS  Bug 54000
				/*if voyage &lt;&gt; null then
					if not _passport.useTIDictDeferUpdate then		// cnwdad1 23/02/2009 - PAR #18927.
						//02 Aug 2013	NDL	Par 32154
						voyage.validateNoCargoMatchingPreNote( self.myProxyTrackedItem, locn );
					endif;
					if locn &lt;&gt; null and locn.isKindOf(CM_VoyageController) then	//01 Feb 2011	NDL	Par 25543
						locn.CM_VoyageController.has20FTInBackend(self.myProxyTrackedItem);		// 12/07/2010 cnwmh5 #24827
					endif;
				endif;*/
				//end 21/07/2022 navds20 TFS  Bug 54000
				
				//start 21/07/2022 navds20 TFS  Bug 54000
				if locn &lt;&gt; null
				and locn.isKindOf(CM_VoyageController) then
					ti := self.myProxyTrackedItem;
					if not _passport.useTIDictDeferUpdate then
						otherTI := locn.searchForOnsiteTI(ti.id,matches,ti.cargoType,ti.getMyCargoGroupId(),ti.getCargoSubTypeCode(), ti.operatorCode); //03.Nov.2023 navsp TFS 61067
						if otherTI &lt;&gt; null then
							app.raiseCMException2(Onship_already_exists, ti.id, voyage.code, null, null);
						endif;
					endif;
					locn.CM_VoyageController.has20FTInBackend(self.myProxyTrackedItem);
				endif;
			endif;
			//end 21/07/2022 navds20 TFS  Bug 54000
			// cannot create a Tranship prenote on ship											// TFS #2122
			if self.imExStatus.code = TI_IMEX_STATUS_TRANSHIP then								// TFS #2122
				if not app.myRoot.allowTranshipInterModal then									// TFS 53083
					app.raiseCMException(Cannot_create_EDI_Tranship, ETRow_ImExStatus, null);	// TFS #2122
				endif;
			endif;																				// TFS #2122
			
		elseif transportMode = TI_TRANSMODE_RAIL_STR then
			terminal.validateWagonId(self.wagon, self.myWagonClass, self.myProxyTrackedItem, self.myUserObject); // par 29158
			
		elseif transportMode = TI_TRANSMODE_ROAD_STR then
		
		elseif transportMode = TI_TRANSMODE_NULL_STR then	//06 Dec 2013	NDL	Par 32854
		
		else
	
			app.raiseCMException1(Input_field_not_valid,  transportMode ,  "", null); //cnwdb2 PAR 35364
	
					
		endif;
	endif;
	
// cnwdad1 11/05/2009 - CCMS 1735.
	if app.isSubTerminalsOn(terminal) then
		if self.subTerminalCode &lt;&gt; null and terminal &lt;&gt; null then
			if terminal.allSubTerminals[self.subTerminalCode] = null then
				app.raiseCMException1(	INVALID_FIELD,
										app.getString(SubTerminal_GC) &amp; " (" &amp; self.subTerminalCode &amp; ")",
										app.getString(SubTerminal_GC),
										null);
			endif;
		endif;
	endif;
	// CCMS 1071 Attach Prenote Attachments to the parent
	if self.myMasterObject &lt;&gt; null then
		self.myMasterObject.getMyProxyTrackedItem.attachChild(self.getMyProxyTrackedItem, _passport);
	endif;
	
	if self.bookingReference.length &gt; 30 then														// 22/03/2016 cnwma1 PAR #37698 
		app.raiseCMException2( ERR_STRING_TO_LONG, app.getErrorString(BookingRef), '30',null ,null);
	endif;
	operator := app.myRoot.allOperators[self.operatorCode];		// 20/9/17 MAP TFS2749
	if operator &lt;&gt; null then
		operatorStr := operator.description;
	endif;
	if self.carrier &lt;&gt; null then
		carrier := app.myRoot.allCarriers[self.carrier];
		if carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, false) then
			app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
		endif;
	endif;

	if self.wagon &lt;&gt; null and self.transportMode = TI_TRANSMODE_RAIL_STR then
		wagon := terminal.getCurrentWagonByID(self.wagon);
		if wagon &lt;&gt; null then
			train := wagon.myTrainInwards;
			if train &lt;&gt; null and train.myCarrier &lt;&gt; null then
				carrier := train.myCarrier;
				if not carrier.canCarrierAccessForOperator(operator, dac, false) then
					app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
				endif;
			endif;
		endif;
	endif;
	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//	carrierObj := app.myRoot.allCarriers[self.carrier];
//	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType];
//	if carrierObj &lt;&gt; null and
//	   operator &lt;&gt; null and
//	   cargoTypeObj &lt;&gt; null and
//	   not operator.canOpAccessCarrierForCargoType(carrierObj, self.cargoType) then
//		app.raiseCMException3(Opera_denie_carri_acces_cargo_, operator.description, carrierObj.description, cargoTypeObj.description, null, null);
//	endif;
	
	self.validateOneStopHazards(); //01 Feb 2018	NDL	TFS 36932
	//epr tfs 38518 24/5/18
	if self.action = CM_EDITrackedItem.EDI_ACTION_ADD and app.isWebApp then
		self.canUserAccessSelf();
	endif;
	
	// ### TFS 57812 (58798) 22Jun2023 NAVPW1
	if self.itemised and self.numberOfItems &gt; 1 then
		app.raiseCMWarning(Itemi_been_track_item_quant_gr, null, null, null);
	endif;
	// ### TFS 57812 (58798) 22Jun2023 NAVPW1
	
epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="968a15ba-c8e5-40fb-b1df-7a5bd9f744f2">
        <updating/>
        <source>validateForDelete(_passport: CM_Passport input): Boolean updating;
/*
Date		Who		Reason
07/03/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars

begin
	inheritMethod(_passport);

	self.checkEDIVoyageCutoff (self.myUserObject);
epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForProcess" id="fbbda485-8447-4771-b77c-d7b3a5f0c6a3">
        <updating/>
        <source>validateForProcess(_passport: CM_Passport input): Boolean updating;
/*

Purpose:			Allow modify for  Prenote EDI PAR 37172

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2015	cnwgb1	Initial creation

*/

vars

begin
	// 21/02/2014 cnwar2 #33202
	if not (self.action.isBlank() or
			self.action = CM_EDITrackedItem.EDI_ACTION_ADD or
			self.action = CM_EDITrackedItem.EDI_ACTION_UPDATE or
			self.action = CM_EDITrackedItem.EDI_ACTION_MODIFY or
			self.action = CM_EDITrackedItem.EDI_ACTION_DELETE) then
		app.raiseCMException(InvalidEDIAction, null, self.myUserObject);
		return false;
	endif;

	if self.action = CM_EDITrackedItem.EDI_ACTION_ADD then
		return self.validateForCreate(_passport);
	elseif self.action = CM_EDITrackedItem.EDI_ACTION_UPDATE or self.action = CM_EDITrackedItem.EDI_ACTION_MODIFY then
		return self.validateForUpdate(_passport);
	elseif self.action = CM_EDITrackedItem.EDI_ACTION_DELETE then
		return self.validateForDelete(_passport);
	endif;
	return true;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="accc5fbb-cc82-4d93-ba71-8f3ecd3819ec">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/03/2012	cnwcs5		par 29158 - EDI cutoffs
// 17/03/2017	cnwrs1		TFS3778/TFS3801 duplicate cargo on site is allowed if cargo type has duplicates allowed
// 06/06/2017	cnwdap1		TFS 4434 SNO COPARN Prenotes and VGM Updates
// 17/04/2018	jlgrh7 		TFS 38055 MSL - coparn deletes stop fields
// 28/08/2018	jlgrs1		TFS 39619 PEN - Approved Carriers For Operator 
// 29/08/2018	JLGNS1		Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
// 24/03/2020	jlgdap1		TFS 48816 MSL VGM in COPARN
// 14/12/2023	navcs2		ChangeRequest 57539: CUX | Multiple Prenotes Unique by Booking Reference
// ---------------------------------------------------------------------------
vars
	updateMode		: Integer;
	tiUpdCntrl		: CMIF_TIUpdateController;
	theCargoType	: CM_CargoType;
	subItemError	: Boolean;
	realTi, ti		: CM_TrackedItem;
	locationString	: String;
	operator		: CM_Operator;
	dac				: CM_DataAccessController;
	wagonObj		: CM_Wagon;
	train			: CM_Train;
	operatorStr		: String;
	isUpdateTI		: Boolean;										//+TFS38055
	carrierObj		: CM_Carrier;
begin
	
	inheritMethod(_passport);
	isUpdateTI := true;																//+TFS38055										
	self.checkEDIVoyageCutoff (self.myUserObject);	// par 29158
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if theCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', self.myUserObject);
		app.raiseCMException(Input_required_field_cargoType, 'cargoType', self.myUserObject); // cnwdb2	PAR 35364
	endif;
	
	if self.imExStatus = null then		// 26/03/2009 cnwar2 #19219
	//	app.raiseCMException1(REQUIRED_FIELD, 'IMEX Status', 'imExStatus', self.myUserObject);
		app.raiseCMException(Input_required_field_ImexStats, 'imExStatus', self.myUserObject); // cnwdb2	PAR 35364
	endif;

// need to be able have user indicate if container was washed or pre-tripped prior to coming on-site
// if checked then set the cleaned / pre-tripped date-time to today (ie time actually booked onsite).

	if self.myProxyTrackedItem &lt;&gt; null then	
		if self.cargoType &lt;&gt; self.myProxyTrackedItem.cargoType then
			// need to delete/clear and recreate as of a different type
			if self.myProxyTrackedItem = self.myOriginalProxyTI then
				self.myProxyTrackedItem := null;
			else
				self.eraseProxyTrackedItem();
			endif;
		endif;
		
	endif;
	
	if self.myProxyTrackedItem = null then
		if self.myOriginalProxyTI &lt;&gt; null and self.cargoType = self.myOriginalProxyTI.cargoType then
			// can use original as they are the same class
			self.myProxyTrackedItem := self.myOriginalProxyTI;
			realTi := app.myProxyManager.getRealObject(self.myProxyTrackedItem).CM_TrackedItem;
			// // Par 10591 check to make sure prenote hasn't already been released due to faulty display issue
			if realTi &lt;&gt; null and 
			   realTi.state = TI_STATE_NORMAL and
			   not theCargoType.allowDuplicates and
			   not self.updateVGMOnly then								// TFS 4434
				//app.raiseCMException1(Full_Replacement_Message,realTi.id &amp; ' is already on site', null,  null);		//- cnwmd1, Par 20524
				app.raiseCMException1(Already_site, realTi.id , null,  null);
			endif;
		else
			self.myProxyTrackedItem := self.myTerminal.createTI(theCargoType, true);
		endif;
	endif;
	
	if self.updateVGMOnly then											// TFS 4434
		if realTi &lt;&gt; null and realTi.state = TI_STATE_NORMAL and 				// TFS 48816
		not theCargoType.allowDuplicates then									// TFS 48816
			return _passport.noErrors();								// TFS 4434
		endif;																	// TFS 48816
	endif;																// TFS 4434
	
	// set the values on the transient tracked item

	//self.setTrackedItemData(self.myProxyTrackedItem, _passport);									//-TFS38055
	self.setTrackedItemData(isUpdateTI, self.myProxyTrackedItem, _passport);			//+TFS38055

	if self.myIntFaceInOutCommon &lt;&gt; null then
		self.myIntFaceInOutCommon.setTrackedItemData(self.myProxyTrackedItem);
	endif;

	subItemError := validateForSubItemDuplicates();

	if (not subItemError) then
		self.validateSubItems(_passport);
	endif;

	//proxy.setTotalQVW;	//Count our children now				//-cnwml2 MSL CCMS 1017
	
	// clean out the discrepancies as the validation will re-create if necessary
	self.myProxyTrackedItem.clearAllDiscrepancies();

	if realTi= null then	//ccms 1676. Feb 2009
		realTi := app.myProxyManager.getRealObject(self.myProxyTrackedItem).CM_TrackedItem;
	endif;
	
	/**
	14/12/2023	navcs2	ChangeRequest 57539 start
	**/
	if self.myTerminal.getConfig( PrenoteUniqBooking ).Boolean then		 
		if not self.myTerminal.noOnsiteDuplicate(self, self.cargoType, self.operatorCode, self.bookingReference, false, false) then
			app.raiseCMException2(Preno_with_same_booki_ref, self.id, locationString,"", null);
		elseif realTi &lt;&gt; null and self.id = realTi.id then
			app.raiseCMWarning2(ERR_PRENOTE_ID_EXISTS, self.id, locationString,"", null,null);
		else
			// No error, do nothing
		endif;
	/**
	14/12/2023	navcs2	ChangeRequest 57539 End
	**/
	elseif realTi &lt;&gt; null then	// PIN is stored on real, not on proxy
		self.myProxyTrackedItem.noPINforHazardousODProcess(true, true, realTi.myPinNo, _passport);	//ccms 1676. Feb 2008
		
		// 13/07/2010 cnwar2 #24865 - if ID change, check not duplicate
		if realTi.id &lt;&gt; self.myProxyTrackedItem.id then
			ti := self.myTerminal.allOnsiteTIsByIdCargoType[self.myProxyTrackedItem.id, self.myProxyTrackedItem.cargoType];
			if ti &lt;&gt; null then
				locationString:= "Onsite at " &amp; ti.locationId;
				app.raiseCMWarning2(ERR_PRENOTE_ID_EXISTS, ti.id, locationString,"", null, ti);
			endif;
			
			ti := self.myTerminal.allNotifiedTIsByIdCargoType[self.myProxyTrackedItem.id, self.myProxyTrackedItem.cargoType];
			if ti &lt;&gt; null then
				locationString:= "Notified at " &amp; ti.locationId;
				app.raiseCMException2(ERR_PRENOTE_ID_EXISTS, ti.id, locationString,"", null);
			endif;
		endif;
	endif;
	
	// 22991 set validation mode for on-ship BOL items
	updateMode := TI_UPDMODE_RECEIPT;
	if self.isBOLItem() then // PAR 28400 if self.isKindOf(CMIF_OnshipCargo) then
		updateMode := TI_UPDMODE_BOLITEM;
	endif;
	tiUpdCntrl := app.createTIUpdateControl(updateMode, null, self.myUserObject);
	tiUpdCntrl.setInterfaceAttributes(self); //epr TFS 2744 21/2/17
	myProxyTrackedItem.validateTrackedItem(tiUpdCntrl, _passport);	//Sub items are recursively validated here
	//app.msgBox("Trans Mode " &amp; transportMode, "box",0);

	//Do transportation mode specific checks...
	if transportMode.trimBlanks =  TI_TRANSMODE_SHIP_STR then
		if not self.isKindOf(CMIF_OnshipCargo) then
		//Can't edit a ship prenote !!! except for General Cargo on-ship CCMS 1071
			app.raiseCMException2(VB_PRENOTE_ON_SHIP, myProxyTrackedItem.id, myProxyTrackedItem.voyageCode, "", null);		
		endif;
	elseif transportMode.trimBlanks = TI_TRANSMODE_RAIL_STR then
		//Must be a valid wagon
		self.myTerminal.validateWagonId(self.wagon, self.myWagonClass, self.myProxyTrackedItem, self.myUserObject);
	elseif transportMode = TI_TRANSMODE_ROAD_STR then
	
	else
		//Must be one of the above...
		app.raiseCMException2(ERR_INVALID_VALUE, "the transport mode (" &amp; transportMode &amp; ")","","", null);
	endif;	
	
	if self.wagon &lt;&gt; null and self.transportMode = TI_TRANSMODE_RAIL_STR and self.myTerminal &lt;&gt; null then
		wagonObj := self.myTerminal.getCurrentWagonByID(self.wagon);
		if wagonObj &lt;&gt; null then
			train := wagonObj.myTrainInwards;
			if train &lt;&gt; null and train.myCarrier &lt;&gt; null then
				carrierObj := train.myCarrier;
				if not carrierObj.canCarrierAccessForOperator(operator, dac, false) then
					app.raiseCMException2(Carri_does_not_have_acces_oper, carrierObj.description, operatorStr, null, null);
				endif;
			endif;
		endif;
	endif;
		
	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//	carrierObj := app.myRoot.allCarriers[self.carrier];
//	if carrierObj &lt;&gt; null and
//	   operator &lt;&gt; null and
//	   theCargoType &lt;&gt; null and
//	   not operator.canOpAccessCarrierForCargoType(carrierObj, theCargoType.id) then
//		app.raiseCMException3(Opera_denie_carri_acces_cargo_, operator.description, carrierObj.description, theCargoType.description, null, null);
//	endif;
	
	self.validateOneStopHazards(); //01 Feb 2018	NDL	TFS 36932

epilog
	delete tiUpdCntrl;
	return _passport.noErrors();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateOneStopHazards" id="68d509e2-0acf-4e98-8823-cb7b84da064a">
        <source>validateOneStopHazards();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2018	jlgndl1	Initial creation	TFS 36932

*/

vars

	hazard 			: CM_Hazard;
	tiHazard 		: CM_TIHazard;

begin

	if self.isOneStopPrenote() then
		foreach hazard in self.allTIHazards do
			tiHazard := hazard.CM_TIHazard;
			if tiHazard.getUndgCodesAsString(false).trimBlanks = null then	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
				app.raiseCMException(Hazard_must_have_undg_code, null, null);
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
