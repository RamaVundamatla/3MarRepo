    <JadeMethod name="convertToNewStructure_Imex" id="b4f59a4f-0740-4704-a383-9088de9998a8">
        <updating/>
        <source>convertToNewStructure_Imex(_controller:CnEcReleaseController;_terminal:CM_Terminal;_phase:Integer;_upgrader:PortSchema_7_2_0) updating;
/*
------------------------------------------------------------------------
Created:			09 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
constants
	EX_MASK = #10;
	EMPTY_MASK = #04;
	IMP_MASK = #20;
	STO_MASK = #40;
	TRANSIT_MASK = #1400;
	DLR_MASK = #1100;
vars
	mask : Integer;
begin
	mask := self.imExStatus.bitAnd(TI_IMEX_STATUS_MASK);
	if mask = IMP_MASK then
		//OK, import, determine if we HAVE an importStatus already built
		self.imExStatus := TI_IMEX_STATUS_IMPORT;
	elseif mask = EX_MASK then
		self.imExStatus := TI_IMEX_STATUS_EXPORT;
	elseif mask = STO_MASK then
		self.imExStatus := TI_IMEX_STATUS_STORAGE;
	elseif mask = TRANSIT_MASK then
		self.imExStatus := TI_IMEX_STATUS_REMAINONBOARD;
	elseif mask = DLR_MASK then
		self.imExStatus := TI_IMEX_STATUS_REMAINONBOARD;
	elseif mask = SOB_MASK then
		self.imExStatus := TI_IMEX_STATUS_REMAINONBOARD;
	endif;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_phase" type="Integer"/>
        <Parameter name="_upgrader" type="PortSchema_7_2_0"/>
    </JadeMethod>
    <JadeMethod name="convertToNewStructure_Transit" id="7475d305-e4b6-4289-9de5-2ce37cd848af">
        <updating/>
        <source>convertToNewStructure_Transit(_controller:CnEcReleaseController;_terminal:CM_Terminal;_phase:Integer;_upgrader:PortSchema_7_2_0) updating, protected;
/*
------------------------------------------------------------------------
Created:			09 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
constants
	DLR_MASK = #1100;

vars
	mask : Integer;
begin
	mask := self.imExStatus.bitAnd(TI_IMEX_STATUS_MASK);
	if mask = DLR_MASK then
		self.transitStatus := TI_TransitStatusDLR;
	elseif mask = SOB_MASK then
		self.transitStatus := TI_TransitStatusSOB;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_phase" type="Integer"/>
        <Parameter name="_upgrader" type="PortSchema_7_2_0"/>
    </JadeMethod>
    <JadeMethod name="copySnapShotForReporting" id="a167d39a-64e7-4191-851e-0b462c69b6e5">
        <updating/>
        <source>copySnapShotForReporting(_jrwTrans: CM_JRWTransaction input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2018	jlgab1	Initial creation

*/

vars
	tran : CM_TITransaction;
	cmifSnapShot : CMIF_SnapShotReporting;
	tiSnapShot, childTiSnapShot : CM_TISnapShot;

begin
	if _jrwTrans = null then
		return;
	endif;
	
	// TFS 40632
	tran := self;
	if tran.mySnapShot &lt;&gt; null then // all receive and release transactions, plus pack and unpack
		tiSnapShot := tran.mySnapShot.CM_TISnapShot;
		
		create cmifSnapShot transient;
		cmifSnapShot.mySnapShot := tiSnapShot;
		cmifSnapShot.cargoID := tiSnapShot.id;
		cmifSnapShot.parentId := tiSnapShot.id;
		
		if not tiSnapShot.allChildSnapShots.isEmpty() then
			cmifSnapShot.parentChild := "PARENT";
		endif;
		_jrwTrans.allSnapShotReportings.add(cmifSnapShot);
		
		foreach childTiSnapShot in tiSnapShot.allChildSnapShots	discreteLock do
			create cmifSnapShot transient;
			cmifSnapShot.mySnapShot := childTiSnapShot;
			cmifSnapShot.cargoID := childTiSnapShot.id;
			cmifSnapShot.parentChild := "CHILD";
			cmifSnapShot.parentId := tiSnapShot.id;
			
			
			_jrwTrans.allSnapShotReportings.add(cmifSnapShot);

		endforeach;

	endif;

epilog

end;</source>
        <Parameter name="_jrwTrans" type="CM_JRWTransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCAMSAuditTransaction" id="f2e04ca9-e332-4154-9d4c-50b099fff8bb">
        <source>createCAMSAuditTransaction(_auditType :Integer;  _trx :CM_TITransaction; _passport :CM_Passport input);
/*
Date		Who		Reason
17 Dec 2012	cnwcs5	Initial creation - par 30855
*/
vars
	ti		: CM_TrackedItem;
	params	: CMIF_TITransactionController;
	trx		: CM_CAMSAudit;	
	xml		: String;
begin 
	ti := self.myTrackedItem;
	
	if ti = null then 
		return;	// should never happen
	endif;
	
	create params transient;
	
	params.type 	:= TRANS_TYPE_CAMSAUDIT;
	params.noCharge	:= true;
	
	trx	:=	ti.createTransaction(params, _passport).CM_CAMSAudit; 

	if trx = null then
		return;
	endif;
	
	trx.setAuditType (_auditType);
	trx.setMyRelatedTransaction (_trx);
epilog	
	delete params;
end;</source>
        <Parameter name="_auditType" type="Integer"/>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCharge" id="8cd6d962-84f4-4940-82ad-a92fc15743c3">
        <source>createCharge(_passport : CM_Passport);
/*
Date		Who		Reason
19 Dec 2024	navlw1	JIRA-33692: MTN | Terminal Config for Financials Enabled Minor Issues
31 Jan 2025	navlw1 	JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
*/
vars
	co		: CM_Bank;
	term	: CM_Terminal;
	
begin
	// Web got broken by using passport terminal. Getting terminal off transaction.

	term := self.myTerminal;

	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, CM_TITransaction::myTerminal.name &amp; " is null.");
		return;
	endif;

	// Start navlw1 #JIRA-33865 31/01/2025
	if self.noCharge then
		app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		return;
	endif;
	
	if not term.getConfig(FinancialsEnabled).Boolean then
		app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
		
	//jlier1 MTN-19295 6/11/24
	if self.myTrackedItem = null then
		return; //will only be if it was charge for prenote that was deleted - prenotes don't create charges anyway so can return;
	endif;
	
	co := self.myTrackedItem.companyOid;

	//CNWTH2 if TI has no company Oid (valid for Logs - at least) you can't do this,
	//and it is valid for no charge to be made.
	if co = null or app.isUnitTestGarbageCollect then
		return;
	endif;

	co.createChargeCargo(self);
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createEventLocationActivity" id="09e50375-9f80-411e-b768-4cf921f5eab2">
        <source>createEventLocationActivity( _ti : CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ):CMEVT_LocationActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	locationActivity : CMEVT_LocationActivity;
	cargoType : CM_CargoType;
	success : Boolean;

begin

	success := true;

	if _ti = null then
		return null;
	endif;
	
	cargoType := _ti.myCargoType;
	
	if not cargoType.saveLocationActivity then
		return null;
	endif;
	
	if self.isKindOf( CM_BBLocationDiscrepancy ) then
		return null;
	endif;

	if not self.isKindOf( CM_Move )
	and not self.isKindOf( CM_BBDiscrepancy )
	then
		return null;
	endif;
	
	create locationActivity persistent;
	success := locationActivity.setFromTiTransaction( self, _tiTransCntrl );
	
	//A temporary hack to create auditability for the devs use until the new auidt collection on 
	//CM_Object makes it into prod and the proper audits are added to this class.
	if success then
		locationActivity.createTemporaryAuditObject();
		locationActivity.createCharge(null); // ### TFS 51219 31MAY2021 NAVAB1
		
		locationActivity.setMyBalanceForNeedsRecalc(); // ### TFS 51515 NAVAB1
	endif;

epilog

	if not success then
		delete locationActivity;
		locationActivity := null;
	endif;
	
	return locationActivity;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8aa603fa-30f7-48b3-935b-54d67398c73b">
        <updating/>
        <source>delete() updating;
/*
Purpose:		Cleanup Audit Objects		

Date		Who		Reason
07 Jan 2010	conkc1	Initial creation
18 Aug 2017	jlgkpd1	TFS #5725 - clean up previousVersions when a transaction is deleted
28 Sep 2018 jlgdap1	TFS 41153 JMT AppServer crash when deleting tracked item transactions
*/
vars
	
begin
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
	// TFS #5725
	if self.previousVersions &lt;&gt; null then
		self.previousVersions.rebuild();				// TFS 41153
		self.previousVersions.purge();
		delete self.previousVersions;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleted" id="1ae5cf3d-2040-45bb-809f-8101fc92a75f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>deleted(set: Boolean; _value: Boolean io) updating, mapping;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(DeletedFlag);
		else
			flags := flags.getValueWithBitUnset(DeletedFlag);
		endif;
	else
		_value := (flags.bitAnd(DeletedFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="b06722a6-0f6c-4d6b-8031-11a2aecccb69">
        <methodInvocation>mapping</methodInvocation>
        <source>destinationPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.destinationPort.length = 3 and 
		   app.myRoot &lt;&gt; null then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
