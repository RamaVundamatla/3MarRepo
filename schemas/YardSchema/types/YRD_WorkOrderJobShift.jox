    <JadeMethod name="create" id="da7aef27-60fe-4058-865f-63f159a819dd">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderJobShiftView;
	self.permissionMaint	:= PmAdmWorkOrderJobShiftMaint; 
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="3b7b839e-c595-4a45-b1d7-0a76e4fc4a43">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
24 Jul 2023 navhl20 Defect 59274: MTN - Split Jobs is not working correctly
*/

vars
	pxyJobSheet,
	jobSheet	: CM_WorkPointJobSheet;
	obj			: CM_Job;
	result		: Integer;
begin
	jobSheet := self.cmbJobSheet.listObject.CM_WorkPointJobSheet;
	if jobSheet = null then
		app.raiseCMException(Sheet_should_select_shift_jobs, null, null);			//24.7.2023 navhl20 #59274
		return;
	endif;
	
	if self.allJobs.isNotEmpty() then
		pxyJobSheet := app.createUpdateProxy(jobSheet).CM_WorkPointJobSheet;
		while true do
			app.myTrxUA.trxUpdateWOJobSheet(self.allJobs,pxyJobSheet,app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.unloadForm();
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return;
		endwhile;
	endif;
epilog
	delete pxyJobSheet;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbJobSheet" id="4af3620d-2854-454e-97c2-50f5a5d0cda1">
        <source>loadCmbJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
23 Sep 2024 navhl20	Bug 66211: EUP - Job Sheets should be filtered on Shift and Split Job form based on criteria of WO Operation
*/

vars
	jobSheet 	 : CM_WorkPointJobSheet;
	//term		 : CM_Terminal;
	cmb			 : CMUI_ComboBox;
begin
	//term := self.myTerminal;														//23.09.2024 navhl20 #66211
	cmb	:= self.cmbJobSheet;
	cmb.clear();
	//foreach jobSheet in  term.allJobSheetsForWorkPoints do						//23.09.2024 navhl20 #66211
	foreach jobSheet in self.allJobSheets  as CM_WorkPointJobSheet discreteLock do	//23.09.2024 navhl20 #66211
		cmb.addItemObject(jobSheet.externalName, jobSheet);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllJobs" id="84ae80c4-2e1a-4ac8-a015-a954c47b2211">
        <source>setAllJobs(_allJobs : CM_JobSet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars

begin
	self.allJobs.clear();
	_allJobs.copyNoDuplicates(self.allJobs,false);
epilog

end;</source>
        <Parameter name="_allJobs" type="CM_JobSet"/>
    </JadeMethod>
    <JadeMethod name="setJobSheets" id="2d3c0dcf-6315-4978-8632-83f781494c34">
        <updating/>
        <source>setJobSheets(_jobSheetSet : CM_JobSheetSet)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2024 navhl20	Bug 66211: EUP - Job Sheets should be filtered on Shift and Split Job form based on criteria of WO Operation

*/

vars

begin
	self.allJobSheets.clear;
	_jobSheetSet.tryCopy(self.allJobSheets);
epilog

end;</source>
        <Parameter name="_jobSheetSet" type="CM_JobSheetSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="00ddb57d-bd06-4b5e-a460-b4e33511d4d7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars

begin
	inheritMethod();
	self.btnOk.caption := app.getErrorString(Save);
	self.btnCancel.caption := app.getErrorString(Close);
	self.caption := self.caption &amp; self.allJobs.listString(Comma,CM_Job::id.name);
	self.loadCmbJobSheet();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a64f86fa-61e2-4702-b96c-99d5a8d98e5e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 July 2023 09:01:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026227, locale);
	lblJobSheet.translateCaption(Xlat_0026228, locale);
end;</source>
    </JadeMethod>
</GUIClass>
