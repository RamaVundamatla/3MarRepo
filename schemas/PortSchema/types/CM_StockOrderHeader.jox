    <JadeMethod name="getQuantityDelivered" id="6f694f5b-fc48-4391-8dc0-2101b60ccb48">
        <source>getQuantityDelivered() : Integer;

// cnwdvb1 24 October 2002 

vars

	bolOut	: CM_BOLOut;
	num		: Integer;

begin

	foreach bolOut in self.allBOLOuts do
		num := num + bolOut.allTrackedItems.size;
	endforeach;
	return num;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStockOrderSummary" id="22d88114-ef54-45e8-9f4c-95e7a949440f">
        <updating/>
        <source>getStockOrderSummary(_orderLine : CM_StockOrderProductLine) : CM_StockOrderSummary updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	operator	: CM_Operator;
	theSummary	: CM_StockOrderSummary;
	product		: CM_Product;
begin
	
	theSummary := self.myVoyage.allStockOrderSummaries.getAtKey(self.myOperator, _orderLine.myProduct);
	if theSummary = null then
		//need to create one
		create theSummary persistent;
		theSummary.setForCreate(self.myOperator, _orderLine.myProduct, self.myVoyage, _orderLine.myStockOrderHeader);
	endif;
		
	return theSummary;
end;</source>
        <Parameter name="_orderLine" type="CM_StockOrderProductLine"/>
        <ReturnType type="CM_StockOrderSummary"/>
    </JadeMethod>
    <JadeMethod name="hasDamagedTIs" id="9468f09c-fb13-42eb-bfc9-20e911303428">
        <source>hasDamagedTIs() : Boolean;
//--------------------------------------------------------------
// Created: 25 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	line : CM_StockOrderLine;

begin
	foreach line in self.allStockOrderLines where
			CM_StockOrderTILine.hasInstance(line) do
			
			//epr par 12714 10/10/06
			if line.CM_StockOrderTILine.myTrackedItem = null then
				continue;
			endif;
			
			if 	line.CM_StockOrderTILine.myTrackedItem.damaged then
				return true;
			endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
