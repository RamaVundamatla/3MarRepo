    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaValueForTi" id="fff38c0c-2a6d-4636-b2dc-369d2b0a7f9d">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/07/2017	cnwma1	TFS #5513:STWO - Direct Delivery Invoicing Set-up

*/

vars

begin
	if _ti.directDelivery then
		_criteriaValue := CM_YADataBoolean.VALUE_TRUE;
	else
		_criteriaValue := CM_YADataBoolean.VALUE_FALSE;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
