    <JadeMethod name="isInternalSystemUser" id="acd61665-d3dc-4875-a6a6-fc54e890149b">
        <source>isInternalSystemUser() : Boolean;
/*

Purpose:			Move 'special' user checking code into one place

Parameters:			

Return Value:		

Date				Who		Reason
05 October 2020		jlgmd1	Initial creation TFS 49758 MTN - Navis Smart Data API - Snapshot Data

*/

vars
	userCode : String;
begin
	userCode := self.code.trimRight.toUpper;
	
	if	userCode = SUPERUSER_Str or
		userCode = JMTSUPPORT_Str or
		userCode = OPSVIEWUSER_Str
	then
		return true;
	endif;
	
	return false;
epilog

end;</source>
