    <JadeMethod name="createSAPRequest" id="148e2eaa-486f-439c-bc53-b80e7ac69b9b">
        <source>createSAPRequest(_cashReceipt : CM_CashReceipt;_isCancel : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2018	    cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
16 Nov    2018      cnwma1  ChangeRequest 42045: PEL1 - SAP Integration : Additional Changes - Extended
27 Nov    2018      cnwma1  Bug 42217: PEL1 - Post Pay Estimates Cancellation
23 Jan    2019	    cnwma1	ChangeRequest 42943: PEL1 - Recheck Finance for WSDL 1.4 on Web Portal
*/

vars
	pxyCashReceipt ,
	cashRec			: CM_CashReceipt;
	cashRecStatus   : Integer;
	msg				: String;
begin
	return;
	
	msg :=  method.qualifiedName                                                                   &amp; 
			' ' &amp; "isCancel :"             &amp; _isCancel.asStringJMT                                 &amp;
			' ' &amp; "CashReceipt : "     	   &amp; _cashReceipt.externalInvoiceNumber                    &amp;
			' ' &amp; "Payment Type :"         &amp; app.paymentTypeEnumToString(_cashReceipt.paymentType) &amp;
			' ' &amp; "Work Order :"           &amp; self.id ;
	app.writeLog(msg,LogINFO);
	
	if _isCancel then
		/*
		37189.009 Cancel Estimation
		WSDL 1.10: Auto-Collection - Estimation Cancellation
		PaymentType_AutoCollection
		*/
		if _cashReceipt.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then 
			if _cashReceipt.isAutoCollection then  //16.11.2018 cnwma1 TFS #42045
			     
				self.processSAPCancelEstimate(_cashReceipt);
			elseif _cashReceipt.isPostPay then
				/*
				27.11.2018 cnwma1  Bug 42217
				PaymentType_PostPay
				Not Creating SAP Requests here,Only Updating cash receipt status to CREDIT_CANCEL_APPROVED
				Added here to make the code more consistent  
				*/
				
				if process.isInTransactionState then
					cashRec := _cashReceipt;
					cashRecStatus := CM_CashReceipt.CREDIT_CANCEL_APPROVED;
					cashRec.setPaymentStatus(cashRecStatus);
				else 	
					pxyCashReceipt := app.createUpdateProxy(_cashReceipt).CM_CashReceipt;
					app.myTrxUA.trxUpdateCashRecPaymentStatus(pxyCashReceipt ,CM_CashReceipt.CREDIT_CANCEL_APPROVED,app.myPassport);
					if app.myPassport.hasErrors then
						msg :=  method.qualifiedName &amp; 
								' ' &amp; "**SAP**" 		 &amp;
								' ' &amp; "CashReceipt :"   &amp; _cashReceipt.externalInvoiceNumber &amp;
								' ' &amp; "ERRORS : "       &amp; app.myPassport.getErrorsAndWarningsAsString;
						app.writeLog(msg,LogINFO);
					endif;
				endif;
				
			endif;
		endif;
	else 
		if _cashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
			if _cashReceipt.isAutoCollection then
				/*
				37189.001 Perform Credit Check for Auto-Collection Customer 
				WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
				PaymentType_AutoCollection
				*/
				self.processSAPAutoEstReq(_cashReceipt);
			elseif _cashReceipt.isPostPay then
				/*
				37189.003 Perform Credit Check for Post-Billing Customer
				WSDL 1.6: Post-Billing - Credit Limit
				PaymentType_PostPay
				*/
				self.processSAPPostBillEstReq(_cashReceipt);
			elseif _cashReceipt.isPrePay then 		//23.01.2019 cnwma1 TFS #42943
				/*
				37189.002 Perform Credit Check for Pre-Billing Customer
				WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
				PaymentType_PrePay
				*/
				self.processSAPPreBillCheckLimit(_cashReceipt);
			endif;
		endif;
	endif;
epilog
	delete pxyCashReceipt;	
end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_isCancel" type="Boolean"/>
    </JadeMethod>
