		delete camPro;
		commitTransaction;
	endforeach;
	
	//discrepancies
	foreach discrepancyArray in term.discrepancies do
		beginTransaction;
		if not discrepancyArray.isEmpty then
			discrepancyArray.purge();
		endif;
		delete discrepancyArray;
		commitTransaction;
	endforeach;
	beginTransaction;
	term.discrepancies.clear();
	commitTransaction;
	
	foreach vehicle in term.vehicles do
		self.deleteVehicle(vehicle);
	endforeach;
	
	//allStkOrdByProcessFulfillStat
	//allStockOrderHeaders
	foreach stockOrderHeaderGeneric in term.allStkOrdByProcessFulfillStat do
		beginTransaction;
		delete stockOrderHeaderGeneric;
		commitTransaction;
	endforeach;
	
	//allWharves
	foreach wharf in term.allWharves do
