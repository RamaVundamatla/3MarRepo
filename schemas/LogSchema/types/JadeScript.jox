<Class name="JadeScript">
    <JadeMethod name="eprAddLogTickets" id="52d35806-3f3d-4731-8994-bfb0af69af0f">
        <source>eprAddLogTickets();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2017	jlger1	Initial creation

*/

vars
	
	logDocket : CM_BOLIn;
	logScaleHdrPxy,
	hdr 			: CM_LogScalingHdr;
	logScaleExtraPxy: CM_LogScalingExtra;
	logDetailPxy,
	dtl				: CM_LogScalingDtl;
	now 			: TimeStamp;
	quantity,
	 i : Integer;
	 logStart : String;
	 logId : String;
	first	: String;
begin
	logDocket := "4074.275275".asOid.CM_BOLIn;
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	
		create logScaleHdrPxy transient;
	logScaleHdrPxy.setProxy(logDocket.number,
							logDocket.myOperator.code, null, now, logDocket.myTerminal);
	app.myPassport.setMyTerminal(logDocket.getMyTerminal);
	create logScaleExtraPxy transient;	// creating logScaleExtraPxy. PAR 27133, ccms 1118 03.03.2011  Purged in epilog when deleting parent object
	logScaleExtraPxy.setProxy(logScaleHdrPxy, "BOB", logScaleHdrPxy.inputDateTime, logScaleHdrPxy.inputDateTime);	// PAR 27133, ccms 1118 03.03.2011
			
	logStart:=logDocket.myExtension.CM_BOLExtLogIn.allTicketSequences.first.fromId;
	quantity:=logDocket.myExtension.CM_BOLExtLogIn.allTicketSequences.first.quantity;
	first:=logStart[(logStart.length -quantity.String.length)+1:end];
	//write first;
	//return;
	logStart:=logStart[1:logStart.length -quantity.String.length ];
	while i &lt; quantity do
		
		logId := logStart &amp; (i + first.Integer).String.padLeadingZeros(quantity.String.length);// 
		create logDetailPxy transient; //Purged in epilog when deleting parent object
		logDetailPxy.setProxy(logId, "OK", 8, 8, logScaleHdrPxy, "BOB");
		i:=i+1;

	endwhile;
	

	app.myTrxCA.trxCreateLogScalingData(logScaleHdrPxy, app.myPassport);
epilog
	delete logScaleHdrPxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="printShipLoadListMax" id="b1ea5ce0-e511-4ef2-bfb3-b29827cdab07">
        <source>printShipLoadListMax();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2017	jlger1	Initial creation

*/

vars
	sohLocation : CM_SOHLocation;
begin
	app.initialize();
	// app.myQAFilter.myRWLogDocket;
	
	foreach sohLocation in CM_SOHLocation.instances do
		if not sohLocation.allTrackedItems.isEmpty then
			write sohLocation.String &amp; " " &amp; sohLocation.allTrackedItems.size.String;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="printShipLogList" id="0f0bf3c5-17b6-48a4-bcaf-2c7cb3d08408">
        <source>printShipLogList();
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	r	: CM_GenericTablePrint;
	r	: LOG_ShipLogList;
	idx,
	colNo,
	savePos	: Integer;
	nextTopRow:          Integer;
	nextLeftColumn:      Integer;
	saveLeft	: Real;
	col		: JadeTableColumn;

begin
	app.printer.printPreview := true;
	app.printer.setMargins(Print_Landscape,0,0,10,10);

//	r := CM_GenericTablePrint.createPrintForm;
	r := LOG_ShipLogList.createPrintForm;


	r.tblReport.visible := true;
//	r.frmTable.visible := true;
	r.tblReport.top := 0;
	r.tblReport.left := 0;
	
	r.frmHeader.width := app.printer.pageWidth;
//	r.lblHeader1.caption := 'The main heading';
//	r.lblHeader1.visible := true;
//	r.lblHeader1.centreHorizontallyInParent;
	app.printer.setHeader(r.frmHeader);

	// set footer
	r.frmFooter.width := app.printer.pageWidth;
//	r.lblTheUser.caption := 'rjs';//app.getMyUserCode;
	//r.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(r.frmFooter);
	
	r.tblReport.rows := 0;
	r.tblReport.columns := 3;
	r.tblReport.accessColumn(1).width := 120;
	r.tblReport.accessColumn(2).width := 100;
	r.tblReport.accessColumn(3).width := 130;


		// Force the header frame to be printed and save
	// the first real print position
	app.printer.print(r.frmNull);
	savePos	:= app.printer.getPrintPosition;	
	
	// Add data to table
	foreach idx in 1 to 20000 do
//		r.addRowToTable(idx.String &amp; Tab &amp; 'A' &amp; idx.String &amp; Tab &amp; 'B' &amp; idx.String, false );
		r.addRowToTable('FG166461' &amp; Tab &amp; '42.0' &amp; Tab &amp; '.706', false);
	endforeach;
	

///////////////
	// now set topRow/leftColumn and height/width
	r.setMaxTableHeight;
	r.setMaxTableWidth;
	r.setFixedRowHeight;
	r.setFixedColumnWidth;

	nextTopRow := r.tblReport.fixedRows + 1;
	nextLeftColumn := r.tblReport.fixedColumns + 1;
	
	saveLeft := r.frmTable.left;
	
	colNo := 1;
	while nextTopRow &lt;= r.tblReport.rows or nextLeftColumn &lt;= r.tblReport.columns do
		r.nextTablePosition(nextTopRow, nextLeftColumn, 0);
		if colNo &lt;= 3 then
			app.printer.setPrintPosition(savePos);
			r.frmTable.left := saveLeft + (r.frmTable.width * (colNo-1)) + ((colNo-1) * 10);
			colNo := colNo + 1;
		else
			colNo := 2;		// as we print column 1 below
			app.printer.newPage;
			app.printer.print(r.frmNull);
			r.frmTable.left := saveLeft;
		endif;
		if not app.printer.frameFits(r.frmTable) then
			//process.debug; commented out PAR 19975
		endif;
		app.printer.print(r.frmTable);
	endwhile;


/*
	app.printer.print(r.frTable);
	
	app.printer.setPrintPosition(savePos);
	r.frTable.left := r.frTable.width + 3;
	app.printer.print(r.frTable);

	app.printer.setPrintPosition(savePos);
	r.frTable.left := (r.frTable.width * 2) + 3;
	app.printer.print(r.frTable);
*/	
epilog
	app.printer.close;
	delete r;
end;</source>
    </JadeMethod>
    <JadeMethod name="runPrintForm" id="a69bccd3-3cfc-46a3-9b88-a032a2930067">
        <source>runPrintForm();

vars

	form 	: LOG_VoyageManifest;
	i		: Integer;
	count	: Integer;
	
begin

	app.printer.printPreview := true;
	app.printer.setMargins(Print_Landscape,0,0,10,10);


	form := LOG_VoyageManifest.createPrintForm;
	app.printer.setHeader(form.frmHeader);
	app.printer.setFooter(form.frmFooter);
	form.lblFooter1.caption := 'OWENS SERVICES TAURANGA';
	app.printer.print(form.frmLine);
	app.printer.print(form.frmLotHeading);
	form.lblTotalPcs.caption := '2174';
	foreach i in 1 to 1000 do
		if not app.printer.frameFits(form.frmDetail) then
			count := count + 1;
			app.writeStatement( count.String);
		endif;
		app.printer.print(form.frmDetail);
	endforeach;
	app.printer.print(form.frmTotals);
	app.printer.print(form.frmGrandTotals);
	
	
epilog
	app.printer.close;
	delete form;
end;</source>
    </JadeMethod>
</Class>
