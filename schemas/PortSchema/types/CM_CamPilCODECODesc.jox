    <JadeMethod name="outputHeader_NAD" id="be0df94c-f554-4459-8948-46fe185635cd">
        <updating/>
        <source>outputHeader_NAD(_protocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _camTaskHistory: CM_CamTaskHistory input; _coll: HugeStringArray input) : String updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", _protocol.camGroup.shippersCode.trimBlanks, '160', '87'), _coll);

	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="specialFileName" id="0aaccde4-592a-4215-83f7-0463b65fea7f">
        <source>specialFileName(_camGroup: CM_CamGroup; _startDateTime: TimeStamp; _runDateTime : TimeStamp): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2014	cnwmc5	Initial creation

*/

vars
	timeStamp 	: TimeStamp;
	utcString 	: String;
	
begin
	timeStamp := _runDateTime.localToUTCTime();
	utcString := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	
	return "CPL_PIL_COARRI_" &amp; utcString;

epilog

end;</source>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
