        <source>getLocation() : String;
// Get the primary location of the tracked items
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	ti		: CM_TrackedItem;
begin
    ti := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	//if self.allTrackedItems.size &gt; 0 then
	if ti &lt;&gt; null then //23/06/2023	navkc1	CR 58406 Task 58408
        //return self.allTrackedItems.first.getPrimaryLocationId(REAL_MODE);   
