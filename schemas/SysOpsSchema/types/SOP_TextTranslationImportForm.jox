    <JadeMethod name="doBaseFormCancel" id="419786fb-113e-44ea-b3ae-4e1046138ec4">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

/*
Purpose:	To make sure the alt+C key gets actioned correctly.

Date				Who		Reason
09 November 2009	cnwrl1	Initial creation as part of PAR 21253
*/
	
vars
	
begin
	inheritMethod();
	self.unloadForm();
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBrowseFile" id="0e2c95c1-9ffc-4ecf-a34f-b5ba96e82180">
        <source>doBrowseFile();

vars
	dlg : CMDFileOpen;
begin
	statusLine.caption := null;
	create dlg;
	dlg.fileMustExist := false;
	dlg.dialogTitle := "Select Text Translation Import File";
	dlg.createPrompt := false;
	dlg.filter := "Comma Separated Variable (*.csv)|*.csv|All Files (*.*)|*.*";
	if dlg.open = 0 then
		txtFileName.text := dlg.fileName;
	endif;
epilog
	delete dlg;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doImport" id="71184591-7674-4380-97fe-175b7e7a111c">
        <updating/>
        <source>doImport() updating, protected;
// adm 060509 Par 19230 show warnings
vars
	file : File;
begin
	statusLine.caption := null;
	statusLine.refreshNow;
	
	agent.allWarnings.clear;
	agent.setLineCount(1); // account for heading line
	
	on FileException do fileExHandler(exception);

	create file transient;
	file.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version	
	file.fileName := txtFileName.text;
	file.open;

	agent.setupProgressCallback(self,
								SOP_TextTranslationExportForm::zInitialiseProgressMonitor.name,
								SOP_TextTranslationExportForm::zUpdateProgressMonitor.name,
								"Importing text translations");
	agent.doImportCSV(file);
	
	if not agent.allWarnings.isEmpty then
		app.showErrorWarningDialogArray("Translation Load", null, agent.allWarnings, ErrWarnMode_CanAckWarnings);
	endif;
epilog
	delete file;
	if myProgress &lt;&gt; null then
		zFinaliseProgressMonitor;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fileExHandler" id="ca4f3574-6e03-43a8-8c7b-6275820b638b">
        <source>fileExHandler(ex : FileException) : Integer;

vars

begin
	statusLine.caption := "Error: " &amp; ex.text;
	return Ex_Abort_Action;
end;
</source>
        <Parameter name="ex" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
