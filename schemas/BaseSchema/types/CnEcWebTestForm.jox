    <JadeMethod name="doShowError" id="b14a01d7-58ef-442e-a798-561fe8132ebc">
        <updating/>
        <source>doShowError():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Generic method to display an error message for a database transaction.
//
// Parameters:	None
//
// Returns:		Boolean - Flag to indicate whether an error message as found and show.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	errorMessage	:=	self.aError;

	if errorMessage &lt;&gt; null then
		app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
epilog
	self.aError	:=	null;
	return errorMessage = null;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getConfirmDelete" id="60f4d684-ac6b-478c-8b05-76f240ba34b2">
        <source>getConfirmDelete(pEntityName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate the User's response to the
//				question of whether the requested object is to be deleted.
//
// Parameters:	pEntityName (String) - The name of the entity to be deleted.
//
// Returns:		Boolean - If true, the User chose "Yes", otherwise "No".
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ARE_YOU_SURE_START	: String = "Are you sure you want to delete '";
	ARE_YOU_SURE_END	: String = "' ?";
	MESSAGE_TITLE		: String = "Confirm Delete";
	
vars
	askMessage		: String;
	messageResponse	: Integer;

begin
	askMessage		:=	ARE_YOU_SURE_START &amp; pEntityName &amp; ARE_YOU_SURE_END;
	messageResponse	:=	app.msgBox(askMessage, MESSAGE_TITLE, MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
epilog
	return (messageResponse = MsgBox_Return_Yes);
end;</source>
        <Parameter name="pEntityName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDatabaseServerName" id="14b162b6-b2fc-4e80-99c2-6992a8663084">
        <executionLocation>server</executionLocation>
        <source>getDatabaseServerName():String serverExecution;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Purpose:		Returns the name of the Database Server machine.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theServer	: String;

begin
	theServer	:=	app.computerName();
epilog
	return theServer;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="05a4c866-4fcf-4cd6-9a6b-fe4a967d0c51">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	create self.aMyTA transient;
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="resynchObjAndSetEdition" id="24a349c9-6464-40d3-8068-2b1945227073">
        <updating/>
        <source>resynchObjAndSetEdition(pTheObject:Object) updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Resynchronizes the target object and stores its edition
//
// Parameters:	theObject - The object for which to resynch and store the edition
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
/*
	Use of "resynchObject" is preferable to "resynch" as it uses an object that
	is already	resident in cache (self) to resynchronize another object.  This
	is preferable to sending resynch to the object to be resynchronized, as if
	it is not in cache, it will have to be fetched from the server to dispatch
	the resynch method, whereupon it will be marked as obsolete.  If the object
	passed to resynchObject is not in cache, it does nothing.
*/
begin
	if pTheObject &lt;&gt; null then
		self.aObjectEdition	:=	pTheObject.edition();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="a583cc95-9ae6-4328-859d-a087a5ad69d6">
        <updating/>
        <source>setFormCaption(pCaptionName:String; pIsNew:Boolean; pIsClone:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Sets the receiver's caption.
//
// Parameters:	pCatptionName - The title of the form.
//				pIsNew - True if the form is for a new object.
//				pIsClone - True if the form is for a cloned web test.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsNew then
		self.caption	:=	self.ACTION_ADD &amp; " " &amp; pCaptionName;
	elseif pIsClone then
		self.caption	:=	self.ACTION_CLONE &amp; " " &amp; pCaptionName;
	else
		self.caption	:=	self.ACTION_EDIT &amp; " " &amp; pCaptionName;
	endif;
end;</source>
        <Parameter name="pCaptionName" type="String"/>
        <Parameter name="pIsNew" type="Boolean"/>
        <Parameter name="pIsClone" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unload" id="0cf64441-9681-4cb3-a3ad-1e5fd49247a3">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.aMyTA;
end;</source>
    </JadeMethod>
</GUIClass>
