    <JadeMethod name="myClassToCreate" id="15bf2b5e-2b2f-44d7-b742-5f7f4ea3af72">
        <methodInvocation>mapping</methodInvocation>
        <source>myClassToCreate(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subSchema : Schema;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := currentSchema.getClass(self.classNameToCreate);
	// PAR 8262 - for CentrePorts subschema
	if _value = null then
		subSchema := currentSchema.getSubschema("CPLSchema");
		if subSchema &lt;&gt; null then
			_value := subSchema.getClass(self.classNameToCreate);
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="290becaa-0421-4f6a-89cc-d50ae59b81bd">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 14 November 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 19/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk

vars

	cargoType	: SelfType;
	completedOK		: Boolean;
	recipe : CM_Recipe;
	pxyRecipe : CM_Recipe;

begin

	cargoType := inheritMethod();
	
	cargoType.myTIBehaviourType := self.myTIBehaviourType;
		
	if self.myDrawingAttribute &lt;&gt; null then
		cargoType.myDrawingAttribute := self.myDrawingAttribute.pxyCreateUpdateProxy();
	endif;
	
	if self.allTerminals &lt;&gt; null then	//This is in need for CM_Root::resetCargoTypes when going to the new JMT release. CCMS 1080 PAR 19704 May 2009
		self.allTerminals.copy(cargoType.allTerminals);
	endif;
	
	if self.allCommodities &lt;&gt; null then	//CCMS 1080 PAR197004. July 2009
		self.allCommodities.copy(cargoType.allCommodities);
	endif;

	if self.allDamagePositions &lt;&gt; null then	// PAR 22394 18/02/2010. We need this for CM_Root::resetCargoTypes() when going to the new JMT release.
		self.allDamagePositions.copy(cargoType.allDamagePositions);
	endif;
	if self.allDamageDefinitionCodes &lt;&gt; null then	// PAR 22394 18/02/2010. We need this for CM_Root::resetCargoTypes() when going to the new JMT release.
		self.allDamageDefinitionCodes.copy(cargoType.allDamageDefinitionCodes);
	endif;
	
	//29 Nov 2011	NDL	Par 28761
	if self.allSealTypes &lt;&gt; null then
		self.allSealTypes.copy(cargoType.allSealTypes);
	endif;
	
	cargoType.myVolumeMeasurementType	:= self.myVolumeMeasurementType;		// PAR #33606
	cargoType.myWeightMeasurementType	:= self.myWeightMeasurementType;		// PAR #33606
	
	//21 May 2021	NDL	TFS 51243
	foreach recipe in self.allRecipes do
		pxyRecipe := recipe.pxyCreateUpdateProxy();
		pxyRecipe.setMyCargoType( cargoType );
	endforeach;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return cargoType;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete cargoType;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresSystemProductType" id="7c5b6028-e117-4388-826d-7a8202541634">
        <source>requiresSystemProductType() : Boolean;
/* ---------------------------------------------------------------------------
Created:	10 July 2009	by cnwvu1

Purpose:	CCMS 1080 PAR19704.
			A user defined cargot types, that haven't got subcargo types
			(product types) requires dummy system product type.
			Exception for some specific cargo types as Trailer and Vehicle.
			
Change Date		Who		Reason
-----------		-------	------------------------------------------------------
10/03/2010		cnwdap1	PAR #22938 Vehicles now require a system product type
						so we have somewhere to store reefer properties - vehicles
						can be defined as "treat as reefer"
------------------------------------------------------------------------------*/
vars

begin
	if self.productType = ProductType_Vehicle then
	//	return true;
	endif;
	
	if self.isSystemCargoBOLType then
		return false;
	endif;

	if self.isSubCargoTypeRequired then
		return false;
	endif;
	
	if self.productType = ProductType_Trailer then	// PAR #22938 or self.productType = ProductType_Vehicle then
		return false;
	endif;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCanWeightBeCertified" id="913b1276-3d24-467c-96d6-d9bf765b909c">
