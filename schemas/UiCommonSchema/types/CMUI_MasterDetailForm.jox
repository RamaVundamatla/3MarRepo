    <JadeMethod name="tblDataDetail_keyDown" id="ebf560d0-2296-48b1-b972-e3a9a70c20e1">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDataDetail_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if table.userInputEnabled
	and table.row &gt; table.fixedRows
	and shift = 0
	and keyCode = J_key_Tab then
		self.origValueInteger := table.rows;
		//if at the end of the last row then a new row will be added
		self.doQueryRowColumnChange(table, table.row+1);
		if table.rows &gt; self.origValueInteger then
			//A new row has been added, reset key code
			//To prevent jade from re-setting the column
			keyCode := 0;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataDetail_rowColumnChg" id="77d6e6b3-e33d-419f-8b2e-6940e1feb941">
