    <JadeMethod name="delete" id="9ed83364-492c-474d-930f-297e3b68c670">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2024	jlier1	Initial creation

*/

vars

begin
	delete self.dimensions;
	delete self.weights;
epilog

