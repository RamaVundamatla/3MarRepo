	theForm.txtAddrAdr2.text         := null;
	theForm.txtAddrAdr3.text         := null;
	theForm.txtAddrRegion.text       := null;
	theForm.txtAddrPostCode.text     := null;
	theForm.txtAddrCity.text 		 := null;
	theForm.txtAddrDelIns.text 		 := null;
	self.myCurrentAddress   		 := null;
end;</source>
