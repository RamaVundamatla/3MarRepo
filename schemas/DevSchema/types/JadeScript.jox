	form : Form;
	objSet : ObjectSet;
	obj : Object;
	ass : CM_Association;
begin
	app.initialize;
	schema := rootSchema.getSchema("ShipSchema");
	klass := schema.getClass("SHP_LoadListComparison");
	create form as klass;
	form.sendMsg("setupIgnoreCodes");
	form.sendMsg("setupTranshipCodes");
	form.sendMsg("setupUpdateCodes");
	objSet := form.getPropertyValue("allUpdateFieldsObjects").ObjectSet;
	foreach obj in objSet do
		ass := obj.CM_Association;
		write ass.asString&amp;' '&amp;ass.asInteger.String;
	endforeach;
epilog
	delete form;
end;
</source>
