    <JadeMethod name="translateWindowMenu" id="47a4d4a7-461c-4ce0-871a-5cbcfa75c10d">
        <source>translateWindowMenu(_locale : CM_Locale);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2009	cnwrd1	Initial creation

*/

vars
	i : Integer;
begin


foreach i in 1 to self.menuItemCount do
	//write self.menuItems(i).name &amp; '  &gt;&gt;&gt; ' &amp; self.menuItems(i).caption;
	if  self.menuItems(i).caption = '&amp;Arrange Icons' then
		self.menuItems(i).caption :=  app.getErrorString(Arrange_icons);
	endif;
	
	if  self.menuItems(i).caption = '&amp;New Window' then
		self.menuItems(i).caption :=  app.getErrorString(NewWindow);
	endif;
		
	if  self.menuItems(i).caption = 'Tile &amp;Horizontal' then
		self.menuItems(i).caption :=  app.getErrorString(Tile_horizontal);
	endif;
	
	if  self.menuItems(i).caption = 'Tile &amp;Vertical' then
		self.menuItems(i).caption :=  app.getErrorString(Tile_vertical);
	endif;
	
	if  self.menuItems(i).caption = '&amp;Cascade' then
		self.menuItems(i).caption :=  app.getErrorString(Cascade);
	endif;
	
endforeach;
/*
  &gt;&gt;&gt; &amp;Arrange Icons
  &gt;&gt;&gt; &amp;Cascade
  &gt;&gt;&gt; &amp;New Window
  &gt;&gt;&gt; Tile &amp;Horizontal
  &gt;&gt;&gt; Tile &amp;Vertical
  */
epilog

end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="unload" id="525d8ae6-cdc6-4c45-95bf-e018bae7c8cc">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
// ***************************************************************************
// This is similar to method MobileUISchema::MOB_BaseForm::unload.  
// Changes to this method may also need to be done in that method
// ***************************************************************************

vars
	realUserWindow	: CM_UserWindowForOpen;
	
begin
	self.clearErrorWarnings();
	self.allSelectorCriteria.purge();
	app.writeLog(self.class.name &amp; " close", LogINFO);	
	
	self.allMeasurementControls.purge;			// PAR #31155

	if self.myAssistant &lt;&gt; null then
		delete self.myAssistant;
	endif;

	if self.visible and app.getMyUser &lt;&gt; null
	//21 Feb 2019	NDL	TFS 43332	- removed this
//	and not self.isKindOf(CM_ContainerEnqForm) then		// 8/11/18 MAP TFS41143	don't want this instance of Cargo Enquiry to overwrite newer XML of another, this is done on exiting column organiser instead
	then
		realUserWindow := app.getUserWindow(self.name, true);	// returns a transient
		if realUserWindow &lt;&gt; null then 			
			realUserWindow.setProxy(app.getMyUser, self.name, self.getXMLSettingsForSave(), self.top, self.left, self.width, self.height, self.windowState);
		endif;
	endif;

	if app.myController &lt;&gt; null and self.myMasterMenuAction &lt;&gt; null then
		app.myController.deleteMenuAction(self.myMasterMenuAction);
	endif;
	
	self.endNotificationForSubscriber(self);
	
	self.endTimer(self.BaseForm_TimerNotes);	//13/03/2025	navkc1 JIRA Story MTN-34219
	self.endTimer(self.BaseForm_TimerRefresh);	//13/03/2025	navkc1 JIRA Story MTN-34219
	//self.allNoteRecords.purge();				//13/03/2025	navkc1 JIRA Story MTN-34219
	//self.doClearNoteRecords(true); 					//27/03/2025	navkc1 JIRA Story MTN-34156
	self.doClearNoteRecords(true, true); //23/06/2025	navkc1 JIRA MTN 34973
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCaptionDeadlockRetry" id="4caa306c-9077-4d54-9b4f-613c3d87e4d7">
        <updating/>
        <source>updateCaptionDeadlockRetry(_caption : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2025	jlier1	Initial creation 34531

*/

vars

begin
	//only update if testing environment or master terminal
	if not app.myRoot.isClientJMTTesting and not app.myRoot.isClientJadeMaster then
		return;
	endif;
	self.caption := _caption &amp; " DLRT " &amp; app.myPassport.silentDeadlockRetryCount.String;
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateHazardsFromDetailForm" id="d5d39f9a-d7be-4d58-9f89-ac7331574c55">
        <updating/>
        <source>updateHazardsFromDetailForm(_hazDict : CM_HazardByCodeDict) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars

begin
	// do nothing at this level - reimplement at the local form level
	return true;
epilog

end;</source>
        <Parameter name="_hazDict" type="CM_HazardByCodeDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="9396326f-3e5f-4598-a6ac-33a772729b03">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
//--------------------------------------------------------------
//Created: 04 June 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
18 Oct 2010	cnwkpd1	PAR #25810 - EDI performance changes
					Change to ensure refreshNow and doWindowEvents are called
					less frequently
//10 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
*/

constants
	MinRefreshTime	= 2000;			// Only every 2 seconds at most

vars
	lastRefresh		: Decimal[20];
	
begin
	if (not self.frmModalDialog.visible) then
		return;
	endif;
	
	self.modalDialogUpdateInfo(_cmifMonitor.message);
	if _cmifMonitor.newCaption &lt;&gt; null then
		self.lblModalMessage.caption := _cmifMonitor.newCaption;
	endif;
	//self.lblModalInfo.caption 		:= _cmifMonitor.message;
	self.pbProgressBar.partsInJob	:= _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone	:= _cmifMonitor.partsDone;
	_cmifMonitor.monitorReturnValue := self.modalDialogReturnValue;	
//	self.frmModalDialog.doWindowEvents(0);

	//self.pbProgressBar.refreshNow(); //does nothing, no response after app lostFocus. App whiteout when gotFocus, (Not Responding)
	//self.lblModalInfo.doWindowEvents(0); updates control but causes whiteouts, flickering and intermittent freezing
	//self.pbProgressBar.doWindowEvents(0); as above
	
	// PAR #28510 - Only refresh and doWindowEvents after a defined period of time
	if self.userScript &lt;&gt; null and self.userScript.isDecimal then
		lastRefresh := self.userScript.Decimal;
	endif;
	
	if app.relativeMachineTime - lastRefresh &gt; MinRefreshTime then
		self.refreshNow();
		self.frmModalDialog.doWindowEvents(0); //causes controls to update but background to freeze, whiteout and slow flicker.
		self.userScript := app.relativeMachineTime.String;
	endif;
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateProgressAuto" id="48d84450-5c33-42d4-83b0-861d3e0ef9ae">
        <source>updateProgressAuto(_cmifMonitor: CMIF_Monitor);
//----------------------------------------------------------------
//	Created:	08 August 2003	by Jason Chapman  (cnwjc2)
//
//  Shows the progress dialog (caused by a note)
//  Can't have cancel etc.
//
//----------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin

	if not global.isValidObject(_cmifMonitor) then
		self.frmModalDialog.visible := false;
		return;
	endif;
	
	if (not self.frmModalDialog.visible) then
		self.frmModalDialog.visible := true;
	endif;

	self.lblModalInfo.caption := _cmifMonitor.message;
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.frmModalDialog.doWindowEvents(0);

	if _cmifMonitor.partsDone &gt;= _cmifMonitor.partsInJob then
		self.frmModalDialog.visible := false;
	endif;
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor"/>
    </JadeMethod>
    <JadeMethod name="viewPermissionsController" id="60d5737c-dbf7-44da-a87b-79fb2e7429c7">
        <source>viewPermissionsController(c1,c2,c3,c4,c5,c6 : Control input);
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cntrl : Control;
	indx  : Integer;
	s1,s2,s3,s4,s5,s6 : String;

begin
	if c1 &lt;&gt; null then
		s1 := c1.name;
	endif;	
	if c2 &lt;&gt; null then
		s2 := c2.name;
	endif;	
	if c3 &lt;&gt; null then
		s3 := c3.name;
	endif;	
	if c4 &lt;&gt; null then
		s4 := c4.name;
	endif;	
	if c5 &lt;&gt; null then
		s5 := c5.name;
	endif;	
	if c6 &lt;&gt; null then
		s6 := c6.name;
	endif;	

	foreach indx in 1 to self.controlCount do
	    cntrl := controls(indx);
		if 	cntrl.isKindOf(JadeMask) or cntrl.isKindOf(CheckBox) or cntrl.isKindOf(ComboBox) or 
			cntrl.isKindOf(TextBox) or cntrl.isKindOf(OptionButton) or cntrl.isKindOf(ListBox) or 
			cntrl.isKindOf(Table) then
			if cntrl.name[1:8] &lt;&gt; 'vBorder_' then
			    if cntrl.name = s1 or
			    	cntrl.name = s2 or
			    	cntrl.name = s3 or
			    	cntrl.name = s4 or
			    	cntrl.name = s5 or
			    	cntrl.name = s6 then
					cntrl.enabled := true;	    	
					cntrl.parent.enabled := true;
				else
					cntrl.enabled := false;
				endif;	    	  
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="c1" type="Control" usage="input"/>
        <Parameter name="c2" type="Control" usage="input"/>
        <Parameter name="c3" type="Control" usage="input"/>
        <Parameter name="c4" type="Control" usage="input"/>
        <Parameter name="c5" type="Control" usage="input"/>
        <Parameter name="c6" type="Control" usage="input"/>
    </JadeMethod>
