    <JadeMethod name="create" id="36d4dbe4-712f-48d8-8d22-d27197287ecb">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_CheckPoint;
	self.permissionView	 := PmHMSCheckPointView;
	self.permissionMaint := PmHMSCheckPointMaint;
	self.myDataClass := HMS_CheckPoint;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="7021d02b-96e1-4c85-b52a-3f5012af277c">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	pxyCheckPoint			: HMS_CheckPoint;
	theForm					: SOP_HMS_TableMaintForm;
	table					: CM_EntryTable;
	checkpointType			: Integer;
	hiLoTideReference		: String;
	gapTimeDifference		: Integer;
	hiLoRelativeTimeTo		: Integer;
	hiLoRelativeTimeFrom	: Integer;
	hiLoTideReference2		: String;
	hiLoRelativeTimeTo2		: Integer;
	hiLoRelativeTimeFrom2	: Integer;
	tideRangeReference		: String;
	tideRangeAmount			: Integer;
	tideRangeReference2		: String;
	tideRangeAmount2,
	tideState 				: Integer;
	gapCheckArrivals,
	gapCheckDepartures 		: Boolean;
	tmpJadeCode,
	shipsDepartTimings,
	tmpTideStateString : String;
	tmpTimeGapToCheckRegion	: HMS_HarbourRegion;
	
begin
  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_CheckPoint transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyCheckPoint := theForm.myProxyObject.HMS_CheckPoint;
	table := theForm.tblInput1;
	table.setObjectFromTable(pxyCheckPoint, null, false);
	
	if theForm.cmbChkPointType.listIndex &gt; 0 then
		checkpointType := theForm.cmbChkPointType.itemData[theForm.cmbChkPointType.listIndex];
	endif;
	
	tmpJadeCode:=null;
	if checkpointType = HMS_ChkPointType_HiLo then
		hiLoTideReference		:=	theForm.tblInput1.getValueByName(ETRow_RelativeToTide).String;
		hiLoRelativeTimeTo 		:=	theForm.tblInput1.getValueByName(ETRow_RelativeToTime).Integer;
		hiLoRelativeTimeFrom	:=	theForm.tblInput1.getValueByName(ETRow_RelativeFromTime).Integer;
		hiLoTideReference2		:=	theForm.tblInput1.getValueByName(ETRow_RelativeToTide2).String;
		hiLoRelativeTimeTo2		:=	theForm.tblInput1.getValueByName(ETRow_RelativeToTime2).Integer;
		hiLoRelativeTimeFrom2	:=	theForm.tblInput1.getValueByName(ETRow_RelativeFromTime2).Integer;
	//jlgka1 TFS 45620 --&gt;
	/*elseif checkpointType = HMS_ChkPointType_TideRange then
		tideRangeReference		:=	theForm.tblInput1.getValueByName(ETRow_TideRangeReference).String;
		tideRangeAmount 		:=	theForm.tblInput1.getValueByName(ETRow_TideRangeAmount).Integer;
		tideRangeReference2		:=	theForm.tblInput1.getValueByName(ETRow_TideRangeReference2).String;
		tideRangeAmount2 		:=	theForm.tblInput1.getValueByName(ETRow_TideRangeAmount2).Integer;*/
	//jlgka1 TFS 45620 &lt;--
	elseif checkpointType = HMS_ChkPointType_TimeGap then
		gapTimeDifference := theForm.tblInput1.getValueByName(ETRow_GapBetweenMovements).Integer;
		tmpTimeGapToCheckRegion := theForm.cmbRegForTimeGap.listObject.HMS_HarbourRegion;
		gapCheckArrivals:=  theForm.tblInput1.getValueByName(ETRow_GapCheckArrivals).Boolean; //epr par 16514 16/4/08
		gapCheckDepartures:=  theForm.tblInput1.getValueByName(ETRow_GapCheckDepartures).Boolean; //epr par 16514 16/4/08		
	//jlgka1 TFS 45620 --&gt;
	/*elseif checkpointType = HMS_ChkPointType_ShipsDepart then
		hiLoTideReference		:=	theForm.tblInput1.getValueByName(ETRow_RelativeToTide).String;
		shipsDepartTimings := theForm.tblInput1.getValueByName(ETRow_ShipsDepartTimings).String;	
	elseif checkpointType = HMS_ChkPointType_UserHookCode then
		tmpJadeCode := self.jadeCode;	
	elseif checkpointType = HMS_ChkPointType_TideState then
		tmpTideStateString	:= theForm.tblInput1.getValueByName(ETRow_TideState).String;
		if tmpTideStateString = app.getErrorString(Flood) then
			tideState:= HMS_CheckPoint.TideState_Flood;
		elseif tmpTideStateString = app.getErrorString(Ebb) then
			tideState:=HMS_CheckPoint.TideState_Ebb;
		endif;*/
	//jlgka1 TFS 45620 &lt;--	
	endif;
	
	pxyCheckPoint.setProxy(app.myRoot, 
						theForm.cmbHarbour.listObject.HMS_Harbour,
						checkpointType,
						theForm.cmbTidalModel.listObject.HMS_TidalModelDefinition,
						hiLoTideReference,
						hiLoRelativeTimeTo,
						hiLoRelativeTimeFrom,
						hiLoTideReference2,
						hiLoRelativeTimeTo2,
						hiLoRelativeTimeFrom2,
						tideRangeReference,
						tideRangeAmount,
						tideRangeReference2,
						tideRangeAmount2,
						gapTimeDifference,
						shipsDepartTimings,
						gapCheckArrivals,
						gapCheckDepartures,
						tmpTimeGapToCheckRegion,
						tideState,
						tmpJadeCode,
						app.myPassport.userCode);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyCheckPoint, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyCheckPoint, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="24571d38-964b-41a4-bc19-80444d306bb0">
        <source>getCollection(): Collection;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
//	return self.myForm.SOP_HMS_TableMaintForm.myHarbour.allCheckPoints;
	return app.myRoot.allHMSCheckpoints;

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
