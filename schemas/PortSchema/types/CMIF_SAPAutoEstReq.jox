<Class name="CMIF_SAPAutoEstReq" id="c0729c29-7fe1-4253-82ef-cbd83cd21463">
    <superclass name="CMIF_SAPWSRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>37189.001 Perform Credit Check for Auto-Collection Customer 
WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
PaymentType_AutoCollection</text>
    <PrimAttribute name="amount" id="46fa098a-da9c-4155-a06d-3da7928f265e">
        <type name="String"/>
        <text>CM_CashReceipt.cashValue</text>
    </PrimAttribute>
    <PrimAttribute name="amountEstmtOpen" id="7b324f65-707f-4db5-8450-fe9546091451">
        <type name="String"/>
        <text>Total of CM_CashReceipt.cashValue with CM_CashReceipt.paymentStatus =  CREDIT_CHECK_APPROVED
on all terminal for AutoCollection Debtor.
CM_Debtor.getEstimateOpenAmountAutoColl</text>
    </PrimAttribute>
    <PrimAttribute name="currency" id="32b95124-0255-43fa-89aa-6272fc8b8eb7">
        <type name="String"/>
        <text>if cashReceipt.getBank.isPelDomestic then
	value := "IDR";
else
	value := "USD";
endif;</text>
    </PrimAttribute>
    <PrimAttribute name="customerNo" id="3925454e-b81c-4f95-a3bb-7c6ecebc271b">
        <type name="String"/>
        <text>CM_Debtor.code</text>
    </PrimAttribute>
    <PrimAttribute name="estimationID" id="61f31a33-64d9-4fa0-9404-962e418d7364">
        <type name="String"/>
        <text>CM_CashReceipt.externalInvoiceNumber</text>
    </PrimAttribute>
    <PrimAttribute name="profitCenter" id="b5b80a48-80be-4481-a053-7e0d3ea3b8ee">
        <type name="String"/>
        <text>CM_Berth.externalReference1</text>
    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="f33a96eb-e18f-47f3-a473-fd95848ea1f0">
        <source>copyToRealWSObject(_realRequest: SAP11_AutocollEstimationRequest_DT input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.amounEstmtOpen := self.amountEstmtOpen;
	_realRequest.amount := self.amount;
	_realRequest.currency := self.currency;
	_realRequest.customerNo := self.customerNo;
	_realRequest.estimationID := self.estimationID;
	_realRequest.profitCenter := self.profitCenter;

epilog

end;</source>
        <Parameter name="_realRequest" type="SAP11_AutocollEstimationRequest_DT" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyToSAPAutoEstReq" id="ca40a3dd-67e8-4beb-a5da-075f8e1c35cb">
        <updating/>
        <source>copyToSAPAutoEstReq(_cashReceipt : CM_CashReceipt) updating;
/*

Purpose:			
	37189.001 Perform Credit Check for Auto-Collection Customer 
	WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
	PaymentType_AutoCollection		
Return Value:		

Date		Who		Reason
25 Jun 2018 cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations
29 Jan 2019 cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues
*/
vars
begin

	self.estimationID 	 := self.sapHelper(_cashReceipt,"estimationID");
	self.customerNo 	 := self.sapHelper(_cashReceipt,"customerNo");
	self.amount       	 := self.sapHelper(_cashReceipt,"amount");  	  
	self.profitCenter 	 := self.sapHelper(_cashReceipt,"profitCenter");
	self.currency     	 := self.sapHelper(_cashReceipt,"currency");
	self.amountEstmtOpen := _cashReceipt.getDebtor.getEstimateOpenAmount(PaymentType_AutoCollection).String;  //29.01.2019 cnwma1 #43214
	
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="getActivityHistoryExtraDetails" id="c68157ae-36a7-4fea-bd62-387224266e76">
        <source>getActivityHistoryExtraDetails(_activityHistory: CM_ActivityHistoryExtInterface input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

begin
	
	return self.getEstimationIdString( _activityHistory );

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWSDLType" id="aededac4-9437-4f05-8c70-f0da5a257daf">
