<Class name="CM_TerminologyTypeExpression" id="cb7d86af-7f2a-4ed0-bf6f-3a5790c75062">
    <superclass name="CM_TerminologyEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminology"/>
    <ExplicitInverseRef name="allTerminologyExpressions" id="afcd36ab-b30d-4755-9928-32851d588818">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_TermExpressionByDescr"/>
        <access>readonly</access>
        <Inverse name="CM_TerminologyExpression::myTermTypeExpression"/>
    </ExplicitInverseRef>
    <PrimAttribute name="expressionDescr" id="5cc4433f-1904-485b-8d82-824219ab68f3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="expressionType" id="b26e2c2b-871d-443b-b789-aedce0eca56c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminologyType" id="3f623646-8550-4ee2-83f5-af5cfe9d7317">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TerminologyType"/>
        <access>readonly</access>
        <Inverse name="CM_TerminologyType::allTerminologyTypeExpressions"/>
    </ExplicitInverseRef>
    <PrimAttribute name="systemExpression" id="48d2a052-dec0-4c84-81fd-19cccacea9d7">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getExpressionTypeHeading" id="bdbabfc9-80d4-4259-807b-e3eb96137e19">
        <source>getExpressionTypeHeading() : String;
// ---------------------------------------------------------------------------
// Created:     16 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.expressionDescr &amp; '  (' &amp; self.systemExpression &amp; ') &gt;&gt;'; 

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ec069e9f-4326-43f3-9f01-f4b96c6f2613">
        <updating/>
        <source>setForUpdate(_pxyExpObj : CM_TerminologyTypeExpression; _termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.expressionType := _pxyExpObj.expressionType;
	self.expressionDescr := _pxyExpObj.expressionDescr;
	self.systemExpression := _pxyExpObj.systemExpression;
	self.myTerminologyType := _termType;
	
end;</source>
        <Parameter name="_pxyExpObj" type="CM_TerminologyTypeExpression"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminologyType" id="346b7988-c1c8-4a6a-98be-01c1cd6d6911">
        <updating/>
        <source>setMyTerminologyType(_termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myTerminologyType := _termType;

end;</source>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="52527b2a-06d7-44aa-b31a-76f68614c6a0">
        <updating/>
        <source>setProxy(_expType : Integer; _expDescr, _sysExp : String; _termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.expressionType := _expType;
	self.expressionDescr := _expDescr;
	self.systemExpression := _sysExp;
	self.myTerminologyType := _termType;

end;</source>
        <Parameter name="_expType" type="Integer"/>
        <Parameter name="_expDescr" type="String"/>
        <Parameter name="_sysExp" type="String"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c78b1271-c35d-4f09-8a08-535bc7f862a2">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     12 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myTerminologyType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology Type is null');
	endif;
	
	if self.expressionType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Expression type description is null');
	endif;
	
	if self.systemExpression = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'systemExpression is null');	
	endif;

end;</source>
    </JadeMethod>
</Class>
