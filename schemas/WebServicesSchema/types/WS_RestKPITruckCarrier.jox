<Class name="WS_RestKPITruckCarrier" id="4a3f2eee-377b-4be7-b460-ad24ee304d5a">
    <superclass name="WS_RestKPITruck"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="vehicleVisits" id="296c2274-bbde-4818-ab87-f3bd701b8e80">
        <memberTypeInverse/>
        <type name="WS_RestVehicleVisitArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="55bd9439-9b1b-48cb-80c2-2a9c59978585">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jan 2026	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars

begin
	self.vehicleVisits.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="c16d931f-6515-4a60-908b-1cd936f681e4">
        <updating/>
        <source>setProxyFromObject(kpiTruckCarrier : CM_KPITruckByCarrierDay;includeDetails : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2025	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars
		vvr 			:	CM_VehicleVisitRecord;
		wsVVR   		: 	WS_RestVehicleVisit;
		invalidObject 	: Boolean;
begin
	self.carrierId := kpiTruckCarrier.code;
	self.accrualCode := kpiTruckCarrier.dateTime.Date.String;
	self.dwellTimeAvg := kpiTruckCarrier.dwellTimeAve;
	self.dwellTimeMax := kpiTruckCarrier.dwellTimeMax;
	self.dwellTimeMin := kpiTruckCarrier.dwellTimeMin;
	self.dwellTimeTotal := kpiTruckCarrier.dwellTimeTotal;
	self.numTruck := kpiTruckCarrier.numTrucks;
	
	
	if includeDetails then 
		on Exception do app.handleDeletedObject(exception, vvr, invalidObject);
		foreach vvr in kpiTruckCarrier.allVehicleVisitRecords do 
			vvr.edition;
			if invalidObject = true then 
				invalidObject := false;
				continue;
			endif;
			create wsVVR transient;
			wsVVR.setProxyFromObject(vvr);
			self.vehicleVisits.add(wsVVR);
		endforeach;
		on Exception do null;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="kpiTruckCarrier" type="CM_KPITruckByCarrierDay"/>
        <Parameter name="includeDetails" type="Boolean"/>
    </JadeMethod>
</Class>
