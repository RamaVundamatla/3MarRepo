    <JadeWebServicesMethod name="getPortsForVoyage" id="46bb8798-b314-425e-8579-69fceb7098e9">
        <usesRPC>default</usesRPC>
        <source>getPortsForVoyage(_voyageCode : String) : WS_PortsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Sep 2008	cnwkao1	Initial creation
06 Mar 2009	cnwkpd1	PAR #19039 - remove isValidObject references for performance
03 Dec 2021 navma1	ChangeRequest 52511: SAL - Web Portal - Ports of Call
28/07/2023	navcs2	Bug 52469: MTN - Changes are needed to improve the performance of the following webservices. getPorts() and getPortsForVoyage()

*/

vars
	response			: WS_PortsResponse;
	completedOK			: Boolean;
	proxyPort			: WS_Port;
	voyage				: CM_Voyage;
	port 				: CM_Port;
	allPortsToDisplay	: CM_PortByCode3AndCountryDict;
	failedDAC			: CM_DataAccessController;
	passport			: CM_Passport;
	user				: CM_User;
	portRotation		: CM_PortRotation;
	vessel				: CM_Vessel;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	user 	 := passport.myUser;
	
	if _voyageCode &lt;&gt; null then
		voyage := passport.myTerminal.lookupVoyage(_voyageCode,null,false);
		if voyage = null then
			voyage:=passport.getObjectOfTypeFromOid(_voyageCode,CM_Voyage).CM_Voyage;
		endif;
		
		// 03.12.2021 navma1 #52511
		if voyage = null then
			vessel := app.myRoot.allVessels[_voyageCode.toUpper.trimBlanks];
		endif;
		// 03.12.2021 navma1 #52511
	endif;
	
	create allPortsToDisplay transient;
	
	if vessel &lt;&gt; null and vessel.myDefaultTrade &lt;&gt; null then							// 03.12.2021 navma1 #52511
		foreach portRotation in vessel.myDefaultTrade.allPortRotations do 
			port := portRotation.myPort;
			if port = null then
				continue;
			endif;
			
			if not port.isActivePort then
				continue;
			endif;
			
			if not port.canUserAccessSelf(user, failedDAC, passport) then
				continue;
			endif;
			
			allPortsToDisplay.addNoDuplicates(port,false); // Just in case the same port added to the rotation more than one 
			
		endforeach;
		
		foreach port in allPortsToDisplay do
			create proxyPort transient;								
			proxyPort.setProxyFromObject(port);
			response.allPorts.add(proxyPort);
		endforeach;
		
		
	elseif voyage = null or voyage.isNullVoyage() then		
		foreach port in app.myRoot.allActivePorts  do						// 28/07/2023 navcs2 Bug 52469
			if not port.bIsPort then										// 28/07/2023 navcs2 Bug 52469
				continue;													// 28/07/2023 navcs2 Bug 52469
			endif;															// 28/07/2023 navcs2 Bug 52469
			
			if not port.canUserAccessSelf(user, failedDAC, passport) then
				continue;
			endif;
			
			create proxyPort transient;								
			proxyPort.setProxyFromObject(port);
			response.allPorts.add(proxyPort);
		endforeach;
	else
		
		foreach port in voyage.allPorts discreteLock do
			if port = null then
				continue;
			endif;
		
			if port.isActivePort then
				if not port.canUserAccessSelf(user, failedDAC, passport) then
					continue;
				endif;
				if not allPortsToDisplay.includes(port) then
					allPortsToDisplay.add(port);
				endif;
			endif;
		endforeach;
		// read from dictionary to get in sequence
		foreach port in allPortsToDisplay do
			create proxyPort transient;								
			proxyPort.setProxyFromObject(port);
			response.allPorts.add(proxyPort);
		endforeach;
	endif;
	

	completedOK := true;
	return response;
	
	
epilog
	delete allPortsToDisplay;
	
	if not completedOK then
		self.cnSetTransactionError(true);
		delete response;				
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	self.cnEndTransaction();
end;</source>
        <wsdlName>getPortsForVoyage</wsdlName>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="WS_PortsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPreference" id="e3b51d47-754b-4c16-9927-fc198d45f650">
        <source>getPreference() : WS_PreferenceResponse webService;

/*

Purpose:			Get the Terminal the current session is assigned to.

Parameters:			None

Return Value:		Terminal response populated


Date		Who		Reason
3 Feb 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application
16 Jul 2020	jlgmd1	TFS #49792 - Commented out trx logging as its not helpful for this method, and this method is called *a lot*

*/

vars
	response		: WS_PreferenceResponse;
	completedOK		: Boolean;
	terminal        : WS_Terminal;
	preference		: WS_Preference;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	//cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	//self.initialisePassport();	// TFS 49792, may need to be re-enabled if we ever use any passport calls here... but thats very unlikely
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	if currentSession.myCurrentTerminal &lt;&gt; null then
		create preference transient;
		preference.setProxyFromObject(currentSession.myCurrentTerminal);
		response.preference := preference;
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		//cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	//cnEndTransaction;
	
end;</source>
        <text>Get the Terminal the current session is assigned to.</text>
        <wsdlName>getPreference</wsdlName>
        <ReturnType type="WS_PreferenceResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPrenoteFromBookingRef" id="26c584f0-a68f-4288-86e5-c6c9e5d5e1da">
        <usesRPC>default</usesRPC>
        <source>getPrenoteFromBookingRef(bookingRefNumber : String) : WS_PrenoteFromBookRefResponse webService;

/*

Purpose:			Get prenote data according to the input Booking Reference Number. 

Parameters:			booking ref

Return Value:		


Date		Who		Reason
07 Jan 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application
13 Mar 2009	cnwkpd1	PAR #19130 - Booking Ref number needs to be case insensitive

*/

vars
	response		: WS_PrenoteFromBookRefResponse;
	completedOK		: Boolean;
	
	iter			: Iterator;
	bookingRef		: CM_BookingRef;
	obj				: Object;
	objArr			: ObjectArray;
	terminal		: CM_Terminal;
	bookingRefTI	: CM_BookingRefItem;
	proxy			: WS_PrenoteFromBookRef;	
	bookingRefKey	: String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	iter := terminal.allBookingRefsByRef.createIterator;
	
	bookingRefKey := bookingRefNumber.toUpper();		// PAR #19130
	
	terminal.allBookingRefsByRef.startKeyGeq(bookingRefKey, iter);
	
	create objArr transient;
	
	while iter.next(bookingRef) do
		if bookingRef.bookingReference &lt;&gt; bookingRefKey then			// PAR #17611
			break;
		endif;
		
		objArr.add(bookingRef);		
	endwhile;
	
	delete iter;
	iter := objArr.createIterator();
	
	while iter.next(bookingRef) do
		foreach bookingRefTI in bookingRef.allBookingRefItems do
			create proxy transient;
			proxy.setDefaultsFromObject(bookingRefKey, bookingRefTI);
			response.allPrenoteFromBookRef.add(proxy);
		endforeach;
	endwhile;

	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	delete objArr;
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;

</source>
        <text>Get prenote data according to the input Booking Reference Number. </text>
        <wsdlName>getPrenoteFromBookingRef</wsdlName>
        <Parameter name="bookingRefNumber" type="String"/>
        <ReturnType type="WS_PrenoteFromBookRefResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPrenoteFromCargoId" id="edec3a5b-cb66-41e1-924c-ced1dd6b5ac2">
        <usesRPC>default</usesRPC>
        <source>getPrenoteFromCargoId(cargoId : String; cargoType : Integer) : WS_PrenoteFromCargoIdResponse webService;
/*

Purpose:			Get prenote data according to the input Cargo ID. 

Parameters:			booking ref

Return Value:		


Date		Who		Reason
07 Jan 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application
*/

vars
	response		: WS_PrenoteFromCargoIdResponse;
	completedOK		: Boolean;
	
	objArr			: ObjectArray;
	terminal		: CM_Terminal;
	
	trackedItem		: CM_TrackedItem;
	proxy 			: WS_PrenoteFromCargoId;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	self.setIgnoreWarnings(false);
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	
	trackedItem := terminal.lookupTrackedItem(cargoId, cargoType, TI_STATE_NOTIFIED, null, true);
	
	//03 May 2013	NDL	Par 31506
	if trackedItem = null then
		trackedItem := terminal.allNotifiedTIsByAlternativeId.getAtKey( cargoId );
	endif;
	
	if trackedItem = null then
		trackedItem := terminal.lookupTrackedItem(cargoId, cargoType, TI_STATE_NORMAL, null, true);
	endif;
	
	if trackedItem &lt;&gt; null then
		if trackedItem.site = TI_SITE_ONSITE then
			app.raiseCMException3(ERR_TI_ONSITE, trackedItem.cargoTypeDescr, trackedItem.id, trackedItem.myTerminal.code, null, null);
			completedOK := true;
			return response;
		else
			app.raiseCMWarning1(WARN_TI_PRE_NOTIFIED, trackedItem.id, null, null, trackedItem);
		endif;
	endif;
	
	create proxy transient;
	proxy.setDefaultsFromObject(cargoId,trackedItem);
	response.allPrenoteFromCargoId.add(proxy);	
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <text>Get prenote data according to the input Cargo ID. </text>
        <wsdlName>getPrenoteFromCargoId</wsdlName>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="cargoType" type="Integer"/>
        <ReturnType type="WS_PrenoteFromCargoIdResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPushEventsClasses" id="b1251f67-02a9-4ec8-855f-c8bb41b977d2">
        <source>getPushEventsClasses() : WS_PushEventsClassesResponse webService;

/*

Purpose:			Get a list of class names that are valid for the Events Stream).
					
Parameters:			None

Return Value:		


Date		Who		Reason
03 Nov 2017	jlgkpd1	TFS 7163 - Web Services to serialise objects to JSON

*/

vars
	response		: WS_PushEventsClassesResponse;
	completedOK		: Boolean;
	ddClass			: CM_DataDumpClass;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmPushEventsMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;

	// Build response
	foreach ddClass in app.myRoot.allDataDumpClasses do
		response.classNames.add(ddClass.className);
	endforeach;
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_PushEventsClassesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPushEventsConfiguration" id="e0fb5df0-79e5-4d82-bb44-9d969ba4ed1b">
        <source>getPushEventsConfiguration() : WS_PushEventsConfigResponse webService;
/*

Purpose:			Get the configuration details from the Push Events root object

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	response		: WS_PushEventsConfigResponse;
	completedOK		: Boolean;
	pushEventsRoot	: CM_PushEventsRoot;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmPushEventsMaint);
	// Check for any errors
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	pushEventsRoot := CM_PushEventsRoot.firstInstance();
	if pushEventsRoot = null then
		app.raiseCMException(Push_Events_not_running, null, null);
		completedOK := true;
		return response;
	endif;
	
	response.configurationDetails := pushEventsRoot.configurationDetails;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the current configuration details for the JMTPushEvents mechanism.</text>
        <ReturnType type="WS_PushEventsConfigResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPushEventsObjectsForClass" id="0edeaf4f-cfa5-46e5-880a-5d97e738500b">
        <source>getPushEventsObjectsForClass(request : WS_PushEventsObjectsRequest) : WS_PushEventsObjectsResponse webService;

/*

Purpose:			Get a list of oids for the passed in className (if it is a valid exposed class
					for the Events Stream).
					
Parameters:			className - class name to get objects for
					includeSubclasses - whether or not to include subclasses of the class
					startFrom - index of the object in the result set to start from
					maxResults - maximum number of results to return

Return Value:		


Date		Who		Reason
02 Nov 2017	jlgkpd1	TFS 7163 - Web Services to serialise objects to JSON

*/

vars
	response		: WS_PushEventsObjectsResponse;
	completedOK		: Boolean;
	cls				: Class;
	maxResults,
	startFrom		: Integer64;
	resultObjects	: ObjectArray;
	i				: Integer64;
	obj				: Object;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmPushEventsMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Check that the className passed in is a valid and exposed class
	if app.myPushEventsAgent.findDataDumpClassForClassName(request.className) = null then
		app.raiseCMException1(ERR_CouldNotFindClass, request.className, null, null);
		completedOK := true;
		return response;
	endif;
	
	cls := currentSchema.getClass(request.className);
	startFrom := request.startFrom.max(1);
	maxResults := 0;
	if request.maxResults &lt;&gt; 0 then
		maxResults := request.maxResults + startFrom - 1;
	endif;
	create resultObjects transient;

	// Get the instances using the input parameters
	cls.allInstances(resultObjects, maxResults, request.includeSubclasses);
	
	// Populate the result set with the oid 
	foreach obj in resultObjects do
		i := i + 1;
		if i &gt;= startFrom then
			response.objectIdentifiers.add(self.getOidStringForObject(obj));
		endif;
	endforeach;
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete resultObjects;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_PushEventsObjectsRequest"/>
        <ReturnType type="WS_PushEventsObjectsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getQueueTask" id="336d8d42-8ba1-4256-997b-00c5c6f9bdcd">
        <source>getQueueTask(_taskOid : String) : WS_QueueTaskResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2017	jlger1	Initial creation

*/

vars
	
	response		: WS_QueueTaskResponse;
	completedOK		: Boolean;
	queueTask 		: WS_QueueTask;
	rtTask			: CM_RTQueueTask;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	rtTask:=app.myPassport.getObjectOfTypeFromOid(_taskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if rtTask = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);
		completedOK := true;
		return response;
	endif;
		
	create queueTask transient;
	queueTask.setProxyFromObject(rtTask);
	response.myQueueTask:=queueTask;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_taskOid" type="String"/>
        <ReturnType type="WS_QueueTaskResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getROROVoyageStructure" id="79f15414-c7ef-4de1-8045-c6664de36178">
        <source>getROROVoyageStructure(_voyageRequest : WS_VoyageRequest) :  WS_VoyageResponse webService;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jun 2011	cnwdw1	Initial creation
08 Jun 2012	cnwkpd1	PAR #29758 - ensure completedOK set when returning response, even after JMT exception, so that 
					passport errors can be returned
11 Jul 2012 cnwer1	PAR 29962 - Work with LOLO
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1 

*/

vars
	response 	: WS_VoyageResponse;
	wsVoyage 	: WS_Voyage;
	user			: CM_User;
	terminal	: CM_Terminal;
	voyage 		: CM_Voyage;
	workPoint	: CM_WorkPoint;
	mach 		: CM_Machine;
	crane		: CM_Crane;
	completedOK : Boolean;
	requestCode   : String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Populate list of Terminals
	user := app.getMyUser();
	terminal := app.myPassport.myTerminal;
	
	voyage:=terminal.lookupVoyage(_voyageRequest.voyageCode,_voyageRequest.arrivalDT.asTimeStampFromWebInterface,false);		//cnwmc5 - 13 Jan 2016 - PAR 37326
	
	if voyage = null then
		app.raiseCMException1(Voyage_not_found,_voyageRequest.voyageCode,null,null);
		completedOK := true;		// PAR #29758
		return response;
	endif;
	
	workPoint:= terminal.allWorkPointsByCode[_voyageRequest.workPoint];
	if workPoint = null then
		mach:=terminal.machines[_voyageRequest.workPoint];
		if mach.isKindOf(CM_Crane) then
			crane := mach.CM_Crane;
		endif;
	endif;

	if crane = null and workPoint = null then
		app.raiseCMException1(Work_point_not_found,_voyageRequest.workPoint,null,null);
		completedOK := true;			// PAR #29758
		return response;
	endif;
	
	create wsVoyage transient;
	response.myVoyage:=wsVoyage;
	wsVoyage.setProxyFromObject(voyage);
	if workPoint &lt;&gt; null then
		wsVoyage.setROROStructureFromObject(voyage,workPoint);
	
		wsVoyage.setJobsForWorkPoint(workPoint,voyage);
	endif;
	
	if crane &lt;&gt; null then
		wsVoyage.setLOLOStructureFromObject(voyage,crane);
		wsVoyage.setJobsForWorkPoint(crane,voyage);
	endif;

	
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;

end;</source>
        <Parameter name="_voyageRequest" type="WS_VoyageRequest"/>
        <ReturnType type="WS_VoyageResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRailLines" id="a9387da1-97da-435c-b4b6-3f01d122c7e0">
        <source>getRailLines() :WS_RailLinesResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Feb 2017	#cnwsc8	initial development
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	                  

*/

vars
	response		: WS_RailLinesResponse;
	wsRailLine	    : WS_RailLine;
	completedOK		: Boolean;
	taTypeKey 		: Integer;
	taIdKey			: String;
	taIter			: Iterator;
	railLine		: CM_RailLine;
	taDict 			: CM_TAByTypeIdDict;
	ta				: CM_TerminalArea;
	terminal		: CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	
	
	taDict := terminal.allTerminalAreasByTypeId;

	taIter := taDict.createIterator;
	taDict.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, taIter);
	
	while taIter.next(ta) do
		taIter.getCurrentKeys(taTypeKey, taIdKey); //MTN-35226
		if taTypeKey &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		
		foreach railLine in ta.CM_Rail.allRailLinesByIndex do
			create wsRailLine transient;
			wsRailLine.setProxyFromObject(railLine);
			wsRailLine.description := ta.id &amp; ' ' &amp; railLine.id;
			response.allRakes.add(wsRailLine);
		endforeach;
		
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_RailLinesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRailRakeListForTrain" id="a122fd30-a44d-46f6-bf32-6ccbdcaf2f8d">
        <source>getRailRakeListForTrain(request : WS_RailRakeListRequest) : WS_RailRakeListResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2017	cnwsc8	Initial creation

*/

vars
	completedOK 	: Boolean;
	str				: String;
	response  		: WS_RailRakeListResponse;
	train			: CM_Train;
	terminal 		: CM_Terminal;
	details			: StringArray;
	railLine		: CM_RailLine;
	rline			: CM_RailLine;
	tokens			: StringArray;
	summaryLine		: WS_RailConfirmSummary;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	if request.trainUid = "" then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17 
	train := app.myPassport.getObjectOfTypeFromOid(request.trainUid,CM_Train).CM_Train;
	if train = null then
		completedOK := true;
		return response;
	endif;
	
	details := train.getPopulateListRakes(request.inwards, null, request.localConfirmedCargo);

	if details = null then
		completedOK := true;
		return response;
	endif;
	
	create tokens transient;
	
	foreach str in details do
		tokens.clear();
		str.getTokensForDelimiter(";",tokens);
		if tokens.size = 5 then
			//epr TFS 5535 4/8/17 
			rline :=  app.myPassport.getObjectOfTypeFromOid(tokens[1],CM_RailLine).CM_RailLine;
			if rline &lt;&gt; null then
				railLine := rline;
				str := railLine.getFullId;
				create summaryLine transient;
				summaryLine.rakeUid 		:= rline.getOidString();
				summaryLine.rakeFullName 	:= rline.getFullId();
				summaryLine.wagonNotified 	:= tokens[2].Integer;
				summaryLine.cargoNotified 	:= tokens[3].Integer;
				summaryLine.wagonConfirmed 	:= tokens[4].Integer;
				summaryLine.cargoConfirmed 	:= tokens[5].Integer;
				response.allSummaryLines.add(summaryLine);
			endif;
		endif;
	endforeach;

	completedOK:=true;
	return response;
epilog
	if details &lt;&gt; null then
		delete details;
	endif;
	if tokens &lt;&gt; null then
		delete tokens;
	endif;
		
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RailRakeListRequest"/>
        <ReturnType type="WS_RailRakeListResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getRailRakeSummaryForTrain" id="dc918fc8-bf52-4a6f-995d-78644962cb98">
        <source>getRailRakeSummaryForTrain(request : WS_RailRakeSummaryRequest) : WS_RailRakeSummaryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Apr 2017	cnwsc8	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	completedOK 	: Boolean;
	str				: String;
	response  		: WS_RailRakeSummaryResponse;
	train			: CM_Train;
	terminal 		: CM_Terminal;
	details			: JadeDynamicObjectArray;
	jdo				: JadeDynamicObject;
	obj				: Object;
	railLine		: CM_RailLine;
	rline			: CM_RailLine;
	summaryLine		: WS_RailRakeSummary;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	
	if request.rakeUid = "" then
		completedOK := true;
		return response;
	endif;

	if request.trainUid = "" then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17 
	railLine := app.myPassport.getObjectOfTypeFromOid(request.rakeUid,CM_RailLine).CM_RailLine;
	if railLine = null then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	train := app.myPassport.getObjectOfTypeFromOid(request.trainUid,CM_Train).CM_Train;
	if train = null then
		completedOK := true;
		return response;
	endif;
		
	details := railLine.getWagonSummary(request.inwards, train, null, request.localConfirmedCargo);

	if details = null then
		completedOK := true;
		return response;
	endif;
	
	
	foreach jdo in details do
		create summaryLine transient;
		summaryLine.color := jdo.getPropertyValue("color").Integer;
		summaryLine.level := jdo.getPropertyValue("level").Integer;
		summaryLine.text  := jdo.getPropertyValue("text").String;
		obj := jdo.getPropertyValue("object").Object;
		if obj &lt;&gt; null then
			summaryLine.objectUid := obj.getOidAsString();
		endif;
		response.allSummaryLines.add(summaryLine);
	endforeach;

	completedOK:=true;
	return response;
epilog
	if details &lt;&gt; null then
		details.purge; //epr TFS 3670 21/4/17
		delete details;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_RailRakeSummaryRequest"/>
        <ReturnType type="WS_RailRakeSummaryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReleaseRequestTypes" id="0c45f8d5-0336-4deb-855f-bafa8ea5df77">
        <usesRPC>default</usesRPC>
        <source>getReleaseRequestTypes() : WS_ReleaseRequestTypesResponse webService;
/*
Purpose:	

Date		Who		Reason
30/12/2008	cnwdz2	PAR #17554 - Development of new RIA Web Service application
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string constants
29/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - new release request type of Unknown
*/

vars
	response			: WS_ReleaseRequestTypesResponse;
	completedOK			: Boolean;
	releaseRequestType	: WS_ReleaseRequestType;
	
	canArchive,canViewRail, canViewRoad,canViewPacking, canViewShip,
	canViewUnknown		:Boolean;
	
	passport	: CM_Passport;
	user		: CM_User;
	terminal	: CM_Terminal;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
		
	// Create the response
	create response transient;
	
	passport 	:= app.myPassport;
	user 		:= passport.myUser;
	terminal 	:= passport.myTerminal;
	
	canArchive 		:= app.myCurrentUserCan(terminal, PmGteMTReleaseArchive);
	canViewRail 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewRail);
	canViewRoad 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewRd);
	canViewPacking 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewGen);
	canViewShip 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewShip);
	canViewUnknown 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewUnknown);	// par 28696
		
	// Populate response
	if canViewRail or canViewRoad or canViewPacking or canViewShip or canViewUnknown then 	// par 28696
		create releaseRequestType transient;
		releaseRequestType.description 	:= BR_TYPE_ALL_STR;								// PAR #27972
		releaseRequestType.id 			:= 1000;
		releaseRequestType.setOidFromId("1000");
		response.allReleaseRequestTypes.add(releaseRequestType);
	endif;
	
	if canViewRoad then
		create releaseRequestType transient;
		releaseRequestType.description 	:= BR_TYPE_ROAD_STR;								//PAR #27972
		releaseRequestType.id 			:= BR_TYPE_ROAD;
		releaseRequestType.setOidFromId(BR_TYPE_ROAD.String);
		response.allReleaseRequestTypes.add(releaseRequestType);
	endif;
	
	if canViewRail then
		create releaseRequestType transient;
		releaseRequestType.description 	:= BR_TYPE_RAIL_STR;								// PAR #27972
		releaseRequestType.id 			:= BR_TYPE_RAIL;
		releaseRequestType.setOidFromId(BR_TYPE_RAIL.String);
		response.allReleaseRequestTypes.add(releaseRequestType);		
	endif;
	
	if canViewPacking then
		create releaseRequestType transient;
		releaseRequestType.description 	:= BR_TYPE_PACKING_STR;							// PAR #27972
		releaseRequestType.id 			:= BR_TYPE_PACKING;
		releaseRequestType.setOidFromId(BR_TYPE_PACKING.String);
		response.allReleaseRequestTypes.add(releaseRequestType);
	endif;
	
	if canViewShip then
		create releaseRequestType transient;
		releaseRequestType.description 	:= BR_TYPE_SHIP_STR;								// PAR #27972
		releaseRequestType.id 			:= BR_TYPE_SHIP;
		releaseRequestType.setOidFromId(BR_TYPE_SHIP.String);
		response.allReleaseRequestTypes.add(releaseRequestType);		
	endif;
	
	if canViewUnknown then		// par 28696
		create releaseRequestType transient;
		releaseRequestType.description 	:= BR_TYPE_UNKNOWN_STR;								
		releaseRequestType.id 			:= BR_TYPE_UNKNOWN;
		releaseRequestType.setOidFromId(BR_TYPE_UNKNOWN.String);
		response.allReleaseRequestTypes.add(releaseRequestType);		
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getReleaseRequestTypes</wsdlName>
        <ReturnType type="WS_ReleaseRequestTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReleaseWOsForExtension" id="47628c21-5d1a-43d7-8aec-e32ef3ee9351">
        <source>getReleaseWOsForExtension() : WS_WorkOrdersResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars
	response : WS_WorkOrdersResponse;
	completedOK : Boolean;
	proxyWorkOrder : WS_WorkOrder;
	wo : CM_WorkOrder;
	iter : Iterator;
	startObject : CM_WorkOrder;
	prospects : CM_WorkOrderByIdDict;
	terminal : CM_Terminal;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;		
	
	app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	create prospects transient;
	terminal := app.myPassport.myTerminal;
	
	iter := terminal.allWorkOrdersByStatus.createIterator;
	startObject := terminal.allWorkOrdersByStatus.getAtKeyGeq( WO_STATUS_APPROVED );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( wo ) do
			if wo.taskStatus &lt;&gt; WO_STATUS_APPROVED then
				break;
			endif;
			if wo.isWorkOrderForRelease then
				prospects.addNoDuplicates( wo, false );
			endif;
		endwhile;
	endif;
	delete iter;
	
	iter := terminal.allWorkOrdersByStatus.createIterator;
	startObject := terminal.allWorkOrdersByStatus.getAtKeyGeq( WO_STATUS_PARTCOMPLETE );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( wo ) do
			if wo.taskStatus &lt;&gt; WO_STATUS_PARTCOMPLETE then
				break;
			endif;
			if wo.isWorkOrderForRelease then
				prospects.addNoDuplicates( wo, false );
			endif;
		endwhile;
	endif;
	delete iter;
	
	
	foreach wo in prospects discreteLock  do
		
		if not wo.allWoDtls.first.CM_WodRelease.isAvailableForExtension() then
			continue;
		endif;
		
		create proxyWorkOrder transient;
		proxyWorkOrder.setProxyFromObject(wo);
		response.allWorkOrders.add(proxyWorkOrder);
		
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog

	delete iter;
	delete prospects;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_WorkOrdersResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getReportOutputFormats" id="fccc4715-ddc2-4e9e-8ccf-988b44290829">
        <usesRPC>default</usesRPC>
        <source>getReportOutputFormats() : WS_ReportOutputFormatsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2008	cnwkao1	Initial creation - getOutputFormatsForReport without taking a parameter

*/

vars
	report			: CM_QryReport;
	reportFormats	: IntegerArray;
	reportFormat	: WS_ReportOutputFormat;
	response		: WS_ReportOutputFormatsResponse;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
