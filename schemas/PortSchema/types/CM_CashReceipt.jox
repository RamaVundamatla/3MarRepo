    <JadeMethod name="clearInvalidTiRefs" id="efe58c36-c9f9-4ad3-b97f-55cacd339e6d">
        <source>clearInvalidTiRefs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2016	cnwndl1	Initial creation	TFS 1726

*/

vars

	localTiArray : CM_TIArray;

begin

	create localTiArray transient;
	self.getAllGoodTrackedItems( localTiArray );
	
	self.allTrackedItems.clear();
	if not localTiArray.isEmpty then
		localTiArray.copy( self.allTrackedItems );
	endif;

epilog

