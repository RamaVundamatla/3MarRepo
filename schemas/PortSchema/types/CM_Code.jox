    <JadeMethod name="validateForCreate" id="29310f69-4755-4150-8b8a-acff5499c7b2">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars

begin
	if (not self.isCodeGroupNOTRequired) and
	   self.myCodeGroup = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'code group', 'myCodeGroup', null);
		app.raiseCMException(Input_required_field_codeGrp, 'myCodeGroup', null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.myCodeGroup &lt;&gt; null and
	   self.myCodeGroup.allCodes.includesKey(self.code) then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
	endif;
	
	self.validateMe();
end;</source>
    </JadeMethod>
