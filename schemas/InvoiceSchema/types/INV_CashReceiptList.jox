    <JadeMethod name="deleteProxyCashReceipt" id="7df32002-8fd2-481c-b724-c36a78ed9ae0">
        <updating/>
        <source>deleteProxyCashReceipt() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2019	jlgab1	Initial creation

*/

vars
	tmpController : CMIF_ProformaInvLinesForDebtor;

begin

	if self.myProxyCashReceipt &lt;&gt; null then
		// TFS 45953 collect transients so they can be deleted later
		create tmpController transient;
		tmpController.populateAllTransients(self.myProxyCashReceipt.allCashPayments);
		tmpController.allTransientsToDelete.purge;
		delete tmpController;

		delete self.myProxyCashReceipt;
	endif;
end;
</source>
