    <JadeMethod name="hasHadStop" id="37ffa27b-f909-4fdf-92d7-32c864709ab0">
        <source>hasHadStop(_stopID : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars

	theAddedStops	: IntegerArray;
	txn				: CM_BOLTransaction;
	
begin

	create theAddedStops transient;

	foreach txn in self.allBOLTransactions where txn.type = TRANS_TYPE_STOPSET and (not txn.isDeleted) do
		theAddedStops.add(txn.CM_BOLStopCreated.stopID);	
	endforeach;

	if theAddedStops.includes(_stopID) then
		return true;
	endif;

	return false;

epilog

	delete theAddedStops;
	
end;
</source>
        <Parameter name="_stopID" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
