    <JadeMethod name="addRowFromXML" id="fae018ad-111c-4bc7-9d95-277e73e02267">
        <source>addRowFromXML(pStr : String);
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

end;</source>
        <Parameter name="pStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRow" id="22b7135e-ccd3-4977-9d2c-ca69c0f920f2">
        <source>getEntTableRow(_rowName:String):EntTableRow;
/*
Purpose:			

Date		Who		Reason
01JUL2021	NAVAB1	TFS 51361
*/

vars
	tableRowObj	: EntTableRow;
	
begin
	foreach tableRowObj in self.allEntTableRowsByName do
		if tableRowObj.name = _rowName then
			return tableRowObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getName" id="32f2eb0d-1a13-4757-8091-18d8ac996331">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     09 November 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.String &amp; ' (' &amp; self.name &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNameFromErrorReturnString" id="a986bb01-96b1-4f13-a63d-e42565bef5e6">
        <source>getNameFromErrorReturnString(pErrorReturn : String) : String;
// ---------------------------------------------------------------------------
// Created:     09 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow	: EntTableRow;
	tmpName	: String;
	
begin

	tmpRow := self.allEntTableRowsByErrorRtn[pErrorReturn];
	
	if tmpRow &lt;&gt; null then
		tmpName := tmpRow.name;
	else
		tmpName := pErrorReturn;
	endif;
	
	return tmpName;

end;</source>
        <Parameter name="pErrorReturn" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="ca74f271-6cd4-4c67-9778-717ed6b7f850">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlStr	: String;

begin

	xmlStr := self.formatAsXMLPrefix(XMLTag_EntTableGroup) &amp;
			  self.formatAsXML(XMLTag_GroupName, self.name.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_ConstantName, self.constantName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXMLSuffix(XMLTag_EntTableGroup);
	
	return xmlStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="906b3b4b-9b61-436c-9565-48dbfeadb3de">
        <updating/>
        <source>set(pName, pText : String; pRoot : EntTableDataRoot) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name 	:= pName;
	self.text	:= pText;
	
	self.myEntTableDataRoot := pRoot;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pRoot" type="EntTableDataRoot"/>
    </JadeMethod>
    <JadeMethod name="setConstantName" id="6659e529-270b-4383-b9fa-79ce6b3906fe">
        <updating/>
        <source>setConstantName() updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpName	: String;
	
begin

	tmpName := self.myEntTableDataRoot.translateConstantName(GroupType, self.name);
	
	self.constantName := GroupPrefix &amp; tmpName[1].toUpper &amp; tmpName[2:end];

end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b9309f9c-dc88-4f56-b6a8-874a477b01c5">
        <updating/>
        <source>setForUpdate(_name : String) updating;
// ---------------------------------------------------------------------------
// Created:     25 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := _name;

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
</Class>
