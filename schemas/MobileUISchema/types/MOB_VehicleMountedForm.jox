    <JadeMethod name="btnReject_click" id="da30216b-d37c-44ba-aee0-dc7ff3f2ba5e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReject_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation

*/

vars
	rejectedOK : Boolean;
	timeRemaining 	: Integer;
	option 			: Integer;
begin
	self.addInfoDisplay(null);
	rejectedOK:=true;
	if self.isEnquiryMode or self.isShowOverstowCargo then
		rejectedOK:=self.doRejectNonRTCargo();
	elseif self.frmTaskTable.visible and self.isInDischargeMode then //epr par  25518 20/8/10
		self.doResetSearch();
	else
		
		self.doRejectTasks(true);
	endif;
	
	if rejectedOK then
		self.btnAccept.caption:= app.getErrorString(Accept); //epr par 34740 22/8/14
		if self.getTimerStatus(self.Timer_Move,option  ,timeRemaining) then
			self.endTimer(self.Timer_Move);
			self.btnAccept.enabled:=true;
		endif;
	endif;
epilog
	self.btnReject.value := false;		//+cnwml2 PAR26347 SFW CCMS 1099

		
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
