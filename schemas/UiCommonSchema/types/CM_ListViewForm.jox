    <JadeMethod name="queryUnload" id="23ef0a4f-ef58-45b5-a2e1-53153104eb3a">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/* AA 29/6/01: If adding or editing then ask user if they want to abandon edits.
This happens when the form itself is closed or the MDI frame is closed. When the
MDI frame is closed, the user gets a message box for each window being edited.

*/
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin
	if mode &lt;&gt; Mode_View then
		if reason = QueryUnload_User or reason = QueryUnload_MdiChild then
			result := app.msgBox(app.getErrorString1(ConfirmCancel,  'the object' ), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
