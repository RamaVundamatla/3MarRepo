<Class name="CM_EnqControllerHMSTrans" id="7d64fb7b-6e08-47c0-8c33-7c4a02e6b28e">
    <superclass name="CM_EnqControllerTransaction"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="endDateTime" id="3833e6be-6a82-44b9-b21a-302c19240fa1">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="23d6dc5a-a6c7-4ce9-8ffd-ca209916cc62">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <PrimAttribute name="startDateTime" id="9b68eb5c-973a-43f4-acad-84300d08e8d5">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="doDateSearch" id="d674f63b-cfa9-4cc5-9117-c3798861582d">
        <updating/>
        <source>doDateSearch() protected, updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
//11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
vars
	iteratorObj		: Iterator;
	transObj		: HMS_Transaction;
	keyTimeStamp	: TimeStamp;
	type,
	keyType			: Integer;
	breakOut		: Boolean;
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	
	type := Trans_Type_ResourceCharged;		// only HMS_VTMISTransactions 
	iteratorObj	:=	myTerminal.allHMSTransactionsByTypeDate.createIterator();
	myTerminal.allHMSTransactionsByTypeDate.startKeyGeq(type, self.startDateTime, iteratorObj);
	
	while iteratorObj.next(transObj) do
		iteratorObj.getCurrentKeys(keyType,keyTimeStamp);  //MTN-35226
		
			if (keyType &lt;&gt; type) or
			   (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
			break;
		endif;
		
		if self.includesObject(transObj, breakOut, passport) then
			self.addObjectToSet(transObj);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="f4c7b4c7-c723-4ea9-a882-33b3a2485c85">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
// top-level search by terminal then either date or event type
vars
	now				: TimeStamp;
	crit			: CM_SelectorCriteriaLine;
	termSet			: CM_TerminalSet;
	ut				: CM_UserTerminal;
	tranType		: CM_TransactionType;
	term			: CM_Terminal;
begin

	self.reset();
	now := app.actualTimeServer();
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['transactionDT', _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
			self.startDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.startDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.endDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	create termSet transient;	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['myTerminal', _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;

	if not termSet.isEmpty then
		foreach term in termSet do
			self.myTerminal := term;
			self.doSearch;
		endforeach;
	endif;
	
epilog
	endLoad;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="f8455d7b-343b-451b-adb6-00ca33c584f1">
        <updating/>
        <source>doSearch() updating, protected;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars

begin
	self.doDateSearch();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="29ac570a-c64a-4676-bb85-7f43d672b489">
        <updating/>
        <source>reset() updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars

begin
	inheritMethod();
	
	self.myTerminal := null;
	self.startDateTime := null;
	self.endDateTime := null;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="e993d9dc-b1f6-482d-a96a-bbcb8747d2b6">
        <updating/>
        <source>setMyFilterClass() updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars

begin
	self.myFilterClass := HMS_VTMISTransaction;

end;</source>
    </JadeMethod>
</Class>
