    <JadeMethod name="tIFTMBC98BCommodityDescrDef1" id="06d0a336-3cbe-49f8-90db-8578d4f9cae9">
        <updating/>
        <source>tIFTMBC98BCommodityDescrDef1() updating;
///25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// Test the loading of commodity description default when FTX+AAA is after TMP
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	VoyageName = "UTV101";
	ShipName = "UTBOAT";
	BookingRefNo1 = "528282976";
	BookingRefNo2 = "528282977";
	BookingRefNo3 = "528282978";
	BookingRefNo4 = "528282979";
	Commodity1 = "FROZEN VEGAN";
	Commodity2 = "FROZEN FISHERMAN";
	Commodity3 = "A PILE OF STUFF";
	Commodity4 = "DANGEROUS HOT FISH";
	LloydsNumber = "9227314";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	booking : CM_BookingRef;
	text : String;
	bookingItem : CM_BookingRefItem;
	operatorCode : String;
	tempStr : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiBookingCommodity, true);
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	self.deleteBooking(BookingRefNo1);
	self.deleteBooking(BookingRefNo2);
	self.deleteBooking(BookingRefNo3);
	self.deleteBooking(BookingRefNo4);
	self.opts.addAssoc(ETRow_LloydsNumber, '9227314');
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	vessel := self.addVesselCellular(ShipName, self.getOperator(operatorCode));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, operatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	text :=
"UNA:+,? '
UNB+UNOC:1+"&amp;operatorCode&amp;"+SFL+0908210954:1403110+207'
UNH+1403111+IFTMBC:D:98B:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingRefNo1&amp;"'
TDT+12+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+SGSIN'
LOC+7+IDBLW'
NAD+MS+"&amp;operatorCode&amp;"'
GID+1'
TMP+2+-020:CEL'
FTX+AAA+++"&amp;Commodity1&amp;"'
EQD+CN++22R1+++5'
EQN+7'
MEA+AAE+AAB+KGM:147000'
UNT+16+1403111'
CNT+16:1'
UNT+11+281700001'
UNH+1403111+IFTMBC:D:98B:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingRefNo2&amp;"'
TDT+12+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+SGSIN'
LOC+7+IDBLW'
NAD+MS+MAE'
GID+1'
TMP+2+-020:CEL'
FTX+AAA+++"&amp;Commodity2&amp;"'
EQD+CN++45R1+++5'
EQN+7'
MEA+AAE+AAB+KGM:147000'
DGS+IMD+5.1+2014'
UNT+16+1403111'
CNT+16:1'
UNT+11+281700001'
UNH+1403111+IFTMBC:D:98B:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingRefNo3&amp;"'
TDT+12+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+SGSIN'
LOC+7+IDBLW'
NAD+MS+MAE'
GID+1'
FTX+AAA+++"&amp;Commodity3&amp;"'
EQD+CN++4230+++5'
EQN+7'
MEA+AAE+AAB+KGM:147000'
UNT+16+1403111'
CNT+16:1'
UNT+11+281700001'
UNH+1403111+IFTMBC:D:98B:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;BookingRefNo4&amp;"'
TDT+12+"&amp;VoyageName&amp;"+1++"&amp;operatorCode&amp;":172:87+++" &amp; LloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+SGSIN'
LOC+7+IDBLW'
NAD+MS+MAE'
GID+1'
FTX+AAA+++"&amp;Commodity4&amp;"'
EQD+CN++42G1+++5'
EQN+7'
DGS+IMD+5.1+2014'
MEA+AAE+AAB+KGM:147000'
UNT+16+1403111'
CNT+16:1'
UNT+11+281700001'
UNZ+1+2817'";
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMBC", "IFTMBC"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	booking := self.getBooking(BookingRefNo1);
	self.assertNotNull(booking);
	bookingItem := booking.allBookingRefItems.first;
	if bookingItem.isoType = "22R1" then
		self.assertEqual(bookingItem.commodity, "REEF");
		self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity1);
	else
		self.assertEqual(bookingItem.commodity, "********************");
	endif;
	booking := self.getBooking(BookingRefNo2);
	self.assertNotNull(booking);
	bookingItem := booking.allBookingRefItems.first;
	if bookingItem.isoType = "45R1" then
		self.assertEqual(bookingItem.commodity, "REEF");
		self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity2);
	else
		self.assertEqual(bookingItem.commodity, "********************");
	endif;
	booking := self.getBooking(BookingRefNo3);
	self.assertNotNull(booking);
	bookingItem := booking.allBookingRefItems.first;
	if bookingItem.isoType = "4230" then
		self.assertEqual(bookingItem.commodity, "TBA");
		self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity3);
	else
		self.assertEqual(bookingItem.commodity, "********************");
	endif;
	booking := self.getBooking(BookingRefNo4);
	self.assertNotNull(booking);
	bookingItem := booking.allBookingRefItems.first;
	if bookingItem.isoType = "42G1" then
		self.assertEqual(bookingItem.commodity, "HAZD");
		self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity4);
	else
		self.assertEqual(bookingItem.commodity, "********************");
	endif;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
    </JadeMethod>
