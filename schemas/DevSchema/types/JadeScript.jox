    <JadeMethod name="ma161219" id="a6e4fc97-2257-4c29-9a31-266322ec8a7c">
        <source>ma161219();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2019	jlgma1	Initial creation

*/

vars
	glcode : CM_GLCode;
	str    : String;
	terminal : CM_Terminal;
	invoice  : CM_Invoice;
	invLine  : CM_InvoiceLine;
	roundDecimalOpt : Integer;
begin
	
	invoice := "2216.820262".asOid.CM_Invoice;
	
	foreach invLine in invoice.invoiceLines discreteLock do
	
		
		if invLine.getMyTerminal &lt;&gt; null then
			roundDecimalOpt := invLine.getMyTerminal.getConfig(InvoiceRoundLineTotal).Integer;
