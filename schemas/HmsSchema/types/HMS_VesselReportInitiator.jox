    <JadeMethod name="runReport" id="cbd1bc7f-ebf1-4c69-9f9e-f13f3b71ef0a">
        <updating/>
        <source>runReport() protected, updating;
// -------------------------------------------
// Created 11 May 2004 by cnwdvb1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// -------------------------------------------
vars

	ts 				: TimeStamp;
	pxyRptParam		: HMS_ReportParam;
	report			: HMS_TGACustomReport;
	pilot,
	tugmaster,
	supervisor,
	launchmaster	: String;
	hmsObject 		: HMS_Object;
	tmpReportOutput	: JadeReport;	// PAR13089
	
begin

	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;
	
	create report transient;
	report.myHarbour := self.myHarbour;
//	ts.setDate(self.tblEntry.getValueByName(ETRow_FromDate).Date);
	ts.setDate(self.tblEntry.getValueAsDate(ETRow_FromDate));
	ts.setTime(self.tblEntry.getValueByName(ETRow_FromTime).Time);
	report.portDate_From := ts;
//	ts.setDate(self.tblEntry.getValueByName(ETRow_ToDate).Date);
	ts.setDate(self.tblEntry.getValueAsDate(ETRow_ToDate));
	ts.setTime(self.tblEntry.getValueByName(ETRow_ToTime).Time);
	report.portDate_To := ts;

	// Save user settings for report
	pilot 		:= self.tblEntry.getValueByName(ETRow_Pilot).String;
	tugmaster	:= self.tblEntry.getValueByName(ETRow_Tugmaster).String;		
	launchmaster:= self.tblEntry.getValueByName(ETRow_Launchmaster).String;
	supervisor	:= self.tblEntry.getValueByName(ETRow_Supervisor).String;
	if self.reportParam &lt;&gt; null then
		pxyRptParam := app.createUpdateProxy(self.reportParam).HMS_ReportParam;
		pxyRptParam.setProxy(self.myHarbour, launchmaster, pilot, supervisor, tugmaster, app.myPassport.userCode);
		app.myTrxUA.trxUpdateHMSObject(pxyRptParam, app.myPassport);
	else
		create pxyRptParam transient;
		pxyRptParam.setProxy(self.myHarbour, launchmaster, pilot, supervisor, tugmaster, app.myPassport.userCode);
		app.myTrxCA.trxCreateHMSObject(pxyRptParam, hmsObject, app.myPassport);
		if hmsObject &lt;&gt; null then
			self.reportParam := hmsObject.HMS_ReportParam;
		endif;
	endif;
	report.textPilot		:= pilot;
	report.textTugmaster	:= tugmaster;
	report.textSupervisor	:= supervisor;
	report.textLaunchmaster	:= launchmaster;
	
	create tmpReportOutput transient;				// PAR13089
	tmpReportOutput.description := report.caption;	// PAR13089
	app.printer.setReport(tmpReportOutput);			// PAR13089

	app.printer.setMargins(Print_Landscape,5,0,5,0);

	app.printer.printPreview := false;
	report.processReport();
	
	app.printPreview(tmpReportOutput, true);		// PAR13089

epilog
	delete pxyRptParam;	
	delete report;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ed2912a4-6192-43c1-959e-8d2bee3ceeac">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// -------------------------------------------
vars
	weipaShippingSchedule : Boolean;
begin

	if self.reportType = HMS_ReportInitiatorBase.HMS_ReportType_VoyageList then
		self.caption := HMS_VesselReportInitiator.SHIPPING_COMPLAN_REPORT_NAME &amp; ' Initiation'; //16988 cnwdz2
		self.lblDescription.caption := 'This report prints vessel details for the supplied date range.';
	else
		self.caption := HMS_VesselReportInitiator.WORK_ORDERS_REPORT_NAME &amp; ' Initiation'; //16988 cnwdz2
		self.lblDescription.caption := 'This report prints Work Orders and Berth Meterage details for the supplied date range.';	
	endif;
	
	self.frmPrinter.visible := false;
	self.minimumHeight := 310;
	self.minimumWidth := 260;
	
	inheritMethod();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="74954260-acfc-4f9b-bc33-f9daa671c093">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:40:27.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022929, locale);
end;</source>
    </JadeMethod>
</GUIClass>
