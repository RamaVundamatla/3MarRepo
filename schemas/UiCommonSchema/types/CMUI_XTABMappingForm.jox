    <JadeMethod name="setControlsForMapping" id="f7196f79-03af-4ce4-b769-47800dd7d17b">
        <updating/>
        <source>setControlsForMapping() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation

*/

vars

begin

	// make all operator controls invisble initially;
	self.setControlsForOperator (txtValue1, txtValue2, txtDate1, txtDate2, txtTime1, txtTime2, lblValue, lblAnd, cmbValue, tblValue, true, self.myQueryProperty, null);
	
	// set up the table details
	self.initMappingTable();
	
	// load the data
	self.loadMapping( 0 );
	
	//setup the Mapping Table Buttons
	self.setMappingLineTableButtons();
	
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForOperator" id="13b23450-184c-419c-89b4-c143134f5329">
        <updating/>
        <source>setControlsForOperator(_txtValue1, _txtValue2 :TextBox input;
						_txtFromDate, _txtToDate :CMUI_DateMask input;
						_txtFromTime, _txtToTime :CMUI_TimeMask input;
						_lblValue, _lblAnd :Label input; _cmbValue :ComboBox input; _tblValues :Table input;
						_update :Boolean; 
						_property :CM_QueryProperty; _operator :CM_QueryOperator) updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	: Integer;
	array	: ObjectArray;
	params  : CM_QueryCriteriaLineHolder; 
begin
	// NOTE:
	// we could use this method in the selector as well if we moved it onto an Assistant class
	_txtFromDate.visible 	:= false;
	_txtToDate.visible 		:= false;
	_lblValue.visible 		:= false;
	_lblAnd.visible 		:= false;
	_txtValue1.visible 		:= false;
	_txtValue2.visible 		:= false;
	_cmbValue.visible 		:= false;
	_tblValues.visible 		:= false;

	if _property = null or _operator = null then
		return;
	endif;
	
	_lblValue.visible := true;
	
	type := _property.getControlTypeForOperator(_operator);
	
	if type = QueryControl_TextBox then
		_property.setTextValues(_txtValue1, null, _operator, app.myPassport);
		_txtValue1.visible := true;
		_txtValue1.enabled := _update;
		
	elseif type = QueryControl_ComboBox then
		_property.setComboValues(_cmbValue, null,_operator, app.myPassport);
		_cmbValue.visible := true;
		_cmbValue.enabled := _update;
		
	elseif type = QueryControl_MultiSelect then
		create params transient;
		_property.setListValues(_tblValues, params, _operator, app.myPassport);
		_tblValues.visible := true;
		_tblValues.enabled := _update;
		
	elseif type = QueryControl_Date then
		_property.setDateValues(_txtFromDate, null, _operator, app.myPassport);
		_txtFromDate.visible := true; //always use fromDate box for single date comparison
		_txtFromDate.enabled := _update;
		
	elseif type = QueryControl_DateRange then
		create array transient;
		array.add(_txtFromDate);
		array.add(_txtToDate);
		
		if _property.isKindOf(CM_QDateProperty) then
			_property.CM_QDateProperty.setDateRangeValues(array, null, _operator, app.myPassport);
		else
			_property.CM_QDateMethod.setDateRangeValues(array, null, _operator, app.myPassport);	// 27/01/2009 CCMS-1734 (#18809) cnwar2
		endif;
		
		_txtFromDate.visible 	:= true;
		_txtToDate.visible 		:= true;
		_lblAnd.visible 		:= true;
		
		_txtFromDate.enabled 	:= _update;
		_txtToDate.enabled 		:= _update;
		
	elseif type = QueryControl_NumTextBoxRange then
		create array transient;
		array.add(_txtValue1);
		array.add(_txtValue2);
		
		if _property.isKindOf(CM_QDateProperty) then
			_property.CM_QDateProperty.setTextRangeValues(array, null, _operator, app.myPassport);
		else
			_property.CM_QDateMethod.setTextRangeValues(array, null, _operator, app.myPassport);	// 27/01/2009 CCMS-1734 (#18809) cnwar2
		endif;
		
		_txtValue1.visible 	:= true;
		_txtValue2.visible 	:= true;
		_lblAnd.visible 	:= true;
		
		_txtValue1.enabled 	:= _update;
		_txtValue2.enabled 	:= _update;
		
	//14 may 2012	NDL	Par 29532	
	elseif type = QueryControl_Time then
		_property.setTimeValues(_txtFromTime, null, _operator, app.myPassport);
		_txtFromTime.visible := true;
		_txtFromTime.enabled := _update;
	
	//14 may 2012	NDL	Par 29532
	elseif type = QueryControl_TimeRange then
		create array transient;
		array.add(_txtFromTime);
		array.add(_txtToTime);
		
		_property.CM_QTimeMethod.setTimeRangeValues(array, null, _operator, app.myPassport);
		
		_txtFromTime.visible 	:= true;
		_txtToTime.visible 		:= true;
		_lblAnd.visible 		:= true;
		
		_txtFromTime.enabled 	:= _update;
		_txtToTime.enabled 		:= _update;
		
	endif;

epilog
	delete params;
	delete array;		// PAR #27874
	
end;</source>
        <Parameter name="_txtValue1" type="TextBox" usage="input"/>
        <Parameter name="_txtValue2" type="TextBox" usage="input"/>
        <Parameter name="_txtFromDate" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_txtToDate" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_txtFromTime" type="CMUI_TimeMask" usage="input"/>
        <Parameter name="_txtToTime" type="CMUI_TimeMask" usage="input"/>
        <Parameter name="_lblValue" type="Label" usage="input"/>
        <Parameter name="_lblAnd" type="Label" usage="input"/>
        <Parameter name="_cmbValue" type="ComboBox" usage="input"/>
        <Parameter name="_tblValues" type="Table" usage="input"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="setMappingLineTableButtons" id="538bed33-d422-45fb-b7e8-ab2314642a55">
        <updating/>
        <source>setMappingLineTableButtons() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation

*/

vars

	index : Integer;
	line : CM_XTABMappingLine;
	
begin

	line := getFirstSelectedLine(index);
	self.cmbOperator.listIndex := -1;
	self.doCmbOperatorClick();
	
	if line = null then
		btnUpdate.enabled := false;
		btnDelete.enabled := false;
		btnMoveUp.enabled := false;
		btnMoveDown.enabled := false;
		self.txtMapValue.text := null;
	else
		btnUpdate.enabled := true;
		btnDelete.enabled := true;
		btnMoveUp.enabled := index &gt; tblMappings.fixedRows + 1;
		btnMoveDown.enabled := index &lt; tblMappings.rows;
		if line.myQueryOperator &lt;&gt; null then
			self.cmbOperator.listIndex := self.cmbOperator.findStringExact(1,line.myQueryOperator.description);
			self.setControlsForOperator (txtValue1, txtValue2, txtDate1, txtDate2, txtTime1, txtTime2, lblValue, lblAnd, cmbValue, tblValue, true, self.myQueryProperty, line.myQueryOperator);
		endif;
		self.txtMapValue.text := line.mappedValue;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyOrder" id="4582c33b-483d-4283-8560-381c1623435f">
        <source>setProxyOrder()protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_XTABMapping;
	value	:Integer;
begin
	proxy 	:= self.myProxyObject.CM_XTABMapping;
	
	if optOrderValue.value then
		value	:= CM_XTABMapping.ORDER_MAPPING_VALUE;
	else
		value	:= CM_XTABMapping.ORDER_MAPPING;
	endif;
	
	if proxy.order &lt;&gt; value then
		proxy.setOrder (value);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxyOtherValues" id="cd66ce17-d251-4832-954b-f11ff15220aa">
        <source>setProxyOtherValues() protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_XTABMapping;
	value	:Integer;
begin
	proxy 	:= self.myProxyObject.CM_XTABMapping;
	
	if optGrpHeading.value then
		value	:= CM_XTABMapping.OTHER_GROUPED;
	else
		value	:= CM_XTABMapping.OTHER_SEPERATE;
	endif;
	
	if proxy.order &lt;&gt; value then
		proxy.setOtherValues (value);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSearchValueOnOperator" id="7bee20e8-742c-4459-b5b7-f91cb5ca9be9">
        <source>setSearchValueOnOperator(	_txtValue1, _txtValue2 :TextBox input;
						_txtFromDate, _txtToDate :CMUI_DateMask input;
						_txtFromTime, _txtToTime :CMUI_TimeMask input;
						_cmbValue :ComboBox input; _tblValues :CMUI_ListTable input;
						_property :CM_QueryProperty; _operator :CM_QueryOperator io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	cnwndl1	Initial creation

*/

vars

	type : Integer;
	value : Any;
	dateArray : DateArray;
	rangeArray : IntegerArray;
	timeArray : TimeArray;
	
begin
	
	if _property = null or _operator = null then
		return;
	endif;
	
	type := _property.getControlTypeForOperator(_operator);
	
	if type = QueryControl_TextBox then
		value := _txtValue1.text;
		value := _property.translateToSearchValue(value);
		_operator.setSearchValue( value );
		
	elseif type = QueryControl_ComboBox then
		value := _cmbValue.listObject;
		if value = null then
			value := _cmbValue.text;
		endif;	
		value := _property.translateToSearchValue(value);
		_operator.setSearchValue( value );
		
	elseif type = QueryControl_MultiSelect then
		_property.setValuesFromList(_tblValues, _operator);	//CMUI_ListTable
		
	elseif type = QueryControl_Date then
		value := _txtFromDate.text; 
		value := _property.translateToSearchValue(value);
		_operator.setSearchValue(value);
		
	elseif type = QueryControl_DateRange then
		create dateArray transient;
		dateArray.add( _txtFromDate.getDate );
		dateArray.add( _txtToDate.getDate );
		_operator.setSearchValue(dateArray);
		
	elseif type = QueryControl_NumTextBoxRange then
		create rangeArray transient;
		rangeArray.add(_txtValue1.text.Integer);
		rangeArray.add(_txtValue2.text.Integer);
		_operator.CM_QDateDayRange.setSearchValue(rangeArray);
	//14 May 2012	NDL	Par 29532
	elseif type = QueryControl_Time then
		value := _txtFromTime.text; 
		value := _property.translateToSearchValue(value);
		_operator.setSearchValue(value);
	//14 May 2012	NDL	Par 29532	
	elseif type = QueryControl_TimeRange then
		create timeArray transient;
		timeArray.add( _txtFromTime.getTime );
		timeArray.add( _txtToTime.getTime );
		_operator.setSearchValue(timeArray);
	
	endif;

epilog

	delete dateArray;
	delete rangeArray;
	delete timeArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_txtValue1" type="TextBox" usage="input"/>
        <Parameter name="_txtValue2" type="TextBox" usage="input"/>
        <Parameter name="_txtFromDate" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_txtToDate" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_txtFromTime" type="CMUI_TimeMask" usage="input"/>
        <Parameter name="_txtToTime" type="CMUI_TimeMask" usage="input"/>
        <Parameter name="_cmbValue" type="ComboBox" usage="input"/>
        <Parameter name="_tblValues" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_operator" type="CM_QueryOperator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0a03d444-b2ad-4866-a1e4-e60ae34df63d">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	summaryName : String;
	niceName : String;
	formCaption : String;
begin
	inheritMethod();
	
	self.modalResult	:= IDCANCEL;
	self.centreOverParent( 20 );
	
	self.myQueryProperty := self.myXTABGrouping.getQueryProperty;
	
	if self.myXTABMapping &lt;&gt; null then
		self.myProxyObject := app.createUpdateProxy (self.myXTABMapping).CM_XTABMapping;
	else
		create self.myProxyObject as CM_XTABMapping transient;
		
		self.myProxyObject.CM_XTABMapping.setPropertyName (self.myQueryProperty);
		
	endif;
	
	self.setControlsForMapping;
	self.loadOperatorsCombo;
	
	if self.myXTABGrouping.myOutputFormat &lt;&gt; null then
		summaryName := self.myXTABGrouping.myOutputFormat.name; 
	endif;
	niceName := self.myQueryProperty.niceName;
	if summaryName &lt;&gt; null then
		formCaption := summaryName &amp; " / " &amp; niceName;
	else
		formCaption := niceName;
	endif;
	
	self.setCaption( app.getErrorString1(MappingFormCaption,formCaption));//"Mapping for ' " &amp; formCaption &amp; " '   ");
	
epilog

end;</source>
    </JadeMethod>
