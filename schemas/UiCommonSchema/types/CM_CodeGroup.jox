// ---------------------------------------------------------------------------
// Created:     07 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	code : CM_Code;	
	iter : Iterator;
	obj  : SOPVM_CodeGroup;
begin
	create obj transient;
	
	obj.initializeMe(self, _level, _parent);
	_collection.add(obj);
	//obj.myForm := _form;
/*	
	iter := self.allCodes.createIterator();
	while iter.next(code) do
		code.loadTreeViewArray(_collection, _level + 1, _form, obj);
	endwhile;
	
epilog
	delete iter;
	*/
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
</Class>
