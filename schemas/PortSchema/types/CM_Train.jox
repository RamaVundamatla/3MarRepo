    <JadeMethod name="isOutBound" id="2d310219-7557-4710-b8ef-99207557a1ba">
        <source>isOutBound() : Boolean;
/*
Purpose:			

Date		Who		Reason
10 December 2021	navab1	TFS 51853
*/

vars
	aT	:	Time;
	isPos	:	Integer;
	numDays	:	Integer;
	mins : Integer;
	
	nowTS : TimeStamp;
	thenTS : TimeStamp;
begin
	thenTS := self.scheduledDepartureDT;
	if not thenTS.isValid() then
		thenTS := self.departureDT;
	endif;
	
	if thenTS.isValid() then
	
		aT := nowTS.differenceAsTime(thenTS, isPos, numDays);

		// Is within 30 minutes in the past
		if numDays = 0
		and aT.hour = 0
		and isPos = 1 
		and aT.minute &gt;= 30 then
			return true;
		endif;
	endif;
	
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
