//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//there can be only one - (is null if file loads ok)
	//if this isn't null then they are abandoning the file load so we will delete
	if self.myEDIFileInError &lt;&gt; null then
		app.myTrxDA.trxDeleteEDIFile(self.myEDIFileInError, app.myPassport);
	endif;
	
	self.myEDIFileInError := _ediFile;

epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
