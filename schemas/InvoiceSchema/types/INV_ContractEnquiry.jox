    <JadeMethod name="fldMain_sheetChg" id="21679ae0-8409-4148-ba9a-cd8b09ecfe1f">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars

begin
	if fldMain.topSheet = self.shtContract then
		self.tblData.visible    := true;		//14.10.2024 navlc30 #19508
		self.tblDetails.visible	:= false;
		self.tblRates.visible   := false;
		self.btnQuerySelector.enabled	:= true;
		self.btnQueryVolume.enabled		:= true;
		self.btnAttachments.enabled		:= true;
		self.btnCopy.enabled			:= true;
		self.btnRemove.enabled			:= true;
		self.btnNew.enabled				:= true;
		self.btnBulkUpdate.enabled		:= true;		
	elseif fldMain.topSheet = self.shtDetails then
		self.tblData.visible    := false;		//14.10.2024 navlc30 #19508
		self.tblDetails.visible	:= true;
		self.tblRates.visible   := false;
		self.btnQuerySelector.enabled	:= false;
		self.btnQueryVolume.enabled		:= false;
		self.btnAttachments.enabled		:= false;
		self.btnCopy.enabled			:= false;
		self.btnRemove.enabled			:= false;
		self.btnNew.enabled				:= false;
		self.btnBulkUpdate.enabled		:= false;
	elseif fldMain.topSheet = self.shtRate then
		self.tblData.visible    := false;		//14.10.2024 navlc30 #19508
		self.tblDetails.visible	:= false;
		self.tblRates.visible   := true;
		self.btnQuerySelector.enabled	:= false;
		self.btnQueryVolume.enabled		:= false;
		self.btnAttachments.enabled		:= false;
		self.btnCopy.enabled			:= false;
		self.btnRemove.enabled			:= false;
		self.btnNew.enabled				:= false;
		self.btnBulkUpdate.enabled		:= false;		
	endif;
epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getContractsForBU" id="bf9c5b37-50f7-4605-a229-ef21c83522e5">
        <source>getContractsForBU();
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	contract : CM_InvoiceContract;
begin
	
	foreach contract in self.myCurrentBank.allInvoiceContractsById discreteLock do
		
		if not self.includeContract(contract, true) then
			continue;
		endif;
		
		self.addRowToTable(contract);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDates" id="329b7835-dcd4-4909-9746-c9281eebf09c">
        <source>getContractsForDates();
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	debtor : CM_Debtor;
	contract : CM_InvoiceContract;
	iter : Iterator;
begin

	// ### Contract fromTS filter has a start range
	if self.filterQueryContractFromStart.isValid() then
		contract := self.myCurrentBank.allInvoiceContractsByFromTS.getAtKeyGeq(self.localToSystemTime(self.filterQueryContractFromStart)); // ### TFS BUG 58796 26JUN2023 NAVAB1 - localToSystemTime
		iter := self.myCurrentBank.allInvoiceContractsByFromTS.createIterator();

		if contract = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.filterQueryContractFromEnd.isValid() then
				if self.systemToLocalTime(contract.fromTS) &gt; self.filterQueryContractFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
					break outerloop;
				endif;
			endif;

			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
				
		endwhile;

		delete iter;
		
		return;
	endif;
	
	// ### Contract fromTS filter has an end range, no start range
	if self.filterQueryContractFromEnd.isValid() then
		contract := self.myCurrentBank.allInvoiceContractsByFromTS.first;
		iter := self.myCurrentBank.allInvoiceContractsByFromTS.createIterator();

		if contract = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.systemToLocalTime(contract.fromTS) &gt; self.filterQueryContractFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
				break outerloop;
			endif;

			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
				
		endwhile;

		delete iter;
		
		return;
	endif;
	
	// ### Contract toTS filter has a start range
	if self.filterQueryContractToStart.isValid() then
		contract := self.myCurrentBank.allInvoiceContractsByToTS.getAtKeyGeq(self.localToSystemTime(self.filterQueryContractToStart)); // ### TFS BUG 58796 26JUN2023 NAVAB1 - localToSystemTime
		iter := self.myCurrentBank.allInvoiceContractsByToTS.createIterator();

		if contract = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.filterQueryContractToEnd.isValid() then
				if self.systemToLocalTime(contract.toTS) &gt; self.filterQueryContractToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
					break outerloop;
				endif;
			endif;

			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
				
		endwhile;

		delete iter;
		
		return;
	endif;
	
	// ### Contract toTS filter has an end range, no start range
	if self.filterQueryContractToEnd.isValid() then
		contract := self.myCurrentBank.allInvoiceContractsByToTS.first;
		iter := self.myCurrentBank.allInvoiceContractsByToTS.createIterator();

		if contract = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.systemToLocalTime(contract.fromTS) &gt; self.filterQueryContractToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
				break outerloop;
			endif;

			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
				
		endwhile;

		delete iter;
		
		return;
	endif;

epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDebtors" id="18a14ac9-fd8a-47af-866e-410519ec36ff">
        <source>getContractsForDebtors();
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	contract : CM_InvoiceContract;
	debtor : CM_Debtor;
begin
	
	foreach debtor in self.allDebtors discreteLock do

		foreach contract in debtor.allInvoiceContracts discreteLock do
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
		
		
		endforeach;
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDetailDates" id="313652eb-8993-4f8d-ae1c-17b536186dc5">
        <source>getContractsForDetailDates();
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	debtor : CM_Debtor;
	contract : CM_InvoiceContract;
	detail : CM_InvoiceContractDetails;
	iter : Iterator;
	contractSet : CM_InvoiceContractSet;
begin
	create contractSet transient;
	
	// ### DETAIL 'FROM' DATE RANGE
	if self.filterQueryDetailFromStart.isValid() 
	or self.filterQueryDetailFromEnd.isValid() then
		if self.filterQueryDetailFromStart.isValid() then // ### Detail fromTS filter has a start range
			detail := self.myCurrentBank.allInvoiceContractDetailByFrom.getAtKeyGeq(self.localToSystemTime(self.filterQueryDetailFromStart)); // ### TFS BUG 58796 26JUN2023 NAVAB1 - localToSystemTime
		endif;
		
		if detail = null then
			detail := self.myCurrentBank.allInvoiceContractDetailByFrom.first;
		endif;
		iter := self.myCurrentBank.allInvoiceContractDetailByFrom.createIterator();

		if detail = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(detail);
		
		while iter.next(detail) do : outerloop
			if self.filterQueryDetailFromEnd.isValid() then
				if self.systemToLocalTime(detail.fromTS) &gt; self.filterQueryDetailFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
					break outerloop;
				endif;
			endif;

			if not self.includeDetail(detail, false) then
				continue;
			endif;
			
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;
	
	// ### DETAIL 'TO' DATE RANGE
	elseif self.filterQueryDetailToStart.isValid() 
	or self.filterQueryDetailToEnd.isValid() then
		if self.filterQueryDetailToStart.isValid() then // ### Detail toTS filter has a start range
			detail := self.myCurrentBank.allInvoiceContractDetailByTo.getAtKeyGeq(self.localToSystemTime(self.filterQueryDetailToStart)); // ### TFS BUG 58796 26JUN2023 NAVAB1 - localToSystemTime
		else	// ### Detail toTS filter has an end range, no start range
			detail := self.myCurrentBank.allInvoiceContractDetailByTo.first;
		endif;
		
		iter := self.myCurrentBank.allInvoiceContractDetailByTo.createIterator();

		if detail = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(detail);
		
		while iter.next(detail) do : outerloop
			if self.filterQueryDetailToEnd.isValid() then
				if self.systemToLocalTime(detail.fromTS) &gt; self.filterQueryDetailToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
					break outerloop;
				endif;
			endif;

			if not self.includeDetail(detail, false) then
				continue;
			endif;

			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;	

	endif;

	
	foreach contract in contractSet discreteLock do
		
		if not self.includeContract(contract, false) then
			continue;
		endif;
		
		self.addRowToTable(contract);
	endforeach;
		
	
epilog
	delete iter;
	delete contractSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForId" id="7ff07bf7-9f97-45fd-b773-ba3502a5c56e">
        <source>getContractsForId();
/*
Purpose:			

Date		Who		Reason
30 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

	contract : CM_InvoiceContract;
	iter : Iterator;
begin
	contract := self.myCurrentBank.allInvoiceContractsById[self.filterQueryContract,null];
	
	if contract &lt;&gt; null then // if a contract exists for this Id iterate just those Ids
		iter := self.myCurrentBank.allInvoiceContractsById.createIterator();
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if contract.contractId &lt;&gt; self.filterQueryContract then
				break;
			endif;
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
			
		
		endwhile;
		
	else // The 'includeContract' does a 'contains' search for the Id
	
		foreach contract in self.myCurrentBank.allInvoiceContractsById discreteLock do
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.addRowToTable(contract);
		endforeach;
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForRateDates" id="da84c510-3daa-42ed-8284-35d59f887147">
        <source>getContractsForRateDates();
/*
Purpose:			

Date		Who		Reason
29 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	debtor : CM_Debtor;
	rate : CM_InvoiceContractRate;
	rateEntry : CM_InvoiceContractRateEntry;
	contract : CM_InvoiceContract;
	detail : CM_InvoiceContractDetails;
	iter : Iterator;
	contractSet : CM_InvoiceContractSet;
begin
	create contractSet transient;
	
	// ### RATE 'FROM' DATE RANGE
	if self.filterQueryRateFromStart.isValid() 
	or self.filterQueryRateFromEnd.isValid() then
		if self.filterQueryRateFromStart.isValid() then // ### Rate fromTS filter has a start range
			rateEntry := self.myCurrentBank.allInvoiceContractRteEntByFrom.getAtKeyGeq(self.localToSystemTime(self.filterQueryRateFromStart)); // ### TFS BUG 58796 26JUN2023 NAVAB1 - localToSystemTime
		else // ### Detail fromTS filter has an end range, no start range
			rateEntry := self.myCurrentBank.allInvoiceContractRteEntByFrom.first;
		endif;
		iter := self.myCurrentBank.allInvoiceContractRteEntByFrom.createIterator();

		if rateEntry = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(rateEntry);
		
		while iter.next(rateEntry) do : outerloop
			if self.filterQueryRateFromEnd.isValid() then
				if self.systemToLocalTime(rateEntry.fromTS) &gt; self.filterQueryRateFromEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
					break outerloop;
				endif;
			endif;

			if not self.includeRateEntry(rateEntry) then
				continue;
			endif;
			
			rate := rateEntry.myInvoiceContractRate;
			
			if not self.includeRate(rate,false) then
				continue;
			endif;
			
			detail := rate.myInvoiceContractDetail;
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;
	
	// ### RATE 'TO' DATE RANGE
	elseif self.filterQueryRateToStart.isValid() 
	or self.filterQueryRateToEnd.isValid() then
		if self.filterQueryRateToStart.isValid() then // ### Detail toTS filter has a start range
			rateEntry := self.myCurrentBank.allInvoiceContractRteEntByTo.getAtKeyGeq(self.localToSystemTime(self.filterQueryRateToStart)); // ### TFS BUG 58796 26JUN2023 NAVAB1 - localToSystemTime
		else	// ### Detail toTS filter has an end range, no start range
			rateEntry := self.myCurrentBank.allInvoiceContractRteEntByTo.first;
		endif;
		
		iter := self.myCurrentBank.allInvoiceContractRteEntByTo.createIterator();

		if rateEntry = null then // ### TFS BUG 56837 28FEB2023 NAVAB1
			return; // ### TFS BUG 56837 28FEB2023 NAVAB1
		endif;
		
		iter.startAtObject(rateEntry);
		
		while iter.next(rateEntry) do : outerloop
			if self.filterQueryRateToEnd.isValid() then
				if self.systemToLocalTime(rateEntry.fromTS) &gt; self.filterQueryRateToEnd then // ### TFS BUG 58796 26JUN2023 NAVAB1 - systemToLocalTime
					break outerloop;
				endif;
			endif;

			if not self.includeRateEntry(rateEntry) then
				continue;
			endif;
			
			rate := rateEntry.myInvoiceContractRate;
			
			if not self.includeRate(rate,false) then
				continue;
			endif;

			detail := rate.myInvoiceContractDetail;
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;	

	endif;

	
	foreach contract in contractSet discreteLock do
		
		if not self.includeContract(contract, false) then
			continue;
		endif;
		
		self.addRowToTable(contract);
	endforeach;
		
	
epilog
	delete iter;
	delete contractSet;

end;</source>
    </JadeMethod>
