<Class name="CMSWebSession" id="835ed594-b611-4564-a6dc-5e11c9b8b9e3">
    <superclass name="CnEcSchemaSession"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_environ"/>
    <ImplicitInverseRef name="myPassport" id="339337c9-ac76-4ffd-a38e-78e2c727c38b">
        <embedded/>
        <type name="CM_Passport"/>
    </ImplicitInverseRef>
    <PrimAttribute name="numberOfLoginAttempts" id="b0665ae8-0b2b-4923-9038-2bcbfaddc083">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="theUser" id="1ef08968-c37c-4847-8345-b10dd76473ff">
        <embedded/>
        <type name="CM_User"/>
    </ImplicitInverseRef>
    <JadeMethod name="processRequest" id="0e9fa93c-7205-4793-bdf5-29e3eaf8149e">
        <updating/>
        <source>processRequest(httpString: String; queryString: String) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:		A passport needs to be held for each webSession (i.e. each user).
//				This method is called whenever a web request is made and so
//				we set app.myPassport to the currentSession's passport so all
//				app.myPassport calls will use the passport for the current user
//				instead of just for the current app.
// ---------------------------------------------------------------------------
vars

begin

	if self.myPassport = null then
		// should not get here as should be set during WebLogin::btnSubmit_click
		create self.myPassport transient;
		if self.theUser &lt;&gt; null then
			self.myPassport.setForLogon(self.theUser);
		endif;
	endif;
	
	app.setPassport(self.myPassport);
	
	inheritMethod(httpString, queryString);

epilog
	app.setPassport(null);

end;</source>
        <Parameter name="httpString" type="String"/>
        <Parameter name="queryString" type="String"/>
    </JadeMethod>
    <JadeMethod name="reply" id="20c7c2ff-e64e-4d54-b264-8ff99d651f8e">
        <updating/>
        <source>reply(html: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	inheritMethod(html);
end;</source>
        <Parameter name="html" type="String"/>
    </JadeMethod>
</Class>
