    <JadeMethod name="handleShowModal" id="cbe34c05-a7e5-4fc3-b11a-4cd94e3e99eb">
        <updating/>
        <source>handleShowModal():Integer updating;

vars
	sa:StringArray;
	meth:String;
	atcgModalCount:Integer;
begin
	create sa transient;
	app.atcgModalCount:=app.atcgModalCount+1;
	atcgModalCount:=app.atcgModalCount;

	if atcgModalCount = 1 then
		myMB_MsgBoxForm_1:=app.getForm('MB_MsgBoxForm').MB_MsgBoxForm;
		myMB_MsgBoxForm_1.show;
		myMB_MsgBoxForm_1.activate;
		sa.add('tp014m_MMBF_btnDialog1_click');
	
	elseif atcgModalCount = 2 then
		myMB_MsgBoxForm_2:=app.getForm('MB_MsgBoxForm').MB_MsgBoxForm;
		myMB_MsgBoxForm_2.show;
		myMB_MsgBoxForm_2.activate;
		sa.add('tp018m_MMBF_btnDialog1_click');
	endif;

	foreach meth in sa do
		if meth[6:3] &lt;&gt; "mv_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			app.atcgReplayFailure:=true;
			break;
		endif;
	endforeach;

	if atcgModalCount = 1 then
		if app.isValidObject(myMB_MsgBoxForm_1) then
			myMB_MsgBoxForm_1.unloadForm;  // 16:53:27
		endif;
		myMB_MsgBoxForm_1:=null;
		return 1;
	
	elseif atcgModalCount = 2 then
		if app.isValidObject(myMB_MsgBoxForm_2) then
			myMB_MsgBoxForm_2.unloadForm;  // 16:53:33
		endif;
		myMB_MsgBoxForm_2:=null;
		return 6;
	endif;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="5716853d-0aca-4d68-a160-2757791ecd19">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('tp002_VMRF_btnReadTag_click');
	sa.add('tp002v_VMRF_btnReadTag_click');
	sa.add('tp004_VMRF_tblJobs_click');
	sa.add('tp004v_VMRF_tblJobs_click');
	sa.add('tp006_VMRF_btnReadTag_click');
	sa.add('tp006v_VMRF_btnReadTag_click');
	sa.add('tp008_VMRF_fldMain_click');
	sa.add('tp008v_VMRF_fldMain_click');
	sa.add('tp010_VMRF_fldMain_click');
	sa.add('tp010v_VMRF_fldMain_click');
	sa.add('tp012_VMRF_btnLogoff_click');
	sa.add('tp016_HHLF_btnExit_click');
	sa.add('tp999_tidyUp');
	app.atcgSetMsgBoxReturn('Are you sure you want to log off?', 'Are you sure?', 1, 1);
	app.atcgSetMsgBoxReturn('Exiting will close this application. Are you sure you wish to exit?', 'Are you sure?', 4, 6);

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
