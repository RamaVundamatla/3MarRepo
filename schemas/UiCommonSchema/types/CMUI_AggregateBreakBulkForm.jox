epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="popPotentialBulkItems" id="8d96961b-b7db-466d-80e0-46feeea6d2fb">
        <source>popPotentialBulkItems();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars

	cargoType : CM_CargoType;
	location : CM_LocationsController;
	foundHeight : Integer;
	ti : CM_TrackedItem;
	index : Integer;
	iter : Iterator;
	startObject : CM_TrackedItem;
	cargoSubType : CM_Product;

begin

	cargoType := self.cmbNewCargoType.listObject.CM_CargoType;
	cargoSubType := self.cmbNewSubCargo.listObject.CM_Product;
	
	if self.txtNewLocation.text &lt;&gt; null then
		self.myTerminal.findLocationFromString( self.txtNewLocation.text.trimBlanks, true, location, foundHeight );
	endif;
	
	self.cmbIDs.clear();
	index := self.cmbIDs.addItem( " " );
	
	if cargoType &lt;&gt; null then
		if location &lt;&gt; null then
			iter := location.allTrackedItems.createIterator;
			while iter.next( ti ) do
				if ti.myCargoType = cargoType then
					if cargoSubType &lt;&gt; null and ti.myProduct &lt;&gt; cargoSubType then
						continue;
					endif;
					index := self.cmbIDs.addItem( ti.id );
					self.cmbIDs.itemObject[index] := ti;
				endif;
			endwhile;
		else
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id,null);
			if startObject &lt;&gt; null then
				iter.startAtObject( startObject );
				while iter.next( ti ) do
					if ti.myCargoType &lt;&gt; cargoType then
						break;
					endif;
					if cargoSubType &lt;&gt; null and ti.myProduct &lt;&gt; cargoSubType then
						continue;
					endif;
					index := self.cmbIDs.addItem( ti.id );
					self.cmbIDs.itemObject[index] := ti;
				endwhile;
			endif;
		
		endif;
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCargoTypes" id="e85ec3ea-c16e-4bba-b022-9f66eea75263">
        <source>populateCargoTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars

	coll : CM_CargoTypeSet;
	cargoType : CM_CargoType;
	index : Integer;

begin

	self.cmbNewCargoType.clear();
	
	create coll transient;
	self.myTerminal.getAllCargoTypes (coll, false);
	
	foreach cargoType in coll do
		if cargoType.isBulkByWeight or cargoType.isBulkByVolume then
			index := self.cmbNewCargoType.addItem( cargoType.description );
			self.cmbNewCargoType.itemObject[index] := cargoType;
		endif;
	endforeach;
	
epilog

	delete coll;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSubCargoTypes" id="51c1e895-7132-4a0c-b185-f895c9b758fa">
        <source>populateSubCargoTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars	
	cargoType : CM_CargoType;
	prod : CM_Product;
begin

	cargoType := self.cmbNewCargoType.listObject.CM_CargoType;
	
	self.cmbNewSubCargo.clear();
	
	if cargoType &lt;&gt; null then
		if cargoType.hasProductTypes then
			foreach prod in  cargoType.allProducts do
				//epr TFS 1846 18/4/16
				if prod.isNotActive then
					continue;
				endif;				
				self.cmbNewSubCargo.addItemObject( prod.description,prod );			
			endforeach;
		endif;
	endif;
	
	self.cmbNewSubCargo.enabled := self.cmbNewSubCargo.listCount &gt; 0;
	self.lblSubCargoType.enabled := self.cmbNewSubCargo.enabled;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblRange" id="8ed19f35-1ee3-4483-991f-108404cb7183">
        <updating/>
        <source>populateTblRange()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
05/03/2015	cnwmh5	Transient Leak

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	startObject : Object;
	cargoType : Integer;
	operator : CM_Operator;
	location : CM_LocationsController;
	allTis : CM_TIArray;
	msg, tblString : String;
	index : Integer;
	showWeight : Boolean;
begin

	create allTis transient;

	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.myCargoType &lt;&gt; null
	and self.myTrackedItem.myCargoType.allowDuplicates
	then

		cargoType := self.myTrackedItem.cargoType;
		operator := self.myTrackedItem.myOperator;
		location := self.myTrackedItem.myPrimaryActualLocation;
		startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType,null);
		
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject( startObject );
			while iter.next( ti ) do
				if ti.cargoType &lt;&gt; cargoType then
					break;
				endif;
				if ti = self.myTrackedItem then
					continue;
				endif;
				if ti.myOperator &lt;&gt; operator then
					continue;
				endif;
				if ti.myPrimaryActualLocation &lt;&gt; location then
					continue;
				endif;
				if ti.isBulkByQuantity and ti.totalQuantity &lt; 1 then
					continue;
				endif;
				if (ti.isBulkByVolume or ti.isBulkByWeight) and ti.totalWeight = 0 then
					continue;
				endif;
				
				allTis.add(ti);
			endwhile;
			delete iter;
		endif;
	
	endif;
	
	//epr CCMS 1366 7/4/14
	showWeight:=(self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume);
	
	self.tblRange.clear();
	self.tblRange.fixedColumns := 0;
	self.tblRange.columns := 1;
	self.tblRange.rows := 1;
	self.tblRange.fixedRows := 1;
	self.tblRange.selectMode := Table.SelectMode_Default;
	self.tblRange.setCellText(1,1, app.getErrorString(Select_items_aggregate));
	self.tblRange.accessCell(1,1).fontBold := true;
	
	//Add us first
	ti := self.myTrackedItem;
	tblString:=ti.id;
	if showWeight then
		tblString:=tblString &amp;  " (" &amp; ti.myCargoType.getBulkTrackByDisplayForWeight( ti.totalWeight, ti.getDensity, true) &amp; ")";
	else
		tblString:=tblString &amp; " (" &amp; ti.totalQuantity.String &amp; ")";
	endif;
	index := self.tblRange.addItem(tblString);
	self.tblRange.accessRow(index).itemObject := ti;
	self.tblRange.accessRow(index).selected := true;
	
	foreach ti in allTis do
		tblString:=ti.id;
		if showWeight then
			tblString:=tblString &amp;  " (" &amp; ti.myCargoType.getBulkTrackByDisplayForWeight( ti.totalWeight, ti.getDensity, true) &amp; ")";
		else
			tblString:=tblString &amp; " (" &amp; ti.totalQuantity.String &amp; ")";
		endif;
		index := self.tblRange.addItem(tblString);
		self.tblRange.accessRow(index).itemObject := ti;
	endforeach;

epilog

	delete iter;
	delete allTis;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="3230d022-e633-4383-af13-1c9a1422b02e">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	msg : String;

begin

	self.myTrackedItem := _ti;
	
	if _ti &lt;&gt; null and _ti.canMergeBreakBulk then
		self.lblSelectBBs.caption := _ti.id &amp; " (" &amp; _ti.totalQuantity.String &amp; ")";
		return true;
		
	else
		self.lblSelectBBs.caption := null;
		if _ti = null then
			msg := app.getErrorString(No_Cargo_selected);
		else
			msg := app.getErrorString(No_merge_cargo_not_BB);
		endif;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return false;
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c528e211-04e5-4672-9376-1c0a910fa369">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	convertedAmount : String;
	decimalSeparator  : String;

begin

	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;   // 17/12/2015  cnwjre1 37073
	self.handleMenusForModalDisplay();
	self.minimumHeight := 450;
	self.minimumWidth := 450;

	inheritMethod();
	
	self.lblSelectBBs.caption := app.getErrorString(Aggre_selec_break_bulk_items_i);
	self.txtNewLocation.text := self.myTrackedItem.myPrimaryActualLocation.getFullId;
	
	self.populateCargoTypes();
	self.populateTblRange();
	
	self.tblPkgingWeight.setup(Type_Weight, self.backColor);
	//convertedAmount:="0.00";									 // 17/12/2015  cnwjre1 37073
	convertedAmount := "0" &amp; decimalSeparator &amp; "00";			 // 17/12/2015  cnwjre1 37073
	if self.myTrackedItem.myCargoType.myWeightMeasurementType &lt;&gt; null then
		self.tblPkgingWeight.setValues(convertedAmount &amp; " " &amp; self.myTrackedItem.myCargoType.myWeightMeasurementType.shortName);
	else
		self.tblPkgingWeight.setValues(convertedAmount &amp; " " &amp; app.getDefaultMeasurementForType(Type_Weight).shortName);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblRange_mouseUp" id="e807e18d-d3f6-4dca-b851-52d9f82a31e9">
