    <JadeMethod name="getObjectEmailBody" id="90092fed-1cb0-4860-9bae-9f81018eaa99">
        <source>getObjectEmailBody(_objectEmail: CM_ObjectEmail): String;
//----------------------------------------------------------------
//	Created:	24 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str				: String;
	entTableDef		: EntTableDef;
	tmpObjectEmail	: CM_ObjectEmail;
	entRow			: EntTableRow;
	heading			: String;
	strObjStr		: CM_StringWithString;
	strObj			: CM_String;
	strDict			: CM_StringDict;
	index			: Integer;
begin

	tmpObjectEmail := _objectEmail;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[tmpObjectEmail.entTableName];
	
	if entTableDef = null then
		return tmpObjectEmail.message &amp; CrLf;
	endif;
	
	create strDict transient;
	
	foreach entRow in entTableDef.allEntTableRows do
		heading := entRow.getHeading(null, null, app.myCurrentLocale);
		if tmpObjectEmail.allIncludedFields.includes(heading) then
			index := tmpObjectEmail.allIncludedFields.indexOf(heading);
			create strObjStr transient;
			strObjStr.set(index.String, heading &amp; ": " &amp;  self.getDisplayStringForAttribute(entRow.name, false));
			strDict.add(strObjStr);	
		endif;
	endforeach;
	
	foreach strObj in strDict do
		str := str &amp; strObj.CM_StringWithString.strString &amp; CrLf &amp; CrLf;
	endforeach;
	
	//add the additional message
	return str &amp; CrLf &amp; CrLf &amp; _objectEmail.message &amp; CrLf;

epilog
	delete strObjStr;
	if strDict &lt;&gt; null then
		strDict.purge;
	endif;
	delete strDict;		

end;</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
        <ReturnType type="String"/>
    </JadeMethod>
