    <JadeMethod name="pxyCreateUpdateProxy" id="b0499fd9-7e73-4db2-a85e-d8a523ebcd8a">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     21 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyAttrPlan		: SelfType;
	completedOK		: Boolean;
	
begin
	pxyAttrPlan := inheritMethod();
	
	pxyAttrPlan.commodityGroup	:= self.commodityGroup;
	pxyAttrPlan.isoTypeGroup	:= self.isoTypeGroup;
	pxyAttrPlan.myCargoType		:= self.myCargoType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyAttrPlan;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyAttrPlan;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
