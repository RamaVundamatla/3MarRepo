/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwjk3	SFW1030

*/

vars
	ydc	: YRD_ContainerDrawingController;
	obj	: Object;
begin
	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		ydc.getOverlayEditFrame().deleteAllRectFrames();
	endforeach;
	self.clearSelectedRegionObjs(); // 26 Sep 2011	NDL	Par 28236
	inheritMethod();
epilog

end;</source>
