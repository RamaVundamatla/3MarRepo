    <JadeMethod name="createEmptyChild" id="9a983f45-143b-4295-bd5e-268216d8ce6d">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_LogTreatment transient;
	myObject.CM_LogTreatment.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	myParent := _parent;

end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="cce40ed5-1b37-4d69-a488-4c16b364b787">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLogTreatment : CM_LogTreatment;
begin
	create proxyLogTreatment transient;
	proxyLogTreatment.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	self.myObject := proxyLogTreatment;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="c7500e70-9d18-4038-914c-07fbe80111d4">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin

 on Exception do app.handleDeletedObject(exception, self.myObject.CM_LogTreatment, invalidObj); // cnwrd1 3.11.08 par 18090
 
	app.myTrxDA.trxDeleteLogTreatment(self.myObject.CM_LogTreatment, app.myPassport);
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="b1313998-8237-4558-9742-0a22bf3a0552">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyTreat, newTreat : CM_LogTreatment;
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_LogTreatment transient;
	endif;
	
	proxyTreat := self.myForm.myProxyObject.CM_LogTreatment;
	
	proxyTreat.setProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
							self.myForm.tblInput1.getValueByName('description').String,
							self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
							self.myObject.CM_LogTreatment.myCodeGroupLogSpecs);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateLogTreatment(proxyTreat, newTreat,app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newTreat;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateLogTreatment(proxyTreat, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyTreat;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPeerClass" id="525a62af-161a-4c2f-8341-ad0ed07d002f">
