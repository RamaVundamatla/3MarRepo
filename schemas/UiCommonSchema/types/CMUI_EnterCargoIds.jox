    <JadeMethod name="checkLength" id="0f0b9044-6b87-4305-a6cb-33538ff9d1fb">
        <source>checkLength(): Boolean protected;

/*
Date			Who		Reason
02 March 2018	jlgmd1	Initial creation TFS 37320 CIG - Length in the ID Fields

*/

vars
	id 		: String;
	maxLength	: Integer;
begin
	if myCargoType &lt;&gt; null and myCargoType.id = TI_CargoType_Container then
		maxLength := ContainerID_Length;
	else
		maxLength := TrackedItemID_Length;
	endif;

	foreach id in self.ids do
		if id.length &gt; maxLength then
			app.raiseCMException2(ContainerIdToLong, id, maxLength.String, 'id', null);
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkSystem_click" id="c225fe8a-dd22-4642-a9dc-4f689e8c7130">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkSystem_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2012	cnwndl1	Initial creation	Par 30526

*/

vars

	autoIdGen : CM_AutoCargoIdGen;

begin

	if not self.chkSystem.value then
		return;
	endif;

	if self.myTerminal = null then
		app.msgBox( app.getErrorString(Terminal_reference_set), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
	
	autoIdGen := self.myTerminal.getMyAutoIdGenerator( CM_AutoCargoIdGen ).CM_AutoCargoIdGen;
	
	if autoIdGen = null then
		app.msgBox( app.getErrorString(Must_config_style), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		return;
	endif;
	
	if self.chkSystem.value then
		self.chkSystem.value := false;
	endif;

epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="5a44f020-a732-43ea-98a2-295c67c9230c">
        <updating/>
