    <JadeMethod name="initTableAverage" id="36fc69e1-3ce7-410d-b45f-aa715238fc85">
        <source>initTableAverage();

/*

Purpose:		Initialise the stats table	

Date			Who		Reason
03/05/2012		cnwmh5	Initial creation

*/

vars

	tempDate					: Date;
	daysCount					: Integer;
	dateText					: String;
	index 						: Integer;
	
begin

	self.tblADetails.accessColumn(1).width := 200;
	self.tblADetails.accessColumn(2).width := 200;
	
	foreach index in 3 to self.tblADetails.columns step 1 do
		self.tblADetails.accessColumn(index).alignment := Table.Alignment_Right;
	endforeach;
	
	self.tblADetails.selectMode := Table.SelectMode_WholeRows;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTableCleanUpResults" id="710605ec-50e3-4239-8592-b7b641acdde1">
        <updating/>
        <source>initTableCleanUpResults() updating;

/*

Purpose:		Initialise the table	

Date			Who		Reason
19/11/2013		cnwmh5	Initial creation

*/

vars
	tempWidth					: Integer;
begin

	self.tblCleanUpReslts.rows		:= 1;
	self.tblCleanUpReslts.columns 	:= 12;

	self.tblCleanUpReslts.accessCell(1, 1).text := 
		'Date' &amp; Tab &amp; 
		'Start Time ' &amp; Tab &amp;
		'End Time ' &amp; Tab &amp;
		'Number ' &amp; Tab &amp; 
		'Task ' &amp; Tab &amp;
		'Starting Size ' &amp; Tab &amp;		
		'Ending Size ' &amp; Tab &amp; 
		'Time Taken ' &amp; Tab &amp; 
		'Size Diff ' &amp; Tab &amp; 
		'Total Time ' &amp; Tab &amp; 
		'Inc in Week ' &amp; Tab &amp;
		'Actual Inc ';
	
	self.tblCleanUpReslts.accessColumn(1).width := 70;
	tempWidth := tempWidth + self.tblCleanUpReslts.accessColumn(1).width;
	self.tblCleanUpReslts.accessColumn(2).width := 60;
	tempWidth := tempWidth + self.tblCleanUpReslts.accessColumn(2).width;
	self.tblCleanUpReslts.accessColumn(3).width := 60;
	tempWidth := tempWidth + self.tblCleanUpReslts.accessColumn(3).width;
	self.tblCleanUpReslts.accessColumn(4).width := 70;
	self.tblCleanUpReslts.accessColumn(4).alignment := Table.Alignment_Right;
	tempWidth := tempWidth + self.tblCleanUpReslts.accessColumn(4).width;
	self.tblCleanUpReslts.accessColumn(5).width := 147;
	tempWidth := tempWidth + self.tblCleanUpReslts.accessColumn(5).width;
	self.tblCleanUpReslts.accessColumn(6).width := 90; 
	self.tblCleanUpReslts.accessColumn(6).alignment := Table.Alignment_Right;
	tempWidth := tempWidth + self.tblCleanUpReslts.accessColumn(6).width;
