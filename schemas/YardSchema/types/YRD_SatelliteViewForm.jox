    <JadeMethod name="mnuRegionShow1_click" id="d3d12bca-0bd6-447e-83f7-0b7c2443beef">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRegionShow1_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars
	gcArea: CM_IrregularBlockArea;
	cm_ObjectArray	: CM_ObjectArray;
	size : Integer;
	index : Integer;
	locCont : CM_LocationsController;
	isRack : Boolean;
begin

	if self.allSelectedRegionLocs.isEmpty then
		return;
	endif;
	
	create cm_ObjectArray transient;
	self.findRegionGridLocs( cm_ObjectArray, false, true );

	if cm_ObjectArray.isEmpty then
		return;
	endif;
	
	//20 Jan 2012	NDL	Par 28901	
	size := cm_ObjectArray.size;
	foreach index in 1 to size reversed do
		locCont := cm_ObjectArray[index].CM_LocationsController;
		if locCont.myTerminalArea = null /*or locCont.myTerminalArea.isInterchangeArea*/ then  // 14/01/2013 cnwmc5 - PAR #30926
			cm_ObjectArray.removeAt(index);
		endif;
		isRack :=  locCont.isRack;
		if isRack and gcArea = null then
			gcArea := locCont.CM_IrregularBlockController.myTerminalArea.CM_IrregularBlockArea;
		endif;
	endforeach;
	
	if cm_ObjectArray.isEmpty then
		return;
	endif;
	
	if gcArea &lt;&gt; null then
		self.myAssistant.showGeneralBlockAreaForm(gcArea, self.myCurrentDrawingController.getViewMode(),
											self.myMasterMenuAction);
	else
		self.myAssistant.showYardGridAreasMultiArea(	cm_ObjectArray,
											self.myCurrentDrawingController.getViewMode(),
											self.myMasterMenuAction,
											0);
		//20 Jan 2012	NDL	Par 28901										
		self.myAssistant.showRoRoLaneAreasForm(	cm_ObjectArray,
											self.myCurrentDrawingController.getViewMode(),
											self.myMasterMenuAction
											);	
	endif;
	
epilog

	delete cm_ObjectArray;
	
			
end;</source>
