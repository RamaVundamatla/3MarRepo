    <JadeMethod name="btnCancel_click" id="a6329998-66fa-4850-89aa-b67ae722057f">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	self.CNEC_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFind_click" id="c1772f9b-93c5-4fbb-8d1d-f4cae4183245">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
