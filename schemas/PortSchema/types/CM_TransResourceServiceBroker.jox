    <JadeMethod name="pxyCreateUpdateProxy" id="889ac8a5-8e03-48c7-a7ba-e48372aec1ad">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
06 January 2010	cnwndl1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars

	pxyMe : SelfType;
	completedOK		: Boolean;
	
begin

	pxyMe :=  inheritMethod();

	pxyMe.myResourceType := self.myResourceType;
	pxyMe.myTransServiceBroker := self.myTransServiceBroker;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="69edcef5-ab02-44be-9567-822348b2fa4f">
        <updating/>
        <source>setForCreate(_pxySB: SelfType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(_pxySB);
	self.myResourceType := _pxySB.myResourceType;
	self.myTransServiceBroker := _pxySB.myTransServiceBroker;
	
	if not self.isTransient then
		if self.myResourceType &lt;&gt; null then
			self.myResourceType.setHasBeenUsed( true );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_pxySB" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setResourceTypeAndBroker" id="a4325734-7f5c-47fd-b2d3-f8371ba08a89">
        <updating/>
        <source>setResourceTypeAndBroker(_resourceType : CM_ResourceType; _transServiceBroker : CM_TransServiceBroker) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin

	self.myResourceType := _resourceType;
	self.myTransServiceBroker := _transServiceBroker;
	
epilog

end;</source>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
        <Parameter name="_transServiceBroker" type="CM_TransServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="d07a5e20-6b78-4ae5-beeb-a11d09f16ad8">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2017	cnwma1	Initial creation

*/
vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TransResourceServiceBroker::myTransServiceBroker.name 
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
