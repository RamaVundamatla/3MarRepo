end;</source>
    </JadeMethod>
    <JadeMethod name="jtdAllProfileText" id="3ab5a8f7-e4ad-4b83-b536-8cfd1e9712f5">
        <source>jtdAllProfileText() : String;

begin
	return method.text;
end;</source>
        <text>_defaultProfileName eprTest;

_defaultAutoPingInterval 10;

_defaultStatusDisplay on;

_beginDriverProfile eprLander
	_randomSelection false
	_defaultThinkSecs 0
	_stopWhenAllEntriesRun true
	_beginProlog
		_method MobileLanderApp;startup;1;0;
	_endProlog
	_beginEpilog
		_method MobileLanderApp;stop;1;0;
	_endEpilog
	_method MobileLanderApp;getLanderCargo;1;10;
	_method MobileLanderApp;getLanderWLEs;1;10;
	_method MobileLanderApp;doLanderComplete;1;10;
_endDriverProfile

_beginDriverProfile eprTest
	_randomSelection false
	_defaultThinkSecs 5
	_stopWhenAllEntriesRun true
	_beginProlog
		_method VehicleApp;startup;1;0;
	_endProlog
	_beginEpilog
		_method VehicleApp;stop;1;0;
	_endEpilog
	_method VehicleApp;updateFaultQuestions;1;0;
	_method VehicleApp;getNextTask;1;0;
	_method VehicleApp;acceptTask;1;0;
	_method VehicleApp;doPickup;1;0;
	_method VehicleApp;doSetdown;1;0;
_endDriverProfile

</text>
        <ReturnType type="String"/>
    </JadeMethod>
