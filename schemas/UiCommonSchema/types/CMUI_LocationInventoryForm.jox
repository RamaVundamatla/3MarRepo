        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2021	navndl1	Initial creation	TFS 51229

*/

vars

begin
	inheritMethod();
	
	self.grpCriteria.top := self.frmToolbar.height;
