    <JadeMethod name="lstOperators_click" id="7c11a32e-6097-498b-ade1-4d6400238133">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstOperators_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin

