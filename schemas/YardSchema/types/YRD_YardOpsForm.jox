    <JadeMethod name="doBuildMnuAllocateTI" id="6b3d34fd-6019-4aa5-80d0-21e388aa0bdc">
        <source>doBuildMnuAllocateTI(_wle : CM_WorkListEntry);
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	mnuChild, mnuMaster	: MenuItem;
	mnuIndex : Integer;
	ti : CM_TrackedItem;
	tiColl : CM_TIByIdCargoTypeDict;
	woDetail : CM_WorkOrderTIDtl;
	
begin
	if _wle = null or _wle.myTrackedItem &lt;&gt; null then
		return;
	endif;
	
	if _wle.myRequest.getWORequestByType() &lt;&gt; null then  //wle from a request by type dont want to assign cargo here like this.
		return;
	endif;
		
	mnuMaster := self.mnuAllocateTI;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := _wle;
	self.mnuAllocateTIsub.visible := false;

	woDetail := _wle.getWorkOrderTIDtl();
	
	if woDetail = null or woDetail.allAvailableTIs.isEmpty() then
		mnuMaster.enabled := false;
		return;
	endif;
	
	//	When multiple WLE selected just offer next available TI
	
	if self.tblWorkEntries.allSelectedObjects.size &gt; 1 then
		self.mnuAllocateTIsub.caption :=  app.getErrorString(Next_available);
		self.mnuAllocateTIsub.visible := true;
		return;
	endif;

	// 	Build up menu of available TIs

	create tiColl transient;
	woDetail.allAvailableTIs.copy(tiColl);

	foreach ti in tiColl do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // clone menu
		endif;
		mnuChild.caption := ti.id;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := ti.id;
		mnuChild.userObject := ti;
	endforeach;

	//  Hide remaining old sub menu items
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	
epilog
	delete tiColl;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuPackWLE" id="d70efda6-affa-4fa8-a367-c6b4b404ee01">
        <source>doBuildMnuPackWLE(_wle: CM_WOPackWLE);
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;

begin
	self.mnuAutoplan.visible := false;
	self.mnuMoveIt.visible := false;
	self.mnuQueue.visible := false;	
	self.mnuUnassignTI.visible := false;	

	if _wle &lt;&gt; self.myCurrentWLE then
		return;
	endif;

	self.doBuildMnuAllocateTI(_wle);
	
	ti := _wle.myTrackedItem;

	if ti = null then
		return;
	endif;
	
	self.mnuPackUnpack.caption := app.getErrorString(CMUI_Pack_Unpack) &amp; ti.id &amp; "...";
	self.mnuPackUnpack.userObject := _wle;
	self.mnuPackUnpack.visible := true;
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_WOPackWLE"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblJobs" id="e7790cbf-0854-4805-bd43-8b0fb16bb1b9">
        <updating/>
        <source>doBuildMnuTblJobs(_job : CM_Job) updating;
// -----------------------------------------------------------------------------
// Created:		23 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	idx : Integer;
	mnuChild : MenuItem;
	theRequest : CM_Request;
	
begin
	
	self.mnuAutoplan.visible:=false; //epr par 36069 4/5/14 removed because does the same as the Queue menus
	self.mnuQueueJob.visible := false;
	self.mnuSep1.visible := false;
	self.mnuAddInternalMove.visible := true;
	self.mnuEditInternalMove.visible := false;
	self.mnuEditToDoJob.visible := false;
	self.mnuShowJobWLE.visible := false;
	self.mnuSetPriority.visible := false;

	if _job = null then
		return;
	endif;
	
	if _job.isKindOf(CM_YardInternalJob) then
		self.mnuQueueJob.visible := true;
		self.mnuSep1.visible := true;
		if _job.getWorkOrder() = null then
			theRequest := _job.allRequests.first;
			if theRequest &lt;&gt; null then
				if theRequest.isKindOf(CM_YardDeliveryRequest) then
					self.mnuEditInternalMove.caption := app.getErrorString1(Edit_Item, _job.id);	
				elseif theRequest.isKindOf(CM_YardMoveRequest) then
					self.mnuEditInternalMove.caption := app.getErrorString1(View_Item, _job.id);
				endif;
				self.mnuEditInternalMove.visible := true;
				self.mnuEditInternalMove.userObject := _job;
			endif;
		endif;
	endif;

	if _job.isKindOf(CM_WOToDoTaskJob) then
		self.mnuEditToDoJob.visible := true;
		self.mnuEditToDoJob.userObject := _job;
	endif;
	
	self.mnuShowJobWLE.visible := true;
	self.mnuShowJobWLE.userObject := _job;
	
	//  Priority
	
	self.mnuSetPriority.visible := true;
	self.mnuSetPriority.userObject := _job;
	
	foreach idx in 1 to CM_Job.MaxPriority do
		mnuChild := self.mnuSetPriority.getMenuItem(idx);
		mnuChild.checked := (idx = _job.priority);
	endforeach;

	self.mnuToggleMultiSelJobs.checked := self.mnuToggleMultiSelect.checked;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuAutoplan.visible:=false;
		self.mnuQueueJob.visible := false;
		self.mnuSep1.visible := false;
		self.mnuAddInternalMove.visible :=false;
		self.mnuEditInternalMove.visible := false;
		self.mnuEditToDoJob.visible := false;
		self.mnuShowJobWLE.visible := false;
		self.mnuSetPriority.visible := false;
		self.mnuPackUnpack.visible := false; // TFS 2734
		self.mnuDisconnect.visible := false; // TFS 2734
 
	endif;
	
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblWle" id="71aba9f0-274b-461a-982b-9af5523aa63d">
        <source>doBuildMnuTblWle(_wle: CM_WorkListEntry);
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	toLocn : CM_LocationsController;
begin


	
	if self.tblWorkEntries.allSelectedObjects.size &gt; 1 then
		self.resetSelectedNotOfClass(_wle);
	endif;

	self.mnuInspectWLE.visible :=  app.isAllowedToInspect();
	self.mnuInspectWLE.visible := app.isSpecial(); // 
	self.mnuDeleteCurrentEntry.visible := false;

	
	if _wle &lt;&gt; null then
		if _wle.isKindOf(CM_WOToDoWLE) then
			self.doBuildMnuToDoWLE(_wle.CM_WOToDoWLE);
			return;
		elseif _wle.isKindOf(CM_WOPackWLE) then
			self.doBuildMnuPackWLE(_wle.CM_WOPackWLE);
			return;
		elseif _wle.isKindOf(CM_WOUnpackWLE) then
			self.doBuildMnuUnpackWLE(_wle.CM_WOUnpackWLE);
			return;
		elseif _wle.isKindOf(CM_YardWLE) then
			inheritMethod(_wle);
			self.doBuildMnuYardWLE(_wle.CM_YardWLE);
		endif;
	endif;

	self.mnuDeleteCurrentEntry.visible := false;

	if _wle.status = WLE_COMPLETED then
		self.mnuMoveIt.visible := false;
		self.mnuQueueSelected.visible := false;
		self.mnuAutoplanSelected.visible := false;
		self.mnuUnplanSelected.visible := false;
		self.mnuUnqueueSelected.visible := false;
	endif;
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuMoveIt.visible := false;
		self.mnuQueueSelected.visible := false;
		self.mnuAutoplanSelected.visible := false;
		self.mnuUnplanSelected.visible := false;
		self.mnuUnqueueSelected.visible := false;
		self.mnuPackUnpack.visible := false; // TFS 2734
		self.mnuDisconnect.visible := false; // TFS 2734
 
	endif;

	
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuToDoWLE" id="c60dc294-e51b-4ee5-b862-7a18abdb4d15">
        <source>doBuildMnuToDoWLE(_wle: CM_WOToDoWLE);
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.mnuAutoplan.visible := false;
	self.mnuMoveIt.visible := false;
	self.mnuQueue.visible := false;	
	self.mnuUnassignTI.visible := false;	

	if _wle &lt;&gt; self.myCurrentWLE then
		return;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.mnuEdit.visible := true;
	
	self.doBuildMnuAllocateTI(_wle);
	
	if self.tblWorkEntries.allSelectedObjects.size &gt; 1 then
		self.mnuComplete.caption := app.getErrorString(Complete_selected_tasks); 
	else
		self.mnuComplete.caption := app.getErrorString(Complete_task); 
	endif;
	
	self.mnuComplete.visible := self.canCompleteToDoWLE(_wle);

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuUnpackWLE" id="795a112d-d52a-4a63-b4a3-acb3357532f8">
        <source>doBuildMnuUnpackWLE(_wle: CM_WOUnpackWLE);
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	
begin
	self.mnuAutoplan.visible := false;
	self.mnuMoveIt.visible := false;
	self.mnuQueue.visible := false;	
	self.mnuUnassignTI.visible := false;	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	ti := _wle.myTrackedItem;

	if ti = null then
		return;
	endif;
	
	self.mnuPackUnpack.caption := app.getErrorString(CMUI_Pack_Unpack) &amp; ti.id &amp; "...";
	self.mnuPackUnpack.userObject := _wle;
	self.mnuPackUnpack.visible := true;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOUnpackWLE"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuYardWLE" id="5fa534d0-7c40-435f-9c6a-cb65b01ce7e8">
        <source>doBuildMnuYardWLE(_wle: CM_YardWLE);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwrd1	Initial creation

*/

vars
	
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	// if we have a WorkOrderMove request - CM_WOMoveRequest &amp; we have no TI then we want to:
	//populate the assign cargo menu
	// disable the queue and move and autoplan menu's
	self.mnuAutoplan.visible := false; //epr par 36069 4/5/14 removed because does the same as the Queue menus
	if _wle.myTrackedItem = null and _wle.myRequest.isKindOf(CM_WOMoveRequest) then
		self.mnuMoveIt.visible := false;
		self.mnuQueue.visible := false;	
		self.mnuUnassignTI.visible := false;	

		self.doBuildMnuAllocateTI(_wle);	
	else
	//if we are anything else we want to
	//enable queue/move/etc
		self.mnuQueueSelected.visible := true;
		self.mnuUnqueueSelected.visible := true;
		if _wle.myTrackedItem &lt;&gt; null then
			self.mnuMoveIt.visible := true;
		else
			self.mnuMoveIt.visible := false;
		endif;
		
		if _wle.isPlanOnPickupNoTarget then
			self.mnuMoveIt.visible := false;
			self.mnuQueueSelected.visible := false;
			
		elseif _wle.isPlanOnPickup then
			self.mnuQueueSelected.visible := false;
		endif;	
	endif;
	
	
	

epilog

end;</source>
        <Parameter name="_wle" type="CM_YardWLE"/>
    </JadeMethod>
    <JadeMethod name="doBuildShiftSearchCombo" id="6c3dcbea-b7ca-42af-8bff-b2d676548150">
        <source>doBuildShiftSearchCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Oct 2009	cnwrd1	Initial creation
22 Jun 2010	cnwkpd1	PAR #24609 - Change to CM_Terminal.getShiftsFromRange behaviour
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	iter		: Iterator;
	shift		: CM_Shift;
	tmpString : String;
	idxRow,
	oldShiftDay,
	day, idx, shiftDay : Integer;
	isFirst		: Boolean;
//	shifts : CM_ShiftStartDateCodeDict;
	frmTS, toTS,startLocalTS,endLocalTS : TimeStamp;
	tmpTime : Time;

begin
	oldShiftDay := 0;
	idxRow := 2;	
	
	
	frmTS.setDate(app.actualTimeServer().TimeStamp.date);
	tmpTime.setTime(0,0,0,0);
	frmTS.setTime(tmpTime);
	
	toTS.setDate(app.actualTimeServer().TimeStamp.date + 20);
	tmpTime.setTime(23,59,59,0);
	toTS.setTime(tmpTime);
	
	self.cmbShift.clear();
	//shifts.clear();
//	create shifts transient;
	
	self.allShifts.purge();				// PAR #24609
	
	//create shifts transient;
	//self.myTerminal.getShiftsFromRange(shifts,frmTS, toTS);
	self.myTerminal.getShiftsFromRange(self.allShifts, self.localToSystemTime(frmTS), self.localToSystemTime(toTS));
	
	//shifts.copy(self.allShiftsDays);
	
	self.cmbShift.addItemObject('',null  ) ;
	
	iter := self.allShifts.createIterator();
	while iter.next(shift) do
		if shift.ignore then
			continue;
		endif;
		
		startLocalTS := self.systemToLocalTime(shift.startDateTime);
		endLocalTS	 := self.systemToLocalTime(shift.endDateTime);
		shiftDay := startLocalTS.Date.dayOfWeek();
		tmpString := shift.getShiftDay().padBlanks(10) &amp; Tab &amp; 
						startLocalTS.Date.shortFormatJMT &amp; " " &amp; startLocalTS.Time.String &amp; Tab &amp; 
						endLocalTS.Date.shortFormatJMT &amp; " " &amp; endLocalTS.Time.String &amp; Tab &amp; 
						shift.getShiftLengthDesc() &amp; Tab &amp; 
						shift.code &amp; Tab &amp; 
						shift.description;
						
		//	idx := self.tblShift.addItemObject(shift,tmpString);
		self.cmbShift.addItemObject(tmpString,shift  ) ;
		
	endwhile;
	
epilog
	//shift := self.tblShift.accessRow(3).itemObject.CM_Shift;
	//shifts.deleteObjects(false);
	
//	delete shifts;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteJob" id="fd1e4806-b217-4177-b993-ca4628cc3961">
        <updating/>
        <source>doDeleteJob() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwrd1	Initial creation

*/

vars
	result : Integer;
	yardJobSet : CM_JobSet;
begin

	if not app.myCurrentUserCan(self.myTerminal,PmAdmReqstmoveMaint) then
		return ;
	endif;	
	

	
	create yardJobSet transient;
	
	self.tblJobs.allSelectedObjects.copy(yardJobSet);	
	app.mousePointer := MousePointer_HourGlass;	

	while true do
		//app.myTrxDA.trxDeleteYardInternalJob(yardJobSet, app.myPassport);
		app.myTrxDA.trxDeleteJobs(yardJobSet, app.myPassport);
		if app.myPassport.trxCompletedOK then	
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Delete_internal_request), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
	delete yardJobSet;
end;

</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="ef055312-e98e-40e2-a7b2-41378d4e7430">
        <updating/>
        <source>doEdit() updating;
// -----------------------------------------------------------------------------
// Created:		23 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	job : CM_Job;
	tiSet : CM_TISet;
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;

begin
	if self.optViewJob.value then
		job := self.getCurrentJob();
		if job = null then
			return;
		endif;
		if job.isKindOf(CM_YardInternalJob) and job.getWorkOrder() = null then
			self.showRequestInternalMove( job );
		elseif job.isKindOf(CM_WOToDoTaskJob) then
			create tiSet transient;
			job.CM_WOToDoTaskJob.allTrackedItems.copy(tiSet);
			self.showToDoTasks(tiSet);
		endif;
		return;
	endif;

	if self.myCurrentWLE &lt;&gt; null then
		if self.myCurrentWLE.isKindOf(CM_WOToDoWLE) then
			create tiSet transient;
			create wleArray transient;
			self.getWLEsInTableSelectedOfClass(CM_WOToDoWLE, wleArray);
			foreach wle in wleArray where wle.myTrackedItem &lt;&gt; null do
				tiSet.add(wle.myTrackedItem);
			endforeach;
			self.showToDoTasks(tiSet);
			return;
		elseif self.myCurrentWLE.isKindOf(CM_WOPackWLE) then
			self.showPack(self.myCurrentWLE.CM_WOPackWLE);
			return;
		elseif self.myCurrentWLE.isKindOf(CM_WOUnpackWLE) then
			self.showUnpack(self.myCurrentWLE.CM_WOUnpackWLE);
			return;
		endif;
	endif;

	inheritMethod();

epilog
	delete tiSet;
	delete wleArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="5582ee78-6b6a-46a4-95b9-559922134edb">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navdp20  ChangeRequest 57304:[57305] EUP - [Framework] - Add selection counter and Text Filtering on Yard Operation screen
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
	
begin
    /* //23/04/2024	navkc1 CR63736 Task 63770
	rows		:= 0;
	filterText  := self.txtFilterBox.text.toUpper();	
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;
	if self.optViewWorkList.value then
		tbl := tblWorkEntries;
    elseif self.optViewJob.value then
		tbl := tblJobs;
	endif;
	
	start := tbl.fixedRows + 1;

	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblInfo.rows := 0;      
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	*/ //05/06/2024	navkc1 CR 63736 Task 63770
	rows := self.frmTableFilter.numOfRowVisible;
	
	self.numRows := rows;
	self.frmModeStatusBar.myFrameCaption.caption :=rows.String &amp; " rows found.";
	
	if rows = 0 then 
		self.tblInfo.rows := 0;          
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuAllocateTI" id="b33f1a39-595e-4b08-ad59-723124b851e7">
        <updating/>
        <source>doMnuAllocateTI(menuItem : MenuItem input) updating, protected;
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	result : Integer;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	woDetail : CM_WorkOrderTIDtl;

begin
	if menuItem = self.mnuAllocateTI or self.myCurrentWLE &lt;&gt; self.mnuAllocateTI.userObject then
		return;
	endif;
	
	create wleArray transient;

	ti := menuItem.userObject.CM_TrackedItem;

	if ti = null then
		//  Null TI means multiple selections - the next available TI will be allocated
		self.getWLEsInTableSelectedOfClass(self.myCurrentWLE.class, wleArray);
	else
		wleArray.add(self.myCurrentWLE);
	endif;
	
	foreach wle in wleArray where wle.myTrackedItem = null do
		if ti = null then
			woDetail := wle.getWorkOrderTIDtl();
			if woDetail = null or woDetail.allAvailableTIs.isEmpty() then
				continue;
			endif;
		endif;
		//  Allocate TI to WLE
		while true do
			app.myTrxUA.trxUpdateWLEAllocateWodTI(wle, ti, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(self.mnuAllocateTI.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ...
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;

	//refresh table
	self.displayExtraInfoForObj(self.myCurrentWLE);
	
epilog
	delete wleArray;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuColourLegend" id="7f39a065-b297-42a7-ac07-2562b4cd7bfa">
        <source>doMnuColourLegend(menuItem: MenuItem input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwrd1	Initial creation

*/

vars
	colLegend	: CMUI_ColourLegend;

begin
/*
	// Update the navigator
	create cLegend;
	self.myMasterMenuAction.setHeading(cLegend.caption); 
	cLegend.centreWindow;

	cLegend.show;
*/

	// Update the navigator
	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Job Unactioned",					Black,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Returned",						Red,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Part Complete",				Black,				White,				"picJobPartComp", false);
	colLegend.addLegendItem("Job Complete",						Black,				White,				"picJobComp", false);
	colLegend.addLegendItem("Unactioned Receipt Job",			CM_Job.Colour_ReceiptUnactioned,		White,				null, false);
	colLegend.addLegendItem("Unactioned Release Job",			CM_Job.Colour_ReleaseUnactioned,				White,				null, false);
	colLegend.addLegendItem("Partially Worked Receipt Job",		CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem("Partially Worked Release Job",		CM_Job.Colour_ReleasePartComplete,			White,				null, false);
	colLegend.addLegendItem("Completed Receipt Job",			White,				CM_Job.Colour_ReceiptComplete,				null, false);
	colLegend.addLegendItem("Completed Release Job",			White,				CM_Job.Colour_ReleaseComplete, null, false);
	colLegend.addLegendItem("Job is Overstowed",				White,				Red,				null, true);		
	colLegend.addLegendItem("Matched up to a TBA Container",		Black,				 LightGreen,		null, false);
	colLegend.addLegendItem("Returned Job",						Black,				Red,				null, false);
	colLegend.addLegendItem("Other",							White,				Mauve,				null, false);
	
	colLegend.showModal;


epilog
	delete colLegend;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuPackUnpack" id="41a11a06-1b3e-48c8-9b7e-9448945b1278">
        <updating/>
        <source>doMnuPackUnpack(menuItem: MenuItem input) updating, protected;
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.myCurrentWLE = menuItem.userObject then
		if self.myCurrentWLE.isKindOf(CM_WOPackWLE) then
			self.showPack(self.myCurrentWLE.CM_WOPackWLE);
		elseif self.myCurrentWLE.isKindOf(CM_WOUnpackWLE) then
			self.showUnpack(self.myCurrentWLE.CM_WOUnpackWLE);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuSetPriorityClick" id="ecf99698-6fc3-4d44-93ae-27875ac3efbe">
        <updating/>
        <source>doMnuSetPriorityClick(_menuItem: MenuItem input) updating;
// -----------------------------------------------------------------------------
// Created:		24 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	jobArray : CM_JobArray;
	priority : Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	if _menuItem = self.mnuSetPriority then
		return;
	endif;
	
	priority := _menuItem.caption.asIntegerJMT();
	
	if priority = null then
		return;
	endif;
	
	create jobArray transient;
	self.getSelectedJobs(jobArray);
	
	if jobArray.isEmpty() then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateJobPriority(jobArray, priority, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.mnuSetPriority.caption, app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	_menuItem.checked := not _menuItem.checked;

epilog
	delete jobArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMove_Instant" id="7c434064-e80a-49f5-8123-8bf29385ad34">
        <updating/>
        <source>doMove_Instant() updating;
// -----------------------------------------------------------------------------
// Created:		29 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.myCurrentWLE &lt;&gt; null then
		if self.myCurrentWLE.isKindOf(CM_WOToDoWLE)
		or self.myCurrentWLE.isKindOf(CM_WOPackWLE)
		or self.myCurrentWLE.isKindOf(CM_WOUnpackWLE) then
			return;
		endif;
	endif;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMove_QueueForJobs" id="ff930ef3-bfc1-47d1-851f-3c732c6e5871">
        <updating/>
        <source>doMove_QueueForJobs(_all : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		Queue WLEs for move jobs in Jobs Table.
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//	02/02/2016	cnwmc5		PAR 37491 - wasn't accounting for WLEs in JOB mode...
// -----------------------------------------------------------------------------

vars
	wleArray : CM_WLEArray;

begin
	create wleArray transient;
	
	if _all then
		self.getWLEsForJobsMoveAll(wleArray);
	else
		self.getWLEsForJobsMoveSelected(wleArray);	
	endif;
	
	self.tblWorkEntries.clearAllData();
	wleArray.copy(self.tblWorkEntries.allSelectedObjects);
	
	self.doMove_ForMode(QUEUE_MODE, false);
	
epilog
	delete wleArray;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_UnqueueForJobs" id="231bdc95-3405-4c9a-853f-9204548e40a0">
        <updating/>
        <source>doMove_UnqueueForJobs(_all : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		Unqueue WLEs for move jobs in Jobs Table.
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	wleArray : CM_WLEArray;

begin
	create wleArray transient;
	
	if _all then
		self.getWLEsForJobsMoveAll(wleArray);
	else
		self.getWLEsForJobsMoveSelected(wleArray);	
	endif;
	
	self.tblWorkEntries.clearAllData();
	wleArray.copy(self.tblWorkEntries.allSelectedObjects);
	
	self.doMove_Unqueue(false);
	
epilog
	delete wleArray;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="5790a47d-4e23-4a7e-8e48-2d96ff1746df">
        <updating/>
        <source>doRefresh() updating, protected;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 03 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 27 Mar 2023  navdp20 ChangeRequest 57304:[57305] EUP - [Framework] - Add selection counter and Text Filtering on Yard Operation screen

vars
	job			: CM_Job;
	wleArray	: CM_WLEArray;
	
begin
	self.tblWorkEntries.clearAllData();
	self.tblJobs.clearAllData();
	self.doNotableClear();
	self.setMyCurrentListObjects(null);
	self.displayExtraInfoForObj(null);
	self.setStatusBarCaption();
	self.btnMoveIt.enabled := self.optViewWorkList.value;

	if self.optViewWorkList.value then
		//  View by Work Order
		create wleArray transient;
		self.getFilteredWLEs(wleArray);
		self.displayWLEs(wleArray);
		
		if self.filterCargoID &lt;&gt; null then // highlite a cargo ID match.
			self.filterForCargoID();
		endif;
		
		if self.filterShippingLine &lt;&gt; null then // 03 Jun 2022 navak20 TFS 53204
			self.filterForShippingLine();	// 03 Jun 2022 navak20 TFS 53204
		endif;								// 03 Jun 2022 navak20 TFS 53204
		
		self.txtCargoID.visible := true;
		self.lblCargoID.visible := true;
		self.cmbShippingLine.visible := true;	//03 jun 2022	navtnr20  53204
		self.lblShippingLine.visible := true;	//03 jun 2022	navtnr20  53204
	else
		//  View By Job
		
		self.txtCargoID.visible := false;
		self.lblCargoID.visible := false;
		self.cmbShippingLine.visible := false;	//03 jun 2022	navtnr20 53204
		self.lblShippingLine.visible := false;	//03 jun 2022	navtnr20 53204
		if self.myTerminal.myYardJobSheet = null then	//17 May 2012	NDL	Par 28193
			return;
		endif;
		
		foreach job in self.myTerminal.myYardJobSheet.allJobsByOrder do
			if self.filterJob(job) and self.includeJob(job) then
				self.tblJobs.addItemObject( job, self.displayRowForDataTable(job, self.tblJobs) );
			endif;
		endforeach;
		self.numRows := (self.tblJobs.rows - self.tblJobs.fixedRows);                               //27.3.2023 navdp20 #57304[57305]
		self.frmModeStatusBar.myFrameCaption.caption := self.numRows .String &amp; " rows found.";		//27.3.2023 navdp20 #57304[57305]
	endif;
epilog
	delete wleArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="08dac6cf-4a88-4146-abb5-237e4de82e2d">
        <updating/>
        <source>doResize() updating;
/*
Purpose:			

Date		Who		Reason
20 September 2021	navab1	TFS 51853
*/

vars

begin
	inheritMethod();
	
	self.fldSearch.top := self.frmQueryToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearchClear" id="fd2c3b4c-6ceb-4ee7-9684-78396bd91a38">
        <source>doSearchClear();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation
31 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
*/

vars

begin
	self.mskDateFrom.setDate(null);
	self.mskDateTo.setDate(null);
	self.txtWorkOrderId.text := null;
	self.txtJobId.text := null;
	self.cmbOrganisation.listObject := null;
	self.cmbOperator.listObject := null;
	self.chkDependantTsks.value := false;
	self.cmbShippingLine.listObject := null; // 31.05.2022 navtnr20 TFS 53204
	
	self.mltTasks.setSelected(self.allTaskTypes); 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSearch" id="37b8f968-5309-4602-97d4-21d82ee3a050">
        <updating/>
        <source>doShowSearch() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// 31 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
*/

vars
	searchTime : Time;
	searchDate : Date;
	searchTS : TimeStamp;
begin
	//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	searchTime := TimeStartOfDay;
	searchDate := self.mskDateFrom.getDate();
	if searchDate = null then
		self.filterDateFrom := null;
	else
		searchTS.cnEcSetDateAndTime(searchDate,searchTime); 
		self.filterDateFrom := self.localToSystemTime(searchTS).date();
	endif;
	
	searchDate := self.mskDateReqFrom.getDate();
	if searchDate = null then
		self.filterDateReqFrom := null;
	else
		searchTS.cnEcSetDateAndTime(searchDate,searchTime); 
		self.filterDateReqFrom := self.localToSystemTime(searchTS).date();
	endif;
	
	searchTime := TimeEndOfDay;
	searchDate := self.mskDateTo.getDate();
	if searchDate = null then
		self.filterDateTo := null;
	else
		searchTS.cnEcSetDateAndTime(searchDate,searchTime); 
		self.filterDateTo := self.localToSystemTime(searchTS).date();
	endif;
	searchDate := self.mskDateReqTo.getDate();
	if searchDate = null then
		self.filterDateReqTo := null;
	else
		searchTS.cnEcSetDateAndTime(searchDate,searchTime); 
		self.filterDateReqTo := self.localToSystemTime(searchTS).date();
	endif;
	
	//self.filterDateFrom := self.mskDateFrom.getDate();
	//self.filterDateTo := self.mskDateTo.getDate();
	//self.filterDateReqFrom := self.mskDateReqFrom.getDate();
	//self.filterDateReqTo := self.mskDateReqTo.getDate();
	
	
	self.filterWorkOrderId := self.txtWorkOrderId.text;
	self.filterJobId := self.txtJobId.text.trimBlanks();
	self.filterCargoID := self.txtCargoID.text.trimBlanks();
	self.filterShift := self.cmbShift.listObject.CM_Shift;
	//31-MAY-2022 navtnr20 53204 START
	if self.cmbShippingLine.listObject &lt;&gt; null then
		self.filterShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine.code;
	endif;
	// 31-MAY-2022 navtnr20 53204 END
	
	//self.filterOrganisation := self.cmbOrganisation.listObject.CM_Organisation;
	//self.filterOperator := self.cmbOperator.listObject.CM_Operator;

	self.allTaskTypesFiltered.clear();
	self.mltTasks.getSelected(self.allTaskTypesFiltered); 
	
	self.doRefresh();
	self.showSearcher(true);
epilog

end;</source>
    </JadeMethod>
