    <JadeMethod name="getRandomColour" id="e15490d8-7358-48e2-8093-dbafd1f734a0">
        <subschemaFinal/>
        <source>getRandomColour() : Integer subschemaFinal;
/*
------------------------------------------------------------------------
Created:			15 April 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	colour_red : Integer;
	colour_green : Integer;
	colour_blue : Integer;
	mySeed : Integer;
	val : Integer;
begin
	
	// JADE PAR 39045: use this instead of (255 * app.random31(mySeed, 100)).
    colour_red := app.random31(mySeed, 255);
    colour_green := app.random31(mySeed, 255);
    colour_blue := app.random31(mySeed, 255);

	val :=  colour_red + (colour_green * 256) + (colour_blue * 256 * 256);
	
	return val;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReportToSendItems" id="f696f8aa-8892-471b-91d0-c70cb235cb11">
        <source>getReportToSendItems(_reportViewName 	: String; 
					 _reportPaths		: StringArray;
					 _showSelectedFrame : Boolean io; 
					 _jrwReportName 	: String output; 
					 _printPreview 		: Boolean output; 
					 _outputType 		: Integer output;
					 _filePath			: String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 December 2007 by cnwaer1
//
// Purpose:     _reportPath parameter added Sept 2010 to allow selecting invoice or invoice rate reports within the invoice view
// Feb 2012 from CCMS 1262 transaction enquiry make _showSelectedFrame io to support the report selected/all option
//	Oct 2014 35069 _reportPath changed to a StringArray to allow a list of valid report paths to extend the range of reports
// ---------------------------------------------------------------------------
vars
	tmpFrm			: CMUI_SendToReport;
	errorString 	: String;
	fileNameError 	: String;
begin
	if _reportViewName = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'A report configuration (eg, CM_TrackedItemView) was not specified');
	endif;
	
	create tmpFrm transient;
	tmpFrm.init(_showSelectedFrame, _reportViewName, _reportPaths);
	
	tmpFrm.showModal();
	
	if tmpFrm.modalResult = IDCANCEL then
		return false;
	endif;
	
	 // SFW CCMS 1115 PAR23680 and CCMS 1262 new parameters
	tmpFrm.getResult(_jrwReportName, _printPreview, _outputType, _filePath, _showSelectedFrame);
	//Check we have a report and file path (if required).
	if _jrwReportName = null then
		errorString := app.getErrorString(ReportCapital);
	endif;
	
	if _outputType &lt;&gt; JadeReportWriterReport.PRINTER and
	   _filePath = null then
		fileNameError := app.getErrorString(File_Name);
		if errorString &lt;&gt; null then 
			errorString := errorString &amp; ", " &amp; fileNameError;
		else
			errorString := fileNameError;
		endif;
			
	endif;
	
	//We got errors so show a message box.
	if errorString &lt;&gt; null then
		app.msgBox(app.getErrorString1(RequiredFields, errorString), app.getErrorString(Required_Fields), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	return true;
epilog
	delete tmpFrm;
end;</source>
        <Parameter name="_reportViewName" type="String"/>
        <Parameter name="_reportPaths" type="StringArray"/>
        <Parameter name="_showSelectedFrame" type="Boolean" usage="io"/>
        <Parameter name="_jrwReportName" type="String" usage="output"/>
        <Parameter name="_printPreview" type="Boolean" usage="output"/>
        <Parameter name="_outputType" type="Integer" usage="output"/>
        <Parameter name="_filePath" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
