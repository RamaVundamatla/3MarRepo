    <JadeMethod name="pwFixVBS" id="283bfb48-ad47-453c-be7c-ad9325fce513">
        <source>pwFixVBS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023	navpw1	Initial creation

*/

constants
	TSTime = 3;
vars
	terminal : CM_Terminal;
	vbsSlot : CM_VehicleBookingTimeSlot;
	tsStart	: TimeStamp;
	date,
	date2 : Date;
	time,
	time2 : Time;
	tsEnd : TimeStamp;
	allVBTimeslotsById : CM_VehicleBookingTimeSlotById;
	tsTransaction : TimeStamp;
	count : Integer;
	allTerminals : CM_TerminalByCodeDict;
	
begin
	//date.setDate(1, 3, 2023);
	//date.setDate(11, 11, 2022);
	//time.setTime(0, 0, 0, 0);
	//tsStart.setDate(date);
	//tsStart.setTime(time);
	
	//date2.setDate(25, 3, 2023);
	date2.setDate(16, 3, 2023);
	time2.setTime(0, 0, 0, 0);
	tsEnd.setDate(date2);
	tsEnd.setTime(time2);
	
	beginTransaction;
	app.writeLog("Starting fixup script at time " &amp; app.actualTimeAppServer.asStringJMT, LogINFO);
	tsTransaction := app.actualTimeAppServer.addSeconds(TSTime);
	
	allTerminals := app.myRoot.allTerminals;
	
	foreach terminal in allTerminals do
		allVBTimeslotsById := terminal.myVehicleBookingTerminal.allVBTimeslotsById;
		foreach vbsSlot in allVBTimeslotsById where vbsSlot.bookingTSstart &lt; tsEnd do
			if app.actualTimeAppServer &gt; tsTransaction or count &gt;= 3000 then
				app.writeLog("Current Time is: " &amp; app.actualTimeAppServer.asStringJMT &amp; " interim-commit of " &amp; count.String &amp; " updates", LogINFO);
				commitTransaction;
				beginTransaction;
				tsTransaction := app.actualTimeAppServer.addSeconds(TSTime);
				count := 0;
			endif;
			
			if vbsSlot.bookingTSstart.date.isWeekDay then
				vbsSlot.setPropertyValue(CM_VehicleBookingTimeSlot::myVBTimeSlotType.name, terminal.allTerminalVBSSlotTypes["VB01"]);
				count += 1;
			else
				vbsSlot.setPropertyValue(CM_VehicleBookingTimeSlot::myVBTimeSlotType.name, terminal.allTerminalVBSSlotTypes["VB02"]);
				count += 1;
			endif;
		endforeach;
	endforeach;
	
	if process.isInTransactionState then
		app.writeLog("Current Time is: " &amp; app.actualTimeAppServer.asStringJMT &amp; " commiting " &amp; count.String &amp; " updates", LogINFO);
		commitTransaction;
	endif;
	
	app.writeLog("Finishing fixup script at time " &amp; app.actualTimeAppServer.asStringJMT, LogINFO);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwFixVBSTemplatesJBL" id="873cbeb5-3714-4a52-877d-af88cd6cc737">
        <source>pwFixVBSTemplatesJBL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2023	navpw1	Initial creation TFS: 53697

*/

vars
	terminal : CM_Terminal;
	vehicleBookingTerminal : CM_VehicleBookingTerminal;
	vehicleBookingDayTemplate : CM_VehicleBookingDayTemplate;
	vehicleBookingTimeTemplate : CM_VehicleBookingTimeTemplate;
	invalid : Boolean;
	vbsSlotType : CM_VehicleBookingTimeSlotType;
	
begin
	on Exception do app.handleDeletedObject( exception, vehicleBookingTimeTemplate.myVBTimeslotType, invalid);
	
	terminal := app.myRoot.allTerminals["JBL"];
	
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	
	vbsSlotType := terminal.allTerminalVBSSlotTypes["1234"];
	
	if vbsSlotType = null then
		return;
	endif;
	
	if vehicleBookingTerminal = null then
		return;
	endif;
	
	if vehicleBookingTerminal.allVehicleBookingDayTemplates.isEmpty then
		return;
	endif;
	
	foreach vehicleBookingDayTemplate in vehicleBookingTerminal.allVehicleBookingDayTemplates do :vehicleDayTemplate
		if vehicleBookingDayTemplate.allTimeTemplates.isEmpty then
			continue vehicleDayTemplate;
		endif;
		
		foreach vehicleBookingTimeTemplate in vehicleBookingDayTemplate.allTimeTemplates do :vehicleTimeTemplate
			if vehicleBookingTimeTemplate.myVBTimeslotType = null then
				continue vehicleTimeTemplate;
			endif;
			
			vehicleBookingTimeTemplate.myVBTimeslotType.edition;
			
			if not invalid then
				continue vehicleTimeTemplate;
			endif;
			
			invalid := false;
			
			beginTransaction;
			vehicleBookingTimeTemplate.setPropertyValue(CM_VehicleBookingTimeTemplate::myVBTimeslotType.name, vbsSlotType);
			commitTransaction;
		endforeach;
		
	endforeach;
	
	on Exception do null;
	
epilog
	
end;</source>
    </JadeMethod>
