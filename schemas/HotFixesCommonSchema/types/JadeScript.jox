<Class name="JadeScript">
    <JadeMethod name="buildFilesForJARI" id="8eb72258-c591-4cc0-978d-281e5d9dec77">
        <source>buildFilesForJARI();

/*

Purpose:			Assemble all files for given releases ready for a JARI
					
					
					Currently copies files only
					
					If duplicate file exists then aborts - Need to come up with a strategy for renaming filename and install file
Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwmd1	Initial creation

*/
constants
	Target_Folder : String = 'F:\SETUP\782\JARI\MikeTest';
	Base_Folder : String = 'F:\SETUP\';
	Base_773_Folder : String = '773';
	Base_781_Folder : String = '781';
	Base_782_Folder : String = '782';
	
	Hotfixes_Folder : String = 'Hotfixes';
	JadeMaster_Folder : String = 'JadeMaster';
	Schemas_Folder : String = 'schemas';
	Server_Folder : String = 'server';
	Misc_Folder : String = 'c_misc';
	Bin_Folder : String = 'c_bin';
	JMT_Folder : String = 'JMT';
	
	Preload_File : String = 'JMTInstall_preload2.txt';
	Install_File : String = 'JMTInstall.txt';
	
	Cmd_Schema : String = 'SCM';
	Cmd_RunJade : String = 'RUNJADE';
	Cmd_SchemaCheck : String = 'SCMCHK';
	PortSchema : String = 'PortSchema';
	Delimeter : String = ',';
vars
	basefolder, hotfixesFolder, tfolder, tBinFolder, tMiscFolder, tSchemasFolder, jmtFolder  : FileFolder;
	sSchemasFolder : FileFolder;
	schemaNode, fileNode, hotfixesNode, patchNode : FileNode;
	preloadFile, installFile, schemaFile, outputFile : File;
	cmdLine, release, hotfix, patch, par, portSchemaFileName, tmpStr : String;
	pos, numPatches, numScripts : Integer;
	ts : TimeStamp;
	successfulCopy : Boolean;
begin
	/*Create folder structure
		\server
			\c_bin
			\c_misc
				\Documentation
				\japInstaller
				\schemas
				
	create \server\c_misc\JMTInstall_preload2.txt (target preload file)
	
	Iterate thru each release
		Copy all schemas   JMTnnn\Schemas to \schemas
		Append target preload file with the contents of JMTnnn\JMTInstall.txt
		
		
		Iterate thru each hotfix
			copy JMTnnn\Hotfixes\nnnHotfix_nnn\nnnHotfix_nnn\schemas\*.* to \schemas
			Append target preload file with the contents of JMTnnn\Hotfixes\nnnHotfix_nnn\nnnHotfix_nnn\jmtInstall.txt
			
		etc...
		
		
		Note don't copy the line SCMCHK::NOERRORS to the target preload
		
		
		
	
	*/
	
	write 'Start...';
	create tfolder transient;
	tfolder.usePresentationFileSystem := true;
	tfolder.fileName := Target_Folder;
	if not tfolder.isAvailable() then
		tfolder.make();
	endif;
	
	create tBinFolder transient;
	tBinFolder.fileName := Target_Folder &amp; '\' &amp; Server_Folder  &amp; '\' &amp; Bin_Folder ;
	if not tBinFolder.isAvailable() then
		tBinFolder.make();
	endif;
	
	create tMiscFolder transient;
	tMiscFolder.fileName := Target_Folder &amp; '\' &amp; Server_Folder  &amp; '\' &amp; Misc_Folder ;
	if not tMiscFolder.isAvailable() then
		tMiscFolder.make();
	endif;
	
	create tSchemasFolder transient;
	tSchemasFolder.fileName := Target_Folder &amp; '\' &amp; Server_Folder  &amp; '\' &amp; Misc_Folder &amp; '\' &amp; Schemas_Folder;
	if not tSchemasFolder.isAvailable() then
		tSchemasFolder.make();
	endif;
	
	create preloadFile transient;
	preloadFile.fileName := tMiscFolder.fileName &amp; '\' &amp; Preload_File &amp; tmpStr &amp; '.csv';
	preloadFile.mode := File.Mode_Output;
	
	
	
	create basefolder transient;
	basefolder.usePresentationFileSystem := true;
	basefolder.fileName := Base_Folder;
	create jmtFolder transient;
	create hotfixesFolder transient;
	create sSchemasFolder transient;
	
	foreach fileNode in basefolder.files() do
		if fileNode.class = FileFolder and (fileNode.name = Base_773_Folder or fileNode.name = Base_781_Folder or fileNode.name = Base_782_Folder) then
			release := fileNode.name;
			write 'release ' &amp; release;
			
	//Processing Full Release
			jmtFolder.fileName := fileNode.fileName &amp; '\' &amp; JMT_Folder &amp; release;
			if not jmtFolder.isAvailable() then write 'Aborting - JMT Folder not available'; return; endif;
			sSchemasFolder.fileName := jmtFolder.fileName &amp; '\' &amp; Schemas_Folder;
			if not sSchemasFolder.isAvailable() then write 'Aborting - Schemas Folder not available'; return; endif;
			foreach schemaNode in sSchemasFolder.FileFolder.files do
				successfulCopy := call copyFile (schemaNode.fileName, tSchemasFolder .fileName &amp; '\' &amp; schemaNode.name, true);
				if not successfulCopy then
					write 'Schema Copy. File already exists: ' &amp; schemaNode.fileName;
					write 'Aborted';
					return;
				endif;
			endforeach;
			
	//Processing Hotfixes
			hotfixesFolder.fileName := fileNode.fileName &amp; '\' &amp; Hotfixes_Folder;
			if not hotfixesFolder.isAvailable() then write 'Aborting - Hotfixes Folder not available'; return; endif;
			foreach hotfixesNode in hotfixesFolder.files where hotfixesNode.class = FileFolder do
				hotfix := hotfixesNode.name[hotfixesNode.name.pos('_', 1) + 1 : end];
				foreach patchNode in hotfixesNode.FileFolder.files where patchNode.class = FileFolder and patchNode.name &lt;&gt; JadeMaster_Folder and patchNode.name[1:3] &lt;&gt; release do
					patch := patchNode.name[1:3];
					par := patchNode.name[8:end];
					
					sSchemasFolder.fileName := patchNode.fileName &amp; '\' &amp; patch &amp; '\' &amp; Schemas_Folder;
					if not sSchemasFolder.isAvailable() then write 'Aborting - Schemas Folder not available'; return; endif;
					foreach schemaNode in sSchemasFolder.FileFolder.files do
						successfulCopy := call copyFile (schemaNode.fileName, tSchemasFolder .fileName &amp; '\' &amp; schemaNode.name, true);
						if not successfulCopy then
							write 'Schema Copy. File already exists: ' &amp; schemaNode.fileName;
							write 'Aborted';
							return;
						endif;
					endforeach;
				endforeach;
				
			endforeach;
		
		
		endif;
	endforeach;
	write 'Finished';
epilog
	delete basefolder;
	delete tfolder;
	delete tBinFolder;
	delete tMiscFolder;
	delete tSchemasFolder;
	delete jmtFolder;
	delete hotfixesFolder;
	delete sSchemasFolder;
	
	delete preloadFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createDataPatch" id="a342da33-44ed-41fa-ac02-6baa7bba693c">
        <source>createDataPatch( _parNo, _patchNo : String; _extractOptionDB : Boolean; _readmeParTopic, _readmeParDescription, _readmeCloseDetail, _readmeAreasAffected : String );

vars
	p	: Patch;
	rt	: RootHotFixes;
	
begin

	rt := RootHotFixes.firstInstance;

	if rt = null then
		beginTransaction;
		create rt;
		commitTransaction;
	endif;

	beginTransaction;
	create p;
	p.setForCreate( _parNo, /*_patchNo,*/ _extractOptionDB, false, false, _readmeParTopic, _readmeParDescription, _readmeCloseDetail, _readmeAreasAffected, "" );
	commitTransaction;
	
end;
</source>
        <Parameter name="_parNo" type="String"/>
        <Parameter name="_patchNo" type="String"/>
        <Parameter name="_extractOptionDB" type="Boolean"/>
        <Parameter name="_readmeParTopic" type="String"/>
        <Parameter name="_readmeParDescription" type="String"/>
        <Parameter name="_readmeCloseDetail" type="String"/>
        <Parameter name="_readmeAreasAffected" type="String"/>
    </JadeMethod>
