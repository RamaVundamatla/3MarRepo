    <JadeMethod name="getUncreditedAmount" id="6e4b92bf-c324-4fd6-a580-b4a434f80e18">
        <source>getUncreditedAmount() : Decimal;
// 37141 return the proforma total less any cash credits, used to determine how much more credit can be applied
vars
//	amount		: Decimal[16, 6];
	cashPayment		: CM_CashPayment;
	creditDetail	: CM_CashCreditDetail;
	amount		: Decimal[23, 6];	//11 May 2018	NDL	TFS 38528
begin
	if self.allCashPayments.isEmpty then
		amount := self.lineTotal;
	else
		foreach cashPayment in self.allCashPayments do
			amount := amount + cashPayment.getUncreditedAmount();
		endforeach;
	endif;
	
	// from TFS 1890 Apr 2016 guard against over-allocation
	if amount &lt; 0 then
		amount := 0;
	endif;
	return amount;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isManual" id="19cb1ac3-1504-4de0-8c91-138eb3cc857f">
        <source>isManual() : Boolean;
// TFS 45953 do not use void as manual indicator
/*
Purpose:	TFS 45953		
Date				Who			Reason
OCTOBER 2019		JLGAB1 initial creation
*/



vars

	cashPayment : CM_CashPayment;
begin
	foreach cashPayment in self.allCashPayments	discreteLock do
		return cashPayment.isManual;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMyCashReceiptCancelled" id="4945b420-8725-4bd7-bd90-4030c740ff3a">
        <source>isMyCashReceiptCancelled() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/02/2025	navkc1 JIRA Bug MTN-34043: QTS | All cash lines are updated to VOID when a cash receipt is CANCELLED

*/

vars
	cr		: CM_CashReceipt;
begin
	
	cr := self.myCashReceipt;
	
	if cr &lt;&gt; null then
		if cr.isCancelled() then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
