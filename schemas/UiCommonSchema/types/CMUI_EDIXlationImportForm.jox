    <JadeMethod name="doCmbTypeClick" id="5a7ad2d8-b4dd-439f-a9a4-8f74f40dbccb">
        <updating/>
        <source>doCmbTypeClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2023	jlier1	Initial creation

*/

vars
	oldType, newType : Integer;
begin
	oldType	:= self.cmbType.tag.Integer;
	newType := self.cmbType.getCurrentItemData;
	
	if oldType = newType then
		return;
	endif;
	
	// resize form based on which controls should be visible
	self.setupControls (newType);
	

	self.cmbType.tag := newType.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="c728439b-caa0-4455-ac2b-2d94bb383601">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 January 2023		jlizm1	Initial creation TFS 56291 POB - CSV Import of translation terms
15 February 2023	jlizm1	TFS 56604 CSV Import of translation terms - improve error messages
18 December 2024	navcs2	MTN-33462	EUP NTO-972 - EDI Data translation uploads do not save the Foreign Out Code
*/

vars
	type 		: Integer;
	colSystem 	: Integer;
	colForeign 	: Integer;
	colOut 		: Integer;				// 18/12/2024 navcs2 MTN-33462
	terminal	: CM_Terminal;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	filePath,
	filter 		: String;
	file		: File;
	theResult	: Integer;
	cmifMonitor	: CMIF_Monitor;
	
begin
	if not app.getMyUser.canDo(null, PmAdmEdixlationMaint) then
		return ;
	endif;
	
	type := self.cmbType.tag.Integer;
	colSystem := self.txtColSystem.text.asIntegerJMT;
	colForeign := self.txtColForeign.text.asIntegerJMT;
	colOut := self.txtColForeignOut.text.asIntegerJMT;		// 18/12/2024 navcs2 MTN-33462
	
	if type = XLATION_TYPE_NULL then
		app.msgBox (app.getErrorString(Please_select_type), app.getErrorString(Error), MsgBox_OK_Only);
		self.cmbType.setFocus;
		return;
	endif;
	
	if not CM_XlationTable@isSystemXlation(type) then
	
		if type = XLATION_TYPE_WORKPOINT or CM_XlationTable@isOperatorTerminalXlation(type) then
			terminal := self.cmbTerminal.listObject.CM_Terminal;
			if terminal = null then
				app.msgBox (app.getErrorString1(Please_Select_A, app.getErrorString(Terminal)), app.getErrorString(Error), MsgBox_OK_Only);
				self.cmbTerminal.setFocus;
				return;
			endif;
		endif;
		
		if type &lt;&gt; XLATION_TYPE_WORKPOINT then
			operator := self.cmbOperator.listObject.CM_Operator;
			if operator = null then
				app.msgBox (app.getErrorString(Please_select_operator), app.getErrorString(Error), MsgBox_OK_Only);
				self.cmbOperator.setFocus;
				return;
			endif;
		endif;
		
		if type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
			cargoType := self.cmbCargoType.listObject.CM_CargoType;
			if cargoType = null then
				app.msgBox (app.getErrorString(Please_select_cargo_type), app.getErrorString(Error), MsgBox_OK_Only);
				self.cmbCargoType.setFocus;
				return;
			endif;
		endif;
	endif;
	
	if colSystem = null then
		app.msgBox (app.getErrorString1(REQUIRED_FIELD, app.getFormCaptionsString(Xlat_0025424)), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtColSystem.setFocus;
		return;
	endif;
	
	if colForeign = null then
		app.msgBox (app.getErrorString1(REQUIRED_FIELD, app.getFormCaptionsString(Xlat_0025423)), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtColForeign.setFocus;
		return;
	endif;
	
	
	filter := "Comma Separated Variable (*.csv)|*.csv|All Files (*.*)|*.*";
	filePath := app.getFilePath('c:\', filter, null, true);
	
	if filePath = null then
		return;
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.kind := File.Kind_Unknown_Text;
	
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.message := app.getErrorString(PleaseWait) &amp; "...";
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Data Translations', app.getErrorString(PleaseWait) &amp; "...");
	self.pbProgressBar.visible := true;
	self.updateProgress(cmifMonitor);
	self.modalDialogReturnValue := 0;
	
	while true do
	
		app.myTrxCA.trxImportEDIXlationFromCSV(file, type, operator, terminal, cargoType, self.chkIgnoreFirstRow.value, colSystem, colForeign, colOut, app.myPassport);		// 18/12/2024 navcs2 MTN-33462
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;	
	endwhile;
	
	inheritMethod();

epilog
	delete file;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;	
	self.pbProgressBar.visible := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="0a47732c-a600-4f15-9b51-68b051dd5473">
        <updating/>
        <source>setupControls(_type :Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2023		jlier1	Initial creation TFS 56291 POB - CSV Import of translation terms
31 January 2023		jlizm1	TFS 56291 POB - CSV Import of translation terms

*/

constants
	SPACING = 10;
	LABEL_SPACING = 100;
	GAP_TO_BOTTOM = 80;
	
vars
	isFullWidth		:Boolean;
	
begin
	// hide everything
	self.lblOperator.visible	:= false;
	self.cmbOperator.visible	:= false;
	self.lblTerminal.visible	:= false;
	self.cmbTerminal.visible	:= false;
	self.lblCargoType.visible	:= false;
	self.cmbCargoType.visible	:= false;
	self.lblCargoType.top := self.lblTerminal.top;
	self.cmbCargoType.top := self.cmbTerminal.top;
		
	if  CM_XlationTable@isSystemXlation(_type)  then		
		// system code - nothing more to show 
	elseif _type = XLATION_TYPE_WORKPOINT then
			self.lblTerminal.visible	:= true;
			self.cmbTerminal.visible	:= true;	
			self.lblTerminal.left := self.lblType.left;
			self.cmbTerminal.left := self.cmbType.left;
	else
		// operator code xlation
		self.lblOperator.visible	:= true;
		self.cmbOperator.visible	:= true;
		
		if CM_XlationTable@isOperatorTerminalXlation(_type) then
			self.lblTerminal.visible	:= true;
			self.cmbTerminal.visible	:= true;
			isFullWidth 				:= true;
			self.cmbTerminal.left := self.cmbOperator.left + self.cmbOperator.clientWidth + LABEL_SPACING;
			self.lblTerminal.left := self.cmbTerminal.left - self.lblTerminal.clientWidth - SPACING;
			
		elseif _type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
			self.lblCargoType.visible 	:= true;
			self.cmbCargoType.visible 	:= true;
			isFullWidth 				:= true;
			self.cmbCargoType.left := self.cmbOperator.left + self.cmbOperator.clientWidth + LABEL_SPACING;
			self.lblCargoType.left := self.cmbCargoType.left - self.lblCargoType.clientWidth - SPACING;
		endif;
	endif;
	
	
	if isFullWidth then
		if self.cmbCargoType.visible then
			self.clientWidth := (SPACING + self.cmbCargoType.left + self.cmbCargoType.width + SPACING + SPACING).Integer;
		else
			self.clientWidth := (SPACING + self.cmbTerminal.left + self.cmbTerminal.width + SPACING + SPACING).Integer;
		endif;
	else
		self.clientWidth := (SPACING + self.cmbType.left + self.cmbType.width + SPACING + SPACING).Integer;
	endif;
	
	self.height := self.txtColForeign.top + self.txtColForeign.height + GAP_TO_BOTTOM;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c6ccb978-889a-42d1-ad3e-678f337b6fcf">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2023		jlier1	Initial creation TFS 56291 POB - CSV Import of translation terms
31 January 2023		jlizm1	TFS 56291 POB - CSV Import of translation terms

*/

vars
	cargoType : CM_CargoBOLType;
begin
	inheritMethod();
	
	self.myAssistant.comboBoxEDIXlationTypes (self.cmbType, true, false, null);
	self.myAssistant.comboBoxTerminalAll (self.cmbTerminal, null);
	self.myAssistant.comboBoxCargoTypesAll(self.cmbCargoType, cargoType.CM_CargoType);
	
	setupControls(0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="890d3ecf-d4be-47a3-b967-f603b467f050">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 January 2025 10:08:32.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025419, locale);
	chkIgnoreFirstRow.translateCaption(Xlat_0025420, locale);
	grpType.translateCaption(Xlat_0025421, locale);
	lblCargoType.translateCaption(Xlat_0025422, locale);
	lblColForeign.translateCaption(Xlat_0025423, locale);
	lblColForeignOut.translateCaption(Xlat_0027033, locale);
	lblColSystem.translateCaption(Xlat_0025424, locale);
	lblOperator.translateCaption(Xlat_0025425, locale);
	lblTerminal.translateCaption(Xlat_0025426, locale);
	lblType.translateCaption(Xlat_0025427, locale);
end;</source>
    </JadeMethod>
</GUIClass>
