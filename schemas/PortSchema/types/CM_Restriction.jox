    <JadeMethod name="getRestrictionBounds" id="1bc20050-78d0-4ed2-85eb-75e3010c951d">
        <source>getRestrictionBounds(fromArea, toArea : String output; pLocationControllers : CM_LCArray);
// ---------------------------------------------------------------------------
// Created:			31 May 2001 by cnwdwq1
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	sharedLock(self);
	
	if pLocationControllers.isEmpty then
		fromArea 	:= '&lt;Unknown&gt;';
		toArea		:= fromArea;
		return;
	endif;

	fromArea := pLocationControllers.first.getID();

	if pLocationControllers.size = 1 then
		toArea 	:= fromArea;
	else
		toArea 	:= pLocationControllers.last.getID();
	endif;
end;</source>
        <Parameter name="fromArea" type="String" usage="output"/>
        <Parameter name="toArea" type="String" usage="output"/>
        <Parameter name="pLocationControllers" type="CM_LCArray"/>
    </JadeMethod>
