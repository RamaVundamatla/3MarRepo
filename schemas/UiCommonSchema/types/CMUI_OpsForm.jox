        <source>doToggleExtraInfo() protected, updating;
// ---------------------------------------------------------------------------
// Created:      10 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if self.mnuToggleExtraInfo.caption = self.MNU_EXTRAINFO_SHOW then
		self.splExtraInfo.showRightControl(100 - self.splExtraInfoRatio, true);
		self.mnuToggleExtraInfo.caption := self.MNU_EXTRAINFO_HIDE;
	else
		self.splExtraInfoRatio := self.splExtraInfo.leftToRightRatio;
		self.splExtraInfo.hideRightControl(true);
		self.mnuToggleExtraInfo.caption := self.MNU_EXTRAINFO_SHOW;
	endif;
	
	self.doResizeGridContainer;
end;</source>
