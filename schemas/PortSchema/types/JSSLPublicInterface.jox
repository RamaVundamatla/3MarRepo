    <JadeMethod name="setTransactionStateFlag" id="bd4ddaba-73e6-46af-8a7d-c8b07ea2495c">
        <updating/>
        <source>setTransactionStateFlag(pIsDoTransactionState:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 April 2003 by cnwdad1
//
// Purpose:		Sets a flag to tell the Security Registry whether to handle
//				database transaction state.  If false, it will be assumed that the
//				application schema will handle the transaction state.
//
//				The flag will default to true.
//
// Parameters:	pIsDoTransactionState - True if the Security Registry will handle
//					the transaction state, or false if the application schema will
//					handle the transaction state.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pIsDoTransactionState);
end;</source>
        <Parameter name="pIsDoTransactionState" type="Boolean"/>
    </JadeMethod>
