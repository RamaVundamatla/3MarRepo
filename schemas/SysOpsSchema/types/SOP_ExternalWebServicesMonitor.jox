    <JadeMethod name="populateTableOpsView" id="5396541d-ea7e-409b-b2b1-42bf4d45915e">
        <updating/>
        <source>populateTableOpsView() updating;
/*
Purpose:			

Date			Who		Reason
27 July 2021	navab1	TFS 50669
30 Aug 2022 	navma1	Bug 54684: MTN - Issues with External Monitor Screen if there are more than 32,000 record
03/4/2023		jlier1 	TFS 56856 - refactored 
26/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working
05/11/2025 navcs2 MTN-35303 CUX - Slowness in External Web Services Monitor

*/

vars
	table       : CM_DataTable;
	ewsact      : CM_EWSActivityOpsview;
	theDataLine : String;
	idx 		: Integer;
	fromTime, 
	toTime 		: Time;
	terminals	: CM_TerminalByCodeDict;			//27 May 2024	navcs2	ChangeRequest 59188
	progress			: CMIF_Monitor;	
	numberOfTasks,
	numberDone			: Integer;
	lastUpdate			: Decimal [20];
begin
	numberOfTasks :=  app.myRoot.allEWSOpsviewActivities.size;
	
	// 15/08/2024	navcs2	Bug 65588 Start
	create progress transient;
	app.myPassport.setMyCMIFMonitor(progress);
	progress.myParent := self;
	if progress &lt;&gt; null then
		progress.numFound := numberOfTasks;
		progress.message := "Searching External Web Service Activites....";
		progress.partsDone := 0;
		progress.partsInJob := numberOfTasks;
		self.modalDialogShow(null, app.getErrorString(Cancel),null ,OK , app.getErrorString(CMUI_Retreiving_Data), progress.message);
	endif;
	// 15/08/2024	navcs2	Bug 65588 End
	
	if self.mskTimeFrom.getTime().isValid then		//27 May 2024	navcs2	ChangeRequest 59188
		fromTime := self.mskTimeFrom.getTime();		//27 May 2024	navcs2	ChangeRequest 59188
	else
		fromTime.setTime(0,0,0,0);
	endif;
	if self.mskTimeTo.getTime().isValid then		//27 May 2024	navcs2	ChangeRequest 59188
		toTime := self.mskTimeTo.getTime();			//27 May 2024	navcs2	ChangeRequest 59188
	else
		toTime.setTime(23,59,59,999);
	endif;
	
	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
	
	create terminals transient;
	
	self.getTerminals(terminals);	//27 May 2024	navcs2	ChangeRequest 59188
	self.getStatus();				//27 May 2024	navcs2	ChangeRequest 59188
	self.getResponses();			//27 May 2024	navcs2	ChangeRequest 59188	
	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	
	if self.cmbType.listIndex &gt; 1 then						//27 May 2024	navcs2	ChangeRequest 59188
		self.filterType := self.cmbType.text;				//27 May 2024	navcs2	ChangeRequest 59188
	endif;
	if self.cmbAction.listIndex &gt; 1 then					//27 May 2024	navcs2	ChangeRequest 59188
		self.filterAction := self.cmbAction.text[1:1];		//27 May 2024	navcs2	ChangeRequest 59188
	endif;
	
	self.filterInterfaceName:=null;
	self.filterClass:= CM_EWSActivityOpsview;
	
	table := self.tblData;
	
	table.fixedRows := 1;
	table.rows := 1;

	foreach ewsact in app.myRoot.allEWSOpsviewActivities  reversed do // ### TFS 53105 29JUL2022 NAVAB1 REVERSED to check date and make quicker
		if self.filterDateFrom.isValid() 			// ### TFS 53105 29JUL2022 NAVAB1
		and ewsact.created &lt; filterDateFrom then 	// ### TFS 53105 29JUL2022 NAVAB1
			break;									// ### TFS 53105 29JUL2022 NAVAB1
		endif;

		if not self.includeObjectEWS(ewsact) then
			continue;
		endif;
	
		theDataLine := ewsact.getAttributeStringForDefArray(table.allTblDataEntRows);

		if table.rows &gt;= JadeTableRowLimit then					//30.08.2022 navma1 #54684				// 05/11/2025 navcs2 MTN-35303
			app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String)				// 05/11/2025 navcs2 MTN-35303
				,app.getErrorString(TableRowLimitReached),MsgBox_OK_Only + MsgBox_Information_Icon);	// 05/11/2025 navcs2 MTN-35303
			break;																						// 05/11/2025 navcs2 MTN-35303
		endif;
		
		idx := table.addItemObject(ewsact, theDataLine);

		// // 15/08/2024	navcs2	Bug 65588 Start
		numberDone := numberDone + 1;
		if (app.relativeMachineTime - lastUpdate) &gt; 500 then
			if progress &lt;&gt; null then
				self.updateProgress(progress);
				if not progress.updateProgress(progress.message, numberOfTasks,numberDone) then
					return;
				endif;
			endif;
			lastUpdate := app.relativeMachineTime;
		endif;
		// 15/08/2024	navcs2	Bug 65588 End
	endforeach;
	
	self.lblQueryLinesValue.caption := (table.rows - table.fixedRows).String;
	
epilog
	delete progress;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := MP_DEFAULT;	
	delete terminals;		//27 May 2024	navcs2	ChangeRequest 59188
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTableQships" id="e447e662-af38-4f9f-8a8d-3e76fec94da8">
        <updating/>
        <source>populateTableQships() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 05 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

***************************************************
03/4/2023	jlier1 		TFS 56856 - refactored to call one method to search - just set up the filtered attributes here
26/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working

*/
vars
	fromTime, 
	toTime 			: Time;		
	terminals : CM_TerminalByCodeDict;				//27 May 2024	navcs2	ChangeRequest 59188
begin
	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	

	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
		
	create terminals transient;
	self.getTerminals(terminals);	//27 May 2024	navcs2	ChangeRequest 59188
	self.getStatus();				//27 May 2024	navcs2	ChangeRequest 59188
	self.getResponses();			//27 May 2024	navcs2	ChangeRequest 59188	
	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	
	self.filterClass:= CM_EWSActivityQships;
	self.filterInterfaceName :=null;
	
	self.populateTable(terminals,app.myRoot.allEWSActivities);

epilog
	delete terminals;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTableSearch" id="a64053c5-e4ad-4544-b967-e96ccb9e72ab">
        <source>populateTableSearch(_allEWSActivities : ObjectSet; _pd : CMS_Progress);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
27/09/2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
*/

vars
	iter 		: Iterator;
	obj			: Object;
	ewAct 		: CM_ExternalWebServiceActivity;
	theDataLine : String;
	idx 		: Integer;
	pd			: CMS_Progress;
begin
	pd := _pd;
	
	self.tblData.fixedRows := 1;
	self.tblData.rows := 1;
	
	self.myFilteredCollection.clear();
	
	iter:=_allEWSActivities.createIterator;
	
	while iter.next(obj) do
		ewAct := obj.CM_ExternalWebServiceActivity;
		theDataLine := ewAct.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		idx := self.tblData.addItemObject(ewAct, theDataLine);
		pd.progress.partsDone := idx;
		self.myFilteredCollection.add(ewAct);																						
		if ewAct.isInvoiceParts then													// 27/09/2024	navcs2		ChangeRequest 66181
			if ewAct.CM_EWSActivityInvoiceAPIParts.direction =  CM_EWSActivityInvoiceAPIParts.DIRECTION_RECEIVE then
				tblData.accessRow(idx).backColor := LightYellow;
			else					
				tblData.accessRow(idx).backColor := LightBlue;
			endif;
		endif;
		
		if idx &gt;= JadeTableRowLimit then
			app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String),
				app.getErrorString(TableRowLimitReached), MsgBox_OK_Only + MsgBox_Information_Icon);
			break;
		endif;
		
	endwhile;
epilog
	delete iter;
	delete pd;
end;</source>
        <Parameter name="_allEWSActivities" type="ObjectSet"/>
        <Parameter name="_pd" type="CMS_Progress"/>
    </JadeMethod>
    <JadeMethod name="resetFilters" id="02eeeace-d7bd-4f03-8878-6f380228425d">
        <updating/>
        <source>resetFilters() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2023	jlier1	Initial creation 56856
24/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working

*/

vars

begin
	self.filterAction:=null;
	self.filterDateFrom:=null;
	self.filterDateTo:=null;
	self.filterInvoice:=null;
	self.filterProtocol.clear();			// 24/05/2024	navcs2	ChangeRequest 59188
	self.filterResponseCode.clear();		// 24/05/2024	navcs2	ChangeRequest 59188
	self.filterStatus.clear();				// 24/05/2024	navcs2	ChangeRequest 59188
	self.filterTerminals.clear();			// 24/05/2024	navcs2	ChangeRequest 59188
	self.filterType:=null;
	self.filterText := null;				// 14/08/2024	navcs2	Bug 65590
	
epilog

end;</source>
