    <JadeMethod name="setTerminalAreasFromType" id="9ebd8b53-e43d-43b2-83c9-de4f3c4e735f">
        <updating/>
        <source>setTerminalAreasFromType(_taTypes : CM_TATypeByTypeDict) updating;
//Given an array of terminal areas, adds them to the list of ta's
//held in the system.
// 13 Dec 11	EPR 	PAR 28714 - allowedTerminalAreas has been replaced by allowedTAMasters
vars

	taSet		: CM_TerminalAreaSet;
begin
 	//--------------
 	//Clear out the existing collection
 	//--------------

 	if self.allowedTAMasters.size &gt; 0 then
		self.allowedTAMasters.clear;
	endif;
	
	if _taTypes.isEmpty  then
		return;
	endif;

	//-------------
	//Add these to the coll
	//-------------
	create taSet transient;
	self.getTerminalAreasFromType(_taTypes, taSet);
	taSet.copy(self.allowedTAMasters);

epilog

	delete taSet;
end;</source>
        <Parameter name="_taTypes" type="CM_TATypeByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="6c0866a3-7539-43f2-8a8f-1f46a168438a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

// cnwdvb1 21 May 2003 

vars

	propName	: String;
	
begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;

	if	propName = CM_Machine::myMachineController.name or
		propName = CM_Machine::allQueues.name or
		propName = CM_Machine::myPrimaryQueue.name or
		propName = CM_Machine::allAllowedCargoTypes.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);


end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="statusStr" id="b8740896-af5f-48e7-940c-7039dfdf2664">
        <methodInvocation>mapping</methodInvocation>
        <source>statusStr(set: Boolean; value: String io) mapping;
//Returns the machine status object's current status
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin
	value := "";
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if status = null then
		return;
	endif;
	
	value := status.getStatusStr(status.status);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="storeErrorDetails" id="8ca33727-7bf9-4564-a8a2-5091f42c65e9">
        <source>storeErrorDetails(_detail  : String; _array : StringArray512 io);
// -------------------------------------------
// Created 09 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	if _detail = null then
		return;
	endif;
	
	if _array = null then
		create _array transient;
	endif;
	
	if not _array.includes(_detail) then
		_array.add(_detail[1:512]);
	endif;


end;</source>
        <Parameter name="_detail" type="String"/>
        <Parameter name="_array" type="StringArray512" usage="io"/>
    </JadeMethod>
    <JadeMethod name="useDetailsViewForPickup" id="42948497-15fd-466d-bde8-fc2027ead9bf">
        <source>useDetailsViewForPickup() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwmd1	Initial creation

*/

vars
	config 			:CM_RTVehicleConfig;
	gotException	:Boolean;
	result			:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, config, gotException);
	
	config := self.myTerminal.getRTVehicleConfigForObject (self);
	
	result := config.useDetailsViewForPickup;
	
	// will return false if no config object
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
