    <JadeMethod name="pxyCreateUpdateProxy" id="ffa4ce4e-e4aa-4284-9e49-7ce89f919640">
        <source>pxyCreateUpdateProxy(): SelfType;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars
	pxySelf : SelfType;
	mapping : CM_EDIIssueMapping;
begin
	pxySelf :=  inheritMethod();
	
	pxySelf.myTerminal := self.myTerminal;
	pxySelf.myEDIFileType := self.myEDIFileType;
	
	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
