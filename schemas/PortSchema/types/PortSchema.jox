    <JadeMethod name="cmsCommitTransaction" id="acf65946-1bcd-485d-b71c-ccc27fb20f04">
        <updating/>
        <source>cmsCommitTransaction(_passport : CM_Passport) updating;

vars

begin

	if _passport &lt;&gt; null then
		// test to ensure any deferred updates have been done
		if _passport.raiseExIfDeferredUpdNotDone() then
			app.cmsAbortTransaction();
			return;
		endif;
	endif;

	commitTransaction;
//	self.setLockFlag(false);
	self.commitAlert();
	self.beginLoadCount := 0;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="cmsEndLoad" id="d499379f-f75c-4410-b4ca-74fb84ac0eaa">
        <source>cmsEndLoad(_loadStateSet : Boolean io);
// ---------------------------------------------------------------------------
// Created:     26 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _loadStateSet then
		endLoad;
		_loadStateSet := false;
	endif;
	

end;</source>
        <Parameter name="_loadStateSet" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnGlobalExceptionHandler" id="8eb8c325-a742-4c1f-96fb-0d9171149d8a">
        <updating/>
        <source>cnGlobalExceptionHandler(exObj: Exception): Integer updating;
//
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
//
vars
	msg : String;
begin
	msg := method.qualifiedName &amp;' Exception handler called,'&amp;exObj.errorCode.String&amp;' '&amp;exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
	app.writeLog(msg, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	if exObj.errorCode = 1228 or 
	   exObj.errorCode = 1295 or 
	   exObj.errorCode = 3015 or 
	   exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := method.qualifiedName &amp;' SDS Exception, cant continue,'&amp;exObj.errorCode.String&amp;' '&amp;exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
	
	//epr 29/8/19 let JADE return the appropriate REST error message - 16 Feb 2021 NDL Migrated to here from 'CardSchema' patched version, so its not lost.
	if exObj.errorCode &gt; 11100 and exObj.errorCode &lt;= 11199  then
		msg := method.qualifiedName &amp; " passed back REST exceptions";
		app.writeLog(msg, LogERROR);
		return Ex_Pass_Back;
	endif;

	return inheritMethod(exObj);
epilog

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnGlobalLockExceptionHandler" id="11999e84-5287-4612-b7fe-02be0ecf5a61">
        <updating/>
        <source>cnGlobalLockExceptionHandler(pExObj: LockException): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 April 2021	navmd1	Initial creation Migrated REST changes from CardSchema, so we don't have to keep caring about CS changes (as much)

*/

vars
	res	: Integer;
begin	
	
	// We only care about mangling REST web methods, anything else can just use the non-modified handler
	if not app.cnApplicationType = ApplicationType_Non_GUI_Rest then
		return inheritMethod(pExObj);
	endif;
	
	app.setCnApplicationType(ApplicationType_Non_GUI_Web);	// Pretend we're a SOAP app instead ;)
	res := inheritMethod(pExObj);
	app.setCnApplicationType(ApplicationType_Non_GUI_Rest);	// Reset
	
	return res;
epilog
	
end;</source>
        <Parameter name="pExObj" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
