    <JadeMethod name="areAllEntryTasksEqStatus" id="e39bde9f-1220-4ce4-b9e7-b488b477d0bf">
        <source>areAllEntryTasksEqStatus(_status : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2011	cnwer1	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if not wle.areAllEntryTasksEqStatus(_status) then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areAllQueueEntriesEqualStatus" id="58f1e7c5-9809-4307-9b07-40790a623202">
        <source>areAllQueueEntriesEqualStatus(statusToCheck : Integer) : Boolean	;
//Returns true if all task statuses are == passed in status,
//else returns false.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 06 Mar 2025  navma1 		 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
vars
	entry : CM_RTQueueEntry;
begin
	foreach entry in allEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		//Collect all statuses
		if entry.status &lt;&gt; statusToCheck then
			return false;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="statusToCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areAllnonCompleteWLEsInTransit" id="79e197cb-3fe8-4b3e-bf73-7f82b1225bd2">
        <source>areAllnonCompleteWLEsInTransit():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2009	cnwndl1	Initial creation	Par 21519
29/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars

	wle	:	CM_WorkListEntry;
	
begin
	foreach wle in self.workListEntries discreteLock do				//06.03.2025 navma1 #MTN-34179
		if wle.status &lt;&gt; WLE_COMPLETED then
			if wle.myTrackedItem &lt;&gt; null then // PAR 24225
				if not wle.myTrackedItem.isInTransitOnShip then
					return false;
				endif;
			endif;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areWLEsAllDone" id="6bfbc85d-2bf6-4ef6-b69f-bc62f6a05415">
        <source>areWLEsAllDone() : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 23/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 06/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking job as Direct Delivery
// 02 Apr 2024  navma1		ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen//02.04.2024 navma1 #63302
// 06 Mar 2025  navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------
vars
	wle			:	CM_WorkListEntry;
	directLoad  : Boolean;
	ti			: CM_TrackedItem;
begin

	directLoad := self.isDirectDeliveryJob;															// TFS 52293
	foreach wle in self.workListEntries discreteLock where wle.myDirectDeliveryParentWLE = null do	// TFS 51935
		
		ti := wle.myTrackedItem;																	//02.04.2024 navma1 #63302
		
		if directLoad and ti &lt;&gt; null and ti.hasBeenMerged  then										// TFS 52360	//06.03.2025 navma1 #MTN-34179
			continue;																				// TFS 52360
		endif;																						// TFS 52360
		
		if wle.status &lt;&gt; WLE_COMPLETED then
			return false;
		endif;
	endforeach;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areWLEsAllStatus" id="ee5876f1-c275-46f5-ae29-463d1a96897b">
        <source>areWLEsAllStatus(wleStat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06 Mar 2025	 navma1		 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------
vars
	wle	:	CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if wle.status &lt;&gt; wleStat then
			return false;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="wleStat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
