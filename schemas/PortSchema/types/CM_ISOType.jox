    <JadeMethod name="isHeightOK" id="63307a4c-1554-4912-abd8-2ed18cbc99e3">
        <source>isHeightOK(): Boolean;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 24 July 2003
//
//	Checks that only one height is being passed
//
//-----------------------------------------------------------------------

vars

begin
	if self.is4ft3High and (self.is4ftHigh or self.is8ft6High or self.is9ft6High or self.is8ftHigh) then
		return false;
	endif;
	
	if self.is4ftHigh and (self.is4ft3High or self.is8ft6High or self.is9ft6High or self.is8ftHigh) then
		return false;
	endif;
	
	if self.is8ft6High and (self.is4ft3High or self.is4ftHigh or self.is9ft6High or self.is8ftHigh) then
		return false;
	endif;
	
	if self.is9ft6High and (self.is4ft3High or self.is4ftHigh or self.is8ft6High or self.is8ftHigh) then
		return false;
	endif;
	
	if self.is8ftHigh and (self.is4ft3High or self.is4ftHigh or self.is8ft6High or self.is9ft6High) then
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
