    <JadeMethod name="translateForm" id="363fe1ad-899b-4984-bb73-5d5b156a3de2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 August 2025 09:54:07.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017105, locale);
	btnAddrDelete.translateCaption(Xlat_0023676, locale);
	btnAddrNew.translateCaption(Xlat_0023677, locale);
	btnAddrSave.translateCaption(Xlat_0023678, locale);
	btnAddrUpdate.translateCaption(Xlat_0023679, locale);
	btnCancel.translateCaption(Xlat_0017106, locale);
