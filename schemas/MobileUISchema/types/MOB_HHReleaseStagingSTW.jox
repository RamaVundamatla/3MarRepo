    <JadeMethod name="doResizeControls" id="91abdad8-cf23-431f-ad6b-fa505e5546d6">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	listHeight : Real;
	spaceForCombos : Real;
	spaceForButtons : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtRequestId.setAndIncrementTabIndex( tabIndex );
		self.txtRequestId.visible := true;
	endif;
	self.txtRequestId.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	

	cTop := cTop + self.txtRequestId.height + ( self.resizedMargin );
	spaceForCombos := ( stdHeight + self.resizedMargin ) * 2;
	spaceForButtons := self.getCMDButtonsHeight() + ( self.resizedMargin * 2 );
	listHeight:= (self.clientHeight - cTop - ( spaceForCombos + spaceForButtons + self.resizedMargin) );
	if _initialSetup then
		self.tblRequestDesc.setAndIncrementTabIndex( tabIndex );
		self.tblRequestDesc.visible := true;
		self.tblRequestDesc.fixedColumns := 0;
		self.tblRequestDesc.fixedRows := 0;
		self.tblRequestDesc.columns := 1;
		self.tblRequestDesc.rows := 1;
	endif;
	self.tblRequestDesc.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 listHeight ); 
								
	cTop := cTop + self.tblRequestDesc.height + self.resizedMargin;
	if _initialSetup then
		self.cmbMachine.setAndIncrementTabIndex( tabIndex );
		self.cmbMachine.visible := true;
	endif;
	self.cmbMachine.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.cmbMachine.height + ( self.resizedMargin );
	if _initialSetup then
		self.cmbTargetArea.setAndIncrementTabIndex( tabIndex );
		self.cmbTargetArea.visible := true;
	endif;
	self.cmbTargetArea.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findRequest" id="682f1ba0-d9e5-4832-bae0-884adeb0682f">
        <updating/>
        <source>findRequest( _returning : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation	Par 37033

*/

vars

	requestString : String;
	request : CM_Request;
	term : CM_Terminal;
	selectedRoadRelease : CM_BulkRelease;
	selectedPackRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	resDetString : String;
	index : Integer;
	stagedItemCount : Integer;
	outStandingItemCount : Integer;
	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	ta : CM_TerminalArea;
	locSumm : String;
	opt1Str :String;
	opt2Str :String;
	opt3Str : String;
	returnValue : Integer;
	stagingLC : CM_LocationsController;
	stwComplete : Boolean;
	delim : String;
	
	selectedShipRelease : CM_BulkRelease;	//10 Jan 2016	NDL	3189/2876
	selectedRailRelease : CM_BulkRelease;	//10 Jan 2016	NDL	3189/2876
	fullText : String;	//05 Apr 2017	NDL	TFS 3478
	array : HugeStringArray;	//05 Apr 2017	NDL	TFS 3478
	str : String;	//05 Apr 2017	NDL	TFS 3478
	backColor : Integer; //05 Apr 2017	NDL	TFS 3478
	baseBackColor : Integer;	//05 Apr 2017	NDL	TFS 3478
	
	allStagedLCs : CM_LCSet;

begin

	self.cmbTargetArea.listIndex := 1;	//22 Mar 2016	NDL

	requestString := self.txtRequestId.text;
	if not _returning then		//10 Dec 2015	NDL	Par 37288
		self.myBulkRelease := null;
	endif;
	stagedItemCount := 0;
	outStandingItemCount := 0;
	
	if requestString.trimBlanks = null or requestString = self.lblRequestId.caption.toUpper then
		if requestString = null then
			self.txtRequestId.text := self.lblRequestId.caption.toUpper;
		endif;
			
	else
		//find an active road release.
		term := self.myMobileDataAgent.myTerminal;
		selectedRoadRelease := self.getActiveBulkRelease( term, BR_TYPE_ROAD, true, requestString );	//09 Nov 2015	NDL	Par 37152
		selectedPackRelease := self.getActiveBulkRelease( term, BR_TYPE_PACKING, true, requestString );	//08 Dec 2015	NDL	Par 37288
		selectedShipRelease := self.getActiveBulkRelease( term, BR_TYPE_SHIP, true, requestString );	//10 Jan 2016	NDL	3189/2876
		selectedRailRelease := self.getActiveBulkRelease( term, BR_TYPE_RAIL, true, requestString );	//10 Jan 2016	NDL	3189/2876
		
		//08 Dec 2015	NDL	Par 37288
		//if selectedPackRelease &lt;&gt; null and selectedRoadRelease &lt;&gt; null then
		if selectedPackRelease &lt;&gt; null and ( selectedRoadRelease &lt;&gt; null or selectedShipRelease &lt;&gt; null or selectedRailRelease &lt;&gt; null ) then	//10 Jan 2016	NDL	3189/2876
			if _returning and self.myBulkRelease &lt;&gt; null then
				//leave it alone.
			else
				fullText := app.getErrorString(Pack_and_road_found_select);
				//One of each found,make them choose.
				opt1Str := app.getErrorString( Use_pack_request );
				//10 Jan 2016	NDL	3189/2876
				if selectedRoadRelease &lt;&gt; null then
					opt2Str := app.getErrorString( Use_road_release_request );
				elseif selectedShipRelease &lt;&gt; null then
					opt2Str := app.getErrorString( Use_ship_release_request );
				elseif selectedRailRelease &lt;&gt; null then
					opt2Str := app.getErrorString( Use_rail_release_request );
				endif;
				opt3Str := app.getErrorString(Neither_above_cancel);
				returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 3, app.getErrorString(Select_option) );
				if returnValue = 1 then
					self.myBulkRelease := selectedPackRelease;
				elseif returnValue = 2 then
					//10 Jan 2016	NDL	3189/2876
					if selectedRoadRelease &lt;&gt; null then
						self.myBulkRelease := selectedRoadRelease;
					elseif selectedShipRelease &lt;&gt; null then
						self.myBulkRelease := selectedShipRelease;
					elseif selectedRailRelease &lt;&gt; null then
						self.myBulkRelease := selectedRailRelease;
					endif;
				else
					return;
				endif;
			endif;
			
		elseif selectedPackRelease &lt;&gt; null then
			self.myBulkRelease := selectedPackRelease;
		elseif selectedRoadRelease &lt;&gt; null then
			self.myBulkRelease := selectedRoadRelease;
		elseif selectedShipRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
			self.myBulkRelease := selectedShipRelease;
		elseif selectedRailRelease &lt;&gt; null then	//10 Jan 2016	NDL	3189/2876
			self.myBulkRelease := selectedRailRelease;
		endif;
		
	endif;

	if self.myBulkRelease = null then
		fullText := app.getErrorString(No_request_found);
	else
		create tiSet transient;
		if self.myBulkRelease.isPackingType then	//14 Decc 2015	NDL	Par 37288
			if self.myBulkRelease.releaseByType then
				fullText := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_Type);
			else
				fullText := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_ID);
			endif;
		elseif self.myBulkRelease.releaseByType then
			outStandingItemCount := self.myBulkRelease.getTotalOutstanding;
			stagedItemCount := self.myBulkRelease.getTotalStaged(tiSet, firstStagingLC);
			fullText := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_Type) &amp; " ["
			&amp; stagedItemCount.String &amp; "/" &amp; outStandingItemCount.String &amp; " " &amp; app.getErrorString(YAM_Msg_Items) &amp; "]";
		else
			outStandingItemCount  := self.myBulkRelease.getTotalOutstanding;
			stagedItemCount := self.myBulkRelease.getTotalStaged(tiSet, firstStagingLC);
			fullText := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_ID) &amp; " ["
			&amp; stagedItemCount.String &amp; "/" &amp; outStandingItemCount.String &amp; " " &amp; app.getErrorString(YAM_Msg_Items) &amp; "]";
		endif;
		
		tiSet.clear();//09 Nov 2015	NDL	Par 37152
		foreach reserveDetail in self.myBulkRelease.allReserveDetails do
			resDetString := reserveDetail.getStwHandHeldDetails(stwComplete);
			if resDetString &lt;&gt; null then
				delim := "-";
				if stwComplete then
					delim := "*";
				endif;
				if self.myBulkRelease.isPackingType and reserveDetail.isPackingParent then	//01 Feb 2016	NDL	Par 37448
					fullText := fullText &amp; CrLf &amp; delim &amp; "[" &amp; app.getErrorString(Parent) &amp; "] " &amp; resDetString;
				else
					fullText := fullText &amp; CrLf &amp; delim &amp; " " &amp; resDetString;
				endif;
			endif;
			//09 Nov 2015	NDL	Par 37152
			if reserveDetail.isFullyStaged then
				create allStagedLCs transient;	//05 May 2017	NDL	TFS 4016
				reserveDetail.getTotalStaged( null, stagingLC, allStagedLCs );
			//	if stagingLC &lt;&gt; null then
			//		fullText := fullText &amp; CrLf &amp; "   " &amp; stagingLC.getFullId;
			//	endif;
				//05 May 2017	NDL	TFS 4016 - Now want to show all staged areas, not just the first one.
				if not allStagedLCs.isEmpty then
					fullText := fullText &amp; CrLf &amp; "   " &amp; allStagedLCs.getFullId(", ");
				endif;
				delete allStagedLCs;
				
				continue;
			endif;  
			tiSet.clear();	//01 Feb 2016	NDL	Par 37448
			self.getSelectableCargoReleaseSTW( tiSet, self.myBulkRelease, reserveDetail, firstStagingLC );
			locSumm := self.getLocationSummary( tiSet );
			if locSumm &lt;&gt; null then
				fullText := fullText &amp; CrLf &amp; "   " &amp; locSumm;
			endif;
			
		endforeach;
		
		//08 Dec 2015	NDL	Par 37288
		tiSet.clear();	//17 Dec 2015	NDL	Par 37288
		if self.myBulkRelease.isPackingType then
			foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
				resDetString := reserveDetail.getStwHandHeldDetails( stwComplete );
				delim := "-";
				if stwComplete then
					delim := "*";
				endif;
				if resDetString &lt;&gt; null then
					fullText := fullText &amp; CrLf &amp; delim &amp; "[" &amp; app.getErrorString(Child) &amp; "] " &amp; resDetString;
				endif;
				if reserveDetail.isFullyStaged then
					reserveDetail.getTotalStaged( null, stagingLC, null );
					if stagingLC &lt;&gt; null then
						fullText := fullText &amp; CrLf &amp; "   " &amp; stagingLC.getFullId;
					endif;
					continue;
				endif;
				tiSet.clear();	//01 Feb 2016	NDL	Par 37448
				self.getSelectableCargoReleaseSTW( tiSet, self.myBulkRelease, reserveDetail, firstStagingLC );
				locSumm := self.getLocationSummary( tiSet );
				if locSumm &lt;&gt; null then
					fullText := fullText &amp; CrLf &amp; "   " &amp; locSumm;
				endif;
				
			endforeach;
		endif;
		
		if firstStagingLC &lt;&gt; null then
			//09 Nov 2015	NDL	Par 37152
			index := self.cmbTargetArea.findObject(firstStagingLC);
			if index &gt; 0 then
				self.cmbTargetArea.listIndex := index;
			endif;
		endif; 
		
	endif;
	
	//05 Apr 2017	NDL	TFS 3478
	self.tblRequestDesc.rows := 0;
	self.tblRequestDesc.selectMode := Table.SelectMode_None;
	if fullText &lt;&gt; null then
		create array transient;
		fullText.getTokensForDelimiterHuge( CrLf, array );
		if not array.isEmpty then
			baseBackColor := self.tblRequestDesc.backColor;
			backColor := baseBackColor;
			foreach str in array do
				if str.trimBlanks = null then
					continue;
				endif;
				if str.length &gt; 1 and str[1:1] = '*' then
					backColor := LightGray;
					str := "-" &amp; str[2:end];
				elseif str.length &gt; 1 and str[1:1] = '-' then
					backColor := baseBackColor;
				else
					// leave it as what it was last time
				endif;
				index := self.tblRequestDesc.addItem(str);
				self.tblRequestDesc.accessRow(index).backColor := backColor;
			endforeach;
		endif;
	endif;

epilog

	delete tiSet;
	delete array;
	delete allStagedLCs;

end;</source>
        <Parameter name="_returning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="09e12289-a77b-4d03-8761-f5f10adc361f">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();

	self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
	self.myMobileGenericAgent.setMyMachine( self.myMachine );
	self.myMobileGenericAgent.setMyYardLocation( self.cmbTargetArea.listObject.CM_LocationsController );
	self.myMobileGenericAgent.setChecksState( REAL_MODE );
	
	self.gotoForm( MOB_HHStagingCargoSTW, false );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="32316ce4-fe45-4df6-b3fe-64e759547912">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

	user : CM_User;

begin

	if self.myMobileGenericAgent.myMachine = null then
		if self.myMachine &lt;&gt; null and self.myMachine.loggedOn then
			user := app.getMyUser;
			if user &lt;&gt; null and self.myMachine.user = user then
				// set it so it will log-off when it is cleared. (Post previous crash etc.)
				self.myMobileGenericAgent.setMyMachine(self.myMachine);
			endif;
		endif;
	endif;
	
	self.myMobileGenericAgent.clearAll();
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateMachine" id="3fb03038-ebd4-4256-9886-a0e9c71075c6">
        <updating/>
        <source>populateMachine( _machine : CM_Machine ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2016	cnwndl1	Initial creation	TFS 1667

*/

vars

	term : CM_Terminal;
	iter : Iterator;
	machine : CM_Machine;
	type : Integer;
	newIndex : Integer;
	index : Integer;
	user : CM_User;
	myLoggedOnMachine : CM_Machine;
	machineDisplay : String;

begin

	self.cmbMachine.clear();
	self.myMachine := null;
	user := app.getMyUser;

	term := self.myMobileDataAgent.myTerminal; 
	iter := term.machines.createIterator;

	while iter.next( machine ) do
	
		if machine.hasRadioTelemetry then  //we don't want these showing
			continue;
		endif;
	
		if machine.isNotAvailableForEntry then
			continue;
		endif;
	
		type := machine.machineType;
	
		if type = MACHINETYPE_PORTAINER_CRANE
		or type = MACHINETYPE_IMV
		or type = MACHINETYPE_TRUCK_TRACTOR
		then
			continue;
		endif;
		
		machineDisplay := machine.id;
		if machine.loggedOn then
			if machine.user &lt;&gt; null then
				if machine.user.code.trimBlanks &lt;&gt; null then
					machineDisplay := machineDisplay &amp; " (" &amp; machine.user.code.trimBlanks &amp; ")";
				elseif  machine.user.userName.trimBlanks &lt;&gt; null then
					machineDisplay := machineDisplay &amp; " (" &amp; machine.user.userName.trimBlanks &amp; ")";
				endif;
			endif;
		endif;
	
		newIndex := self.cmbMachine.addItem( machineDisplay );
		self.cmbMachine.itemObject[newIndex] := machine;
		
		if machine.loggedOn then
			if machine.user &lt;&gt; user then
				self.cmbMachine.itemEnabled[newIndex] := false;
			elseif myLoggedOnMachine = null then
				//We are still logged onto this one.
				myLoggedOnMachine := machine;
			endif;
		endif;
		
	endwhile;
	
	
	if self.cmbMachine.listCount &lt; 1 then
		self.cmbMachine.addItemAt( 'No Available Machines', 1 );
	else
		self.cmbMachine.addItemAt( '&lt;Select Machine&gt;', 1 );
		self.cmbMachine.listIndex := 1;
	endif;
	
	if _machine &lt;&gt; null then
		index := self.cmbMachine.findObject(_machine);
		if index &gt; 0 then
			self.cmbMachine.listIndex := index;
			self.myMachine := _machine;
		endif;
	endif;
	
	//Perhaps the app crashed / lost contact and we are still logged on
	//nothing else deliberately chosen so default to this one.
	if myLoggedOnMachine &lt;&gt; null and self.myMachine = null then
		index := self.cmbMachine.findObject(myLoggedOnMachine);
		if index &gt; 0 then
			self.cmbMachine.listIndex := index;
			self.myMachine := myLoggedOnMachine;
		endif;
	endif;
	
epilog

	delete iter;

end; </source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="populateTargetArea" id="61bf2692-bc18-43d8-b2c0-b32fed3e9dfc">
        <source>populateTargetArea( _lc : CM_LocationsController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	ta : CM_TerminalArea;
	firstTa : CM_TerminalArea;
	iter : Iterator;
	newIndex : Integer;
	index : Integer;
	lc : CM_LocationsController;

begin

	self.cmbTargetArea.clear();
	
	term := self.myMobileDataAgent.myTerminal; 
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	
	if firstTa &lt;&gt; null then
		iter := term.allTerminalAreasByTypeId.createIterator;
		iter.startAtObject( firstTa );
		while iter.next( ta ) do
			if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
				break;
			endif;
			lc := null;
			if ta.isKindOf( CM_InterchangeArea ) then
				lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089
			elseif ta.isKindOf( CM_BlockStack ) then
				lc := ta.CM_BlockStack.myLocationsController;
			endif;
			if lc = null then
				continue;
			endif;
			newIndex := self.cmbTargetArea.addItem( ta.id );
			self.cmbTargetArea.itemObject[newIndex] := lc;
		endwhile;
		
		if self.cmbTargetArea.listCount &lt; 1 then
			self.cmbTargetArea.addItemAt( 'No Target Areas', 1 );
		elseif self.cmbTargetArea.listCount = 1 then
			self.cmbTargetArea.listIndex := 1;
		else
			self.cmbTargetArea.addItemAt( '&lt;Select Target Area&gt;', 1 );
			self.cmbTargetArea.listIndex := 1;
		endif;
		
		if _lc &lt;&gt; null then
			index := self.cmbTargetArea.findObject(_lc);
			if index &gt; 0 then
				self.cmbTargetArea.listIndex := index;
			endif;
		endif;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setBtnsState" id="b0f4cf69-d8fb-4b72-9a30-756832c4c7f4">
        <updating/>
        <source>setBtnsState() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

begin

	self.cmbTargetArea.enabled := ( self.cmbTargetArea.listCount &gt; 1 );
	if not self.cmbTargetArea.enabled and self.cmbTargetArea.listCount &gt; 0 then
		self.cmbTargetArea.listIndex := 1;
	endif;
	
	self.myMachine := self.cmbMachine.listObject.CM_Machine;

//	self.btnOne.enabled := ( self.cmbTargetArea.listObject &lt;&gt; null and self.myBulkRelease &lt;&gt; null );
//	self.btnOne.enabled := (  self.myBulkRelease &lt;&gt; null );	//15 Mar 2016	NDL	TFS 1484
	self.btnOne.enabled := (  self.myBulkRelease &lt;&gt; null and self.myMachine &lt;&gt; null );//05 Apr 2016	NDL	TFS 1667


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="edb5325b-34fb-4d3a-b8e1-43a5521ef301">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars


begin

	self.doResizeControls(true);
	
	//reset if returning from somewhere else...
	self.populateTargetArea( self.myMobileGenericAgent.myYardLocation );
	self.populateMachine( self.myMobileGenericAgent.myMachine );	//05 Apr 2016	NDL
	self.myMobileGenericAgent.setMyYardLocation( null );
	if self.myMobileGenericAgent.myBulkRelease &lt;&gt; null then
		self.txtRequestId.text := self.myMobileGenericAgent.myBulkRelease.code;
		self.myBulkRelease := self.myMobileGenericAgent.myBulkRelease;	//08 Dec 2015	NDL	Par 37288
		self.myMobileGenericAgent.setMyBulkRelease( null );
	endif;
	
	self.myMobileGenericAgent.setStringField1( null );
	
	self.myMobileGenericAgent.setChecksState( 0 );
	
	self.findRequest( true );
	
	self.setBtnsState();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8a35449c-4f61-4adc-b08f-49b3bfad3a26">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Back), null, null, null );

	self.setupControls();
	
	self.txtRequestDesc.visible := false;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="abce063a-a908-479f-bbc1-449bf697aeab">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 April 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021218, locale);
	lblRequestId.translateCaption(Xlat_0021219, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtRequestId_gotFocus" id="1782895c-efd4-44a0-bc96-4940a3a5ce55">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRequestId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

begin

	if txtRequestId.text = lblRequestId.caption.toUpper then
		//txtTruck.text := null;
		txtRequestId.selStart := 0;
		txtRequestId.selLength := lblRequestId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtRequestId_lostFocus" id="524629fe-01f6-42c3-9710-b7bb034d07cd">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRequestId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

begin

	if txtRequestId.text.trimBlanks = null then
		txtRequestId.text := lblRequestId.caption.toUpper;
	endif;
	
	txtRequestId.selStart := 0;
	txtRequestId.selLength := 0;
	
	if self.myBulkRelease = null or self.myBulkRelease.code &lt;&gt; txtRequestId.text then
		self.findRequest( false );
	endif;
	
	self.setBtnsState();

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
