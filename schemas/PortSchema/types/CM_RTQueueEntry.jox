    <JadeMethod name="getNextEntryFirstDirectorTask" id="3bc090a3-c010-43d3-b718-2906fc979770">
        <source>getNextEntryFirstDirectorTask() : CM_RTQueueTask;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2011	cnwrd1	Initial creation
//cnwrd1 par 26797 21.1.2011
*/



vars
	nextEntry		: CM_RTQueueEntry;
	nextTask 		: CM_RTQueueTask;
	invalidProcess	: Boolean;
	
begin

	on Exception do app.handleDeletedObject(exception, nextEntry, invalidProcess); // PAR 

	nextEntry := self.getNextRelatedEntry(); //epr 17/2/15 par 35702 CCMS 2457
	
	if nextEntry = null then
		return null;
	endif;
	
	foreach nextTask in nextEntry.allTasks do
		if nextTask.taskType = TASK_DIRECTOR then
			break;
		endif;
	endforeach;
	
	return nextTask;
	

epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
