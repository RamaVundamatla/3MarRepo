    <JadeMethod name="getQuerySet" id="36d53fc4-7100-4d0f-b619-ed1a04f48562">
        <source>getQuerySet( _dtoQuerySet : DTO_QuerySetForRT input );
// -------------------------------------------
// Created	21 April 2008 by cnwvu1
// -------------------------------------------

vars
	querySet	: CM_SelectorQueryAccess;
	terminal	: CM_Terminal;
	
begin

	terminal	:= app.getMyTerminalDO_NOT_USE();
	querySet	:= terminal.myRTVehicleConfig.myQueriesForDrivers; // epr ccms 1099 25.5.10 getConfig(SelectorQueriesForRT).CM_SelectorQueryAccess;
	if querySet = null then
		return;
	endif;
	
	_dtoQuerySet.setFromPersistent( querySet );
	
end;
</source>
        <Parameter name="_dtoQuerySet" type="DTO_QuerySetForRT" usage="input"/>
