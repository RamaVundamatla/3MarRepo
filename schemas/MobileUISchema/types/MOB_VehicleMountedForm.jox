    <JadeMethod name="sortTableInRTQueueOrder" id="9935425f-92ee-4f3d-b0f6-5c589a46134f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::sortTableInRTQueueOrder"/>
        </interfaceImplements>
        <source>sortTableInRTQueueOrder(_table : Table) : Boolean;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars

begin

	if _table = self.tblTasks then
		if self.isEnquiryMode then
			return false;
		elseif self.isInDischargeMode then //epr par 33552
			return false;
		else
			return true;
		endif;
	else
		return false;
	endif;

epilog

end;</source>
