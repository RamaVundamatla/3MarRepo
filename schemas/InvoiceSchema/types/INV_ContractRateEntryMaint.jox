    <JadeMethod name="setupForm" id="5efa41a7-4384-4374-9e18-b0a5c0896282">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646 Task 55668: UI - Contracts Rate Entries
12 Apr 2023 navmk20		Bug 57311: MTN - Contract Screens Not Saving Columns

*/

vars
	entry : CM_InvoiceContractRateEntry;
begin
	self.setFromToLabels(); // ### TFS BUG 57505 14APR2023 NAVAB1
	
	inheritMethod();						// 12/4/2023 navmk20 TFS 57311
	//self.handleMenusForModalDisplay();	// 12/4/2023 navmk20 TFS 57311
	if self.updateMode then
		self.populateRateEntry();
		self.mskContractFromEnd.enabled := false;	//23-03-2023 navtnr20 57226
		self.mskContractFromEndTime.enabled := false;//23-03-2023 navtnr20 57226
		self.mskContractFromStart.enabled := false;//23-03-2023 navtnr20 57226
		self.mskContractFromStartTime.enabled := false;//23-03-2023 navtnr20 57226
	else
		// ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
		if self.myInvContractRate &lt;&gt; null then
			entry := self.myInvContractRate.allInvoiceContractRateEntries.last;
			if entry &lt;&gt; null 
			and entry.toAmount &lt; 99999999999.9900 then // ### TFS BUG 60193 31AUG2023 NAVAB1
				self.txtFrom.text := (entry.toAmount + 1).String;
			else
				self.txtFrom.text := "1"; // ### TFS BUG 59918 20SEP2023 NAVAB1
			endif;
		else
			self.txtFrom.text := "1"; // ### TFS BUG 59918 20SEP2023 NAVAB1
		endif;
		self.txtTo.setFocus(); // ### TFS BUG 59918 20SEP2023 NAVAB1
	endif;
	self.getXMLSettingsForSetup(); // ### TFS BUG 59918 20SEP2023 NAVAB1
epilog

end;</source>
    </JadeMethod>
