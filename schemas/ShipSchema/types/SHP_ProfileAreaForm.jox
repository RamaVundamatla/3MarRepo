    <JadeMethod name="doZoomWebPic" id="864379c1-6b9a-4bb5-b563-1ab8b0f269e9">
        <updating/>
        <source>doZoomWebPic(button : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		07 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.webPicLeftButton := (button = Window.MouseButton_Left);
	if self.webPicLeftButton then
		self.webPicScaleFactor := self.webPicScaleFactor + 0.25;
	else
		self.webPicScaleFactor := self.webPicScaleFactor - 0.25;
	endif;
	if self.webPicScaleFactor &gt; 2 then
		self.webPicScaleFactor := 0.5;
	elseif self.webPicScaleFactor &lt; 0.5 then
		self.webPicScaleFactor := 2;
	endif; 
	self.showWebCamPicture();

end;</source>
        <Parameter name="button" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="20e12f6c-2ab9-40ef-acb4-894969b8b2f1">
        <source>fileExceptionHandler(_ex : Exception; _label : String) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2008	cnwrd1	Initial creation

*/

vars
	errorText: String;
begin
	errorText := "Opening file: '" &amp; _ex.FileException.file.fileName &amp; "' caused an error";
	errorText := errorText &amp; Lf &amp; _ex.text &amp; Lf &amp; Lf &amp; "Aborting " &amp; _label &amp; " Operation!";
	app.msgBox(errorText, "File Open Error",
		MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fldMain_click" id="79488e67-f57a-4fc4-b9ef-e4240a14208d">
        <controlMethod name="Folder::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_click(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:		04 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 09/08/2011	cnwcs5	CCMS MES 1033 - RORO KPI
vars
	sheet	:Sheet;
	table	:Table;
begin
	sheet := folder.topSheet;
	
	if sheet = self.shtDelays then
		self.showDelaysStats();
		
	elseif sheet = self.shtMoves then
		table := self.tblStats;
		
		if table.rows = table.fixedRows then
			self.showMoveStatsByJS();
		endif;
		
	elseif sheet = self.shtBays then
		table := self.tblBays;
		
		if table.rows = table.fixedRows then
			self.showBayStats();
		endif;
		
	elseif sheet = self.shtRORODecks then
		self.showRORODecksStats;
		
	elseif sheet = self.shtROROMoves then
		self.showROROMovesStats;
	endif;

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="frmGridArea_contextMenu" id="145afc04-cd8e-4d43-9dc0-0b17d7af0bcd">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	gridPoint	: CMUI_GridPoint;
	lTI : CM_TrackedItem;
//	theLogController : CM_LogController;
//	aSub : CM_BlockStack;
//	aRestriction : CM_Restriction;
	
begin
	gridPoint := cntrl.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y); //self.frmGridArea
	
	self.doTurnOffContextMenus();
	
	// cnwrl1 13/03/2009 - PAR 18245 - start of coding
	// make sure the hide/show part of the context menu is available if on Side Profile sheet.
	self.mnuGridHideLegend.visible	:= true;
	self.mnuGridHideMacro.visible	:= true;

	
	if gridPoint &lt;&gt; null then
		if gridPoint.myLocationsController &lt;&gt; null then
			lTI := gridPoint.SHP_BayPoint.getTI(x, y);
			if lTI &lt;&gt; null then
				self.mnuCargo.visible := true;
				self.doBuildMnuContainer(lTI);
			endif;
		endif;
	endif;
	self.mnuZoomSub.visible := false;
	self.mnuGridAreaContext.visible := false;
	self.mnuGridAreaContext.enabled := false;
	
	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, x, y);
	
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
