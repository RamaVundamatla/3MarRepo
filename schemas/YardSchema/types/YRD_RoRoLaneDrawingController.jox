    <JadeMethod name="refreshYardAllocationLines" id="ec3f408c-3745-4899-b0c0-1a475f3551fc">
        <updating/>
        <source>refreshYardAllocationLines() updating;

/*

Purpose:			Re-draw Yard Allocation lines

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	SWF1030 - Initial creation

*/

vars
	obj 		: Object;
	iter 		: Iterator;
	newHeight	: Integer;
	oldHeight	: Integer;
	x1, x2		: Integer;
	y1, y2 		: Integer;
	
begin

	if self.drawFromNote then
		self.drawSelf(true);
	endif;

	//  Remove old Yard Allocation lines

	iter := self.allYAObjects.createIterator();

	while iter.next(obj) do
		self.allYAObjects.getIteratorKeys(x1, y1, x2, y2, iter);
		if obj.isKindOf(CM_YardAllocation) then
			self.myDrawingFrame.drawWidth := y2 - y1;
			self.myDrawingFrame.drawLine( x1, y1, x2, y1, self.myDrawingFrame.backColor );
			self.allYAObjects.removeKeyEntry(x1, y1, x2, y2, obj);
		endif;
	endwhile;
	
	delete iter;

	//  Draw new Yard Allocation lines
	
	iter := self.allYARows.createIterator();
	
	while iter.next(obj) do
		self.allYARows.getIteratorKeys(x1, y1, x2, y2, iter);
		self.allYARows.removeKeyEntry(x1, y1, x2, y2, obj);
		oldHeight := y2 - y1;
		self.drawYardAllocationLinesForRow(obj.CM_RoRoController, x1, y1, x2, y2);
	endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFontDefaults" id="2b13719a-62c9-4ebd-ad62-01bc363ba675">
        <updating/>
        <source>setFontDefaults() updating;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFontName	: String;
	theFontSize	: Real;
	lFactor     : Real;
begin

	theFontSize := (self.FontSize * self.scaleFactor.Integer);
	if lFactor = 1 then
		theFontSize := 8;
	elseif lFactor = 1.5 then
		theFontSize := 10;
	endif;	
	self.defaultFontSizeForAttributes	:= theFontSize * 2;
end;</source>
    </JadeMethod>
