    <JadeMethod name="addToolbarControls" id="16369e42-b632-439c-8a73-7197adaeb9bc">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			Adds toolbar controls to the forms toolbar

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
