    <JadeMethod name="setForCreate" id="7bb582f2-81a3-4543-9f77-21381e4c037a">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_Receival; _realVVR: CM_VehicleVisitRecord input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2010	cnwdap1	Initial creation PAR #23442
*/
vars

