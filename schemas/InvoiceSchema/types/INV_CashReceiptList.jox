/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if validateClose() then

		self.unloadForm();
	
	endif;

epilog

end;</source>
