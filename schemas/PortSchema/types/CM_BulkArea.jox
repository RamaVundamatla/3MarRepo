    <JadeMethod name="setProxy" id="31a07b38-eb92-4025-ac4b-b5a92031741a">
        <updating/>
        <source>setProxy(pID, pComment : String;  pType : Integer; pTerm : CM_Terminal;
		 pMaxVolume, pMinVolume	: Decimal; pMaxWeight, pMinWeight	: Integer;
		 _autoRestrictionEnabled, _hideFromOverView : Boolean; restrictionProxy : CM_LocationRestrictBulk input; 
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
					_defaultInterchangeArea: CM_InterchangeArea) updating;

// Created:		R Barr 3/11/2006 Comalco
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
vars

begin
	setProxyTerminalArea(pID, pComment, pType, false, pTerm, _autoRestrictionEnabled, true,_hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	maxVolume := pMaxVolume;
	minVolume := pMinVolume;
	maxWeight := pMaxWeight;
	minWeight := pMinWeight;

end;











</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="pMaxVolume" type="Decimal"/>
        <Parameter name="pMinVolume" type="Decimal"/>
        <Parameter name="pMaxWeight" type="Integer"/>
        <Parameter name="pMinWeight" type="Integer"/>
        <Parameter name="_autoRestrictionEnabled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="restrictionProxy" type="CM_LocationRestrictBulk" usage="input"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="setRestrictionFromProxy" id="3d9e0f59-9477-41a5-9846-8c175c30e3b3">
        <source>setRestrictionFromProxy(proxy : CM_BulkArea):CM_LocationRestrictBulk;

// create, upate or delete restriction from proxy

vars
	restriction			: CM_LocationRestrictBulk;
	proxyRestriction	: CM_LocationRestrictBulk;

begin
	// create, upate or delete restriction
	proxyRestriction := proxy.getRestriction;
	restriction := self.getRestriction();

	if proxyRestriction &lt;&gt; null then
		if restriction = null then
			create restriction persistent;
		endif;
		restriction.setForUpdate(proxyRestriction);
	elseif restriction &lt;&gt; null then
		delete restriction;
		restriction := null;
		return null;
	endif;

	// set references
	if restriction &lt;&gt; null then
		restriction.setReferences(self);
	endif;


	return restriction;
end;
</source>
        <Parameter name="proxy" type="CM_BulkArea"/>
        <ReturnType type="CM_LocationRestrictBulk"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9ad610d1-5865-49f5-86ca-2d6518ba0dde">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	:	CM_LocationsController;

begin

	foreach lc in self.allLocationsControllers do
		if lc.hasTIs then
			app.raiseCMException2(ERR_LC_HAS_TIS,lc.getFullId,null, null, null); // PAR 20584 AKB2009SEP
			break;
		endif;
	endforeach;

	self.checkRTQueueTaskUsage();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2ba92831-bc30-41c1-893c-2c940167ed0b">
        <source>validateForUpdate(pRealTerminalArea: CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		10 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	res : CM_LocationRestriction;
	prodMinMax : CM_TerminalAreaProductMinMax;
	prod : CM_Product;
	found : Boolean;
begin
	inheritMethod(pRealTerminalArea);
	
	res := self.allRestrictionsLocation.first.CM_LocationRestriction;
	
	if res = null then
		return;
	endif;
	
	foreach prodMinMax in self.allProductMinMax discreteLock do
		found := false;
		foreach prod in res.allProducts discreteLock do : innerLoop
			if prodMinMax.myProduct = prod then
				found := true;
				break innerLoop;
			endif;
		endforeach;
		if not found then
			prod := prodMinMax.myProduct;
			app.raiseCMException3(TERMAREA_PRODUCTMINMAX_ERROR,self.id, "'" &amp; prod.description &amp; "'", "'" &amp; prod.description &amp; "'", null, self);
		 
		endif;
	endforeach;


	
//	

end;
</source>
        <Parameter name="pRealTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
