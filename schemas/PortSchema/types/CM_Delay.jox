    <JadeMethod name="setForCreate" id="0b8b04ba-721f-4edf-aa3d-04233b419290">
        <updating/>
        <source>setForCreate(_delay : CM_Delay) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
31/03/2011	cnwcs5		CCMS SFW 1132 - add delays to machine history.
									  - use local variable for events &amp; passport
									  - refactor setForCreate/setForUpdate so start event is always created b4 end event
*/
vars
	passport	:CM_Passport;
	eventStart	:CMEVT_DelayStart;
	eventEnd	:CMEVT_DelayEnd;
	
	cmifEventCtrl : CMIF_DelayEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
	
begin
	_delay.raiseExceptionIfNotTransient(method);	
	
	self.setForUpdate(_delay);
	
	self.doUpdateVoyageKPI();
	
	passport := app.myPassport;
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	// create event for delay start
	eventStart := app.createEvent(EVT_DelayStart, self.startDT, self.myTerminal, passport.userCode, false, false,0).CMEVT_DelayStart;
	
	if eventStart  &lt;&gt; null then
		self.myEventStart	:= eventStart;

		//eventStart.createCharge(passport);
		app.myPassport.addEventTransactionForDeferUpd(eventStart,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
		if self.myMachine &lt;&gt; null then
			self.createMachineHistory (eventStart);
		endif;
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_DelayStart;
	cmifEventCtrl.dateTime := self.startDT;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := passport.userCode;
	cmifEventCtrl.myDelay := self;
	
	eventStart := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_DelayStart;
	//17/02/2025	navkc1 JIRA Bug MTN-33582
	
	// if they have entered the delay end then create an event for the end as well
	if self.endDT.isValid then		
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		// they have set the delay end time so create event and history
		eventEnd := app.createEvent(EVT_DelayEnd, self.endDT, self.myTerminal, passport.userCode, false, false,0).CMEVT_DelayEnd;
	
		if eventEnd  &lt;&gt; null then
			self.myEventEnd := eventEnd;
			
			//eventEnd.createCharge(app.myPassport);
			app.myPassport.addEventTransactionForDeferUpd(eventEnd,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			// create machine history for the delay
			self.createMachineHistory (eventEnd);
		endif;
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
		delete cmifEventCtrl;
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_DelayEnd;
		cmifEventCtrl.dateTime := self.endDT;
		cmifEventCtrl.myTerminal := self.myTerminal;
		cmifEventCtrl.userCode := passport.userCode;
		cmifEventCtrl.myDelay := self;
		
		eventEnd := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_DelayEnd;
		//17/02/2025	navkc1 JIRA Bug MTN-33582
		
	endif;
	
	self.createAssociatedEvent();	//24 Aug 2018	NDL	TFS 40309
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="14abd78e-b950-4b09-bdcf-08bd70666ad1">
        <updating/>
        <source>setForUpdate(_proxy : CM_Delay) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
31/03/2011	cnwcs5		CCMS SFW 1132 - add delays to machine history.
05/09/2011	cnwcs5		CCMS MES 1033 - RORO kpi
*/
vars
	eventStart			:CMEVT_DelayStart;
	eventEnd			:CMEVT_DelayEnd;
	history				:CM_MachineDelayHistory;
	oldMachine, 
	newMachine			:CM_Machine;
	newStart, newEnd	:TimeStamp;
	passport			:CM_Passport;
	cmifEventCtrl		:CMIF_DelayEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	oldMachine			:= self.myMachine;
	newMachine			:= _proxy.myMachine;
	newStart			:= _proxy.startDT;
	newEnd				:= _proxy.endDT;
	passport			:= app.myPassport;
	
	self.myTerminal 	:= _proxy.myTerminal;
	self.myVoyage 		:= _proxy.myVoyage;
	self.myDelayType 	:= _proxy.myDelayType;
	self.startDT 		:= newStart;
	self.estEndDT 		:= _proxy.estEndDT;
	self.endDT 			:= newEnd;
	self.myMachine 		:= newMachine;
	self.myDriver 		:= _proxy.myDriver;
	self.myWorkPoint 	:= _proxy.myWorkPoint;
	
	self.remarks  		:= _proxy.remarks;
	
	eventStart 	:= self.myEventStart;
	
	if eventStart = null then
		// no start event - we must be being called from setForCreate
		return;
	endif;
	
	if eventStart.dateTime &lt;&gt; newStart then
		// the delay start time has changed so update the event and history as well
		eventStart.setDateTime(newStart);			
	endif;
	// this next bit keeps the history in synch with any changes to machine		
	history := eventStart.myMachineHistory;

	if history &lt;&gt; null then
		self.updateMachineHistory (eventStart);
	else
		// no history and now we need one
		if newMachine &lt;&gt; null then
			// maybe they just added machine
			self.createMachineHistory (eventStart);
		endif;
	endif;

	eventEnd := self.myEventEnd;

	if eventEnd = null then
		if newEnd.isValid then		
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			// they have set the delay end time so create event and history
			eventEnd := app.createEvent(EVT_DelayEnd, newEnd, self.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_DelayEnd;
		
			if eventEnd  &lt;&gt; null then
				self.myEventEnd := eventEnd;
				
				//eventEnd.createCharge(app.myPassport);
				app.myPassport.addEventTransactionForDeferUpd(eventEnd,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
				// create machine history for the delay
				self.createMachineHistory (eventEnd);
			endif;
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
			create cmifEventCtrl transient;
			cmifEventCtrl.type := EVT_DelayEnd;
			cmifEventCtrl.dateTime := newEnd;
			cmifEventCtrl.myTerminal := self.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myDelay := self;
			
			eventEnd := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_DelayEnd;
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
			
		endif;
	else
		if eventEnd.dateTime &lt;&gt; newEnd then
			// they have changed the delay end time
			eventEnd.setDateTime(newEnd);
		endif;
		// this next bit keeps the history in synch with any changes to machine			
		history := eventEnd.myMachineHistory;

		if history &lt;&gt; null then
			self.updateMachineHistory (eventEnd);
		else
			// no history and now we may need one
			if newMachine &lt;&gt; null then
				// maybe they just added machine or are creating
				self.createMachineHistory (eventEnd);
			endif;
		endif;

	endif;
		
	self.doUpdateVoyageKPI();
	
	self.updateAssociatedEvent();	//24 Aug 2018	NDL	TFS 40309
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_proxy" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="setMyEventEnd" id="24e551aa-013a-4684-8840-bfe54f9c3a53">
        <updating/>
        <source>setMyEventEnd(_eventEnd : CMEVT_DelayEnd) updating;
/*

Purpose:			

Parameters:			

