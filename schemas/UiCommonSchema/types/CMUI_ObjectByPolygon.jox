    <JadeMethod name="findObjectInDictFromPoint" id="7394b3cb-88e7-4bbd-86bd-2b220161df2a">
        <source>findObjectInDictFromPoint(_x1,_y1 : Integer) : Object;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	deadParrot : PointArray;
	tmpIterator	: Iterator;
	tmpObj : Object;
	x1,y1,x2,y2 : Integer;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return null;
	endif;
	
	tmpIterator.reset();
	while tmpIterator.next(tmpObj) do
		deadParrot := null;
		self.getIteratorKeys(x1,y1,x2,y2,deadParrot, tmpIterator);
		if deadParrot.isPointInPolygon(_x1,_y1, 1) then
			return tmpObj;
		endif;
	endwhile;
	return null;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictFromPointClass" id="a1f153ae-5fc4-4385-9c1b-70fc12cad517">
        <source>findObjectInDictFromPointClass(_x1,_y1 : Integer; _class : Class) : Object;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	deadParrot : PointArray;
	tmpIterator	: Iterator;
	tmpObj : Object;
	x1,y1,x2,y2 : Integer;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return null;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		if not tmpObj.isKindOf(_class) then
			continue;
		endif;
		self.getIteratorKeys(	x1,y1,x2,y2,deadParrot, tmpIterator);
		if deadParrot.isPointInPolygon(_x1,_y1, 1) then
			return tmpObj;
		endif;
	endwhile;
	return null;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXY" id="3630bbe1-cde5-4929-9213-0fa875f2a8c4">
        <source>findObjectInDictGetXY(_obj : Object; key1, key2 : Point output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	deadParrot : PointArray;
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return false;
	endif;
	
	tmpIterator.reset();
	
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, deadParrot,tmpIterator);
			key1.setX(x1);
			key1.setY(y1);
			key2.setX(x2);
			key2.setY(y2);
			return true;
	endwhile;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="key1" type="Point" usage="output"/>
        <Parameter name="key2" type="Point" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictXYClassBehave" id="be50d034-d11c-4d49-82be-a084d533a5b0">
        <source>findObjectInDictXYClassBehave(_x1,_y1 : Integer; _class : Class; _behaviour : Integer) : Object;
// ---------------------------------------------------------------------------
// Created:		6 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	deadParrot : PointArray;
	tmpIterator	: Iterator;
	tmpObj : Object;
	tiB : CM_TIBehaviourType;
	x1,y1,x2,y2 : Integer;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return null;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		if not tmpObj.isKindOf(_class) then
			continue;
		endif;
		if _class = CM_TILC then
			tiB := tmpObj.CM_TILC.myCargoType.myTIBehaviourType;
			if not tiB &lt;&gt; null then
				return null;
			endif;
			if tiB.behaviourType &lt;&gt; _behaviour then
				return null;
			endif;
		endif;
		self.getIteratorKeys(	x1,y1,x2,y2,deadParrot, tmpIterator);
		if deadParrot.isPointInPolygon(_x1,_y1, 1) then
			return tmpObj;
		endif;
	endwhile;
	return null;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_behaviour" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDict" id="57f22d46-2092-41b7-a401-6bb2d34f5c86">
        <source>findObjectsInDict( _x1, _y1,_x2,_y2 : Integer; _objs : ObjectArray input; _class : Class; _includeTouched : Boolean) ;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	deadParrot : PointArray;
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	if _objs = null then
		return;
	endif;
	
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2, deadParrot,tmpIterator);
		
		
		/// ### THIS will need to be changed if we start rotating the rectangles to do herring bone
		///			this is assuming that the recangles are not rotated.
		if _includeTouched then
			if ((x1 &lt;= _x1 and x2 &gt;= _x1) or (x1 &gt;= _x1 and x2 &lt;= _x2) or (x1 &lt;= _x2 and x2 &gt;= _x2))
			and ((y1 &lt;= _y1 and y2 &gt;= _y1) or (y1 &gt;= _y1 and y2 &lt;= _y2) or (y1 &lt;= _y2 and y2 &gt;= _y2)) then
			
				if tmpObj.isKindOf(_class) then
					if not _objs.includes(tmpObj) then
					   _objs.add(tmpObj);
					  endif;
				endif;
			endif;
		else
			if x1 &gt;= _x1 and
			   x2 &lt;= _x2 and
			   y1 &gt;= _y1 and
			   y2 &lt;= _y2 then
	
				if tmpObj.isKindOf(_class) then
					if not _objs.includes(tmpObj) then
					   _objs.add(tmpObj);
					  endif;
				endif;
			endif;
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_includeTouched" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIterator" id="a6dc21aa-1ea2-42e6-abc2-7adba6a8acc8">
        <source>getIterator() : Iterator;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myIterator;
end;</source>
        <ReturnType type="Iterator"/>
    </JadeMethod>
    <JadeMethod name="getPointsForObject" id="a7636318-3c27-4e94-8ae2-55e7aec40afd">
        <lockReceiver/>
        <updating/>
        <source>getPointsForObject(_obj : Object; _x1, _y1, _x2,_y2 : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	x1, y1, x2, y2 : Integer;
//	xx1, yy1, xx2, yy2 : Integer;
	tmpObj		: Object;
	tmpIterator	: Iterator;
	tmpPoly : PointArray;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
	endif;

//	self.startKeyGeq(_x1, 0, 0, 0, tmpIterator);
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
	

		self.getIteratorKeys(x1, y1, x2, y2,tmpPoly, tmpIterator);

		self.getXYsFromRectanglePolygon(tmpPoly,_x1, _y1, _x2, _y2 );
		if tmpObj = _obj then
			return;
		endif;

	endwhile;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPolygonForObject" id="85c78c82-f08f-419a-8e89-15c972e07412">
        <source>getPolygonForObject(_obj : Object) : PointArray;
// ---------------------------------------------------------------------------
// Created:		6 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	deadParrot : PointArray;
	tmpIterator	: Iterator;
	tmpObj : Object;
	x1,y1,x2,y2 : Integer;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return null;
	endif;
	
	tmpIterator.reset();
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(	x1,y1,x2,y2,deadParrot, tmpIterator);
		if tmpObj = _obj then
			return deadParrot;
		endif;
		return null;		
	endwhile;
	return null;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="getXYsFromRectanglePolygon" id="bc284676-9a9b-4483-99e5-5418d26d16d9">
        <source>getXYsFromRectanglePolygon(_poly : PointArray; _x1,_y1,_x2,_y2 : Integer io);
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY : Integer;
	aPoint : Point;
	
begin
	_x1 := 99999999;
	_y1 := 99999999;
	_x2 := 0;
	_y2 := 0;
	
	foreach aPoint in _poly do
		tmpX := aPoint.x;
		tmpY := aPoint.y;
		
		_x1 := _x1.min(tmpX);
		_y1 := _y1.min(tmpY);
		_x2 := _x2.max(tmpX);
		_y2 := _y2.max(tmpY);
		
		
	endforeach;
end;</source>
        <Parameter name="_poly" type="PointArray"/>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeObjectFromDict" id="a1cd6bb3-cb0c-4e05-9ef9-dcff6adce204">
        <lockReceiver/>
        <updating/>
        <source>removeObjectFromDict(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	x1, y1, x2, y2 : Integer;
	tmpObj		: Object;
	tmpIterator	: Iterator;
	tmpPoly : PointArray;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
	endif;

	tmpIterator.reset();
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
	
		self.getIteratorKeys(x1, y1, x2, y2,tmpPoly, tmpIterator);

		self.removeKeyEntry(x1, y1, x2, y2,tmpPoly, tmpObj);
		delete tmpPoly;
		break;
	endwhile;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="removeObjectsInDict" id="34f52a4c-e8c2-44c1-9a74-916c3a9af489">
        <lockReceiver/>
        <updating/>
        <source>removeObjectsInDict(_x1, _y1, _x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	x1, y1, x2, y2 : Integer;
//	xx1, yy1, xx2, yy2 : Integer;
	tmpObj		: Object;
	tmpIterator	: Iterator;
	tmpPoly : PointArray;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
	endif;
//	app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " _x1: " &amp; _x1.String
//						 &amp; " _y1: " &amp; _y1.String &amp; " _x2: " &amp; _x2.String &amp; " _y2: " &amp; _y2.String);

//	self.startKeyGeq(_x1, 0, 0, 0, tmpIterator);
	tmpIterator.reset();
	while tmpIterator.next(tmpObj) do
	

		self.getIteratorKeys(	x1,y1,x2,y2,tmpPoly, tmpIterator);

	//	self.getXYsFromRectanglePolygon(tmpPoly,x1, y1, x2, y2 );


//if tmpObj = "2455.42".asOid then
//	app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1.tmpObj " &amp; tmpObj.String &amp; " x1: " &amp; x1.String
//						 &amp; " y1: " &amp; y1.String &amp; " x2: " &amp; x2.String &amp; " y2: " &amp; y2.String);
//endif;

		if x1 &gt; _x2 then
//			break;
		endif;
		if _x1 &lt;= x1 and
		   _x2 &gt;= x2 and
		   _y1 &lt;= y1 and
		   _y2 &gt;= y2 then
/*if tmpObj.isKindOf(CM_LocationsController) then
app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. tmpObj " &amp; tmpObj.String &amp; tmpObj.CM_LocationsController.getFullId() &amp; " removed");
else
app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. tmpObj " &amp; tmpObj.String  &amp; " removed");
endif;*/
			self.removeKeyEntry(x1,y1,x2,y2,tmpPoly, tmpObj);
			delete tmpPoly;
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
</CollClass>
