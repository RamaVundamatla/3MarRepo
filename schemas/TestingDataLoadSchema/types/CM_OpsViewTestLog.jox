        <source>setForCreate(data : CM_OpsViewTestLog) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2022	navsp1	Initial creation

*/

vars
		timestamp : TimeStamp;
	time : Time;
	
begin
	
	self.name := data.name;
	self.description := data.description;
	self.updatedOn := app.actualTimeServer();
	self.voyage		:= data.voyage;
	self.param1 := data.param1;
	self.param2 := data.param2;
	self.param3 := data.param3;
	self.param4 := data.param4;

epilog

end;</source>
