    <JadeMethod name="getHandlingType" id="3fb33697-1fef-43c9-945b-b280a999ca02">
        <source>getHandlingType(): CM_HandlingType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	YFS 3424

*/

vars
	
	palletType : CM_PalletType;
	retValue : CM_HandlingType;

begin

	if self.myPalletDetailsTI &lt;&gt; null then
		palletType := self.myPalletDetailsTI.getPalletTypeObj;
	endif;

	if palletType &lt;&gt; null  then
		retValue := palletType.getMyHandlingType;
	
	else
		//get the default ones...
		retValue := inheritMethod();
		
	endif;
	
	return retValue;

epilog

end;</source>
        <ReturnType type="CM_HandlingType"/>
    </JadeMethod>
