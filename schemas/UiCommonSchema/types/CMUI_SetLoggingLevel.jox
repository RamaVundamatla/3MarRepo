    <JadeMethod name="addLogLevelsToCmb" id="726bdd7a-503e-4c08-903a-e2a058bb7289">
        <options>4</options>
        <source>addLogLevelsToCmb(_cmb : ComboBox input; _allowBlank : Boolean) typeMethod;
/*

Purpose:			Populates the combo box with a known list of log levels in a sensible order

Parameters:			

Return Value:		

Date				Who		Reason
01 April 2021		navmd1	Initial creation TFS 51054

*/

vars

begin

	_cmb.clear();
	_cmb.sorted := false;
	
	if _allowBlank then
		_cmb.itemData[ _cmb.addItem( "" ) ]	:= 999;
	endif;
	
	_cmb.itemData[ _cmb.addItem( "INFO (0)"  ) ]	:= 0;
	_cmb.itemData[ _cmb.addItem( "FATAL (1)" ) ]	:= 1;
	_cmb.itemData[ _cmb.addItem( "ERROR (2)" ) ]	:= 2;
	_cmb.itemData[ _cmb.addItem( "WARN (3)"  ) ]	:= 3;
	_cmb.itemData[ _cmb.addItem( "DEBUG (4)" ) ]	:= 4;
	_cmb.itemData[ _cmb.addItem( "TRACE (5)" ) ]	:= 5;

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_allowBlank" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="ee31b181-883f-4b5c-a4ef-5d11b950377d">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

begin

	self.permissionView  := PmUsersSignedOnView;
	self.permissionMaint := PmUsersSignedOnView;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="e91ac99d-8700-43ec-8aca-0d7ba245cbfc">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

begin
	if self.cmbLogLevel.listIndex &gt; -1 then
		self.modalResult := self.cmbLogLevel.itemData[ self.cmbLogLevel.listIndex ];
	else
		self.modalResult := IDCANCEL;
	endif;
	self.unloadForm;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getUserFromMachine" id="844ade38-5c90-491f-ada2-493506fbb28f">
        <source>getUserFromMachine(_str : String):CM_User protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	iter : Iterator;
	term : CM_Terminal;
	machine : CM_Machine;

begin

	iter := app.myRoot.allTerminals.createIterator;
	while iter.next( term ) do
		machine := term.machines.getAtKey(_str);
		if machine &lt;&gt; null then
			if machine.loggedOn then
				return machine.user;
			endif;
		endif;
	endwhile;
	
	return null;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="handleComputerNameFail" id="eeeebf35-dd46-49f1-bdcb-64e44fa3fcf7">
        <source>handleComputerNameFail(_exc : Exception; _invalidObject : Boolean io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation

*/

constants
	MgmtMsg	= 5905;
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;

	if _exc.errorCode = MgmtMsg then
		// Set _invalidObject, and resume in the calling method, which will then
		// interrogate excOccurred, to identify an invalid/deleted object
		_invalidObject := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLogLevelResp" id="b81d68a3-3767-4d50-b587-13a56fc46435">
        <source>handleLogLevelResp( _process : Process; _logLevel : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	index : Integer;

begin

	index := _logLevel + 1; // first legit log level is zero.

	if index &lt;= self.cmbLogLevel.listCount then
		self.cmbLogLevel.itemEnabled[ index ] := false;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_logLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProcessObject" id="ce97a05a-1ebd-4f25-bce0-ebc9330c005b">
        <updating/>
        <source>setProcessObject( _processObj : Process ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

begin

	self.processObj := _processObj;

epilog

end;</source>
        <Parameter name="_processObj" type="Process"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="49aafbac-2870-4e8d-ad89-1d52a1573af7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053
01 April 2021		navmd1	TFS 51054 Moved logging levels list to type method so I can reuse it for the Web Service Configs

*/

vars

	
	userStr : String;
	user : CM_User;
	cpuName : String;
	appName : String;
	isInValid : Boolean;
	edition : Integer;
	logLevel : Integer;

begin

	inheritMethod();
	
	if self.processObj = null then
		self.modalResult := 99;
		self.unloadForm();
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.processObj, isInValid );
	edition := self.processObj.edition;
	if isInValid then
		self.modalResult := 99;
		self.unloadForm();
		return;
	endif;
	
	isInValid := false;	
	userStr := self.processObj.userCode;
	user := app.myRoot.allUsers[userStr];
	
	if user = null then	
		user := self.getUserFromMachine(userStr);
	endif;
	
	if user &lt;&gt; null then 
		userStr := userStr &amp; ' - ' &amp; user.userName;
	endif;
	
	on Exception do self.handleComputerNameFail(exception, isInValid);
	cpuName := self.processObj.getComputerName();
	if isInValid then
		isInValid := false;	
		cpuName := "Unknown Computer";
	endif;
	
	appName := self.processObj.persistentApp.name;
	if isInValid then
		self.modalResult := 99;
		self.unloadForm();
		return;
	endif;
	
	if self.processObj.userInfo &lt;&gt; null and
	   self.processObj.userInfo &lt;&gt; appName then
		appName := appName&amp;' ('&amp;self.processObj.userInfo&amp;')';
	else
		appName := appName&amp;' ('&amp;self.processObj.cnGetInstanceId64(self.processObj).String&amp;')';
	endif;
	
	self.lblAppName.caption := "Appliocation = " &amp; appName &amp; CrLf &amp; "User = " &amp; userStr &amp; CrLf &amp; "Computer = " &amp; cpuName;
	
	CMUI_SetLoggingLevel@addLogLevelsToCmb(self.cmbLogLevel, false);
	
	if self.processObj = process then
		//its us, and we know our own logging level so disable it in the combo
		logLevel := app.logLevel;
		self.cmbLogLevel.itemEnabled[ logLevel + 1 ] := false;
	
	//02 Dec 2019	NDL	TFS 47053
	elseif self.processObj &lt;&gt; null then	
		//send a request for the log level
		self.beginNotification(self.processObj, EVENT_APP_LOG_LEVEL_Resp, Response_Continuous, null);
		self.processObj.causeEvent( EVENT_APP_LOG_LEVEL_Req, true, 0 );	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f7805908-b2dc-4e43-bbe2-2809d5273408">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 December 2019 08:10:06.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023834, locale);
	lblAppName.translateCaption(Xlat_0023835, locale);
	lblLogLevel.translateCaption(Xlat_0023836, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="22f328f0-7be9-4163-8f2b-b662231e4551">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

begin

	if eventType = EVENT_APP_LOG_LEVEL_Resp then
		self.handleLogLevelResp(theObject.Process, userInfo.Integer);
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
