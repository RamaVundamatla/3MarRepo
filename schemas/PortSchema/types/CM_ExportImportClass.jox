    <JadeMethod name="myClass" id="37553ed8-ad07-487d-90c0-05946f53e4c8">
        <methodInvocation>mapping</methodInvocation>
        <source>myClass(set: Boolean; _value: Class io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := currentSchema.getClass(self.className);
	endif;
end;</source>
