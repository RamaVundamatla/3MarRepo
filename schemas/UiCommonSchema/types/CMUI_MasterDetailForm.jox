	self.setColorsForEntryTable(self.tblDetailEnt);
		
	self.setColorsForTable(self.tblDataMaster);
	self.setColorsForTable(self.tblDataDetail);
	
	theBackColour := self.backColor;
	
	self.frmThumbMaster.backColor := theBackColour;
	self.frmSearch.backColor := theBackColour;
	self.frmDetailEnt.backColor := theBackColour;

end;</source>
