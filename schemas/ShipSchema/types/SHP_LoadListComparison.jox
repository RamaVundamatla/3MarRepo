    <JadeMethod name="addExceptionHandler" id="090dbcdb-261b-47bb-a2eb-3c59365fbcb7">
        <source>addExceptionHandler(exObj : Exception; _passport : CM_Passport input) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     3 August 2009 by cnwjo3
//
// Purpose:     Handle exceptions if in the prenote creation phase an exception/error occurs
vars
	index : Integer;
	obj   : Object;
begin
	if exObj.isKindOf(CM_Exception) then
		if exObj.CM_Exception.isWarning then
			app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
			return Ex_Continue;
		endif;
		
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		
		if exObj.continuable then
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="1dbf91f4-e0c7-4f82-a747-462496d59b2a">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm			: CMUI_Toolbar;
begin
	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSV,CMUI_Toolbar.Control_Alignment_Left);
	//frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);

//	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnReeferPrint, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnSummaryPrint, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);//ccms 1096
	frm.addButton(self.btnLoadComp, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDischargeComp, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnVoyageDetComp, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnBulkEdit, CMUI_Toolbar.Control_Alignment_Left);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);

	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	if self.bAllowSummaryDefn then
		//frm.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		frm.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	//13 July 2016	NDL	TFS 2345
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSaveRTS, CMUI_Toolbar.Control_Alignment_Left);

	//frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSaveUpdate, CMUI_Toolbar.Control_Alignment_Left);

	//frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addFrame(self.frmLoadListView, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="1f2b7d86-d676-49b0-bf3e-5bebb5aa50db">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnRunComparison, CMUI_Toolbar.Control_Alignment_Left);
	self.btnRunComparison.default := true;
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="47d90fc5-7444-4a09-94fe-d19484a37f67">
        <source>allowsTableFilters(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2025	navra1	Initial creation for //navra1 - MTN-36126 - 24th Sep 2025

*/

vars

begin

	if self.context = "AUTO" then
		if _table = self.tblData then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="0a38dbe6-bfb8-4452-aaeb-8904d1649424">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2025	navra1	Initial creation for //navra1 - MTN-36126 - 24th Sep 2025

*/

vars
	visibleCount : Integer;
begin
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="4084274a-1d2e-43bc-b0fe-8e9cb7dc4f31">
        <source>armNotesForObject(_item: CM_Object);
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	beginNotification(_item, Object_Update_Event, Response_Continuous, 0);
	beginNotification(_item, Object_Delete_Event, Response_Continuous, 0);	//01 Aug 2013	NDL	Par 31544

end;</source>
        <Parameter name="_item" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="btnBulkEdit_click" id="3141f5d8-c3c7-4d6e-83e0-81bc72bf0e16">
