    <JadeMethod name="doBtnStatusReturnClick" id="1fbf44d7-de5a-43d8-aae4-cb50e827cf26">
        <source>doBtnStatusReturnClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	form : INV_InvoiceReturn;
	inv : CM_Invoice;

begin

	inv := self.myCurrentInvoice;
	if inv = null then
		return;
	endif;

	// TFS 39618 PATCH 1 if not app.getMyUser.canDo( self.myTerminal, PmAdmInvListStatusReturn ) then
	if not self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_POSTED_REVERSE) then  // TFS 39618 PATCH 1 
		return;
	endif;
	
	create form transient;
	form.setMyTerminal( self.myTerminal );
	form.setMyInvoice( inv);
	form.setParentForm( self );
	
	form.showModal();

epilog

	delete form;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnStatusSuspenseClick" id="9c63a73a-de99-4ce0-932e-10fe05833e55">
        <updating/>
        <source>doBtnStatusSuspenseClick() updating;
/* ---------------------------------------------------------------------------
Created:	23 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	app.mousePointer := MP_HOURGLASS;
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoicelistMaint) then

		app.msgBox(app.getErrorString1(VB_SECMOVE,"Invoice Status Void") ,
										"Invoice Security",
