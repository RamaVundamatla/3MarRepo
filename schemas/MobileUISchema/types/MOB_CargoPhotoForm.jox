*/

vars

begin
	self.unloadForm();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleImageThumbnailException" id="c22db2c2-a5d9-41e0-a4ef-d1d990728fe4">
        <source>handleImageThumbnailException(_exc : Exception; _image : Any; _invalidThumbnail : Boolean io) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2013	cnwrd1	Initial creation
//cnwrd1 par 32342

*/

constants
	ImageNotValid = 14015;
vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	
	
	if _exc.errorCode = ImageNotValid  then
		_invalidThumbnail := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;


epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_image" type="Any"/>
        <Parameter name="_invalidThumbnail" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPicFileName" id="d5221818-14c1-4ba4-ad50-9eaf808c2862">
        <updating/>
        <source>setPicFileName(_fileName : String)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	#cnwdz2	 CCMS MES 1005 par 22294

*/

vars

begin
	self.picFileName := _fileName;
epilog

end;</source>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="93f7f906-25ad-40f2-8181-ac3e78806bde">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars
	
	invalidThumbnail : Boolean;

begin
						   
	self.doResizeControls(true);
	
	self.originalPhoto := app.loadPicture(picFileName);
	self.photoPreview.picture := self.originalPhoto;
	
	on Exception do self.handleImageThumbnailException(exception, self.photoPreview.picture,invalidThumbnail); //cnwrd1 par 32342
	
	self.photoPreview.picture := self.photoPreview.createPictureAsType(false, false, 24, Window.PictureType_Png);	
	
	if invalidThumbnail then //cnwrd1 par 32342
		app.msgBox('Picture to large for Thumbnail', '', MsgBox_OK_Only);
	endif;	
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="04f4a1dc-54e3-4f58-b3e9-13aeb4dbf884">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	#cnwdz2	 CCMS MES 1005 par 22294

*/

vars

begin

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Cancel), null, null, null );
	
	self.btnOne.enabled := self.canTakePhoto();	//07 Dec 2010	NDL	Par 23831
	self.btnTwo.enabled := true;
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="19d82ca4-ef8b-4bac-be11-8474185f7f39">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013927, locale);
	lblDesc.translateCaption(Xlat_0013928, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
