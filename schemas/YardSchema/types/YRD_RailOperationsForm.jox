    <JadeMethod name="unload" id="21b7b1ca-1390-4892-9be6-1284c143fa70">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2017	cnwndl1	Initial creation	TFS 3685

*/

vars

	idx : Integer;
	mnuChild : MenuItem;

begin
	
	//09 Mar 2017	NDL	TFS 3685
	if self.resDetMenuCount &gt; 1 then
		foreach idx in 2 to self.resDetMenuCount do  // pos 1 is the original...
			mnuChild := self.mnuWagonAssignBulk.getMenuItem(idx); 
			if mnuChild &lt;&gt; null then
				//get rid of the old ones.
				delete mnuChild;
			endif;
		endforeach;
		self.resDetMenuCount := 0;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="5082e74f-9abb-49c3-a9f7-75afe0977390">
