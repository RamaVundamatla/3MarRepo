    <JadeMethod name="setupThumbnailDetails" id="a2aa1f6e-bce9-4b94-912d-a2858107a773">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;
    row     : Integer;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_EdiFormatTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_EdiFormatMaint);
	theForm.shtTblInput1.visible := true;

	theForm.myAssistant.comboBoxOperator(theForm.cmbOperator, null, null);
		
	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="3439f0a4-7b4c-45f7-a710-3dbb3e48a962">
        <updating/>
        <source>


showThumbnail(_ediFF : CM_FileFormatEDI) updating;
// Purpose:     
// Changed On   	Changed By  	Reason
// ----------   ----------  --------------------------------------------------
// 28 July 2022 	navvt20 		Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
vars

	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Name, _ediFF.name);
	theForm.tblInput1.setValueByName(ETRow_Description, _ediFF.description);
	theForm.tblInput1.setValueByName(ETRow_NoLongerUsed, _ediFF.noLongerUsed);

	if _ediFF.myOperator &lt;&gt; null then
		theForm.cmbOperator.listObject := _ediFF.myOperator;
		//theForm.tblInput1.setValueByName(ETRow_EdiOperator, _ediFF.myOperator.code); // 28.07.2022 navvt20 TFS 54199
		theForm.tblInput1.setValueByName(ETRow_EdiOperator, _ediFF.myOperator.description); // 28.07.2022 navvt20 TFS  54199
	endif;
		
	theForm.tblData.accessColumn(2).width := 130;
	
end;</source>
        <Parameter name="_ediFF" type="CM_FileFormatEDI"/>
    </JadeMethod>
