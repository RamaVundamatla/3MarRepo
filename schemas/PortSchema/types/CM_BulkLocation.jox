    <JadeMethod name="getMatchingTrackedItem" id="f138d9a9-1d11-40b8-a771-eae48c8fb7b3">
        <source>getMatchingTrackedItem(_product: CM_Product): CM_TrackedItem;

// Created by cnwdvb1 on 31 October 2006

vars

	ti			: CM_TrackedItem;
	
begin

	if _product = null then
		return null;
	endif;
	
	foreach ti in self.allTrackedItems discreteLock do
		if ti.myProduct = _product then
			return ti;
		endif;
	endforeach;
		
	return inheritMethod(_product);

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
