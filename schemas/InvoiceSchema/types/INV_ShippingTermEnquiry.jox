    <JadeMethod name="doNotableAdd" id="aca4ad52-1149-4a6b-bb77-eefac787faa6">
        <source>doNotableAdd(_shipTerm: CM_InvoiceContractShipTerm);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	
	self.allNotableObjects.add(_shipTerm);
	beginNotification(_shipTerm, self.myTerminal.getTerminalEvent(Event_InvShipTermUpdate), Response_Continuous, null);
	beginNotification(_shipTerm, EventFileAdd, Response_Continuous, null);
	beginNotification(_shipTerm, EventFileDelete, Response_Continuous, null);

epilog

end;</source>
        <Parameter name="_shipTerm" type="CM_InvoiceContractShipTerm"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="8bcb7724-ce1b-42e5-8892-d8acbf68d275">
        <source>doNotableClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvShipTermUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="f9a68050-7919-4f52-a25b-64fd399c1d0a">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRemove.enabled := false;
		self.btnNew.enabled := false;
		self.btnUpdate.enabled := false;
		self.cmbBusinessUnit.enabled := false;
		self.tblShipTerm.enabled := false;
		self.btnAudits.enabled := false;
	endif;
		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="4507c487-cfd3-427f-8a00-833eacc242f4">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	theReturn : Integer;
	shipTerm : CM_InvoiceContractShipTerm;
begin
	shipTerm := _obj.CM_InvoiceContractShipTerm;
	if shipTerm = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if app.msgBox(app.getErrorString2(Sure_want_remov_from_invoi_shi, shipTerm.code,null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	while true do
 	app.myTrxDA.trxDeleteInvContractShpngTerms(shipTerm, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
		else
			theReturn := app.showErrorWarningDialog("Invoice Contract Ship Term", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doTblCFContMenu" id="aebf0dbb-8a8e-425d-a318-829de56e1482">
        <updating/>
        <source>doTblCFContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblShipTerm;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="d3222127-0b18-493c-afc9-ae1e275d9591">
        <updating/>
        <source>doViewAudits(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

begin
	if _obj = null then
		return;
	endif;

	if self.myAssistant = null then
		create self.myAssistant as CMUI_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	app.viewAuditForm(_obj.CM_InvoiceContractShipTerm, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initTblShipTerm" id="b27a9b87-071c-4623-810c-8cfb1224e9dc">
        <source>initTblShipTerm(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblShipTerm;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_InvoiceContractShipTerm);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblShipTerm);	
		//self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
