    <JadeMethod name="zResetDataFilterRatio" id="3c05f7ef-2151-438b-84e6-8ef861fb5958">
        <source>zResetDataFilterRatio() protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	filterHeight	: Real;
	filterRatio		: Integer;
begin

	filterHeight := tblSearch.height + tblSearch.top + 20;
	
	if self.isSearcherFloating then
		if frmSearch.height &lt; filterHeight then
			frmSearch.height := filterHeight;
		endif;
		return;
	endif;

	if sptDataFilter.height &lt;&gt; 0 then	// 06/03/2015 cnwar2 #35810
		filterRatio := (((tblSearch.height + tblSearch.top + 30) / sptDataFilter.height) * 100).Integer;
		
		//cnwmc5 - PAR 31051
		if app.isUsingSkin() then
			filterRatio := (((tblSearch.height + tblSearch.top + 12) / sptDataFilter.height) * 100).Integer;
		endif;
	
		sptDataFilter.setLeftToRightRatioAndResize(filterRatio);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSearchTblInit" id="053b449b-b21f-40de-a8bf-812fee9e34ad">
        <updating/>
        <source>zSearchTblInit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	RowHeight		: Integer = 20;		// Nominal row height for CM_EntryTables for calc of height

vars
	defName			: String;
	entTableDef		: EntTableDef;

begin
	if (not self.allowSearch) then
		return;
	endif;
	self.tblSearch.setTerminologyRelevantTerminal(self.myTerminal);
	
	defName := self.searcherTblGetDefName();
	if defName = null then
		self.initFilterTable();			// call the old method for now
		return;
	endif;

	// Par 15247
	//beginLoad;
	entTableDef := app.myController.getEntTableDef(defName);
	if entTableDef &lt;&gt; null then
		self.tblSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; ETDef_ContEnqFind &amp; ') not found');
		return;
	endif;
	
	self.searcherTblInitControls();
	
	self.tblSearch.adjustHeight(RowHeight * entTableDef.allEntTableRows.size);
epilog
	endLoad;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSelectAll" id="bc352456-de87-4ee0-828a-d2516593b2ed">
        <source>zSelectAll() protected;
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl			: CM_DataTable;
	
begin
	if (not self.allowMultiSelectEdit)
	and (not self.allowMultiSelectDelete) then //PAR 10935
		return;
	endif;
	
	tbl := self.tblData;
	//jlier1 JIRA-35555 24/7/25
	tbl.selectAll();
	
	if self.myCurrentObject &lt;&gt; null then
		//remove myCurrentObject, then add it on the end of selectedObjects array - in this way
		//the object we are looking at will still be the one that is used as the master in bulk edit mode
		//(which uses the last selected object as the master)
		if tbl.allSelectedObjects.includes(self.myCurrentObject) then
			tbl.allSelectedObjects.remove(self.myCurrentObject);
		endif;
		tbl.allSelectedObjects.add(self.myCurrentObject);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetControlsForAddEdit" id="a4a7b465-b4de-48fa-9362-cc0aa2fef6fd">
        <updating/>
        <source>zSetControlsForAddEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.useTblThumb then
		tblThumb.visible	:=	false;
	endif;	
	
	self.btnEditTV.enabled 			:= false;
	self.btnDeleteTV.enabled 		:= false;
	self.btnNewTV.enabled 			:= false;
	self.btnNextTV.enabled			:= self.allowNext and (self.mode = Mode_Add);
	self.btnPrintTV.enabled 		:= false;
	self.btnExportCSVTV.enabled		:= false;
	self.btnResetSearchTV.enabled	:= false;
	self.btnSearchTV.enabled		:= false;
	self.btnSelectAllTV.enabled		:= false;
	self.btnShowSearchTV.enabled	:= false;
	self.btnCloseSearchTV.enabled	:= false;

	if self.allowAdd or self.allowUpdate then
		self.btnSaveBase.enabled 	:= true;
		self.btnCancelBase.enabled 	:= true;
	endif;
	
	// disable other controls to force user to save/cancel add/update first.
	
	tblSearch.enabled	:=	false;

	self.setControlsForAddEdit();
//	self.frmToolbar.updateControls();
//	self.frmSearchToolbar.updateControls();
end;</source>
