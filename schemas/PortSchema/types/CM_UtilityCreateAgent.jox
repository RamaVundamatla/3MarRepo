    <JadeMethod name="utlCreateROROVesselDeck" id="c68b0dae-602c-4e78-a0c6-36f26611deda">
        <updating/>
        <source>utlCreateROROVesselDeck(_proxyDeck : CM_Deck input;
						_realDeck : CM_Deck output;
						_copyDeckItems : Boolean;
						_passport : CM_Passport input) updating;
						
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Mar 2011	cnwer1	Initial creation
17 May 2011 cnwer1	27486 copy did not save sub decks or deck items
*/

vars
	subDeck : CM_Deck;
	realSubDeck : CM_Deck;
	iter : Iterator;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxyDeck, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	create _realDeck as _proxyDeck.class persistent;
	
	if not _copyDeckItems then
		_realDeck.initLayout(_proxyDeck);
	endif;
	
	_realDeck.setForCreate(_proxyDeck,_passport);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realDeck);
	endif;

	
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if _copyDeckItems then
		self.utlCreateRORODeckItems(_proxyDeck ,
									_realDeck,
									_passport);
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		iter:=_proxyDeck.getSubDeckCollection.createIterator;
		while iter.next(subDeck) do
		
			self.utlCreateROROVesselDeck(subDeck ,
											realSubDeck ,
											true,
											_passport);
		
			if app.myPassport.hasErrors then
				return;
			endif;
		
		endwhile;

	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_realDeck" type="CM_Deck" usage="output"/>
        <Parameter name="_copyDeckItems" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateROROVoyageDeck" id="8c0aa36e-cf06-48c8-83d3-08b20bd88c29">
        <updating/>
        <source>utlCreateROROVoyageDeck(_proxyDeck : CM_DeckVoyage input;
						_realDeck : CM_DeckVoyage output;
						_voyageStructure  : CM_ROROVoyageStructure;
						_copyDeckItems : Boolean;
						_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	subDeck : CM_DeckVoyage;
	realSubDeck : CM_DeckVoyageSub;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxyDeck, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	create _realDeck persistent;
	
	if not _copyDeckItems then
		_realDeck.initLayout(_proxyDeck);
	endif;
	
	_realDeck.setForCreate(_proxyDeck,_passport);
	
	
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if _copyDeckItems then
		self.utlCreateRORODeckItems(_proxyDeck ,
									_realDeck,
									_passport);
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		foreach subDeck in _proxyDeck.allSubDecks discreteLock do
		
			self.utlCreateROROVoyageSubDeck(subDeck.CM_DeckVoyageSub ,
											realSubDeck ,
											true,
											_passport);
	
			if app.myPassport.hasErrors then
				return;
			endif;
			
		endforeach;

	endif;


epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVoyage" usage="input"/>
        <Parameter name="_realDeck" type="CM_DeckVoyage" usage="output"/>
        <Parameter name="_voyageStructure" type="CM_ROROVoyageStructure"/>
        <Parameter name="_copyDeckItems" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
