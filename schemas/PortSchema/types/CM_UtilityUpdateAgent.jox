    <JadeMethod name="utlUpdateInvoiceProcInvAPI" id="cf62b82a-f259-4111-b601-45e4c3e508a0">
        <updating/>
        <source>utlUpdateInvoiceProcInvAPI(_passport : CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 November 2023	navra1	Initial creation for  TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR -61386/Task - 61564)
04 September 2024	jlizm1	TFS 65951 NSW Dyanmic Integration - invoice process

*/

vars
	pxyProcess, realProcess, invoiceAPIProcess : CM_InvoiceProcess;
begin
	// create the default invoice process object
	if CM_InvoiceProcessInvoiceAPI.instances.isEmpty then
		create pxyProcess as CM_InvoiceProcessInvoiceAPI transient;
		pxyProcess.setProxy(InvoiceProcessInvoiceAPI, "InvoiceAPI Process", PINEmail_InvProcAPIOffset);
		app.myUtilityCA.utlCreateInvoiceProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_InvoiceProcessInvoiceAPI!!!", LogINFO);
			return;
		endif;
		invoiceAPIProcess := realProcess;
	else
		invoiceAPIProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	endif;
	
	// in case there's been a change in status priority, get everything in priority order out of the way
	// Add 10000 to all priorities
	//self.setupVoyageStatusMovePriority(defaultProcess);
	
	// now create / update all statuses		
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_OPEN,				1, 	app.getErrorString(Open_GC), White, PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_PENDING, 			2, 	app.getErrorString(Pending),White, PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED, 			3, 	app.getErrorString(Posted),White, PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED_CREDIT, 	4, 	app.getErrorString(Posted_credit),White, PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED_REVERSE, 	5, 	app.getErrorString(Posted_returned), White,PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_VOID, 			6, 	app.getErrorString(Void),White, PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_SUSPENSE,			7, 	app.getErrorString(Suspense), White,PINEmail_InvProcDefOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED_PENDING,	8, 	app.getErrorString(Posted_pending), White,PINEmail_InvProcAPIOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED_ERROR,		9, 	app.getErrorString(Posted_error), White,PINEmail_InvProcAPIOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED_CREDIT_PENDING,	10, 	app.getErrorString(Posted_return_pending), White, PINEmail_InvProcAPIOffset);
	self.setupInvoiceStatus(invoiceAPIProcess, CM_Invoice.INVOICE_POSTED_CREDIT_ERROR,		11, 	app.getErrorString(Posted_return_error), White, PINEmail_InvProcAPIOffset);
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
