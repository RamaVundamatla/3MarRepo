    <JadeMethod name="rollDi" id="599907df-8495-41e5-a804-e2d507e66bd0">
        <source>rollDi(_frame : Frame input; _index : Integer);
// ---------------------------------------------------------------------------
// Created:		24 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	dice : Integer;
begin
	if _frame.helpKeyword = "X" then
		return;
	endif;
	
	dice := self.getRandomNumber();
		
	_frame.drawFontSize := 16;
	_frame.autoRedraw := true;
	_frame.clearGraphics();
	_frame.fontBold := true;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	_frame.drawPictureAt(self.getDiPic(dice),4,4);

	self.allValues[_index] := dice;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rollDice" id="fbdbc710-0122-43a5-a95d-adbddd5f4f8a">
        <updating/>
        <source>rollDice() updating;
// ---------------------------------------------------------------------------
// Created:		24 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx, dice : Integer;
	objs : ObjectArray;
begin

	self.numRolls := self.numRolls + 1;

	if self.numRolls = 3 then
		self.btnRoll.enabled := false;
	endif;	
	self.rollDi(frmDi1,1);
	self.rollDi(frmDi2,2);
	self.rollDi(frmDi3,3);
	self.rollDi(frmDi4,4);
	self.rollDi(frmDi5,5);

	self.getResults();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDiHold" id="3b0ab223-4b41-4cad-8c24-60582d53e82a">
        <source>setDiHold(frame : Frame input; _index : Integer);
// ---------------------------------------------------------------------------
// Created:		24 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allValues[_index] = 0 then
		return;
	endif;
	if frame.helpKeyword = null then
		frame.helpKeyword := "X";
	else
		frame.helpKeyword := null;
	endif;
	
	if frame.helpKeyword = "X" then
		frame.drawWidth := BOUNDARYWIDTH;
		frame.drawRectangle(1,1,frame.clientWidth - BOUNDARYWIDTH, frame.clientHeight - BOUNDARYWIDTH,Red);
//		frame.boundaryColor := Red;
//		frame.boundaryWidth := BOUNDARYWIDTH;
//		frame.left := frame.left - BOUNDARYWIDTH;
//		frame.top := frame.top - BOUNDARYWIDTH;
	else
		frame.clearGraphics();
		frame.drawPictureAt(self.getDiPic(self.allValues[_index]),4,4);

//		frame.boundaryColor := White;
//		frame.boundaryWidth := 0; //BOUNDARYWIDTH;
//		frame.left := frame.left + BOUNDARYWIDTH;
//		frame.top := frame.top + BOUNDARYWIDTH;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
</GUIClass>
