    <JadeMethod name="doConvertTIAttachments" id="2b8e3599-85ce-4e6b-b7d4-45d129f6f5e0">
        <updating/>
        <source>doConvertTIAttachments() updating, protected;
/*
Purpose:			Creates a CMIF_PreNote object for each tracked item in allAttachments,
					clears tracked items from allAttachments, and adds the CMIF_PreNotes instead

Parameters:			None

Return Value:		None

Date		Who		Reason
24/02/2010	cnwdap1	PAR #21827 Initial creation
*/
vars
	obj			: Object;
	preNote		: CMIF_PreNote;
	ti, pxyTi	: CM_TrackedItem;
	preNotes	: ObjectArray;
	tisToRemove	: ObjectArray;

begin
	create preNotes transient;
	create tisToRemove transient;
	
	// do we have any tracked items in the allAttachments collection?
	foreach obj in self.allAttachments where CM_TrackedItem.hasInstance(obj) do
		ti := obj.CM_TrackedItem;
		tisToRemove.add(ti);
		
		// create a prenote instead
		create preNote transient;
		preNote.setFromTI(ti, self.myTerminal);
		if ti.isTransient then
			preNote.setMyProxyTrackedItem(ti);
		else
			pxyTi := ti.pxyGetProxyObject();
			if pxyTi = null then
				pxyTi := app.createUpdateProxy(ti).CM_TrackedItem;
			endif;
			preNote.setMyOriginalProxyTI(pxyTi);
		endif;
		preNotes.add(preNote);
	endforeach;
	
	// remove tis from allAttachments
	foreach obj in tisToRemove do
		self.allAttachments.remove(obj);
	endforeach;
	
	// add in prenotes
	foreach obj in preNotes do
		self.allAttachments.add(obj);
	endforeach;
	
epilog
	delete preNotes;
	delete tisToRemove;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDefaultAttachmentFormDetails" id="78788402-f564-4d46-a0a4-82656aaf91b0">
        <updating/>
        <source>doDefaultAttachmentFormDetails() updating, protected;
/*
Date		Who		Reason
04/09/2009	cnwdap1	Initial creation
09/10/2009	cnwdap1	PAR #21160 Prevent booking item picker being shown on attachments form
13/10/2009	cnwdap1	PAR #20950 Default transport mode for the attachment to that of the parent form
12/03/2010	cnwdap1	PAR #23164 Correct re-displaying a CMIF_PreNote transient attachment object
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
24 Jun 2013	cnwcs5	par 31758 - do not default wewight from parent when adding attachment
05/02/2023	navkc1 	Bug 62302: CUX | Can't mark onboard or child cargo as 'overlanded'
*/
vars
	parentForm		: CMUI_ReceiveCargoForm;
	bookingRef		: String;
	bookingItem		: CM_BookingRefItem;
	voyage			: CM_Voyage;
	dischargePort, destination,
	transhipPort	: CM_Port;
	operator		: CM_Operator;
	isOverlanded	: Boolean;
	

begin
	parentForm	:= self.myParentForm.CMUI_ReceiveCargoForm;
	bookingRef	:= parentForm.txtBookingRef.getString;

	
	if bookingRef &lt;&gt; null then
		self.txtBookingRef.setValue(bookingRef);
		
		bookingItem	:= parentForm.cmbBRItem.getObject.CM_BookingRefItem;
		
		if bookingItem &lt;&gt; null and self.updateMode = self.Mode_Add then		// PAR #23164 don't set from the parent form if we're editing an existing attachment
			self.cmbBRItem.listCollection(bookingItem.myBookingReference.allBookingRefItems, true, 0);
			self.cmbBRItem.setForObject(bookingItem);
			
			self.myBookingRefItem := bookingItem;	// PAR #21160 supress booking item picker
		endif;
	endif;
	
	voyage 			:= parentForm.cmbVoyageCode.listObject.CM_Voyage;
	destination		:= parentForm.cmbDestPort.listObject.CM_Port;
	dischargePort 	:= parentForm.cmbDischargePort.listObject.CM_Port;
	transhipPort	:= parentForm.cmbTranshipPort.listObject.CM_Port;
	operator		:= parentForm.cmbOperatorCode.listObject.CM_Operator;
	
	//05/02/2023	navkc1 Bug 62302
	isOverlanded := parentForm.chkOverlanded.getBoolean();
	self.chkOverlanded.setValue(isOverlanded); 
	
	// If parent is overlanded, disable the control. Doesn't make sense if parent is overlanded and child is not.
	if isOverlanded then
		self.chkOverlanded.enabled := false;
	endif;
	
	// Do not default total weight at a;;
	self.cmbVoyageCode.setIndexFromObject(voyage);
	self.cmbVoyageCode_click(self.cmbVoyageCode);			// this loads the operators
	self.cmbOperatorCode.setIndexFromObject(operator);
	self.cmbDestPort.gotFocus(self.cmbDestPort);			// this loads the destination ports
	self.cmbDischargePort.gotFocus(self.cmbDischargePort);	// this loads the discharge ports
	self.cmbTranshipPort.gotFocus(self.cmbTranshipPort);
	self.cmbDestPort.setIndexFromObject(destination);
	self.onDestinationChanged(self.cmbDestPort);
	self.cmbDischargePort.setIndexFromObject(dischargePort);
	self.cmbTranshipPort.setIndexFromObject(transhipPort);
	
	// PAR #20950 Default transport mode for the attachment to that of the parent form
	if self.isOnshipForm or self.transportMode = TI_TRANSMODE_SHIP_STR then // par 22556 10.3.2010 cnwrd1  // par 22879 cnwrd1 11/3/2010
		self.myAssistant.comboBoxTransportModes(self.cmbTransportMode.getEmbeddedControl.ComboBox, null); 
	else
		self.myAssistant.comboBoxTransportModesNoShip(self.cmbTransportMode.getEmbeddedControl.ComboBox, null); 
	endif;// par 22556 10.3.2010 cnwrd1 
	
	
	self.cmbTransportMode.setForText(parentForm.cmbTransportMode.getString);
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="d85ada1d-6552-4949-8b69-dab0442cc3e5">
        <updating/>
        <source>doDelete() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2009	cnwdap1	Initial creation
*/
vars

begin
	self.doDeleteAttachment();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteAttachment" id="a75baf6c-2c23-41ea-9aad-d9ea7a700297">
        <updating/>
        <source>doDeleteAttachment() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2009	cnwdap1	Initial creation
*/
vars

begin
	// deletes a transient attachment object
	if not self.isAttachmentForm then
		return;
	endif;
	
	// flexigate form
	if self.isFlexiGateForm and self.myPxyGTEEntity &lt;&gt; null then
		self.myParentForm.CMUI_ReceiveCargoForm.deleteAttachment(self.myPxyGTEEntity);
		self.myPxyGTEEntity.setMyVehicleVisit(null);
		self.myPxyGTEEntity.setParentObject(null);
		delete self.myPxyGTEEntity;
		
	// pre note form
	elseif self.isPreNoteForm then
		self.myParentForm.CMUI_ReceiveCargoForm.deleteAttachment(self.myIntFacePreNote);
		delete self.myIntFacePreNote;
		
	endif;
	
	self.unloadForm;
	self.bringMainFormToFront();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeriveTemperatures" id="b41dd154-e8c0-41fa-af4b-171929a8cfd1">
        <source>doDeriveTemperatures(_operator : CM_Operator; _carriageTempC, _carriageTempF, _packTempC, _packTempF : Decimal output) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/07/2009	cnwdap1	Initial creation
04/10/2017	jlgdap1	TFS 7204 STWR Correct real handling for non-standard locales
*/
vars
	useFahrenheit	: Boolean;

begin
	_carriageTempF		:= app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
	_carriageTempC 		:= NULL_TEMPERATURE;
	_packTempC 			:= NULL_TEMPERATURE;
	_packTempF 			:= app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
	

	if _operator = null then
		return;
	endif;
	
	useFahrenheit := _operator.displayTempFahrenheit;
	if useFahrenheit then
		//if self.txtCarriageTemp.getString.asCastRealJMT() = 0 then		//-cnwml2 PAR24459
		if self.txtCarriageTemp.getString() = null then
			_carriageTempF		:= app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
		else
			//_carriageTempF 		:= self.txtCarriageTemp.getString.asCastRealJMT();		// TFS 7204
			_carriageTempF 		:= self.txtCarriageTemp.getString.asRealJMT();				// TFS 7204
		endif;
		_carriageTempC 			:= NULL_TEMPERATURE;
		//if self.txtPackTemp.getString.asCastRealJMT() = 0 then			//-cnwml2 PAR24459
		if self.txtPackTemp.getString() = null then
			_packTempF			:= app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
		else
			//_packTempF 			:= self.txtPackTemp.getString.asCastRealJMT();			// TFS 7204
			_packTempF 			:= self.txtPackTemp.getString.asRealJMT();					// TFS 7204
		endif;
		_packTempC 				:= NULL_TEMPERATURE;
	else	
		//if self.txtCarriageTemp.getString.asCastRealJMT() = 0 then		//-cnwml2 PAR24459
		if self.txtCarriageTemp.getString() = null then
			_carriageTempC 		:= NULL_TEMPERATURE;
		else
			//_carriageTempC 		:= self.txtCarriageTemp.getString.asCastRealJMT();		// TFS 7204
			_carriageTempC 		:= self.txtCarriageTemp.getString.asRealJMT();				// TFS 7204
		endif;
		_carriageTempF 			:= app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846

		//if self.txtPackTemp.getString.asCastRealJMT() = 0 then			//-cnwml2 PAR24459
		if self.txtPackTemp.getString() = null then
			_packTempC			:= NULL_TEMPERATURE;
		else
			//_packTempC 			:= self.txtPackTemp.getString.asCastRealJMT();			// TFS 7204
			_packTempC 			:= self.txtPackTemp.getString.asRealJMT();					// TFS 7204
		endif;
		_packTempF 				:= app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_carriageTempC" type="Decimal" usage="output"/>
        <Parameter name="_carriageTempF" type="Decimal" usage="output"/>
        <Parameter name="_packTempC" type="Decimal" usage="output"/>
        <Parameter name="_packTempF" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doFilterDetailsByCargoType" id="030e012e-b92a-45f6-a3d7-9251f8f7f738">
        <updating/>
        <source>doFilterDetailsByCargoType(_cargoType : CM_CargoType) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2009	cnwjk3	Initial creation
19/11/2009	cnwmh5	PAR21492 - Need to clear/load cmbDimType correctly
15/02/2010	cnwdap1	PAR #22088 Open Dimensions section for system cargo type Timber
17/02/2010	cnwdap1	PAR #22397 New parameter for setDimTypeDetails method
09/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - default Total Weight/Volume to cargo type default measurement types
05/12/2014  cnwma1  PAR #35338 Not selecting a Volume measurement can cause 1090 errors
*/
vars
	product	: CM_Product;
	opening : Boolean;
begin
	if _cargoType = self.existingCargoType then
		return;
	endif;
	self.tblTotalVolume.enabled := true;												// PAR #33606
	self.tblTotalWeight.enabled := true;	
	if _cargoType &lt;&gt; null and not _cargoType.classNameToCreate = CM_Container.name then 
		self.setIsGeneralCargo();
		
		//epr TFS 1707 6/4/16
		if _cargoType.isBreakBulk or _cargoType.isBulkProduct then															// PAR #33606
			if self.myPxyGTEEntity = null then														// PAR #33606
				if _cargoType.myWeightMeasurementType &lt;&gt; null then									// PAR #35338
					self.tblTotalWeight.setValues(Space &amp; _cargoType.myWeightMeasurementType.shortName);// PAR #33606
				endif;
				if _cargoType.myVolumeMeasurementType &lt;&gt; null then									// PAR #35338
					self.tblTotalVolume.setValues(Space &amp; _cargoType.myVolumeMeasurementType.shortName);// PAR #33606
				endif;
			endif;																					// PAR #33606
			if _cargoType.isTrackByVolume then														// PAR #33606
				self.tblTotalWeight.enabled := false;												// PAR #33606
				self.tblTotalVolume.enabled := true;												// PAR #33606
			elseif _cargoType.isTrackByWeight then													// PAR #33606
				self.tblTotalVolume.enabled := false;												// PAR #33606
				self.tblTotalWeight.enabled := true;												// PAR #33606
			endif;																					// PAR #33606
		endif;																						// PAR #33606
	
	else
		if _cargoType &lt;&gt; null and _cargoType.classNameToCreate = CM_Container.name and not self.isAnyCargo() then //17/03/2011 cnwdz2 24750
			if cmbCommodity.getObject &lt;&gt; null and cmbCommodity.getObject.CM_Commodity.isEmpty then
				self.setIsEmptyContainer;
			else
				self.setIsFullContainer;
			endif;
		endif;
		
	endif;

	if self.tblTotalVolume.enabled then
		if self.isAutoVolumeCalcCT() then
			if not self.txtQuantity.isHidden then		// 20/6/19 MAP TFS41707
				self.autoCalcVolumeQtyPieces();
			else
				self.autoCalcVolume();
			endif;
		endif;
	endif;

		//epr TFS 7756 20/2/18 simplified
	self.checkSectionState();
	self.doOpenCloseSection(self.lblDimensions, self.lblCargoDetails, self.btnDimensions, opening);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doFilterDetailsBySubCargoType" id="e24e3b82-15ee-4bc6-b1de-29ddd7af4393">
        <updating/>
        <source>doFilterDetailsBySubCargoType(_product : CM_Product) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2009	cnwjk3	Initial creation
01/12/2009	cnwdap1	CCMS 1007 Allow reefer details on general cargo if subproduct is set up as such
17/02/2010	cnwdap1	PAR #22278 Display reefer fields based on commodity requiring reefer, not on sub-cargo type being a possible reefer type
15/03/2010	cnwdap1	PAR #23190 Redo ent table display if product attributes to display have changed
10/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - rail prenote screen needs to default total weight/volume measurements from product
01/07/2014	cnwdap1	PAR #34483 CCMS DPH 2384 Show BOL details for On-Ship attachments
20/02/2017 cnwer1	TFS 7756 simplified
*/
vars
	opening : Boolean;
begin
	if _product &lt;&gt; null then
		if self.isAttachmentForm() then
				if not self.currentEntTableDef.isOneOf(ETDef_AttachmentGeneral, ETDef_AttachmentBOLGeneral)  or (self.existingCargoSubType &lt;&gt; _product) then
				if self.isOnshipForm then																																															// PAR #34483
					self.initFieldsForEntDefName(ETDef_AttachmentBOLGeneral, false);																																				// PAR #34483
				else																																																				// PAR #34483
					self.initFieldsForEntDefName(ETDef_AttachmentGeneral, false);
				endif;																																																				// PAR #34483
			endif;
			
		elseif self.isRailPreNoteForm then
			// do nothing - we never change the ent def type for this form
		else
			// PAR # 23190 Redo ent table control display to pick up changed product attributes
			if (self.existingCargoSubType &lt;&gt; _product) then 
				self.initFieldsForEntDefName(self.currentEntTableDef, false);
			endif;
		endif;
	endif;
	
	//epr TFS 7756 20/2/18
	self.checkSectionState();
	self.doOpenCloseSection(self.lblDimensions, self.lblCargoDetails, self.btnDimensions, opening);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doFilterProductAttributes" id="abee0b5b-115f-4052-ac13-f60afcee2873">
        <updating/>
        <source>doFilterProductAttributes(_product : CM_Product) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2009	cnwjk3	Initial creation
12/10/2009	cnwdap1	PAR #21125 Default total weight/volume if product has weight and volume, 
					and hide subcargo level weight and volume
12/10/2009	cnwdap1	PAR #21098 If product attributes have already been set (e.g. by default 
					from a booking item being prenoted), don't overwrite with the product default
10/03/2010	cnwcs5	par 22775 - set captions for sub-cargo dimension fields	
15/03/2010	cnwdap1	PAR #23190 Refactoring of product attribute hiding/showing, 
					and then recall ent table building once we now which ones to display
					Type attribute can be Code (combo box) or Value (text box)
23/03/2010	cnwdap1	PAR #23190 New Type textbox was not being hidden when Type combo box was
13/04/2010	cnwdap1	PAR #23673 Remove cnEcStripDecimalZeros use - this doesn't work with locales
11/10/2011 	cnwmh5	#28186 - Change height, width, length, density to use asStringMeasurementJMT
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
30/08/2013	cnwdap1	PAR #32371 If subcargo type has a non-standard weight/volume, and we've hidden the 
								subcargo type weight/volume field, change total weight field to be non-standard 
								Check for non-standard measurement having already been set before calling setup on measurement tables
07/10/2013	cnwdap1	PAR #32612 When hiding weight and volume and showing total weight and total volume instead,	the total weight and 
								total volume heights were getting out of whack - reset them so the measurement combos are still visible
21/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - Stop substituting the weight / total weight and volume / total volume fields, 
								total weight and total volume are always totals, product attribute weight and volume are just attributes
								Deleted a bunch of commented out code
								Hide Total Volume for bulk cargo with no density, disable Total Weight/Total Volume as appropriate
20/02/2018 	cnwer1	TFS 7756  Actually show what is visible on cargo type that can be saved i.e. bulk cannot save weight
13/05/2022 	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
19/06/2024	navrv30	Ticket 63877: PNL - Cannot Create MDF cargo for some Cargo Subtypes
*/
vars
	default					: Boolean;
	cargoType				: CM_CargoType;
	productAttr 			: CM_ProductAttr;
	allProductAttributes 	: ObjectSet;
	attr 					: Object;
	control 				:  CMUI_FieldFrame;
	defaultHidden 			: Boolean;
	opening 				: Boolean;
	bBGenericsIsHidden		: Boolean;
	measurementName			: String;
begin
	


	// if we have no current item, 
	default := self.updateMode = self.Mode_Add and self.myBookingRefItem = null and self.myTI = null;
	bBGenericsIsHidden := default;
	
	if _product = null then
		cargoType := self.cmbType.getObject().CM_CargoType;
	else
	
		cargoType := _product.myCargoType;
	endif;
	if cargoType = null then
		cargoType := self.cmbType.getObject().CM_CargoType;
	endif;
	
	
	bBGenericsIsHidden := cargoType = null or cargoType.id &lt;&gt; TI_CargoType_BreakBulk and cargoType.classNameToCreate &lt;&gt; "CM_BreakBulkGeneric";
	
	self.tblDiameter.isHidden := bBGenericsIsHidden;
	self.txtGrade.isHidden := bBGenericsIsHidden;
	self.txtGrammage.isHidden := bBGenericsIsHidden;
	self.tblRollingLength.isHidden := bBGenericsIsHidden;
	
	defaultHidden:=cargoType = null or (not cargoType.isSystemCargoBOLType and not cargoType.isTrailer) or cargoType.id =TI_CargoType_Generator;
	self.tblWidth.isHidden:=defaultHidden ;
	self.txtWidthText.isHidden:=true;
	self.tblLength.isHidden:=defaultHidden;
	self.txtLengthText.isHidden:=true;
	self.tblHeight.isHidden:=defaultHidden;
	self.txtHeightText.isHidden:=true;
	self.tblWeight.isHidden:=cargoType = null or (not cargoType.isSystemCargoBOLType) or cargoType.id &lt;&gt; TI_CargoType_BreakBulk;
	self.tblVolume.isHidden:=cargoType = null or (not cargoType.isSystemCargoBOLType) or cargoType.id &lt;&gt; TI_CargoType_BreakBulk;
	self.cmbDimType.isHidden:=true;
	self.txtDimType.isHidden:=true;
	self.tblDensity.isHidden:=cargoType = null or (not cargoType.isSystemCargoBOLType) or cargoType.id &lt;&gt; TI_CargoType_BreakBulk;
	self.txtQuantity.isHidden:=true;	
	if _product = null then
		if not bBGenericsIsHidden then
			self.lblDimensions.isHidden := false;
			self.checkSectionState();
			self.doOpenCloseSection(self.lblDimensions, self.lblCargoDetails, self.btnDimensions, opening);
		else
			if  defaultHidden then
				self.lblDimensions.isHidden := true;
			endif;
			self.checkSectionState();
			self.doOpenCloseSection(self.lblDimensions, self.lblCargoDetails, self.btnDimensions, opening);
		endif;
		return;
	endif;
	if default  and self.existingCargoSubType = _product then
		default:=false;
	endif;
	create allProductAttributes transient;
	
	_product.getAllProductAttributes(allProductAttributes);
	self.lblDimensions.isHidden := true;
	foreach attr in allProductAttributes discreteLock do
		productAttr:=attr.CM_ProductAttr;
		control:=getControlForAttributeType(productAttr.name);
		if control = null then
			continue;
		endif;
		
		if (productAttr.name = ETRow_MyWeight ) and
		 cargoType &lt;&gt; null and not cargoType.isBreakBulk then
			control.isHidden:=true;
			continue;
		endif;
		if productAttr.name = ETRow_MyType then
			self.setDimTypeDetails(cargoType, _product, null);				// 19/11/2009 cnwmh5 PAR21492
			continue;
		endif;
		self.lblDimensions.isHidden := false;
		control.setMyCaption(productAttr.displayName);
		control.isHidden:=false;
		if default then
			if control.isKindOf(CMUI_FieldMeasureTable) then
				//19/06/2024	navrv30	Ticket 63877
				if productAttr.myMeasurementType = null then 
					measurementName := productAttr.getDefaultMeasurementName();
				else
					measurementName := productAttr.getMeasurementName(productAttr.myMeasurementType.measurementType);
				endif;
				control.CMUI_FieldMeasureTable.setValues(productAttr.getDisplayValueString  &amp; Space &amp; measurementName);  
			else
				control.setValue(productAttr.getDisplayValueString);
			endif;
		endif;
	
	endforeach;

	self.checkSectionState();
	self.doOpenCloseSection(self.lblDimensions, self.lblCargoDetails, self.btnDimensions, opening);
	
	// PAR #23190 show/hide default stuff according to cargo type
	//self.doHideShowProductAttributes(cargoType);
	
	/*
	return; 
	
	if _product.getMyWidth().getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.getMyWidth.name) then	// PAR #23190
		self.tblWidth.isHidden := false;												// PAR #31155
		self.tblWidth.setMyCaption (_product.getMyWidth.displayName);					// PAR #31155
		if default and _product.getMyWidth &lt;&gt; null then 
			self.tblWidth.setValues(_product.getMyWidth.getDisplayValueString &amp; Space &amp; _product.getMyWidth.getMeasurementName(Type_Width));	// PAR #31155
		endif;
	else
		self.tblWidth.isHidden := true;  												// PAR #31155
	endif;
	
	if _product.myWidthString.getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.myWidthString.name) then	// PAR #23190
		self.txtWidthText.isHidden := false;
		self.txtWidthText.setMyCaption (_product.myWidthString.displayName);	// par 22775
		if default then 
			self.txtWidthText.setValue(_product.myWidthString.getDisplayValueString);
		endif;
	else
		self.txtWidthText.isHidden := true;
	endif;

	if _product.getMyLength().getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.getMyLength.name) then	// PAR #23190
		self.tblLength.isHidden := false;												// PAR #31155
		self.tblLength.setMyCaption (_product.getMyLength.displayName);					// PAR #31155
		if default then 
			self.tblLength.setValues(_product.getMyLength.getDisplayValueString &amp; Space &amp; _product.getMyLength.getMeasurementName(Type_Length));	// PAR #31155
		endif;
	else
		self.tblLength.isHidden := true;												// PAR #31155
	endif;

	if _product.myLengthString.getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.myLengthString.name) then	// PAR #23190
		self.txtLengthText.isHidden := false;
		self.txtLengthText.setMyCaption (_product.myLengthString.displayName);	// par 22775
		if default then 
			self.txtLengthText.setValue(_product.myLengthString.getDisplayValueString);
		endif;
	else
		self.txtLengthText.isHidden := true;
	endif;

	if _product.getMyHeight().getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.getMyHeight().name) then	// PAR #23190
		self.tblHeight.isHidden := false;												// PAR #31155
		self.tblHeight.setMyCaption (_product.getMyHeight.displayName);					// PAR #31155
		if default then 
			self.tblHeight.setValues(_product.getMyHeight.getDisplayValueString &amp; Space &amp; _product.getMyHeight.getMeasurementName(Type_Height));	// PAR #31155
		endif;
	else
		self.tblHeight.isHidden := true;
	endif;

	if _product.myHeightString.getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.myHeightString.name) then	// PAR #23190
		self.txtHeightText.isHidden := false;
		self.txtHeightText.setMyCaption (_product.myHeightString.displayName);	// par 22775		
		if default then 
			self.txtHeightText.setValue(_product.myHeightString.getDisplayValueString);
		endif;
	else
		self.txtHeightText.isHidden := true;
	endif;

	self.setQuantityCaptionAndVisible(method.name,_product);	//03 Mar 2014	NDL	Par 33596

	if _product.isMyWeightViewable() and cargoType.allAttributesOnProduct.includes(_product.getMyWeight().name) then	// PAR #23190
		self.tblWeight.isHidden := false;												// PAR #31155
		self.tblWeight.setMyCaption (_product.getMyWeight.displayName);					// PAR #31155
		if default then 
			self.tblWeight.setValues(_product.getMyWeight.getDisplayValueString &amp; Space &amp; _product.getMyWeight.getMeasurementName(Type_Weight));	// PAR #31155
		endif;																		// PAR #31155
	else
		self.tblWeight.isHidden := true;												// PAR #31155
		//epr TFS 1707 6/4/16 total weight and volume don't belong here
			endif;		

	if _product.myVolume.getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.myVolume.name) then	// PAR #23190
		self.tblVolume.isHidden := false;												// PAR #31155
		self.tblVolume.setMyCaption (_product.myVolume.displayName);					// PAR #31155
		if default then 
			self.tblVolume.setValues(_product.myVolume.getDisplayValueString &amp; Space &amp; _product.myVolume.getMeasurementName(Type_Volume));	// PAR #31155
			self.autoCalcVolume();	//calculating from dimensions **
		endif;
	else
		self.tblVolume.isHidden := true;				// PAR #31155
	endif;		

	if _product.myType.getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.myType.name) then	// PAR #23190
		if _product.myType.validationType = _product.myType.ValidationType_Codes then
			self.cmbDimType.isHidden := false;
			self.txtDimType.isHidden := true;
		elseif _product.myType.validationType = _product.myType.ValidationType_Value then
			self.cmbDimType.isHidden := true;
			self.txtDimType.isHidden := false;
		endif;
		self.cmbDimType.setMyCaption (_product.myType.displayName);	// par 22775
		self.txtDimType.setMyCaption (_product.myType.displayName);	// par 22775
		if default then 
			self.cmbDimType.setValue(_product.myType.getDisplayValueString);
			self.txtDimType.setValue(_product.myType.getDisplayValueString);
		endif;
	else
		self.cmbDimType.isHidden := true;
		self.txtDimType.isHidden := true;	// PAR #23190 resubmit
	endif;

	if _product.myDensity.getIsViewable() and cargoType.allAttributesOnProduct.includes(_product.myDensity.name) then	// PAR #23190
		self.tblDensity.isHidden := false;												// PAR #31155
		self.tblDensity.setMyCaption (_product.myDensity.displayName);					// PAR #31155
		if default then 
			self.tblDensity.setValues(_product.myDensity.getDisplayValueString &amp; Space &amp; _product.myDensity.getMeasurementName(Type_Density));	// PAR #31155
		endif;
	else
		self.tblDensity.isHidden := true;												// PAR #31155
	endif;
	
	if self.tblWidth.isHidden and self.txtWidthText.isHidden and self.tblLength.isHidden and
	   self.txtLengthText.isHidden and self.tblHeight.isHidden and self.txtHeightText.isHidden and
	   self.txtQuantity.isHidden and self.tblWeight.isHidden and self.tblVolume.isHidden and
	   self.cmbDimType.isHidden and self.txtDimType.isHidden and self.tblDensity.isHidden then	// 23546 add txtDimType
		self.lblDimensions.isHidden := true;
	else
		self.lblDimensions.isHidden := false;
	endif;
	
	// PAR #23190 show/hide default stuff according to cargo type
	self.doHideShowProductAttributes(cargoType);
	*/
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doHideShowProductAttributes" id="912ae8af-0cca-4527-8b34-21ef630e8495">
        <updating/>
        <source>doHideShowProductAttributes(_cargoType : CM_CargoType) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2009	cnwdap1	#21658 For Trailer and Vehicle Cargo Types, show length/width/height dimensions fields
15/02/2010	cnwdap1	PAR #22088 For system cargo type Timber, show length, width and height text boxes 
					(this is a system cargo type nad has no products, but still have a requirement to capture some dimensions details)
15/03/2010	cnwdap1	Initial creation PAR #23190 refactoring
16/03/2010	cnwcs5	par 22726 - override labels for length, width, height for CM_Car
21/09/2011  cnwmh5 #28157 - remove clearing of length, width, and height as not required.
27/03/22013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin

	if _cargoType.productType = ProductType_Trailer or _cargoType.id = TI_CargoType_Container then	//16 Oct 2013	NDL	Par 32573
		self.cmbMTGrade.isHidden := false;
	else
		self.cmbMTGrade.isHidden := true;
	endif;
	
	
	//+cnwml2 MSL CCMS 1017
	if _cargoType.useTareCargoWeight then
		self.tblTareWeight.isHidden := false;								// PAR #31155
		self.tblNettWeight.isHidden := false;								// PAR #31155
	else
		self.tblTareWeight.isHidden := true;								// PAR #31155
		self.tblNettWeight.isHidden := true;								// PAR #31155
	endif;
	
	//epr 20/2/18 tfs 7756 all the dimension stuff is handled in doFilterProductAttributes
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doIMEXStatusChanged" id="f663b5d8-a621-49a2-9505-e0d57c61fdb3">
        <updating/>
        <source>doIMEXStatusChanged() protected,updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 June 2009	cnwjk3	Initial creation
12 Oct	2016	cnwma1	TFs #2636  Query on Tranship to Port visibility Prenote / Gate Screens

*/

vars
	imexStatus : CM_IMEXStatus;
begin
	self.doSetSubTerminal();		//+cnwml2 PAR24393
	self.initFieldsForEntDefName(self.currentEntTableDef, false);   // 12/10/2016 cnwma1 TFS #2636

epilog

