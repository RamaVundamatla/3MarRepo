    <JadeMethod name="checkCalculationTypes" id="3f16dcb1-e7c2-47b0-b422-0404c729645a">
        <source>checkCalculationTypes();
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars
	iter01 : Iterator;
	oArray : ObjectArray;
	theObj : CM_CalculationType;
	message : String;
	term : CM_Terminal;
begin
	create oArray transient;
	CM_CalculationType.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(theObj) do
		
		theObj.healthCheckIsValid(self);
		
	endwhile;
epilog
	delete oArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkInvoiceLineMappings" id="8c6c54ac-9be4-49db-bf88-1fa46c7de252">
        <source>checkInvoiceLineMappings();
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars


	iter01, iter02 : Iterator;
	qtyMap : CM_QuantityRangeMap;
	invline : CM_InvoiceLineDesc;
	oArray1, oArray2, oArray3 : ObjectArray;
	idx : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
	bu : CM_Bank;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	
	
	if not self.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_TranMapCargo) then
		return;
	endif;

	create oArray1 transient;
	create oArray3 transient;
	CM_QuantityRangeMap.allInstances(oArray1,0,false);
	iter01 := oArray1.createIterator;
	
	while iter01.next(qtyMap) do
		bu := qtyMap.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;

		// TFS 40620 foreach invline in qtyMap.allInvoiceLineMaps do
		foreach mapping in qtyMap.allTMInvoiceLineMappings do // TFS 40620
			invline := mapping.myTMInvoiceLineDesc; // TFS 40620
		
		
			if not oArray3.includes(invline) then
				oArray3.add(invline);
			endif;
			
		endforeach;
	endwhile;
	
	create oArray2 transient;
	CM_InvoiceLineDesc.allInstances(oArray2,0,false);
	iter02 := oArray2.createIterator;

	

	while iter02.next(invline) do
		bu := invline.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
		if not oArray3.includes(invline) then
			
			create detail transient;
			detail.setForCreate(self, CMIF_InvoiceHealthAgent.CheckType_TranMapCargo, invline.narration, CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType, invline.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_None, invline);

		endif;
	endwhile;

	
	
epilog
	delete oArray1;
	delete oArray3;
	delete iter01;
	delete oArray2;
	delete iter02;

end;</source>
    </JadeMethod>
    <JadeMethod name="checkInvoiceLineTypes" id="b8ca8499-8b00-43fa-9cec-933b63249ea6">
        <source>checkInvoiceLineTypes();
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars
	iter01 : Iterator;
	oArray : ObjectArray;
	theObj : CM_InvoiceLineDesc;
	message : String;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	create oArray transient;
	CM_InvoiceLineDesc.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(theObj) do
		bu := theObj.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
			
		theObj.healthCheckIsValid(self);
		
	endwhile;
epilog
	delete oArray;
end;</source>
    </JadeMethod>
