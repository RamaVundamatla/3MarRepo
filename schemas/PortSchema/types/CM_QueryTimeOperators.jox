<Class name="CM_QueryTimeOperators" id="a7ad7f9a-6a53-41c2-88b7-1894a11e77c2">
    <superclass name="CM_QueryOperator"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="query"/>
    <PrimAttribute name="searchValue" id="d142c07e-b149-4509-90bb-26e364010594">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getSearchValue" id="6472801a-4c29-479f-a861-da778ae41cf0">
        <source>getSearchValue(): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	return self.searchValue;

epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="ef3ce03b-82fd-4c3d-8245-c9641be560c2">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	return _prop.translateToDisplayValue(self.searchValue);

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="3b6904bb-c2c9-4bc5-81eb-31ce8b26b795">
        <updating/>
        <source>setSearchValue(_value: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	self.searchValue := null;
	if _value &lt;&gt; null and (_value.isKindOf(Time) or _value.isKindOf(String)) then // par 18123
		self.searchValue := _value.Time;
		if not self.searchValue.isValid() then
			app.raiseCMException1( Invalid_time_expect_format, "hh:mm", null, self );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
