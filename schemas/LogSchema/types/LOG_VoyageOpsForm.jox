    <JadeMethod name="initTblOrderData" id="f0bda982-2aba-47c2-88c3-5565c6958af4">
        <updating/>
        <source>initTblOrderData() updating;
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
// 09/02/2011	cnwcs5	CCMS JML 1114 / PAR 26847 - allow multiselect
vars
	entTableDef : EntTableDef;
	table		: CM_DataTable;									// 09/02/2011 cnwcs5 CCMS JML 1114
begin
	self.optDetails.value 			:= true;
	
	// use local variable - it is faster
	table 					:= self.tblOrderData;				// 09/02/2011 cnwcs5 CCMS JML 1114
	table.stretchToParent 	:= true;
	table.userInputEnabled 	:= false;
	table.selectMode 		:= Table.SelectMode_None;			// 09/02/2011 cnwcs5 CCMS JML 1114
	table.selectionType		:= CM_BaseTable.SelectionType_Row;	// 09/02/2011 cnwcs5 CCMS JML 1114
	table.multiSelect		:= CM_BaseTable.MultiSelect_None;	// 09/02/2011 cnwcs5 CCMS JML 1114
	table.showFocus			:= false;							// 09/02/2011 cnwcs5 CCMS JML 1114;
	table.autoSize 			:= Table.AutoSize_Column;
	table.rows 				:= table.fixedRows;
	
	table.cnEcResizeContents();
	table.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	
	entTableDef := app.myController.getEntTableDef(ETDef_TblOrderData);
	
	table.setTblDataEntRowsFromDef(entTableDef);

	table.accessColumn(table.getColumnByRowName(ETRow_ReqdQuantity)).alignment := Table.Alignment_Right;
	table.accessColumn(table.getColumnByRowName(ETRow_AllocVolume)).alignment := Table.Alignment_Right;	
	table.resortTableByColumn(table.getColumnByRowName(ETRow_MyLogLot));
	
	table.readOnly := false;	
end;</source>
    </JadeMethod>
