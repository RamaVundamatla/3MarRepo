    <JadeMethod name="sendTelegram" id="e8bd2183-0837-4e34-a235-1f9d313a1ec8">
        <source>sendTelegram(_telegram:Binary);

vars

begin
	if self.myTcpMsg &lt;&gt; null and
	   self.connected then
		self.myTcpMsg.cnWrite(_telegram, self.myTcpMsg);
	else
		self.staMain.caption := "Disconnected. Write failed.";
	endif;
end;</source>
        <Parameter name="_telegram" type="Binary"/>
    </JadeMethod>
