    <JadeMethod name="getDisplayRowColour" id="f463bd53-1ad5-403d-b7df-98a89625d396">
        <source>getDisplayRowColour(): Integer;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myUserTISnapShot = null then
		return null;
	elseif self.myUserTISnapShot.ignore then
		return Grey;
	elseif self.myVoyage &lt;&gt; null then
		return PaleGreen;
	else
		return PaleYellow;	
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4c8c53af-3239-495d-9788-bbf3457544b3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sts	: CM_CargoStatus;
	ct	: CM_CargoType;
begin
	
	if self.myUserTISnapShot &lt;&gt; null then
		return self.myUserTISnapShot.getDisplayStringForAttribute(_attrName, _short);
	endif;
	
	if _attrName = ETRow_DestinationPortDescr then // TFS 40336
		return self.destinationPortDescription; // TFS 40336
	elseif _attrName = ETRow_CargoSubtypeDescr then // TFS 40336
		return self.cargoSubtypeDescription; // TFS 40336
	elseif _attrName = ETRow_DischargePortDescr then // TFS 40336
		return self.dischargePortDescription; // TFS 40336
	elseif _attrName = ETRow_Type then
	//global.processDebug('CNWJC2',true);
		if self.typeAttributes.bitAnd(ISO_REEFER) &lt;&gt; 0 then
			return CMIF_CandHRpt.ISO_Reefer;
		elseif self.typeAttributes.bitAnd(ISO_GENERAL) &lt;&gt; 0 then
			return CMIF_CandHRpt.ISO_General;
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsTranship then
		return self.isTransship.String;
	elseif _attrName = ETRow_ContentsStatus then
		sts := app.myRoot.allContentsStatuses[self.contentsStatus];
		if sts &lt;&gt; null then
			return sts.description;
		else
			return "Unknown";
		endif;
	elseif _attrName = ETRow_ImExStatus then
		sts := app.myRoot.allImexStatuses[self.imExStatus];
		if sts &lt;&gt; null then
			return sts.abbreviation;
		else
			return "Unknown";
		endif;
	elseif _attrName = ETRow_TransitStatus then
		sts := app.myRoot.allTransitStatuses[self.transitStatus];
		if sts &lt;&gt; null then
			return sts.description;
		else
			return "Unknown";
		endif;
	elseif _attrName = ETRow_CargoType then
		ct := app.myRoot.allCargoTypesById[self.cargoType];
		if ct &lt;&gt; null then
			return ct.description;
		else
			return "Unknown";
		endif;
	elseif _attrName = ETRow_Ignore then
		return false.String;
	elseif _attrName = ETRow_LastChangedBy then
		return null;
	elseif _attrName = ETRow_LastChangedDT then
		return null;
	elseif _attrName = ETRow_ChangeReason then
		return null;
	elseif _attrName = ETRow_Size then
		if self.is40 then
			return "40'";
		else
			return "20'";
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExchangeStats" id="87f303dc-02df-4e99-8fa3-ca88665474a0">
        <source>getExchangeStats(_aCandHRpt : CMIF_CandHRpt input);
//----------------------------------------------------------------
//	Created:	21 July 2005	by Jason Chapman  (cnwjc2)
//
//
//	The order in which the snap shot is evaluated is important.  Do not change without first checking the effects.
//
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 03/11/2010	cnwdap1		PAR #26146 Correct tranship handling
// 08/07/2011	cnwjre1		Par 27781 use discharge port for tranships and export voyage
vars
	tmpShippingLine 		: CM_ShippingLine;
	tmpDebtor 				: CM_DebtorNode;
	tmpShipPortGroup 		: CM_ShipPortGroup;

	lgd						: CM_LineGroupDebtor;
	port					: CM_Port;
	shipPort				: CM_ShipPort;
	str						: String;
	tmpOperator				: CM_Operator;
	summaryTLG				: CMIF_CandHTradeLineGeo;
	tmpVoyage				: CM_Voyage;
	errType,
	portCode				: String;
	hasError				: Boolean;
	tmpTI					: CM_TrackedItem;	// PAR #26146

begin

if _aCandHRpt.usePRE_CCMS1468 then
	self.getExchangeStatsOLD(_aCandHRpt);
	return;
endif;

	if self.myUserTISnapShot &lt;&gt; null then
		self.myUserTISnapShot.getExchangeStats(_aCandHRpt);	
		return;
	endif;

	tmpVoyage := _aCandHRpt.myVoyage;
	tmpOperator := self.getCandHOperator(_aCandHRpt.useOrginialLDG);
	
	on Exception do app.handleDeletedObject(exception, tmpTI, hasError);	//cnwas3 par 27703
	// PAR #26146 get TI
	tmpTI := self.myTrackedItem;
	
	/*
	if _aCandHRpt.useOrginialLDG
	and CM_UserTISnapShot.hasInstance(self) then
		tmpOperator := app.myRoot.allOperators[self.CM_UserTISnapShot.myTISnapShot.operatorCode];
	else
		tmpOperator := app.myRoot.allOperators[self.operatorCode];
	endif;
	*/

	if _aCandHRpt.myOperator &lt;&gt; null and
	   _aCandHRpt.myOperator &lt;&gt; tmpOperator then
		return;	
	endif;

	if self.imExStatus = TI_IMEX_STATUS_IMPORT or
	   self.imExStatus = TI_IMEX_STATUS_EXPORT or
	   self.imExStatus = TI_IMEX_STATUS_TRANSHIP or		// PAR #23645 CCMS 1116
	   self.imExStatus = TI_IMEX_STATUS_STORAGE then
	
		// refer also method getCandHShippingLine
		tmpShippingLine := tmpVoyage.myShippingLine;
		// refer also method getCandHDebtor
		if tmpOperator &lt;&gt; null then
			tmpDebtor := tmpOperator.debtor;
		endif;

		if self.imExStatus = TI_IMEX_STATUS_IMPORT then
			errType := 'Imp';
			portCode := self.loadPort;
		elseif self.imExStatus = TI_IMEX_STATUS_EXPORT then 	// PAR #26146 or self.imExStatus = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
			errType := 'Exp';
			portCode := self.dischargePort;
		// PAR #26146 split out tranships in to separate process
		elseif self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
			errType := 'Tsh';
			/* par 27781 cnwjre1 July 2011 should use dischargePort for exports - prior code
			if tmpTI &lt;&gt; null and tmpTI.loadPort &lt;&gt; null then	//cnwas3 par 27703
				portCode := tmpTI.loadPort;
				//if tmpTI.myImportVoyage = _aCandHRpt.myVoyage then
				//cnwjo3 par 26358.  In the scenario where a tranship item
				//is received from ship (discharge) but then the user
				//sets the TI to a non-tranship item we need to verify that
				//the tmpTI is still a tranship item.  if not we can rely on loadPort
				if tmpTI.isTranshipItem and tmpTI.myImportVoyage = _aCandHRpt.myVoyage then
					portCode := tmpTI.myTranshipDetail.importOriginalLoadPort;
				endif;
			else
				portCode := self.loadPort;				//cnwas3 par 27703
			endif;
			*/
			// 27781 new code as in getCandHShipPortGroup, retaining 26358 (no longer a tranship) and 27703 (null self.myTrackedItem) changes
			if tmpTI &lt;&gt; null and
			   tmpTI.isTranshipItem then
				if tmpTI.myImportVoyage = tmpVoyage then
					if tmpTI.myTranshipDetail &lt;&gt; null then
						portCode := tmpTI.myTranshipDetail.importOriginalLoadPort;
					endif;
					if portCode = null then
						portCode := tmpTI.loadPort;
					endif;
				elseif tmpTI.myExportVoyage = tmpVoyage then
					portCode := self.dischargePort;
				endif;
			endif;
			if portCode = null then
				portCode := self.loadPort;
			endif;
		// PAR #26146 and now 27781 end
		elseif self.imExStatus = TI_IMEX_STATUS_STORAGE then
			errType := 'Sto';
			portCode := self.loadPort;
		endif;
		
		if tmpOperator = null then
			_aCandHRpt.addError("Excluded: " &amp; id &amp; " (" &amp; errType &amp; 
				") Operator (" &amp; self.getCandHOperatorCode(_aCandHRpt.useOrginialLDG) &amp; 
				") not found");
		endif;
		
		port := app.myRoot.allPorts[portCode];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				// refer also method getCandHShipPortGroup
				tmpShipPortGroup := shipPort.shipPortGroup;
			else
				_aCandHRpt.addError("Note: " &amp; id &amp; " (" &amp; errType &amp; ") Port not in group: " &amp; portCode);
			endif;
		else
			_aCandHRpt.addError("Note: " &amp; id &amp; " (" &amp; errType &amp; ") Invalid port: " &amp; portCode);
		endif;

	elseif self.transitStatus = TI_TransitStatusSOB or
	   self.transitStatus = TI_TransitStatusDLR then
		lgd := tmpVoyage.myDefaultLineGroupDebtor;
		// refer also method getCandHShippingLine
		tmpShippingLine := lgd.shipPortGroup.shippingLine;
		// refer also method getCandHSDebtor
		tmpDebtor := lgd.debtor;
		// refer also method getCandHShipPortGroup
		tmpShipPortGroup := lgd.shipPortGroup;
		
	elseif (imExStatus = TI_IMEX_STATUS_REMAINONBOARD) then
		return;
	endif;

	if tmpShippingLine = null then
		hasError := true;
		_aCandHRpt.addError("Excluded: " &amp; id &amp; " (" &amp; errType &amp; ") Shipping line not found");
	endif;
	if tmpDebtor = null then
		hasError := true;
		_aCandHRpt.addError("Excluded: " &amp; id &amp; " (" &amp; errType &amp; ") Debtor not found");
	endif;
	
	if hasError then
		return;
	endif;

	summaryTLG := _aCandHRpt.getSummaryTLG(tmpShippingLine, tmpDebtor, tmpShipPortGroup, true);

	//all done in here now
	summaryTLG.setItemFromSnap(self);
	
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExchangeStatsOLD" id="12795003-1d03-4cf0-b946-e24723e20bd0">
        <source>getExchangeStatsOLD(_aCandHRpt : CMIF_CandHRpt input);
//----------------------------------------------------------------
//	Created:	21 July 2005	by Jason Chapman  (cnwjc2)
//
//	The order in which the snap shot is evaluated is important.  Do not change without first checking the effects.
//----------------------------------------------------------------

// PRE CCMS 1468 Version
// 07/06/2010	cnwdap1		CCMS 1116 Tranship changes

vars
	lgd						: CM_LineGroupDebtor;
	terminal				: CM_Terminal;
	port					: CM_Port;
	shipPort				: CM_ShipPort;
	spg						: CM_ShipPortGroup;
	str						: String;
	operator				: CM_Operator;
	slCode,
	spgCode					: String;
	summaryTLG				: CMIF_CandHTradeLineGeo;
	tmpVoyage				: CM_Voyage;
	tmpCandHReport			: CMIF_CandHRpt;
begin

	if self.myUserTISnapShot &lt;&gt; null then
		self.myUserTISnapShot.getExchangeStats(_aCandHRpt);	
		return;
	endif;

	tmpCandHReport := _aCandHRpt;
	tmpVoyage := tmpCandHReport.myVoyage;
	terminal := self.myTerminal;
	if _aCandHRpt.useOrginialLDG
	and CM_UserTISnapShot.hasInstance(self) then
		operator := app.myRoot.allOperators[self.CM_UserTISnapShot.myTISnapShot.operatorCode];
	else
		operator := app.myRoot.allOperators[self.operatorCode];
	endif;

	if tmpCandHReport.myOperator &lt;&gt; null
	and  tmpCandHReport.myOperator &lt;&gt; operator then
		return;	
	endif;

	if self.transitStatus = TI_TransitStatusSOB then
		lgd := tmpVoyage.myDefaultLineGroupDebtor;
		
	elseif self.transitStatus = TI_TransitStatusDLR then
		lgd := tmpVoyage.myDefaultLineGroupDebtor;
		
	elseif self.imExStatus = TI_IMEX_STATUS_IMPORT then
		//port := app.myRoot.allPorts[self.loadPort];
		port := app.myRoot.allPorts[self.loadPort];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				spg := shipPort.shipPortGroup;
				if spg &lt;&gt; null then
					//changed was assuming the codes were all 3 chars
					slCode := spg.shippingLine.code.trimBlanks &amp; " ";
					spgCode := spg.code.trimBlanks &amp; " ";
					
					str := slCode &amp; spgCode &amp; operator.debtor.name;
					lgd := spg.lineGroupDebtors[str];
				else
				//PAR 2677 Prevent string too long errors by using new addError method. Also
				//make the messages themselves shorter. errorString is only 640 chars long
					tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Imp) No shipping port group");
				endif;
			else
				tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Imp) Invalid port: " &amp; self.loadPort);
			endif;
		else
			tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Imp) Invalid port: " &amp; self.loadPort);
		endif;
	elseif self.imExStatus = TI_IMEX_STATUS_EXPORT or self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
		//port := app.myRoot.allPorts[self.dischargePort];
		port := app.myRoot.allPorts[self.dischargePort];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				spg := shipPort.shipPortGroup;
				if spg &lt;&gt; null then
					//changed was assuming the codes were all 3 chars
					slCode := spg.shippingLine.code.trimBlanks &amp; " ";
					spgCode := spg.code.trimBlanks &amp; " ";
					str := slCode &amp; spgCode &amp; operator.debtor.name;
					lgd := spg.lineGroupDebtors[str];
				else
				//PAR 2677 Prevent string too long errors by using new addError method.
					tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Exp) No shipping port group");
				endif;
			else
				tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Exp) Invalid port: " &amp; self.dischargePort);
			endif;
		else
			tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Exp) Invalid port: " &amp; self.dischargePort);
		endif;
	elseif (imExStatus = TI_IMEX_STATUS_REMAINONBOARD) then
		return;
	elseif (imExStatus = TI_IMEX_STATUS_STORAGE) then
		//port := app.myRoot.allPorts[self.loadPort];
		port := app.myRoot.allPorts[self.loadPort];
		if port &lt;&gt; null then
			shipPort := port.shippingPorts[tmpVoyage.myShippingLine.code];
			if shipPort &lt;&gt; null then
				spg := shipPort.shipPortGroup;
				if spg &lt;&gt; null then
					//changed was assuming the codes were all 3 chars
					slCode := spg.shippingLine.code.trimBlanks &amp; " ";
					spgCode := spg.code.trimBlanks &amp; " ";
					str := slCode &amp; spgCode &amp; operator.debtor.name;
					lgd := spg.lineGroupDebtors[str];
				else
				//PAR 2677 Prevent string too long errors by using new addError method. Also
				//make the messages themselves shorter. errorString is only 640 chars long
					tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Sto) No shipping port group");
				endif;
			else
				tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Sto) Invalid port: " &amp; self.loadPort);
			endif;
		else
			tmpCandHReport.addError("Excluded: " &amp; id &amp; " (Sto) Invalid port: " &amp; self.loadPort);
		endif;
	endif;

	if lgd = null then
		tmpCandHReport.addError("Excluded: " &amp; id &amp; " No Line Group Debtor: " &amp; str &amp; ".  Check the line's Port Groups.");
		return;
	endif;
	
	summaryTLG := _aCandHRpt.getSummaryTLGfromLGD(lgd, true);

	//all done in here now
	summaryTLG.setItemFromSnapOLD(self);
	
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
    </JadeMethod>
