    <JadeMethod name="findEntryForTIorRegNum" id="af652192-6233-4120-827c-6a4099cfb401">
        <source>findEntryForTIorRegNum(	_search, _twinSearch : String;
						_machine : CM_Machine;
						_maxEntries : Integer;
						_allFoundRTQEntries : CM_RTQueueEntryArray input );
/*

Purpose:	used by the RT app for searching tries to location a ti matching either
			ti string passed in.
			
			- the first string can be a reg number also so finds those entries where the source or 
			target is a truck and reg number matches the string

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	iter 		: Iterator;
	qEntry 		: CM_RTQueueEntry;
	rtQueueTask : CM_RTQueueTask;
begin

	iter:= self.allEntries.createIterator;
	while iter.next(qEntry) do
		
		if _maxEntries &gt; 1 and _allFoundRTQEntries.size = _maxEntries then
			break;
		endif;
		rtQueueTask:=qEntry.getFirstUncompletedTask;
		if rtQueueTask = null then
			continue;
		endif;	
		//epr CCMS 1391 reactored code block into method on rtqueue entry
		if not rtQueueTask.matchesTIorRegNum(_search, _twinSearch,_machine) then
			continue;
		endif;
	
		_allFoundRTQEntries.add( qEntry);			
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_search" type="String"/>
        <Parameter name="_twinSearch" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_maxEntries" type="Integer"/>
        <Parameter name="_allFoundRTQEntries" type="CM_RTQueueEntryArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getATaskForMachine" id="dca688e8-e5f2-4879-a2dd-b6aa0ab6afd5">
        <source>getATaskForMachine(task : CM_RTQueueTask io; mach : CM_Machine; _messageLogger : CM_MachineRTQueueEntryLogger input);
//Called from the machine, we check our entries for a suitable task..
//If we cannot find one, then ask our children, and its children...
//The queues are HIERARCHICAL, we search from current Queue DOWN, as the
//machine has exposure to everything below its current queue.

/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	entry				: CM_RTQueueEntry;
	subQ				: CM_RadioTelemetryQueue;
	iter				: Iterator;
	pLC					: CM_LocationsController;
	ti 					: CM_TrackedItem;
	allQueuesOrdered	: CM_RTQueueEntryArray;
	lastTA				: CM_TerminalArea;
begin

	// CCMS 1310
	
	lastTA := mach.myLastTA;
	create allQueuesOrdered transient;
	if self.doesQueueOrderNeedManipulating(lastTA) then
		
		if self.orderQueueEntriesByPriority(allQueuesOrdered, lastTA) then
			
		else
			//was getting a  1308  exception because if RT Queue Entry getATaskForMachine set up for auto overstow tasks using yard allocations if this adds
			// a new o/s entry to this queue which will then get a 1308 exception
			self.allEntries.copy(allQueuesOrdered);
			//iter := self.allEntries.createIterator();	
		endif;
	else
		self.allEntries.copy(allQueuesOrdered);
		//iter := self.allEntries.createIterator();	
	endif;
	iter := allQueuesOrdered.createIterator();
	
	while iter.next(entry) do
		if not tryLock(entry, Reserve_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			//Locked by someone else.. continue
			continue;
		endif;
		// Added DVB 29/05/03
		if entry.isMultiQueueEntry() then
			// Have to manually ask for this.
			continue;
		endif;
		ti := entry.myWorkListEntry.myTrackedItem;

		if ti &lt;&gt; null then
			pLC := ti.getPrimaryLocation(REAL_MODE);
			if pLC &lt;&gt; null and pLC.isKindOf(CM_SlotController) then
				//entry.myWorkListEntry.myTrackedItem.getPrimaryLocation(REAL_MODE).isKindOf(CM_SlotController) then
				// We do not want discharge jobs to be automatically assigned.
				unlock(entry);
				continue;
			endif;
		endif;
		entry.getATaskForMachine(task, mach,null,null, _messageLogger);
		if task &lt;&gt; null then 
			//Found one!
			exclusiveLock(task.myEntry);
			return;
		endif;
		
		//This is not us! Carry on..
		unlock(entry);
	endwhile;
	delete iter;
	//----------------
	//Ask children queues for a task (if they have any)
	//----------------
	mach.addLogEntry("No available tasks in Queue " &amp; id.trimRight &amp; " checking sub-queues..");
	iter := self.allSubQueuesByOrder.createIterator;
	while iter.next( subQ) do
		//epr 11/3/09 removed can be worked test there are no longer system defined queues this effectively always returned true since 7.7.3
	
		if not subQ.compareQueueToType(mach.getMachineTypeGroup) then
			continue;
		endif;
		mach.addLogEntry("Testing sub-Queue " &amp; subQ.id.trimRight );
		subQ.getATaskForMachine(task, mach, _messageLogger);
		if task &lt;&gt; null then 
			return;
		endif;
	endwhile;
epilog
	delete iter;
	delete allQueuesOrdered;
end;</source>
        <Parameter name="task" type="CM_RTQueueTask" usage="io"/>
        <Parameter name="mach" type="CM_Machine"/>
        <Parameter name="_messageLogger" type="CM_MachineRTQueueEntryLogger" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllEntries" id="78cdabea-e163-44e1-a426-33bd4cec6473">
        <source>getAllEntries(_entries: CM_RTQueueEntryArray io);
//Returns ALL entries in the queue and all of its subQueues called on. Can be called on the 
//appropriate queue.
vars
	queue	 : CM_RadioTelemetryQueue;
begin
	//--------------
	//Copy my entries' tasks first
	//--------------
	self.allEntries.copy(_entries);
	//--------------
	//Get all sub-queues of this queue's entries
	//--------------
	foreach queue in self.allSubQueuesById do
		queue.getAllEntries(_entries);	// Need to recurse so we get all entries in subqueues
	endforeach;		
end;</source>
        <Parameter name="_entries" type="CM_RTQueueEntryArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllMachines" id="4dc9285c-875b-452c-ad84-43ce0e89df1a">
        <source>getAllMachines(_machines : CM_MachineByIdDict input; _secondary, _showInherited, _includeCranes : Boolean);

// cnwdvb1 03 June 2003 
/*

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
	3/7/08		EPR			Par 17526 added parameter _inlcludeCranes should be able to see them on the YRD_QueuesForm
*/
vars

	machine : CM_Machine;

begin
	//17/08/2011 cnwdz2 27747
	/*
	if self.myParentQueue &lt;&gt; null and _showInherited then
		self.myParentQueue.getAllMachines(_machines, _secondary, _showInherited,_includeCranes);
	endif;
	*/
	if _showInherited then
		self.getMachinesForInheritedQueue(_machines, _includeCranes);
	endif;
	self.getPrimaryMachines(_machines, false,_includeCranes);
	if _secondary then
		self.getSecondaryMachines(_machines);
	endif;

end;</source>
        <Parameter name="_machines" type="CM_MachineByIdDict" usage="input"/>
        <Parameter name="_secondary" type="Boolean"/>
        <Parameter name="_showInherited" type="Boolean"/>
        <Parameter name="_includeCranes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllQueues" id="c0cd9d55-d687-4c75-9125-ea6a5c27e587">
        <source>getAllQueues(queuesToReturn	:	Collection	input);
//Recursive call to retrieve all the queues in the system. Initially called on masterQueue
//it traverses down, adding all queues to the array.
vars
	rtQ	:	CM_RadioTelemetryQueue;
begin
	queuesToReturn.add(self);	
	foreach rtQ in self.allSubQueuesByOrder do
		rtQ.getAllQueues(queuesToReturn);
	endforeach;	
end;</source>
        <Parameter name="queuesToReturn" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllQueuesForMachineTA" id="e6de2e6e-6f53-4bbf-937d-c31e4a852828">
        <source>getAllQueuesForMachineTA(	_machine : CM_Machine input;
							_queues : Collection input);

/* Changes

Date		Name	TFS#		Description
============================================================================
01/05/2024	jlika1	TFS 63914 	CUX | Vehicle App - Enable driver to switch to Master Queue from a sub-queue
============================================================================*/
vars
	subQueue : CM_RadioTelemetryQueue;
	machineType : CM_MachineType;
	ta : CM_TerminalAreaMaster;
	addSelf : Boolean;
begin

	machineType:=_machine.getMachineType;
	addSelf:=true;
		
	//epr epr par 25838 28/9/10
	//only imvs can work voyage queues there is no rt from voyage cranes i.e. they're not part of the terminal
	/*if addSelf and (self.isKindOf(CM_VoyageQueue) and machineType.type &lt;&gt; MACHINETYPE_IMV) then
		addSelf:=false;
	endif;*/
	
	if addSelf and (self.isKindOf(CM_VoyageQueue) and (machineType.type = MACHINETYPE_RTG or  machineType.type = MACHINETYPE_RMG)) then
		addSelf:=false;
	endif;
	
	
	if addSelf and (not  self.compareQueueToType(machineType.myMachineTypeGroup)) then
		addSelf:=false;
	endif;	
	
	//epr 11/3/09 removed can be worked test there are no longer system defined queues this effectively always returned true since 7.7.3
	
	if addSelf then
		foreach ta in _machine.allowedTAMasters discreteLock do
			if self.isKindOf(CM_SubQueue) then
				if self.CM_SubQueue.allMoveFromTAMasters.size &gt; 0 and not self.CM_SubQueue.allMoveFromTAMasters.includes(ta) then
					continue;
				endif;
			endif;
			if not _queues.includes(self) then
				_queues.add(self);
				break;
			endif;		
		endforeach;
	endif;
	
	
	foreach subQueue in self.allSubQueuesByOrder discreteLock do
		subQueue.getAllQueuesForMachineTA(_machine, _queues);
	endforeach;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_queues" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllQueuesForMachineType" id="08218705-ac49-405a-8f30-d468eedb1668">
        <source>getAllQueuesForMachineType(	_machineType : Integer;
							_queuesToReturn	:	CM_RTQueueArray	io);
/*

Purpose:		RTG Machines can only work RTG lane rt queues while
				any other type of machine can't work RTG lane queues


Return Value:		


Date		Who		Reason
18 October 2006	cnwer1	Initial creation - PAR#12766

*/
vars

	rtQ	:	CM_RadioTelemetryQueue;
begin
	if (_machineType &lt;&gt; MACHINETYPE_RTG and not self.queueType = QTYPE_RTG) or
		(_machineType &lt;&gt; MACHINETYPE_RMG and not self.queueType = QTYPE_RTG) then
		_queuesToReturn.add(self);
	endif;
	
	foreach rtQ in self.allSubQueuesByOrder do
		rtQ.getAllQueuesForMachineType(_machineType,_queuesToReturn);
	endforeach;	
epilog

end;</source>
        <Parameter name="_machineType" type="Integer"/>
        <Parameter name="_queuesToReturn" type="CM_RTQueueArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllQueuesForMove" id="d905f180-789d-4748-8bb2-a43af6c18b73">
        <source>getAllQueuesForMove(_fromArea : CM_TerminalAreaMaster  input; _toArea : CM_TerminalAreaMaster  input; 
							_queues : Collection input);

/*

Purpose:			
Return a list of RT (sub) queues that can acces the from TA (if given) and the to Ta (if given).

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2009	cnwrd1	Initial creation

*/

vars
	subQueue : CM_RadioTelemetryQueue;
	ta : CM_TerminalAreaMaster;
	addSelf : Boolean;
begin

	addSelf:=true;
	
	if addSelf and self.isKindOf(CM_MasterQueue) then
		addSelf:=false;
	endif;
		
	//only imvs can work voyage queues there is no rt from voyage cranes i.e. they're not part of the terminal
	if addSelf and self.isKindOf(CM_VoyageQueue) then
		addSelf:=false;
	endif;
	
	//epr 11/3/09 removed can be worked test there are no longer system defined queues this effectively always returned true since 7.7.3
	
	if addSelf then
			
			addSelf := false; //+ cnwmd1 Par 25639
			
			if self.isKindOf(CM_SubQueue) then			
				if _fromArea &lt;&gt; null then
					//if not self.CM_SubQueue.allMoveFromTAMasters.includesObject ( _fromArea ) then  	//- cnwmd1 Par 25639
					if self.CM_SubQueue.allMoveFromTAMasters.includesObject ( _fromArea ) then  		//+ cnwmd1 Par 25639
						//addSelf := false; 	//- cnwmd1, Par 25639
						addSelf := true; 		//+ cnwmd1 Par 25639
					endif;
				endif;
				
				if _toArea &lt;&gt; null then
					//if not self.CM_SubQueue.allMoveToTAMasters.includesObject ( _toArea ) then  		//- cnwmd1 Par 25639
					if self.CM_SubQueue.allMoveToTAMasters.includesObject ( _toArea ) then  			//+ cnwmd1 Par 
						//addSelf := false;		//- cnwmd1, Par 25639
						addSelf := true;		//+ cnwmd1 Par 25639
					endif;
				endif;
			
			if addSelf then
				if not _queues.includes(self) then
					_queues.add(self);		
				endif;		
			endif;
		endif;
	endif;
	
	
	foreach subQueue in self.allSubQueuesByOrder discreteLock do
		subQueue.getAllQueuesForMove(_fromArea, _toArea, _queues);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_fromArea" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_toArea" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_queues" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTasks" id="393e2614-61d0-4576-8197-b5b702fac0fa">
        <source>getAllTasks(tasks	: CM_RTQueueTaskArray io);
//Returns ALL tasks in the queue and all of its subQueues called on. Can be called on the 
//appropriate queue.
vars
	entry	:	CM_RTQueueEntry;
	queue	 : CM_RadioTelemetryQueue;
begin
	//--------------
	//Copy my entries' tasks first
	//--------------
	//foreach entry in self.allEntries do
	foreach entry in self.allEntries discreteLock do	//15 Feb 2011	NDL	Par 26994
		entry.allTasks.copy(tasks);
	endforeach;
	//--------------
	//Get all sub-queues of this queue's entries
	//--------------
	foreach queue in self.allSubQueuesById do
		queue.getAllTasks(tasks);	// Need to recurse so we get all tasks in subqueues
//		foreach entry in queue.allEntries do		
//			entry.allTasks.copy(tasks);
//		endforeach;
	endforeach;		
end;</source>
        <Parameter name="tasks" type="CM_RTQueueTaskArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="00bd1f5c-9c26-4de1-980f-bd43ef59032c">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     June 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt				: String;
	tmpStr			: String;
	subQueue		: CM_SubQueue;
	machineGroup	: Integer;
	yController		: CM_LocationsController;
	
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	tmpStr := null;

// ---------------------------------------------------------------------------
//			This section is Audit for RT Queue Maintenance screen   
// ---------------------------------------------------------------------------
	//  SUB QUEUE
	if self.isKindOf(CM_SubQueue) then
		
		subQueue := self.CM_SubQueue;
		
		foreach machineGroup in subQueue.allAllowedMachineTypeGroups do				
			if tmpStr = null then			
				tmpStr := machineGroup.String;		
			else	
				tmpStr := tmpStr &amp;', ' &amp; machineGroup.String;
			endif;	
		endforeach;		
		txt := txt &amp; 'machineGroups' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
		tmpStr:=null;		
		
	endif;

/*	foreach tug in allTugs do		
		if tmpStr = null then	
			tmpStr := tug.code;
		else	
			tmpStr := tmpStr &amp;', ' &amp; tug.code;
		endif;	
	endforeach;		
	txt := txt &amp; 'Tugs' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
	tmpStr:=null;		
*/	
	
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
