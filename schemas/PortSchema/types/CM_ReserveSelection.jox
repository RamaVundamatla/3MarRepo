    <JadeMethod name="getMyCommodityCriteria" id="7240972d-a3c5-4a6a-8b2d-6bf635cea05a">
        <source>getMyCommodityCriteria() : CM_StringArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navmk20	Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info

*/
vars
	iter 			: Iterator;
	criteria 		: CM_YACriteria;
	myYaData		: CM_YAData;
	commodity 		: Object; 
	commodityCode 	: String;
	commodityCodeArray : CM_StringArray;

begin
	
	if self.myReleaseCriteria = null then
		return null;
	endif;
	
	create commodityCodeArray transient; //22/04/2024 NAVKC1 Transient leak
	
	iter := self.myReleaseCriteria.allCriteria.createIterator;
	while iter.next( criteria ) do
		if criteria.myYACriteriaType = null  then
			continue;
		endif;
		if criteria.myYACriteriaType.type = YACriteriaType_Commodity then 
			foreach commodity in criteria.myYAData.CM_YADataObjects.allObjects do
				commodityCode := commodity.CM_Commodity.code;
				if commodityCode &lt;&gt; null then
					commodityCodeArray.add(commodityCode);
				endif;
			endforeach; 
		endif; 
	endwhile;
	return commodityCodeArray;
	
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_StringArray"/>
    </JadeMethod>
    <JadeMethod name="getMyCommodityCriteriaDesc" id="9bb66cdb-e8b3-494e-ace0-6815d46d7d0e">
        <source>getMyCommodityCriteriaDesc(): CM_StringArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2023	navmk20	Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info

*/

vars
	iter 				: Iterator;
	criteria 			: CM_YACriteria;
	myCommodities		: CM_Commodity;
	commodity			: Object;
	commodityDescArray	: CM_StringArray;
	
begin
	create commodityDescArray transient;
	
	if self.myReleaseCriteria = null then
		return null;
	endif;
	
	iter := self.myReleaseCriteria.allCriteria.createIterator;
	while iter.next( criteria ) do
		if criteria.myYACriteriaType = null  then
			continue;
		endif;
		
		if criteria.myYACriteriaType.type = YACriteriaType_Commodity then 
			foreach commodity in criteria.myYAData.CM_YADataObjects.allObjects do
				myCommodities := app.myRoot.allCommodities[commodity.CM_Commodity.code];
				if myCommodities &lt;&gt; null and myCommodities.description &lt;&gt; null then
					commodityDescArray.add(myCommodities.description);
				endif;
			endforeach; 
		endif; 
	endwhile;
	return commodityDescArray;
	
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_StringArray"/>
    </JadeMethod>
    <JadeMethod name="getMyCriteriaCargoId" id="71b8cbee-f23e-4c1d-84cf-9363273f3a0f">
