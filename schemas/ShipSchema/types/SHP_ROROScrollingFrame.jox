/*
Date		    Who			Reason
20 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	self.autoRedraw := true;
	
	
	//if self.isInPainter then
	//	return;
	//endif;
	
	//self.caption := null;
	
	//self.autoRedraw := true;	
epilog

end;</source>
