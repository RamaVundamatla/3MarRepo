    <JadeMethod name="mpdTestWSDLDocExtract" id="86a2bc74-9874-40fc-bb86-e1a1f3b91e6c">
        <source>mpdTestWSDLDocExtract();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars
	agent : DEV_ReleaseExtractAgent;
	prof : JadeProfiler;
begin
	app.initialize();
	prof := process.profiler;
	prof.methodCount := 200;
	
	
	create agent transient;
	
	// These aren't really needed, but just in case
	agent.monthlyVersion := "050";
	agent.versionString := app.myRoot.getVersionString() &amp; agent.monthlyVersion;
	agent.targetReleaseDirectory := "F:\Releases\" &amp; app.myRoot.getVersionString() &amp; "\Monthly\" &amp; agent.versionString;
	agent.baseReleaseDirectory := agent.targetReleaseDirectory &amp; "\BaseRelease";
	agent.baseJARIDirectory := agent.targetReleaseDirectory &amp; "\BaseJARIRelease";
	agent.tempServerDirectory := app.cnGetServerMiscPath();
	agent.isMonthlyExtract := true;
	
	// These ones are important however
	agent.extractWSDLChanges := true;
	agent.setPropertyValue("targetSourceDirectory","F:\Releases\" &amp; app.myRoot.getVersionString() &amp; "\Monthly\" &amp; agent.versionString);
	
	//agent.doReleaseExtract();
	//prof.start();
	agent.doExtractWSDLChanges(true);		// This should always be false, unless you want to break the snapshot!
	//prof.report();
	
epilog
	delete agent;	
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdXLATBulkRemoveFormCap" id="5c4df0fb-72eb-44d3-b589-4e9c28f8c161">
        <source>mpdXLATBulkRemoveFormCap();
/*

Purpose:			Checks FormCaptions to see if they still refrence anything (they shouldn't if the form has been deleted) and deletes them

Parameters:			

Return Value:		

Date				Who		Reason
05 February 2019	jlgmd1	Initial creation TFS 43007 Remove Teklogix

*/

constants
	UpdateRun : Boolean = false;
vars
	cat : ConstantCategory;
	const : Constant;
	coll : ConstantNDict;
	sc : SchemaColl;
	indirectRefs,
	visited : FeatureSet;
	formsToCheck : StringArray;
	form : String;
	pattern : JadeRegexPattern;
	matches : JadeRegexMatch;
	controlName : String;
begin
	global.cnEcGetConstants("XLAT_FormCaptions", coll);
	
	create formsToCheck transient;
	formsToCheck.add('FormClass="INV_InvoiceLineMapping"');
	
	
	create sc transient;
	rootSchema.allSubschemas(sc);
	
	create indirectRefs transient;
	create visited transient;
	
	if UpdateRun then
		beginTransaction;
	endif;
	
	create pattern transient;
	pattern.setExplicitCapture(true).setMultiline(true).setDotAll(true).compile('.+ ControlName="(\w+)" .+');
	
	foreach const in coll do :contLoop
		indirectRefs.clear();
		visited.clear();
		
		foreach form in formsToCheck do
			if const.text.pos(form, 1) &gt; 0 then
				const.getRefs(sc.first, sc, indirectRefs, visited);
				
				if pattern.match(const.text, matches) then
					controlName := matches.at(1).value;
				else
					controlName := "&lt;Control Name Not Found&gt;";
				endif;
				
				write const.name &amp; Tab &amp; controlName &amp; Tab &amp; indirectRefs.size.String &amp; Tab &amp; visited.size.String;
				if UpdateRun and indirectRefs.size = 0 and visited.size = 0 then
					delete const;
				endif;
				continue contLoop;
			endif;
		endforeach;
		
	endforeach;
	
	if UpdateRun then
		commitTransaction;
		
		self.verifyXLAT();
	endif;
	
epilog
	delete sc;
	delete indirectRefs;
	delete visited;
	delete formsToCheck;
	delete pattern;
	delete matches;
end;</source>
    </JadeMethod>
