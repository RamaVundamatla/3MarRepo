    <JadeMethod name="useRemoteDrives" id="3b6e90aa-249f-4e9a-ae4d-e8a21accd802">
        <executionLocation>server</executionLocation>
        <source>useRemoteDrives() serverExecution;

vars
	cmd,path:String;
	retCode,result:Integer;
begin
	path := 'F:\Windows\system32';
	cmd := '\net.exe' &amp; ' use R: \\cnwchcm24\cnwjbl$ /USER:cnw\cnwjbl1 1keepthemout1';
	//cmd := '\net.exe' &amp; ' use R: /Delete /YES';
	//cmd := '\findwindows.exe';
	retCode:=node.createExternalProcess(path,path&amp;cmd,null,null,false,false,result);
end;</source>
    </JadeMethod>
    <JadeMethod name="zbmkControlSession" id="7734b828-8849-464e-8f49-8dda8fc5af3c">
