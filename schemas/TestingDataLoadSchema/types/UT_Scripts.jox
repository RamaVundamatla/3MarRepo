    <JadeMethod name="resetData_37201" id="2ea432dd-d382-44d4-a1bc-2b0eafba5520">
        <source>resetData_37201();
/*

Purpose:	Reset 37201		

Date		Who		Reason
20/05/2022	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	passportTerm 			: CM_Terminal;
	
	truckFound				: Boolean;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	truckFound := false;
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "37201" and vvr.timeOut = null do
		truckFound := true;
		break;
	endforeach;
	
	//if vvr &lt;&gt; null then
	if truckFound = true then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37205" id="6d188337-2b4c-4ade-ba89-e5259132cbf0">
        <source>resetData_37205();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2020	jlgmh5	Initial creation

*/
constants
	VechileID				: String = "37205";

vars

	terminal				: CM_Terminal;
	ti						: Object;
	cargoType				: CM_CargoType;
	user					: CM_User;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	cargoType := self.getCargoType("BOTB");
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	self.deleteVehicle("37205");
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG37205A01");

	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, cargoType.id, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	vehicle := self.getVehicle(VechileID);
	if vehicle = null then
		app.writeLog("Unable to find vehicle " &amp; VechileID, LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
	self.deleteVehicle(VechileID);

epilog

	delete tisToDelete;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37207" id="fe6633cc-eae3-438c-aac2-d2f90efac00e">
        <source>resetData_37207();
/*

Purpose:			Delete the train and all it's wagons

Parameters:			

Return Value:		

Date		Who		Reason
24/08/2021	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	train					: CM_Train;
	user					: CM_User;
	
	tisToDelete				: StringArray;
	
begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	passportTerm := app.myPassport.getMyTerminal();
	app.myPassport.setMyTerminal(terminal);
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	create tisToDelete transient;
	tisToDelete.add("JLG37207A01");
	self.deleteTIResetScript(tisToDelete, terminal);
	
	train := self.getTrain("TRAIN37207", null);
	self.deleteTrainAndAssociatedObjs(train);

epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete tisToDelete;
	
end;</source>
    </JadeMethod>
