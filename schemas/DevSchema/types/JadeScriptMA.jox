    <JadeMethod name="euPDupVBSSlots" id="5dd0df4d-fa7c-49d8-8263-2cc1ae3a889a">
        <source>euPDupVBSSlots();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023		navma1	Initial creation

*/

vars
	term 	: CM_Terminal;
	vbs  	: CM_VehicleBookingTimeSlot;
	lFile   : File;
begin
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\eupVBS.csv";
    lFile.open;
	
	lFile.writeLine(
					"Term"       &amp; "," &amp;
					"ID"  		 &amp; "," &amp;
					"EXTID"   );
					
	foreach term in app.myRoot.allTerminals do
		foreach vbs in term.myVehicleBookingTerminal.allVBTimeslotsById do
			
					lFile.writeLine(term.code &amp;Comma&amp; vbs.id &amp;Comma&amp; vbs.externalReference);
		endforeach;
		
	endforeach;
	
  lFile.close;
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="eup52850" id="5a31cb7d-d359-490e-811a-e20d903fa730">
        <source>eup52850();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2022		navma1	Initial creation

*/

vars
	cargoType : CM_CargoType;
begin

	cargoType := app.myRoot.allCargoTypesById[10];
	
	if cargoType &lt;&gt; null and cargoType.description.toUpper = "Trailer".toUpper then
		
		write cargoType.id.String &amp; Tab &amp; cargoType.description;
		beginTransaction;
			 cargoType.setPropertyValue(CM_CargoType::id.name,10000.Integer);
		commitTransaction;
	endif;
epilog

end;</source>
    </JadeMethod>
