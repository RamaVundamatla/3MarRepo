    </JadeMethod>
    <JadeMethod name="getTotalRunnableTests" id="1048b9dc-0cc2-48f9-a650-94ca0bd1e9ef">
        <updating/>
        <source>getTotalRunnableTests() updating;

/*

Purpose:			Get the total number of runnable tests	

Parameters:			

Return Value:		


Date				Who		Reason
28 September 2011	cnwmh5	Initial creation

*/

vars

	klass							: Class;
	meth							: Method;
		
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	
	totalRunnableTests				: Integer;
	
begin
	
	// get the main unit test class, not found the leave
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create methodsDict transient;
	foreach klass in classes do
		//methodsDict := klass.cnGetMethods();
		//cnwmc5 - 13 Sep 2012
		methodsDict.clear();
		klass.cnGetMethods.copy(methodsDict);
		foreach meth in methodsDict do
			// if not runnable unit test method then next
			if not meth.isRunnableUnitTestMethod() then
				continue;
			endif;
			totalRunnableTests := totalRunnableTests + 1;
		endforeach;
	endforeach;
	self.setTotalRunableTests(totalRunnableTests);
	
	if app.myUMTestRunONight &lt;&gt; null and app.overnightRun then					// 24/04/2012 cnwmh5
		beginTransaction;
		///app.myUMTestRunONight.setTotalRunnable(totalRunnableTests);
		app.myUMTestRunONight.updateTotalRunnable(totalRunnableTests);			// 05/09/2013 cnwmh5
		commitTransaction;
	endif;
	
epilog

	delete methodsDict;						// 14/09/2012 cnwmh5 fix transient leak issue
	delete classes;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getTrxSummary" id="ac2b19fc-ea06-43c4-8db7-16d3d9ab20e7">
        <source>getTrxSummary(): String;
//25 August 2010	cnwdw1	
//
vars
	t: UT_TrxAnalyser;
	sum: String;
begin
	create t transient;
	sum := sum &amp; t.summarizeTrx("CM_TrxControlCreateAgent", false) &amp; CrLf;
	sum := sum &amp; t.summarizeTrx("CM_TrxControlDeleteAgent", false) &amp; CrLf;
	sum := sum &amp; t.summarizeTrx("CM_TrxControlUpdateAgent", false) &amp; CrLf &amp; CrLf;
	sum := sum &amp; t.summarizeTrx("CM_TrxControlCreateAgent", true) &amp; CrLf;
	sum := sum &amp; t.summarizeTrx("CM_TrxControlDeleteAgent", true) &amp; CrLf;
	sum := sum &amp; t.summarizeTrx("CM_TrxControlUpdateAgent", true) &amp; CrLf;
	
	return sum;

epilog
	delete t;					// 13/09/2012 cnwmc5	transient leak issue
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateOwnerArray" id="0af607b8-dcc8-41ec-b46f-2f54ad73b307">
        <source>populateOwnerArray(_lookFor : String; _tokens : StringArray512 input; _ownerArray : StringArray io) : Boolean;

/*

Purpose:		Popuplate the owner array with who created the test

Date			Who		Reason
04/07/2017		cnwmh5	Initial creation

*/

vars

	token					: String;
	lookForPos				: Integer;
	linePos					: Integer;
	userName				: String;
	loopBrokenOutOf			: Boolean;
	
begin

	loopBrokenOutOf := false;

	foreach token in _tokens do
		if token.toUpper().cnContains(_lookFor) then
			lookForPos := token.toUpper.pos(_lookFor, 1);
			if lookForPos = 0 then
				continue;
			endif;
			userName := token[lookForPos:end];
			if not _ownerArray.includes(userName.toUpper) then
				_ownerArray.add(userName.toUpper);
				linePos := -1;
				loopBrokenOutOf := true;
				break;
			endif;
			if token.toUpper().cnContains(_lookFor) then
				linePos := -1;
				loopBrokenOutOf := true;
				break;
			endif;
		endif;
	endforeach;

	return loopBrokenOutOf;
	
epilog

end;</source>
        <Parameter name="_lookFor" type="String"/>
        <Parameter name="_tokens" type="StringArray512" usage="input"/>
        <Parameter name="_ownerArray" type="StringArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
