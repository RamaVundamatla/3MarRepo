        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="terminalCode" id="c1a1293a-5e6e-46aa-afc1-37cb13526848">
        <length>5</length>
        <embedded/>
        <virtual/>
        <type name="String"/>
        <access>readonly</access>
