    <JadeMethod name="getMyRTQueueLabel" id="3c603bea-5a3d-4387-9378-005be875036b">
        <source>getMyRTQueueLabel() : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQueue : CM_RadioTelemetryQueue;
begin
	rtQueue:=self.getMyRTQueue;
	if rtQueue &lt;&gt; null then
		return rtQueue.id;
	else
		return "&lt;Unassigned&gt;";
	endif;
epilog

end;</source>
