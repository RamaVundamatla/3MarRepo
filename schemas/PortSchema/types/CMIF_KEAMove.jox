    <JadeMethod name="setFromTxn" id="94dbb3e0-a1fd-433c-901d-234afa82d277">
        <updating/>
        <source>setFromTxn(_moveTxn: CM_Move) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2014	cnwdw1	Initial creation
*/
vars

begin
	self.moveTxn := _moveTxn;
	self.sourceType := _moveTxn.getLocationType(_moveTxn.sourceLocn, self.sourceLC);
	self.targetType := _moveTxn.getLocationType(_moveTxn.targetLocn, self.targetLC);
epilog

end;</source>
