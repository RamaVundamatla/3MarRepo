    <JadeMethod name="cloneTISheet" id="d5689ce3-a032-4230-9e65-5d11e4b7e45c">
        <source>cloneTISheet(_index : Integer);
// ---------------------------------------------------------------------------
// Created:	25 September 2009 By Graeme Black cnwgb1
// 			CCMS MES 1008 PAR 20320
// Purpose:	Clone the item sheet for EDI files containing multiple items
// I'm assuming there isn't a tabIndex clash. I moved the base tabindexes to
// above 11000 in the painter to avoid this
// ---------------------------------------------------------------------------
// 14/10/2009	cnwcs5	par 20836 - re-parent verify errors table
vars
	newSheet : Control;
	newTable : CM_DataTable;
begin
	newSheet 			:= self.shtEDIData.loadControl( _index );
	newSheet.parent 	:= self.fldDetail;
	newSheet.tabIndex 	:= self.shtEDIData.tabIndex + 100*_index;
	
	newTable 			:= self.tblEDITI.loadControl( _index ).CM_DataTable;
	newTable.parent 	:= newSheet;
	
	newTable.CM_DataTable.accessRow(1).backColor := self.tblEDITI.accessRow(1).backColor;
	newTable.tabIndex 	:= self.tblEDITI.tabIndex + 100*_index;
	
	self.initTblEDITI( _index );
	//newTable.move(0, 0, newSheet.width, newSheet.height);	// par 20836
	newTable.stretchToParent := true;						// par 20836
	newSheet.cnEcResizeContents();
	
epilog
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
