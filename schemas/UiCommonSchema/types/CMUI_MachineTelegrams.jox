    <JadeMethod name="translateForm" id="dd38fecd-1af9-4869-a324-1d8bdd9a80a6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007791, locale);
	btnDelete.translateBubbleHelp(Xlat_0005081, locale);
	btnDelete.translateCaption(Xlat_0005082, locale);
	btnDoSearch.translateBubbleHelp(Xlat_0005083, locale);
	btnDoSearch.translateCaption(Xlat_0005084, locale);
	btnEdit.translateCaption(Xlat_0005085, locale);
	btnLog.translateCaption(Xlat_0005086, locale);
	btnNew.translateBubbleHelp(Xlat_0005087, locale);
	btnNew.translateCaption(Xlat_0005088, locale);
	btnPrint.translateCaption(Xlat_0005089, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007792, locale);
	mnuContextTbl.translateCaption(Xlat_0007793, locale);
	mnuInspectObj.translateCaption(Xlat_0007794, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateObjectInTable" id="cd87937b-14ca-40fd-b241-9b5f2eca0432">
        <source>updateObjectInTable(_eventType : Integer; theObject : CM_Object; _tbl : CM_DataTable input) : Boolean protected;

// Created by cnwdvb1 on 05 September 2006

vars

	theRow	: Integer;

begin

	if _eventType = Object_Delete_Event or _eventType = Object_Update_Event then
		_tbl.findObjectInRow(theObject, theRow);
	
		if theRow &lt;= _tbl.fixedRows then
			return false;
		endif;
	
		_tbl.removeItem(theRow);
		
		if _eventType = Object_Update_Event then
			self.tblDataDisplayRow(theObject.CM_RTGTelegram);
		endif;
		/*if self.tblData.rows &gt; self.tblData.fixedRows then
			self.tblData.selectRow(self.tblData.fixedRows + 1, false);		
			self.setCurrentPackage(self.tblData.accessRow(self.tblData.fixedRows + 1).itemObject.CM_Package);
		endif;*/
		
	elseif _eventType = Object_Create_Event then
		self.tblDataDisplayRow(theObject.CM_RTGTelegram);
	endif;
	
	 _tbl.colourRows(self.colorRow1, self.colorRow2);
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="theObject" type="CM_Object"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
