    <JadeMethod name="upgradeCargoGroupAssign" id="0f630989-92d4-43eb-bbd9-1fc3e47bc58c">
        <source>upgradeCargoGroupAssign(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 39186

*/
vars

	cga : CM_CargoGroupAssignment;
	notAllComplete : Boolean;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting 'Notified Cargo Groups'", null);

	foreach cga in CM_CargoGroupAssignment.instances do
		app.myTrxUA.trxUpgradeCargoGroupAssign( cga, app.myPassport );
		if app.myPassport.trxCompletedOK then
			//
		else
			app.writeLog(method.qualifiedName &amp; " " &amp; cga.String &amp; " failed to convert", LogINFO);
			app.writeLog(method.qualifiedName &amp; " " &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogINFO);
			notAllComplete := true;
			app.myPassport.clearErrorsWarnings();
		endif;
	endforeach;

	app.writeLog(method.qualifiedName &amp; " Converted 'Notified Cargo Groups", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converted 'Notified Cargo Groups") ;	
	endif;
	
	if notAllComplete then
		return;
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="upgradeVoyageTransfer" id="dc1f2fdd-8174-4534-9dfe-f5243b4fb9a6">
        <source>upgradeVoyageTransfer(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	voyageJobTransferType : CM_VoyageJobTransferType;
	root : CM_Root;
	iter : Iterator;
	 voyJob: CM_VoyageJob;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating 'System' Voyage Job Transfer Types, populate Jobs", null);

	root := CM_Root.firstInstance;
	
	voyageJobTransferType := root.allVoyageJobTransferTypes.getAtKey(VESSEL_TYPE_RORO);
	if voyageJobTransferType = null then
		beginTransaction;
		create voyageJobTransferType persistent;
		voyageJobTransferType.setProxy( VESSEL_TYPE_RORO, VESSEL_TYPE_RORO_DESCR,null );
		voyageJobTransferType.setIsSytem();
		commitTransaction;
	endif;
	
	voyageJobTransferType := root.allVoyageJobTransferTypes.getAtKey(VESSEL_TYPE_LOLO);
	if voyageJobTransferType = null then
		beginTransaction;
		create voyageJobTransferType persistent;
		voyageJobTransferType.setProxy( VESSEL_TYPE_LOLO, VESSEL_TYPE_LOLO_DESCR,null );
		voyageJobTransferType.setIsSytem();
		commitTransaction;
	endif;
	
	iter := CM_VoyageJob.instances.createIterator;
	beginTransaction;
	while iter.next( voyJob ) do
		voyJob.setTransferType( VESSEL_TYPE_LOLO );
	endwhile;
	commitTransaction;
	
	iter := CM_VoyageHatchLidJob.instances.createIterator;
	beginTransaction;
	while iter.next( voyJob ) do
		voyJob.setTransferType( VESSEL_TYPE_LOLO );
	endwhile;
	commitTransaction;
	
	iter := CM_VoyageDeckJob.instances.createIterator;
	beginTransaction;
	while iter.next( voyJob ) do
		voyJob.setTransferType( VESSEL_TYPE_RORO );
	endwhile;
	commitTransaction;
	
	iter := CM_VoyageHoldJob.instances.createIterator;
	beginTransaction;
	while iter.next( voyJob ) do
		voyJob.setTransferType( VESSEL_TYPE_RORO );
	endwhile;
	commitTransaction;
	
	iter := CM_VoyageROROJob.instances.createIterator;
	beginTransaction;
	while iter.next( voyJob ) do
		voyJob.setTransferType( VESSEL_TYPE_RORO );
	endwhile;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Created 'System' Voyage Job Transfer Types, populated Jobs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Created 'System' Voyage Job Transfer Types, populated Jobs") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
