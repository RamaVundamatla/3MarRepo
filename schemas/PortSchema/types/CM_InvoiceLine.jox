    <JadeMethod name="getTIID" id="749855f1-8e5f-4058-bec4-3e92839060c7">
        <source>getTIID() : String;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTIid : String;
begin
	theTIid := self.trackedItemId;
	if self.myTransactionTI &lt;&gt; null then
		theTIid := self.myTransactionTI.myTrackedItem.id;
	else
		theTIid := self.trackedItemId;
	endif;
	if theTIid = null and self.trackedItem &lt;&gt; null then
		theTIid := self.trackedItem.id;
	endif;

	return theTIid;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForLine" id="4200e0af-3512-4949-bd61-a257c8d2e971">
        <source>getTaxAmountForLine() : Real;

vars
	taxAmount : Real;
	charge : CM_Charge;
begin
	foreach charge in self.charges do
		taxAmount := taxAmount + charge.getTaxAmountForCharge();
	endforeach;

	return taxAmount;

end;</source>
