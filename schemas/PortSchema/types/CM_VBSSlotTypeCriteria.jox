    <JadeMethod name="setForUpdate" id="eae396e7-cc99-42ed-a7c2-f8099bec222c">
        <updating/>
        <source>setForUpdate(_proxy: CM_VBSSlotTypeCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 june 2022 navtnr20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
20 Dec 2022	navak20 Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
*/

vars
	realVBS : CM_VehicleBookingTimeSlotType;
begin
	if self.myVehicleBookingSlotType = null then
		if not self.isTransient then
			if _proxy.myVehicleBookingSlotType &lt;&gt; null and _proxy.myVehicleBookingSlotType.isTransient then
				realVBS := _proxy.myVehicleBookingSlotType.pxyGetRealObject();
			endif;
			if realVBS = null then
				// 20.12.2022 navak20 TFS 55978
				if _proxy.myVehicleBookingSlotType = null then
					return;
				endif;
				// 20.12.2022 navak20 TFS 55978
				if not _proxy.myVehicleBookingSlotType.isTransient then
					realVBS := _proxy.myVehicleBookingSlotType;
				endif;
			endif;
			self.myVehicleBookingSlotType := realVBS;
		else
			self.myVehicleBookingSlotType := _proxy.myVehicleBookingSlotType;
		endif;
	endif;
	inheritMethod(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_VBSSlotTypeCriteria"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaseData" id="d8c6285c-99bd-4e5f-855e-4c92213402cd">
