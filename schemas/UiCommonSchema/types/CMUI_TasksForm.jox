    <JadeMethod name="initTasksTable" id="7470525a-de86-4f68-bdac-0450e92185dc">
        <source>initTasksTable( _table : CM_DataTable input ) protected;
// Set up the task table, task description and Add checkbox
vars
	col		: Integer;
	etDef	: EntTableDef;
	table	: CM_DataTable;
begin
	if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
		etDef := app.myController.getEntTableDef(ETDef_ToDoTasks);
	else
		etDef := app.myController.getEntTableDef(ETDef_ToDoTasksAdd);
	endif;
	table := _table;
	table.setTblDataEntRowsFromDef (etDef);

	table.userInputEnabled	:= true;
	table.selectMode		:= Table.SelectMode_None;
	table.showFocus		:= false;
	
	if self.mode &lt;&gt; CM_ContainerEnqForm.TASK_MODE_REMARKS then
		col := table.getColumnByRowName (ETRow_Add);
		if col &lt;&gt; 0 then
			table.accessColumn (col).alignment	:= Table.Alignment_Center;
			table.accessedColumn.widthPercent	:= 12;		// room for the column caption
		endif;
	endif;
	// feedback from Shane 20/10 add Remarks to all tables
	col := table.getColumnByRowName (ETRow_SortKey);
	if col &lt;&gt; 0 then
		table.accessColumn (col).visible	:= false;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listCargo" id="fac528f7-6fa2-4760-812e-df2a0c511e68">
        <source>listCargo() protected;

vars
	str		: String;
	ti		: CM_TrackedItem;
begin
	str := "Cargo: ";
	// task remarks are for the single selected cargo item only
	if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
		str := self.myTrackedItem.id;
	else
		foreach ti in self.allTrackedItems do
			str := str &amp; ti.id &amp; ", ";
		endforeach;
		if str.length &gt; 7 then
			str := str[1:str.length-2];		// strip last comma
		endif;
	endif;
	
	self.txtTop.text := str;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTasks" id="3ebc5dc7-95ca-45c8-99b2-aaead92b076b">
        <updating/>
        <source>loadTasks(_obj : CM_Object) updating, protected;
// load the tasks for the tracked items based on the mode
// Date			Who			Reason
// 17 Oct 2022 	navtnr20 	ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 18 Feb 2025	navlw1 		JIRA-33941: MTN | To Do Task List UI Change
vars
	row				: Integer;
	minHeight,
	colWidth,
	textHeight		: Integer;
	addCol,
	remarksCol,
	col				: Integer;
	sortKey			: Integer;
	gotException	: Boolean;
	itemEnabled		: Boolean;
	table			: CM_DataTable;
	passport		: CM_Passport;
	terminal		: CM_Terminal;
	user			: CM_User;
	ti				: CM_TrackedItem;
	task			: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	taskDict		: CM_ToDoTaskDescByCode;
	iter 			: Iterator;
	control			: Control;
	etDef	: EntTableDef;
begin
	ti := _obj.CM_TrackedItem;
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	
	// this next line will cause an exception if ti is invalid
	self.expectedEdition := ti.edition;
	if gotException then
		// display message and close form
		self.unloadFormWithMessage;
	endif;
	
	passport 			:= app.myPassport;
	user				:= passport.myUser;
	terminal			:= self.myTerminal;
	table				:= self.tblTasksAdd;
	
	table.rows	:= table.fixedRows;
	col := table.getColumnByRowName (ETRow_Add);
	addCol := col;
	remarksCol := table.getColumnByRowName (ETRow_Remarks);
	// start 17.10.2022 navtnr20 TFS 54967
	if self.mode = CM_ContainerEnqForm.TASK_MODE_INSTRUCTION then	
		table.showColumnByColName(ETRow_Instruction);
		table.hideColumnByColName(ETRow_Add);
		table.hideColumnByColName(ETRow_Remarks);
	else
		table.hideColumnByColName(ETRow_Instruction);
	endif;
	//End 17.10.2022 navtnr20 TFS 54967
	create taskDict transient;
	if self.mode = CM_ContainerEnqForm.TASK_MODE_ADD then			
		user.getToDoTasksAddRemoveForTerm(terminal, taskDict);
		self.grpBottom.caption := app.getErrorString(Task_to_Add);
		if col &lt;&gt; 0 then
			table.accessCell(1, col).text := app.getErrorString(AddUpper);
		endif;
	elseif self.mode = CM_ContainerEnqForm.TASK_MODE_COMPLETE then
		self.grpBottom.caption := app.getErrorString(Task_to_Complete);
		if col &lt;&gt; 0 then
			table.accessCell(1, col).text := app.getErrorString(Complete);
		endif;
	elseif self.mode = CM_ContainerEnqForm.TASK_MODE_REMOVE then
		self.grpBottom.caption := app.getErrorString(Task_to_Remove);
		if col &lt;&gt; 0 then
			table.accessCell(1, col).text := app.getErrorString(Remove);
		endif;
	elseif self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
		self.grpBottom.caption := app.getErrorString(Task_Remarks);
	elseif	 self.mode =  CM_ContainerEnqForm.TASK_MODE_INSTRUCTION then	//01.11.2022 navtnr20 TFS 54967
		self.grpBottom.caption := app.getErrorString(Task_instructions);	//01.11.2022 navtnr20 TFS 54967
	endif;
	
	if self.mode = CM_ContainerEnqForm.TASK_MODE_ADD then
		iter := taskDict.createIterator();
		while iter.next(taskDesc) do
			itemEnabled := true;
			foreach task in ti.allToDoTasksToDo do
				if task.toDoTaskDesc = taskDesc then
					itemEnabled := false;
					break;
				endif;
			endforeach;
			if taskDesc.description = null then 
				itemEnabled := false;
			endif;
		
			if itemEnabled and not taskDesc.isAvailableForCargoType(ti.cargoType) then
				continue;
			endif;
		
			if itemEnabled and not taskDesc.isValidForGenSet( ti ) then
				continue;
			endif;
			if not itemEnabled then
				continue;
			endif;
			row := table.addItemObject (taskDesc, "");		// add this entry with blank details
			table.setCellValueByName (ETRow_Description, row, taskDesc.description);
			table.setCellValueByName (ETRow_SortKey, row, taskDesc.sortKey.padLeadingWith('0', 6));
			// enable maintenance of remarks
			table.rowHeight[row] := 18;				// navlw1 #JIRA-33941 18/02/2025
			table.accessCell (row, remarksCol).inputType 	:= Table.InputType_TextBox;
			control := table.accessCell(row, remarksCol).cellControl;
			if control.isKindOf(TextBox) then
				control.TextBox.scrollVertical := true;
				table.accessedCell.wordWrap := true; 	// navlw1 #JIRA-33941 18/02/2025
			endif;
			
			if not self.canUpdate then
				// over ride default of checkbox
				if addCol &lt;&gt; null then
					table.accessCell (row, addCol).inputType 	:= Table.InputType_None;
					table.accessedCell.text						:= null;
				endif;
			endif;
				
		endwhile;
	else
		foreach task in ti.allToDoTasksToDo do
			if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
				row := table.addItemObject (task, "");				// add this task entry with blank details
			else
				row := table.addItemObject (task.toDoTaskDesc, "");		// add this task description entry with blank details
			endif;
			table.setCellValueByName (ETRow_Description, row, task.toDoTaskDescDesc);
			table.accessCell (row, remarksCol).wordWrap := true;
			if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
				minHeight := 60;						// room for multi-line remarks
			else
				minHeight := 18;						// standard row height
			endif;
			colWidth := table.accessColumn(remarksCol).width;
			textHeight := self.getTextHeightForWidth(task.remarks, colWidth) + 4;	// margins of 2 top and bottom
			if textHeight &lt; minHeight then
				textHeight := minHeight;						// standard row height
			endif;
			table.rowHeight[row] := textHeight;			// room for actual remarks

			table.setCellValueByName (ETRow_Remarks, row, task.remarks);
			if task.myInstructions &lt;&gt; null then	//26.10.2022 navtnr20 TFS 54967
				table.setCellValueByName (ETRow_Instruction.formatWithEllipsis(1,100,true), row,task.myInstructions.internalInstructions &amp;" "&amp; task.myInstructions.externalInstruction);//28.10.2022 navtnr20 TFS 54967
			endif;	//26.10.2022 navtnr20 TFS 54967
			sortKey := 0;
			if task.toDoTaskDesc &lt;&gt; null then
				sortKey := task.toDoTaskDesc.sortKey;
			endif;
			table.setCellValueByName (ETRow_SortKey, row, sortKey.padLeadingWith('0', 6));
			
			if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
				table.accessCell (row, 2).inputType 	:= Table.InputType_TextBox;
				control := table.accessCell(row, 2).cellControl;
				if control.isKindOf(TextBox) then
					control.TextBox.scrollVertical := true;
				endif;
			else
				if not self.canUpdate then
					// over ride default of checkbox
					if addCol &lt;&gt; null then
						table.accessCell (row, addCol).inputType 	:= Table.InputType_None;
						table.accessedCell.text						:= null;
					endif;
				endif;
			endif;
		endforeach;
	endif;

	// sort in sort key then description order, so that if sort keys are not used or are not unique then the description is used as well
	col := table.getColumnByRowName (ETRow_SortKey);
	if col &lt;&gt; null then
		table.sortColumn [1] := col;
	endif;
	col := table.getColumnByRowName (ETRow_Description);
	if col &lt;&gt; null then
		table.sortColumn [2] := col;
	endif;
	table.resort;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="mnuColOrganizer_click" id="9a24dd65-2c3f-4dbf-b8d1-fbaf3ce36cf0">
