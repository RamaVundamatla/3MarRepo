    <JadeMethod name="popTblResourcesCrV3" id="bd6c188b-79a2-4179-8b0c-661f7d900596">
        <source>popTblResourcesCrV3( _table : CM_DataTable input; _woVoyDtl : CM_WorkOrderVoyageDtl; _harbour : HMS_Harbour );
/*

Purpose:			

Parameters:			Version 3 of TFS 41980

Return Value:		

Date		Who		Reason
23 November 2018	jlgndl1	Initial creation	TFS 41980
28 Nov 2018	NDL		Now cater for Permit requests too.

*/

vars

	entDef : EntTableDef;
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	
	rowIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	qColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	drColIndex : Integer;
	
	noEntryColour : Integer;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	localFromDT : TimeStamp;
	localToDT : TimeStamp;
	
	dateMask : CMUI_DateMask;

	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	drIndex : Integer;
	debtor : CM_Debtor;
	resourceList: String;
	resIndex : Integer;
	
	wodPermitRequest : CM_WodPermitRequest;
	iter : Iterator;

begin

	if _woVoyDtl.CM_WodCargoRequest.myVoyageCargoRequest = null and _woVoyDtl.CM_WodCargoRequest.myPermitRequest = null then
		return;
	else
		wodVoyageCargoRequest := _woVoyDtl.CM_WodCargoRequest.myVoyageCargoRequest;
		wodPermitRequest := _woVoyDtl.CM_WodCargoRequest.myPermitRequest;
	endif;
	
	if self.dateMaskArray &lt;&gt; null and not self.dateMaskArray.isEmpty then
		self.dateMaskArray.purge;
	endif;
	_table.clear();
	
	entDef := app.myController.getEntTableDef(ETDef_HmsWoResourcesUsed);
	_table.setMyEntTableDef(entDef);	
	_table.setTblDataEntRowsFromDef(entDef);
	_table.hideColumnByColName( ETRow_Include );	//23 NOV 2018	NDL	TFS 41980
	
	_table.tabKey := J_key_Tab;
	
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	qColIndex := _table.getColumnByRowName( ETRow_QuantityUnits );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	drColIndex := _table.getColumnByRowName( ETRow_Debtor );
	
	noEntryColour := _table.accessCell(1,1).backColor;
	
	if wodVoyageCargoRequest &lt;&gt; null then
		iter := wodVoyageCargoRequest.allMarineServiceDetails.createIterator;
	elseif wodPermitRequest &lt;&gt; null then
		iter := wodPermitRequest.allMarineServiceDetails.createIterator;
	endif;
	
	while iter.next( wodMarineServiceDet ) do
	
		resourceType := wodMarineServiceDet.myHMSResourceType;
		if resourceType = null then
			continue;
		else
			resourceList := resourceType.getResourcesForCmbList( self.cmbResource, _harbour );
			resource := wodMarineServiceDet.myHMSResource;
		endif;
		
		debtor := wodMarineServiceDet.myDebtor;
		drIndex := -1;
		resIndex := -1;
		
		_table.rows := _table.rows + 1;
		rowIndex := _table.rows;
		
		_table.accessCell( rowIndex, rtColIndex ).text := resourceType.description;
		_table.accessCell( rowIndex, rtColIndex ).itemObject := resourceType;
		
		_table.accessCell( rowIndex, rColIndex ).inputType := Table.InputType_ComboBox;
		_table.accessCell( rowIndex, rColIndex ).comboList := resourceList;
		if resource &lt;&gt; null then
			resIndex := self.cmbResource.findObject( resource );
			if resIndex &gt; 0 then
				_table.accessCell( rowIndex, rColIndex ).text := resource.description;
			endif;
		endif;
		
		if resourceType.isQuantityRequired then
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_TextBox;
			_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.dataType := TextBox.DataType_Numeric;
			if resourceType.numDecimalPlaces &gt; 0 then
				_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.decimals := resourceType.numDecimalPlaces;
			endif;
		else
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, uColIndex ).backColor := noEntryColour;	
		endif;
		if resourceType.quantityUnits &lt;&gt; null then
			_table.accessCell( rowIndex, qColIndex ).text := resourceType.quantityUnits;
		endif;
		_table.accessCell( rowIndex, qColIndex ).inputType := Table.InputType_None;
		_table.accessCell( rowIndex, qColIndex ).backColor := noEntryColour;
			
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, fdColIndex ).cellControl := dateMask;	
			_table.initCellForTime( _table.accessCell( rowIndex, ftColIndex ) );
		else
			_table.accessCell( rowIndex, fdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, fdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ftColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ftColIndex ).backColor := noEntryColour;
		endif;
		
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, tdColIndex ).cellControl := dateMask;
			_table.initCellForTime( _table.accessCell( rowIndex, ttColIndex ) );
		else
			_table.accessCell( rowIndex, tdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, tdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ttColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ttColIndex ).backColor := noEntryColour;
		endif;
		
		_table.accessCell( rowIndex, uColIndex ).text := null;
		_table.accessCell( rowIndex, fdColIndex ).text := null;
		_table.accessCell( rowIndex, ftColIndex ).text := null;
		_table.accessCell( rowIndex, tdColIndex ).text := null;
		_table.accessCell( rowIndex, ttColIndex ).text := null;
		_table.accessCell( rowIndex, uColIndex ).itemObject := wodMarineServiceDet;
	
		if wodMarineServiceDet.unitsUsed &gt; 0 then
			_table.accessCell( rowIndex, uColIndex ).text := wodMarineServiceDet.unitsUsed.asStringJMTWithPrecision( resourceType.numDecimalPlaces, false);
		endif;
		if wodMarineServiceDet.fromDateTime.date.isValid then
			localFromDT := self.systemToLocalTime( wodMarineServiceDet.fromDateTime );
			_table.accessCell( rowIndex, fdColIndex ).cellControl.CMUI_DateMask.setDate( localFromDT.date );
			_table.accessCell( rowIndex, fdColIndex ).text := localFromDT.date.asStringJMT;
			_table.accessCell( rowIndex, ftColIndex ).text := localFromDT.time.asStringJMT;
		endif;
		if wodMarineServiceDet.toDateTime.date.isValid then
			localToDT := self.systemToLocalTime( wodMarineServiceDet.toDateTime );
			_table.accessCell( rowIndex, tdColIndex ).cellControl.CMUI_DateMask.setDate( localToDT.date );
			_table.accessCell( rowIndex, tdColIndex ).text := localToDT.date.asStringJMT;
			_table.accessCell( rowIndex, ttColIndex ).text := localToDT.time.asStringJMT;
		endif;
		
		_table.accessCell( rowIndex, drColIndex ).inputType := Table.InputType_ComboBox;
		_table.accessCell( rowIndex, drColIndex ).comboList := debtorListForCombo;
		if debtor &lt;&gt; null then
			drIndex := self.cmbDebtor.findObject( debtor );
			if drIndex &gt; 0 then
				_table.accessCell( rowIndex, drColIndex ).text := debtor.name;
			endif;
		endif;
		
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_woVoyDtl" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="popTblResourcesForShift" id="cc15fe69-49ea-4376-9529-f2129af528e6">
        <source>popTblResourcesForShift(	_table : CM_DataTable input; 
							_wodShiftMovement : CM_WodShiftMovement; 
							_wodExtension : CM_WodExtension;
							_resources : HMS_ResourceByTypeDict	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2018	jlgdap1		Initial creation TFS 40488 PEL1 Resources for Shift Movements
//
vars
	entDef : EntTableDef;
	rowIndex : Integer;
	inclColIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	qColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	noEntryColour : Integer;
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	dateMask : CMUI_DateMask;
	localFromDT : TimeStamp;
	localToDT : TimeStamp;

begin
	if self.dateMaskArray &lt;&gt; null and not self.dateMaskArray.isEmpty then
		self.dateMaskArray.purge;
	endif;
	_table.clear();
	
	entDef := app.myController.getEntTableDef(ETDef_HmsWoResourcesUsed);
	_table.setMyEntTableDef(entDef);	
	_table.setTblDataEntRowsFromDef(entDef);
	_table.hideColumnByColName( ETRow_Debtor );	//23 NOV 2018	NDL	TFS 41980
	
	_table.tabKey := J_key_Tab;
	
	inclColIndex := _table.getColumnByRowName( ETRow_Include );
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	qColIndex := _table.getColumnByRowName( ETRow_QuantityUnits );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	
	noEntryColour := _table.accessCell(1,1).backColor;
	
	if _resources = null or _resources.isEmpty then // TFS 40747  noticed in testing
		return;
	endif;
	
	foreach resource in _resources do
		//epr 3/7/18 don't show resources not for the terminals harbour
		if resource.myHarbour &lt;&gt; self.myTerminal.myHarbour then
			continue;
		endif;
		if resource.isNotAvailableForEntry then
			continue;
		endif;
		
		resourceType := resource.myResourceType;
		_table.rows := _table.rows + 1;
		rowIndex := _table.rows;
		
		if _wodExtension &lt;&gt; null then	//19 Feb 2019	NDL	TFS 43374
			wodMarineServiceDet := _wodExtension.allMarineServiceDetails.findWodMarineServiceDet(resource);
		elseif _wodShiftMovement &lt;&gt; null then
			wodMarineServiceDet := _wodShiftMovement.allMarineServiceDetails.findWodMarineServiceDet(resource);
		endif;
		
		_table.accessCell( rowIndex, rtColIndex ).text := resourceType.description;
		_table.accessCell( rowIndex, rtColIndex ).itemObject := resourceType;
		_table.accessCell( rowIndex, rColIndex ).text := resource.description;
		_table.accessCell( rowIndex, rColIndex ).itemObject := resource;
		if resourceType.isQuantityRequired then
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_TextBox;
			_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.dataType := TextBox.DataType_Numeric;
			if resourceType.numDecimalPlaces &gt; 0 then
				_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.decimals := resourceType.numDecimalPlaces;
			endif;
		else
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, uColIndex ).backColor := noEntryColour;	
		endif;
		if resourceType.quantityUnits &lt;&gt; null then
			_table.accessCell( rowIndex, qColIndex ).text := resourceType.quantityUnits;
		endif;
		_table.accessCell( rowIndex, qColIndex ).inputType := Table.InputType_None;
		_table.accessCell( rowIndex, qColIndex ).backColor := noEntryColour;
			
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, fdColIndex ).cellControl := dateMask;	
			_table.initCellForTime( _table.accessCell( rowIndex, ftColIndex ) );
		else
			_table.accessCell( rowIndex, fdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, fdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ftColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ftColIndex ).backColor := noEntryColour;
		endif;
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, tdColIndex ).cellControl := dateMask;
			_table.initCellForTime( _table.accessCell( rowIndex, ttColIndex ) );
		else
			_table.accessCell( rowIndex, tdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, tdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ttColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ttColIndex ).backColor := noEntryColour;
		endif;
		
		_table.accessCell( rowIndex, uColIndex ).text := null;
		_table.accessCell( rowIndex, fdColIndex ).text := null;
		_table.accessCell( rowIndex, ftColIndex ).text := null;
		_table.accessCell( rowIndex, tdColIndex ).text := null;
		_table.accessCell( rowIndex, ttColIndex ).text := null;
		_table.accessCell( rowIndex, uColIndex ).itemObject := wodMarineServiceDet;
		if wodMarineServiceDet &lt;&gt; null then
			_table.accessCell( rowIndex, inclColIndex ).text := "1"; //Selected
			if wodMarineServiceDet.unitsUsed &gt; 0 then
				_table.accessCell( rowIndex, uColIndex ).text := wodMarineServiceDet.unitsUsed.asStringJMTWithPrecision( resourceType.numDecimalPlaces, false);
			endif;
			if wodMarineServiceDet.fromDateTime.date.isValid then
				localFromDT := self.systemToLocalTime( wodMarineServiceDet.fromDateTime );
				_table.accessCell( rowIndex, fdColIndex ).cellControl.CMUI_DateMask.setDate( localFromDT.date );
				_table.accessCell( rowIndex, fdColIndex ).text := localFromDT.date.asStringJMT;
				_table.accessCell( rowIndex, ftColIndex ).text := localFromDT.time.asStringJMT;
			endif;
			if wodMarineServiceDet.toDateTime.date.isValid then
				localToDT := self.systemToLocalTime( wodMarineServiceDet.toDateTime );
				_table.accessCell( rowIndex, tdColIndex ).cellControl.CMUI_DateMask.setDate( localToDT.date );
				_table.accessCell( rowIndex, tdColIndex ).text := localToDT.date.asStringJMT;
				_table.accessCell( rowIndex, ttColIndex ).text := localToDT.time.asStringJMT;
			endif;
		else
			_table.accessCell( rowIndex, inclColIndex ).text := "0"; // NOT Selected
		endif;
		
		if _wodExtension = null then	//19 Feb 2019	NDL	TFS 43374 - to include Wod Extension
			if _wodShiftMovement = null or _wodShiftMovement.allMarineServiceDetails.isEmpty then
				_table.accessCell( rowIndex, inclColIndex ).text := "1"; //Selected
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_wodShiftMovement" type="CM_WodShiftMovement"/>
        <Parameter name="_wodExtension" type="CM_WodExtension"/>
        <Parameter name="_resources" type="HMS_ResourceByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="populateAvailableWORels" id="9c767b0b-71d4-4e60-b449-7bccf1b22971">
        <source>populateAvailableWORels( _wodtl : CM_WodReleaseExtension );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

	wodDetail : CM_WorkOrderDtl;
	wo : CM_WorkOrder;
	iter : Iterator;
	startObject : CM_WorkOrder;
	prospects : CM_WorkOrderByIdDict;
	index : Integer;

begin

	self.cmbRelExtWORel.clear();
	self.cmbRelExtWORel.enabled := true;
	
	create prospects transient;  // The Cargo Release Work Orders that are seemingly in the right state to be allowed to be extended.
								// i.e. Cargo Releases that are Approvced or Part Complete 
	
	iter := self.myTerminal.allWorkOrdersByStatus.createIterator;
	startObject := self.myTerminal.allWorkOrdersByStatus.getAtKeyGeq( WO_STATUS_APPROVED );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( wo ) do
			if wo.taskStatus &lt;&gt; WO_STATUS_APPROVED then
				break;
			endif;
			if wo.isWorkOrderForRelease then
				prospects.addNoDuplicates( wo, false );
			endif;
		endwhile;
	endif;
	delete iter;
	
	iter := self.myTerminal.allWorkOrdersByStatus.createIterator;
	startObject := self.myTerminal.allWorkOrdersByStatus.getAtKeyGeq( WO_STATUS_PARTCOMPLETE );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( wo ) do
			if wo.taskStatus &lt;&gt; WO_STATUS_PARTCOMPLETE then
				break;
			endif;
			if wo.isWorkOrderForRelease then
				prospects.addNoDuplicates( wo, false );
			endif;
		endwhile;
	endif;
	delete iter;
	
	
	foreach wo in prospects discreteLock  do
		
		if not wo.allWoDtls.first.CM_WodRelease.isAvailableForExtension() then
			continue;
		endif;
		
		index := self.cmbRelExtWORel.addItem( wo.id );
		self.cmbRelExtWORel.itemObject[index] := wo.allWoDtls.first;
		
	endforeach;
	
	// And lastly include the one associated with the current Cargo Release Extension work order 
	// Because we may just be displaying one that is past the available for adding state. 
	if _wodtl &lt;&gt; null and _wodtl.myReleaseWorkOrder &lt;&gt; null then
		self.cmbRelExtWORel.enabled := false;
		index := self.cmbRelExtWORel.findObject( _wodtl.myReleaseWorkOrder );
		if index &lt; 1 then
			index := self.cmbRelExtWORel.addItem( _wodtl.getMyParent.id );
			self.cmbRelExtWORel.itemObject[index] := _wodtl.myReleaseWorkOrder;
		endif;
	endif;

epilog

	delete iter;
	delete prospects;

end;</source>
        <Parameter name="_wodtl" type="CM_WodReleaseExtension"/>
    </JadeMethod>
    <JadeMethod name="populateCmbDebtor" id="2968ccbe-f25c-4360-bca0-c544e1f860d5">
        <updating/>
        <source>populateCmbDebtor()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	debtor : CM_Debtor;
	drIndex : Integer;

begin

	self.debtorListForCombo := null;

	self.cmbDebtor.clear();
	foreach debtor in app.myRoot.myRootCompany.debtors do
		if debtor.consignors.isEmpty then
			continue;
		endif;
		self.cmbDebtor.itemObject[ self.cmbDebtor.addItem( debtor.name ) ] := debtor;
	endforeach;
	
	if self.cmbDebtor.listCount &gt; 0 then
		foreach drIndex in 1 to self.cmbDebtor.listCount do
			if drIndex &gt; 1 then
				self.debtorListForCombo := self.debtorListForCombo &amp; Tab;
			endif;
			self.debtorListForCombo := self.debtorListForCombo &amp; self.cmbDebtor.itemText[ drIndex ];
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateOOWConfirm" id="f780b7d3-5ae7-41a6-a0ea-bb51d2be703c">
        <source>populateOOWConfirm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlger1	Initial creation

*/

vars
	dynaDict : DynaDictionary;
	holdId : String;
	obj : Object;
	job : CM_Job;
	holdJob : CM_VoyageHoldJob;
	comboValues : String; 
begin
	self.setupOOWConfirmTable();
	
	create dynaDict transient;
	dynaDict.setMembership( CM_VoyageHoldJob );
	dynaDict.addExternalKey(String, 100, false, false);
	dynaDict.endKeys(true);
	
	foreach job in self.myVoyage.allVoyageJobs do
		if job.isKindOf(CM_VoyageHoldJob) then
			if job.status &lt;&gt; JOB_COMPLETE then
				dynaDict.putAtKey(job.CM_VoyageHoldJob.getHoldId, job);
			endif;
		endif;
	endforeach;
	
	foreach obj in dynaDict do
		holdJob := obj.CM_VoyageHoldJob;
		if holdId &lt;&gt; null then
			//we have loaded at least one
			if holdId &lt;&gt; holdJob.getHoldId then
				self.addHoldSubTotalLine( holdId );
			endif;
		endif;
		self.addHoldJobToOOWConfrm( holdJob, comboValues );
		holdId := holdJob.getHoldId;
	endforeach;
	
	if holdId &lt;&gt; null then
		self.addHoldSubTotalLine( holdId );
	endif;
	
	self.setPermitTotalDays(false);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshFromChildSourceForm" id="719679db-fd72-41b0-bd74-559e29b5d331">
        <source>refreshFromChildSourceForm();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
08 January 2010	cnwrd1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	loadStateSet : Boolean;
	workOrder : CM_WorkOrder;
	pxyWOSource : CM_WorkOrderTISource;
	task : CM_WorkOrderDtl;
	cargoType : CM_CargoType;
begin
	task := self.lstTasks.listObject.CM_WorkOrderDtl;

	workOrder := self.myProxyWorkOrder;
	
	task := self.lstTasks.listObject.CM_WorkOrderDtl;
	pxyWOSource := task.CM_WodPack.mySource;
	

	//Note: No cancel functionality for Add is allowed for. This is done on purpose.
	//Having to allow for the cancel would require a copy of the proxy to be made
	//if frm.modalResult = IDOK and self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
	if self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
		self.displayPackSource(task.CM_WodPack);
	elseif self.mode = self.Mode_Update then 
		//Either cancel has been presssed or an update on the persistent source has occurred.  
		//Refresh from persistent source in both cases.  
		//This is so that:
		//1. In the event of updating a persistent object the latest edition of the real object is retreived 
		//2. In the event of a cancel, any changes to the proxies has been backed out of
		
		app.cmsBeginLoad(loadStateSet);
		
		delete pxyWOSource;
		
		pxyWOSource := self.setProxyWorkOrderSource(task.CM_WodPack);
		self.displayPackSource(task.CM_WodPack);
		
		app.cmsEndLoad(loadStateSet);
	endif;
	
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
end;
</source>
    </JadeMethod>
    <JadeMethod name="selectPermitFor" id="fe243034-d766-4b44-bf46-cfc5db2f610c">
        <source>selectPermitFor();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlger1	Initial creation 41880

*/

vars
	permitFor : Integer;
	permitWOD : CM_WorkOrderVoyageDtl;
	iter : Iterator;
	workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin
	if not self.cmbRelatedWO.visible then
		return;
	endif;
	
	self.cmbRelatedWO.clear;
	permitFor:=	self.cmbPermitFor.listData;
	
	if self.myCurrentProxyTask &lt;&gt; null and self.myCurrentProxyTask.CM_WodPermitRequest.pxyGetRealObject &lt;&gt; null then
		permitWOD:=self.myCurrentProxyTask.CM_WodPermitRequest.pxyGetRealObject.myPermitWodVoyageDetail;
		if permitWOD &lt;&gt; null then
			self.cmbRelatedWO.addItemObject(permitWOD.getDisplayString(false), permitWOD);
			self.cmbRelatedWO.setIndex(1);
			return;
		endif;
	endif;
	
	if permitFor &lt;&gt; WO_TASK_EXTENSION and permitFor &lt;&gt; WO_TASK_SHIFTMOVEMENT and permitFor &lt;&gt; WO_TASK_MARINEINITIAL then
		return;
	endif;
	
	iter:= self.myVoyage.allWorkOrders.createIterator;
	
	while iter.next(workOrder) do
		if workOrder.taskStatus = WO_STATUS_CANCELLED then
			continue;
		endif;
		if workOrder.taskStatus &lt;&gt; WO_STATUS_PENDING and 
			workOrder.taskStatus &lt;&gt; WO_STATUS_USERENTRY then
			continue;
		endif;
		foreach workOrderDetail in workOrder.allWoDtls discreteLock do
			if   workOrderDetail.detailType &lt;&gt; permitFor  then
				continue;
			endif;
			if workOrderDetail.CM_WorkOrderVoyageDtl.myRelatedPermitRequest &lt;&gt; null and 
				workOrderDetail.CM_WorkOrderVoyageDtl.myRelatedPermitRequest &lt;&gt; permitWOD then
				continue;
			endif;
			self.cmbRelatedWO.addItemObject(workOrderDetail.getDisplayString(false), workOrderDetail);
		endforeach;	
	endwhile;
	
	if self.cmbRelatedWO.listCount = 1 then
		self.cmbRelatedWO.setIndex(1);
		
	endif;	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectPermitType" id="b5b5eaeb-c53c-4f0e-8469-148871ad3e14">
        <source>selectPermitType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlger1	Initial creation

*/

vars
	permitType : Integer;
	comboValues : String; 
begin
	permitType:=self.cmbPermitType.listData;
	self.cmbPermitFor.visible:= true;  //now visible for everything
	self.lblPermitFor.visible:=self.cmbPermitFor.visible;
	self.cmbPermitOperator.visible:=false;
	self.lblPermitOperator.visible:=false;
	self.cmbRelatedWO.visible:=true;
	self.lblRelatedWO.visible:=true;
	if permitType = INV_WO_PERMIT_CARGONOPENALTY or permitType = INV_WO_PERMIT_CARGOPENALTY then
		self.lblPermitOperator.visible:=true;
		self.cmbPermitOperator.visible:=true;
	endif;
	
	self.cmbPermitFor.clear;
	//jlier TFS 52305 8/11/21	
	/*if permitType = INV_WO_PERMIT_MANUALETMAL then
		
		self.cmbPermitFor.addItemWithData(app.getErrorString(Voyage_initial_marine_service), WO_TASK_MARINEINITIAL);
	endif;*/
	self.cmbPermitFor.addItemWithData(app.getErrorString(Voyage_shift_movement), WO_TASK_SHIFTMOVEMENT);
	self.cmbPermitFor.addItemWithData(app.getErrorString(Voyage_extension), WO_TASK_EXTENSION);
	self.tblOOWConfirm.visible:=false;
	if permitType = INV_WO_PERMIT_CONTINUEPENALTY or
		permitType = INV_WO_PERMIT_CONTINUNOPENALTY then
		//epr TFS 42342 4/12/18
		self.cmbRelatedWO.visible:=false;
		self.lblRelatedWO.visible:=false;
		self.populateOOWConfirm();
	endif;
	
	

	

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setActiveTab" id="33f37b00-1eac-4ef2-b801-1a3374a0291d">
        <source>setActiveTab();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	wod 		: CM_WorkOrderDtl;
	workOrder	: CM_WorkOrder;
begin
	
	self.fldDetails.tabsHeight 	 := 0;
	self.fldDetails.tabsPosition := 0; // top
	
	wod 		:= self.myCurrentProxyTask;
	workOrder	:= self.myProxyWorkOrder;
	
	
	self.shtMove.visible 		  := false;
	self.shtPack.visible 		  := false;
	self.shtUnpack.visible 		  := false;
	self.shtReceival.visible      := false;
	self.shtRelease.visible       := false;
	self.shtShift.visible         := false;
	self.shtCargoRequest.visible  := false;
	self.shtTimeChange.visible    := false;
	self.shtExtension.visible     := false;
	self.shtWaterRequest.visible  := false;
	self.shtHMSCancel.visible     := false;
	self.shtMarineI.visible       := false;
	self.shtMarineD.visible       := false;
	self.shtBlank.visible         := false;
	self.shtVoyageRequest.visible := false;
	self.shtPermit.visible        := false;
	self.shtBillingAdj.visible    := false;
	self.shtRelExtension.visible  := false;
	self.shtToDo.visible          := false;
	self.shtNullVoyage.visible    := false;
	
	if workOrder.isKindOf(CM_WorkOrderTI) then
		if wod.isKindOf(CM_WodExportReturn) then
			self.shtBlank.visible 		 := true;
			self.fldDetails.topSheet     := self.shtBlank;
		elseif wod.isKindOf(CM_WodMove) then
			self.shtMove.visible 		 := true;
			self.fldDetails.topSheet     := self.shtMove;
		elseif wod.isKindOf(CM_WodNullVoyage) then
			self.shtNullVoyage.visible 	 := true;
			self.fldDetails.topSheet     := self.shtNullVoyage;
		elseif wod.isKindOf(CM_WodPack) then
			self.shtPack.visible 		 := true;
			self.fldDetails.topSheet     := self.shtPack;
		elseif wod.isKindOf(CM_WodReceive) then
			self.shtReceival.visible     := true;
			self.fldDetails.topSheet     := self.shtReceival;
		elseif wod.isKindOf(CM_WodRelease) then
			self.shtRelease.visible     := true;
			self.fldDetails.topSheet     := self.shtRelease;
		elseif wod.isKindOf(CM_WodReleaseExtension) then
			self.shtRelExtension.visible     := true;
			self.fldDetails.topSheet     := self.shtRelExtension;
		elseif wod.isKindOf(CM_WodToDo) then
			self.shtToDo.visible      := true;
			self.fldDetails.topSheet  := self.shtToDo;
		elseif wod.isKindOf(CM_WodUnpack) then
			self.shtUnpack.visible 		 := true;
			self.fldDetails.topSheet     := self.shtUnpack;
		endif;
		
	elseif workOrder.isKindOf(CM_WorkOrderVoyage) then
		if wod.isKindOf(CM_WodBillingAdjustment) then
			self.shtBillingAdj.visible 	  := true;
			self.fldDetails.topSheet      := self.shtBillingAdj;
		elseif wod.isKindOf(CM_WodCargoRequest) then                 //??
			self.shtCargoRequest.visible  := true;
			self.fldDetails.topSheet      := shtCargoRequest;
		elseif wod.isKindOf(CM_WodExtension) then
			self.shtExtension.visible 	 := true;
			self.fldDetails.topSheet     := shtExtension;
		elseif wod.isKindOf(CM_WodHMSRequestCancel) then
			self.shtHMSCancel.visible 	 := true;
			self.fldDetails.topSheet     := shtHMSCancel;
		//elseif wod.isKindOf(CM_WodMarineServiceDetail) then  //??
		elseif wod.isKindOf(CM_WodMarineServicesDepart) then
			self.shtMarineD.visible 	 := true;
			self.fldDetails.topSheet     := shtMarineD;	
		elseif wod.isKindOf(CM_WodMarineServicesInitial) then
			self.shtMarineI.visible 	 := true;
			self.fldDetails.topSheet     := shtMarineI;	
		elseif wod.isKindOf(CM_WodPermitRequest) then
			self.shtPermit.visible 	 	 := true;
			self.fldDetails.topSheet 	 := shtPermit;
		elseif wod.isKindOf(CM_WodShiftMovement) then
			self.shtShift.visible 	 	 := true;
			self.fldDetails.topSheet 	 := shtShift;
		elseif wod.isKindOf(CM_WodTimeChange) then
			self.shtTimeChange.visible 	 := true;
			self.fldDetails.topSheet 	 := shtTimeChange;
		elseif wod.isKindOf(CM_WodVoyageCargoRequest) then //??
			self.shtCargoRequest.visible := true;
			self.fldDetails.topSheet 	 := shtCargoRequest;	
		elseif wod.isKindOf(CM_WodVoyageRequest) then 
			self.shtVoyageRequest.visible := true;
			self.fldDetails.topSheet 	 := shtVoyageRequest;	
		elseif wod.isKindOf(CM_WodWaterRequest) then 
			self.shtWaterRequest.visible := true;
			self.fldDetails.topSheet 	 := shtWaterRequest;	
		endif;
	endif;
	
	self.fldDetails.topSheet.caption := self.lstTasks.text;
	//self.fraTaskBottom_1.top := 56;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForViewMode" id="01df38be-f6af-4707-9ad3-8d2d73970950">
        <source>setControlsForViewMode() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/08/2009	cnwmd1	Initial creation
24/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
10/09/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
	mde 			: Integer;
	allowSourceEdit : Boolean;
begin
	mde := self.mode;
	
	if self.workOrderMode = WorkOrderMode_Cargo then				// TFS 38560
		if self.myCurrentProxyTask &lt;&gt; null and self.myCurrentProxyTask.detailType = WO_TASK_PACK then
			// do some pack task source stuff
			allowSourceEdit := not self.myCurrentProxyTask.CM_WodPack.mySource.hasNonIDSource();
			
			self.txtPackCargo.visible 	  := allowSourceEdit;
			self.cmbPackCargoType.enabled := allowSourceEdit;
			self.tbPackCargo.visible 	  := not allowSourceEdit;	
			self.cmbPackCargoType.visible := allowSourceEdit;	
			self.lblPackCargoType.visible := allowSourceEdit;	
			self.txtPackCargo.enabled     := false;					//10.09.2021 navma1 #51002
		endif;
	endif;															// TFS 38560

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultsCallBack" id="2e2b3e62-7118-42ee-a4e0-f4d52c59e513">
        <source>setDefaultsCallBack(pTbl : CM_EntryTable input; pAttrName : String; pRow : Integer; pObj : Object): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07/01/2010	cnwrd1	Initial creation
21/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
01/02/2023  navma1	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	str				: String;
	rtnCode			: Boolean;
	tmpInt			: Integer;
	woDTL 			: CM_WorkOrderDtl;				// TFS 38560
begin
	
	woDTL := pObj.CM_WorkOrderDtl;					// TFS 38560
	
	rtnCode := true;
	
	
	if pAttrName = ETRow_TaskID then
		str := woDTL.taskID;
	endif;																		// TFS 38560
	
	if woDTL.isKindOf(CM_WorkOrderTIDtl) then									// TFS 38560
		if pAttrName = ETRow_TaskTotalRequired then
			str := woDTL.myParent.getTotalRequired().asStringJMT();
		elseif pAttrName = ETRow_TaskTotalPlanned then
			//str := woDTL.CM_WorkOrderTIDtl.totalPlanned.asStringJMT();		// TFS 38560  //01.02.2023 navma1 #56141 Task#56147
		elseif pAttrName = ETRow_TaskTotalActioned then
			str := woDTL.CM_WorkOrderTIDtl.totalActioned.asStringJMT();			// TFS 38560
		elseif pAttrName = ETRow_TaskTotalComplete then
			str := woDTL.CM_WorkOrderTIDtl.totalComplete.asStringJMT();			// TFS 38560
		elseif pAttrName = ETRow_TaskTotalAvailable then
			str := woDTL.CM_WorkOrderTIDtl.allAvailableTIs.size.asStringJMT();	// TFS 38560
		endif;
	else
		rtnCode := false;
	endif;	
	
	if str &lt;&gt; null then
		pTbl.setValue(pRow, str);
	endif;
	
	return rtnCode;
epilog

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
