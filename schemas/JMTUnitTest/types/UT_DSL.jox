    <JadeMethod name="deleteBookingObj" id="b7381d31-9cb3-490b-abf9-d895381f0fe5">
        <source>deleteBookingObj(_booking: CM_BookingRef);
//18 December 2008	cnwdw1	
//
vars
	item: CM_BookingRefItem;
	col : Collection;
begin
	///if not process.isInTransactionState then
		beginTransaction;
	///endif;
	foreach item in _booking.allBookingRefItems do
		item.allTIHazards.rebuild;
		if not global.isValidObject(item.myProduct) then					// 18/08/2015 cnwmh5
			item.setMyProduct(null);
		endif;
	endforeach;
	col := _booking.allWorkOrderSources;
	col.purge();
	commitTransaction;

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxDA.trxDeleteBookingRef(_booking, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;</source>
