    <JadeMethod name="resetCOOTransferredAmounts" id="5879bb33-e5ab-44c2-9933-75a5e8e8b91e">
        <updating/>
        <source>resetCOOTransferredAmounts(_detail : CM_OwnershipChangeDetail input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 13MAY2024
ADO -  BUG 64115
*/


vars
	subDetail : CM_OwnershipChangeDetail;
	transferredVolume, transferredWeight : Decimal[23,4];
	transferredQuantity : Integer;
begin

	if _detail.allSubDetails.isNotEmpty() then // if they have un included any sub details re set the main detail (cargo group)
		_detail.setProxyTransfers(0,0,0,_detail.included);
		foreach subDetail in _detail.allSubDetails discreteLock do
			if subDetail.isIncluded() then
				transferredVolume := transferredVolume + subDetail.transferredVolume;
				transferredWeight := transferredWeight + subDetail.transferredWeight;
				transferredQuantity := transferredQuantity + subDetail.transferredQuantity;
			endif;
		
		endforeach;
		_detail.setProxyTransfers(transferredWeight,transferredVolume,transferredQuantity,_detail.included);
	endif;
end;</source>
        <Parameter name="_detail" type="CM_OwnershipChangeDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="4217b73a-1614-452c-a753-2c9d9d72da1b">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <source>saveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_CMUI_TrackedItems interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2023 navmv20 CR 58233 Task 58236: UI - Add Item
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars
	pxyOwnershipDetail : CM_OwnershipChangeDetail;
	ti, myTrackedItem : CM_TrackedItem;
	cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail;
	detailSet : CM_OwnershipChangeDetailSet;
	theReturn : Integer;
	storageDetail : CM_StorageDetail;
	totalWeight,
	totalVolume : Decimal[14,4]; //11/08/2023 navmv20 Bug 59697
	totalQuantity : Integer; //11/08/2023 navmv20 Bug 59697
begin
	if _allTIs = null or _allTIs.isEmpty then
		return true;
	endif;
	
	create cmifOwnershipChangeDtl transient;
	create detailSet transient;
	
	foreach ti in _allTIs do
		create pxyOwnershipDetail transient;
		//11/08/2023 navmv20 Bug 59697 - start
		totalWeight := ti.getOnSiteOnShipWeight();
		totalVolume := ti.getOnSiteOnShipVolume();
		totalQuantity := ti.getOnSiteOnShipQuantity();
		//pxyOwnershipDetail.setProxy(ti.totalWeight,ti.totalVolume,ti.totalQuantity,true,self.myOwnershipChange,null,ti);
		pxyOwnershipDetail.setProxy(totalWeight,totalVolume,totalQuantity,true,self.myOwnershipChange,null,ti);
		//11/08/2023 navmv20 Bug 59697 - end
		detailSet.add(pxyOwnershipDetail);
	endforeach;
	
	detailSet.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	
	while true do
		app.myTrxCA.trxCreateOwnershipChangeDtls(cmifOwnershipChangeDtl,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownership_change_details), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
			
		break;
	endwhile;
	
	self.getFreeStorageForNewOperator();//19 July 2023 navmv20 CR 58239 Task 58241
	self.getFreeStorageForOldOperator();//19 July 2023 navmv20 CR 58239 Task 58241
	self.getFreeStoExpForOldOperator(); //20/05/2024	navkc1 Bug 64186
	self.getFreeStoExpForOriOperator();//20/05/2024	navkc1 Bug 64186
	
	self.displayStatus();
	return true;

epilog
	delete cmifOwnershipChangeDtl;
	delete detailSet;
end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
