    <JadeMethod name="displayEntryTerminal" id="e24dca40-d6d3-4c3a-a2a3-7c773ff3d813">
        <source>displayEntryTerminal(_terminal : Object) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars
	returnVal		: String;
	
begin
	if _terminal = null then
		return null;
	endif;
	
	returnVal := _terminal.getPropertyValue("code").String;
	returnVal := returnVal &amp; " - " &amp; _terminal.getPropertyValue("name").String;
	
	return returnVal;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
