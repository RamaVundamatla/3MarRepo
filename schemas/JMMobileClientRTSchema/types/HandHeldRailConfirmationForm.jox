        <source>txtWagonPos_change(textbox: TextBox input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	posID		: String;
begin
	posID := textbox.text.trimBlanks();
	if posID.length &gt;= 1 and self.txtWagonIn.text = null then // vehicleID &lt;&gt; self.previousWagonIDIn then
	//	self.clearInwardInfo();
		delete self.myDTOWagonIn;
		create self.myDTOWagonIn transient;
		self.maxCloneButtonsIn := 1;
		self.txtWagonIn.text := null;
		self.lblJobInfoIn.caption := null;
		
		self.doGetWagonDetailsIn(null);
		//self.previousWagonIDIn := vehicleID;
	endif;


epilog

end;</source>
