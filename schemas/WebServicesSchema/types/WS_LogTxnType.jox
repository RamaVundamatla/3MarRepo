<Class name="WS_LogTxnType" id="b7ad8065-de1a-47a7-a71a-62afe1b31757">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A transaction type that is applicable for logs</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="b4889e40-ea14-41eb-a2c7-4bc4810a46c1">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Transaction Type Code</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="9b8dfd89-8937-4f5a-83f8-2b781acb6599">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Transaction Type Description. ex. 57 = Disassembly , 65 = No-Number Swap</text>
    </PrimAttribute>
    <JadeMethod name="setDetails" id="b0bc2513-14fb-4fe6-bb43-b07b24c2469e">
        <updating/>
        <source>setDetails(description : String; code : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars

begin
	self.cmObjectId 	:= code.String;
	self.code			:= code;
	self.description	:= description;
epilog

end;</source>
        <Parameter name="description" type="String"/>
        <Parameter name="code" type="Integer"/>
    </JadeMethod>
</Class>
