    <JadeMethod name="comboBoxMoveMode" id="e3925007-250c-439f-b3cb-ae7144f63e94">
        <source>comboBoxMoveMode(pTbl : CM_EntryTable input; pAttrName : String; _moveMode : Integer);
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	cmb : ComboBox;
	idx,
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	cmb := pTbl.accessCell(row, pTbl.ColumnValue).cellControl.ComboBox;
	
	//str := 'Instant Move' &amp; Tab &amp; 'Queued Move' &amp; Tab &amp; 'Planned Move' &amp; Tab &amp; 'Auto Planned Queued Move';
	str :=  app.getErrorString(Instant_Move) &amp; Tab &amp; app.getErrorString(Queued_Move) &amp; Tab &amp; app.getErrorString(Planned_Move) &amp; Tab &amp; app.getErrorString(Auto_Planned_Queued_Move);
	
	pTbl.accessCell(row, pTbl.ColumnValue).comboList := str;
//	cmb.addItemAt('Instant Move', 1);	
//	cmb.itemData[1] := REAL_MODE;
//	cmb.addItemAt('Queued Move', 2);		
//	cmb.itemData[2] := QUEUE_MODE;
//	cmb.addItemAt('Planned Move', 3);		
//	cmb.itemData[3] := PLANNING_MODE;
//	cmb.addItemAt('Auto Planned Queued Move', 4);		
//	cmb.itemData[4] := AUTO_PLAN_MODE;
	
	str := app.moveModeStatusEnumToString(_moveMode);
/*	if _moveMode = REAL_MODE then
		cmb.listIndex := 1;
	elseif _moveMode = QUEUE_MODE then
		cmb.listIndex := 2;	
	elseif _moveMode = PLANNING_MODE then
		cmb.listIndex := 3;	
	elseif _moveMode = AUTO_PLAN_MODE then
		cmb.listIndex := 4;
	else
		cmb.listIndex := 1;	
	endif;*/
	
	pTbl.accessCell(row, pTbl.ColumnValue).text := str;
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxMoveModeSpecific" id="ccdaefc9-fdfc-431a-9a1f-97faac8191bb">
        <source>comboBoxMoveModeSpecific(pTbl : CM_EntryTable input; pAttrName : String; _moveMode : Integer; _str : String);
/*
----------   ----------  --------------------------------------------------
Created:	06 December 2006 By cnwmo1

Purpose:	_str is passed to specify particular modes to be displayed e.g. 
			'Instant Move' &amp; Tab &amp; 'Queued Move' &amp; Tab &amp; 'Planned Move' &amp; Tab &amp; 'Auto Planned Queued Move';


Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb : ComboBox;
	idx,
	row : Integer;
	str : String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	cmb := pTbl.accessCell(row, pTbl.ColumnValue).cellControl.ComboBox;
	pTbl.accessCell(row, pTbl.ColumnValue).comboList := _str;
	str := app.moveModeStatusEnumToString(_moveMode);
	pTbl.accessCell(row, pTbl.ColumnValue).text := str;
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxOperator" id="dc4b28b4-92d1-498a-8746-d9cf28c763cb">
        <source>comboBoxOperator(_cmb : ComboBox input; 
				_operator : CM_Operator;
				_voyage : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   24th June by CNWTH2 to consider user data access, and CM_Operator.isNotAvailableForEntry
// ----------   ----------  --------------------------------------------------
// 08/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------
vars
	col				: CM_OperatorByCodeDict;
	tmpOperator		: CM_Operator;
	any				: Any;
	passport		: CM_Passport;
	tmpStr			: String;
	idx,
	keepIdx			: Integer;
	failedDAC  :CM_DataAccessController;
	descFirst : Boolean;			// TFS 53362
begin

//** 	for controls changed to CMUI_ComboboxObjets - once all changed will comment out remaining code 
	if _cmb.isKindOf(CMUI_ComboOperator) then 
		_cmb.CMUI_ComboOperator.resetCollectionForVoyage(_voyage);
		return; // other stuffed handled by comboOhbject methods
	endif;
//**

	_cmb.clear();
	// do not sort as collection is already sorted
	_cmb.sorted := false;	

	if _voyage = null 
	or _voyage.isNullVoyage then
		col := app.myRoot.allOperators;
	else
		col := _voyage.allOperators;
	endif;
	
	passport := app.myPassport;
	// TFS 53362 combo needs to be sorted if we're viewing description first
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then
		descFirst := true;
		_cmb.sorted := true;
	endif;
	// TFS 53362 end of this bit
	
	foreach tmpOperator in col do
		//if we don't have access to the operator passed in, list it - it SHOULD be included regardless
		if ((not tmpOperator.canUserAccessSelf(null, failedDAC, passport)) 
		or (tmpOperator.isNotAvailableForEntry)) 
		and (tmpOperator &lt;&gt; _operator) then
			continue;
		endif;
		
		// Already done the checks above
		// don't call displayEntryOperator as it may return null for _operator
		// and _operator must be included in the combobox
		if descFirst then													// TFS 53362
			tmpStr := tmpOperator.description &amp; Tab &amp; tmpOperator.code;		// TFS 53362
		else																// TFS 53362
			tmpStr := tmpOperator.code &amp; Tab &amp; tmpOperator.description;
		endif;																// TFS 53362
		idx := _cmb.addItem(tmpStr);
		_cmb.itemObject[idx] := tmpOperator;

	endforeach;

	if _operator &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_operator);
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="comboBoxOperatorCashOnlyDr" id="3bf03e1c-64d5-41ea-a3c3-c8dae3180498">
        <source>comboBoxOperatorCashOnlyDr(_combo : ComboBox input; _voyage : CM_Voyage; _operator : CM_Operator; _term : CM_Terminal );
/*
Purpose:		TFS 37454	
Date				Who			Reason
MARCH 2018		CNWAB1		Initial creation
*/


vars
	operator : CM_Operator;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	terminal : CM_Terminal;
	ops : CM_OperatorByCodeDict;
begin

	_combo.clear();
	
	passport	:= app.myPassport;
	terminal := _term;
	if terminal = null and passport &lt;&gt; null then
		terminal := passport.myTerminal;
	endif;

	ops :=  app.myRoot.allOperators;

	if _voyage &lt;&gt; null then
		ops := _voyage.allOperators;
	endif;
	
	foreach operator in ops do
		//if we don't have access to the consign passed in, list it - it SHOULD be included regardless
		if (not operator.canUserAccessSelf(null, failedDAC, passport) or operator.isNotAvailableForEntry) and (operator &lt;&gt; _operator) then
			continue;
		endif;
			
		if operator.debtor = null or not operator.debtor.isCashOnlyDebtor( terminal ) then
			continue;
		endif;
		
		_combo.itemObject[_combo.addItem(self.displayEntryOperator(operator))] := operator;
	endforeach;
	
	if _operator &lt;&gt; null and _combo.findObject(_operator) &gt; 0 then
		_combo.listObject := _operator;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxOperatorGroup" id="eb0cf430-5b94-422b-a2ce-6484c06be108">
        <source>comboBoxOperatorGroup(_cmb : ComboBox input; 
						_operatorGroup : CM_OperatorGroup;
						_isForEntry : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Updated : 	28 May 2004 CNWTH2 - isForEntry determinds whether or not to include those operator groups
//				flagged as being not available for entry (in other words for searching purposes only)
//				CCMS#1207
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	opGroup				: CM_OperatorGroup;
	opGroupDict			: CM_OperatorGroupByCodeDict;
	found				: Boolean;
	str					: String;
begin

	_cmb.clear();
	_cmb.sorted := false;
	
	opGroupDict := app.myRoot.allOperatorGroups;
	
	foreach opGroup in opGroupDict do
		if (not opGroup.isAvailableForEntry and _isForEntry) then
			continue;
		endif;
		
		//This is passing _operatorGroup to displayEntryOperatorGroup on each iteration 
		/*_cmb.itemObject[_cmb.addItem(self.displayEntryOperatorGroup(_operatorGroup))] := opGroup;
		if opGroup = _operatorGroup then
			found := true;
		endif;*/
		
		//Now
		str := self.displayEntryOperatorGroup(opGroup);
		if str &lt;&gt; null then
			_cmb.itemObject[_cmb.addItem(str)] := opGroup;
			if opGroup = _operatorGroup then
				found := true;
			endif;
		endif;
				
	endforeach;
	
	if found then
		_cmb.text := self.displayEntryOperatorGroup(_operatorGroup);
		_cmb.listObject := _operatorGroup;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_isForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxOperatorShippingLine" id="37e2b08e-0c8f-41d5-8943-4f57885c6537">
        <source>comboBoxOperatorShippingLine(pCmb : CMUI_ComboBox input; 
							_operator : CM_Operator;
							_shippingLine : CM_ShippingLine);
//-----------------------------------------
// Created: 12 Septembre 2003 By: cnwgd1
//-----------------------------------------
vars
	idx : Integer;
	tmpStr : String;
	tmpOperator : CM_Operator;
	operDict : CM_OperatorByCodeDict;
	passport : CM_Passport;
begin

	pCmb.clear();
	
	if _shippingLine = null then
		return;
	endif;
	
	create operDict transient;
	_shippingLine.getAllOperators(operDict); //operators;
	
	if _operator &lt;&gt; null then
		if (not operDict.includes(_operator)) then
			operDict.add(_operator); //&lt;&lt;-- add additional operator as it may be the default vessel operator.
		endif;
	endif;
	
	self.comboBoxVoyageOperatorWithCol(pCmb, _operator, operDict);

epilog
	delete operDict;
end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
