    <JadeMethod name="isCoastal_Match" id="2a0d1e6e-a5a2-457e-b0ab-1531529ddc1b">
        <source>isCoastal_Match(_yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsCoastal );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;
		
	// Return true regardless.
	return true;


end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isColour_Match" id="4f2abe3e-2d33-4d36-8c21-a9538f2ab0c1">
        <source>isColour_Match(_yaData: CM_YADataString): Boolean;
vars

	yaData : CM_YAData;
	yaDataString : CM_YADataString;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_Colour );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataString) then
		yaDataString := yaData.CM_YADataString;
		if yaDataString &lt;&gt; null then
			return _yaData.doesValueMatch( yaDataString.value );
		endif;
	endif;
		
	return _yaData.doesValueMatch(self.colour);
	
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCommReefer_Match" id="cacb7bb6-5bb2-42fb-8844-35a0c559269c">
        <source>isCommReefer_Match(_yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	isReefer : Boolean;
	isoType : CM_ISOType;
	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsReefer );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;


	//23 Mar 2015	NDL	Par 35886
	if self.myCargoType = null then
		return true;
	else
		if self.myCargoType.id = TI_CargoType_Container then
			isoType := self.getISOTypeFromRequest();
			if isoType &lt;&gt; null then
				isReefer := isoType.isReefer;
			else
				isReefer := false;
			endif;
		elseif self.myCargoType.mySystemProductType &lt;&gt; null then
			isReefer := self.myCargoType.mySystemProductType.isReefer;
		else
			isReefer := false;
		endif;
	endif;
	
	return _yaData.doesValueMatch(isReefer);


end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCommodityGroup_Match" id="b28c6a51-2ecd-43ed-b6c1-de0fb868318f">
        <source>isCommodityGroup_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	commodityGroup : CM_CommodityGroup;

begin

	// Take a look anyway.
	if self.myCommodity = null then
		return true;
	endif;
	
	commodityGroup := self.myCommodity.myCommodityGroup;
	
	// Take a look anyway.
	if commodityGroup = null then
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(commodityGroup);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCommodity_Match" id="eb8ea9ef-b053-4675-9fce-238ac98fd5b3">
        <source>isCommodity_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// 19 Nov 2024 navlc30 JIRA 33242 EUP | Kiosk - Default Additional question shown with incorrect subtype and commodity
// -------------------------------------------
vars

begin

	// We let yard delivery requests through.
	if self.isDeliveryRequest and self.myCommodity = null then
		return true;
	endif;
	
	// Take a look anyway.
	if self.myCommodity = null and not _yaData.myYAParent.isYAKioskCriteria() then				//19.11.2024 navlc30 #33242
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(self.myCommodity);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isConsignee_Compare" id="346ad3fc-0790-4d4f-b3da-5c498ad6c816">
        <source>isConsignee_Compare(object: Object;code: String): Boolean;
begin
	return object.CM_ConsigneeConsignor.code.trimBlanks() = code;
end;</source>
