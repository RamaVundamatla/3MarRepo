<Class name="CM_DeckVoyageSub" id="bb3d1b8c-dd94-4a5f-bd6b-d4a25d0e14f1">
    <superclass name="CM_DeckVoyage"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyageStructures"/>
    <ExplicitInverseRef name="myParentDeck" id="40b3efbf-e1e3-47c0-a70e-bee793d95d29">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DeckVoyage"/>
        <access>readonly</access>
        <Inverse name="CM_DeckVoyage::allSubDecks"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelfSub" id="07152de5-a640-4d1f-89e1-f4ccd167fb4b">
        <source>cloneMySelfSub(_parentDeck : CM_DeckVoyage;_clearCode : Boolean; _copy : Boolean): CM_DeckVoyageSub;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Mar 2011	cnwer1	Initial creation
16 May 2011 cnwer1	27486 - no need to set the roro vessel structure as it is derived from its parent
*/

vars
	newDeck : CM_DeckVoyageSub;
begin
	newDeck := self.cloneSelf(_copy);
	newDeck.setMyParentDeck(_parentDeck);
	
	if _clearCode then
		newDeck.code:=null;
	endif;
	

	self.cloneMySelfSuper(newDeck, _copy);

	

	return newDeck;
epilog

end;</source>
        <Parameter name="_parentDeck" type="CM_DeckVoyage"/>
        <Parameter name="_clearCode" type="Boolean"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckVoyageSub"/>
    </JadeMethod>
    <JadeMethod name="delete" id="697f7642-49f2-4ab6-b5f4-9c244a2e2154">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	roroStructure : CM_ROROVoyageStructure;
begin
	if self.isTransient then
		return;
	endif;
	
	if self.myParentDeck &lt;&gt; null then
		roroStructure:=self.myParentDeck.myVoyageStructure;
		if roroStructure &lt;&gt; null then
			roroStructure.causeEvent(EVENT_VESSEL_DECK_DELETE,false,self);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getROROStructure" id="7170eab2-7822-4867-9f92-545c7a07333b">
        <source>getROROStructure(): CM_ROROVoyageStructure;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myParentDeck &lt;&gt; null then
		return self.myParentDeck.myVoyageStructure;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="CM_ROROVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="be3708d2-196f-4e41-9826-7bcfe6813809">
        <source>getVoyage(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myParentDeck.getVoyage();

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="isSubDeck" id="4b1ae083-6127-4dbb-b6f1-7f27e24f8797">
        <source>isSubDeck(): Boolean;
/*
Purpose:			
Date		Who		Reason
17 October 2011	cnwab1	Initial creation
*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7249c4d6-07cd-4232-8cb3-653021384f34">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxySubDeck : CM_DeckVoyageSub;
	completedOK		: Boolean;
begin
	pxySubDeck:= inheritMethod();
	pxySubDeck.myParentDeck:=self.myParentDeck;
	
	completedOK := true;			
	return pxySubDeck;
epilog
	if not completedOK then			
		delete pxySubDeck;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a132ac44-b46f-444c-addf-4a00a43298cf">
        <updating/>
        <source>setForCreate(_proxyDeck: CM_DeckVoyageSub input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1116

*/

vars
	lastDeck : CM_Deck;	
	realParentDeck : CM_DeckVoyage;
begin
	
	realParentDeck:=_proxyDeck.myParentDeck;
	if realParentDeck.isTransient then
		realParentDeck :=realParentDeck.pxyGetRealObject();
	endif;
	
	
	self.myParentDeck:=realParentDeck;
	
	lastDeck:= self.myParentDeck.allSubDecks.last;
	if lastDeck = null then
		self.ordinal:=1;
	else
		self.ordinal:=lastDeck.ordinal+1;
	endif;
	
	inheritMethod(_proxyDeck, _passport);

	
	
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVoyageSub" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6590a5ad-3f38-414c-b558-ee7e09af8acc">
        <updating/>
        <source>setForUpdate(_proxyDeck: CM_Deck input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_ROROVoyageStructure;
begin
	inheritMethod(_proxyDeck, _passport);

	roroStructure:=self.myParentDeck.myVoyageStructure;
	if roroStructure &lt;&gt; null then
		if _proxyDeck.pxyGetRealObject = null then
			app.myEventManager.createSingleObjInfoNoteEvt(roroStructure, EVENT_VESSEL_DECK_CREATE, self);		
		else
			app.myEventManager.createSingleObjInfoNoteEvt(roroStructure, EVENT_VESSEL_DECK_UPDATE, self);	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyParentDeck" id="b9cbe288-b2e8-4e8a-8ec8-327534183bf6">
        <updating/>
        <source>setMyParentDeck(_parentDeck : CM_DeckVoyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwer1	Initial creation

*/

vars

begin
	self.myParentDeck :=_parentDeck;
epilog

end;</source>
        <Parameter name="_parentDeck" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="5d6c3803-f44b-4f7c-bfea-7e02aec4d810">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	iter : Iterator;
	deck : CM_DeckVoyage;
begin
	inheritMethod(_passport);

	iter:=self.myParentDeck.allSubDecks.createIterator;
	while iter.next(deck) do
		if deck.code = self.code then
			app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Deck),null,null);
			return;
		endif;
	endwhile;
epilog
	delete iter;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="dd5dede4-d7a2-4c59-b3c2-00d8036036fe">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	realSelf : CM_DeckVoyageSub;
	parentDeck , subDeck: CM_DeckVoyage;
	iter : Iterator;
begin
	inheritMethod(_passport);
	
	realSelf:=self.pxyGetRealObject;

	if realSelf &lt;&gt; null then
		parentDeck:=realSelf.myParentDeck;
		iter:=parentDeck.allSubDecks.createIterator;
		while iter.next(subDeck) do
			if subDeck.code = self.code and subDeck &lt;&gt; realSelf then
				app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Deck),null,null);
				return;
			endif;	
		endwhile;
	endif;
epilog
	delete iter;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
