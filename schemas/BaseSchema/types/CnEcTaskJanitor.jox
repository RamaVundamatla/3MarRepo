    <DbClassMap file="baseshed"/>
    <JadeMethod name="doTask" id="e8a90d69-1924-450c-a104-dde60d20d865">
        <updating/>
        <source>doTask():Boolean updating;

vars
	success		: Boolean;
	complete	: TimeStamp;
	iter		: Iterator;
	taskObj		: CnEcBackShedTask;
	now			: TimeStamp;
begin
	
	notifyStartOfTask();
	
	beginTransaction;
	
	now := app.actualTimeServer();// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	iter := self.myManager.allBackShedTasks.createIterator();
	
	while iter.next(taskObj) do
		if taskObj.completedTimeStamp.isValid then
			if taskObj.completedTimeStamp.Date &lt; now.Date then
				delete taskObj;
			endif;
		else
			if ( not taskObj.scheduleTimeStamp.isValid or taskObj.scheduleTimeStamp.Date &lt; now.Date ) and not taskObj.isRunning then
				delete taskObj;
			endif;	 			
		endif;
	endwhile;
	
	commitTransaction;
	
	success := true;
	notifyFinishOfTask(success);
epilog
	delete iter;
	return success;	 
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
