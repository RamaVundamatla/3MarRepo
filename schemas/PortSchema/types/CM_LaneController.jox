    <JadeMethod name="getBoomName" id="8eea7baa-9e8c-4cef-b592-a356d1547256">
        <source>getBoomName(_inBoom :Boolean):String;
// ---------------------------------------------------------------------------
// Created:     27 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	boom	:CM_Boom;
begin
	boom := self.getBoom (_inBoom);
	
	if boom &lt;&gt; null then
