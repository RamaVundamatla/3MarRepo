    <JadeMethod name="setupWarningMessages" id="d4909b74-d54d-48ed-84e7-9304ed819a0c">
        <source>setupWarningMessages() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2009	cnwndl1	Initial creation	Par 21519 - moved from setControlsForAddEdit

*/

vars

	theForm				: SOP_TableMaintForm;
	dict				: XLAT_TranslationByCatAndNumber;
	selectedDict		: XLAT_TranslationByNumberDict;
	realEventType		: CM_EventType;
	interestedWarning	: CM_InterestedWarning;
	errorObj			: XLAT_Translation;
	
begin

	theForm := self.myForm;
	theForm.mulSelect1.enabled := true;

	theForm.mulSelect1.clearSelected();
	
	dict := app.myRoot.allLocales['0000'].allXlatTranslationsByCatNumber;
	
	create selectedDict transient;
	if theForm.myProxyObject &lt;&gt; null then
		realEventType := theForm.myProxyObject.CM_EventType.pxyGetRealObject();
	else
		realEventType :=theForm.myCurrentObject.CM_EventType;
	endif;
	
	if realEventType &lt;&gt; null then
		foreach interestedWarning in realEventType.allInterestedWarnings do
			errorObj := dict[XLAT_Exceptions, interestedWarning.errorCode];
			if errorObj &lt;&gt; null then
				selectedDict.add(errorObj);
			endif;
		endforeach;
	endif;
			
	theForm.mulSelect1.setSelected(selectedDict);
	
epilog

	delete selectedDict;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="af136181-9438-462a-84a3-ca2d440981cb">
        <updating/>
        <source>showThumbnail(pEventType: CM_EventType) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
// 29/07/2022	jlizm1		TFS 54165 EDI Voyage Events
// ---------------------------------------------------------------------------

vars
	theForm				: SOP_TableMaintForm;
	dict				: XLAT_TranslationByCatAndNumber;
	errorObj			: XLAT_Translation;
	interestedWarning	: CM_InterestedWarning;
	selectedDict		: XLAT_TranslationByNumberDict;
begin
	theForm	:=	self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput1.showRowByName(ETRow_Type, false);
	theForm.tblInput1.setValueByName(ETRow_Category, pEventType.getCategoryString);	// 29 Oct 2009	NDL	Par 21519
	theForm.myAssistant.comboBoxEventTypeCategory(theForm.cmbCategory,pEventType.category);	// 29 Oct 2009	NDL	Par 21519

	theForm.tblInput1.setValueByName(ETRow_SystemAction,theForm.myAssistant.getEventTypeActionName(pEventType.type));
	theForm.tblInput1.setValueByName(ETRow_Name, pEventType.name);
	theForm.tblInput1.setValueByName(ETRow_Description,	pEventType.description);	
	theForm.tblInput1.setValueByName(ETRow_Colour, pEventType.colour);
	//epr par 36902 14/6/15
	if pEventType.category = CM_EventType.VOYAGE_EVENT then
		theForm.tblInput1.showRowByName(ETRow_NumDecimalPlaces,false);
		theForm.tblInput1.setValueByName(ETRow_NumDecimalPlaces,pEventType.amountDecimalPlaces); 
		
		theForm.tblInput1.showRowByName(ETRow_IsFromToDateTimeRequired,false);								//nds TFS 3047 13/01/17
		theForm.tblInput1.setValueByName(ETRow_IsFromToDateTimeRequired,pEventType.isFromToDateTimeRequired); //nds TFS 3047 13/01/17
		theForm.tblInput1.showRowByName(ETRow_UnitDescription,false);										//nds TFS 3047 13/01/17					
		theForm.tblInput1.setValueByName(ETRow_UnitDescription,pEventType.unitDescription); 				//nds TFS 3047 13/01/17	
		theForm.tblInput1.showRowByName(ETRow_ShowWeight, false);											// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_ShowWeight,pEventType.showWeight);							// TFS 54165
		//24 Aug 2018	NDL	TFS 40309
		theForm.cmbVoyageDelay.listIndex := -1;
		theForm.tblInput1.setValueByName(ETRow_MyVoyageDelay, null); 
		if pEventType.myDelayTypeToCreate &lt;&gt; null then
			theForm.cmbVoyageDelay.listIndex := theForm.cmbVoyageDelay.findObject( pEventType.myDelayTypeToCreate );
			theForm.tblInput1.setValueByName(ETRow_MyVoyageDelay, pEventType.getDisplayStringForAttribute(ETRow_MyVoyageDelay, true)); 
		endif;
		
		theForm.cmbMeasureUnit.listIndex := -1;								// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_WeightMeasureType, null);	// TFS 54165
		if pEventType.myWeightType &lt;&gt; null then								// TFS 54165
			theForm.cmbMeasureUnit.listIndex := theForm.cmbMeasureUnit.findObject( pEventType.myWeightType );	// TFS 54165
			theForm.tblInput1.setValueByName(ETRow_WeightMeasureType, pEventType.getDisplayStringForAttribute(ETRow_WeightMeasureType, true));	// TFS 54165
		endif;
		
	elseif pEventType.category = CM_EventType.TRAIN_EVENT then													//ChangeRequest 45575
		theForm.tblInput1.showRowByName(ETRow_NumDecimalPlaces,false);											//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_NumDecimalPlaces,pEventType.amountDecimalPlaces); 				//ChangeRequest 45575
		theForm.tblInput1.showRowByName(ETRow_IsFromToDateTimeRequired,false);									//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_IsFromToDateTimeRequired,pEventType.isFromToDateTimeRequired);	//ChangeRequest 45575
		theForm.tblInput1.showRowByName(ETRow_UnitDescription,false);											//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_UnitDescription,pEventType.unitDescription); 					//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_MyVoyageDelay, null); 											//ChangeRequest 45575
		theForm.cmbVoyageDelay.listIndex := -1;																	//ChangeRequest 45575
		theForm.tblInput1.hideRowByName(ETRow_ShowWeight,false);		// TFS 54165
		theForm.tblInput1.hideRowByName(ETRow_WeightMeasureType,false);	// TFS 54165
		theForm.cmbMeasureUnit.listIndex := -1;							// TFS 54165
	else
		theForm.tblInput1.hideRowByName(ETRow_NumDecimalPlaces,false);
		theForm.tblInput1.hideRowByName(ETRow_IsFromToDateTimeRequired,false);								//nds TFS 3047 13/01/17
		theForm.tblInput1.hideRowByName(ETRow_UnitDescription,false);										//nds TFS 3047 13/01/17
		theForm.tblInput1.setValueByName(ETRow_MyVoyageDelay, null); 
		theForm.cmbVoyageDelay.listIndex := -1;
		theForm.tblInput1.hideRowByName(ETRow_ShowWeight,false);		// TFS 54165
		theForm.tblInput1.hideRowByName(ETRow_WeightMeasureType,false);	// TFS 54165
		theForm.cmbMeasureUnit.listIndex := -1;							// TFS 54165
	endif;
	theForm.mulSelect1.clearSelected();
	
	if pEventType.showWeight then											// TFS 54165
		theForm.tblInput1.showRowByName(ETRow_WeightMeasureType, false);	// TFS 54165
	else
		theForm.tblInput1.hideRowByName(ETRow_WeightMeasureType, false);	// TFS 54165
	endif;

	if pEventType.isWarningEvent then	// 29 Oct 2009	NDL	Par 21519
		self.setupWarningMessages();
		theForm.shtMultiSelect1.enabled := true;
	else
		 theForm.shtMultiSelect1.enabled := false;
	endif;
	self.disableMulSelect1Contents();
	
	self.resetCategory( pEventType.category );	//24 Aug 2018	NDL	TFS 40309
epilog
	delete selectedDict;
end;</source>
        <Parameter name="pEventType" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="73cc4e86-9f94-4609-b722-9d2bff8302ee">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lEventType:CM_EventType;
	cell : JadeTableCell;
begin

	lEventType := _obj.CM_EventType;
	if(_idxRow &lt;&gt; 1) then
		if self.colourColumn &gt; 0 then
			cell := myForm.tblData.accessCell(_idxRow, self.colourColumn);
			cell.text := null;
			cell.backColor := lEventType.colour;
		endif;
	endif;	

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
