        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="75f907c8-f884-4681-976d-85b302bafa7c">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	queryOper : CM_QueryOperator;
	class : Class;
	className : String;

begin
	
	//first choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QStringIsOneOf then
			return class;
		endif;
	endwhile;
	delete iter;
	
	//second choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QStringLookup then
			return class;
		endif;
	endwhile;
	
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="cd520292-e8b2-464e-a7bd-baeb168369b5">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation

*/

vars
	propValue : String; 

begin
	
	propValue := _obj.sendMsg(self.propertyName).String;
	
	if self.needToUpperCase then
		propValue := propValue.toUpper;
	endif;

	return propValue;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
