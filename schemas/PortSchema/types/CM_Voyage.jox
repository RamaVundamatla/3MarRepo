    <JadeMethod name="jrwGetAllLoadStartTimes" id="908af20d-a6cb-4fc3-8d28-0b47e5885df4">
        <source>jrwGetAllLoadStartTimes():String;
/*
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	movement	:HMS_Movement;
	interval	:CM_TimeStampInterval;
	result		:String;
begin
	movement := self.getMovementFirstRealBerth;
	
	if movement = null then
		return null;
	endif;
	
	foreach interval in movement.allCargoOperationsIntervals do
		if result &lt;&gt; null then
			result := result &amp; CrLf;
		endif;
		
		result := result &amp; interval.startDT.asStringTimeDayDate();
	endforeach;
	
	if interval = null then
		// collection was empty
		result := self.getRealBerthDT.asStringTimeDayDate;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jrwGetAllLoadStopTimes" id="56f36c9e-ce8d-459b-b3bf-570aa0b294c9">
        <source>jrwGetAllLoadStopTimes():String;
/*
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	movement	:HMS_Movement;
	interval	:CM_TimeStampInterval;
	result		:String;
begin 
	movement := self.getMovementFirstRealBerth;
	
	if movement = null then 
		return null;
	endif;
	
	foreach interval in movement.allCargoOperationsIntervals do
		if result &lt;&gt; null then
			result := result &amp; CrLf;
		endif;
		
		result := result &amp; interval.endDT.asStringTimeDayDate();
	endforeach;
	
	if interval = null then 
		// collection was empty
		result := self.getRealBerthDT.cnEcAddMinutes (self.getGrossLoadingTimeMinutes()).asStringTimeDayDate;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
