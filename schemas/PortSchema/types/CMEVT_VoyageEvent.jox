    <JadeMethod name="getVesselLengthOverall" id="8ea09bfc-379a-4787-a5e3-f3b82d61a37a">
        <source>getVesselLengthOverall() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 April 2025		jlizm1	Initial creation MTN 34568 PEN Expose vessel fields to event stream

*/

vars
	vessel 	: CM_Vessel;
	hmsData : HMS_VesselData;
	
begin
	vessel := self.getVessel;

	if vessel = null then
		return null;
	endif;
	
	hmsData := vessel.myHMSVesselData;
	
	if hmsData = null then
		return null;
	endif;
	
	return hmsData.dim_LengthOverall;
	
epilog

end;</source>
