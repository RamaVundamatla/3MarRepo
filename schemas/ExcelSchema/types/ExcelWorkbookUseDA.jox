    <JadeMethod name="doFinished" id="d6db7188-23e6-46d5-b570-ef97db37c3e6">
        <updating/>
        <source>doFinished() updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	At this point we have populated the workbook so do a cleanup
					but leave the ExcelApplicationDA running till Excel is closed.

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	delete myControllingAppsDA;
	delete self;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doGetDataFromHostApplication" id="5616b171-15aa-455d-89cb-a2fa775bf5be">
        <updating/>
        <source>doGetDataFromHostApplication() : ExcelHugeStringArray updating;

/*****************************************************
	Written by	:	cnwgrp1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	hsa : ExcelHugeStringArray;
	str : String;
begin
	create hsa transient;
	myControllingAppsDA.invokeMethod(myControllingAppsContext,
									myControllingAppsDataMethod,
	 								hsa,
	 								mySelectedWorkbookDefn.myApplicationExtractOptions,
	 								mySelectedWorkbookDefn.associatedObjectType,
	 								associatedObjectName,
	 								mySelectedWorkbookDefn.myAssociatedObject);
	
		return hsa;
	
epilog
	

end;</source>
        <ReturnType type="ExcelHugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="doShowExcelEmbedded" id="56e5d807-980a-479e-94f7-9b9f10cebfa2">
        <updating/>
        <source>doShowExcelEmbedded() updating;

vars

begin
	doUseExcelParam('c:\data.xls', false, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doUseExcelParam" id="d140deb0-73cf-4933-a7eb-941b6ce7e8bd">
        <updating/>
        <source>doUseExcelParam(
	destinationFileName : String;
	showExcel, embedded : Boolean) updating;

/*****************************************************
	Written by	:	cnwrh3		08 November 2004
	Description	:	Exports data into Excel.
	Parameters	:	destinationFileName - where to save the Excel workbook that data will be extracted to.
					showExcel - if true, Excel is made visible, otherwise Excel remains invisible.

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	root 		: Root;
	objArray	: ObjectArray;
	wbDef		: WorkbookDefinition;
	iter		: Iterator;
	
begin
	on Exception do app.defaultExceptionHandler(exception);
	
	setMyRoot(Root.firstInstance);
	
	if myRoot = null then	// we are in trouble if this is the case - there can't be any WBs
		beginTransaction;
			create myRoot;
		commitTransaction;
	endif;
	
	create objArray transient;
	
	iter := myRoot.allWBDefnsByAssocNameAndName.createIterator;
	
	myRoot.allWBDefnsByAssocNameAndName.startKeyGeq(associatedObjectName, null, iter);
	
	while iter.next(wbDef) do
		if wbDef.associatedObjectName &lt;&gt; associatedObjectName then
			break;
		endif;
		if wbDef.isComplete then	//grp 28/6/2004	PAR 8583
			objArray.add(wbDef);
		endif;
		
	endwhile;
	
	if objArray.size = 0 then
		app.msgBox('There are no Excel workbooks defined for ' &amp; associatedObjectName,
							'Workbook Error', MsgBox_OK_Only);
		return;
	elseif objArray.size() = 1 then
		mySelectedWorkbookDefn := objArray[1].WorkbookDefinition;
	else
		mySelectedWorkbookDefn := selectWorkbook(objArray);
		if self.mySelectedWorkbookDefn = null then
			return;
		endif;
	endif;
	
	getDataAndStartExcel(destinationFileName, showExcel, embedded);
	
epilog
	doFinished;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="destinationFileName" type="String"/>
        <Parameter name="showExcel" type="Boolean"/>
        <Parameter name="embedded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUseExcelToAnalyse" id="e77130de-179a-4720-974c-01844916a797">
        <updating/>
        <source>doUseExcelToAnalyse() updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
	28/6/2004	GRP	PAR 8583 Check that workbook defn has an Excel Workbook before making it available for use.
******************************************************/

vars
	
	
begin
	self.doUseExcelParam(null, true, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="doUseExcelToSave" id="0e4d47f7-5d81-4fc1-99c0-3c1bee312f84">
        <updating/>
        <source>doUseExcelToSave() updating;

vars
	cmdFileSave : CMDFileSave;
	destinationFileName : String;
	
begin
	create cmdFileSave transient;
	
	cmdFileSave.fileMustExist := false;
	cmdFileSave.createPrompt := false;
	cmdFileSave.noReadOnlyReturn := false;
	cmdFileSave.overwritePrompt := true;
	cmdFileSave.pathMustExist := true;
	cmdFileSave.validate := true;
	
	cmdFileSave.filter := "Excel Workbook Files (*.xls)|*.xls|All Files (*.*)|*.*";
	cmdFileSave.filterIndex := 1;
	cmdFileSave.defaultExt := "xls";
	
	if cmdFileSave.open() = 0 then
		destinationFileName := cmdFileSave.fileName;
		self.doUseExcelParam(destinationFileName, false, false);
	endif;
	
epilog
	delete cmdFileSave;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDataAndStartExcel" id="fe785977-0c6c-4788-8edd-6ed21379ba4d">
        <updating/>
        <source>getDataAndStartExcel(
	destinationFileName : String;
	showExcel, embedded : Boolean) updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	hsa		: ExcelHugeStringArray;
	form : EmbeddedExcelForm;

begin
	hsa := doGetDataFromHostApplication;
	
	if hsa.size = 0 then
		app.msgBox('Excel not started as no data was selected', 'No Data', MsgBox_OK_Only);
		return;
	endif;
	
	create myExcelApplicationDA;
	myExcelApplicationDA.setMyWorkbookDefinition(mySelectedWorkbookDefn);
	
	if destinationFileName &lt;&gt; null then
		myExcelApplicationDA.setFileName(destinationFileName);
	endif;
	
	myExcelApplicationDA.initialise;
	
	if not myExcelApplicationDA.getDataAndTopSheet then
		app.msgBox('The definition of the Excel Workbook is invalid.' &amp; CrLf &amp; CrLf &amp;
						'Please contact your System Administrator', 'Workbook Error', MsgBox_OK_Only);
		return;
	endif;
	
	myExcelApplicationDA.pasteArrayInDatasheet(hsa);
	
	if showExcel then
		self.myExcelApplicationDA.makeVisible(true);
	else
		self.myExcelApplicationDA.closeWorkbook();
	endif;
	
	
	if embedded then	// spreadsheet has been saved
		create form transient;
		form.show;
		form.oleControl1.linkFromFile(destinationFileName);
//		process.debug;
		return;
	endif;

epilog

	delete hsa;
	
end;</source>
        <Parameter name="destinationFileName" type="String"/>
        <Parameter name="showExcel" type="Boolean"/>
        <Parameter name="embedded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectWorkbook" id="e66c1806-27c8-4e5d-a717-692da8597e27">
        <updating/>
        <source>selectWorkbook(
	array : ObjectArray) : WorkbookDefinition updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/
constants
	Option_Load_Form = 1;
	Option_Activate_Form = 2;
	Option_Delete_Form = 3;
	
vars
	wbList		: WorkbookListForm;

begin
	create wbList;
	wbList.setMyWBArray(array);
	wbList.setMyDA(self);
	myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsShowMethod, wbList, Option_Load_Form);
	
	wbList.showModal;
	
	if wbList.mySelectedWorkbookDefn = null then
		app.msgBox('Excel not started as no selection was made', 'No Selection', MsgBox_OK_Only);
		myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsShowMethod, wbList, Option_Delete_Form);
		return null;
	endif;
	
	myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsShowMethod, wbList, Option_Delete_Form);
	
	return wbList.mySelectedWorkbookDefn;
	
epilog
	delete wbList;

end;</source>
        <Parameter name="array" type="ObjectArray"/>
        <ReturnType type="WorkbookDefinition"/>
    </JadeMethod>
