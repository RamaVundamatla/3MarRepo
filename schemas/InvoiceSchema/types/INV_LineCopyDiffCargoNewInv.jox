    <JadeMethod name="toolbarShowCaptions" id="4124face-2397-47f7-a68e-503edb773996">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	
	self.fldMain.height:= self.fldMain.height -heightDiff - 10;
	self.doResize();

epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="12432d2e-65dd-4c7c-988a-fef731672960">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 May 2023 16:00:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025941, locale);
	btnClear.translateCaption(Xlat_0025942, locale);
	btnRemove.translateCaption(Xlat_0025943, locale);
	btnSearchCargo.translateCaption(Xlat_0025944, locale);
	mnuColumnOrganizer.translateCaption(Xlat_0025945, locale);
	mnuContextMenu.translateCaption(Xlat_0025946, locale);
	shtCargoItems.translateCaption(Xlat_0025947, locale);
end;</source>
    </JadeMethod>
</GUIClass>
