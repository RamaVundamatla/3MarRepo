        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="erase" id="47bf114a-a525-4772-b7da-f3dc4c77a246">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		18 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 12 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberActioned" id="b03e5dd1-c4ba-4e25-a691-4cec563cdc49">
        <source>getNumberActioned() : Integer;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	count : Integer;
	woTransaction : CM_WOTransaction;
begin

	foreach woTransaction in self.myParent.allWOTransactions 
	where woTransaction.getMySchedule() = self and woTransaction.type = TRANS_TYPE_WO_ACTION do
		count := count +  woTransaction.CM_WODtlActioned.numberItems;
	endforeach;
	
	return count;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberComplete" id="bd8c83c5-177f-4e54-a6cc-225a15ae1138">
        <source>getNumberComplete(): Integer;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	count : Integer;
	woTransaction : CM_WOTransaction;
	
begin
	foreach woTransaction in self.myParent.allWOTransactions
	where woTransaction.getMySchedule() = self and woTransaction.type = TRANS_TYPE_WO_COMPLETE do
		count := count +  woTransaction.CM_WODtlCompleted.numberItems;
	endforeach;
	
	return count;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getScheduledDTLocalTZ" id="bad3cbb6-9395-4618-88ff-a48f431a9da3">
        <source>getScheduledDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.scheduledDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="89ee3a02-69ba-49f0-bfa3-8e854bee9ae9">
        <source>pxyCreateUpdateProxy(): SelfType;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// -----------------------------------------------------------------------------

vars
	pxy : SelfType;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ac348bf0-2a7a-4834-bce5-f22e30a4d0d1">
        <updating/>
        <source>setForCreate( _pxyschedule : CM_WorkOrderSchedule) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation

*/

vars

begin

	self.myRoot := app.myRoot;	
	self.setForUpdate( _pxyschedule ) ;		
	
epilog

end;</source>
        <Parameter name="_pxyschedule" type="CM_WorkOrderSchedule"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a8d5fba-e31b-4188-9129-257ef2ab5827">
        <updating/>
        <source>setForUpdate( _pxyschedule : CM_WorkOrderSchedule) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars

begin

	self.numberScheduled := _pxyschedule.numberScheduled;
	self.scheduledDT 	 := _pxyschedule.scheduledDT;
	
epilog

end;</source>
        <Parameter name="_pxyschedule" type="CM_WorkOrderSchedule"/>
    </JadeMethod>
