<Class name="CMIF_TMCCommodityGroup" id="43cab43a-f5c2-431a-878c-f6c9664af7e3">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myCommodityMap" id="b635e5af-ec7a-4e8d-a1b5-e3d8ced58baa">
        <embedded/>
        <type name="CM_CommodityMap"/>
    </ImplicitInverseRef>
    <JadeMethod name="getItemLevel" id="49f874f4-a01c-4b85-90c4-a2aab869801f">
        <source>getItemLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return CMIF_TranMapController.TM_Level_09_Commodity;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMoveGroup" id="08d8e948-a139-4b9d-a54d-c55f29259443">
        <source>getMoveGroup() : CMIF_TMCMoveGroup;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	atmc : CMIF_TranMapController;
begin
	foreach atmc in self.allGroupMembers do
		if atmc.isKindOf(CMIF_TMCMoveGroup) then
			return atmc.CMIF_TMCMoveGroup;
		endif;
	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CMIF_TMCMoveGroup"/>
    </JadeMethod>
    <JadeMethod name="getMyTransactionMap" id="4faac5ff-26b2-4ae1-b171-a05abb9c4949">
        <source>getMyTransactionMap(): CM_TranMap;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myCommodityMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap;

end;</source>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="ac55dcb4-d40b-47e0-9b4a-982c6bbdf539">
        <source>getPicture(form : INV_TransactionMap) : Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picCommodity;
end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="8f9ea175-1d87-486d-ae7d-a128cf8f0d87">
        <source>getRealMapObject(): Object;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myCommodityMap;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="faa54875-1128-4036-a86d-9b1ece227bdc">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;

vars
	tsb : CM_TransServiceBroker;
	tmcSB : CMIF_TMCSBGroup;
	tmcMove : CMIF_TMCMoveGroup;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	foreach tsb in self.myCommodityMap.allTransServiceBrokersByType do
		if tsb.isKindOf(CM_TransResourceServiceBroker) then	//07 Jan 2010 NDL CCMS MES 1006
			continue;
		endif;
		if tsb.myTransactionType = null then
			create tmcSB as CMIF_TMCSBDefault;
		else
			create tmcSB;
		endif;
		tmcSB.myServiceBroker := tsb;
		tmcSB.itemName := tsb.getTransactionClassName(); 
		tmcSB.extractName := tsb.getTransactionCode();	// 23659
		tmcSB.myGroup := self;
		tmcSB.initialise(_groupCount);
	endforeach;

	if self.myCommodityMap.moveMap.size &gt; 0 then
		create tmcMove;
		tmcMove.myCommodityMap := self.myCommodityMap;
		tmcMove.itemName := "Move";
		tmcMove.extractName := "(Move)";	// 23659
		tmcMove.myGroup := self;
		tmcMove.initialise(_groupCount);
	endif;
	
	_groupCount :=_groupCount + 1;

end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="94917b1e-5e21-4bcd-a2fc-24556639da34">
        <source>setControllerCurrent();
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();

	myTMCController.myCurrentMapCommodity := self.myCommodityMap;
	myTMCController.myCurrentMapContents := myTMCController.myCurrentMapCommodity.contentsMap;
	myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
	myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
	myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
	myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
	myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="f88baf31-e6b9-41d2-9ed6-f570a859e23e">
        <source>setEnableObjects(form : INV_TransactionMap io);

begin
	inheritMethod(form);

	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU
	form.menuTMVnew.visible := false;  // MAIN VTMIS NEW MENU
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;

	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Commodity;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Commodity;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_TransType;

	form.btnNew.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.menuSItemNew.enabled := true;
	form.menuSINewTranType.visible := true;
	form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.menuMapNewTranStandard.visible := true;

	form.menuSItemDelete.visible := true;
	form.btnDelete.enabled := true;
	
	

	

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="259d8da0-19ad-412d-889c-a7c52fca081d">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	form.myCurrentMapCommodity := self.myCommodityMap;
	form.myCurrentMapContents := form.myCurrentMapCommodity.contentsMap;
	form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
	form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
	form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
	form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
	form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;
	form.myTMCCommodity := self;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
