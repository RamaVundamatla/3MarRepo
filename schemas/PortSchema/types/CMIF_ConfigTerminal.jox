    <JadeMethod name="setFinancialIOClass" id="814cd1ff-f053-4aa5-806a-01351d3ffbff">
        <updating/>
        <source>setFinancialIOClass(_ioCLass : Class) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	clsCol : ClassColl;
	cls : Class;
	aFIO : CM_ExtFinanceIO;
	str : String;
begin
	self.financialIOClass := null;
	cls := _ioCLass;
	if cls = null then
		cls := CM_DefaultFinanceIO;
	endif;	
	aFIO := cls.firstInstance().CM_ExtFinanceIO;
	if aFIO = null then
	/* PAR 31601
		beginTransaction;
		create aFIO as cls persistent;
		aFIO.initialise(app.myRoot.myRootCompany, cls.getNiceName());
		app.cmsCommitTransaction(app.myPassport);
		*/
		
		aFIO := app.myTrxCA.trxCreateExternalFinanceClass(_ioCLass);
	endif;
	self.financialIOClass := aFIO;
				
end;</source>
        <Parameter name="_ioCLass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistentData" id="c5f00757-a4c2-4685-bdf9-a222db15e762">
        <updating/>
        <source>setFromPersistentData(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwrs2
//
// Purpose:     
//07 Jul 2022 navhl20 TFS 53697 EUP - VBS MTN - [1] - VBS Slot Types 
// ---------------------------------------------------------------------------
vars
	propCol	: PropertyColl;
	prop	: Property;
	keyStr	: String;
	
begin

	inheritMethod(_terminal);



	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		if prop.name = CMIF_ConfigTerminal::allTerminalsForRelease.name then
			self.allTerminalsForRelease.clear;
			_terminal.allTerminalsForRelease.copy(self.allTerminalsForRelease);
			continue;
		elseif prop.name = CMIF_ConfigTerminal::allTerminalsForVoyageInland.name then
			self.allTerminalsForVoyageInland.clear;
			_terminal.allTerminalsForVoyageInland.copy(self.allTerminalsForVoyageInland);
			continue;
		elseif prop.name = CMIF_ConfigTerminal::storageConfigType.name then	//02 Nov 2017	NDL	TFS 7032
			self.storageConfigType := _terminal.getMyStorageConfigType();
			continue;
		elseif prop.name = CMIF_ConfigTerminal::myRoadProcess.name then	//01 Oct 2020	NDL	TFS 49189
			self.myRoadProcess := _terminal.getMyRoadProcess();
			continue;
		elseif prop.name = CMIF_ConfigTerminal::myVBSProcess.name then	//07 Jul 2022 navhl20 TFS 53697
			self.myVBSProcess := _terminal.getMyVBSProcess();			//07 Jul 2022 navhl20 TFS 53697
			continue;													//07 Jul 2022 navhl20 TFS 53697
		endif;
		
		keyStr := self.getKeyStringForProperty(prop.name);		
		
		if keyStr &lt;&gt; null then
			self.setPropertyFromStringValue(prop, _terminal.getConfig(keyStr));
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setStartupMoveMode" id="79932acd-9771-41fd-9532-9a6e6096b6a0">
