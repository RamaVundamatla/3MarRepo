    <ImplicitInverseRef name="btnCancel" id="ea5a0562-2fd5-425b-b8a7-29002c86497c">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="215d9219-502b-4b40-a710-cd07956dae3e">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="fraRuler" id="e583f698-a02b-4f50-a42f-093c2f329bb5">
        <embedded/>
        <type name="JSSLine3D"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInstruction" id="f4877a9c-86d0-4173-9c4c-6ee434ee560f">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtInput" id="02d35df1-7508-4111-b0a4-fee00c6b149a">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="44a8bbcc-ce96-49cc-9347-58615133e27b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 -  btnCancel_click
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	0;
	unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="466e6f63-1971-4dbb-b103-3f392c29b547">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 -  btnOk_click
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if txtInput.text.trimBlanks() &lt;&gt; null then
		app.mousePointer	:=	Busy;
		modalResult			:=	1;
		unloadForm;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="e1bd4689-96a5-4002-9510-235ba47bff74">
        <source>getValue():String;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 -  getValue
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return txtInput.text.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="4f31e7f6-ae10-4504-aebd-977adb8571c9">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 -  load
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProperties" id="d6ec3d7c-0569-4ec9-b6ca-cc3313b879eb">
        <updating/>
        <source>setProperties(pTitle:String; pInstruction:String; pDefaultValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 -  setProperties
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption			:=	pTitle;
	lblInstruction.caption	:=	pInstruction;
	txtInput.text			:=	pDefaultValue;
end;</source>
        <Parameter name="pTitle" type="String"/>
        <Parameter name="pInstruction" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
    </JadeMethod>
</GUIClass>
