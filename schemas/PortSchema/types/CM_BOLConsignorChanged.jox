<Class name="CM_BOLConsignorChanged" id="0a5d283a-e85f-49d7-8299-8510dd6cf5e3">
    <superclass name="CM_BOLTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="detailDescription" id="71f63aed-a5cc-4f20-9d14-3bf7b8fd673f">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="newConsignorCode" id="a039388d-1119-4998-a0d6-afe89a932787">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="previousConsignorCode" id="d8acb974-0a97-4e00-9854-887407d7d2a0">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDebtorFromConsignor" id="255fabdb-fefe-44db-a068-042ee8df988e">
        <source>getDebtorFromConsignor(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	debtor : CM_Debtor;
	consignee : CM_ConsigneeConsignor;

begin

	consignee := app.myRoot.allConsigneeConsignors.getAtKey( self.newConsignorCode );
	if consignee &lt;&gt; null then
		debtor := consignee.debtor;
	endif;
	
	return debtor;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="20fff643-f004-44c1-a289-0c35b454eef3">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return inheritMethod &amp; " " &amp; self.detailDescription;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7e6b15b7-48b8-48df-83aa-93f9984d53c0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if _attrName = ETRow_Details then
		return self.detailDescription;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="2ea947d8-4e3b-4c1e-abf0-d9860437782a">
        <updating/>
        <source>setDetails( _prevConsignor : String; _newConsignor : String; bolDtl : CM_BOLDtl ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	self.previousConsignorCode := _prevConsignor;
	self.newConsignorCode := _newConsignor;
	self.detailDescription := bolDtl.getShortDisplay &amp; " " &amp; app.getErrorString2( Consignor_changed_from, _prevConsignor, _newConsignor );

epilog

end;</source>
        <Parameter name="_prevConsignor" type="String"/>
        <Parameter name="_newConsignor" type="String"/>
        <Parameter name="bolDtl" type="CM_BOLDtl"/>
    </JadeMethod>
</Class>
