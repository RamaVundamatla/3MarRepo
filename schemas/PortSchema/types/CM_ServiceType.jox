    <JadeMethod name="validateForUpdate" id="0abbd7f1-b9c2-4a14-be96-02fae6076445">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navkc1	Initial creation

*/

vars
	tmpServiceType		: CM_ServiceType;
begin

	if self.code.trimBlanks = null then
		// No code entered
		app.raiseCMException(NoServiceTypeCodeEntered, null, null);
	endif;
	
	if self.description.trimBlanks = null then
		// No description entered
		app.raiseCMException(NoServiceTypeDescEntered, null, null);
	endif;
	
	foreach tmpServiceType in self.myBank.allServiceTypes do
		if tmpServiceType &lt;&gt; self.pxyGetRealObject() and tmpServiceType.code = self.code then
			// Code already exist
			app.raiseCMException1(ServiceTypeCodeAlreadyUsed, self.code , null, null);
			break;
		endif;
	endforeach;
		
	if self.allServices.isEmpty() then
		// No services selected
		app.raiseCMException(NoServicesSelected, null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
