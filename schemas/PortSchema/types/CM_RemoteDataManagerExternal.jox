<Class name="CM_RemoteDataManagerExternal" id="1d3f63a5-5b78-4bed-9339-6b6c0b0a14a1">
    <superclass name="CM_RemoteDataManager"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <ImplicitInverseRef name="myParseAgent" id="8d050a51-d6ac-4bad-bbfe-c758c8fee0e1">
        <embedded/>
        <type name="CM_RemoteParseAgent"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="931e3e85-e2d1-4463-a54e-7dbad9de91d5">
        <updating/>
        <source>create() updating;

vars


begin

	
	create self.myParseAgent as CM_RemoteParseXMLAgent transient;

end;</source>
    </JadeMethod>
    <JadeMethod name="createHeaderClassExternal" id="4553dbf1-a6d7-48a8-8265-be41290b2870">
        <source>createHeaderClassExternal(_parseAgent : CM_RemoteParseAgent; _version : Integer) : CM_RemoteDataHdr protected;

vars
	header 	: CM_RemoteDataHdr;
	message	: String;

begin
	message := _parseAgent.getMessageType();
	
	if message = TRANSFERRQ then
		create header as CM_RemoteTransferHdr transient;
	elseif message = TIQUERYRQ then
		create header as CM_RemoteTiQueryHdr transient;
	elseif message = SCLTRUCKRQ then
		create header as CM_RemoteScaleTruckHdr transient;
	elseif message = BOLQUERYRQ then
		create header as CM_RemoteBolQueryHdr transient;
	elseif message = LCNQUERYRQ then
		create header as CM_RemoteLcnQueryHdr transient;
	elseif message = LCNENTRYRQ then	// ccms 1119, par 27433, 02/05/2011
		create header as CM_RemoteLogRowMaintHdr transient;	
	elseif message = REJECTRQ then
		create header as CM_RemoteRejectHdr transient;
	elseif message = RETICKETRQ then
		if _version &gt; 1 then
			create header as CM_RemoteReticketHdrNew transient;
		else
			create header as CM_RemoteReticketHdr transient;
		endif;
	elseif message = JOBLSTQRYRQ then
		create header as CM_RemoteJobListQueryHdr transient;
	elseif message = JOBQRYRQ then
		create header as CM_RemoteJobQueryHdr transient;
	elseif message = JOBCOMPLETIONRQ or message = JOBPICKUPRQ then
		create header as CM_RemoteJobCompletionHdr transient;
	elseif message = REGRADERQ then
		create header as CM_RemoteRegradingHdrExt transient;
	elseif message = SCLCHECKRQ then
		create header as CM_RemoteCheckScalingHdr transient;
	elseif message = USERQUERYRQ then
		create header as CM_RemoteUserQueryHdr transient;
	elseif message = CODEQUERYRQ then
		create header as CM_RemoteCodeQueryHdr transient;
	elseif message = BOLENTRYRQ then
		create header as CM_RemoteBOLEntryHdr transient;
	elseif message = BOLMAINTRQ then  //cnwrd1 ccms 1121 11.6.2012
		create header as CM_RemoteBOLMaintHdr transient;
	else
		//app.raiseUnexpectedProgramError(class.name, method.name, "Unknown XML message: '" &amp; message &amp; "'.");
		create header as CM_RemoteErrHdr transient;
	endif;
	
	return header;
end;</source>
        <access>protected</access>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent"/>
        <Parameter name="_version" type="Integer"/>
        <ReturnType type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2acc4b63-bc46-48a4-95ae-bdf4fef99c8a">
        <updating/>
        <source>delete() updating;

vars

begin

	delete self.myParseAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="processExternal" id="71b83977-fe5f-4aaa-9278-fbf16bf7546a">
        <updating/>
        <source>processExternal(_dataString : String; _struct : CnEcXmlStructureInstance; _session : CM_XMLSession) : String updating;

vars
	header 		: CM_RemoteDataHdr;
	response	: String;
	errorText	: String;
	error		: Integer;
	
begin
	on Exception do app.alertExceptionHandler(exception, header, 'Remote Data', error, errorText, true, true);
	///on LockException do app.alertLockExceptionHandler(exception);
	on LockException do self.localLockExceptionHandler(exception);		// 32212 alertLockExceptionHandler with extra code so next transaction runs OK
	
	if _struct &lt;&gt; null and self.myParseAgent &lt;&gt; null then
		app.myPassport.setMyUser(_session.myUser);
		app.myPassport.setMyTerminal(_session.myTerminal);
		self.myParseAgent.setParsedData(_struct);
		header	:=	self.createHeaderClassExternal(self.myParseAgent, _session.theVersion);
		
		if header &lt;&gt; null then
			header.setProxy(self.myRoot, _dataString, _session);
			response	:=	header.processExternal(self.myParseAgent);	// &lt;&lt;&lt;---
		endif;
	endif;
epilog
	if response = null then
		response	:=	self.xmlDefaultResponse(header, error, errorText);
	endif;
	
	delete header;
	return response;
end;</source>
        <Parameter name="_dataString" type="String"/>
        <Parameter name="_struct" type="CnEcXmlStructureInstance"/>
        <Parameter name="_session" type="CM_XMLSession"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
