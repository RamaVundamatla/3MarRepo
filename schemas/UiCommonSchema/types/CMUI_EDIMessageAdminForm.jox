    <JadeMethod name="getAllSelectedEDIData" id="1e599fe8-3800-42e7-91aa-b305deec200a">
        <source>getAllSelectedEDIData():CM_EDIDataByDateStatusDict protected;
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  _coll - gets populated with ALL selected EDI Data objects
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_EDIDataByDateStatusDict;
	obj		:Object;
	invalid	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, obj, invalid);

	create coll transient;
	
	foreach obj in self.tblData.allSelectedObjects do
		if obj &lt;&gt; null and obj.edition &gt;= 0 then	// force exception for invalid object
			coll.add (obj.CM_EDIData);
		endif;
	// we will resume here is obj is invalid
	endforeach;
	
	return coll;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIDataByDateStatusDict"/>
    </JadeMethod>
