    </JadeMethod>
    <JadeMethod name="camsTestWhyTransMissed" id="4ac55476-03f1-4af7-825a-84bab08374d3">
        <source>camsTestWhyTransMissed();
//
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//12 Mar 2020 	jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
//
constants
	StartDate	: Date = '30/06/2014'.Date;// setup start and end dates/time and protocol to use
	EndDate	: Date = '30/06/2014'.Date;
	StartTime	: Time = '13:30:00:000'.Time;
	EndTime		: Time = '13:45:00:000'.Time;
vars
	camProtocol : CM_CamProtocol;
	terminal : CM_Terminal;
	camFile 				: CM_CamFile;
	camGroup				: CM_CamGroup;
	transaction 			: CM_TITransaction;
	camTaskHistory 			: CM_CamTaskHistory;
	startTS, endTS			: TimeStamp;
	coll					: CM_TITransactionByDateTypeDict;
	typeColl				: IntegerArray;
	iter 					: Iterator;
	logExcludedTransaction	: Boolean;		// par 29601
	str						: String;
	type					: Integer;
	includeTransaction, isTransactionToBeProcessed : Boolean;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	result : Boolean;
	transName 	: String;
	trans : CM_TITransaction;
	iterator : Iterator;
begin
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	valDate := EndDate;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	camProtocol := "2173.63".asOid.CM_CamProtocol;
	camGroup := camProtocol.camGroup;
	terminal := "2351.1".asOid.CM_Terminal;
	startTS	:= startDateTime;				// par 29601 June 2012
	endTS := endDateTime;				// par 29601 June 2012
	iter := terminal.allTITransactionsByCamsTS.createIterator();

	create coll transient;
	create typeColl transient;
	
	camProtocol.protocolDesc.sendMsgWithParams("getTransactionTypesToProcess", camProtocol, typeColl);
	
	// build up colection with all transactions os required type/dates in a collection
	foreach type in typeColl do
		// str in the transaction type (integer)
		iter.reset;
		
		terminal.allTITransactionsByCamsTS.startKeyGeq(type, startTS, iter);
		
		while iter.next (transaction) do
			if transaction.type &lt;&gt; type or
				transaction.camsTimeStamp &gt; endTS then 
				break;
			endif;
			
			if type = 17 and transaction.CM_TITransaction.operatorCode = "MSC" then 
				str := str&amp;transaction.String&amp;' '&amp;transaction.myTrackedItem.id&amp;' '&amp;transaction.camsTimeStamp.String&amp;CrLf;
			coll.add (transaction);
			endif;	
		endwhile;
	endforeach;
	
	delete iter;
	
	iter := coll.createIterator;
	
	// remove load state to prevent contention (refer also PAR-15593)
	while iter.next(transaction) do		
		// makes sense to exclude transaction of the incorrect type 1st
		includeTransaction := camProtocol.protocolDesc.includeTransaction (transaction, transaction.camsTimeStamp, startTS, endTS, 
									camProtocol, camGroup, null, logExcludedTransaction, null);	// par 29601 June 2012		// TFS 48785
									
		isTransactionToBeProcessed := camProtocol.protocolDesc.isTransactionToBeProcessed(camProtocol, transaction, null);	
//		result := transaction.myTrackedItem.hasRepairBeenReported(transaction, camProtocol.registeredTransactions); //31357 cnwgb1 2.4.2013

		result := true;
		iterator := transaction.myTrackedItem.allTransactions.createIterator();
		iterator.startAtObject(transaction);
		// find the previous repair or damage transaction
		while iterator.back(trans) do
			if trans = transaction then
				continue;
			endif;
			// Checks for transsaction registered added for PAR 31357 cnwgb1 2 April 2013
			if trans.type = TRANS_TYPE_REPAIR and camProtocol.registeredTransactions.includes(TRANS_TYPE_REPAIR.asStringJMT()) or
			   trans.type = TRANS_TYPE_WASH and camProtocol.registeredTransactions.includes(TRANS_TYPE_WASH.asStringJMT()) or	//cnwrs1 par 27945 15 Aug 2011
			   trans.type = TRANS_TYPE_PRETRIP  and camProtocol.registeredTransactions.includes(TRANS_TYPE_PRETRIP.asStringJMT()) or	//cnwrs1 par 27945 15 Aug 2011
			   trans.type = TRANS_TYPE_DAIRY and camProtocol.registeredTransactions.includes(TRANS_TYPE_DAIRY.asStringJMT()) then		//cnwrs1 par 28644 10 nov 2011
				result := false;
				break;
			elseif trans.isCamsCodecoRecRelType then	//cnwrs1 par 27945 15 Aug 2011
				result := true;
				break;
			endif;
		endwhile;
		str := str&amp;transaction.String&amp;' '&amp;transaction.myTrackedItem.id&amp;' isTransactionToBeProcessed='&amp;isTransactionToBeProcessed.String&amp;' includeTransaction='&amp;includeTransaction.String&amp;' result='&amp;result.String&amp;CrLf;
	endwhile;
	app.msgBox(str, "", 0);
epilog
	delete coll;
	delete typeColl;
end;

</source>
    </JadeMethod>
    <JadeMethod name="certifyForPAR60493" id="e4ea7b23-1175-4040-8495-e60b7726e019">
        <source>certifyForPAR60493();

/*

Purpose:			See JADE PAR #60493 for details - this script is designed to execute the recommended
					checks to avoid the possibility of the 

Date		Who		Reason
31 Oct 2013	cnwkpd1	JADE PAR #60493 - script the check for data corruption

*/
constants
	DbFileName		= "bayplans";
	ModelSchemaName	= "PortSchema";
	WarningMessage	= "### Collection: [";
	MapFileOfOwner	= "Exclusive instances mapped to: mapfile of owner";
	
vars
	dba				: JadeDatabaseAdmin;
	dbFiles			: DbFileArray;
	dbFile			: DbFile;
	certifyLogFile	: File;
	now				: TimeStamp;
	result 			: Integer;
	readOnlySet		: Boolean;
	dbFileFound		: Boolean;
	line,
	oidStr			: String;
	collClassNo,
	parentInstance,
	parentClassNo,
	level,
	subId,
	pos,
	warningLen		: Integer;
	modelSchema		: Schema;
	collClass,
	parentClass		: Class;
	hadErrors		: Boolean;
	property		: Property;
	foundProperty	: Boolean;
	
begin
	// Activate CnKarmaCntrl for logging
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	
	// Firstly rename any existing certify log file
	create certifyLogFile transient;
	certifyLogFile.usePresentationFileSystem := false;
	certifyLogFile.fileName := app.myCnCntrl.logPath &amp; "\certify.log";
	
	if certifyLogFile.isAvailable() then
		certifyLog("Renaming existing certify.log file");
		certifyLogFile.rename(app.myCnCntrl.logPath &amp; "\certify" &amp; "_" &amp; now.getNumeralString &amp; ".log");
	endif;
	
	// Now certify the file
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	
//	foreach dbFile in dbFiles where dbFile.name = DbFileName do
	foreach dbFile in dbFiles where dbFile.getFileStatus() = DbFile.Status_Resident do
		
		dbFileFound := true;
		
		certifyLog("Starting certify of " &amp; dbFile.name);
		
		dbFile.changeAccessMode(DbFile.Mode_ReadOnly);
		readOnlySet := true;
		result := result + dbFile.certifyFile();
		dbFile.changeAccessMode(DbFile.Mode_Update);
		readOnlySet := false;
		
		certifyLog("Certify of " &amp; dbFile.name &amp; " complete, " &amp; result.String &amp; " errors detected");
		
	endforeach;
	
	// Do nothing if the file was not found
	if not dbFileFound then
		certifyLog("&gt;&gt;&gt; DbFile " &amp; DbFileName &amp; " was not found in the database, exiting");
		hadErrors := true;
		return;
	endif;
	
	// If there are any certify errors, then they should be resolved manually
	if result &lt;&gt; 0 then
		certifyLog("&gt;&gt;&gt; Check " &amp; app.myCnCntrl.logPath &amp; "\certify.log and manually resolve the errors before re-running");
		hadErrors := true;
		return;
	endif;
	
	modelSchema := rootSchema.getSchema(ModelSchemaName);
	if modelSchema = null then
		certifyLog("&gt;&gt;&gt; Schema " &amp; ModelSchemaName &amp; " not found, exiting");
		hadErrors := true;
		return;
	endif;
	
	// The certify was completed, and there were no errors, so need to read the certify.log file and 
	// check for the specific type of warning message
	delete certifyLogFile;
	create certifyLogFile transient;
	certifyLogFile.usePresentationFileSystem := false;
	certifyLogFile.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version

	certifyLogFile.openInput(app.myCnCntrl.logPath &amp; "\certify.log");
	
	warningLen := WarningMessage.length();
	while not certifyLogFile.endOfFile() do
		line := certifyLogFile.readLine();
		
		if line.length() &lt;= warningLen then
			continue;
		endif;
		
		// Check this is the right kind of warning message
		if line[1:warningLen] &lt;&gt; WarningMessage then
			continue;
		endif;
		
		if line.pos("parent:", 1) = 0 then
			continue;
		endif;

		if line.pos("not found", 1) = 0 then
			continue;
		endif;
		
		certifyLog("Found warning message: " &amp; line);

		// Now parse the collection oid into its component parts
		pos := warningLen + 1;
		collClassNo := line.scanUntil(".", pos).Integer;
		pos := pos + 1;
		parentInstance := line.scanUntil(".", pos).Integer;
		pos := pos + 1;
		parentClassNo := line.scanUntil(".", pos).Integer;
		pos := pos + 1;
		level := line.scanUntil(".", pos).Integer;
		pos := pos + 1;
		subId := line.scanUntil(".", pos).Integer;
		
		// Check that the collection class exists
		collClass := modelSchema.getClassByNumber(collClassNo);
		if collClass = null then
			certifyLog("&gt;&gt;&gt; Collection class " &amp; collClassNo.String &amp; " not found in " &amp; ModelSchemaName);
			hadErrors := true;
			continue;
		endif;
		
		// Check that the class is still a collection
		if not collClass.isKindOf(CollClass) then
			certifyLog("&gt;&gt;&gt; Class " &amp; collClass.name &amp; " (" &amp; collClassNo.String &amp; ") is not a Collection");
			hadErrors := true;
			continue;
		endif;
		
		// Should the exclusive instances 
		if collClass.display().pos(MapFileOfOwner, 1) &lt;&gt; 0 then
			certifyLog("&gt;&gt;&gt; Collection Class " &amp; collClass.name &amp; " (" &amp; collClassNo.String &amp; ") should be in the owner class mapfile");
			hadErrors := true;
			continue;
		else
			certifyLog("Collection Class " &amp; collClass.name &amp; " (" &amp; collClassNo.String &amp; ") is allowed in other mapfiles");
		endif;
		
		// Now get the parent class
		parentClass := modelSchema.getClassByNumber(parentClassNo);
		if parentClass = null then
			certifyLog("&gt;&gt;&gt; Parent class " &amp; parentClassNo.String &amp; " not found in " &amp; ModelSchemaName);
			hadErrors := true;
			continue;
		endif;
		
		certifyLog("Parent Class " &amp; parentClass.name &amp; " (" &amp; parentClassNo.String &amp; ") found");
		
		// Now check that the parent class has a property which matches the collection subId
		foundProperty := false;
		foreach property in parentClass.getPropertyValue("properties").PropertyNDict do
			if property.subId.Integer = subId and property.getType.name = collClass.name then
				foundProperty := true;
				break;
			endif;
		endforeach;
		
		if not foundProperty then
			certifyLog("&gt;&gt;&gt; Parent class " &amp; parentClass.name &amp; " (" &amp; parentClassNo.String &amp; ") does not have property matching subId " &amp; subId.String);
			hadErrors := true;
			continue;
		endif;
		
		certifyLog("Property " &amp; property.name &amp; " with subId " &amp; subId.String &amp; " found");
	
	endwhile;
	
	certifyLogFile.close();
	
epilog
	// Just in case there was some kind of exception during the certify, ensure that the access mode is 
	// reset
	if readOnlySet then
		dbFile.changeAccessMode(DbFile.Mode_Update);
	endif;

	if hadErrors then
		certifyLog("Errors were found, please check the application log for details and contact Jade Support");
	endif;
	
	delete certifyLogFile;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="certifyLog" id="0ec76b1f-8194-4c18-8ad4-7c26b62e7fcb">
        <source>certifyLog(_msg : String);

