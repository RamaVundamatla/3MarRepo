    <JadeMethod name="getNextLineNumber" id="77a18ab4-e330-49d5-b9d7-56552cfc72df">
        <source>getNextLineNumber(_pxyReserveSelection : CM_ReserveSelection): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
05 September 2022		navma1	Initial creation
11 June	2025			navbk1  34976: MTN - Cargo Review - Setting up a Release by Id and changing it to by type raises a 1312 

*/

vars
	idx 				: Integer;
	lineNumber			: Integer;
	lastReserve			: CM_ReserveDetail;
	lastLineNumber		: Integer;
	dynaDict 	  		: DynaDictionary;
	reserveDetail	: CM_ReserveDetail;
begin
	self.raiseExceptionIfNotTransient(method);
	
	create dynaDict transient;
	dynaDict.setMembership(CM_ReserveSelection);
	dynaDict.addMemberKey(CM_ReserveSelection::lineNumber.name,false,false);
	dynaDict.endKeys(false);
	
	//self.allReserveDetails.copyNoDuplicates(dynaDict,false);									//11.06.25 navbk1 #34976
	
	//START 11.06.25 navbk1 #34976
	foreach reserveDetail in self.allReserveDetails do
			if reserveDetail.isKindOf(CM_ReserveSelection) then
				dynaDict.addNoDuplicates(reserveDetail, false);
			endif;
	endforeach;
	//END 11.06.25 navbk1 #34976

	lastReserve := dynaDict.last.CM_ReserveSelection;
	if lastReserve &lt;&gt; null then
		lastLineNumber := lastReserve.CM_ReserveSelection.lineNumber;
	endif;
	
	lineNumber := lastLineNumber +1;
	
	return  lineNumber;
epilog
	delete dynaDict;
end;</source>
        <Parameter name="_pxyReserveSelection" type="CM_ReserveSelection"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="731047f5-463d-4e6a-912a-66520b4e8b6a">
        <source>getNiceName(): String;
/*

