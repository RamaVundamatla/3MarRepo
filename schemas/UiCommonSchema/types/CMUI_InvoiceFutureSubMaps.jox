    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="isFromCargoAllocation" id="9d018341-1e18-4728-993c-9182c7ea6499">
        <embedded/>
        <type name="Boolean"/>
        <text>Added  - 09/01/2025	navkc1 JIRA Sub-task MTN-19517: MTN | Jade Sub quantity Range Invoice Cargo Allocations</text>
    </PrimAttribute>
    <ImplicitInverseRef name="myParentQuantityMap" id="73daf4cb-24b9-4c3b-b317-34ca2b9693e3">
        <embedded/>
        <type name="CM_QuantityMap"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySubQuantityRange" id="01f7a7c4-26b4-489e-8549-fbbeb4316870">
        <embedded/>
        <type name="CM_QuantityRangeMap"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayQuantityMap" id="0ad9c6d0-31b0-4130-a9a6-13eeea7da6cf">
        <source>displayQuantityMap();
/*
Purpose:			

Date		Who		Reason
18 May 2023	navab1	TFS CR 58022 TASK 58023
*/

vars
	qm,qMap : CM_QuantityMap;
	qrm : CM_QuantityRangeMap;

begin
	inheritMethod();
	self.grpLines.enabled := true;  
	self.grpQuantityMap.enabled := true;  
	self.optSingle.value := true; 
	// Do escalating later
	self.optSingle.enabled := false;
	self.optEscalate.enabled := false;
	self.optGroupAll.value := true;
	self.optGroupAll.enabled := false;
	self.optGroupGreatest.enabled := false;
	self.optGroupLeast.enabled := false;
	
	qrm := self.mySubQuantityRange;
	if qrm = null then
		qrm := self.myCurrentQuantityRangeMap; // Parent Range map
	endif;
	
	if qrm = null then
		return;
	endif;
	
	qMap := qrm.myQuantityMap;
	if qMap.mappingType = CM_QuantityMap.MapType_Single then
		self.optSingle.value := true;
	else
		self.optEscalate.value := true;
	endif;

	if qMap.myCalculationType &lt;&gt; null then
		if self.cmbQuantityType.findObject(qMap.myCalculationType) &gt; 0 then
			self.cmbQuantityType.listObject := qMap.myCalculationType;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="66aaad04-b38f-4774-95f1-a2e2ce370550">
        <updating/>
        <source>doSave(_close : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
18MAY2023	NAVAB1	TFS CR 58022 TASK 58023
*/

vars
	isUpdate	: Boolean;
	count	: Integer;
	qm, pxyQM,realqm : CM_QuantityMap;
	qrm,
	pxyQRM : CM_QuantityRangeMap;
	theReturn, mapType : Integer;
//	map,
//	fsm	: CM_FutureStorageMapping;
	gt : CM_TranMapInvoiceLineGroupType;
	bu : CM_Bank;
begin
	//09/01/2025	navkc1 JIRA Sub-task MTN-19517
	if self.isFromCargoAllocation then
		bu := self.myCurrentQuantityRangeMap.getBank();
	else
		bu := self.myStorageGroup.getBank();
	endif;
	
	isUpdate := self.updateMode;

	
	if optSingle.value then
		mapType := CM_QuantityMap.MapType_Single;
	else
		mapType := CM_QuantityMap.MapType_Escalate;
	endif;
	
	if self.optGroupAll.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeAll);
	elseif self.optGroupGreatest.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeHigh);
	elseif self.optGroupLeast.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeLow);
	endif;
	
	
	if not isUpdate then // CREATE
		if self.myParentQuantityMap = null then
			create pxyQM transient;
		else
			pxyQM := app.createUpdateProxy(self.myParentQuantityMap).CM_QuantityMap;
		endif;
		pxyQM.setProxy(self.myCurrentQuantityRangeMap,self.chkChargeZero.value, mapType,self.cmbQuantityType.listObject.CM_CalculationType, null);
		pxyQM.setMyCalculationType(self.cmbQuantityType.listObject.CM_CalculationType);
		
		create pxyQRM transient;
		pxyQRM.setProxy(pxyQM, txtFrom.text.Integer, txtTo.text.Integer, 0);
		pxyQRM.setProxyInvoiceLineTypesFS(self.tblData.allSelectedObjects, gt);
	else
		pxyQM := app.createUpdateProxy(self.myParentQuantityMap).CM_QuantityMap;
		pxyQM.setProxy(self.myParentQuantityMap.myParentFinancialObject,self.chkChargeZero.value, mapType,self.cmbQuantityType.listObject.CM_CalculationType, null);
		pxyQM.setMyCalculationType(self.cmbQuantityType.listObject.CM_CalculationType);
		
		pxyQRM := app.createUpdateProxy(self.myCurrentQuantityRangeMap).CM_QuantityRangeMap;
		pxyQRM.setProxy(pxyQM, txtFrom.text.Integer, txtTo.text.Integer, 0);
		pxyQRM.setProxyInvoiceLineTypesFS(self.tblData.allSelectedObjects, gt);
	endif;

	
	while true do
		app.myTrxUA.trxUpdateInvoiceFutureStorage(isUpdate, pxyQM,realqm, pxyQRM, null, self.myStorageDetail);
		if app.myPassport.trxCompletedOK then
			global.beep;
			if _close then
				self.unloadForm();
			endif;
			if self.myParentQuantityMap = null then
				self.myParentQuantityMap := realqm;
			endif;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


epilog
	if global.isValidObject(pxyQRM) then
		delete pxyQRM;
	endif;
	if global.isValidObject(pxyQM) then
		delete pxyQM;
	endif;

end;</source>
        <Parameter name="_close" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDescription" id="2e156153-ebe4-42eb-8001-4f6e411ada70">
        <source>setDescription();
/*
Purpose:			
Date		Who		Reason
25 May 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myCurrentQuantityRangeMap &lt;&gt; null then
		self.lblDescription.caption := self.myCurrentQuantityRangeMap.getFullName();
		if self.myStorageGroup &lt;&gt; null then
			self.lblDescription.caption := self.myStorageGroup.code &amp; " " &amp; self.lblDescription.caption;
		endif;
	endif;

	if updateMode then
		self.lblDescription.caption := self.lblDescription.caption &amp; " SUB RANGE " &amp; app.getErrorString(InvCargoAllocMapUPDATE);
	else
		self.lblDescription.caption := self.lblDescription.caption &amp; " SUB RANGE " &amp; app.getErrorString(InvCargoAllocMapNEW);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForNew" id="795f2003-a550-4be3-8f18-262d686c1c54">
        <source>setForNew();
/*
Purpose:			

Date		Who		Reason
18MAY2023	NAVAB1	TFS CR 58022 TASK 58023
*/

vars
	qm,qMap : CM_QuantityMap;
	qrm : CM_QuantityRangeMap;
	sb : CM_FutureStorageMapping;

begin
	if self.updateMode then
		return;
	endif;
	
	self.chkChargeZero.value := false;
	self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
	self.chkMaximum.value := true;
	self.optGroupAll.value := true;
	self.optSingle.value := true; 
	self.grpQuantityMap.enabled := true;
	self.grpLines.enabled := true;
	
	if self.myParentQuantityMap &lt;&gt; null then
		qrm := self.myParentQuantityMap.allQuantityRanges.last;
	endif;
	
	if qrm = null then
		self.txtFrom.text := "0";
	else
		if qrm.rangeEnd &lt;&gt; CM_QuantityRangeMap.MAX_RANGE then
			self.txtFrom.text := (qrm.rangeEnd + 1).String;
			qMap := qrm.myQuantityMap;
			if qMap.mappingType = CM_QuantityMap.MapType_Single then
				self.optSingle.value := true;
			else
				self.optEscalate.value := true;
			endif;
			if qMap.myCalculationType &lt;&gt; null then
				if self.cmbQuantityType.findObject(qMap.myCalculationType) &gt; 0 then
					self.cmbQuantityType.listObject := qMap.myCalculationType;
				endif;
			endif;
		endif;

	endif;
	
	
	sb := self.myStorageMapping;
	if sb &lt;&gt; null then
		qm := sb.myQuantityMap;
		if qm &lt;&gt; null then
			qrm := qm.allQuantityRanges.last;
			if qrm &lt;&gt; null  and qrm.rangeEnd &lt; CM_QuantityRangeMap.MAX_RANGE then
					self.txtFrom.text := (qrm.rangeEnd + 1).String;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
