    <JadeMethod name="addAssignedCargo" id="67756d25-dcff-4481-82cf-1b3ba6f2733b">
        <updating/>
        <source>addAssignedCargo( _ti : CM_TrackedItem input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2015	cnwndl1	Initial creation	Par 36338
12 Nov 2019	NDL	TFS 47298
28 Jun 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
30 Nov 2023	navkc1  ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval
30 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars

	firstTi 				: CM_TrackedItem;
	cargoTypeDesc 			: String;
	productDecs 			: String;
	grpCargoTypeDesc 		: String;
	grpProductDesc 			: String;
	cargoGroupAssignment	: CM_CargoGroupAssignment;
begin

	if _ti.myOperator &lt;&gt; self.myOperator
		and not self.allOperators.includes(_ti.myOperator) //30/11/2023	navkc1 ChangeRequest 58254 Task 58257
	then
		app.raiseCMException2( Cargo_Group_Oper_diff, _ti.operatorCode, self.operatorCode, null, null );
		return;
	endif;
	
	if not self.allAssignedTrackedItems.isEmpty then
		firstTi := self.allAssignedTrackedItems.first;
		if firstTi.myCargoType &lt;&gt; null then
			grpCargoTypeDesc := firstTi.myCargoType.description;
		endif;
		if firstTi.myProduct &lt;&gt; null then
			grpProductDesc := firstTi.myProduct.description;
		endif;
		
		if _ti.myCargoType &lt;&gt; null then
			cargoTypeDesc := _ti.myCargoType.description;
		endif;
		if _ti.myProduct &lt;&gt; null then
			productDecs := _ti.myProduct.description;
		endif;
	
		if cargoTypeDesc &lt;&gt; grpCargoTypeDesc then
			app.raiseCMException2( Cargo_being_added_diffe_cargo_, cargoTypeDesc, grpCargoTypeDesc, null, null );
			return;
		endif;
		if productDecs &lt;&gt; grpProductDesc 
		and grpProductDesc &lt;&gt; null then // 28/06/2023 navmv20 CR 58410 Task 58411
			app.raiseCMException2( Cargo_being_added_subcargo, productDecs, grpProductDesc, null, null );
			return;
		endif;
	endif;

	if not self.allAssignedTrackedItems.includes( _ti ) then
	
		if not self.validateWeightIncluding( _ti ) then
			return;
		endif;
		
		if self.isComplete then
			app.raiseCMWarning1( Cargo_group_already_complet, self.id, null, null, null );
		endif;
		
		if _ti.myCargoGroup &lt;&gt; null then
			_ti.myCargoGroup.removeAssignedCargo( _ti, _passport );
		endif;
		_ti.setMyCargoGroup( self, _passport );
		if process.isInTransactionState then//16Sep2022 navsp1 TFS#54526 - CM_EDICargoTI.setProxy() ends up here without being in transaction state.
			self.updateObjectEdition( self );
		endif;
	endif;
	
	//02 Oct 2018	NDL	TFS 39186
	cargoGroupAssignment := self.getMyCargoGroupAssignment();			//30.06.2025 navma1 #MTN-34090
	if cargoGroupAssignment &lt;&gt; null then
		if cargoGroupAssignment.cargoIdsInclude( _ti.id ) then
			if not cargoGroupAssignment.addProcessedTi( _ti ) then		//07 Sep 2020 NDL	TFS 49789
				return;
			endif;
		else
			if self.preAssignedCargoIdsInclude( _ti.id ) then
				if not cargoGroupAssignment.addProcessedTi( _ti ) then	//07 Sep 2020 NDL	TFS 49789
					return;
				endif;
			endif;
		endif;
	endif;
	
	self.setForArchiving( true, false, null );
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTIForCustDocs" id="7fcb9580-d617-4df2-a6fa-1d314b5415a3">
        <updating/>
        <source>addTIForCustDocs(_ti : CM_TrackedItem input) updating;
/*
Purpose:			

Date		Who		Reason
25 September 2023	navab1	CR 60424 TASK 60549 
*/

vars
	cdd, newCDD : CM_CustomDocumentDetail;
	cd : CM_CustomDocument;

begin
			
	if self.allCustomDocDetails.size = 1 then // only if it was missed from the first document e.g. D126
		if _ti.allCustomDocDetails.isEmpty() then
			cdd :=  self.allCustomDocDetails.first;
			if cdd &lt;&gt; null then
				// ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
				if cdd.isCancelled() then
					return;
				endif;
			
				if cdd.allSubDetails.isNotEmpty() then
					newCDD := cdd.createSubDetailForTI(_ti);
					
					cd := cdd.getCustomDocumentHeader();
					cd.addTI(_ti);
					cdd.setAmountsFromTI(); // update the cargo group amounts
					
					newCDD.createTransactionForTI(TRANS_TYPE_CUSTDOCADDED);
					
					if cd.myCustomDocumentType &lt;&gt; null
					and cd.myCustomDocumentType.allStopsToApply.isNotEmpty() then
						newCDD.applyStops(_ti,cd.myCustomDocumentType.allStopsToApply, true);
					endif;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="assignedCargoHasStops" id="39d4758b-d2d6-4da9-8ed8-3e9d28cb8377">
        <source>assignedCargoHasStops():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2015	cnwndl1	Initial creation	Par	36338 
10 June 2024 navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgDtl : CM_CargoGroupDetail;
	ti		: CM_TrackedItem;
begin
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.hasStops then
				return true;
			endif;
		endforeach;
	else
		foreach cgDtl in self.allCargoGroupDetails discreteLock do
			if cgDtl.hasStops then
				return true;
			endif;		
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignedCargoHasTasks" id="c88dd2ef-272a-4aeb-a2cb-3035d583b20a">
        <source>assignedCargoHasTasks():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2015	cnwndl1	Initial creation	Par	36338 

*/

vars

	ti : CM_TrackedItem;

begin

	foreach ti in self.allAssignedTrackedItems discreteLock do
		if ti.hasToDoTasks then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="couldAddCargoItem" id="82b36567-6500-41f8-83ed-b95356eba05c">
        <source>couldAddCargoItem( _ti : CM_TrackedItem ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2018	jlgndl1	Initial creation	TFS 39186
30/11/2023		navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars

	firstTi : CM_TrackedItem;

begin

	if self.isComplete then
		return false;
	endif;
	
	if self.totalWeight + _ti.totalWeight &gt; self.maxWeight then
		return false;
	endif;

	if _ti.myOperator &lt;&gt; self.myOperator 
		and not self.allOperators.includes(_ti.myOperator) //30/11/2023	navkc1 ChangeRequest 58254 Task 58257
	then
		return false;
	endif;
	
	if not self.allAssignedTrackedItems.isEmpty then
		firstTi := self.allAssignedTrackedItems.first;
		if firstTi.myCargoType &lt;&gt; _ti.myCargoType then
			return false;
		endif;
		if firstTi.myProduct &lt;&gt; _ti.myProduct then
			return false;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="4188b392-154f-417e-a3cc-c4f6ffb249ee">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	self.site := TI_SITE_CARGOGROUP;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefreshAllOperators" id="1fb234b5-e536-4c23-a799-f705b370c7ba">
        <updating/>
        <source>doRefreshAllOperators() updating;
/*

Purpose:			This method goes through all tracked items and update self.allOperators collection

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

vars
	operator			: CM_Operator;
	ti					: CM_TrackedItem;
begin
	
	self.allOperators.clear();
	
	foreach ti in self.allAssignedTrackedItems do
		operator := ti.myOperator;
		
		if operator = null then
			continue;
		endif;
		
		self.allOperators.addNoDuplicates(operator, false);		
	endforeach;
	
	// ### JIRA 33801 14JAN2025 NAVAB1
	if self.allOperators.size = 1 then
		operator := self.allOperators.first;
		if self.myOperator &lt;&gt; operator then
			self.setMyOperator(operator);
		endif;
	endif;
	
	self.updateObjectEdition(self);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllLocations" id="791eefb4-b3db-4bcb-bb19-2bfcb517c9be">
        <source>getAllLocations( _lcs : CM_LCSet input):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608
*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	locnStr : String;
	strArray : StringArray;
	intArray : IntegerArray;
	returnString : String;
	index : Integer;

begin
	
	if self.allAssignedTrackedItems.isEmpty then
		return null;
	endif;
	
	create strArray transient;
	create intArray transient;
	
	iter := self.allAssignedTrackedItems.createIterator;
	while iter.next( ti ) do
		lc := null;
		locnStr := null;
		if ti.isNotified then	//15 Feb 2016	NDL	Par 37544
			locnStr := app.stateEnumToString(TI_STATE_NOTIFIED);
		elseif ti.isOnSite and ti.myPrimaryActualLocation &lt;&gt; null then
			lc := ti.myPrimaryActualLocation;
			locnStr := lc.getFullId();
		// ### TFS 57191 23Mar2023 NAVPW1
		elseif ti.isOnShip and ti.myPrimaryActualLocation &lt;&gt; null then
			locnStr := app.stateEnumToString(TI_STATE_ONSHIP);
		// ### TFS 57191 23Mar2023 NAVPW1
		endif;
		if locnStr = null then
			locnStr := app.getErrorString(OffSite);
		endif;
		if not strArray.includes( locnStr ) then
			if _lcs &lt;&gt; null and lc &lt;&gt; null then
				_lcs.add(lc);
			endif;
			strArray.add( locnStr );
			intArray.add( 1 );
		else
			index := strArray.indexOf( locnStr );
			intArray[index] := intArray[index] + 1;
		endif;
	endwhile;
	
	if strArray.isEmpty then
		return null;
	endif;
	
	index := 0;
	foreach locnStr in strArray do
		index := index + 1;
		if returnString &lt;&gt; null then
			returnString := returnString &amp; ", ";
		endif;
		returnString := returnString &amp; locnStr &amp; " (x" &amp; intArray[index].String &amp; ")";
	endforeach;
	
	return returnString;

epilog

	delete iter;
	delete strArray;
	delete intArray;

end;</source>
        <Parameter name="_lcs" type="CM_LCSet" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllOperatorsCode" id="add0afed-1a9e-420e-aa55-b2c3bb63a841">
        <source>getAllOperatorsCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 61099: UI - Ownership Change Approved

*/

vars
	string		: String;
	operator	: CM_Operator;
begin
	
	if self.allOperators.isEmpty() then
		if self.myOperator &lt;&gt; null then
			return self.myOperator.code;
		endif;
	endif;
	
	foreach operator in self.allOperators discreteLock do
		
		if string &lt;&gt; null then 
			string &amp;= ", ";
		endif;
		
		string &amp;= operator.code;
	endforeach;
	
	return string;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllOperatorsStr" id="a70f1842-8e26-44e6-8b1f-3110bc38d8be">
        <source>getAllOperatorsStr() : String;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	 CR 58246 TASK 58248 
*/

vars
	op : CM_Operator;
	reString : String;
begin
	foreach op in self.allOperators discreteLock do
		if reString = null then
			reString := op.oidAsBin;
		else
			reString := reString &amp; "," &amp; op.oidAsBin;
		
		endif;
	endforeach;
	
	return reString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllPreAssignedCargoIds" id="7a423993-c625-4ef4-a7a8-36ed6e4e2977">
        <source>getAllPreAssignedCargoIds( _allPreAssignedCargoIds : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ncg : CM_NotifiedCargoGroup;

begin

	_allPreAssignedCargoIds.clear();

	if not self.allPreAssignedCargoIds.isEmpty then
		self.allPreAssignedCargoIds.copy( _allPreAssignedCargoIds );
	else
		ncg := self.getMyNotifiedGroup;
		if ncg &lt;&gt; null then
			ncg.allPreAssignedCargoIds.copy( _allPreAssignedCargoIds );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_allPreAssignedCargoIds" type="StringArray" usage="input"/>
    </JadeMethod>
