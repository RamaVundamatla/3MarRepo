    <JadeMethod name="create" id="9fb23264-aea4-4aea-814f-635ce1323f89">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2012	cnwndl1	Initial creation	Par 30901
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin

	self.createdDate := app.actualTimeServer.Date;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="0d9162b7-cac2-464c-b76d-2d1486a9e75b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	dutyDocItem : CM_DutyDocItem;
begin
	if self.isTransient then
		return;
	endif;
	
	
	foreach dutyDocItem in self.allDutyDocItems do
		dutyDocItem.setProxyDutyDoc(null);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="6c881289-e93a-4962-aac3-38c596f748f1">
        <source>doPrint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	term : CM_Terminal;
	reportString : String;

begin

	term := self.getMyTerminal;
	
	if term &lt;&gt; null then
		reportString := term.getConfig(DutyDocumentReport).String;
	endif;
	
	if reportString = null then
		reportString := DefRep_DutyDocumentReport;
	endif;
	
	if reportString.pos("?DOT", 1) &gt; 0 then
		app.printReportDotMatrix(reportString, self, false);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllCashReceipts" id="fea7d9e9-be8b-4f64-aa36-c227e0a5f0d2">
        <source>getAllCashReceipts() : String;
/*
Purpose:			
Date		Who		Reason
21 May 2014	cnwab1	Initial creation
*/

vars
	allCashReceipts : CM_CashReceiptDict;
	rec : CM_CashReceipt;
	docStr : String;
begin

	create allCashReceipts transient;	
	 self.getCashReceipts( allCashReceipts );

	 
	 
	foreach rec in allCashReceipts discreteLock do
		if docStr = "" then
			docStr := rec.getOidString; //	.oidAsBin;
		else
			docStr := docStr &amp; "," &amp; rec.getOidString; // oidAsBin;
		endif;
 
	endforeach;
	
	return docStr;
	 
	 
	 
epilog
	delete allCashReceipts;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllDutyDocItems" id="e539e126-1e25-4d09-9891-3f9816aa7be1">
        <source>getAllDutyDocItems() : String;
/*
Purpose:			
Date		Who		Reason
21 May 2014	cnwab1	Initial creation
*/

vars
	doc : CM_DutyDocItem;
	docStr : String;
begin
	foreach doc in self.allDutyDocItems discreteLock do
		if docStr = "" then
			docStr := doc.getOidString; //	.oidAsBin;
		else
			docStr := docStr &amp; "," &amp; doc.getOidString; // oidAsBin;
		endif;
 
	endforeach;
	
	return docStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOL" id="e1f9fccd-a413-4a71-b6b4-c8e1e1a18375">
        <source>getBOL() : String;
//16 December 2013	cnwdw1	
//
vars

begin
	if self.bol = "" then
		if self.allDutyDocItems.size &gt; 0 then
			return self.allDutyDocItems.first.bol;
		endif;
	endif;
	return self.bol;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="0faadf7a-760c-44ac-896a-50b134d1b457">
        <source>getBank():CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2013	cnwndl1	Initial creation

*/

vars
	item : CM_DutyDocItem;
	ti : CM_TrackedItem;
	term : CM_Terminal;
	bank : CM_Bank;
begin

	foreach item in self.allDutyDocItems do
		ti := item.getMyTrackedItem();
		if ti &lt;&gt; null then
			bank := ti.companyOid;
			if bank &lt;&gt; null then
				return bank;
			endif;
		endif;
	endforeach;
	
	term := self.getMyTerminal;
	if term &lt;&gt; null then
		bank := term.getDefaultCompanyBank();
		if bank &lt;&gt; null then
			return bank;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getCargoIdsFor" id="e9e731d5-cd6d-4cf8-90c5-7e6994401d16">
        <source>getCargoIdsFor( _items : CM_DutyDocItemSet ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	str : String;
	allTis : CM_TISet;
	ti : CM_TrackedItem;
	
begin
	
	create allTis transient;
	self.getTIsFor(_items, allTis);

	
	foreach ti in allTis do
		if str = null then
			str := ti.id;
		else
			str := str &amp; ", " &amp; ti.id;
		endif;
	endforeach;
	

epilog

	delete allTis;
	return str;

end;</source>
        <Parameter name="_items" type="CM_DutyDocItemSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCashReceipts" id="64c7ca1b-bba8-4b76-b32b-79a14133c286">
        <source>getCashReceipts( _allCashReceipts : CM_CashReceiptDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	term : CM_Terminal;
	debtor : CM_Debtor;
	debtorTerm : CM_DebtorTerminal;

begin

	//  'The Cash Module' is a Balance bought forward style of accounting
	// Financial payments( CM_CashReceipt objects) are simply recorded as a credit against a Debtor )
	// and 'payment' of an invoiceLine, ( CM_CashPayment ) is a credit against the invoice line and a debit against a Debtor.
	//  Duty Docs have multiple cargo items with multiple invoice lines. 
	//  Therefore no possible way of unconditionally staing that any one particular 'physical payment of money' directly relates to any specific duty document.
	//return null;
	
	term := self.getMyTerminal;
	if term = null then
		 return;
	endif;
	debtor := self.getMyDebtor;
	if debtor = null then
		return;
	endif;
	debtorTerm := term.allDebtorTerminals.getAtKey( debtor );
	if debtorTerm = null then
		return;
	endif;
	
	debtorTerm.getCashReceiptsForDutyDoc( self, _allCashReceipts );
	
	return;

epilog

end;</source>
        <Parameter name="_allCashReceipts" type="CM_CashReceiptDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getChargesFor" id="9af1b9d2-427d-4b09-8d5c-4057cb055043">
        <source>getChargesFor(	_items : CM_DutyDocItemSet;
				_dutyCharges : Decimal output;	//18 Dec 2013	NDL	Par 33182
				_termCharges : Decimal output;
				_storageCharges : Decimal output;
				_otherCharges : Decimal output;
				_totalCharges : Decimal output
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	allTis : CM_TISet;
	term : CM_Terminal;
	bank : CM_Bank;
	ti : CM_TrackedItem;
	agent : CM_CashInvoiceProformaAgent;

begin
	
	create allTis transient;
	self.getTIsFor(_items, allTis);
	
	if allTis.isEmpty then
		return;
	endif;
	
	term := self.getMyTerminal;
	if term &lt;&gt; null then
		bank := term.getDefaultCompanyBank();
	endif;
	
	if bank = null then
		return;
	endif;
	
	foreach ti in allTis do
		// process a proforma so we can get the proposed charges and then any charges already invoiced
		create agent transient;
		agent.init( bank, ti, self.effectiveDate, false );
		agent.getDutyDocValues(	self,	//_dutyDoc : CM_DutyDocItem;
								_dutyCharges,	//_dutyCharges : Decimal output;	//18 Dec 2013	NDL	Par 33182
								_termCharges,	//_termCharges : Decimal output;
								_storageCharges,	//_storageCharges : Decimal output;
								_otherCharges,	//_otherCharges : Decimal output;
								_totalCharges	//_totalCharges : Decimal output
								);
	endforeach;

epilog

	delete allTis;
	delete agent;

end;</source>
        <Parameter name="_items" type="CM_DutyDocItemSet"/>
        <Parameter name="_dutyCharges" type="Decimal" usage="output"/>
        <Parameter name="_termCharges" type="Decimal" usage="output"/>
        <Parameter name="_storageCharges" type="Decimal" usage="output"/>
        <Parameter name="_otherCharges" type="Decimal" usage="output"/>
        <Parameter name="_totalCharges" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getConfDateDocInChargeLocalTZ" id="b9226de4-69e1-4b28-ae8c-57525c218d2a">
        <source>getConfDateDocInChargeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2016	cnwns1	Initial creation
// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.docInChargeUserDate);
epilog

end;</source>
