<Class name="CM_CuxportConsumerAgent" id="81333ed4-42f1-4072-b8f9-08ed0d9ffde9">
    <superclass name="CM_ExtWebServiceConsumerAgent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="actTerminal" id="85796d13-111f-4086-aadb-6f5e3cdf205b">
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="dataType" id="91d04d99-d97d-4238-8014-2dd776f0c08b">
        <length>31</length>
        <embedded/>
