    <JadeMethod name="utlCreateTerminalBRXref" id="41b9d9d1-d105-469c-8612-e44f29d93154">
        <updating/>
        <source>utlCreateTerminalBRXref(_terminal : CM_Terminal;
						_brXref : CM_TerminalTIsByBR output;
						_passport : CM_Passport input) updating;

/*

Purpose:			Create a new Booking Ref cross reference for the passed in Terminal, ready 
					to be built from all the Tracked Items

Parameters:			Terminal to build cross reference for

Return Value:		_brXref populated with the newly created crosss reference


Date		Who		Reason
28 Aug 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable

*/

vars
	brXref			: CM_TerminalTIsByBR;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_terminal, "Terminal");
	
	// Reserve lock on CM_Terminal to single thread through the check for an existing
	// cross reference
	reserveLock(_terminal);
	brXref := _terminal.getBookingRefXref();
	
	// Error if the Booking Reference cross ref already exists
	if brXref &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, "Booking Ref cross reference",_terminal.displayForXlation(false), null, null); //14.06.2022 navds20 53760
		//Booking Ref cross reference already exists for %1 : Bookin_cross_refere_alread_exi
		app.raiseCMException1(Bookin_cross_refere_alread_exi,_terminal.displayForXlation(false), null, null); //14.06.2022 navds20 53760
		return;
	endif;
	
	// OK to create the cross reference, and set the Terminal extra data to point to it
	create brXref persistent;
	brXref.setMyTerminal(_terminal);
	_terminal.setExtraData(XrefTIByBookingRef, brXref);
	
	// And set up return cross reference value
	_brXref := brXref;
	
	app.writeLog("Booking Ref cross reference created for Terminal " &amp; _terminal.displayForXlation(false), LogINFO);

	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_brXref" type="CM_TerminalTIsByBR" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTerminalSubArea" id="94219bc1-c7f9-40b0-9c4b-0150cbca14d8">
        <source>utlCreateTerminalSubArea(_pxyTerminalSubArea : CM_TerminalSubArea input; 
_newTerminalSubArea: CM_TerminalSubArea output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     CCMS 1314
// ----------   ----------  --------------------------------------------------
vars
	aTA : CM_TerminalArea;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	app.myValCA.valTerminalSubArea(_pxyTerminalSubArea);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	
	create _newTerminalSubArea as CM_TerminalSubArea persistent;
	_newTerminalSubArea.setForCreate(_pxyTerminalSubArea, _passport); // Populate Real Stack from Proxy

	if _passport.noErrors then
		aTA := _newTerminalSubArea.myTerminalArea;
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Create),false,_newTerminalSubArea);
		self.myCreateAuditAgent.audCreateGeneric(_newTerminalSubArea);
	endif;	

end;</source>
        <Parameter name="_pxyTerminalSubArea" type="CM_TerminalSubArea" usage="input"/>
        <Parameter name="_newTerminalSubArea" type="CM_TerminalSubArea" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
