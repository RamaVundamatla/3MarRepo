    <JadeMethod name="setupForm" id="483fe1ef-ae1e-4b0b-931d-0df25f13032a">
        <updating/>
        <source>setupForm() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars
begin
	inheritMethod();

	self.caption := self.myCurrentVoyage.code &amp; " " &amp; self.caption;
	
	self.txtFilter.setupControl(self.tblData,300);
	
	self.getXMLSettingsForSetup();
	
	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.myCurrentVoyage &lt;&gt; null and  self.myCurrentVoyage.myVoyageProgress &lt;&gt; null then
		self.chkPauseAutoProcess.value := self.myCurrentVoyage.myVoyageProgress.pauseProgress;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end
	
	self.initDataTable();
	self.doBuildCmbOperator();
	self.doBuildCmbStatus();
	
	self.startNotifications();
	
	self.doPermissions();
	
	self.doClear();
	
	self.doQuery();
	
	app.myCurrentVoyage := self.myCurrentVoyage;						//navra1 - MTN-33017 - 11th Oct 2024

epilog
end;</source>
