    <JadeMethod name="createRoadProcess" id="80dcabe2-3d37-4e49-bf73-e77e27e1d51a">
        <source>createRoadProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2021	navpw1	Initial creation TFS: 52268

*/

vars
	roadProcess,
	pxyRoadProcess : CM_RoadProcess;
	
begin
	app.initialize();
	
	// 1-Stop Process 
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ONESTOP_VBS ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.ONESTOP_VBS);
		pxyRoadProcess.setDescription("1-Stop LOLO Voyages");
		app.myTrxCA.trxCreateRoadProcess(pxyRoadProcess, roadProcess, app.myPassport);
		delete pxyRoadProcess;
		
		roadProcess := null;
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="handle3039Exception" id="a6b384c6-5b74-4b2d-a3f0-e7ff284b161b">
        <source>handle3039Exception(_exc : Exception; _obj : Object; _invalidObject : Boolean io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2025	navpw1	Initial creation

*/

constants
	SchemaObjectSizeMismatch = 3039;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = SchemaObjectSizeMismatch then
		if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_invalidObject := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pw55839Upgrade" id="942e0311-c3fd-4445-9d73-097ebe915e0b">
        <source>pw55839Upgrade();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2023	navpw1	Initial creation TFS: 54049 (55839)

*/

vars
	terminal : CM_Terminal;
	vehicleVisit : CM_VehicleVisitRecord;
	vbsTimeslot : CM_VehicleBookingTimeSlot;
	
begin
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		foreach vehicleVisit in terminal.allVehicleVisits do
			vbsTimeslot := vehicleVisit.myVehicleBookingTimeslot;
			
			if vbsTimeslot = null then
				continue;
			endif;
			
			if vehicleVisit.allVehicleBookingSlots[vbsTimeslot.id] &lt;&gt; null then
				continue;
			endif;
			
			vehicleVisit.allVehicleBookingSlots.add(vbsTimeslot);
			
		endforeach;
	endforeach;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pw57783" id="166a6aff-e9f9-44b8-a0f8-98e9c300003f">
        <source>pw57783();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navpw1	Initial creation

*/

vars
	vbts : CM_VehicleBookingTimeSlot;
begin
	beginTransaction;
		foreach vbts in CM_VehicleBookingTimeSlot.instances do
			vbts.setPropertyValue(CM_VehicleBookingTimeSlot::externalReference.name, null);
		endforeach;
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="pw577831" id="dd6ab559-e2ae-4b4c-8a97-9cdb39587412">
        <source>pw577831();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2023	navpw1	Initial creation TFS: 57783

*/

vars
	timeSlot				: CM_VehicleBookingTimeSlot;
	autoBookingIdGenerator	: CM_AutoVehicleBookingIdGen;
	externalReference		: String;
	terminal				: CM_Terminal;
	
	iterTerminal			: Iterator;
	allVBTimeslotsById		: CM_VehicleBookingTimeSlotById;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	
begin
	iterTerminal := app.myRoot.allTerminals.createIterator;
	
	while iterTerminal.next(terminal) do
		vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
		
		if vehicleBookingTerminal = null then
			continue;
		endif;
		
		allVBTimeslotsById := vehicleBookingTerminal.allVBTimeslotsById;
		
		if allVBTimeslotsById.isEmpty then
			continue;
		endif;
		
		autoBookingIdGenerator := terminal.getMyAutoIdGenerator(CM_AutoVehicleBookingIdGen).CM_AutoVehicleBookingIdGen;
		
		if not autoBookingIdGenerator.getExtRefEnabled() then
			continue;
		endif;
		
		beginTransaction;
		
		write "Terminal Code: " &amp; terminal.code;
		
		foreach timeSlot in allVBTimeslotsById do
			//if timeSlot.externalReference = null then
			//	continue;
			//endif;
			
			//if not timeSlot.externalReference.startsWith(autoBookingIdGenerator.externalRefPrefix) then
			//	continue;
			//endif;
			
			write "Timeslot Id: " &amp; timeSlot.id;
			
			externalReference := autoBookingIdGenerator.getExternalRefIdFromVBSId(timeSlot.id);
			
			if autoBookingIdGenerator.newExternalRefIdNotAlreadyUsed(externalReference) then
				timeSlot.setPropertyValue(CM_VehicleBookingTimeSlot::externalReference.name, externalReference);
				
			endif;
		endforeach;
		
		commitTransaction;
		
	endwhile;
	
epilog
	delete iterTerminal;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pw60657" id="db3e24eb-c711-47fc-b812-345834dee2e5">
        <source>pw60657();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2024	navpw1	Initial creation TFS: 60657

*/

vars
	terminal : CM_Terminal;
	ta : CM_TerminalArea;
	logController : CM_LogController;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	
begin
	terminal := app.myRoot.allTerminals["WHG"];
	ta := terminal.allTerminalAreas["REJ"];
	logController := ta.CM_RowArea.allRowControllersById["REJTENCO"].CM_LogController;
	create tiSet transient;
	logController.allTrackedItems.copy(tiSet);
	//beginTransaction;
	foreach ti in tiSet do
		if ti.myVoyage = null then
			continue;
		endif;
		
		if global.isValidObject(ti.myVoyage) then
			continue;
		endif;
		
		//ti.setPropertyValue("myVoyage", null);
		app.writeLog("Processing Ti: '" &amp; ti.id &amp; "' - Setting invalid voyage to null", LogDEBUG);
	endforeach;
	//commitTransaction;
	
epilog
	delete tiSet;
	//abortTransaction;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwC3LogReceivalBOL" id="50c621b5-8d78-4fb0-8d83-1e587bfddc0e">
        <source>pwC3LogReceivalBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2025	navpw1	Initial creation

*/

vars
	term,
	termMro: CM_Terminal;
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	strArray : StringArray;
	str : String;
	bolIn : CM_BOLIn;
	completedOk : Boolean;
	
begin
	app.writeLog("Running Script", LogDEBUG);
	create strArray transient;
	strArray.add("V17293548");
	strArray.add("V17293450");
	strArray.add("V17293451");
	strArray.add("V17293469");
	strArray.add("V17293470");
	strArray.add("V17293472");
	strArray.add("V17293473");
	strArray.add("V17293474");
	strArray.add("V17293475");
	strArray.add("V17293476");
	strArray.add("V17293477");
	strArray.add("V17293481");
	strArray.add("V17293482");
	strArray.add("V17293483");
	strArray.add("V17293485");
	strArray.add("V17293497");
	strArray.add("V17293498");
	strArray.add("V17293499");
	strArray.add("V17293502");
	strArray.add("V17293504");
	strArray.add("V17293509");
	strArray.add("V17293510");
	
	create tiSet transient;
	term	:= app.myRoot.allTerminals["WEL"];
	termMro	:= app.myRoot.allTerminals["MRO"];
	bolIn	:= termMro.getBOLInByNumber("7005238", 5001);
	
	//bolIn.inspect;
	
	//return;
	
	beginTransaction;
	foreach str in strArray do
		term.lookupAllOnShipTrackedItems(str, 9, true, false, false, tiSet, null);
		
		ti := tiSet.first;
		
		if ti = null then
			app.writeLog("ti null: " &amp; str, LogDEBUG);
			
		else
			ti.setPropertyValue(CM_TrackedItem::myReceivalBOL.name, bolIn);
			app.writeLog("ti: " &amp; ti.id &amp; " | Bol Set: " &amp; bolIn.number, LogDEBUG);
		endif;
		
		tiSet.clear();
		
	endforeach;
	commitTransaction;
	
	completedOk := true;
	
epilog
	if not completedOk then
		abortTransaction;
	endif;
	
	delete tiSet;
	delete strArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwCheckConstant" id="a84deb0d-c40b-47d4-9c6a-95faf8d61446">
        <source>pwCheckConstant();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2024	navpw1	Initial creation

*/

vars
	portSchema		: Schema;
	constant		: Constant;
	constantName	: String;
	
begin
	write "Enter constant name:";
	read constantName;
	
	if constantName = null then
		write "No Constant entered";
		return;
	endif;
	
	portSchema := rootSchema.getSchema("PortSchema");
	
	if portSchema = null then
		write "Could not find PortSchema";
	endif;
	
	constant := portSchema.getConstant(constantName);
	
	if constant = null then
		write "Could not find constant: '" &amp; constantName &amp; "'";
	endif;
	
	write "";
	write "Modified By:" &amp; Tab &amp; constant.getModifiedBy;
	write "Modified At:" &amp; Tab &amp; constant.cnGetModifiedTimeStamp().asStringJMT();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pwCigTest" id="a95a48d3-f251-4bfa-b036-58876ff01020">
        <source>pwCigTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2024	navpw1	Initial creation

*/

constants
	TerminalCode : String = "PW";
	CargoID : String = "PHL02094";
	CargoTypeAbbre : String = "CONT";
	
vars
	terminal : CM_Terminal;
	cargoType : CM_CargoBOLType;
	ti : CM_TrackedItem;
	tiSet	: CM_TISet;
	completedOk : Boolean;
	
begin
	app.initialize;
	
	terminal := app.myRoot.allTerminals[TerminalCode];
	if terminal = null then
		app.msgBox("Terminal is null", "Terminal Null", MsgBox_OK_Only);
		return;
		
	endif;
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation(CargoTypeAbbre);
	if cargoType = null then
		app.msgBox("Cargo Type is null", "Cargo Type Null", MsgBox_OK_Only);
		return;
		
	endif;
	
	ti := terminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(CargoID, cargoType.id);
	if ti = null then
		app.msgBox("Ti is null", "Ti Null", MsgBox_OK_Only);
		return;
	endif;
	
	if ti.id &lt;&gt; CargoID then
		app.msgBox("Ti does not match id: '" &amp; CargoID &amp; "' | Id of found: '" &amp; ti.id &amp; "'", "Ti Id Not Match", MsgBox_OK_Only);
		return;
	endif;
	
	if ti.cargoType &lt;&gt; cargoType.id then
		app.msgBox("Ti does not match cargo type: '" &amp; CargoTypeAbbre &amp; "' | Cargo Type of found: '" &amp; ti.cargoTypeCode &amp; "'", "Ti Cargo Type Not Match", MsgBox_OK_Only);
		return;
	endif;
	
	create tiSet transient;
	tiSet.add(ti);
	
	beginTransaction;
	delete ti;
	commitTransaction;
	completedOk := true;
	
	//app.myTrxDA.trxDeleteTrackedItems(tiSet, null, false, app.myPassport);
	//if not app.myPassport.trxCompletedOK then
	//	app.msgBox("Failed to delete tracked item: " &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarningsAsStr, "Failed to delete ti", MsgBox_OK_Only);
	//	return;
	//endif;
	
epilog
	if not completedOk then
		abortTransaction;
		app.msgBox("Failed to delete tracked item:", "Failed to delete ti", MsgBox_OK_Only);
	endif;
	delete tiSet;
	
end;
	</source>
    </JadeMethod>
    <JadeMethod name="pwCleanupUTInvLineDesc" id="22f1ac18-05b4-4ec7-890c-bacbe6802d9e">
        <source>pwCleanupUTInvLineDesc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2022	navpw1	Initial creation TFS: 54571

*/

vars
	terminal : CM_Terminal;
	bank : CM_Bank;
	invLineMapping : CM_InvoiceLineDescMapping;
	iter : Iterator;
	isOk : Boolean;
	
begin
	terminal := app.myRoot.allTerminals["UT"];
	bank := terminal.companies["DFBU"];
	
	iter := bank.allInvoiceLineDescMappings.createIterator();
	
	beginTransaction;
	
	while iter.next(invLineMapping) do
		
		if invLineMapping.myDebtor &lt;&gt; null then
			if not global.isValidObject(invLineMapping.myDebtor) then
				delete invLineMapping;
				continue;
			endif;
			
		endif;
		
		if invLineMapping.myInvoiceType &lt;&gt; null then
			if not global.isValidObject(invLineMapping.myInvoiceType) then
				delete invLineMapping;
			endif;
		endif;
		
	endwhile;
	
	commitTransaction;
	isOk := true;
	
epilog
	if not isOk then
		abortTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwCreateAudits" id="9e9651fd-cb4c-4aa3-a7ce-369ad78e6ecb">
        <source>pwCreateAudits();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

vars

	root : CM_Root;
	schema : Schema;
	auditConfig : CM_AuditConfig;
	cmObjectClass : Class;
	
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	dummyObj : CM_Object;
	transObj : CM_Object;
	canHaveAudits: Boolean;
	auditClass: Class;
	
	iterAuditConfig : Iterator;

begin
	app.initialize();
	
	root := CM_Root.firstInstance;
	
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	cmObjectClass := CM_Object;
	
	classColl := schema.getAllClasses(false);
	iterClass := classColl.createIterator;
	
	beginTransaction;
	
		// We Audit the fact that we're enabling/disabling CM_AuditConfigs
		// But We might not have one yet, so lets do that first up
		auditConfig := root.allAuditConfigs[ CM_AuditConfig.name ];
		if auditConfig = null then
			//its not there add it.	
			root.createAuditConfig( CM_AuditConfig );	
		endif;
	
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			//only interested in classes under CM_Object
			continue;
		endif;
		
		if class.abstract or class.transient then
			continue;
		endif;
		
		if class = CM_AvailableForRelease then
			continue;
		endif;
		
		//check to see whether its supposed to be available
		dummyObj := class.firstInstance.CM_Object;
		
		if dummyObj = null or dummyObj.class = CM_Object then
			create transObj as class transient;
			dummyObj := transObj;
		endif;
						
		canHaveAudits := dummyObj@canHaveAudits;
		auditClass := dummyObj@auditClass;
		
		delete transObj;
		
		if not canHaveAudits or auditClass = null then
			//this class is not audited.
			continue;
		endif;
		
		//If we get to here the class should be able to be audited.
		//check that the audit config has been created
		auditConfig := root.allAuditConfigs[ auditClass.name ];
		if auditConfig = null then
			//its not there add it.	
			auditConfig := root.createAuditConfig( auditClass );
			if not auditConfig.canBeUserDisabled then
				app.myUtilityUA.updAuditConfigSetIsEnable( true, auditConfig, app.myPassport);
			endif;
		endif;
		
	endwhile;
	
	//And one special case - "CM_Edit" / 'Tracked Item Edit' Creates audits against CM_Tracked Item that
	//replicate the values in the 'Edits' created via the Container Enquiry Form.
	auditConfig := root.allAuditConfigs[ CM_Edit.name ];
	if auditConfig = null then
		//its not there add it.	
		root.createAuditConfig( CM_Edit );	
	endif;
	
	//clean up any CM_AuditConfig objects for classes that have been deleted and have no associated audits.
	//i.e. at th etime of writing there was a "CM_TIMasterGroup"
	iterAuditConfig := root.allAuditConfigs.createIterator;
	while iterAuditConfig.next( auditConfig ) do
		class := schema.getClass( auditConfig.className );
		if class = null and auditConfig.allAuditObjects.isEmpty then
			delete auditConfig;
		endif;
	endwhile;
	
	commitTransaction;

epilog

	delete classColl;
	delete iterClass;
	delete iterAuditConfig;

end;</source>
    </JadeMethod>
    <JadeMethod name="pwDateTimeConversion" id="141ec212-115e-4955-a512-6da8c12e4779">
        <source>pwDateTimeConversion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2023	navpw1	Initial creation

*/

vars
	date : Integer64;
	tso	: TimeStampOffset;
	ts : TimeStamp;
	
begin
	date := 1680173236;
	ts.setFromUnixEpoch(date);
	tso.setFromLocalTimeStamp(ts, tso.getUTCBias);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pwDeleteCustomsReferencesTemp" id="3e1a21ef-3d44-446b-94e4-449a90707450">
        <source>pwDeleteCustomsReferencesTemp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2023	navpw1	Initial creation

*/

vars
	trackedItem : CM_TrackedItem;
	mergeIter 	: MergeIterator;
	terminal 	: CM_Terminal;
	customsDict : CM_CustomsReferenceDict;
	
begin
	terminal := app.myRoot.allTerminals["PW"];
	create mergeIter transient;
	mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
	mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);
	mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
	while mergeIter.next(trackedItem) do
		if trackedItem.allCustomsReferences = null then
			continue;
		endif;
		write trackedItem.id;
		global.getExtraData(trackedItem.allExtraData, AllCustomsReferences, customsDict);
		beginTransaction;
		customsDict.purge;
		delete customsDict;
		commitTransaction;
	endwhile;
	
	delete mergeIter;
	
	terminal := app.myRoot.allTerminals["UT"];
	create mergeIter transient;
	mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
	mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);
	mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
	while mergeIter.next(trackedItem) do
		if trackedItem.allCustomsReferences = null then
			continue;
		endif;
		write trackedItem.id;
		global.getExtraData(trackedItem.allExtraData, AllCustomsReferences, customsDict);
		beginTransaction;
		customsDict.purge;
		delete customsDict;
		commitTransaction;
	endwhile;
	
	delete mergeIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwDeleteVehicleVisit" id="1b13d9b6-c86a-47d8-a07a-9aba2dda4b32">
        <source>pwDeleteVehicleVisit();
/*

Purpose:			2320.1363453 (VV090304)

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2021	navpw1	Initial creation

*/

vars
	vvr			: CM_VehicleVisitRecord;
	visitNumber	: String;
	
begin
	vvr := "2320.1363453".asOid().CM_VehicleVisitRecord;
	
	if vvr &lt;&gt; null then
		visitNumber := vvr.visitNumber;
		beginTransaction;
		delete vvr;
		commitTransaction;
		app.msgBox("Vehicle Visit deleted successfully: " &amp; visitNumber, "Deleted Vehicle Visit", MsgBox_Exclamation_Mark_Icon);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pwDeleteVoyage" id="1e6aa008-feb4-4ee2-a88b-5650565989bc">
        <source>pwDeleteVoyage();
/*

Purpose:			1. Fix Up dodgy Slot Requests using script below
					2. Change Voyage Status to "Voyage Arrived"
					3. Change Departure Date to now
					4. Delete all cargo using Voyage Operations Screen
					5. Delete the Voyage

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2022	navpw1	Initial creation TFS: 52854

*/

vars
	voyage : CM_Voyage;
	ya : CM_YardAllocation;
	alloc : CM_VoyageAllocation;
	request : CM_SlotRequest;
	cont : CM_SlotController;
	count : Integer;

	ti	: CM_TrackedItem;
	
begin
	voyage := "4480.14555".asOid.CM_Voyage;
	beginTransaction;
	foreach ya in voyage.allVoyageAllocations discreteLock do
		alloc := ya.CM_VoyageAllocation;
		foreach request in alloc.allSlotRequests discreteLock do
			if not app.isValidObject(request.mySlotController) then
				request.setPropertyValue(CM_SlotRequest::mySlotController.name, null);
				count := count + 1;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
	app.msgBox(count.String, "Result", MsgBox_OK_Only);
	
	//Need to delete Cargo Items on voyage
	foreach ti in voyage.allOnshipTIsByCargoTypeId do
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
