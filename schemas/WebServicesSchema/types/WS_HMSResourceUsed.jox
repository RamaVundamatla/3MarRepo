    <JadeMethod name="delete" id="ffcf21d2-a542-4520-81c7-8464851d5721">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

begin

	if self.myDebtor &lt;&gt; null then
		delete self.myDebtor;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromMarineService" id="ca11f1d5-877c-499d-83fb-3ab89cb10d76">
        <updating/>
        <source>setProxyFromMarineService(_wod : CM_WodMarineServiceDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation

*/

vars

begin
	self.setOidDetails(_wod);
	if _wod = null then
		return;
	endif;
	
	if _wod.myHMSResource &lt;&gt; null then
		self.description:= _wod.myHMSResource.description;
		self.resource:=_wod.myHMSResource.getOidAsString;
	    if _wod.myHMSResource.myResourceType &lt;&gt; null then
			self.resourceType:=_wod.myHMSResource.myResourceType.getOidAsString;
		endif;
	endif;
	
	//26 Nov 2018	NDL TFS 41980
	if _wod.myHMSResourceType &lt;&gt; null then
		self.resourceType := _wod.myHMSResourceType.getOidAsString;
	endif;
	
	//26 Nov 2018	NDL TFS 41980
	if _wod.myDebtor &lt;&gt; null then
		create self.myDebtor transient;
		self.myDebtor.setProxyFromObject( _wod.myDebtor );
	endif;

	self.quantity:=_wod.unitsUsed;
	self.toDateTime:=_wod.toDateTime.asStringForWebInterface;
	self.fromDateTime:=_wod.fromDateTime.asStringForWebInterface;
	

epilog

end;</source>
        <Parameter name="_wod" type="CM_WodMarineServiceDetail"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="5687bdc8-59e4-4133-9a94-a7d4282335cc">
        <updating/>
        <source>setProxyFromObject(_object: HMS_ResourceUsed) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	if _object.myResource &lt;&gt; null then
		self.description := _object.myResource.description;
	else
		self.description := _object.description;
	endif;
	
	//self.fromDateTime := _object.fromDateTime.asStringForWebInterface;
	//self.toDateTime := _object.toDateTime.asStringForWebInterface;
	

epilog

end;</source>
        <Parameter name="_object" type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromWorkOrder" id="243284cd-f822-47a3-bce6-2cd7e425102a">
        <updating/>
        <source>setProxyFromWorkOrder( _wod : CM_WodWaterRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation

*/

vars

begin
	self.setOidDetails(_wod);
	if _wod = null then
		return;
	endif;
	
	if _wod.myHMSResource &lt;&gt; null then
		self.description:= _wod.myHMSResource.description;
		self.resource:=_wod.myHMSResource.getOidAsString;
	    if _wod.myHMSResource.myResourceType &lt;&gt; null then
			self.resourceType:=_wod.myHMSResource.myResourceType.getOidAsString;
		endif;
	endif;

	
	self.quantity:=_wod.unitsUsed;
	self.toDateTime:=_wod.toDateTime.asStringForWebInterface;
	self.fromDateTime:=_wod.fromDateTime.asStringForWebInterface;
	
epilog

end;</source>
        <Parameter name="_wod" type="CM_WodWaterRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxyHMSResorceUsed" id="da790f64-5bb9-46db-a1c3-7cb8b6140030">
        <source>setProxyHMSResorceUsed(_proxy : HMS_ResourceUsed input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlger1	Initial creation
*/

vars
	resourceObj		: HMS_Resource;
	resourceType 	: HMS_ResourceType;
	fromTS 			: TimeStamp;
	toTS 			: TimeStamp;
	debtor : CM_Debtor;
	obj : Object;
	wodMarineServiceDetail : CM_WodMarineServiceDetail;
	
begin
	if _proxy = null then
		return;
	endif;
	
	if resource  &lt;&gt; null then
		resourceObj:=app.myPassport.getObjectOfTypeFromOid(self.resource,HMS_Resource).HMS_Resource;	
	endif;
	
	resourceType:= app.myPassport.getObjectOfTypeFromOid(self.resourceType,HMS_ResourceType).HMS_ResourceType;
	
	fromTS:= self.fromDateTime.asTimeStampFromWebInterface;
	
	toTS:= self.toDateTime.asTimeStampFromWebInterface;
	
	//26 Nov 2018	NDL TFS 41980
	if self.myDebtor &lt;&gt; null then
		//epr TFS 44268 18/4/19 don't check data access for this
		debtor :=self.myDebtor.cmObjectId.asOid.CM_Debtor;
	endif;
	
	//27 Nov 2018	NDL	TFS 41980
	if self.cmObjectId &lt;&gt; null then
		obj := app.myPassport.getObjectOfTypeFromOid(self.cmObjectId,Object).Object;
		if obj &lt;&gt; null and obj.isKindOf( CM_WodMarineServiceDetail ) then
			wodMarineServiceDetail := obj.CM_WodMarineServiceDetail;
		endif;
	endif;
	
	_proxy.setProxy(app.myPassport.myTerminal.myHarbour,resourceType,resourceObj,null,fromTS,toTS,self.quantity,null,wodMarineServiceDetail,debtor);
epilog

end;</source>
        <Parameter name="_proxy" type="HMS_ResourceUsed" usage="input"/>
    </JadeMethod>
</Class>
