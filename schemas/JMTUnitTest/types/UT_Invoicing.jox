    <JadeMethod name="xTrxUpdateInvoice" id="6fd5c62e-7ba5-40b9-a8bd-2d1ceaf72217">
        <source>xTrxUpdateInvoice(_invoice : CM_Invoice);

/*

Purpose:		trxUpdateInvoice

Date			Who		Reason
26/05/2015		cnwmh5	Initial creation

*/

vars

	pxyInvoice				: CM_Invoice;
	
	poNumber				: String;

begin

	if _invoice = null then
		return;
	endif;
	
	pxyInvoice := app.createUpdateProxy(_invoice).CM_Invoice;
	
	poNumber := _invoice.purchaseOrderNumber;
	if self.opts.includesKey("PurchaseOrderNumber") then
		poNumber := self.opts.str("PurchaseOrderNumber");
	endif;
	
	pxyInvoice.setProxyForUpdate(_invoice.narration, 
		_invoice.isZeroRatedTax, 
		_invoice.toDT.Date, 
		poNumber, 
		_invoice.debtorReference,
		null,null,	//22.07.2019 cnwma1 TFS #45577
		null,	//14/08/2023	navkc1	Bug 59803
		null,	//14/08/2023	navkc1	Bug 59803
		null	//14/08/2023	navkc1	Bug 59803
		); 
	
	app.myTrxUA.trxUpdateInvoice(pxyInvoice,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyInvoice;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="xTrxUpdateInvoiceLineConvert" id="af3bca1b-4e72-414e-8ed4-b39bf7cc265a">
        <source>xTrxUpdateInvoiceLineConvert(_invoice : CM_Invoice; _lineDesc : CM_InvoiceLineDesc);

/*

Purpose:		trxUpdateInvoiceLineConvert

Date			Who		Reason
27/05/2015		cnwmh5	Initial creation

*/

vars

	theController 					: CMIF_InvoiceLineConvert;
	pxyInvoiceLine					: CM_InvoiceLine;
	obj								: Object;
	
	invoiceLines					: CM_InvoiceLineBySeqNumDict;
	
begin

	if _invoice = null or _lineDesc = null then
		return;
	endif;
	
	create invoiceLines transient;
	pxyInvoiceLine := app.createUpdateProxy(_invoice.invoiceLines.first).CM_InvoiceLine;
	invoiceLines.add(pxyInvoiceLine);
		
	create theController transient;
	invoiceLines.copy(theController.allInvoiceLines);
	theController.myInvoiceLineDesc := _lineDesc;
	
	app.myTrxUA.trxUpdateInvoiceLineConvert(theController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyInvoiceLine;
	invoiceLines.purge();
	delete invoiceLines;
	delete theController;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_lineDesc" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="xTrxUpdateInvoiceLineDesc" id="4367771d-3ffe-46bd-9e59-60a480b6dc16">
        <source>xTrxUpdateInvoiceLineDesc(_invoiceDesc : CM_InvoiceDesc);

/*

Purpose:		trxUpdateInvoiceLineDesc

Date			Who		Reason
26/05/2015		cnwmh5	Initial creation
15/06/2023		navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration

*/

vars

	pxyInvoiceDesc				: CM_InvoiceDesc;

	description					: String;
	isAllowManEditExtRef		: Boolean; 
	
begin

	if _invoiceDesc = null then
		return;
	endif;
	
	//create pxyInvoiceDesc transient;
	beginLoad;
	pxyInvoiceDesc := _invoiceDesc.pxyCreateUpdateProxy();
	endLoad;
	
	description := _invoiceDesc.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("AllowManEditExtRef") then
		isAllowManEditExtRef := self.opts.bool("AllowManEditExtRef").Boolean; 
	endif;
	
	pxyInvoiceDesc.setProxy(_invoiceDesc.accrualType,
		_invoiceDesc.arrNarrationDesc,
		description, 
		_invoiceDesc.invoiceKey,
		_invoiceDesc.invoiceType,
		_invoiceDesc.myFinancialPeriodEnd, 
		_invoiceDesc.myInvTermsOfTrade,
		_invoiceDesc.printSingleLineForDayType, 
		_invoiceDesc.triggerOnAction,
		_invoiceDesc.invoiceGenerationDateFrom,
		_invoiceDesc.invoiceGenerationDateTo,
		_invoiceDesc.invoiceGenerationStatus,
		_invoiceDesc.externalReference,
		_invoiceDesc.isNotAvailableForEntry,
		false, 	// 15.06.2023	navcs2	#58434:[58452]
		false, // 15.06.2023	navcs2	#58434:[58452]
		isAllowManEditExtRef //08/12/2025	navkc1 JIRA 36262
		);
	pxyInvoiceDesc.setCompany(self.myBank);		// 35872 
	
	app.myTrxUA.trxUpdateInvoiceDesc(pxyInvoiceDesc, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyInvoiceDesc;

end;</source>
        <Parameter name="_invoiceDesc" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="xTrxUpdateInvoiceStatus" id="3835ba71-74e9-4923-ab80-860cc9eea968">
        <source>xTrxUpdateInvoiceStatus(_invoice : CM_Invoice; _status : Integer);

/*

Purpose:		trxUpdateInvoiceStatus

Date			Who		Reason
26/05/2015		cnwmh5	Initial creation

*/

vars

	theStatus					: CMIF_InvoiceStatus;
	obj							: Object;
	pxyInvoiceLine				: CM_InvoiceLine;
	invoiceLine					: CM_InvoiceLine;

begin

	if _invoice = null then
		return;
	endif;

	create theStatus transient;
	
	invoiceLine := _invoice.invoiceLines.first;
	self.assertNotNull(invoiceLine);
	
	pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
	theStatus.allInvoiceLines.add(pxyInvoiceLine);
	theStatus.newStatus := _status;
	
	app.myTrxUA.trxUpdateInvoiceStatus(theStatus,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	///delete pxyInvoiceLine;
	if theStatus &lt;&gt; null then
		foreach obj in theStatus.allInvoiceLines do
			delete obj;
		endforeach;
	endif;
	delete theStatus;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
