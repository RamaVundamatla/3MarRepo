    <JadeMethod name="isBreakBulkMove" id="2b45a79d-cb27-4c44-85ab-37839b44f3f1">
        <source>isBreakBulkMove() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2013	cnwrd1	Initial creation

*/

vars

begin
	if self.myBreakBulkMaster &lt;&gt; null then
