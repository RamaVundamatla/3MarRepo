    <JadeMethod name="cashTestSplitMerge" id="f67dc75c-e0ac-4f98-8c60-ca29d22bf0d0">
        <updating/>
        <source>cashTestSplitMerge(_cargo : CM_TrackedItem; _drTerm1 : CM_DebtorTerminal) updating, protected;

/*

Purpose:		
				
				
Parameters:			

Return Value:		


Date		Who		Reason
30/05/2016	cnwjre1	TFS 1990
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	moreNow		: TimeStamp;
	msg			: String;
	count		: Integer;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];//[16, 6]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	service			: CM_Service;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	
	onsiteTi := _cargo;
	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;		// should be 15000

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	count := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		self.assertEqualMsg(cashPayment.cashValue, 5000.Decimal, msg &amp; " " &amp; count.String &amp; " payment value ");
		if count = 1 or count = 2 then
			self.assertNotNullMsg(cashPayment.myInvoiceLine, msg &amp; " " &amp; count.String &amp; " Invoice line" );
		else
			self.assertNotNullMsg(cashPayment.myProformaDetail, msg &amp; " " &amp; count.String &amp; " Proforma" );
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Receipt payments");

	cashInvoice := cashReceipt1.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeWeight1", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 5000.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		elseif count = 2 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 5000.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		endif;
	endforeach;
	assertEqualMsg(count, 2, msg &amp; " Receipt invoice lines");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="cashTestSplitMergeVolume" id="38e9bb74-410e-4ce3-9fe4-afbdd3ccaaf3">
        <updating/>
        <source>cashTestSplitMergeVolume(_cargo : CM_TrackedItem; _drTerm1 : CM_DebtorTerminal) updating, protected;

/*

Purpose:		
				
				
Parameters:			

Return Value:		


Date		Who		Reason
30/05/2016	cnwjre1	TFS 1990
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	moreNow		: TimeStamp;
	msg			: String;
	count		: Integer;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice; // TFS 47529 - this doesn't seem to be run anymore;
	invLine : CM_InvoiceLine; // changed to 23,6 for consistency with other UTs
	
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	service			: CM_Service;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
