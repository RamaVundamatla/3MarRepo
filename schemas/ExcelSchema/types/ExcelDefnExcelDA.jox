    <JadeMethod name="initialise" id="8e3b95bf-863e-4a98-ae83-9fbde3648aab">
        <updating/>
        <source>initialise(intAction	: Integer) updating;

/*****************************************************
	Written by	:	cnwpra1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
	13/1/2005	cnwpra1	PAR 8880, 9410 remove invalid chars in the filename
******************************************************/

vars
	workbook		: I_Workbook;
	first			: Boolean;
	strWorkbookName	: String;
	wbName			: String;
	oidStr			: String;
	t				: TimeStamp;
	scanName		: String;
	int				: Integer;

begin
	if myExcelApplication = null then
		excelBad := true;
		create myExcelApplication;
		myExcelApplication.createAutomationObject;
		excelBad := false;
		first := true;
	endif;
	
	if myFileManagementDA = null then
		create myFileManagementDA;
		myFileManagementDA.setUseLocalDirectory(true);
	endif;
	
	action := intAction;
	
	if action = New_Workbook then
		excelBad := true;
		myExcelApplication.workbooks.add(ExcelApplication.XlWorksheet);
		myExcelApplication.activeWorkbook.worksheets.add(null, null, 1, ExcelApplication.XlWorksheet);
		myExcelApplication.activeWorkbook.sheets.item(1).I_Worksheet.name := myWorkbookDefinition.topWorksheet;
		myExcelApplication.activeWorkbook.sheets.item(2).I_Worksheet.name := myWorkbookDefinition.dataWorksheet;
		fileName := null;			// we will have to do a save as
		excelBad := false;
	elseif action = Open_File_New then
		excelBad := true;
		myExcelApplication.workbooks.open(fileName, null, false, null,null,null,true,null,null,true,null,null,null);
		excelBad := false;
	elseif action = Open_File_Replace then
		excelBad := true;
		myExcelApplication.workbooks.open(fileName, null, false, null,null,null,true,null,null,true,null,null,null);
		excelBad := false;
	elseif action = Update_Current_Workbook then
	
		oidStr := self.String;
		oidStr.replaceChar('/', '_');
		strWorkbookName := myWorkbookDefinition.workbookName &amp; oidStr &amp; t.yyyymmddhhmmss &amp; '.xls';
		wbName := myFileManagementDA.removeBadCharsFromFileName(strWorkbookName);
		fileName := app.getJadeInstallDir &amp; '\ExcelPackage\' &amp; wbName;
		myFileManagementDA.copyBlobToFile(myWorkbookDefinition.workbook, app.getJadeInstallDir &amp; '\ExcelPackage\', wbName );
		excelBad := true;
		myExcelApplication.workbooks.open(fileName, null, false, null,null,null,true,null,null,true,null,null,null);
		excelBad := false;
	endif;
	
	myExcelApplication.visible := true; 
	
	if first then
		myExcelApplication.beginNotifyAutomationEvent(self, 'myAEvents');
		//myExcelApplication.beginNotifyAutomationEvent(self, 'myWBE');
	endif;
	
epilog

end;</source>
        <Parameter name="intAction" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myAEvents_newWorkbook" id="a286c221-3916-4799-8c7d-b4af09ce9cda">
        <controlMethod name="AppEvents::newWorkbook"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>myAEvents_newWorkbook(wb: I_Workbook) updating;

/*****************************************************
	Written by	:	cnwpra1		14 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	work		: I_Workbook;

begin
	//return;			// need to wait till 6.0.19 for this to work
	app.msgBox('Please do not open another workbook during this process.' &amp; CrLf &amp; CrLf &amp;
							'The new Workbook is being closed so the definition can continue.', 
									'New Workbook', MsgBox_OK_Only);
	work := wb;
	work.saved := true;	
	doingClose := true;
	
	//myExcelApplication.endNotifyAutomationEvent(self, 'myAEvents');
	work.close(null, null, null);	
	
	//myExcelApplication.beginNotifyAutomationEvent(self, 'myAEvents');
epilog

end;</source>
        <Parameter name="wb" type="I_Workbook"/>
    </JadeMethod>
    <JadeMethod name="myAEvents_workbookBeforeClose" id="df0c1ab1-ff5a-43eb-a199-85034833d4da">
        <controlMethod name="AppEvents::workbookBeforeClose"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>myAEvents_workbookBeforeClose(wb: I_Workbook; cancel: Boolean) updating;

/*****************************************************
	Written by	:	cnwpra1		10 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	
begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if doingClose then
		doingClose := false;
		return;
	endif;
	
	if doingExcelClose then
		return;
	endif;
	
	app.msgBox('Workbook and Excel closing as requested', 'Excel Closing', MsgBox_OK_Only);
	
	if not self.checkExcelCanBeUsed then
		return;
	endif;
	
	self.closeExcel;
	
epilog

end;</source>
        <Parameter name="wb" type="I_Workbook"/>
        <Parameter name="cancel" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myAEvents_workbookOpen" id="ffcad0aa-ac38-4b0e-a80e-d54623d87e48">
        <controlMethod name="AppEvents::workbookOpen"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>myAEvents_workbookOpen(wb: I_Workbook) updating;

/*****************************************************
	Written by	:	cnwpra1		14 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	work		: I_Workbook;

begin
	app.msgBox('Please do not open another workbook during this process.' &amp; CrLf &amp; CrLf &amp;
							'The other workbook is being closed so the definition can continue.', 
									'Workbook Open', MsgBox_OK_Only);
	
	work := wb;
	work.saved := true;	
	doingClose := true;
	work.close(null, null, null);	
	
epilog

end;</source>
        <Parameter name="wb" type="I_Workbook"/>
    </JadeMethod>
    <JadeMethod name="openBlobForValidation" id="06b0a99c-dcba-455e-985a-2b87eca5ca01">
        <updating/>
        <source>openBlobForValidation(
	sourceBlob : Binary) updating;

vars
	oidStr : String;
	strWorkbookName : String;
	t : TimeStamp;
	
begin
	if myExcelApplication = null then
		create myExcelApplication;
		myExcelApplication.createAutomationObject;
	endif;
	
	if self.myFileManagementDA = null then
		create self.myFileManagementDA transient;
		myFileManagementDA.setUseLocalDirectory(true);
	endif;
	
	oidStr := self.String;
	oidStr.replaceChar('/', '_');
	strWorkbookName := "Temp" &amp; oidStr &amp; t.yyyymmddhhmmss &amp; '.xls';
	fileName := app.getJadeInstallDir &amp; '\ExcelPackage\' &amp; strWorkbookName;
	myFileManagementDA.copyBlobToFile(sourceBlob, app.getJadeInstallDir &amp; '\ExcelPackage\', strWorkbookName );
	myExcelApplication.workbooks.open(fileName, null, false, null,null,null,true,null,null,true,null,null,null);
end;</source>
        <Parameter name="sourceBlob" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="pasteArrayInDatasheet" id="d2cee545-81ed-4005-a0d8-fb90d15b5d86">
        <updating/>
        <source>pasteArrayInDatasheet(array		: ExcelHugeStringArray) updating;

/*****************************************************
	Written by	:	cnwpra1		14 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	str			: String;
	row			: Integer;
	range		: Range;
	str2		: String;

begin
	foreach str in array do
		row := row + 1;
		myDataWorksheet.activate;
		myDataWorksheet.range('A' &amp; row.String, 'A' &amp; row.String).select;
		
		app.copyStringToClipboard(str);
		myDataWorksheet.paste(null,false);
			
	endforeach;
	
epilog

end;</source>
        <Parameter name="array" type="ExcelHugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="saveWorkbookToDB" id="34491ea4-1119-4201-b2fa-26c5f438c675">
        <updating/>
        <source>saveWorkbookToDB() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	work				: I_Workbook;
	bin					: Binary;
	oidStr				: String;
	strWorkbookName		: String;
	strName				: String;
	t					: TimeStamp;

begin
	work := myExcelApplication.activeWorkbook;
	
	// first clear the test data
	self.clearWorksheetData;
	
	if fileName &lt;&gt; null then
		work.save;
	else
		oidStr := self.String;
		oidStr.replaceChar('/', '_');
		strWorkbookName := myWorkbookDefinition.workbookName &amp; oidStr &amp; t.yyyymmddhhmmss &amp; '.xls';
		strName := myFileManagementDA.removeBadCharsFromFileName(strWorkbookName);
		fileName := app.getJadeInstallDir &amp; '\ExcelPackage\' &amp; strName;
		myFileManagementDA.createFolder(app.getJadeInstallDir &amp; '\ExcelPackage\');
		myFileManagementDA.setFileName(fileName);
		work.saveAs(fileName, null, null, null, null, null, null, null, null, null, null);
	endif;
	
	myFileManagementDA.copyFileToBlob(bin, fileName);
	
	beginTransaction;
	myWorkbookDefinition.setWorkbook(bin);
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAction" id="9a6fc5b2-f4dc-41e8-960c-5b9aa2c14d2d">
