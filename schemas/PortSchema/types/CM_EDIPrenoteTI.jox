    <JadeMethod name="setParserWarnings" id="0bd44662-e27c-407b-ab72-470e56a6bf7d">
        <updating/>
        <source>setParserWarnings( _value : HugeStringArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2017	jlgndl1	Initial creation	TFS 5339

*/

vars

	str : String;
	strValue : String;

begin

	if _value &lt;&gt; null and not _value.isEmpty then
		foreach str in _value do
			if strValue &lt;&gt; null then
				strValue := strValue &amp; Lf;
			endif;
			strValue := strValue &amp; str;
		endforeach;
	endif;

	global.setExtraData(self.allExtraData, self, CM_EDIFileTypeXMLOneStopCust.ParserWarnings, strValue);

epilog

end;</source>
        <Parameter name="_value" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setPrenoteInterface" id="8c324495-b782-430e-9a8f-5d08061b9153">
        <source>setPrenoteInterface(_cmifPrenote : CMIF_PreNote input; _doNotGeneratePin : Boolean);
// --------------------------------------------------------------------------------
// Created:		19 February 2010 
// Merged:		5 July 2010 Merged with CM_EDIDataPrenote::setPreNoteInterfaceObject
//
// Parameters:	_cmifPrenote - A reference to the proxy/temp CMIF object.
//				_doNotGeneratePin - A flag to indicate whether to generate a PIN no.
//
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Feb 2012	cnwrs1	Par 29076 	Fix up Hazard Processing in EDI
18/09/2012	cnwcs5	par 30316  	extra fields for pre-notes
23/09/2013	cnwdap1	PAR #32215 	CCMS DPH 2290 New Car Attributes
11/07/2014	cnwrs1	Par 34566 	CCMS 2346 Suzano - Viagram Prenote file 
16/11/2015  cnwgb1  Par 37172 	Modify Semantics
22 Feb 2016	cnwrs1	Par 37568 	TFS 1177 CCMS 2158 - EDI User defined  field expansion
03 May 2016	cnwdap1	TFS #1699 	Verified Gross Mass changes
30 may12017	cnwdap1	TFS 4449 	STWR Mark and Mark Number field length changes
06 Jun 2017	cnwdap1	TFS 4434 	SNO COPARN Prenotes and VGM Updates
15 Jun 2017	cnwrs1	TFS 4462 	SNO add Terminal Operator, Unknown Seal and support multiple seals
28/06/2017	cnwdap1	TFS 4492 	SNO VERMAS Changes
05 Jun 2018	jlgrs1	TFS 39018 	SNO Cargo Operator in COPRAR
04 Mar 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
02 Oct 2020 cnwma1 				ChangeRequest 50112: ASPA - GCI Stevedores
29 Nov 2022	jlika1	TFS 55586 	HS Code User Defined EDI
11 Jan 2023	navkc1	TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
15 Jun 2023	navdap1	TFS 57074	EUP Manifest EDI Operations / Load Task 58604
23 Jun 2023	navadp1	TFS 58813 	EUP - Manifest Instructions
18 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
06 Sep 2023	navra1	TFS 60228   EUP | FR 53824 - Consignee / Consignor Validation (Road Manifest)
08 Sep 2023	navra1	TFS 60391   EUP | FR 53824 - Road Manifest - Grammage Field
26 Sep 2023	navlw1	Bug 60601	EUP | FR 53853 GoodsReceipt - Incorrect UOM Value
06 Oct 2023 navcs2	Bug 60776: EUP | FR 53824 - Transport Manifest - Duplicate Item IDs for different Cargo Group IDs
18 Apr 2024	jlika1	TFS 63738 CUX - Enable trailers to be prenoted with User-Defined EDI
01 Oct 2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
============================================================================*/
vars
	cargoType						: CM_CargoType;
	isoType							: CM_ISOType;
	tmpBookingRef					: CM_BookingRef;
	ff								: CM_ConsigneeConsignor;
	str								: String;
	allStrings						: StringArray;
	tmpHazards 						: ObjectArray;
    modifying       				: Boolean;
	operator 						: CM_Operator;
	opTerm 							: CM_OperatorTerminal;
	ediTI 							: CM_EDITrackedItem;
	obj 							: Object;			//31 Jan 2018	NDL	TFS 36824
	containerNumberTextStr 			: String;
	_ediTiIsTransManifestRelated 	: Boolean;			//navra1 - TFS 60228 - 6th Sep 2023
	reason							: String; 			//05/04/2024	navkc1 Bug 63509
	cargoTypeObj					: CM_CargoType;		// MTN-36141
begin
    modifying := (self.messageMode = CM_EDITrackedItem.EDI_ACTION_MODIFY); //cnwgb1  Par 37172 Modify Semantics
	//Set the properties as best we can figure
	_cmifPrenote.setUserDetails(self);	
	
	if not (modifying and self.transportMode = null) then
        _cmifPrenote.transportMode := self.getTransportModeConstant();
    endif;
	
	// Par 21725 - PHB - Check for the entry of a slot number after the wagon number from the loaded file
	if not (modifying and self.wagonNumber = null) then
        str := self.wagonNumber.trimBlanks();
        
        if str.cnContains(Space) then
            create allStrings transient;
            
            allStrings := str.cnGetTokens(Space);	// Wagon Number is in position 1 and Slot Number in position 2
            
            if allStrings.size &gt; 1 then				// Should always be the case
                _cmifPrenote.wagon		:= allStrings[1][1:20];
                _cmifPrenote.slotNumber	:= allStrings[2][1:20];
            else									// Just in case !
                _cmifPrenote.wagon 		:= self.wagonNumber[1:20];
            endif;
        else
            _cmifPrenote.wagon 	:= self.wagonNumber[1:20];
        endif;
	endif;
    
	if not (modifying and self.wagonNumber = null) then
        _cmifPrenote.myWagonClass := self.getMyTerminal.getWagonClass(wagonNumber, wagonClass);	//13 May 2014	NDL	Par 33615
    endif;
	
	//29 Nov 2013	NDL	Par 33092
	if _cmifPrenote.wagon &lt;&gt; null then
		_cmifPrenote.transportMode := TI_TRANSMODE_RAIL_STR;
	endif;
	
	if not (modifying and self.operatorCode = null) then
        _cmifPrenote.operatorCode 	:= self.operatorCode;
    endif;
	_cmifPrenote.isEDI 			:= true;
	
	create tmpHazards transient;
	//31 Jan 2018	NDL	TFS 36824
	if self.createTIHazardsFromEdiHaz( tmpHazards ) then	
		//One Stop XML Prenote message creates full hazards....
		foreach obj in  tmpHazards do
			_cmifPrenote.allTIHazards.addNoDuplicates( obj.CM_TIHazard, false );
		endforeach;
		
	elseif self.imCodes.size &gt; 0 then
		self.getProxyHazards(self.imCodes, tmpHazards, false);
		tmpHazards.copy(_cmifPrenote.allTIHazards);
		
	endif;
	
	if not (modifying and self.bookingRef = null) then
        _cmifPrenote.bookingReference 	:= self.bookingRef.toUpper;
        tmpBookingRef := self.getMyTerminal.getBookingReferenceLatest(self.operatorCode, self.bookingRef); // adm 150908 Par 17936
        
        if tmpBookingRef &lt;&gt; null then
            if _cmifPrenote.myBookingRefItem = null then
                if self.cargoType &lt;&gt; null then
                    cargoType := app.myRoot.allCargoTypesById[self.cargoType];
                endif;
                
                if self.isoType &lt;&gt; null then
                    isoType := app.myRoot.allISOTypes[self.isoType];
                endif;
                
                _cmifPrenote.myBookingRefItem := tmpBookingRef.getMatchingItem(cargoType, self.commodity, isoType, self.product, null, null, null, null, null, reason); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
            endif;
        endif;
    endif;
	if app.isCargoGroupEnabled then	//17 Feb 2016	NDL	Par 37544
		if not (modifying and self.cargoGroupId = null) then	
			_cmifPrenote.cargoGroupId := self.cargoGroupId;
		endif;
	endif;
	if not (modifying and self.temperature = NULL_TEMPERATURE) then
        _cmifPrenote.carriageTempC		:=	self.temperature;
    endif;
	if not (modifying and self.availabilityGrade = null) then
		_cmifPrenote.availabilityGrade := self.availabilityGrade;
	endif;
	//22 Feb 2016	cnwrs1	Par 37568 TFS 1177 CCMS 2158 - EDI User defined  field expansion
	if not (modifying and self.generatorType = null) then
		_cmifPrenote.setMyGeneratorType(app.myRoot.allGeneratorTypes[self.generatorType]);
	endif;
	if not (modifying and self.destinationTerminal = null) then
		_cmifPrenote.destinationTerminal := self.destinationTerminal;
	endif;
	if not (modifying and self.expectedArrivalDate = null) then
		_cmifPrenote.expectedArrivalDate := self.expectedArrivalDate;
	endif;
	if not (modifying and self.expectedArrivalTime = null) then
		_cmifPrenote.expectedArrivalTime := self.expectedArrivalTime;
	endif;
	if not (modifying and self.onPowerDuringTransit = null) then
		_cmifPrenote.onPowerDuringTransit := self.onPowerDuringTransit;
	endif;
	if not (modifying and self.transitOnPowerDate = null) then
		_cmifPrenote.transitOnPowerDate := self.transitOnPowerDate;
	endif;
	if not (modifying and self.transitOnPowerTime = null) then
		_cmifPrenote.transitOnPowerTime := self.transitOnPowerTime;
	endif;
	//jlgka1 TFS 44416 --&gt; Move code after Cargo Type and Cargo Sub Type
	/*if not (modifying and (self.commodity = "TBA" or self.commodity  = null)) then
        _cmifPrenote.commodity			:=	self.commodity;
    endif;*/
	
	_ediTiIsTransManifestRelated := self.isTransportManifestRelated();							//navra1 - TFS 60228 - 6th Sep 2023
	
	//jlgka1 TFS 44416 &lt;--
	if not (modifying and self.consignor = null) then
		if _ediTiIsTransManifestRelated then													//navra1 - TFS 60228 - 6th Sep 2023
			if app.myRoot.allConsigneeConsignors[self.consignor] &lt;&gt; null then					//navra1 - TFS 60228 - 6th Sep 2023
				_cmifPrenote.consignorCode		:=	self.consignor;								//navra1 - TFS 60228 - 6th Sep 2023
			endif;																				//navra1 - TFS 60228 - 6th Sep 2023
		else																					//navra1 - TFS 60228 - 6th Sep 2023
			_cmifPrenote.consignorCode		:=	self.consignor[1:5];
		endif;
    endif;
	
	if not (modifying and self.consignee = null) then
		if _ediTiIsTransManifestRelated then													//navra1 - TFS 60228 - 6th Sep 2023
			if app.myRoot.allConsigneeConsignors[self.consignee] &lt;&gt; null then					//navra1 - TFS 60228 - 6th Sep 2023
				_cmifPrenote.consigneeCode		:=	self.consignee; 							//navra1 - TFS 60228 - 6th Sep 2023
			endif;																				//navra1 - TFS 60228 - 6th Sep 2023
		else																					//navra1 - TFS 60228 - 6th Sep 2023
			_cmifPrenote.consigneeCode		:=	self.consignee[1:5]; //cnwgb1 PAR 34241 9.6.2014
		endif;
    endif;
	// cnwjre1 4/08/2016 TFS 2489 add customs agent to EDI prenote
	if not (modifying and self.customsAgent = null) then
		_cmifPrenote.customsAgentCode 	:= self.customsAgent;
	endif;
	if not (modifying and self.releaseCarrierCode = null) then
		_cmifPrenote.releaseCarrierCode	:= self.releaseCarrierCode;
	endif;
	if not (modifying and self.customExportEntryNumber = null) then
        _cmifPrenote.customExportEntryNumber	:=	self.customExportEntryNumber;	
    endif;
	if not (modifying and self.destinationPort = null) then
        _cmifPrenote.destinationPort	:=	self.translatePortCode(self.destinationPort);
    endif;
	if not (modifying and self.dischargePort = null) then
        _cmifPrenote.dischargePort		:=	self.translatePortCode(self.dischargePort);
	//21 Jan 2016	NDL	Par 37187
   //     if _cmifPrenote.dischargePort = null then
   //         _cmifPrenote.dischargePort	:=	"****";
   //     endif;
	endif;
	if not (modifying and self.height = null) then
        _cmifPrenote.height 			:= self.height;
    endif;
	if not (modifying and self.id = null) then  //cnwgb1  Par 37172 Modify Semantics Should always happen surely 
        _cmifPrenote.id 				:= self.id[1:20];
    endif;
	//This code is Odd - Why is there an imExStatus and an imexStatus. cnwgb1 16.10.2009
    if not (modifying and self.imexStatus = null) then
        _cmifPrenote.imexStatus := app.myRoot.getImexCodeFromDesc(self.imexStatus);
    endif;
	
	if self.fullOrMT = "E" then
		_cmifPrenote.imExStatus		:=	app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
		_cmifPrenote.statusString	:=	"Storage";
	elseif self.imexStatus = null then
        if not modifying then
            _cmifPrenote.imExStatus		:=	app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
            _cmifPrenote.statusString	:=	"Export";
        endif;
	else
		_cmifPrenote.imExStatus 	:= app.myRoot.allImexStatuses[_cmifPrenote.imexStatus];
		
		if _cmifPrenote.imExStatus &lt;&gt; null then
			_cmifPrenote.statusString	:=	_cmifPrenote.imExStatus.description;
		endif;
	endif;
	
    if not (modifying and self.customsReference = null) then
        _cmifPrenote.customsReference := self.customsReference;		// cnwrl1 09/12/2009 PAR 21907
	endif;
    if not (modifying and self.description = null) then
        _cmifPrenote.description := self.description;			// cnwrl1 14/07/2009 PAR 20247 - CCMS 1859
	endif;
    if not (modifying and self.isoType = null) then
        _cmifPrenote.isoType := self.isoType;
	endif;
    if not (modifying and self.length = null) then
        _cmifPrenote.length	:= self.length;
	endif;
    if not (modifying and self.timeAllowedOffPower = NULL_ALLOWABLE_TIME_OFF_POWER) then
        _cmifPrenote.allowableTimeOffPower := self.timeAllowedOffPower;
	endif;
    if not (modifying and self.loadPort = null) then
        _cmifPrenote.loadPort := self.translatePortCode(self.loadPort);
	endif;
    if not modifying then
        _cmifPrenote.quantity := 1;							//This may need refinement for attached items
	endif;
    if not modifying then
        _cmifPrenote.receiptTransportMode := TI_TRANSMODE_ROAD;
	endif;
    if not (modifying and self.remarks = null) then
        _cmifPrenote.remarks := self.remarks.trimBlanks;	
	endif;
    if not (modifying and self.cargoType = null) then
        _cmifPrenote.cargoType := self.cargoType;
		//epr TFS 6980 26/9/17 if we passsed in products there was a problem with 2 different cargo types with the same product id
        _cmifPrenote.myProduct := self.getMyProduct(cargoType, self.operatorCode);
        if _cmifPrenote.myProduct &lt;&gt; null and  _cmifPrenote.cargoType = 0 then 
            _cmifPrenote.cargoType := _cmifPrenote.myProduct.myCargoType.id;
        endif;
		
		if _cmifPrenote.cargoType = null and _cmifPrenote.isoType &lt;&gt; null then
			 _cmifPrenote.cargoType := TI_CargoType_Container;
		endif;
    endif;    
	
	//jlgka1 TFS 44416 --&gt; Move code here
	if not (modifying and (self.commodity = "TBA" or self.commodity  = null)) then
        _cmifPrenote.commodity	:=	self.commodity;
		
		if self.getMyTerminal.getConfig(UseCargoAndSubTypeAsDef).Boolean then
			_cmifPrenote.checkNsetCommodityFrmDefault();			
		endif;
    endif;
	//jlgka1 TFS 44416 &lt;--
	
    if not (modifying and self.sealNum = null) then
        _cmifPrenote.setSealNum(self.sealNum);	//22 Sep 2010	NDL	Par 25608 - needs cargo type set first...
	endif;
    if not (modifying and self.voyageCode = null) then				
		if self.voyageCode.length &lt;= 20 then																												// 06/10/2023 navcs2 Bug 60776
			_cmifPrenote.voyageCode 		:= self.getVoyageCode();																						// 06/10/2023 navcs2 Bug 60776
		else																																				// 06/10/2023 navcs2 Bug 60776
			app.raiseCMException2(Field_length_characters_long, self.getVoyageCode() &amp; ": " &amp; app.getErrorString(VoyageCode), "20", null, null);			// 06/10/2023 navcs2 Bug 60776
		endif;																																				// 06/10/2023 navcs2 Bug 60776
	endif;
    if not (modifying and self.weight = null) then
        _cmifPrenote.weightTotal 		:= self.weight;
	endif;
    if not (modifying and self.width = null) then
        _cmifPrenote.width 				:= self.width;
	endif;
    if not (modifying and self.getHumidity = NULL_HUMIDITY) then
        _cmifPrenote.setHumidity( self.getHumidity );
	endif;
    if not (modifying and self.volume = null) then
        _cmifPrenote.volume 			:= self.volume;
	endif;
    if not (modifying and self.vent = NULL_INTEGER) then
        _cmifPrenote.ventilation 		:= self.vent;
	endif;
    if not (modifying and self.getOxygen = NULL_OXYGEN) then
        _cmifPrenote.setOxygen( self.getOxygen );
	endif;
    if not (modifying and self.getCarbonDioxide = NULL_CARBON_DIOXIDE) then
        _cmifPrenote.setCarbonDioxide( self.getCarbonDioxide );
	endif;
    if not (modifying and self.curtainsIn = null) then
        _cmifPrenote.curtainsIn 		:= self.curtainsIn;
	endif;
    _cmifPrenote.noPinRequired 		:= _doNotGeneratePin;
    if not (modifying and self.consignorVoyage = null) then
        _cmifPrenote.consignorVoyageCode := self.getConsignorVoyage();
	endif;
    if not (modifying and self.customsSeal = null) then
        _cmifPrenote.setSealNumCustoms( self.customsSeal );	// 20 Sep 2010	NDL	Par 25608
    endif;
	
    if not (modifying and self.freightForwarder = null) then
        ff := app.myRoot.allConsigneeConsignors[self.freightForwarder];
        if ff &lt;&gt; null then
            _cmifPrenote.freightForwarderCode := ff.code;
        endif;
    endif;
    
    if not (modifying and self.vehicle = null) then
        _cmifPrenote.vehicle := self.vehicle[1:12]; //ccms 1726 cnwrs1 sep 2008
	endif;
    if not (modifying and self.carrierCode = null) then
        _cmifPrenote.carrier := self.carrierCode[1:10];
	endif;
    if not (modifying and self.mark = null) then
        //_cmifPrenote.mark := self.mark;						// TFS 4449
        _cmifPrenote.mark := self.mark[1:150];					// TFS 4449
	endif;
    if not (modifying and self.markNumber = null) then
        //_cmifPrenote.markNumber	:= self.markNumber;			// TFS 4449
        _cmifPrenote.markNumber	:= self.markNumber[1:150];		// TFS 4449
	endif;
	
	//cnwmc5 - 29 Jan 2014 - PAR 32864
	if self.overHeight &lt;&gt; NULL_INTEGER then
		_cmifPrenote.overHeight	 	:= self.overHeight;
	endif;
	if self.overLengthFront &lt;&gt; NULL_INTEGER then
		_cmifPrenote.overLengthFront:= self.overLengthFront;
	endif;
	if self.overLengthBack &lt;&gt; NULL_INTEGER then
		_cmifPrenote.overLengthRear := self.overLengthBack;
	endif;
	if self.overWidthLeft &lt;&gt; NULL_INTEGER then
		_cmifPrenote.overWidthLeft 	:= self.overWidthLeft;
	endif;
	if self.overWidthRight &lt;&gt; NULL_INTEGER then
		_cmifPrenote.overWidthRight := self.overWidthRight;
	endif;
	//jlgka1 TFS 44416 --&gt;
	if self.getMyTerminal.getConfig(UseCargoAndSubTypeAsDef).Boolean then
		_cmifPrenote.checkNsetMeasurementFrmDefault();
	endif;
	//jlgka1 TFS 44416 &lt;--
	
	// cnwdad1 02/02/2010 - PAR #22246.
	if app.isSubTerminalsOn(self.getMyTerminal()) then
        if not (modifying and self.subTerminalCode = null) then
            _cmifPrenote.mySubTerminal 		:= self.getMyTerminal().allSubTerminals[self.subTerminalCode];
            _cmifPrenote.subTerminalCode 	:= self.subTerminalCode;
        endif;
	endif;
	
    if not (modifying and self.alternativeId = null) then
        _cmifPrenote.alternativeId := self.alternativeId;
    endif;
    if not (modifying and self.bol = null) then
        _cmifPrenote.billOfLading := self.bol;
    endif;
    if not (modifying and self.clean = null) then
        _cmifPrenote.clean := self.clean;
    endif;
    if not (modifying and self.damaged = null) then
        _cmifPrenote.damaged := self.damaged;
    endif;
	//generatorType?
	//isoTypeGroup?
    if not (modifying and self.preTripped = null) then
        _cmifPrenote.preTripped := self.preTripped;
    endif;
    if not (modifying and self.sealShipper = null) then
        _cmifPrenote.setSealNumShippers(self.sealShipper);	//20 Sep 2010	NDL	Par 25608
    endif;
    if not (modifying and self.sealNumberVent = null) then
        _cmifPrenote.setSealNumVent(self.sealNumberVent);	//20 Sep 2010	NDL	Par 25608
    endif;
    if not (modifying and self.sealTerminalOperator = null) then
        _cmifPrenote.setSealNumTerminalOperator(self.sealTerminalOperator);	
    endif;
    if not (modifying and self.sealUnknown = null) then
        _cmifPrenote.setSealNumUnknown(self.sealUnknown);
    endif;
	//shippingLineCode?
    if not (modifying and self.clientRef = null) then
        _cmifPrenote.clientRef		:= self.clientRef;		// par 30316 Sep 2012
    endif;
    if not (modifying and self.coolingType = null) then
        _cmifPrenote.coolingType	:= self.coolingType;	// par 30316 Sep 2012
    endif;
    if not (modifying and self.eirNumber = null) then
        _cmifPrenote.eirNumber		:= self.eirNumber;		// par 30316 Sep 2012
    endif;
    if not (modifying and self.packDate = null) then
        _cmifPrenote.packDate		:= self.packDate;		// par 30316 Sep 2012
    endif;
    if not (modifying and self.packTempC = NULL_TEMPERATURE) then
        _cmifPrenote.packTempC		:= self.packTempC;		// par 30316 Sep 2012
    endif;
    if not (modifying and self.packTempF &lt;= NULL_TEMPERATURE_FAHRENHEIT) then
        _cmifPrenote.packTempF		:= self.packTempF;		// par 30316 Sep 2012
    endif;
    if not (modifying and self.packTime = null) then
        _cmifPrenote.packTime		:= self.packTime;		// par 30316 Sep 2012
    endif;
    if not (modifying and self.offsiteCleaned = null) then
        _cmifPrenote.offsiteCleaned	:= self.offsiteCleaned;	// par 30316 Sep 2012
    endif;
    if not (modifying and self.offsitePreTrip = null) then
        _cmifPrenote.offsitePreTrip	:= self.offsitePreTrip;	// par 30316 Sep 2012
    endif;
    if not (modifying and self.voltageType = ContainerVoltNull) then
        _cmifPrenote.voltageType	:= self.voltageType;	// par 30316 Sep 2012
    endif;
    if not (modifying and self.make = null) then
        _cmifPrenote.make				:= self.make;				// PAR #32215
    endif;
    if not (modifying and self.model = null) then
        _cmifPrenote.model				:= self.model;				// PAR #32215
    endif;
    if not (modifying and self.carType = null) then
        _cmifPrenote.carType			:= self.carType;			// PAR #32215
    endif;
    if not (modifying and self.year = null) then
        _cmifPrenote.year				:= self.year;				// PAR #32215
    endif;
    if not (modifying and self.colour = null) then
        _cmifPrenote.colour				:= self.colour;				// PAR #32215
    endif;
    if not (modifying and self.trackingNumber1 = null) then
        _cmifPrenote.trackingNumber1	:= self.trackingNumber1;	// PAR #32215
    endif;
    if not (modifying and self.trackingNumber2 = null) then
        _cmifPrenote.trackingNumber2	:= self.trackingNumber2;	// PAR #32215
    endif;
    if not (modifying and self.docsReceived = null) then
        _cmifPrenote.docsReceived.setDate(self.docsReceived);		// PAR #32215
    endif;
    if not (modifying and self.docsSent = null) then
        _cmifPrenote.docsSent.setDate(self.docsSent);				// PAR #32215
    endif;
    if not (modifying and self.docsCleared = null) then
        _cmifPrenote.docsCleared.setDate(self.docsCleared);			// PAR #32215
    endif;
    if not (modifying and self.docsReturned = null) then
        _cmifPrenote.docsReturned.setDate(self.docsReturned);		// PAR #32215
    endif;
    if not (modifying and self.selfPropelled = null) then
        _cmifPrenote.selfPropelled		:= self.selfPropelled;		// PAR #32215
    endif;
    if not (modifying and self.hasRadio = null) then
        _cmifPrenote.hasRadio			:= self.hasRadio;			// PAR #32215
    endif;
    if not (modifying and self.doors = null) then
        _cmifPrenote.nbrDoors			:= self.doors;				// PAR #32215
    endif;
    if not (modifying and self.isNew = null) then
        _cmifPrenote.isNewVehicle		:= self.isNew;				// PAR #32215
    endif;
    if not (modifying and self.totalQuantity = null) then
        _cmifPrenote.numberOfItems	:= self.totalQuantity;			//epr par 32950 14/11/13
    endif;
    if not (modifying and self.productQuantity = null) then
        _cmifPrenote.quantity		:= self.productQuantity;		//epr par 32950 14/11/13
    endif;
    if not (modifying and self.orderNumber = null) then
        _cmifPrenote.orderNumber := self.orderNumber;
    endif;
    if not (modifying and self.invoiceNumber = null) then
        _cmifPrenote.invoiceNumber := self.invoiceNumber;
    endif;
	
	if not (modifying and self.isWeightCertified = null) then						// TFS #1699
		_cmifPrenote.isWeightCertified := self.isWeightCertified;					// TFS #1699
	endif;																			// TFS #1699
	if not (modifying and self.weightCertifiedName = null) then						// TFS #1699
		_cmifPrenote.weightCertifiedName := self.weightCertifiedName;				// TFS #1699
	endif;																			// TFS #1699
	if not (modifying and self.weightCertifiedReference = null) then				// TFS #1699
		_cmifPrenote.weightCertifiedReference := self.weightCertifiedReference;		// TFS #1699
	endif;																			// TFS #1699
	
	//08 Nov 2016	NDL	TFS 2912 / 2419
	if not (modifying and self.serviceOrder = null) then
        _cmifPrenote.serviceOrder := self.serviceOrder;
    endif;
	
	//15 Nov 2016	NDL	TFS 2959 / 2420
	if not (modifying and self.tareWeight = 0) then
        _cmifPrenote.weightTare := self.tareWeight;
    endif;
	//15 Nov 2016	NDL	TFS 2959 / 2420
	if not (modifying and self.cargoWeight = 0) then
        _cmifPrenote.weightCargo := self.cargoWeight;
    endif;
	
	//epr TFS 3581 8/3/17
	//if null default from the operator config
	if self.isExternallyMonitored = null then
		operator:= self.getMyOperator;
		if operator &lt;&gt; null then
			opTerm :=operator.allOperatorTerminals[self.getMyTerminal()];
			if opTerm &lt;&gt; null then
				_cmifPrenote.isExternallyMonitored := opTerm.isExternallyMonitored;
			endif;
		endif;
	else
		_cmifPrenote.isExternallyMonitored:= self.isExternallyMonitored.asBooleanJMT;
	endif;
	
	//24 Apr 2017	NDL	TFS 3414
	if not (modifying and self.heatTreated = null) then
        _cmifPrenote.heatTreated := self.heatTreated.Boolean;
    endif;
	if not (modifying and self.storeOnPallet = null) then
        _cmifPrenote.storeOnPallet := self.storeOnPallet.Boolean;
    endif;
	if not (modifying and self.palletType = null) then
        _cmifPrenote.palletType := self.palletType;
    endif;
	
	if not (modifying and self.updateVGMOnly = null) then						// TFS 4434
		_cmifPrenote.updateVGMOnly := self.updateVGMOnly.Boolean;				// TFS 4434
	endif;
	
	//20 Jun 2017	NDL	TFS 4454
	if not (modifying and self.specialStowage = null) then
        _cmifPrenote.specialStow := self.specialStowage;
    endif;
	
	if not (modifying and self.vgmAuthSignature = null) then				// TFS 4492
		_cmifPrenote.vgmAuthSignature := self.vgmAuthSignature;				// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmCommsType = null) then					// TFS 4492
		_cmifPrenote.vgmCommsType := self.vgmCommsType;						// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmDeterminationDT = null) then				// TFS 4492
		_cmifPrenote.vgmDeterminationDT := self.vgmDeterminationDT;			// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmDocsIssuedDT = null) then					// TFS 4492
		_cmifPrenote.vgmDocsIssuedDT := self.vgmDocsIssuedDT;				// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmDocumentDetails = null) then				// TFS 4492
		_cmifPrenote.vgmDocumentDetails := self.vgmDocumentDetails;			// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmEDITransmission = null) then				// TFS 4492
		_cmifPrenote.vgmEDITransmission := self.vgmEDITransmission;			// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmElectronicMail = null) then				// TFS 4492
		_cmifPrenote.vgmElectronicMail := self.vgmElectronicMail;			// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmMail = null) then							// TFS 4492
		_cmifPrenote.vgmMail := self.vgmMail;								// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmPhone = null) then						// TFS 4492
		_cmifPrenote.vgmPhone := self.vgmPhone;								// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmTelefax = null) then						// TFS 4492
		_cmifPrenote.vgmTelefax := self.vgmTelefax;							// TFS 4492
	endif;																	// TFS 4492
	if not (modifying and self.vgmTelephone = null) then					// TFS 4492
		_cmifPrenote.vgmTelephone := self.vgmTelephone;						// TFS 4492
	endif;																	// TFS 4492
	
	//03 May 2018	NDL	TFS 37795
	if not (modifying and self.remarksAdditional1 = null) then
        _cmifPrenote.remarksAdditional1 := self.remarksAdditional1;
    endif;
	if not (modifying and self.remarksAdditional2 = null) then
        _cmifPrenote.remarksAdditional2 := self.remarksAdditional2;
    endif;
	
	if not (modifying and self.stevedore = null) then           			 //02.10.2020 cnwma1 TFS #50112
        _cmifPrenote.stevedoreCode := self.stevedore;
    endif;
	//jlier1 TFS 53030 8/9/22
	if not (modifying and self.operatorExportReleaseNumber = null) then
        _cmifPrenote.operatorExportReleaseNumber	:=	self.operatorExportReleaseNumber;	
    endif;
	//jlier1 TFS  54846 30/9/22
	if not (modifying and self.countryOfOriginCode = null) then
        _cmifPrenote.countryOfOriginCode	:=	self.countryOfOriginCode;	
    endif;
	//jlika1 TFS 55586 1/12/2022
	if not (modifying and self.hsCode = null) then
        _cmifPrenote.hsCode	:=	self.hsCode;	
    endif;
	// 11/01/2023	navkc1	TFS CR 55625 TASK 55660
	if not (modifying and self.contractIdForTIstring = null) then
		_cmifPrenote.setContractId(self.contractIdForTIstring);
	endif;
	
	// TFS 57074
	if not (modifying and self.itemised = null) then
		_cmifPrenote.itemised := self.itemised;
	endif;
	if not (modifying and self.secondaryBarcodeId = null) then
		_cmifPrenote.secondaryBarcodeId := self.secondaryBarcodeId;
	endif;
	if not (modifying and self.sortingMethod = null) then
		_cmifPrenote.mySortingMethod := app.myRoot.allSortingMethods[self.sortingMethod];
	endif;
	if not (modifying and self.manifestNumber = null) then
		_cmifPrenote.manifestNumber := self.manifestNumber;
	endif;
	// TFS 57074 end
	containerNumberTextStr := self.getContainerNumberText();
	if not (modifying and containerNumberTextStr = null) then		//18 July 2023	jlirs1		TFS 59187 (59019) EUP
		_cmifPrenote.containerNumberText := containerNumberTextStr;
	endif;
	// TFS 58813 start
	if not (modifying and self.instructionType = null) then
		_cmifPrenote.instructionsType := self.instructionType;          //15.Aug.2023 navsp1 TFS 59677
	endif;
	if not (modifying and self.instructionExternal = null) then
		_cmifPrenote.instructionsExternal := self.instructionExternal;  //15.Aug.2023 navsp1 TFS 59677
	endif;
	if not (modifying and self.instructionInternal = null) then
		_cmifPrenote.instructionsInternal := self.instructionInternal;  //15.Aug.2023 navsp1 TFS 59677
	endif;
	// TFS 58813
	//navra1 - TFS 60391 - 8th Sep 2023 - start
	if not (modifying and self.grammage = null) then
		_cmifPrenote.grammage := self.grammage;
	endif;
	//navra1 - TFS 60391 - 8th Sep 2023 - end
	// #60601 - Start
	if not (modifying and self.rollingLength = null) then
		_cmifPrenote.rollingLength := self.rollingLength;
	endif;
	if not (modifying and self.diameter = null) then
		_cmifPrenote.diameter := self.diameter;
	endif;
	// #60601 - End
	
	if not (modifying and self.trailerType = null) then
		_cmifPrenote.trailerType := self.trailerType;
	endif;
	
	if not (modifying and self.condition = null) then	//JIRA-33451
		_cmifPrenote.condition := self.condition;		//JIRA-33451
	endif;												//JIRA-33451
	
	// MTN-36141 new attribute
	if not (modifying and self.cargoTypeContents = null) then
		_cmifPrenote.cargoTypeContents := self.cargoTypeContents;
		if self.cargoTypeContents = null and self.cargoTypeDescContents &lt;&gt; null then
			cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr(self.cargoTypeDescContents);
			if cargoTypeObj &lt;&gt; null then
				_cmifPrenote.cargoTypeContents := cargoTypeObj.id;
			endif;
		endif;
		if _cmifPrenote.cargoTypeContents &lt;&gt; null and self.isoType &lt;&gt; null then
			_cmifPrenote.cargoType := TI_CargoType_Container;
			cargoTypeObj := app.myRoot.allCargoTypesById[_cmifPrenote.cargoTypeContents];
			if cargoTypeObj &lt;&gt; null then
				_cmifPrenote.myProduct := cargoTypeObj.getProductFromCode(self.product);
			endif;
		endif;
	endif;
epilog
	delete allStrings;
	delete tmpHazards;
end;</source>
        <Parameter name="_cmifPrenote" type="CMIF_PreNote" usage="input"/>
        <Parameter name="_doNotGeneratePin" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPropertyByName" id="594660c1-fbf5-4493-8faa-aecc39cf52a6">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
//
// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// 10 Jul 2023	navdap1	TFS 58813 EUP Manifest Instructions and Work Orders
// 19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
//
vars
	value : String;
	contRange : CM_ContRange;
begin
	if _columnName = ETRow_CoolingType then
		value := _value.toUpper;
		if value = 'AIR' or value = 'AC' or value = 'A' or value = ContainerAirCooledStr.toUpper then
			self.coolingType := ContainerAirCooled;
		elseif value = 'WATER' or value = 'WC' or value = 'W' or value = ContainerWaterCooledStr.toUpper then
			self.coolingType := ContainerWaterCooled;
		else
			contRange := self.getContRange();
			if contRange &lt;&gt; null then
				self.coolingType := contRange.coolingType;
			else
				self.coolingType := ContainerCooledNull;
			endif;
		endif;
		return true;
	elseif _columnName = ETRow_VoltageType then
		value := _value.toUpper; 
		if value = 'DUAL' or value = 'DV' or value = 'D' or value = ContainerDualVoltStr.toUpper then 
			self.voltageType := ContainerDualVolt;
		elseif value = 'SINGLE' or value = 'SV' or value = 'S' or value = ContainerSingleVoltStr.toUpper then
			self.voltageType := ContainerSingleVolt;
		else
			self.voltageType := ContainerVoltNull;
		endif;
		return true;
	elseif _columnName = ETRow_InstructionType then			// TFS 58813
		self.instructionType := _value;						// TFS 58813
	elseif _columnName = ETRow_InstructionExternal then		// TFS 58813
		self.instructionExternal := _value;					// TFS 58813
	elseif _columnName = ETRow_InstructionInternal then		// TFS 58813
		self.instructionInternal := _value;					// TFS 58813
	elseif _columnName = ETRow_ContainerNumberText then		//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		self.setContainerNumberText(_value);
	elseif _columnName = ETRow_ShippingLineCode then		// TFS 62598
		self.shippingLineCodeForTI := _value;				// TFS 62598
		self.shippingLineCode := _value;					// TFS 62598
	else
		return inheritMethod(_columnName, _value);
	endif;
end;
</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="96093666-2834-4950-bf88-978defd9b68f">
        <updating/>
        <source>setStatus(_newStatus: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals

*/

vars

	iter : Iterator;
	ediTi : CM_EDITrackedItem;
	invalid : Boolean;

begin

	inheritMethod(_newStatus);
	
	if self.myAttachedItems &lt;&gt; null and not self.myAttachedItems.isEmpty then
		on Exception do app.handleDeletedObject(exception, ediTi,invalid);
		iter := self.myAttachedItems.createIterator;
		while iter.next( ediTi ) do
			if ediTi.isEDIHazDetails or
			   ediTi.isEDISealDetails then
				ediTi.setStatus(_newStatus);
			endif;
		endwhile;
		delete iter;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStringValue" id="71534747-a9e1-4c93-a6a7-476e0746259d">
        <updating/>
        <source>setStringValue(_propName: String; _value: String;_propertyLength : Integer) updating, protected;
//
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
//07 Dec 2022   navma1  ChangeRequest 55783: MTN - Removing unnecessary calls for Class::getPropertyInHTree() method while setting EDI property values
vars

begin
	if _propName = CM_EDIPrenoteTI::isoType.name then
		if _value.length &gt; _propName.length then
			global.setExtraData(self.allExtraData, self, ETRow_IsoTypeDesc, _value);
		endif;
	endif;
	inheritMethod(_propName, _value,_propertyLength);									//07.12.2022 navma1 #55783	
end;
</source>
        <access>protected</access>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_propertyLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTransportModeEDIFormat" id="f749f5f7-16db-4fbb-9470-9acb223fe9f0">
        <updating/>
        <source>setTransportModeEDIFormat(_formatSeqNum: Integer) updating;
//----------------------------------------------------------------
//	Created:	11 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//set if different from TI_TRANSMODE_ROAD_STR (default)
	if _formatSeqNum = TollNZAdvNot then
		self.transportMode := TI_TRANSMODE_RAIL_STR;
	endif;

end;</source>
        <Parameter name="_formatSeqNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="25005e79-26cd-4920-ac56-0a991b77a0a7">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;

/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
06/09/2010		cnwcs5	par 25651 - do not populate collection for transient object
	                              - also optimised code  to use local variables (not done in 7.8.2) and
								    not repeat toUpper calls
*/
	
vars
	updateColl	:Boolean;
	oldValue,
	newValue	:String;
	config		:CM_EDIConfig;
	coll 		:CM_EDITIsByVoyageCodeDict;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	updateColl 	:= not self.isTransient;
	oldValue	:= self.voyageCode.toUpper;
	config		:= self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	// remove the previous non-null value from this collection - only if not transient
	if updateColl and // 06/09/2010 cnwcs5 par 25651
		oldValue &lt;&gt; null and coll &lt;&gt; null then
		if coll.includesKey( self.voyageCode.toUpper, self ) then
			coll.removeKeyEntry( self.voyageCode.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null and not transient).
	self.voyageCode	:= _value[ 1 : self.voyageCode.maxLength ];
	newValue		:= self.voyageCode.toUpper;
	
	if updateColl and	// 06/09/2010 cnwcs5 par 25651
		newValue &lt;&gt; null and coll &lt;&gt; null then
		if not coll.includesKey( newValue, self ) then
			coll.putAtKey( newValue, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="temperature" id="760e6798-49eb-4e11-a6ba-65feb2d877f5">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>temperature(set: Boolean; _value: Real io) mapping, updating;
//----------------------------------------------------------------
//	Created:	25 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tempStr		: String;
begin
	if set then
		self.temperature := _value;
	else
		if self.temperatureAbsolute &lt; NULL_TEMPERATURE then
			tempStr := self.temperatureSign &amp; self.temperatureAbsolute.String;
			if tempStr.isReal then
			
			endif;
		else
			_value := self.temperature;

		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateCommodity" id="ddb57936-971a-4add-903a-8157a193cab4">
        <updating/>
        <source>translateCommodity(_xlationOperator: CM_Operator) updating, protected;
/*
25 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars
	foundMatch    	: Boolean;
	mtCmdty 		: String;
	defCmdty 		: String;
	refCmdty 		: String;
	hazCmdty		: String;
	commodityObj    : CM_Commodity;
	code 			: String;
	value 			: String;
	ignoreCommDescr : Boolean;
	iftminFile		: Boolean;
	cgType			: CM_CargoType;
	prod 			: CM_Product;

begin
	
	inheritMethod(_xlationOperator);
	
	iftminFile := (self.myEDIData.ediFileCode = EDIFileType_IFTMIN);

	if iftminFile then
		value := self.commodityDescription;
	
		if value &lt;&gt; null then
			if _xlationOperator &lt;&gt; null then
				code := _xlationOperator.getXlationSystemCode_Commodity(value, foundMatch, self.temperature)[1:4];
			endif;

			if foundMatch then
				self.commodity := code;
			endif;
		endif;
	else
		if self.commodity = self.commodityDescription then
			ignoreCommDescr := true;
		endif;
		
		if self.commodity &lt;&gt; null then
			commodityObj := app.myRoot.allCommodities[self.commodity];
			if commodityObj = null then
				self.commodity := null;
			endif;
		endif;
	
		if self.commodity = null then
			//epr TFS 2416 26/7/16
			//global.getExtraData(self.allExtraData, ETRow_Commodity, value);				//22.11.2022 navma1 #55424
			value	:= self.rawDataCommodity;												//21.11.2022 navma1 #55424
			if value &lt;&gt; null then
				if _xlationOperator &lt;&gt; null then
					self.commodity := _xlationOperator.getXlationSystemCode_Commodity(value, foundMatch, self.temperature)[1:4];
				else
					self.commodity := value[1:4];
				endif;
			else
				if not ignoreCommDescr then
				value := self.commodityDescription;
				if _xlationOperator &lt;&gt; null and value &lt;&gt; null then
					self.commodity := _xlationOperator.getXlationSystemCode_Commodity(value, foundMatch, self.temperature)[1:4];			
				endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.commodity = null then 
		cgType := self.getCargoTypeObj();													//23Sep2022 navsp1 TFS 52673
		if cgType = null or not cgType.isCommodityRequired then 							//23Sep2022 navsp1 TFS 52673
			//If we can't find the cargo type, they will need to fix this first anyway.
			//If the cargo type doesn't support commodities, don't default it. 
			//The default commodity assignment at the bottom should be avoided.				//23Sep2022 navsp1 TFS 52673
			return;
		endif;
		//12 Sep 2019	NDL	TFS 46537
		if self.getMyTerminal.getConfig(UseCargoAndSubTypeAsDef).Boolean then
			if cgType &lt;&gt; null and cgType.isCommodityRequired then
				if not cgType.isContainer then
					//because the default values later in the method were only really intended for containers
					prod := self.getMyProduct(cgType, self.operatorCode);
					if prod &lt;&gt; null then
						self.commodity := prod.defaultCommodityCode;
					endif;		
					if self.commodity = null then
						self.commodity := cgType.defaultCommodityCode;
					endif;
					return;
				endif;
			endif;
		endif;
		
		app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);	
		if self.fullOrMT = "E" then
			self.commodity := mtCmdty;
		endif;
		if self.isHazardous then
			self.commodity := hazCmdty;
		endif;
		if self.temperature &lt;&gt; NULL_TEMPERATURE then
			// if we don't have a commodity xlation by now it is a reefer 
			self.commodity := refCmdty;
		endif;
		if self.commodity = null then
			self.commodity := defCmdty;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="translatePortCode" id="9c6291f3-9512-4f3f-b298-da2862e58acb">
        <source>translatePortCode(portCode : String) : String;
/* NFS 3833: AA 18/10/01. Method to translate / truncate the port code so that
we get the most likely port code for the persistent TI. Note that we allow 5 chars
on the port code for this object, but the TI will only support 4 chars
*/

//note: this method was copied to CM_EDILoadListTI (cnwjo3)

// 21 mar 2013	cnwcs5	CCMS POL 2097 / par 31259

vars
	operator		: CM_Operator;
	port			: CM_Port;
	xlatedPort		: String;
	foundMatch		: Boolean;
begin
	if portCode = null then
		return null;
	endif;
	
	//Look up the raw code. It just might be correct
	//port := app.myRoot.allPorts[portCode];
	port := app.myRoot.allPorts[portCode];	
	
	if port = null then
		 
		// PORT CODES SHOULD ALL BE 5 CHARACTERS AFTER 7.4.2
			//Try to translate the code using the operators translation table
			operator := app.myRoot.allOperators[operatorCode];
			
			if operator &lt;&gt; null then
				if operator &lt;&gt; null then
					xlatedPort := operator.getXlationSystemCode (portCode, XLATION_TYPE_PORT_BYOP, foundMatch);
				endif;
			endif;
			//port := app.myRoot.allPorts[xlatedPort];
			port := app.myRoot.allPorts[xlatedPort];
//		endif;
	endif;

	if port &lt;&gt; null then
		return port.code;			//Set to translated / short code
	else
		return portCode[1:4];			//Must truncate to 4 chars anyway
	endif;

end;</source>
        <Parameter name="portCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateValue" id="c550b9a7-6f22-4a90-a2f0-886f2824883b">
        <source>translateValue(_fieldName: String; _xlationOperator: CM_Operator; _processedValue: String io) protected;
/*
Date		Who		Reason
12 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	foundMatch :Boolean;
begin
	if _fieldName = CM_EDIPrenoteTI::shippingLineCode.name then
		_processedValue := app.myRoot.getXlationSystemCode(_processedValue, XLATION_TYPE_SHIPPINGLINE, foundMatch);	// par 31259 March 2013
	else
		inheritMethod(_fieldName, _xlationOperator, _processedValue);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_processedValue" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateVesselVoyage" id="8403f27c-8f24-4754-bc3c-fec8846cd927">
        <updating/>
        <source>translateVesselVoyage(_xlationOperator: CM_Operator) updating, protected;
/*
Date		Who		Reason
12 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
1/08/2018 	JLGNS1	Bug 39728: SNO - Prenote issue
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/

vars
	tiOperator		: CM_Operator;
	voyageDesc		: String;
	foundMatch		: Boolean;
	transVoyageCode	: String;	//Bug 39728
begin
	// if we already have a valid voyageCode then dont do anything
	if self.voyageCode &lt;&gt; null then
		if self.getMyTerminal.lookupVoyage(self.voyageCode, null, false) &lt;&gt; null then
			return;
		endif;
	endif;
	//if we have a vessel name then try to translate
	// PAR #30118 if we have an operator set on the prenote already, use this operator for translations
	// if we don't have an operator set yet, use the ediData operator for translations
	if self.operatorCode &lt;&gt; null then											// PAR #30118
		tiOperator := app.myRoot.allOperators[self.operatorCode]; 				//par 
	else																		// PAR #30118
		tiOperator := _xlationOperator;											// PAR #30118
	endif;
	// PAR #30118
	// we previously saved the raw input in extra data
	//global.getExtraData (self.allExtraData, ETRow_VoyageCode, voyageDesc); 				//21.11.2022 navma1 #55424
	voyageDesc := self.rawDataVoyageCode;													//21.11.2022 navma1 #55424
	
	if tiOperator &lt;&gt; null then
		// make sure the manual collection on CM_EDIConfig gets maintained
		transVoyageCode :=	tiOperator.getXlationSystemCode_Voyage(voyageDesc, self.vesselName, null, null, foundMatch);	//Bug 39728
		if not foundMatch and self.doDefaultInvalidVoyageToNull() then		//03 Jan 2018	NDL	TFS 42303
			self.setVoyageCode( self.getMyTerminal.getDefaultVoyageCode );	//03 Jan 2018	NDL	TFS 42303
		elseif transVoyageCode &lt;&gt; null then																					//Bug 39728
			self.setVoyageCode(transVoyageCode);																			//Bug 39728
		endif;																												//Bug 39728
	else
		if  voyageDesc &lt;&gt; null then
			// make sure the manual collection on CM_EDIConfig gets maintained
			self.setVoyageCode(voyageDesc );
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="transportMode" id="3d91177f-7b3b-4c0b-9fec-1d05716fb3cf">
        <methodInvocation>mapping</methodInvocation>
        <source>transportMode(set : Boolean; _value : String io) mapping;
// ---------------------------------------------------------------------------
// Created:	07 March 2010 By Graeme Black cnwgb1
// Status: 	
// Purpose:	PAR 22670 Train COnsist Prenotes should always be Rail.
// ---------------------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediData : CM_EDIData;
begin
	if not set then
		ediData := self.myEDIData;
		if ediData&lt;&gt; null and ediData.isKindOf(CM_EDIDataTrainConsist) then
			_value := TI_TRANSMODE_RAIL_STR;
		else
			_value := self.transportMode;
		endif;
	endif;
epilog
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="update773ImportReleasePIN" id="0e31ab6a-47a6-462b-a394-bddf3f0f015a">
        <updating/>
        <source>update773ImportReleasePIN() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:	30 December 2009 By Graeme Black cnwgb1
// PAR 21881 CCMS 1906
// Purpose:	Update the 7.7.3 OperatorImportReleasePIN from all ExtraData to
//          the concrete attribute. Should only be called from an upgrade 
//			script in release 7.8.1 (and in transaction state)
// ---------------------------------------------------------------------------
vars
	value : String;
begin
    global.getExtraData(self.allExtraData, OperatorImportReleasePIN, value);
	if value &lt;&gt; null and self.operatorImportReleasePIN = null then
		self.operatorImportReleasePIN := value;
		global.setExtraData(self.allExtraData, self, OperatorImportReleasePIN, null);
		return true;
	endif;
	return false;
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyAlternateId" id="42496f15-145e-44d3-b2b3-05160fd412b5">
        <source>verifyAlternateId() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars

begin
	if self.alternativeId = null then
		return;
	endif;
	if self.alternativeId = self.id then
		app.raiseCMException( Cargo_same_alterna_id, ETRow_AlternativeId, self );
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyAvailabilityGrade" id="7d37ce74-a6a1-46ef-9d02-700d7cdc929a">
        <source>verifyAvailabilityGrade() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	mtGrade : CM_MTGrade;
begin
	if self.availabilityGrade = null then
		return;
	endif;
	// otherwise validate this value against the system AvailabilityGrades.
	mtGrade	:= app.myRoot.allAvailabilityGrades[ self.availabilityGrade ];
	if mtGrade = null then
		app.raiseCMException1( Invalid_AvailabilityGrade, self.availabilityGrade.display, ETRow_AvailabilityGrade, self );
	endif;
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyBookingRef" id="478e1065-12ed-4c13-a33b-1ce826be0b17">
        <source>verifyBookingRef() protected;
//
// 09 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 28 Feb 2018	jlgmd1	TFS 37320 CIG - Length in the ID Fields (Bumped validation to 30 to match field length)
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	bookingRefObject : CM_BookingRef;
	brItem : CM_BookingRefItem;
	config : Integer;
	operator : CM_Operator;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	isError : Boolean;
	imexCode : Integer;
begin
	if self.bookingRef.length &gt; 30 then														// 22/03/2016 cnwma1 PAR #37698
		app.raiseCMException2(ERR_STRING_TO_LONG, app.getErrorString(BookingRef), '30', null ,self);
	endif;
	operator := self.getMyOperator;
	if operator = null then
		return;
	endif;
	if self.parentCargoID &lt;&gt; null then
		return;
	endif;
	//jlier1 TFS 52621 30/5/22 - make same as CM_TrackedItem validateBookingReference
	imexCode:=app.myRoot.getImexCodeFromDesc(self.imexStatus);
	if not imexCode = TI_IMEX_STATUS_EXPORT  or imexCode =TI_IMEX_STATUS_TRANSHIP then
		return;
	endif;
	
	terminal := self.getMyTerminal;
	voyage := terminal.lookupVoyage(self.voyageCode, null, null);
		if operator.requiresBookingReference and self.bookingRef = null then
			//No booking ref, This is an error
		   	app.raiseCMException2(VB_BOOKING_REF_REQUIRED, operatorCode, self.id, 'bookingReference', self);
		   	return;
		else
		// dh par 16157 - made a more specific search for booking ref
			bookingRefObject := terminal.getBookingReference(self.operatorCode, bookingRef, voyage);	// adm 150908 Par 17936
		endif;
	
		if bookingRefObject = null then
			//This b/r is invalid or not known to the system
			// 28105 Sep 2011 operator requires booking and terminal config Booking Required is 'Strict' - to be error not warning
			if operator.requiresBookingReference then
				config := terminal.getConfig(BookingRefRequired).Integer;
				if config = BookingRequired_Strict then
					isError := true;
				endif;
			endif;
			if isError then
				//app.raiseCMException1(WARN_BOOKING_REF, bookingReference, 'bookingReference', pControl.myUserObject);
				app.raiseCMException1(WARN_BOOKING_REF, bookingRef, 'bookingReference', self);
			else
				config := terminal.getConfig(BookingRefRequired).Integer;
				if config = BookingRequired_Partial then //28.Jun.2023 navsp1 TFS 57805 - Restrict warning if booking not required
					app.raiseCMWarning1(WARN_BOOKING_REF, bookingRef, 'bookingReference', self, self); //cnwrd1 par 28809 19.3.2012
				endif;
			endif;
			return;
		else
			// PAR #19785 - If we have a Booking Reference, then it must be Active
			if bookingRefObject.status &lt;&gt; BOOKING_REF_ACTIVE then
				app.raiseCMException3(ERR_BOOKING_REF_STATUS,
									  bookingRefObject.bookingReference,
									  bookingRefObject.getStatusString,
									  app.bookingRefStatusEnumToString(BOOKING_REF_ACTIVE),
									  null,
									  self);
				return;									  
			endif;
		endif;		
/*	if operator.requiresBookingReference then				//+cnwml2 PAR26103
		config := terminal.getConfig(BookingRefRequired).Integer;			//+cnwml2 PAR23763 MSL PAR1078
		if config = BookingRequired_None then
			//no validation needed
		elseif config = BookingRequired_Partial then
			if self.bookingRef &lt;&gt; null then
				bookingRefObject := terminal.allBookingRefsByRef[self.bookingRef];
				if bookingRefObject = null then
					app.raiseCMWarning1(InvalidBooking, self.bookingRef, 'bookingRef', self, self);					//+cnwml2 PAR24267
				else
					if bookingRefObject.myOperator &lt;&gt; operator then
						app.raiseCMWarning2(BookingOperatorMatch, bookingRefObject.myOperator.code, operator.code, 'booking Reference', self, self);			//+cnwml2 PAR24267
					elseif bookingRefObject.myVoyage &lt;&gt; null and bookingRefObject.myVoyage &lt;&gt; voyage then        // PAR 23766
						app.raiseCMWarning2(BookingVoyageMatch, bookingRefObject.myVoyage.code, voyage.code, 'bookingReference', self, self);					//+cnwml2 PAR24267
					endif;
				endif;
			else
				app.raiseCMWarning1(WARN_BOOKING_REF, bookingRef, 'bookingReference', self, self);
			endif;
		elseif config = BookingRequired_Strict then 
			if self.bookingRef &lt;&gt; null then
				bookingRefObject := terminal.allBookingRefsByRef[self.bookingRef];
				if bookingRefObject = null then
					app.raiseCMException1(InvalidBooking, self.bookingRef, 'bookingReference', self);
				else
					if bookingRefObject.myOperator &lt;&gt; operator then
						app.raiseCMException2(BookingOperatorMatch, bookingRefObject.myOperator.code, operator.code, 'booking Reference', self);
					elseif bookingRefObject.myVoyage &lt;&gt; null and bookingRefObject.myVoyage &lt;&gt; voyage then        // PAR 23766
						app.raiseCMException2(BookingVoyageMatch, bookingRefObject.myVoyage.code, voyage.code, 'bookingReference', self);
					endif;
				endif;
			else
				app.raiseCMException1(WARN_BOOKING_REF, bookingRef, 'bookingReference', self);
			endif;
		endif;
	endif;*/
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCargoType" id="9037ae64-6f8e-4f96-bc00-bc14ff5d76ec">
        <updating/>
        <source>verifyCargoType() protected, updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 28 Nov 2024  navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	cargoTypeDict 		: CM_CargoTypesByIdDict;
	cargoTypeObj 		: CM_CargoType;
	term 				: CM_Terminal;
	terminalCargoTypes  : CM_CargoTypeSet; 
	includeISOContainer : Boolean;
begin
	includeISOContainer := true;
	
	// ### VALIDATE CARGO IS VALID FOR SYSTEM
	// ###
	cargoTypeDict 	 := app.myRoot.allCargoTypesById;
	if self.cargoTypeDescr.toUpper.cnContains('CONTAINER') then//special case - phuzzy lojic
		cargoTypeObj := cargoTypeDict[TI_CargoType_Container].CM_CargoType;
	else	
		cargoTypeObj := cargoTypeDict[self.cargoType].CM_CargoType;
		if cargoTypeObj = null then
			//03 Apr 2019	NDL	TFS 44194 - Performance
			cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			if cargoTypeObj &lt;&gt; null then
				self.cargoType 		:= cargoTypeObj.type;
				self.cargoTypeDescr := cargoTypeObj.description;
			endif;
			
		else
			self.cargoTypeDescr := cargoTypeObj.description;//keep them in synch
		endif;
	endif;
	
	cargoTypeDict := null;
	if cargoTypeObj = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, self.cargoTypeDescr, ETRow_CargoTypeDescr, self);
		self.cargoType := null;
		return;
		
	endif;
	
	term := self.getMyTerminal();

	if not cargoTypeObj.allTerminals.includes( term ) then	//03 Apr 2019	NDL	TFS 44194
		app.raiseCMException2(Cargot_not_valid_cargot_termin, self.cargoTypeDescr, term.name, ETRow_CargoTypeDescr, self);
	elseif cargoTypeObj.isNotAvailableForEntry then	//PAR 21733
		app.raiseCMException1(Cargo_type_marked_not_availabl, self.cargoTypeDescr, ETRow_CargoTypeDescr, self);
	else
		self.cargoType 		:= cargoTypeObj.type;
		self.cargoTypeDescr := cargoTypeObj.description;
	endif;
epilog
	delete terminalCargoTypes;
	delete cargoTypeDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCargoTypeAndProdContents" id="558cee58-bb97-41e5-8bca-cf1deb3d184a">
        <updating/>
        <source>verifyCargoTypeAndProdContents() protected, updating;
//
// Purpose:		Validate that any supplied caragoTypeContents / cargoTypeDescContents is valid
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/10/2025	navdap1		Initial creation MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	isoTypeObj : CM_ISOType;
	cargoTypeDict : CM_CargoTypesByIdDict;
	cargoTypeObj : CM_CargoType;
	term : CM_Terminal;
	cargoSubType : CM_Product;

begin
	if self.isoType = null then
		return;
	endif;
	
	if not self.isISOTypeRotatable(isoTypeObj) then
		return;
	endif;
	
	// Do we have a cargo type id or a cargo type description
	cargoTypeDict := app.myRoot.allCargoTypesById;
	cargoTypeObj := cargoTypeDict[self.cargoTypeContents];
	if cargoTypeObj = null then
		cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescContents );
		if cargoTypeObj &lt;&gt; null then
			self.cargoTypeContents 		:= cargoTypeObj.type;
			self.cargoTypeDescContents	:= cargoTypeObj.description;
		endif;
		
	else
		self.cargoTypeDescr := cargoTypeObj.description;	//keep them in synch
	endif;
	
	if cargoTypeObj = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, self.cargoTypeDescContents, ETRow_CargoTypeDescContents, self);
		self.cargoTypeContents := null;
		return;
	endif;
	
	term := self.getMyTerminal();

	if not cargoTypeObj.allTerminals.includes( term ) then
		app.raiseCMException2(Cargot_not_valid_cargot_termin, self.cargoTypeDescContents, term.name, ETRow_CargoTypeDescContents, self);
	elseif cargoTypeObj.isNotAvailableForEntry then
		app.raiseCMException1(Cargo_type_marked_not_availabl, self.cargoTypeDescContents, ETRow_CargoTypeDescContents, self);
	endif;
	
	if self.product &lt;&gt; null then
		cargoSubType := cargoTypeObj.allProducts[self.operatorCode, self.product];
		if cargoSubType = null then
			cargoSubType := cargoTypeObj.allProducts[null, self.product];
		endif;
		if cargoSubType = null then
			app.raiseCMException2(CargoSubtype_Invalid, self.cargoTypeDescContents, self.product, null, null);
		endif;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCarrier" id="2702d1ad-b848-4782-b1c9-42b40983f941">
        <updating/>
        <source>verifyCarrier() protected, updating;
//
// 09 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 11 Sep 2023	navra1	TFS 60389 EUP | FR 53824 - Road Manifest Carrier Party
// 28 Nov 2024  navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	loopCarrier 	  : CM_Carrier;
	carrier 		  : CM_Carrier;
	carrierDict 	  : CM_CarrierByCodeDict;
	carrierCodeUpper  : String;
begin
	if self.carrierCode = null then
		return;
	endif;
	
	carrierDict := app.myRoot.allCarriers;
	carrier 	:= carrierDict[self.carrierCode];
	
	if carrier = null then
		if app.myAlternateDict &lt;&gt; null then											//03 Apr 2019	NDL	TFS 44194 - performance
			carrier := app.myAlternateDict.getCarrierByDesc(self.carrierCode);
			if carrier &lt;&gt; null then
				self.carrierCode := carrier.code;
			endif;
		else
			carrierCodeUpper := self.carrierCode.toUpper;							//28.11.2024 navma1 #MTN-19124
			
			foreach loopCarrier in carrierDict do
				if loopCarrier.description.toUpper = carrierCodeUpper then			//28.11.2024 navma1 #MTN-19124
					self.carrierCode := loopCarrier.code;
					carrier 		 := loopCarrier;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if carrier = null then
		//navra1 - TFS 60389 - 11th Sep 2023 - start
		if self.isTransportManifestRelated() then
			app.raiseCMWarning2(ERR_FIELD_CARRIER, self.carrierCode, 'carrier code', ETRow_CarrierCode, self, self);
		endif;
		//navra1 - TFS 60389 - 11th Sep 2023 - end
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyColour" id="01859010-3c04-4b89-92b7-b759150a86de">
        <source>verifyColour() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/08/2013	cnwdap1		Initial creation PAR #32123
// 27/08/2013	cnwdap1		PAR #32326 Allow for more than one colour being supplied e.g. "BLUE RED"
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	colours : StringArray;																	// PAR #32326
	str : String;																		// PAR #32326
begin
	if self.getMyTerminal.getConfig(ValidateColour).Boolean then
		//if self.colour &lt;&gt; null and app.myDutyDocRoot.allVehicleColours[colour] = null then	// PAR #32326
		//	app.raiseCMException1(ERR_INVALID_COLOURCODE, self.colour, "colour", null);			// PAR #32326
		if self.colour &lt;&gt; null then																// PAR #32326
			colours := self.colour.getTokens;													// PAR #32326
			foreach str in colours do															// PAR #32326
				if app.myDutyDocRoot.allVehicleColours[str] = null then							// PAR #32326
					app.raiseCMException1(ERR_INVALID_COLOURCODE, str, "colour", null);			// PAR #32326
				endif;																			// PAR #32326
			endforeach;																			// PAR #32326
		endif;
	endif;
epilog
	delete colours;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCommodity" id="5b4761f5-aecd-46e0-a7db-7c9173e7a06f">
        <updating/>
        <source>verifyCommodity() protected, updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 28 Nov 2024  navma1		MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	loopCommodity,
	commodityObj	 : CM_Commodity;
	commDict 		 : CM_CommodityByCodeDict;
	commCodeUpper,
	commDescUpper	 : String;
	
begin
	
	if self.commodity = null and self.commodityDescription = null then
		self.validateCommodityPlus( null );	//02 Mar 2021	NDL	TFS 50740
		return;
	endif;
	
	commDict 		:= app.myRoot.allCommodities;
	commodityObj 	:= commDict[self.commodity];
	
	if commodityObj = null then
		commodityObj := commDict[self.commodityDescription];
		
		if commodityObj = null then
			if app.myAlternateDict &lt;&gt; null then	//03 Apr 2019	NDL	TFS 44194 - performance
				commodityObj := app.myAlternateDict.getCommodityByDesc( self.commodityDescription );
				if commodityObj &lt;&gt; null then
					self.commodity 			  := commodityObj.code;
					self.commodityDescription := commodityObj.description;
				endif;
			else
				commCodeUpper := self.commodity.toUpper;						//28.11.2024 navma1 #MTN-19124
				commDescUpper := self.commodityDescription.toUpper;				//28.11.2024 navma1 #MTN-19124

				foreach loopCommodity in commDict do
					if loopCommodity.description.toUpper = commDescUpper or 
					   loopCommodity.code.toUpper 		 = commCodeUpper then
					   
						self.commodity 			  := loopCommodity.code;
						self.commodityDescription := loopCommodity.description;
						commodityObj 			  := loopCommodity;
						break;
					endif;
				endforeach; 
			endif;
		endif;
	endif;

	if commodityObj = null then 
		app.raiseCMException2(ERR_FIELD_COMMODITY, self.commodity, ETRow_Commodity, ETRow_Commodity, self); //cnwgb1 PAR 23229 18.3.2010
	else
		self.validateCommodityPlus( commodityObj );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyConsignee" id="f56d3687-83ae-4a22-b63c-6b3ca95343ff">
        <source>verifyConsignee() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 06 Sep 2023	navra1	TFS 60228 EUP | FR 53824 - Consignee / Consignor Validation (Road Manifest)
// 04 Oct 2023	navlw1	CR 60542: EUP | FR Transport Manifest (And CallOff) Consignor/ee To Raise Error When Verification Fails
vars
	loopConsign : CM_ConsigneeConsignor;
	consign 	: CM_ConsigneeConsignor;
	operator 	: CM_Operator;
begin
	if self.consignee = null then
		//navra1 - TFS 60228 - 6th Sep 2023 - start
		operator := app.myRoot.allOperators[self.operatorCode];
		if operator &lt;&gt; null and operator.requiresConsigneeConsignor then
			if self.myEDIData.isTransportManifestRelated() or self.myEDIData.isCallOffRelated() then // #60542
				app.raiseCMException2(OPERATOR_REQUIRES_CONSIGNEE,self.operatorCode,self.id,ETRow_Consignee,self);
			else
				app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGNEE, self.operatorCode,self.id , ETRow_Consignee, self, self);
			endif;	
		endif;
		//navra1 - TFS 60228 - 6th Sep 2023 - end
		return;
	endif;
	
	consign := app.myRoot.allConsigneeConsignors[self.consignee];
	if consign = null then
		if self.myEDIData.isTransportManifestRelated() or self.myEDIData.isCallOffRelated() then // #60542
			app.raiseCMException2(ERR_FIELD_CONSIGNEE,self.consignee,'consignee',ETRow_Consignee,self);
		else
			app.raiseCMWarning2(ERR_FIELD_CONSIGNEE, self.consignee, 'consignee', ETRow_Consignee, self, self);
		endif;
	endif;
	//navra1 - TFS 60228 - 6th Sep 2023 - moved warning to the top
	/*
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator &lt;&gt; null then
		if operator.requiresConsigneeConsignor and
		   self.consignee = null then 
			app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGNEE, self.operatorCode, self.id, ETRow_Consignee, self, self);
		endif;
	endif;
	*/
	
	//07 Sep 2021	NDL	TFS 51928
	self.verifyObjectAvailableForEntry( consign );
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyConsignor" id="502e56ea-f46c-46dd-b381-dedbec745e90">
        <updating/>
        <source>verifyConsignor() protected, updating;
/*
Date		Who		TFS		Reason
---------------------------------------------------------------------------------------------------
02 Feb 2018	jlgrs1	36951	JMT Prenote Partial for GateDoc
03 Jul 2018	jlgrs1	38352	SNO Invalid Consignor
24 Jul 2019	jlgdi1	45733	Set the consignor to blank if invalid consignor is treated as a warning 
							(based on terminal configuration) to allow edi files to be loaded.
06 Sep 2023	navra1	60228   EUP | FR 53824 - Consignee / Consignor Validation (Road Manifest)
04 Oct 2023	navlw1	60542 	EUP | FR Transport Manifest (And CallOff) Consignor/ee To Raise Error When Verification Fails
---------------------------------------------------------------------------------------------------*/
vars
	loopConsign : CM_ConsigneeConsignor;
	consign : CM_ConsigneeConsignor;
	operator : CM_Operator;
begin
	if self.consignor &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors[self.consignor];
		if consign = null then
			if self.getMyTerminal.getConfig(EdiGateDocInvConsignor).Boolean then
				app.raiseCMException2(ERR_FIELD_CONSIGNOR, self.consignor, 'consignor', ETRow_Consignor, self);
			elseif self.isTransportManifestRelated() or self.myEDIData.isCallOffRelated() then // #60542
				app.raiseCMException2(ERR_FIELD_CONSIGNOR, self.consignor, 'consignor', ETRow_Consignor, self);
			else
				// #60542 removed the if statement as no longer needed as its handled above in the elseif
				app.raiseCMWarning2(ERR_FIELD_CONSIGNOR, self.consignor, 'consignor', ETRow_Consignor, self, self);
				self.consignor := "";
			endif;
		endif;
	endif;
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator &lt;&gt; null then
		if operator.requiresConsigneeConsignor and self.consignor = null and self.cargoType &lt;&gt; TI_CargoType_COU then
			if self.isTransportManifestRelated() or self.myEDIData.isCallOffRelated() then // #60542
				app.raiseCMException2(OPERATOR_REQUIRES_CONSIGNOR, self.operatorCode, self.id, ETRow_Consignor, self);
			else
				app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGNOR, self.operatorCode, self.id, ETRow_Consignor, self, self);
			endif;
		endif;
	endif;
	
	//07 Sep 2021	NDL	TFS 51928
	self.verifyObjectAvailableForEntry( consign );
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyContractId" id="f0e75c01-f13b-4594-a223-08181e9bf995">
        <source>verifyContractId() protected;
/*

Purpose:			
		This method validatest the Contract Id entered in the Pre Note.
		
		Use the Operator code entered to get the Debtor, then look up the Contract from the collection in Terminal
		by the Contract Id and Debtor

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navkc1	Initial creation TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
24 Nov 2023 navrv30 #61154: FR | 54089 - EUP - Invoice Contracts - EDI upload for Contract ID
*/

vars
	terminal			: CM_Terminal;
	operator			: CM_Operator;
	debtor				: CM_Debtor;
	allContractsById 	: CM_InvoiceContractByIdDebtor;
	allContractsByTs	: CM_InvoiceContractByToTS;
	contract			: CM_InvoiceContract;
	root				: CM_Root;
	contractIdString,
	operatorCodeString	: String;
	
begin
	
	contractIdString := self.contractIdForTIstring;
	if contractIdString = null then
		return;
	endif;
	
	terminal := self.getMyTerminal();
	if terminal = null then
		return;
	endif;
	
	allContractsById := terminal.allInvoiceContractsById;
	if allContractsById.isEmpty() then
		return;
	endif;
	
	root := app.myRoot;
	if root = null then
		return;
	endif;
	
	operatorCodeString := self.operatorCode;
	operator := root.allOperators[operatorCodeString];
	if operator &lt;&gt; null then
		debtor := operator.debtor;
	endif;
	
	// We have a debtor, look up the Contract using the Debtor
	if debtor &lt;&gt; null then
		contract := allContractsById.getAtKey(contractIdString, debtor);
	// We dont have a debtor, look up the Contract using the current timestamp
	else
		allContractsByTs := terminal.allInvoiceContractsByToTS;
		
		contract := allContractsByTs.getAtKey(app.actualTime());
	endif;
	
	if contract = null then
		if debtor &lt;&gt; null then
			app.raiseCMException2(Contract_not_found_for_debtor, contractIdString, debtor.name, null, self);         //24 Nov 2023 navrv30 #61154
		else
			app.raiseCMException2(Contract_not_found_for_debtor, contractIdString, "Operator/Debtor not defined", null, self);  //24 Nov 2023 navrv30 #61154
		endif;
		return;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCustomsAgent" id="ef1f5598-3edf-46a3-926a-d21f91cec44c">
        <updating/>
        <source>verifyCustomsAgent() protected, updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 28 Nov 2024  navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	loopCustAgent 	  : CM_CustomsAgent;
	custAgent 		  : CM_CustomsAgent;
	customsAgentDict  : CM_CustomsAgentByCodeDict;
	msg 			  : String;
	customsAgentUpper : String;
begin
	
	if self.customsAgent = null then
		return;
	endif;
	
	customsAgentUpper := self.customsAgent.toUpper;									//28.11.2024 navma1 #MTN-19124
	customsAgentDict  := app.myRoot.allCustomsAgents;
	custAgent 		  := customsAgentDict[customsAgentUpper];
	
	if custAgent = null then
		foreach loopCustAgent in customsAgentDict do
			if loopCustAgent.name.toUpper.cnContains(customsAgentUpper) then		//28.11.2024 navma1 #MTN-19124
				self.customsAgent := loopCustAgent.code;
				custAgent 		  := loopCustAgent;
				break;
			endif;
		endforeach;
	endif;
	
	if custAgent = null then
		app.raiseCMWarning3(InvalidCustomsAgent, self.customsAgent, self.id, null, ETRow_CustomsAgent, self, self);
	elseif custAgent.isNotAvailableForEntry then
		msg := ", " &amp; app.getErrorString1(NotAvailableForEntry, "'" &amp; custAgent.name  &amp; "'");
		app.raiseCMWarning3(InvalidCustomsAgent, self.customsAgent, self.id, msg, ETRow_CustomsAgent, self, self);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyHazards" id="e6be02bc-4b9b-4b80-bd5d-7f433d100531">
        <source>verifyHazards() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	tmpHazards : ObjectArray;
	edi : CM_EDITrackedItem;
begin
	//18 Nov 2016	NDL	TFS 2843 / 2604
	foreach edi in self.myAttachedItems where edi.isEDIHazDetails do
		edi.CM_EDIHazDetailsTI.verifySelf();
	endforeach;

	create tmpHazards transient;
	if self.imCodes.isEmpty then
		return;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, true);
epilog
	tmpHazards.purge();
	delete tmpHazards;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyHumidity" id="58ac87d1-1448-47d4-84bd-5a79ddd194d2">
        <source>verifyHumidity() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars

begin
	if self.requiresHumidity and
	   self.getHumidity = NULL_HUMIDITY then
		app.raiseCMWarning1(ERR_OPERATOR_REQUIRES_HUMIDITY, self.operatorCode, 'ventilation', self, self);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyIMEXStatus" id="ac53f093-45ff-4276-a509-00ddcab43df2">
        <updating/>
        <source>verifyIMEXStatus(_terminal : CM_Terminal) protected, updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 01 Oct 2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	loopIMEX : CM_IMEXStatus;
	imex : CM_IMEXStatus;
	imexDict : CM_IMEXStatusByCodeDict;
	mtCommodity : String;
	portDestCode : String;
	upperIMEXStatus : String;
	isoTypeObj : CM_ISOType;		// MTN-36141
	
begin
	if self.imexStatus = null then
		return;
	endif;
	
	imexDict := app.myRoot.allImexStatuses;
	if self.imexStatus.isInteger then
		// if the entered IMEX Status is an integer attempt to match it to the system IMEX Statuses
		imex := imexDict[self.imexStatus.Integer];
	endif;
	
	if imex = null then
		upperIMEXStatus	:= self.imexStatus.toUpper();	// do this once!	// cnwrl1 02/06/2010 PAR 24174
		foreach loopIMEX in imexDict do
			// does the system IMEX Statuses contains the screen entered value.
//			if self.imexStatus.toUpper.cnContains(loopIMEX.description.toUpper) then	// cnwrl1 02/06/2010 PAR 24174 - what it was
			if upperIMEXStatus.cnContains( loopIMEX.description.toUpper ) then
				imex := loopIMEX;
				break;
			endif;
		endforeach;
	endif;
	
	// cnwrl1 02/06/2010 PAR 24174 - start of coding
	if imex = null then
		// Try once last time using the entered imexStatus as the abbreviation.
		foreach loopIMEX in imexDict do
			if upperIMEXStatus = loopIMEX.abbreviation.toUpper then
				self.imexStatus	:= loopIMEX.description;
				imex := loopIMEX;
				break;
			endif;
		endforeach;
	endif;
	// cnwrl1 02/06/2010 PAR 24174 - end of coding
	
	portDestCode := _terminal.getConfig(PortDestCode).String;
	mtCommodity	:= _terminal.getDefaultEmptyCommodity();
	if imex = null then
		//see if we can automatically set it from the load port
//		if self.destinationPort = portDestCode and			// cnwrl1 28/05/2010 PAR 24174 - what it was
		if self.dischargePort = portDestCode and
		   self.commodity &lt;&gt; mtCommodity then
			self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT].description;
		elseif self.loadPort = portDestCode and 
		   self.commodity &lt;&gt; mtCommodity then
			self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
		else
//			app.raiseCMWarning2(ERR_FIELD_IMEX, self.imexStatus, 'IMEX Status', ETRow_ImexStatus, self, self);	// cnwrl1 28/05/2010 PAR 24174 - what it was
			// if the IMEX Status entered cannot be matched then it is an error not a warning - which never get displayed!
			app.raiseCMException2(ERR_FIELD_IMEX, self.imexStatus, 'IMEX Status', ETRow_ImexStatus, self);
		endif;
//	elseif imex.code = TI_IMEX_STATUS_IMPORT and self.destinationPort = null then //set the destination port	// cnwrl1 28/05/2010 PAR 24174 - what it was
//		self.destinationPort := _terminal.getConfig(PortDestCode).String;			// cnwrl1 28/05/2010 PAR 24174 - what it was
	elseif imex.code = TI_IMEX_STATUS_IMPORT and self.dischargePort = null then	//set the discharge port
		self.dischargePort := _terminal.getConfig(PortDestCode).String;
	elseif imex.code = TI_IMEX_STATUS_EXPORT and self.loadPort = null then		//set the load port
		self.loadPort := _terminal.getConfig(PortDestCode).String;
	endif;
	
	if imex &lt;&gt; null and imex.code = TI_IMEX_STATUS_TRANSHIP then
		if not app.myRoot.allowTranshipInterModal and self.messageMode = self.EDI_ACTION_ADD then					// TFS 53083 jlizm1 02/05/2022
			app.raiseCMException(Cannot_create_EDI_Tranship, ETRow_ImexStatus, self);								// TFS #2122
		endif;
	endif;	
	
	// MTN-36141 Default imex status to Storage if we have an ISO type and it's Rotatable
	if self.isoType &lt;&gt; null then
		if self.isISOTypeRotatable(isoTypeObj) then
			self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE].description;
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyISOType" id="b3f4546a-b402-4eff-9869-4df3798c1192">
        <updating/>
        <source>verifyISOType() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
02 Apr 2019	NDL	TFS 44194
14 Oct 2020 cnwma1  Bug 50156: POL-Generator Prenote failing to load as cargo Type defaulting incorrectly
*/

vars
	isoTypeObj  : CM_ISOType;
	cargoType   : CM_CargoType;
begin
	
	cargoType  := self.getCargoTypeObj();  //14.10.2020 cnwma1 #50156
	
	if self.isoType &lt;&gt; null then
		//self.cargoType := TI_CargoType_Container;                                                 //14.10.2020 cnwma1 #50156                 
		//self.cargoTypeDescr := app.myRoot.allCargoTypesById[TI_CargoType_Container].description;	//14.10.2020 cnwma1 #50156
		isoTypeObj := self.getIsoTypeObj();    //14.10.2020 cnwma1 #50156	
	endif;
	
	//14.10.2020 cnwma1 #50156
	if isoTypeObj = null then
		if cargoType &lt;&gt; null then
			if cargoType.isContainer  then
				app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoType, ETRow_IsoType, ETRow_IsoType,  self);
			endif;
		endif;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyId" id="1b42f7cd-2a08-4602-9674-2436b8ac54f9">
        <source>verifyId() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars

begin
	if self.cargoType = TI_CargoType_Container then 
		if (self.id.length &gt; ContainerID_Length) then
			app.raiseCMException2(ContainerIdToLong, id, ContainerID_Length.String, 'id', self);
			return;
		endif;
		// Need to validate the container number check digit.
		//Only for prenotes, edi, create and receive.
		if (not app.checkDigitContainerId(id)) then
			app.raiseCMWarning2(ERR_CONTAINER_NO,  "Container Id", id, 'id', self, self);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyInstructionType" id="c03a3af4-b800-4260-8a09-ae6ec09d275b">
        <source>verifyInstructionType() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/06/2023	navdap1		Initial creation TFS 58813 EUP - manifest Instructions
//
vars
	terminal : CM_Terminal;

begin
	if self.instructionType = null then
		return;
	endif;
	
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null and terminal.allInstructionTypes[self.instructionType] = null then
		app.raiseCMException2(Instruction_type_invalid, self.instructionType, terminal.code, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyOperator" id="d40c92f6-1245-4151-b16c-195483f767ad">
        <updating/>
        <source>verifyOperator() protected, updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 28 Nov 2024  navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	loopOperator  : CM_Operator;
	operator 	  : CM_Operator;
	operatorDict  : CM_OperatorByCodeDict;
	operCodeUpper : String;
begin
	operatorDict := app.myRoot.allOperators;
	operator     := operatorDict[self.operatorCode];
	
	if operator = null then
		
		operCodeUpper := self.operatorCode.toUpper;			//28.11.2024 navma1 #MTN-19124
		
		if app.myAlternateDict &lt;&gt; null then					//03 Apr 2019	NDL	TFS 44194 - performance
			operator := operatorDict[operCodeUpper];		//28.11.2024 navma1 #MTN-19124
			if operator = null then
				operator := app.myAlternateDict.getOperatorByDesc( self.operatorCode );
			endif;
			if operator &lt;&gt; null then
				self.operatorCode := operator.code;
			endif;
		else 
			foreach loopOperator in operatorDict do
				if loopOperator.description.toUpper = operCodeUpper or		//28.11.2024 navma1 #MTN-19124
				   loopOperator.code.toUpper 		= operCodeUpper then	//28.11.2024 navma1 #MTN-19124
					
					self.operatorCode := loopOperator.code;
					operator 		  := loopOperator;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if operator = null then
		app.raiseCMException1(ERR_FIELD_OPERATOR, self.operatorCode, ETRow_OperatorCode, self);
		return;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyParentage" id="822dbb4f-22a7-49d6-84da-0fec07f3aabf">
        <source>verifyParentage(_terminal : CM_Terminal) protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	parentTI : CM_TrackedItem;
	cargoType : CM_CargoType;
	state : Integer;
	ediTI : CM_EDITrackedItem;
begin
	if self.parentCargoID &lt;&gt; null and
	   self.parentCargoType &lt;&gt; null then
		cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(self.parentCargoType);
		if cargoType &lt;&gt; null then
			parentTI := _terminal.lookupTrackedItem(self.parentCargoID, cargoType.id, state, self.voyageCode, false);
		endif;
		if parentTI = null then
			ediTI := self.myEDIData.allEDITrackedItems[self.parentCargoID];
			if ediTI &lt;&gt; null and 
			   ediTI.cargoType &lt;&gt; cargoType.id then
				ediTI := null;
			endif;
		endif;
		if parentTI = null and 
		   ediTI = null then
			// error parent does not exist
			app.raiseCMException2(CargoInvalidParent, self.id, self.parentCargoID, null, self);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyPorts" id="9cec135c-fcef-4ba2-9e7f-11d92374e741">
        <updating/>
        <source>verifyPorts(_terminal : CM_Terminal) protected, updating;
//
// 09 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	portDestCode : String;
	port : CM_Port;
begin
	if self.dischargePort &lt;&gt; null then
		port := app.myRoot.allPorts[self.dischargePort];
		if port = null then
			app.raiseCMException2(ERR_INVALID_DIS_PORT, self.dischargePort, 'discharge port', ETRow_DischargePort, self);
		else
			portDestCode := _terminal.getConfig(PortDestCode).String;
			//special case to auto-resolve imex if blank at this point
			if self.imexStatus = null and self.messageMode &lt;&gt; EDI_ACTION_MODIFY then  			//cnwmc5 - 22 April 2014 - CCMS 2352
				if port.code = portDestCode and self.commodity &lt;&gt; _terminal.getDefaultEmptyCommodity() then
					self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT].description;
				elseif port.code &lt;&gt; portDestCode then
					self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
				endif;	
			endif;
		endif;
	endif;
	
	if self.destinationPort &lt;&gt; null then
		port := app.myRoot.allPorts[self.destinationPort];
		if port = null then
			app.raiseCMWarning2(ERR_FIELD_DESTINATION_PORT, self.destinationPort, 'destination port', ETRow_DestinationPort, self, self);
		endif;
	endif;
	
	if self.loadPort &lt;&gt; null then
		port := app.myRoot.allPorts[self.loadPort];
		if port = null then
			app.raiseCMException2(ERR_FIELD_LOAD_PORT, self.loadPort, 'load port', ETRow_LoadPort,  self);		
		endif;
	endif;
epilog
		
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyProduct" id="49beac2f-8ebc-4896-953b-de93e444b22d">
        <updating/>
        <source>verifyProduct() protected, updating;

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
24 Nov 2021  navma1	Bug 52384: SAL-Error while uploading EDI for CSF activity
06 Dec 2024 navsp1  JIRA 33568 EUP | FR 53824 - Unable to DB Load a Hazardous Manifest (Code 90271)
*/

vars
	loopProduct   : CM_Product;
	productObj    : CM_Product;
	productDict   : CM_ProductByOpCodeProCodeDict;
	cargoTypeObj  : CM_CargoType;
	productStr	  : String;
	ediTI		  : CM_EDITrackedItem;
begin
	if self.product = null and self.cargoType &lt; TI_CargoBOLType_Max then//not user-defined break-bulk type
		return;
	endif;
	
	productStr	 := self.product.toUpper;							//24.11.2021 navma1 #52384
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cargoTypeObj = null then//this would have been raised earlier
		//03 Apr 2019	NDL	TFS 44194
		if app.myAlternateDict &lt;&gt; null then
			productObj := app.myAlternateDict.getProductFromProdCode( self.getMyTerminal(), null, self.product, true, true );
			if productObj &lt;&gt; null then
				self.product  		 := productObj.code;
				self.cargoType		 := productObj.myCargoType.id;
				self.cargoTypeDescr  := productObj.myCargoType.description;
			endif;
		else 
			//24.11.2021 navma1 #52384
			if self.product &lt;&gt; null then
				foreach loopProduct in CM_Product.instances do
					if loopProduct.description.toUpper = productStr or 
					   loopProduct.code.toUpper = productStr then
					
						self.product 	    := loopProduct.code;
						productObj 			:= loopProduct;
						self.cargoType 		:= loopProduct.myCargoType.id;
						self.cargoTypeDescr := loopProduct.myCargoType.description;
						break;
					endif;
				endforeach;
			endif;
		endif;
	else
		if self.product &lt;&gt; null then				//24.11.2021 navma1 #52384
			productDict := cargoTypeObj.allProducts;
			productObj  := productDict[self.operatorCode,self.product];
			
			if productObj = null then
				foreach loopProduct in productDict do
					if loopProduct.description.toUpper = productStr or
					   loopProduct.code.toUpper = productStr then
						
						self.product := loopProduct.code;
						productObj   := loopProduct;
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
		
	if productObj = null then
		//if it's user defined cargotype, MUST have a matching product
		// The following is not always valid e.g. Trailers - I am removing it for PAR 22472 cnwgb1 18.3.2010 Cut day!
		//app.raiseCMException2(ERR_FIELD_PRODUCT, self.product, app.getErrorString(Product), ETRow_ProductCode, self);
	else
		if self.productQuantity = null then
			self.productQuantity := productObj.myQuantity.value;
		endif;
		
		if self.length = null then
			self.length := productObj.getLengthValue();  //myLength.value; //30.1.09 cnwrd1 par #18821 
		endif;
		if self.width = null then
			self.width := productObj.getWidthValue();  //myWidth.value; //30.1.09 cnwrd1 par #18821 
		endif;
		if self.height = null then
			self.height := productObj.getHeightValue();  //myHeight.value; //30.1.09 cnwrd1 par #18821 
		endif; 
		
		if self.volume = null then
			self.volume := productObj.myVolume.value;
		endif;
		if self.weight = null then
			self.weight := productObj.getWeightValue();  //myWeight.value; //30.1.09 cnwrd1 par #18821 
		endif;
		
		foreach ediTI in self.myAttachedItems where ediTI.isKindOf(CM_EDIHazDetailsTI) do		//JIRA 33568
			ediTI.CM_EDIHazDetailsTI.cargoSubType := productObj.code;							//JIRA 33568
		endforeach;																				//JIRA 33568
	endif;
	
	//24.11.2021 navma1 #52384
	if cargoTypeObj &lt;&gt; null and cargoTypeObj.isSubCargoTypeRequired then
		if self.product = null then
			app.raiseCMException1(	ERR_Unspecified_Product,self.id,ETRow_CargoSubType,self);	
		elseif productObj = null then
			app.raiseCMException2(	Cargo_SubType_Not_Found_CType,self.product,	cargoTypeObj.description,ETRow_CargoSubType,self);	
		endif;
	endif;
	//24.11.2021 navma1 #52384
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyRelease" id="90f5b2a7-f109-4c3d-b248-b9c75f6a4e3e">
        <source>verifyRelease() protected;
//
// 28 Nov 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7

//
vars
	theOp : CM_Operator;
begin
	theOp := app.myRoot.allOperators[self.operatorCode];
	if theOp &lt;&gt; null and 
		self.transportMode = TI_TRANSMODE_ROAD_STR and 	// road receipt
		self.getReleaseRequestNumber() = null and
//		self.operatorExportReleaseNumber = null	and 		// no release number entered
		theOp.getRequiresExportOperatorNo and				// release number required
		theOp.getShowOpExportReleaseWarning	then			// they want a warning
		app.raiseCMWarning2(Operat_releas_number_requir_op, theOp.description, self.id, null, null, null);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
