    <JadeMethod name="setupForm" id="cd5d04e7-e728-42c2-a01c-55f80b2e2fd3">
        <updating/>
        <source>setupForm() updating;
vars
begin
	inheritMethod();
	self.isThumbnailVisible := true;//so as to make this false in the following call
	self.hideShowThumbnail();

	self.doSearchYATemplates();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnDeleteTV.enabled:= false;
	endif;
	
end;

</source>
