	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
