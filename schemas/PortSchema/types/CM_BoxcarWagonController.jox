    <JadeMethod name="isThereRoomForTI" id="92854e45-ad12-42b9-8ce3-b294d58454a3">
        <source>isThereRoomForTI(_overHangLC: CM_LocationsController; _control: CMIF_MoveController input; _ti: CM_TrackedItem): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 March 2013		cnwndl1	Initial creation
15 July 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk
04 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	tiWeights : Decimal [16,4];

begin

	if _ti = null then
		return null;
	endif;
	
	if (_ti.getLengthInMetres * 100) &gt; self.myWagon.myWagonClass.internalLength then
		app.raiseCMException(Cargo_dimension_too_big, null, null);
		return app.getErrorString(Cargo_dimension_too_big);
	endif;
	
	if _ti.getActualWidthRaw &gt; self.myWagon.myWagonClass.internalLength then
		app.raiseCMException(Cargo_dimension_too_big, null, null);
		return app.getErrorString(Cargo_dimension_too_big);
	endif;
	
	if _ti.getActualHeightRaw &gt; self.myWagon.myWagonClass.internalLength then
		app.raiseCMException(Cargo_dimension_too_big, null, null);
		return app.getErrorString(Cargo_dimension_too_big);
	endif; 
	
	if _control &lt;&gt; null then
		//02 Feb 2016	NDL	Par 37492
		if _control.weight &lt;&gt; null then
			tiWeights := _control.weight;
			
		elseif _control.isDirectReleaseMove or (_control.myWorkListEntry &lt;&gt; null and _control.myWorkListEntry.isAnyAmount) then	// tfs42863	// TFS 54118
			// in direct release moves and any amount releases can plan a move without splitting the TI, want to
			// verify with the split weight
			if  _control.quantity &gt; 0 and _control.quantity &lt; _ti.totalQuantity then	// tfs42863
				tiWeights := _ti.totalWeight * (_control.quantity/_ti.totalQuantity);	// tfs42863
			endif;
		endif;
	endif;
	
	if tiWeights = null then
		tiWeights := _ti.totalWeight;
	endif;
	
	iter := self.allTrackedItems.createIterator;
	while iter.next( ti ) do
		tiWeights := tiWeights + ti.totalWeight;
	endwhile;
	
	//jlier1 TFS 58104 23/5/23
	if tiWeights &gt; self.myWagon.maxCargoWeight then
		app.raiseCMException(WARN_MAX_LOAD_WEIGHT, null, null);
		return app.getErrorString(WARN_MAX_LOAD_WEIGHT);
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_overHangLC" type="CM_LocationsController"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
