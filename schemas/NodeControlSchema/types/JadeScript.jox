    <JadeMethod name="jhpFileSeek" id="11f2e0eb-37a6-4bca-9a06-531a7a07b1ae">
        <source>jhpFileSeek();
vars
	s,t,u,v,folderName,folderMask,include,exclude:String;
	i,j,k,l,len,firstAvail,highestUsed,fsRootOffset,objRootOffset,soRootOffset:Integer;
	presentationFileSystem,foundSection:Boolean;
	f,g:File; fn:FileNode; ff:FileFolder;
	b:Binary;
begin       
	write "";
	create f;
	f.fileName:="R:\shekc\server\c_system\_userscm.dat";
	f.fileName:="R:\shekc\43936\SysLine.dat";
	f.fileName:="c:\a\bla.tmp";
	f.mode:=File.Mode_Input;
	f.kind:=File.Kind_Binary;
	f.usePresentationFileSystem:=false;
	foreach i in 0 to f.fileLength step 10000 do
		f.seek(i); write f.readBinary(10000).displayLines(f.currentOffset);
	endforeach;
	return;
	
	//f.seek(0); write f.readBinary(1000).displayLines(f.currentOffset);
	f.seek(0); b:=f.readBinary(1000);
	write b[2:4].Integer;
	write b[1:b[2:4].Integer].display;
	firstAvail:=b[33:4].Integer;  // firstAvail
	highestUsed:=b[37:4].Integer;  // highestUsed
	fsRootOffset:=b[45:4].Integer;  // fsRootOffset
	objRootOffset:=b[53:4].Integer;  // objRootOffset
	soRootOffset:=b[65:4].Integer;  // soRootOffset
	
	write objRootOffset;

	f.seek(objRootOffset); len:=f.readBinary(5)[2:4].Integer;
	f.seek(objRootOffset); b:=f.readBinary(len);
	write b.display;
	write b[2:4].Integer;
//	write app.actualTime.Binary.display;
/*	foreach i in 32 to 80 step 4 do
		write b[i+1:4].Integer;  //.String&amp;Tab&amp;b[i+1:4].display[3:end];
	endforeach; /* */
//	write b..displayLines(f.currentOffset);
//	f.seek(73963130); write f.readBinary(4000).displayLines(f.currentOffset);
/*	f.seek(73963200); write f.readBinary(200).displayLines(f.currentOffset);
	f.seek(73963227); write f.readBinary(100).displayLines(f.currentOffset);
	f.seek(73964801); write f.readBinary(200).displayLines(f.currentOffset);
//	f.seek(73964500); write f.readBinary(1000).display; /* */

/*	f.seek(startpos);
	while not f.endOfFile do
		write f.readBinary(160).display;
		l:=l+1;
		if l &gt;= 1 then break; endif;
	endwhile; / * */
epilog
	delete f;
end;</source>
    </JadeMethod>
