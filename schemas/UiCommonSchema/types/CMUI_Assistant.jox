    <JadeMethod name="comboBoxFaultFailureCondition" id="e51acaa8-d0c6-4610-bd5f-023fe69d9ae4">
        <source>comboBoxFaultFailureCondition(_cmb : CMUI_ComboBox input; _failure : String );
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	indx : Integer;
begin
	_cmb.clear;
	_cmb.addItem("");
	_cmb.addItem(AuditStringValue_Yes);
	_cmb.addItem(AuditStringValue_No);
	if _failure = AuditStringValue_Yes then
		indx:=2;
	elseif _failure = AuditStringValue_No then
		indx:=3;
	endif;
