    <JadeMethod name="createVesselVoyage" id="0304dd87-e83e-45b3-aa40-fc3e1196d875">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	voyage1 := self.getVoyage(null);
	if voyage1 &lt;&gt; null then
		self.loadAllJobsToOps(voyage1, false);
	endif;
	deleteVoyage("UTGCBISH1");
	deleteVessel("UTGCBISHOP");
	
	vessel := self.addVesselLOLOholdsRORO("UTGCBISHOP", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage1:=self.addVoyageWithConRORO("UTGCBISH1", "UTGCBISHOP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage1;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="tMoveCargoToWharehouse" id="c9f6af4e-1611-4db8-a674-efa5a0e18acc">
        <source>tMoveCargoToWharehouse();
// cnwndl1
//17 September 2008	cnwdw1	
//
vars
	wh: CM_IrregularBlockArea;
	cargo: CM_Cargo;
	product: CM_Product;
begin
	deleteCargo("UTCARGO00001", self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	deleteProduct("UT MDF 12mm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	
	product := addProduct("UT MDF 12mm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	
	self.assertNotNullMsg( wh, 'The Warehouse' );
	
	cargo := self.addCargoAtLocation("UTCARGO00001", product, product.myOperator, wh.allLocationsControllers.first).CM_Cargo;
	assertLocationHasTI(wh.allLocationsControllers.first, cargo);

end;</source>
    </JadeMethod>
    <JadeMethod name="tWareHouseHazSegregation" id="432fcade-d54c-439d-b46c-347956ca1b16">
        <source>tWareHouseHazSegregation();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

constants

	GCAREA = "HAZWH1";
	ConditionCode = "UTWHSEG";
	TiId1 = "WHHZ0011001";
	TiId2 = "WHHZ0011002";
	TiId3 = "WHHZ0012003";
	
vars

	gcArea : CM_IrregularBlockArea;
	haz11 : CM_HazardClass;
	haz12 : CM_HazardClass;
	pxySegCond : CM_SegregationCondition;
	realSegCond : CM_SegregationCondition;
	segMatrixAgent : CMIF_SegregationMatrixAgent;
	segMatrixTrx : CM_SegregationMatrixTrans;
	pxySegRule1 : CM_SegregationRule;
	pxySegRule2 : CM_SegregationRule;
	terminal : CM_Terminal;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	oper : CM_Operator;
	rack1 : CM_IrregularBlockController;
	rack2 : CM_IrregularBlockController;
	shelf11 : CM_RackShelfController;
	shelf12 : CM_RackShelfController;
	shelf21 : CM_RackShelfController;
	shelf22 : CM_RackShelfController;
	
begin

	terminal := self.getTerminal;
	self.assertTrueMsg(terminal &lt;&gt; null, "failed to find terminal - in setup");
	haz11 := app.myRoot.allHazardClasses.getAtKey("1.1");
	self.assertTrueMsg(haz11 &lt;&gt; null, "failed to find Hazard 1.1 - in setup");
	haz12 := app.myRoot.allHazardClasses.getAtKey("1.2");
	self.assertTrueMsg(haz12 &lt;&gt; null, "failed to find Hazard 1.2 - in setup");
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg(oper &lt;&gt; null, "failed to find Operator - in setup");

	//cleanup, in case we failed last time
	self.deleteContainer( TiId1 );
	self.deleteContainer( TiId2 );
	self.deleteContainer( TiId3 );
	self.deleteTerminalArea(GCAREA);
	realSegCond	:= terminal.allSegregationConditions[Segregation_Type_Warehouse, ConditionCode];
	if realSegCond &lt;&gt; null then
		app.myTrxDA.trxDeleteSegregationCond( realSegCond, app.myPassport);
		self.assertTrueMsg(app.myPassport.noErrors, "failed to delete pre-existing Warehouse Segregation rules - in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	endif;
	
	//create warehouse and racks and shelves
	gcArea := self.addGeneralCargoArea(GCAREA,
									   "UT Hazard Seg Warehouse",
									   10,
									   10,
									   10,
									   null,
									   null);
	self.assertTrueMsg(gcArea &lt;&gt; null, "failed to create Warehouse - in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
									   
	rack1 := self.addGCRackOrGround(gcArea,3,4,3,4,"RK1");
	self.assertTrueMsg(rack1 &lt;&gt; null, "failed to create Rack 1 - in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	shelf11 := self.addGCShelf(rack1, 1, "01", 5, 30000, null);
	self.assertTrueMsg(shelf11 &lt;&gt; null, "failed to create Shelf 1 in Rack 1- in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	shelf12 := self.addGCShelf(rack1, 2, "02", 5, 30000, null);
	self.assertTrueMsg(shelf12 &lt;&gt; null, "failed to create Shelf 2 in Rack 1- in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	rack2 := self.addGCRackOrGround(gcArea,7,4,7,4,"RK2");
	self.assertTrueMsg(rack2 &lt;&gt; null, "failed to create Rack 2 - in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	shelf21 := self.addGCShelf(rack2, 1, "01", 5, 30000, null);
	self.assertTrueMsg(shelf21 &lt;&gt; null, "failed to create Shelf 1 in Rack 2- in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	shelf22 := self.addGCShelf(rack2, 2, "02", 5, 30000, null);
	self.assertTrueMsg(shelf22 &lt;&gt; null, "failed to create Shelf 2 in Rack 2- in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
	//Set up hazard segregation rules for Warehouse locations
	create pxySegCond as app.getSegCondClassForType(Segregation_Type_Warehouse) transient;
	pxySegCond.setProxy(ConditionCode, "Isolate From", 1005687, true, false, 0, 0, 0);
	app.myTrxCA.trxCreateSegregationCond(pxySegCond, realSegCond, app.myPassport);
	self.assertTrueMsg(realSegCond &lt;&gt; null, "failed to create Warehouse Segregation Condition - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxySegCond;
	
	create segMatrixAgent transient;
	segMatrixAgent.ruleType := Segregation_Type_Warehouse;
	
	create pxySegRule1 transient;
	pxySegRule1.setProxy(	haz12,	//_entity1, 
							haz11,	//_entity2 		: CM_Object;
							realSegCond,	//_segCondition 	: CM_SegregationCondition;
							terminal	//_terminal 		: CM_Terminal
							);
	
	create segMatrixTrx transient;
	segMatrixTrx.col := 4;
	segMatrixTrx.row := 4;
	segMatrixTrx.myEntity1 := haz12;
	segMatrixTrx.myEntity2 := haz11;
	segMatrixTrx.myPxySegregationRule := pxySegRule1;
	segMatrixTrx.mySegregationRule := null;
	segMatrixTrx.mySegregationMatrixAgent := segMatrixAgent;
	
	create pxySegRule2 transient;
	pxySegRule2.setProxy(	haz11,	//_entity1, 
							haz12,	//_entity2 		: CM_Object;
							realSegCond,	//_segCondition 	: CM_SegregationCondition;
							terminal	//_terminal 		: CM_Terminal
							);
	
	create segMatrixTrx transient;
	segMatrixTrx.col := 5;
	segMatrixTrx.row := 3;
	segMatrixTrx.myEntity1 := haz11;
	segMatrixTrx.myEntity2 := haz12;
	segMatrixTrx.myPxySegregationRule := pxySegRule2;
	segMatrixTrx.mySegregationRule := null;
	segMatrixTrx.mySegregationMatrixAgent := segMatrixAgent;
	
	app.myTrxUA.trxUpdateSegMatrix(segMatrixAgent, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "failed to update Segregation Matrix (Test 1)- " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	
	// Create cargo with hazards
	self.opts.purge;
	self.opts.addAssoc("Hazard", "1.1");
	self.opts.addAssoc("HazardDescription", "Explosives");
	ti1 := self.addContainerOpts (TiId1, "2200", "MT", oper);
	self.assertTrueMsg(ti1 &lt;&gt; null, "failed to create " &amp; TiId1 &amp; " in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti1.allTIHazards.includesHazard(haz11), TiId1 &amp; " does not have hazard 1.1 in setup");
	
	ti2 := self.addContainerOpts (TiId2, "2200", "MT", oper);
	self.assertTrueMsg(ti2 &lt;&gt; null, "failed to create " &amp; TiId2 &amp; " in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti2.allTIHazards.includesHazard(haz11), TiId2 &amp; " does not have hazard 1.1 in setup");
	
	self.opts.purge;
	self.opts.addAssoc("Hazard", "1.2");
	self.opts.addAssoc("HazardDescription", "Explosives");
	ti3 := self.addContainerOpts (TiId3, "2200", "MT", oper);
	self.assertTrueMsg(ti3 &lt;&gt; null, "failed to create " &amp; TiId3 &amp; " in setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti3.allTIHazards.includesHazard(haz12), TiId3 &amp; " does not have hazard 1.1 in setup");
	
	// move cargo to warehouse, attempt moves to prove the segrgation rules
	
	self.opts.purge;
	self.move( ti1, shelf11 );	
	self.assertTrueMsg( ti1.myPrimaryActualLocation = shelf11, "Move of " &amp; ti1.id &amp; " to Rack 1 Shelf 1 failed.");
	
	self.move( ti2, shelf21 );	// should be OK in the same warehouse.
	self.assertTrueMsg( ti2.myPrimaryActualLocation = shelf21, "Move of " &amp; ti2.id &amp; " to Rack 2 Shelf 1 failed.");
	
	self.move( ti2, shelf12 );	// should be OK on the same rack, both the same type.
	self.assertTrueMsg( ti2.myPrimaryActualLocation = shelf12, "Move of " &amp; ti2.id &amp; " to Rack 1 Shelf 2 failed.");
	
	self.move( ti2, shelf11 );	// should be OK on the same shelf , both the same type.
	self.assertTrueMsg( ti2.myPrimaryActualLocation = shelf11, "Move of " &amp; ti2.id &amp; " to Rack 1 Shelf 1 failed.");
	
	self.assertTrueMsg( rack1.allHazardousTIs.size = 2, "Rack 1 should have 2 items in the Hazardous Tis collection.");
	
	self.opts.addAssoc("ExpectErrors", true);
	self.move( ti3, shelf11 );	//should fail, can't mix 1.1 and 1.2 in the same shelf.
	self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Hazard_seg_location), "Should have and error 85859 for Hazard Segregation");
	
	self.move( ti3, shelf12 );	//should fail, can't mix 1.1 and 1.2 in the same rack.
	self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Hazard_seg_location), "Should have and error 85859 for Hazard Segregation");
	
	self.opts.purge;
	self.move( ti3, shelf21 );	//should be OK, to mix 1.1 and 1.2 in the same warehouse IF different racks.
	self.assertTrueMsg( ti3.myPrimaryActualLocation = shelf21, "Move of " &amp; ti3.id &amp; " to Rack 2 Shelf 1 failed.");
	
	self.assertTrueMsg( rack2.allHazardousTIs.size = 1, "Rack 2 should have 1 item in the Hazardous Tis collection.");
	
	
	//We have been successful, clean up the data.
	self.deleteContainer( TiId1 );
	self.deleteContainer( TiId2 );
	self.deleteContainer( TiId3 );
	self.deleteTerminalArea(GCAREA);
	app.myTrxDA.trxDeleteSegregationCond( realSegCond, app.myPassport);

epilog

	delete pxySegCond;
	delete segMatrixAgent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uRackingTest1" id="e347d83d-31d6-4769-8225-5158ced1879c">
        <updating/>
        <source>uRackingTest1() updating;
/*
Purpose:			
Date		Who		Reason
20 September 2013	NAVAB1	Initial creation
*/

vars
	gcArea : CM_IrregularBlockArea;
	gcRack : CM_IrregularBlockController;
	gcShelf : CM_RackShelfController;
	gcICA : CM_InterchangeArea;
	label, idx : Integer;
	row, rowSt, rowEnd : Integer;
	col, colSt, colEnd : Integer;
	tiID : String;
	bs : CM_BlockStack;
	ya : CM_YardAllocation;
	locations : CM_LCArray;
	voy : CM_Voyage;
begin

	// ### VOYAGE
	voy := createVesselVoyage(null,null,null);
	
	// ### BS CARGO
	self.opts.addAssoc(UTTI_VoyageCode, voy.code);
	deleteTerminalArea("UTGCBISH");
	bs:= addBlockStack("UTGCBISH", 1000, null);
	idx := 0;
	foreach idx in 1 to 30 discreteLock do
//		tiID := gcArea.id &amp; gcRack.ident &amp; gcShelf.ident &amp; idx.String;
		tiID := "GCBISHBARRELL" &amp; idx.String;
		self.addCargoLocation("BARRELS", tiID, TI_IMEX_STATUS_STORAGE, 200, 15000,bs.myLocationsController);
	endforeach;

	
	// ### RACKING AREA
	rowEnd := 20;
	colEnd := 20;
	rowSt := 1;
	colSt := 1;
	create locations transient;
	gcICA := self.addInterchangeArea("GCICA1", null);
	
	gcArea := self.addGeneralCargoArea("GCBISH", "", rowEnd,colEnd,1, null, null);
	
	foreach row in rowSt to rowEnd discreteLock do
		foreach col in colSt to colEnd discreteLock do
			label := label + 1;
			gcRack := self.addGCRackOrGround(gcArea, row,col,row,col,"R" &amp; label.String);
			self.addGCShelf(gcRack, 1, "01", 5, 30000, gcICA);
			self.addGCShelf(gcRack, 2, "02", 5, 30000, gcICA);
			gcShelf := self.addGCShelf(gcRack, 3, "03", 5, 30000, gcICA );
			
			locations.add(gcShelf);
		endforeach;
	endforeach;
	
	// ### YARD ALLOCATION

	ya := self.addYA("UTGCBISH", 
		YACriteriaType_CargoType, "BARRELS", 
		YACriteriaType_Voyage, voy.code,
		null,null,
		locations, null);
	self.assertNotNull(ya);
	
	autoplanTIs(bs.myLocationsController.allTrackedItems);
	
epilog
delete locations;
end;</source>
    </JadeMethod>
</Class>
