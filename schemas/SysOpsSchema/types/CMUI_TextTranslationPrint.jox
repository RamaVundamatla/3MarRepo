        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="addTableDetails" id="3037466b-97fc-4795-ac9b-72d74790ca4e">
        <source>addTableDetails(translatableText : XLAT_TranslatableText);

vars
	translation : XLAT_Translation;
begin
	translation := translatableText.allTextByLocale[myLocale.localeId];
	if translation = null then
		return;
	endif;

	// try adding a row and see if it fits on the page
	if not app.printer.frameFits(fraDetail) then
		app.printer.newPage;
		printTableHeader;
	endif;

	if isDeveloperMode then
		tableDetail.setCellText(1,1,translatableText.myGlobalConstant.name &amp; Tab&amp; translatableText.number.String &amp; Tab &amp; translation.text);
	else
		tableDetail.setCellText(1,1,translation.text);
	endif;
	app.printer.print(fraDetail);

//	fraDetail.height := tableDetail.height + tableDetail.defaultRowHeight;
	//tableDetail.height := tableDetail.height + tableDetail.defaultRowHeight;
//	fraDetail.height := tableDetail.height;
end;
</source>
        <Parameter name="translatableText" type="XLAT_TranslatableText"/>
    </JadeMethod>
    <JadeMethod name="initReportForLandscape" id="e38ef3c4-2383-4254-acd6-e48be6b4d051">
        <updating/>
        <source>initReportForLandscape(_isDeveloperMode : Boolean; _locale : CM_Locale) updating;
//--------------------------------------------------
// Created:	29 March 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	portteclogo.picture := app.getPicLogoProduct();
	picLogo.picture := app.getPicLogoPort();
	picLogo.move((940-picLogo.width),picLogo.top, picLogo.width, picLogo.height);
	isDeveloperMode := _isDeveloperMode;
	myLocale := _locale;
end;</source>
        <Parameter name="_isDeveloperMode" type="Boolean"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="initTableDetails" id="a66dced2-cdba-44d3-8404-922346fd6c24">
        <source>initTableDetails();

vars

begin
	tableDetail.rows := 1;
	tableDetail.fixedColumns := 0;
	tableDetail.fixedRows := 1;
	if isDeveloperMode then
		tableDetail.columns := 3;
	else
		tableDetail.columns := 1;
	endif;
	tableDetail.accessColumn(tableDetail.columns).wordWrap := true;
	printTableHeader;
end;
</source>
    </JadeMethod>
    <JadeMethod name="printHeader" id="58f86ef9-b81c-4cd3-af8a-81737827ea1c">
        <source>printHeader(category : XLAT_Category);

vars

begin
	fraHeader.caption := category.constantCategoryDescription;
	zPrintFrame(fraHeader);
	initTableDetails;
	
end;
</source>
        <Parameter name="category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="printTableHeader" id="0af48f1e-acbd-49a1-8c07-48e0c24dd9fa">
        <source>printTableHeader();

vars

begin
	tableDetail.fixedRows := 1;
	if isDeveloperMode then
		tableDetail.setCellText(1,1,'Constant	Value	Text');
		tableDetail.columnWidth[1] := 130;
		tableDetail.columnWidth[2] := 50;
		tableDetail.columnWidth[3] := tableDetail.width.Integer - 180;
		tableDetail.accessColumn(2).alignment := Table.Alignment_Center;
	else
		tableDetail.setCellText(1,1,'Text');
		tableDetail.columnWidth[1] := tableDetail.width.Integer;
	endif;
	app.printer.print(fraDetail);
	tableDetail.fixedRows := 0;

end;
</source>
    </JadeMethod>
    <JadeMethod name="zPrintFrame" id="0f2f293f-0666-4ec5-9d7f-da12d2e8de00">
        <source>zPrintFrame(f:Frame input);

vars

begin
	if not app.printer.frameFits(f) then
		app.printer.newPage;
	endif;
	
	app.printer.print(f);

end;
</source>
        <Parameter name="f" type="Frame" usage="input"/>
    </JadeMethod>
</GUIClass>
