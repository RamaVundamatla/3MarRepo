//
// ---------------------------------------------------------------------------

vars
	theColumn : Integer;
begin

	theColumn := self.tblData.getColumnByRowName(ETRow_TrainPosition);
	if theColumn &lt;&gt; 0 then
		self.tblData.resortTableByColumn(theColumn);
		self.tblData.accessCell(1,theColumn).fontBold := true;
	endif;
	
	self.buildComboPosition(null);
	if self.cmbAreas.listObject &lt;&gt; null then
		self.buildComboPosition(self.cmbAreas.listObject.CM_Rail);
	endif;

	self.frmConfirmIN.zOrder(1);
	self.frmConfirmIN.visible := true;
	self.frmConfirmIN.centreHorizontallyInParent();
	self.frmConfirmIN.top := 100;
	self.txtWagonRange.text := null;
epilog

end;</source>
