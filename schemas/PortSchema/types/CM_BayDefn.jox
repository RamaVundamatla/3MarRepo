// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.myVesselCellular.useBayCellTierNumbering;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1d726e53-e2a7-4eb0-bc5f-2ad5643bfe0c">
        <source>validateForCreate(_realVessel : CM_CellularVesselStructure);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	isInsert : Boolean;
	realBay : CM_Bay;
begin
	realBay := _realVessel.allBaysByLabel[self.id];
	if realBay &lt;&gt; null then
		// if the real bay has no proxy then the proxy was deleted during edit and we are in here cos the user recreated a bay with the same ID
		isInsert := (realBay.pxyGetProxyObject = null and self.pxyGetRealObject = null);
		
		if not isInsert then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.id, null, null); // AKB2004MAR removed because of delete and insert .
		endif;
	endif;

	self.validateMe;
end;</source>
        <Parameter name="_realVessel" type="CM_CellularVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f1cb45ad-6cdd-480b-b6be-f6e370e87963">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	inheritMethod();

	if app.myPassport.hasErrors then
		return;
	endif;

	self.checkBaySet();
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
