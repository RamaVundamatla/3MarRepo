    <JadeMethod name="doDisconnectPower" id="783c90e9-3425-4966-9fd5-2a649a0a4031">
        <source>doDisconnectPower(_ti : CM_TrackedItem input)  protected;
/*

Date		Who		Reason
23 April 2015	cnwer1	Initial creation PAR 36103

*/

vars
	result : Integer;
	tiId	: String;
begin
	
	if _ti &lt;&gt; null then
		tiId:=_ti.id;
	endif;
	
	result:=app.msgBox(app.getErrorString1(Machine_disconnect_power,tiId),"Disconnect from power",MsgBox_Yes_No);
	if result = MsgBox_Return_No then
		app.setAckTIConnectError(true);
	else
		if _ti &lt;&gt; null then
			app.myMobileAgent.updateTIConnection(_ti,false,false,null);
		endif;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
