    <JadeMethod name="setMyVoyage" id="496c4558-6cc0-4b52-8ddb-a71276ff8642">
        <updating/>
        <source>setMyVoyage( _voyage: CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

begin

	self.myVessel := null;
	self.myVoyage := _voyage;
	
	

epilog

end;</source>
