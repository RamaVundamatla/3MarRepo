    <JadeMethod name="createProperties" id="2b24f6b3-b08c-41e4-bf9d-c4ce6649511d">
        <source>createProperties();
/* ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 02/12/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
// 24/09/2018	jlgka1		TFS #40200 Change the tmpProp to use class property instead
							of hardcoded name.
// ---------------------------------------------------------------------------*/
vars
	tmpProp		: CM_QueryProperty;
begin
	inheritMethod();
	
	create tmpProp as CM_QBolTypeProperty persistent;
	tmpProp.set('Docket Type', CM_BOL::bolType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrCarrierProperty persistent;
	tmpProp.set('Carrier', CM_BOL::carrierCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStrPortProperty persistent;
	tmpProp.set('Destination', CM_BOL::destinationPort.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStrPortProperty persistent;
	tmpProp.set('Discharge Port', CM_BOL::dischargePort.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Handling Contractor Code 1', CM_BOL::handlingContractor1Code.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Handling Contractor Code 2', CM_BOL::handlingContractor2Code.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Handling Sub Contractor Code', CM_BOL::handlingSubContractor1Code.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Has Comments', CM_BOL::hasComments.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Docket Number', CM_BOL::number.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Date', CM_BOL::dateTime.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Inwards Docket', CM_BOL::isInward.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QRefLogSpeciesProperty persistent;
	tmpProp.set('Log Species', CM_BOL::myLogSpecies.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QRefLogGradeProperty persistent;
	tmpProp.set('Log Grade', CM_BOL::myLogGrade.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	
	
	create tmpProp as CM_QRefLogTypeProperty persistent;
	tmpProp.set('Log Type', CM_BOL::myLogType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
		
	create tmpProp as CM_QRefLogTreatmentProperty persistent;
	tmpProp.set('Log Treatment', CM_BOL::myLogTreatment.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	
	
	create tmpProp as CM_QRefLogLengthProperty persistent;
	tmpProp.set('Log Length', CM_BOL::myLogLength.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Match Time', CM_BOL::matchTime.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QRefOperatorProperty persistent;
	tmpProp.set('Operator', CM_BOL::myOperator.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Reference Date', CM_BOL::referenceDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Remarks', CM_BOL::remarks.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	

	create tmpProp as CM_QTransportModeProperty persistent;
	tmpProp.set('Transport Mode', CM_BOL::transportMode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);	
	
	create tmpProp as CM_QStringProperty persistent;					// PAR #33019
	tmpProp.set('Service Order #', CM_BOL::clientRef1.name, self.className);		// PAR #33019
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);								// PAR #33019
																		// PAR #33019
	create tmpProp as CM_QStringProperty persistent;					// PAR #33019
	tmpProp.set('PO #', CM_BOL::clientRef2.name, self.className);					// PAR #33019
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);								// PAR #33019
	
	//epr TFS 47132 18/12/19
	create tmpProp as CM_QRefSubTerminalProperty persistent;
	tmpProp.set('Sub-Terminal', CM_BOL::mySubTerminal.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(tmpProp);
	
	//epr TFS 47132 18/12/19
	create tmpProp as CM_QStrVoyageProperty persistent;
	tmpProp.set('Voyage', CM_BOL::getVoyageCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(tmpProp);

end;</source>
    </JadeMethod>
    <JadeMethod name="isBOLType" id="13aabce4-1586-45b0-987a-adb53ce252b6">
        <source>isBOLType() : Boolean;
/* ---------------------------------------------------------------------------
Created:     21 January 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
