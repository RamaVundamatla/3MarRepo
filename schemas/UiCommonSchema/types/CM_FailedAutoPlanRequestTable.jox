            <optionsList>
                <value>0 - None</value>
                <value>1 - Horizontal</value>
                <value>2 - Vertical</value>
                <value>3 - Both</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="securityLevelEnabled">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="securityLevelVisible">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="selectMode">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - Default</value>
                <value>1 - FixedRows</value>
                <value>2 - FixedColumns</value>
                <value>3 - Multiple cells</value>
                <value>4 - Row</value>
                <value>5 - Column</value>
                <value>6 - Single</value>
                <value>7 - None</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="sheets">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="show3D">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - use application default</value>
                <value>1 - Not 3D</value>
                <value>2 - Use 3D</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="showFocus">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="skinCategoryName">
            <cntrlType>string</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="stretch">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Cell</value>
                <value>2 - None, Picture First</value>
                <value>3 - Cell, Picture first</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="stretchHeight">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="stretchToParent">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="stretchWidth">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="tabActiveColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="tabInactiveColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="tabIndex">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="tabKey">
            <cntrlType>signed-integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="tabStop">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="tag">
            <cntrlType>string</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="top">
            <cntrlType>signed-integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="visible">
            <cntrlType>boolean</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="width">
            <cntrlType>signed-integer</cntrlType>
        </DevControlProperties>
    </DevControlTypes>
</GUIClass>
