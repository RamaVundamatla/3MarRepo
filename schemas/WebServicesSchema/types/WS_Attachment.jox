<Class name="WS_Attachment" id="32401de6-b7ec-49e6-9f9c-8e1d74725942">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Child cargo. This is a single child item that is attached to a parent cargo item.</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="cargoType" id="4c623460-c37b-4093-87a5-a23af7428415">
        <embedded/>
        <type name="WS_CargoType"/>
        <access>readonly</access>
        <text>Cargo type of the child cargo item.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="idTextBox" id="9429362c-6587-4493-af0b-07aec59a16d3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Id of the child cargo item.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="isoType" id="76f54240-0d4d-41a0-9d6e-e2f8936ef5d8">
        <embedded/>
        <type name="WS_ISOType"/>
        <access>readonly</access>
        <text>ISO Type of the child cargo item.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="productType" id="0930c248-9d47-4b0d-999d-477354cb6916">
        <embedded/>
        <type name="WS_Product"/>
        <access>readonly</access>
        <text>Attachment Cargo sub type </text>
    </ImplicitInverseRef>
    <PrimAttribute name="weightTotal" id="ef0c2941-9a76-4aca-a3ea-776606ee2056">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Total weight of the child cargo item.</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="088c94ec-0c05-4e85-ab81-8e19401ef037">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	delete self.cargoType;
	delete self.isoType;
	delete self.productType; //epr TFS 7521 10/11/17
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="2e03f08c-4073-418c-bb07-205a6f1ae464">
        <updating/>
        <source>setProxyFromObject(_object: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2009	#cnwdz2	 

*/

vars
	isoTypeStr	: String;
	isoType		: CM_ISOType;
	product		: CM_Product;
begin
	inheritMethod(_object);
	
	if _object.myCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(_object.myCargoType);
	endif;
	
	isoTypeStr := _object.getISOType();
	if isoTypeStr &lt;&gt; null then
		isoType := app.myRoot.allISOTypes.getAtKey(isoTypeStr);
		if isoType &lt;&gt; null then
			create self.isoType transient;
			self.isoType.setProxyFromObject(isoType);
		endif;
	endif;
	
	//cnwmc5 - 19 Feb 2015 - PAR 34346
	product := _object.myProduct;
	if product &lt;&gt; null then
		create self.productType transient;
		self.productType.setProxyFromObject(product);
		delete self.isoType;
	endif;
	
	self.idTextBox := _object.id;
	
	//self.weightTotal := _object.totalWeight.asStringWeightJMT();	//+cnwml2 MSL CCMS 1017
	self.weightTotal := _object.totalWeight.asStringWeightForWebInterface();	//26 Oct 2012	NDL	Par 30622

	epilog

end;</source>
        <Parameter name="_object" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
