    <JadeMethod name="eprTestMachineSetdown" id="cc24bc3e-4c18-43c8-a7e8-c5430d71a20d">
        <source>eprTestMachineSetdown();
/*

Date		Who		Reason
24 May 2017	cnwer1	Initial creation TFS

*/

vars
	setdownRequest : WS_MachineSetdownTaskRequest;
	queryReqService : JMTUserInterfaceService;
	setdownResponse : WS_MachineStatusResponse;
	machine : CM_Machine;
		task,
	twinTask : CM_RTQueueTask;
begin
	app.initialize;
	
	create setdownRequest transient;
	setdownRequest.taskOid:="2832.7055514";
	setdownRequest.setdownLocation:="CHAS1122331";
	task := setdownRequest.taskOid.asOid.CM_RTQueueTask;
	
	machine:="2296.464".asOid.CM_Machine;
	app.myPassport.setMyUser(machine.user);
	app.myPassport.setMyTerminal(machine.getMyTerminal);
	app.myPassport.setWarningsIgnored(true); 
	app.myPassport.warningsAcknowledged := true;
	app.myTrxUA.trxMachineSetdownTask(machine,task,twinTask,setdownRequest.setdownLocation,setdownRequest.twinSetdownLocation,setdownRequest.overrideToInterchange, setdownRequest.isSwap,null,null, app.myPassport);
	
	

epilog
	delete setdownResponse;
	delete setdownRequest;
	delete queryReqService;

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestMultiIdSearch" id="75fffe76-a735-4278-abf1-de280eeb2998">
        <source>eprTestMultiIdSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2017	jlger1	Initial creation

*/

vars
	wsQueryRequest : WS_TrackedItemQueryRequest;
tiArray : CM_TIArray;
	enqController 	: CM_EnqControllerTI;
	webServiceAgent		: WS_WebServiceAgent;
	qDef			: CM_QueryDefinition;
	strArr			: StringArray;
	noDupArray : CM_TIArray;
	iter : Iterator;
	obj : Object;
	
begin
	create wsQueryRequest transient;
	//wsQueryRequest.setPropertyValue("filterId","EPR03061607");
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,"5");
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterVoyage.name,"BHOLD3");
//	wsQueryRequest.setPropertyValue("context",0);	
//	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterDisconnectedOnly.name,false);
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::doFilterVoyageRequiresJob.name,true);
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterVoyageRequiresJob.name,false);
/*	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterHidePackeditems.name,false);
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterIMEX.name,TI_IMEX_STATUS_IMPORT.String);
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterReeferOnly.name,false);
	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterReeferOnly.name,false);*/
//	wsQueryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterLoadJob.name,"2271.399540");
	//create strArr transient;
	//strArr.add("1");
	//strArr.add("2");
	//strArr.copy(wsQueryRequest.filterAvailabilityGrades);//setPropertyValue("filterAvailabilityGrades",strArr);*/
	app.initialize;
	app.myPassport.setMyUserFromCode("JLGER1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);
	
	
	create enqController transient;
		delete webServiceAgent;
		create webServiceAgent transient;
	
		//setup the query from the request
		webServiceAgent.setupTiSelectorQuery( wsQueryRequest,false, enqController, qDef );
		//	webServiceAgent.doUpdateCriteriaLine(  qDef, enqController.myCriteriaLineHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NOTIFIED );
	
		enqController.doQuery( qDef );
		write enqController.allObjects.size;
		
		enqController.allObjects.inspectModal;
		iter:=enqController.allObjects.createIterator;
		while iter.next(obj) do
			write obj.CM_TrackedItem.id;
		endwhile;
		//create noDupArray transient;											//cnwmc5 - 5 Feb 2015 - PAR 35615
	//	enqController.allObjects.CM_TIArray.copyNoDuplicates(noDupArray);		
	//create tiArray transient;
	//wsQueryRequest.doMulitIdExactSearch(tiArray);
	
	//write noDupArray.size;
	
	delete tiArray;
	delete wsQueryRequest;
	delete strArr;
	
epilog
	delete webServiceAgent;
	if enqController &lt;&gt; null then
		if enqController.myCriteriaLineHolder &lt;&gt; null then
			delete enqController.myCriteriaLineHolder;
		endif;
	endif;
	delete enqController;
	delete noDupArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestPutCargoLoadRelease" id="3512d53a-2d3c-4fa9-832f-71eaacd11f88">
        <source>eprTestPutCargoLoadRelease();
/*

