    <JadeMethod name="isNotSuitableForTranshipDelete" id="2272e531-e6ef-4aae-b507-13f24140645b">
        <source>isNotSuitableForTranshipDelete(): Boolean;
begin
	return type = TRANS_TYPE_CREATED 
			or	type = TRANS_TYPE_REC_SHIP
			
			or 	type = TRANS_TYPE_REC_ST_DEPOT_SHIP			// CCMS 1875
			or 	type = TRANS_TYPE_REC_ST_WHOUSE_SHIP		// CCMS 1875
			or 	type = TRANS_TYPE_REC_ST_MARINE_SHIP		// CCMS 1875
			
			or	type = TRANS_TYPE_STOPCLEAR
			or	type = TRANS_TYPE_STOPSET
			or	type = TRANS_TYPE_STOPCANCEL				// cnwdad1 04/06/2010 - CCMS 1129.
			or	type = TRANS_TYPE_STOPOVERRIDE				// cnwrl1 24/08/2010 PAR 23697
			or	type = TRANS_TYPE_TASKADD
			or	type = TRANS_TYPE_TASKCOMPLETE
			or	type = TRANS_TYPE_TODOTASK;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
