    <JadeMethod name="reloadDataTable" id="3c03690d-6ce0-4b08-beb4-ef6ea23666fe">
        <source>reloadDataTable();
/*
Date			Who		Reason
23 April 2008	cnwer1	Initial creation - PAR#xxxx
11/09/2008		cnwcs5	ccms1061 - optimised table clear.
19/03/2010		cnwcs5	par 23193 - tracked item notifications
*/
vars

begin
	inheritMethod;	// par 23193
	return;			// par 23193
	
	// Much more efficient to just set number of rows
	// rather than deleting each row individually
	self.myDataTable.rows := self.myDataTable.fixedRows;

	
	self.loadDataTable();	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTIFromDataTable" id="292ec1bd-2b78-4239-a6e9-3165a587318e">
        <source>removeTIFromDataTable(_vehicle: CM_Vehicle input)protected;
/*
Purpose:			
Return Value:		

Date				Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx
02/09/2009			cnwcs5	ccms 1061 - remove old VTA handling
*/
vars
	job			: CM_Job;
	ti 			: CM_TrackedItem;
	wle 		: CM_WorkListEntry;
begin
	self.removeDataTableObject(_vehicle);
	
	foreach job in _vehicle.allRoadJobs do
		foreach wle in job.workListEntries where wle.isReceipt do
			self.removeDataTableObject(wle);
		endforeach;
		
		foreach ti in job.CM_RoadJob.allReceiveTrackedItems do
			self.removeDataTableObject(ti);
		endforeach;
	endforeach;
	
	// add row for the lane the vehicle was on
	self.loadDataTable_AddMissingLanes (true);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectTableRowForVehicle" id="423b4dfc-25f0-4ae8-a159-93179cfde8e0">
        <source>selectTableRowForVehicle(_vehicle: CM_Vehicle input) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	row 			: Integer;
	tableObjects 	: ObjectArray;
	obj 			: Object;
	isFirst			: Boolean; //cnwmc5 - par 29716
begin
	if not inheritMethod(_vehicle) then
		return false;
	endif;
	
	self.myDataTable.clearAllSelected;

	create tableObjects transient;
	
	self.getTableObjects(_vehicle,tableObjects);
	
	isFirst := true; //cnwmc5 par 29716
	
	foreach obj in tableObjects do
		//cnwmc5 - par 29716 - changed this if statement to work correctly
		if self.myDataTable.findObjectInRowReversed(obj, row) then	 //self.myDataTable.findObjectInRow(obj, row) then			
			self.myDataTable.selectRow(row, false);
			
			//cnwmc5 - par 29716
			if isFirst = true then
				self.myDataTable.topRow:= row;
			endif;
			
			isFirst := false;
		endif;
	endforeach; 
epilog
	if tableObjects &lt;&gt; null then
		delete tableObjects;
	endif;

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
