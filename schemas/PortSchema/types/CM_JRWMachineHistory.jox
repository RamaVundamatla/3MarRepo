    <JadeMethod name="getDelayTypeCriteria" id="b40daae7-3825-4588-9516-fe636a02ca02">
        <source>getDelayTypeCriteria():String;
// ---------------------------------------------------------------------------
// Created:     01 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:CM_DelayType;
	str		:String;
begin
	foreach type in self.allDelayTypes do
		if str = null then
			str := type.description;
		else
			str := str &amp; CNEC_COMMA &amp; Space &amp; type.description;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
