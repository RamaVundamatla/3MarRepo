<Class name="CM_SlotController">
    <JadeMethod name="populatBayPointActPro" id="4ab0956a-bf40-4eaa-93ff-26e7fc819446">
        <updating/>
        <source>populatBayPointActPro(_bayPoint : SHP_BayPoint input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	theTI, theDTI : CM_TrackedItem;
begin

	theTI := self.getTIAtIndex(REAL_MODE, 1);
	if theTI &lt;&gt; null then
		_bayPoint.tiInfoNumTI := self.allTrackedItems.size;
		theTI.populateBayPoint(_bayPoint);
	endif;

end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
    </JadeMethod>
</Class>
