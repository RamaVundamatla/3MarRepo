    <JadeMethod name="doControlEvent" id="44bbf464-a2a2-43ef-af30-e7a7fa092770">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwndl1	Initial creation

*/

vars

	parent : Control;

begin
	inheritMethod(_control);
	
	if _control.isKindOf( CM_MultiSelectButton ) then
		parent := _control.CM_MultiSelectButton.parent.Control;
		self.doResetColours( parent );
	endif;

epilog

end;</source>
        <Parameter name="_control" type="Control"/>
