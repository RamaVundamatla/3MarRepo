    <JadeMethod name="fixupMaintViewPermission851" id="2aaa866c-bca4-4ca9-a841-a73adebad335">
        <source>fixupMaintViewPermission851();
/*
Purpose:			
Date		Who		Reason
12 July 2016	cnwab1	Initial creation
*/



vars
	root : CM_Root;
	termSecRole : CM_SecurityRole;
	sysSecRole : CM_SecurityRole;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Cleaning up View Only Maint Permissions 851", LogINFO);


	// #### TERMINAL NEW MAINT PERMISSIONS
	root := CM_Root.firstInstance();
	termSecRole := root.mySecurityRoleTerminal;
	
	beginTransaction;
		termSecRole.zfixupMaintViewPermission(PmAdmTransactionEditView, PmAdmTransactioneditMaint, false);
		termSecRole.zfixupMaintViewPermission(PmGCProductGrpMaint, PmGCProductMaint, false);
		termSecRole.zfixupMaintViewPermission(PmHMSBerthUsageMaint, PmHMSBerthUsageView, false);
		termSecRole.zfixupMaintViewPermission(PmShipVesselEnquiryMaint, PmShipDefinMaint, false);
		termSecRole.zfixupMaintViewPermission(PmAdmCargoEnquiryConfigView, PmAdmCargoEnquiryView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmCargoEnquiryConfigMaint,PmAdmCargoEnquiryMaint, false);
		termSecRole.zfixupMaintViewPermission(PmAdmFaultResponseEnqMaint, PmFaultEnquiryMaint, false);
		termSecRole.zfixupMaintViewPermission(PmAdmYAStorageView, PmAdmYAMaint, false);
		termSecRole.zfixupMaintViewPermission(PmAdmYAStorageMaint, PmAdmYAMaint, false);
		termSecRole.zfixupMaintViewPermission(PmVoyageROROPlanningMaint, PmVoyagePlanningMaint, false);
		termSecRole.zfixupMaintViewPermission(PmVoyageROROPlanningView, PmVoyagePlanningView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmInvMapMaint, PmAdmInvLineDescrMaint, false);
		termSecRole.zfixupMaintViewPermission(PmAdmInvoiceSDExInterfaceView, PmAdmInvoiceSDExInterfaceMaint, false);
		termSecRole.zfixupMaintViewPermission(PmGteBookingRefReconMaint, PmGteBookingRefRecon, false);
		termSecRole.zfixupMaintViewPermission(PmGCReleaseEnqMaint, PmGCReleaseEnqView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmEasyGateMaint, PmAdmEasyGateView, false);
		termSecRole.zfixupMaintViewPermission(PmGteInOutEntryMaint, PmGteInOutEntry, false);
		termSecRole.zfixupMaintViewPermission(PmYardAreaEnquiryMaint, PmYardAreaeEnquiryView, false);
		
	commitTransaction;

	// #### SYSTEM NEW MAINT PERMISSIONS
	/*
	root := CM_Root.firstInstance();
	sysSecRole := root.mySecurityRoleSystem;
	
	beginTransaction;
		sysSecRole.zfixupMaintViewPermission(PmWebPageLoaderMaint, PmWebPageLoaderView, false);
	commitTransaction;
	*/
	
	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Cleaning up View Only Maint Permissions 851 complete", LogINFO);	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupNonBulkWeighVolumeCTs" id="7af43ce8-c685-4451-98e7-31b87e9be294">
        <source>fixupNonBulkWeighVolumeCTs(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2018	jlgndl1	Initial creation	TFS 36436

*/

vars

	cargoType : CM_CargoType;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Resetting CargoType.myWeightMeasurementType", LogINFO);
