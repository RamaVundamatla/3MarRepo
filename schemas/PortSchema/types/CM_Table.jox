    <JadeMethod name="windowCreated" id="63e5e10a-3eaf-4982-9cb2-70c0e16166f8">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;

vars

begin

	beginNotification(self, Selection_Event, Response_Continuous, 33);
	notificationStarted := true;

	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
