<Class name="CM_QStrCustDocTypeMethod" id="08707510-b5c5-4119-bf90-ddb424c8453b">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="f18ba605-9188-4186-bf76-dd0d5f54dff9">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	operator	: CM_QStringIsOneOf;
begin
	if self.isTransient() then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="c3a1319c-02f6-45e7-84c1-0f7cd07b1596">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbCustDocType';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="62094d73-01b7-4945-979b-a9387f3f6cf8">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	code	: String;
	docType	: CM_CustomDocumentType;
	terminal: CM_Terminal;
begin

	if self.propertyName = CM_TrackedItem::getCustomDocTypeCodeForSel.name then
		
		code := _obj.sendMsg(self.propertyName).String;
		
		if self.propertyClassName = CM_TrackedItem.name then
			terminal := _obj.CM_TrackedItem.myTerminal;
		elseif self.propertyClassName = CM_TITransaction.name then
			terminal := _obj.CM_TITransaction.myTerminal;
		endif;
		
		if terminal = null then
			return inheritMethod(_obj, _op);
		endif;
		
		docType := terminal.allCustomDocumentTypes[code];
		
		if docType &lt;&gt; null then
			return docType.code;
		endif;
		
		return inheritMethod(_obj, _op);
		
	else
		return inheritMethod(_obj, _op);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="2d219d5d-7670-4d81-9b40-2746c1e22964">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query
*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	userTerminal			: CM_UserTerminal;
	terminal				: CM_Terminal;
	objSetTerminal			: ObjectSet;
	multiTerminal			: Boolean;
	obj						: Object;
	custDocType				: CM_CustomDocumentType;
begin

	_combo.clear();
	
	// Create transients
	create objSetTerminal transient;
	
	foreach selectorCriteriaLine in _params.allCriteriaLines do
		// Get selected Terminals
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
			selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetTerminal);
		endif;
	endforeach;
	
	// If no Terminal selected, get it from user's access
	if objSetTerminal.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			if userTerminal.getMyTerminal() &lt;&gt; null then
				objSetTerminal.add(userTerminal.getMyTerminal());
			endif;
		endforeach;
	endif;
	
	// Set is more than 1 terminal
	multiTerminal := (objSetTerminal.size() &gt; 1);
	
	foreach obj in objSetTerminal do
		
		foreach terminal in objSetTerminal as CM_Terminal do
			foreach custDocType in terminal.allCustomDocumentTypes do
				if multiTerminal then
					_combo.itemObject[_combo.addItem(custDocType.code &amp; " - " &amp; custDocType.description&amp; " ( " &amp; obj.CM_Terminal.code &amp; ")" )] := custDocType;
				else
					_combo.itemObject[_combo.addItem(custDocType.code &amp; " - " &amp; custDocType.description)] := custDocType;
				endif;
			endforeach;
		endforeach;
	endforeach;

epilog
	delete objSetTerminal;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="38dfc87b-faba-43a0-b0fd-3742b79301b6">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	custDocType				: CM_CustomDocumentType;
	selectionValue			: Integer;
	idx						: Integer;
	userTerminal			: CM_UserTerminal;
	objSetTerminal			: ObjectSet;
	terminal				: CM_Terminal;
	obj						: Object;
	multiTerminal			: Boolean;
begin
	
	_tbl.clear();
	_tbl.rows := 0;
	
	create objSetTerminal transient;
	
	foreach selectorCriteriaLine in _params.allCriteriaLines do
		// Get selected Terminals
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
			selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetTerminal);
		endif;
	endforeach;
	
	// If no Terminal selected, get it from user's access
	if objSetTerminal.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			if userTerminal.getMyTerminal() &lt;&gt; null then
				objSetTerminal.add(userTerminal.getMyTerminal());
			endif;
		endforeach;
	endif;
	
	// Set is more than 1 terminal
	multiTerminal := (objSetTerminal.size() &gt; 1);
	
	foreach terminal in objSetTerminal as CM_Terminal do
		// Only process selected banks
		foreach custDocType in terminal.allCustomDocumentTypes do
			selectionValue := 0;
			if _operator &lt;&gt; null then
				if _operator.CM_QStringIsOneOf.allSelectionValues.includes(custDocType.code) then
					selectionValue := 1;
				endif;
			endif;
			
			if multiTerminal then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; custDocType.code &amp; " - " &amp; custDocType.description&amp; " ( " &amp; obj.CM_Terminal.code &amp; ")" );
			else
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; custDocType.code &amp; " - " &amp; custDocType.description);
			endif;
			_tbl.accessRow(idx).itemObject := custDocType;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;

epilog
	delete objSetTerminal;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="a35a5324-a635-40d7-aeb8-681c718eb118">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	custDocType		: CM_CustomDocumentType;
	stringArray		: StringArray;
	numRows,
	index			: Integer;
	string			: String;
begin
	create stringArray transient;

	numRows := _tbl.rows;
	
	foreach index in (_tbl.fixedRows + 1) to numRows do
		string := _tbl.accessCell(index, 1).text;
		
		if string = TableCheckBox_Selected then
			custDocType := _tbl.accessRow(index).itemObject.CM_CustomDocumentType;
			stringArray.add(custDocType.code);
		endif;
	endforeach;
	
	_op.setSearchValue(stringArray);

epilog
	delete stringArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="a3727df9-01f8-49da-8882-786f741d1f43">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	if _value.isKindOf(CM_CustomDocumentType) then
		if _value &lt;&gt; null then
			return _value.CM_CustomDocumentType.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="c3d9710c-c535-48ec-ba55-9963c022b1d2">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_CustomDocumentType;
	returnVal 	: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_CustomDocumentType) then
			object := _value.CM_CustomDocumentType;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
