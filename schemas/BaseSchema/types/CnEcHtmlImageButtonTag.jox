    <DbClassMap file="basehtml"/>
    <PrimAttribute name="inputSource" id="091de007-c172-4e6e-9083-91a44915c618">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <text>This property represents the URL of the image if the input
is of type TYPE_IMAGE (see inputType property).  This URL
may be relative to the Base HREF value.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="3fe8b493-c9cc-4d5f-bf2e-af2ae1c6494d">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return inheritMethod() &amp; ' ALIGN="' &amp; self.inputAlign &amp; '" SRC="' &amp; self.inputSource &amp; '"';
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="7e73762d-b51e-4293-939f-4d8da63fca77">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		30 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.inputType	:=	self.TYPE_IMAGE;
end;</source>
    </JadeMethod>
</Class>
