    <JadeMethod name="utlDeleteMachine" id="01b9a666-b7b8-49fe-886e-fbe8d424fd01">
        <source>utlDeleteMachine(pMachine:CM_Machine io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	app.myValDA.valMachine(pMachine);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

