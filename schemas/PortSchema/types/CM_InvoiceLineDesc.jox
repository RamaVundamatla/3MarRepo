end;</source>
    </JadeMethod>
    <JadeMethod name="doEmptyPoolPartyCalculations" id="148fca34-603d-40f4-ad3b-b4cd966677b7">
        <source>doEmptyPoolPartyCalculations(_debtor : CM_Debtor; _invoiceLine : CM_InvoiceLine input; 
											_transaction : CM_TITransaction);
//
// Purpose:			Check if transaction we are charging has an operator with a pool party
//					- if it does, we need to split the invoice charge across the pool party operators
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/01/2017	cnwdap1		Initial creation TFS 3042 SNO Empty Contanier Pool Management
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	operator, op : CM_Operator;
	debtor : CM_Debtor;
	poolParty : CM_MTPoolingParty;
	partner : CM_MTPoolingPartner;
	total : Real;
	originalInvoiceAmt : Real;
	newTotalAmt : Real;
	newInvoiceLine : CM_InvoiceLine;
	lineAmount : Real;
	seqNum : Integer;
	now : TimeStamp;

    invType : CM_InvoiceDesc;
    invoice : CM_Invoice;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	// is the debtor type an "Empty Pool Party" type?
	if _invoiceLine.invoiceLineDesc.myDebtorType = null or not _invoiceLine.invoiceLineDesc.myDebtorType.isEmptyPoolParty() then
		return;
	endif;
	
	
		// does the transaction have an operator with an empy pool party?
	operator := _transaction.getOperator;
	if operator = null then
		return;
	endif;
	
	if operator.allPoolingPartners.isEmpty then														// TFS 4370
		return;
	endif;

	// OK, we have an operator in an empty pool party, and the debtor type is empty pool party.
	// We have to split the invoice line total into multiple lines, based on the percentages set up
	// on each operator in the pool party
	// double check - do the partners' percentage of charges all add up to 100?
	//poolParty := operator.myPoolingPartner.myPoolingParty;										// TFS 4370
	partner := operator.allPoolingPartners[operator.code, _transaction.myTerminal];					// TFS 4370
	poolParty := partner.myPoolingParty;															// TFS 4370
	
	if poolParty = null then // TFS 3509
		return;
	endif;
	
	foreach partner in poolParty.allPoolingPartners do
		total := total + partner.percentageOfCharges;
	endforeach;
	
	if total &lt;&gt; 100 then
		if canLogExtra then	//27.02.2025 navah1	#34141
			if _transaction &lt;&gt; null then // TFS 3509
				app.invLog(_transaction.typeString &amp; " for cargo item " &amp; _transaction.myTrackedItem.id &amp; " - could not calculate Empty Pool Party lines because Pool Partners' percentages do not add up to 100", LogTRACE.String); // TFS 3509
			else
				app.invLog("Can not calculate Empty Pool Party (" &amp; poolParty.code &amp; ") lines because Pool Partners' percentages do not add up to 100", LogTRACE.String); // TFS 3509
			endif;
		endif;
		return;
	endif;
	
	// right - we have sensible data, now do the splitting up
// TFS 3509	originalInvoiceAmt := _invoiceLine.getTotalAmount;
	originalInvoiceAmt := _invoiceLine.quantity;
	
	now := app.actualTimeServer();
	foreach partner in poolParty.allPoolingPartners do
		if partner.myOperator = operator then
			// this is the operator from the original transaction and invoice line - massage the existing invoice line
// TFS 3509			_invoiceLine.setQuantityAndTotal(partner.percentageOfCharges / 100);
			_invoiceLine.setQuantityAndTotal((partner.percentageOfCharges / 100) * originalInvoiceAmt);
// TFS 3509			newTotalAmt := newTotalAmt + _invoiceLine.getTotalAmount;
			newTotalAmt := newTotalAmt + _invoiceLine.quantity;
		else
			// this is a new operator - create a new invoice line 
		
			debtor := null;// TFS 3509
			
			op := partner.myOperator;// TFS 3509
			if op &lt;&gt; null then
				debtor := op.debtor;// TFS 3509
			endif;
		
			invType := _invoiceLine.invoiceLineDesc.getInvoiceType(debtor);// TFS 3509
			if _invoiceLine.mySnapShotData &lt;&gt; null then
				invoice := _invoiceLine.bank.getAutoInvoiceSnapshot(invType, debtor, now, false, self);// TFS 3509
			else
				invoice := _invoiceLine.invoice;
			endif;
		
			create newInvoiceLine;
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
			newInvoiceLine.setForCreate(seqNum, false, null, _invoiceLine.invoiceLineDesc, invoice, debtor, _invoiceLine.bank, 1, now);// TFS 3509 invoice and debtor
			if _transaction &lt;&gt; null then
				newInvoiceLine.setMyTransaction(_transaction);
				newInvoiceLine.setTrackedItem(_transaction.myTrackedItem);
			endif;
			newInvoiceLine.setSnapShot(_invoiceLine.mySnapShotData, _invoiceLine.mySnapShotQuantity); // TFS 3509
			newInvoiceLine.createCharges();
// TFS 3509			newInvoiceLine.setQuantityAndTotal(partner.percentageOfCharges / 100);
			newInvoiceLine.setQuantityAndTotal((partner.percentageOfCharges / 100) * originalInvoiceAmt);
// TFS 3509			newTotalAmt := newTotalAmt + newInvoiceLine.getTotalAmount;
			newTotalAmt := newTotalAmt + newInvoiceLine.quantity;
			
			newInvoiceLine.setTotalAmount(); //29/09/2025	navkc1 JIRA 35917
			
		endif;
	endforeach;
	
	// double-double-check
	if originalInvoiceAmt &lt;&gt; newTotalAmt then
		if canLogExtra then	//27.02.2025 navah1	#34141
			if _transaction &lt;&gt; null then // TFS 3509
				app.invLog(_transaction.typeString &amp; " for cargo item " &amp; _transaction.myTrackedItem.id &amp; " - Empty Pool Party calc produced a new total of " &amp; newTotalAmt.String &amp; " compared to original total of " &amp; originalInvoiceAmt.String, LogTRACE.String); // TFS 3509
			else
				app.invLog("Empty Pool Party (" &amp; poolParty.code &amp; ") calc produced a new total of " &amp; newTotalAmt.String &amp; " compared to original total of " &amp; originalInvoiceAmt.String, LogTRACE.String); // TFS 3509
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="erase" id="d45d0a6e-5087-42d8-8539-91cee8591c29">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			
Date		Who		Reason
28 May 2013	cnwab1	Initial creation
*/

vars
	invLine : CM_InvoiceLine;
	invChg : CM_Charge;
	iter : Iterator;
	cmqfIC : CMQF_InvoiceContract;
begin
	// 37200 delete of transient proxy from INV_InvoiceLineDesc was going through all of the code below 
	//	which could take a minute or more and was not required at all, for a transient.
	if self.isTransient then
		delete self;
		return;
	endif;

	if _eraseLevel = FORCED_ERASE then
		if self.isVoid and
		   not self.isTransient then
			app.raiseCMException(Cannot_Delete_VOID_LineType, null, null);
		endif;
		
		foreach invLine in self.invoiceLines discreteLock do
			foreach invChg in invLine.charges discreteLock do
				invChg.erase(FORCED_ERASE);
			endforeach;
		endforeach;
		
		self.bank.zRemoveInvoiceLineFromTranMap(self);
		self.bank.zRemoveInvoiceLineFromDebtMap(self);
		self.bank.zRemoveInvLineTypeFromDebtMap(self);
		self.bank.zRemoveInvLineTypeFromChrgeMap(self);
	else
		validateForDelete();
	endif;
	
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqfIC) do
		if cmqfIC.allInvoiceLineTypes.includes(self) then
			cmqfIC.allInvoiceLineTypes.remove(self);
		endif;
	endwhile;

	inheritMethod(_eraseLevel); // This will erase all actual invoicelines of this type as the actual invoice lines are children!

epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="79a3f7cb-e515-4822-959b-d6a81b3d0881">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/12/2016	cnwma1	Initial creation
05/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
04 Nov 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
13-may-2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/

vars
	txt,
	tmpStr	: String;

	tmpService 	: CM_Service;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	

	if self.services.size &gt; 0 then
		foreach tmpService in self.services do
			if tmpService &lt;&gt; null then
				tmpStr := tmpService.name&amp;" "&amp; tmpStr ;
			endif;
		endforeach;
		txt := txt &amp; app.getErrorString(Services) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myCalculationType &lt;&gt; null then
		tmpStr := self.myCalculationType.description;
	endif;
	txt := txt &amp; 'Calculation Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.minimumChargeGroupBy &lt;&gt; null then
		if  self.minimumChargeGroupBy = self.GROUP_BY_NONE then
			tmpStr := app.getErrorString(None);
		elseif self.minimumChargeGroupBy = self.GROUP_BY_INVOICE then
			tmpStr := app.getErrorString(Invoice);
		elseif  self.minimumChargeGroupBy = self.GROUP_BY_INVOICELINE then
			tmpStr := app.getErrorString(Invoice_line);
		else
		
		endif;
	endif;
	txt := txt &amp; 'Group Minimum Charges By' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.myDebtorType &lt;&gt; null then
		if  self.myDebtorType.code = CM_DebtorType.DT_CARGO_OPERATOR then
			tmpStr := app.getErrorString(CM_Cargo_Operator);
		elseif self.myDebtorType.code = CM_DebtorType.DT_SHIP_OPERATOR then
			tmpStr := app.getErrorString(CM_Ship_Operator);
		elseif  self.myDebtorType.code = CM_DebtorType.DT_CONSIGNOR then
			tmpStr := app.getErrorString(CM_Consignor);
		elseif  self.myDebtorType.code = CM_DebtorType.DT_CONSIGNEE then
			tmpStr := app.getErrorString(CM_Consignee);
		elseif  self.myDebtorType.code = CM_DebtorType.DT_CUSTOMS_AGENT then
			tmpStr := app.getErrorString(CM_Customs_Agent);
		elseif  self.myDebtorType.code = CM_DebtorType.DT_FREIGHT_FORWARDER then
			tmpStr := app.getErrorString(FreightForwarder);
		elseif  self.myDebtorType.code = CM_DebtorType.DT_BUSINESS_UNIT then
			tmpStr := app.getErrorString(CM_Consignee);
		elseif  self.myDebtorType.code = CM_DebtorType.DT_CARRIER then
			tmpStr := app.getErrorString(CM_Consignee);
		elseif self.myDebtorType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE then			// TFS 44554
			tmpStr := app.getErrorString(VoyageStevedore);								// TFS 44554
		elseif self.myDebtorType.code = CM_DebtorType.DT_STEVEDORE_RECEIVE then			//04.11.2020 cnwma1 TFS #50112
			tmpStr := app.getErrorString(ReceiveStevedore);		
		elseif self.myDebtorType.code = CM_DebtorType.DT_STEVEDORE_RELEASE then			//04.11.2020 cnwma1 TFS #50112
			tmpStr := app.getErrorString(ReleaseStevedore);		
		elseif self.myDebtorType.code = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSEE then	   //31 Oct 2019	NDL	TFS 47100
			tmpStr := app.getErrorString(BOL_Item_first_consee);
		elseif self.myDebtorType.code = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSOR then	//31 Oct 2019	NDL	TFS 47100
			tmpStr := app.getErrorString(BOL_Item_first_consor);
		elseif self.myDebtorType.code = CM_DebtorType.DT_BOL_OPERATOR then	//31 Oct 2019	NDL	TFS 47100
			tmpStr := app.getErrorString(BOL_Operator);
		elseif self.myDebtorType.code = CM_DebtorType.DT_BOL_VOY_OPERATOR then	//31 Oct 2019	NDL	TFS 47100
			tmpStr := app.getErrorString(BOL_Voyage_operator);
		elseif self.myDebtorType.code = CM_DebtorType.DT_SHIPPING_LINE then			// 13 May 2022 navak20 TFS #53195
			tmpStr := app.getErrorString(ShippingLine);	
		elseif self.myDebtorType.code = CM_DebtorType.DT_SHIPPING_LINE_DESC then			// 13 May 2022 navak20 TFS #53195
			tmpStr := app.getErrorString(ShippingLineDesc);
		
		else
			tmpStr :=self.myDebtorType.description;
		endif;
	endif;
	txt := txt &amp; app.getErrorString(Charges) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	return txt;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
