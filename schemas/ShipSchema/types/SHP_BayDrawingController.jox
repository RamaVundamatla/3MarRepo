    <JadeMethod name="setModes" id="8efda7ba-712e-4e0a-8656-10da1a0d7705">
        <updating/>
        <source>setModes(_displayMode, _imexMode, _workingMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpConfig	: CMIF_ConfigUserVoyagePlanning;

begin

	if self.displayMode &lt;&gt; _displayMode then
		self.setDisplayMode(_displayMode);
		self.setAttrPositions(_displayMode);
	endif;

	self.imexMode := _imexMode;
	self.workingMode := _workingMode;

	tmpConfig := self.myConfig;
	self.otherSlotColor := tmpConfig.shipOtherSlotColor;
	
	if _displayMode = ShpDisplayMode_ColCodeDisch then
		self.showColorOthers := tmpConfig.shipDischargeCCShowOthers;
	elseif _displayMode = ShpDisplayMode_ColCodeLoad then
		if self.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq then
			self.showColorOthers := tmpConfig.shipLoadSeqShowOthers;
		elseif  self.workingMode = SHP_VoyageAreaForm2.WorkMode_Job then
			self.showColorOthers := tmpConfig.shipLoadJobShowOthers;
		elseif  self.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
			self.showColorOthers := tmpConfig.shipLoadPlanShowOthers;
		else
			self.showColorOthers := tmpConfig.shipLoadCCShowOthers;
		endif;
	else
		self.showColorOthers := 0;
	endif;

end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_imexMode" type="Integer"/>
        <Parameter name="_workingMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setScale" id="c67527e6-50d2-4f5e-9322-d48e2d1eb1d2">
        <updating/>
        <source>setScale(_factor: Real; _onDeck, _underDeck: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 29/08/2017	jlgdap1		TFS 5840 Error 15007 when printing Large bay plan in LOLO Planning
// 12/02/2018	jlgns1		Bug 36889: SNO - Header in bay plan printing
// 13/03/2018 	jlgns1 		Bug 37525: SNO - (re Ticket 36886): Header in bay plan printing
vars
	theRowHeight,
	theColWidth		: Integer;
	aBay : CM_Bay;
	maxCells,
	maxTiers : Integer;
	showDetails : Boolean;	//Bug 36889
	newScale : Real;		//Bug 37525

begin
	inheritMethod(_factor, _onDeck, _underDeck);

	if (self.amPrinting and self.printOutputStyle = self.PrintOutput_Large) then
	
		// PAR 37240
		theColWidth 	:= PrintScaleLargeWidth;
		if self.printSeparateODUD then
			theRowHeight 	:= PrintScaleLargeHeightSeparate;
		else
			theRowHeight 	:= PrintScaleLargeHeight;
		endif;
	
	
		self.myVoyage.getMaxCellsTiers(maxCells, maxTiers, self.allBays, _onDeck, _underDeck);
		

		if maxCells &gt; 13 then
			theColWidth 	:= (840 / maxCells).Integer;	//21 Mar 2016	NDL / AB1 - TFS 1686. Was 860, seems to be printer dependent...
			self.defaultFontSize	 := 5.2; //epr TFS 2349 14/7/16
		endif;	
			
		
		showDetails :=  self.myTerminal.getConfig(ShowHeightsLOLOPlanning).Boolean or self.myTerminal.getConfig(ShowWeightsLOLOPlanning).Boolean;		//Bug 36889
																																						//Bug 36889
 		if maxTiers &gt;= 15 or (maxTiers &gt;= 12 and showDetails) then																						//Bug 36889
			theRowHeight 	:= (520 / maxTiers).Integer; 	//21 Mar 2016	NDL / AB1 - TFS 1686. Was 860, seems to be printer dependent...				//Bug 36889
			self.defaultFontSize	 := 78 / maxTiers;																									//Bug 36889
			// TFS 5840 Adjust cell height and default font if we have lots of tiers																	//Bug 36889
			// and adjust it even further if we're displaying weights and heights																		//Bug 36889
			if self.bayHeight  &gt;= app.printer.pageHeight or showDetails  then																			//Bug 36889
				theRowHeight := (480 / maxTiers).Integer;																								//Bug 36889
				self.defaultFontSize := 78 / maxTiers;																									//Bug 36889
				if showDetails then																														//Bug 36889
					// shrink the scale even further																									//Bug 36889
					theRowHeight := (360 / maxTiers).Integer;																							//Bug 36889
					self.defaultFontSize := 45 / maxTiers;																								//Bug 36889
				endif;																																	//Bug 36889
			endif;																																		//Bug 36889
			newScale := (theRowHeight / 7).Real;					//Bug 37525
			if self.scaleFactor &lt;&gt; newScale then					//Bug 37525
				inheritMethod(newScale,true,true);					//Bug 37525
			endif;													//Bug 37525
		endif;																																			//Bug 36889
					
		
	elseif self.amPrinting and self.printOutputStyle = self.PrintOutput_Medium then					//Bug 37525
		theRowHeight 	:= (RowHeightDefault *  _factor).Integer;									//Bug 37525
		theColWidth		:= (ColumnWidthDefault * _factor).Integer;									//Bug 37525
																									//Bug 37525
		self.myVoyage.getMaxCellsTiers(maxCells, maxTiers, self.allBays, _onDeck, _underDeck);		//Bug 37525
																									//Bug 37525
		if maxTiers &gt;= 14 then																		//Bug 37525
			theRowHeight := (200 / maxTiers).Integer; 												//Bug 37525
		endif;																						//Bug 37525
	else
		theRowHeight 	:= (RowHeightDefault *  _factor).Integer;
		theColWidth		:= (ColumnWidthDefault * _factor).Integer;
	endif;

	// must set these BEFORE call to setAttrPositions as it uses these figures
	self.rowHeight := theRowHeight;
	self.columnWidth := theColWidth;

	self.setAttrPositions(self.displayMode);

epilog
end;</source>
        <Parameter name="_factor" type="Real"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
