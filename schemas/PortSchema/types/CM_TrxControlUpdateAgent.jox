    <JadeMethod name="trxUpdateSwapReleaseTI" id="26c8da5f-fb15-4070-b10a-ce50aa0b5583">
        <updating/>
        <source>trxUpdateSwapReleaseTI(_wle : CM_WorkListEntry input;
						_newTI : CM_TrackedItem input;
						_passport : CM_Passport input) updating;
/*

Date		Who		Reason
22 May 2014	cnwer1	Initial creation PAR 34174

*/

vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);

	if _wle = null then
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Work_list_entry_ref), null, null);
		return;
	endif;
	
	if _newTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Cargo), null, null);
		return;
	endif;
	
	beginTransaction;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;

	_wle.swapReleaseTI(_newTI,_passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_newTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
