    <JadeMethod name="setForUpdate" id="b0c00206-6cff-4d8e-9dee-636e1d3ba546">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlizm1	Initial creation TFS 53901 EUP VBS EDI
14 Jul 2023 navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars

begin
	inheritMethod(_proxyEDITI);
	
	self.carrierCode 		:= _proxyEDITI.carrierCode.toUpper;		 	 	//11.08.2023 navma1 #59793
	self.driverCode 		:= _proxyEDITI.driverCode;
	self.driverExternalId 	:= _proxyEDITI.driverExternalId;
	self.externalReference	:= _proxyEDITI.externalReference;
	self.kioskCheck			:= _proxyEDITI.kioskCheck;
	self.preGateInCheck		:= _proxyEDITI.preGateInCheck;
	self.preGateOutCheck	:= _proxyEDITI.preGateOutCheck;
	self.remarks			:= _proxyEDITI.remarks;
	self.slotTypeCode		:= _proxyEDITI.slotTypeCode.toUpper;			//11.08.2023 navma1 #59793
	self.subCarrierCode		:= _proxyEDITI.subCarrierCode.toUpper;			//11.08.2023 navma1 #59793
	self.vehicleRegNumber	:= _proxyEDITI.vehicleRegNumber.toUpper;		//11.08.2023 navma1 #59793
	self.startDate			:= _proxyEDITI.startDate;						//14.07.2023 navma1 #59136
	
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setPropertyByName" id="293a0ec1-e6af-44f5-b8e4-430fad41334b">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars

begin
	if  _columnName = ETRow_RegNumber then
		self.vehicleRegNumber := _value.toUpper;	
	else
		return inheritMethod(_columnName, _value);
	endif;
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyCarrier" id="a6e549d0-75f6-4606-8758-e7696a861878">
        <source>verifyCarrier();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	carrier		: CM_Carrier;
begin
	
	carrier := self.getCarrier();
	
	if carrier = null then
		app.raiseCMException2(CodeInvalid, app.getErrorString(Carrier_code), self.carrierCode, ETRow_CarrierCode, self);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyDriverVehicle" id="df5658e6-f735-4c8f-a2c7-c6fb057a1deb">
        <source>verifyDriverVehicle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	vehicle 		   : CM_Vehicle;
	isVehDrMandatory   : Boolean;
	carrier			   : CM_Carrier;
	driver			   : CM_DriverDetails;
begin
	
	isVehDrMandatory := self.getMyTerminal.getConfig(VsTruckDriverMand).Boolean;
	vehicle 		 := self.getVehicle();
	driver 		     := self.getDriver();
	carrier 		 := self.getCarrier();
	
	
	if isVehDrMandatory then
		if driver = null then
			app.raiseCMException1(Driver_required_field,null, ETRow_DriverCode, self);
		endif;
		
		if vehicle = null then
			app.raiseCMException1(Vehicle_required_field,null, ETRow_RegNumber, self);
		endif;
	endif;
	
	
	if self.driverCode &lt;&gt; null and driver = null then
		app.raiseCMException1(ERR_Driver_Unknown,self.driverCode, ETRow_DriverCode, self); 
	endif;
	
	if self.vehicleRegNumber &lt;&gt; null and vehicle = null then
		app.raiseCMException1(ERR_Vehicle_Unknown,self.vehicleRegNumber, ETRow_RegNumber, self); 
	endif;
	
	if carrier &lt;&gt; null then
		if driver &lt;&gt; null then
			if  not driver.allCarriers.includes(carrier) then
				app.raiseCMException2(Selected_carrier_not_driver, self.carrierCode, ETRow_CarrierCode,driver.code, self);
			endif;
		endif;
		if vehicle &lt;&gt; null then
			if driver &lt;&gt; null then
				if  not driver.allVehicleMachines.includes(vehicle) then
					app.raiseCMException2(Selected_vehicle_not_driver, self.vehicleRegNumber,driver.code ,ETRow_RegNumber,self);
				endif;
			else
				app.raiseCMException1(Driver_required_field,null, ETRow_DriverCode, self);
			endif;
			
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyExternalRefId" id="27d6959a-4d69-4852-8030-b9b9533993d7">
        <source>verifyExternalRefId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate
14 Aug 2023	navma1	Bug 59805: EUP - VBS EDI Validation
*/

vars
	messageMode 			: String;
	extRef					: String;
	vbsSlot					: CM_VehicleBookingTimeSlot;
	slotType				: CM_VehicleBookingTimeSlotType;
	isExtRefUpdateAllowed	: Boolean;	
begin
	
	extRef		:= self.externalReference.toUpper.trimBlanks;
	slotType	:= self.getSlotType();
	messageMode := self.messageMode;
	
	if slotType &lt;&gt; null then
		isExtRefUpdateAllowed := slotType.isExternelRefUpdateAllowed;
		
	endif;
	
	if extRef &lt;&gt; null then										//14.08.2023 navma1 #59805
		vbsSlot := self.getVbsSlotById();
		if vbsSlot = null then
			vbsSlot := self.getVbsSlotByExtId();
		endif;
	endif;
	
	if extRef &lt;&gt; null then										//14.08.2023 navma1 #59805
		if not isExtRefUpdateAllowed then
			app.raiseCMException2(ERR_VBS_EXTREF_Update, self.slotTypeCode,ETRow_ExternalReference,null, self);
		endif;
	endif;
	
	if messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		
		if vbsSlot &lt;&gt; null then
			app.raiseCMException2(External_ref_already_used, extRef,ETRow_ExternalReference,null, self);
		endif;
	else 
		if self.id = null and self.externalReference = null then
			app.raiseCMException(Input_required_field_Id, ETRow_Id, self);
		endif;			
		
		if extRef &lt;&gt; null then
			if vbsSlot = null then
				app.raiseCMException1(ERR_VehicleBooking_ExtId_Found,self.externalReference, ETRow_ExternalReference, self);
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyId" id="86b8e4a0-fb8a-44bb-a621-d48923cae01d">
        <source>verifyId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate
*/

vars
	messageMode : String;
	vbsSlot		: CM_VehicleBookingTimeSlot;
begin
	
	messageMode := self.messageMode;
	
	if messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		if self.id &lt;&gt; null then
			app.raiseCMException(ERR_VehicleBooking_Id, ETRow_Id, self);
		endif;
	else				
		if self.id = null and self.externalReference = null then
			app.raiseCMException(Input_required_field_Id, ETRow_Id, self);
		endif;
		
		if self.id &lt;&gt; null then
			vbsSlot := self.getVbsSlotById();
			
			if vbsSlot = null then
				app.raiseCMException1(ERR_vehicleBooking_Id_Found,self.id, ETRow_Id, self);
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyIsUsed" id="3e345328-f10e-4310-bbb2-c874edac8e58">
        <source>verifyIsUsed();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2023	navma1	Bug 59805: EUP - VBS EDI Validation
*/

vars
	vbsSlot 	: CM_VehicleBookingTimeSlot;
	messageMode : String;
	vvrId		: String;
begin
	
	messageMode := self.messageMode;
	
	if messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		return;
	endif;
	
	vbsSlot := self.getVbsSlotById();
	
	if vbsSlot = null then
		vbsSlot := self.getVbsSlotByExtId();
	endif;
	
	if vbsSlot = null then
		return;
	endif;
	
	if vbsSlot &lt;&gt; null then
		if vbsSlot.isUsed then
			vvrId := vbsSlot.myVehicleVisitRecord.visitNumber;
			app.raiseCMException2(ERR_VehicleBookingSlotUsed,vbsSlot.id,vvrId,null,self);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="31af03da-a391-41a0-920d-7b519d3555e0">
        <updating/>
        <source>verifySelf() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlizm1	Initial creation TFS 53901 EUP VBS EDI
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
14 Aug 2023	navma1	Bug 59805: EUP - VBS EDI Validation
*/

vars
	terminal 	: CM_Terminal;
	driver 		: CM_DriverDetails;
	tmpCode		: String;
	carrier		: CM_Carrier;
	vehicle		: CM_Vehicle;
	
begin
	terminal := self.getMyTerminal;
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	if   self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_MODIFY
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
	then
		app.raiseCMException1( EDI_Action_Is_Invalid, self.messageMode, null, null );
	endif;
	
	self.verifyId();						//07.08.2023 navma1 #59487
	self.verifyExternalRefId();				//07.08.2023 navma1 #59487
	
	if self.messageMode = self.EDI_ACTION_DELETE then
		return;
	endif;
	
	self.verifyCarrier();					//07.08.2023 navma1 #59487
	self.verifySubCarrier();				//07.08.2023 navma1 #59487
	self.verifyDriverVehicle();				//07.08.2023 navma1 #59487
	self.verifySlotType();					//07.08.2023 navma1 #59487
	self.verifyStartDate();					//07.08.2023 navma1 #59487
	self.verifySlotCriteria();				//07.08.2023 navma1 #59487
	self.verifyIsUsed();					//14.08.2023 navma1 #59805
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifySlotCriteria" id="43ac97e5-f231-4432-b9bb-012fde1a28c2">
        <source>verifySlotCriteria();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	scenario 			 : CMIF_YAVBS;
	criteria 			 : CM_YACriteria;
	vbsSlotTypeCriteria  : CM_VBSSlotTypeCriteria;
	criteriaType		: CM_YACriteriaType;
	slotType			: CM_VehicleBookingTimeSlotType;
	carrier				: CM_Carrier;
	str					: String;
	yaData				: String;
	slotTypeCode		: String;
begin
	
	slotType := self.getSlotType();
	carrier  := self.getCarrier();
	
	if slotType = null then
		return;
	endif;
	
	slotTypeCode := slotType.code;
	
	if slotType.myVBSSlotTypeCriteria = null then
		return;
	endif;
	
	vbsSlotTypeCriteria := slotType.myVBSSlotTypeCriteria;
	if carrier = null then
		return;
	endif;
	
	create scenario transient;
	
	scenario.myCarrier := carrier;
	
	foreach criteria in vbsSlotTypeCriteria.allCriteria do
		
		criteriaType := criteria.myYACriteriaType;
		
		if criteriaType.isYATypeCarrier and not criteria.isCMIFAutoPlanDataMatch(scenario)  then	
			if scenario.myCarrier &lt;&gt; null then
				str := scenario.myCarrier.code;
			endif;
			yaData := criteria.myYACriteriaType.getDataDisplay(criteria.myYAData);
			app.raiseCMException4(ERR_VBS_CriteraMatching,'Carrier',str,yaData,slotTypeCode,null ,self);
		endif;
	endforeach;

epilog
	delete scenario;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifySlotType" id="76749f5b-6f8b-47de-9dfa-a1cb1d137756">
        <source>verifySlotType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars

begin
	if self.slotTypeCode &lt;&gt; null then
		if self.getMyTerminal.allTerminalVBSSlotTypes[self.slotTypeCode] = null then
			app.raiseCMException2(ERR_FIELD_TYPE, self.slotTypeCode, app.getErrorString(VBS_Slot_type), ETRow_SlotTypeCode, null);
		endif;
	else
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(VBS_Slot_type), ETRow_SlotTypeCode, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyStartDate" id="55be05d7-0830-4c5e-b887-ce834ccc5659">
        <source>verifyStartDate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
08 Nov 2023	navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
*/

vars
	terminal		: CM_Terminal;
	allowVBSInPast 	: Boolean;
begin
	if not self.startDate.isValid then												//14.07.2023 navma1 #59136
		app.raiseCMException(ERR_StartDateRequired, null, null);
	endif;
	
	terminal := self.getMyTerminal();												// #60951
	allowVBSInPast := terminal.getConfig(AllowVBSInPast).Boolean;					// #60951
	
	if self.startDate.isValid then													//14.07.2023 navma1 #59136
		if self.startDate &lt; app.actualTimeServer.Date then
			if not allowVBSInPast then												// #60951
				app.raiseCMException(Vehic_sched_booki_not_added_th, null, null);
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifySubCarrier" id="c665a18f-5993-4739-9824-75f97679706d">
        <source>verifySubCarrier();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	subCarrier : CM_Carrier;
begin
	
	if self.subCarrierCode = null then
		return;
	endif;
	
	subCarrier := self.getSubCarrier;
	
	if subCarrier = null then
		app.raiseCMException2(ERR_FIELD_CARRIER, self.subCarrierCode, app.getErrorString(Subcarrier), null, null);
	endif;
	
	if subCarrier &lt;&gt; null and not subCarrier.isSubCarrier then
		app.raiseCMException1(ERR_Invalid_SubCarrier, self.subCarrierCode, app.getErrorString(Subcarrier), null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
