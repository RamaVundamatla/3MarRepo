/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2024	navhn30	Initial creation

*/

vars

begin
	self.canWeightBeCertified := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
