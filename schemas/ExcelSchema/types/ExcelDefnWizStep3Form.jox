    <transientAllowed/>
    <ImplicitInverseRef name="groupBox1" id="e215514f-bdcf-40c7-a558-68d81037ca30">
        <embedded/>
        <type name="GroupBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="label7" id="5b8861da-0bdb-43af-954c-2ed5e34b0948">
