<Class name="CM_KPI" id="403f70ae-baab-4fb6-977e-cc102c213e38">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="statistic"/>
    <PrimAttribute name="code" id="7171a86f-dc1e-4bf4-bba5-906a69fa3f56">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>

This is the main sort code, e.g. terminal area code, voyage code etc.</text>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="34374057-7a18-49ec-ae84-816aa93e47a1">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="cdbc4927-d1fe-4f69-9708-0e35402c2242">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allKPIbyTypeTSCode"/>
        <Inverse name="CM_Terminal::allKPIbyTypeCodeTS"/>
        <Inverse name="CM_Terminal::allKPICargo"/>
    </ExplicitInverseRef>
    <PrimAttribute name="type" id="2666c015-11e9-45fd-88aa-67fd7632616d">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userCode" id="0b9c186b-e852-4237-a3d0-2e3c94908a69">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayString" id="b36ed0bf-7b88-4a63-bef7-1a853bdb679a">
        <source>displayString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2012	cnwdw1	Initial creation
*/
vars

begin
	return "Type: "&amp; self.type.String &amp; " DateTime: " &amp; self.dateTime.asStringForWebInterface;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="exportCSV" id="42fa8fd6-f09e-4304-9b63-2ac210fdced8">
        <source>exportCSV() : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	line : String;
begin

	line := 	self.type.String &amp; "," &amp;
				self.dateTime.date.shortFormatJMT() &amp; "," &amp;
				self.dateTime.time.String  &amp; "," &amp;
				self.userCode &amp; "," &amp;
				self.code;
	return line;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="a7ee0e3a-1b23-4311-ab45-17cd6fbbf9fd">
        <source>getDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionString" id="aac70293-85db-43cc-91a5-35402bbd0f5d">
        <source>getDescriptionString(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _short then
		return self.code &amp; " " &amp; self.dateTime.shortCurrentLocaleFormat();
	else
		return self.code &amp; " " &amp; self.dateTime.shortCurrentLocaleFormat();
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="18b890f5-42f6-4d53-86c2-52f0cc42457b">
