    <JadeMethod name="setRefsToNullForCallOffCancel" id="8dd5840d-0f2a-4c12-aa65-f4b965dd9008">
        <updating/>
        <source>setRefsToNullForCallOffCancel() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/08/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
// 16/11/2023	navdap1		TFS 58929 EUP | Calloff Cancel Processing
//
vars
	item : CM_VehicleBookingTimeSlotItem;
	invalidRel, invalidSel : Boolean;
	release : CM_BulkRelease;
	selection : CM_ReserveDetail;

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myCarrier := null;
	self.myDriver := null;
	self.myVehicle := null;
	
	// TFS 58929 Clear invalid references to deleted bulk release and reserve selection
	self.allBulkReleases.rebuild;
	foreach item in self.allVehicleBookingItems do
		invalidRel := false;
		invalidSel := false;
		
		on Exception do app.handleDeletedObject(exception, release, invalidRel);
		if item.myBulkRelease &lt;&gt; null then
			release := item.myBulkRelease;
			release.edition;
			if invalidRel then
				item.setMyBulkReleaseToNull();
			endif;
		endif;
		on Exception do null;
		
		on Exception do app.handleDeletedObject(exception, selection, invalidSel);
		if item.myReserveDetails &lt;&gt; null then
			selection := item.myReserveDetails;
			selection.edition;
			if invalidSel then
				item.setMyReserveDetailToNull();
			endif;
		endif;
		on Exception do null;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="57afd937-d392-4f1c-8f19-b54d46676aa4">
        <updating/>
        <source>setRemarks(_remark : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2023	navsp1	Initial creation TFS ChangeRequest 57805: EUP - Manifest Processing - Truck - Create

*/

vars

begin
	self.remarks	:= _remark;
epilog

end;</source>
