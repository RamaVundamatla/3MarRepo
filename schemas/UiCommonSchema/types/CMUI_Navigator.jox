    <JadeMethod name="keyDown" id="2919f2b0-3efc-424d-a0ae-69dd5221a5d0">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_Esc then
		self.dragMode := Window.DragMode_None;
		return;
	endif;
	
//	if app.isDevelopmentSystem and		// no reason why the users should not see this if they want. PAR 23191
	if keyCode = J_key_F and shift.bitAnd(2) &lt;&gt; 0 then	// CTRL-F
		doShowNavSearch;
		return;
	endif;
	
	//cnwmc5 PAR 31334 - added F3 in also
	if keyCode = J_key_F3 then
		if self.frmFind.visible = true then
			self.doHideNavSearch();
		else
			self.doShowNavSearch();
		endif;
	endif;
	
	if keyCode = J_key_Enter and frmFind.visible = true then
		doNavSearch;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	
end;
</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
