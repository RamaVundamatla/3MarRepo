    <JadeMethod name="onGateChange" id="7a7167b1-7aac-4e50-899b-67eb837fa3fe">
        <updating/>
        <source>onGateChange() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 June 2022		navhl20 TFS 52777 EUP - INT - Generic API: record-scan
12 July 2022		navmd1	TFS 52777 Tidy up/review code

*/

vars
	gate 					: CM_Gate;
	gateArea 				: CM_GateArea;
	laneNumber				: Integer;
	laneCont				: CM_LaneController;
	myLaneCont				: CM_LaneController;
	objSet 					: CM_ObjectSet;
	obj						: Object;	
	gridController 			: CM_GridController;
	detailsChangedVehicle	: Boolean;
begin

	if self.myBulkGateAgent.myWeighBridge &lt;&gt; null then
	//	if self.myBulkGateAgent.myWeighBridge.myGateLane &lt;&gt; null then
			myLaneCont := self.myBulkGateAgent.myWeighBridge.myGateLane;
	//	endif;
	endif;

	self.cmbGateLanes.clear();
	gate := self.cmbGate.listObject.CM_Gate;
	
	if gate &lt;&gt; null then
		create objSet transient;
		gate.getPGateAreas_OUT(objSet);
		foreach obj in objSet do
			gateArea := obj.CM_GateArea;
			if gateArea.laneCount &gt; 0 then
			
				self.cmbGateLanes.enabled := not self.myBulkGateAgent.gateAndLaneSet;
				self.lblGateLane.visible := true; 
				self.cmbGateLanes.visible := true; 
				foreach gridController  in gateArea.allGridControllersByName where gridController.isKindOf(CM_GateAreaLaneController)	do
					laneCont:=gridController.CM_GateAreaLaneController;
					if not laneCont.isOut then
						continue;
					endif;
						
					if laneCont.isUnavailable then 
						continue;					
					endif;								

					self.cmbGateLanes.addItemObject(gridController.getID , laneCont);
				endforeach;
			endif;

		endforeach;
		self.cmbGateLanes.setIndex(1);
	
	endif;	
	
	if self.cmbGateLanes.listCount &gt; 0 then
		if myLaneCont &lt;&gt; null then
			self.cmbGateLanes.setIndexFromObject(myLaneCont);
		endif;
	else
		self.lblGateLane.visible := false;
		self.cmbGateLanes.visible := false;
	endif;
	
	self.loadPrinterCombo();
	
	// TFS 52777
	self.setupGenericWeightInterface();
	if not self.clearingForm and self.visible then
		self.myAssistant.populateScanData(false, true, detailsChangedVehicle, self.txtRegno, null, null, null, null,
			null, null, self.txtWeightOUT, null);
	endif;
epilog
delete objSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="ca73e0e7-1b9e-4daa-a3c0-61b8494f6c01">
