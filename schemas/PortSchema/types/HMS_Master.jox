    <JadeMethod name="getDisplayStringForAttribute" id="f10d6a6f-c2c1-4915-8bd1-ab4d59781dda">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_IsNotAvailableForEntry or _attrName = ETRow_NotAvailForEntry then
		return self.notAvailForEntry.String;
	elseif _attrName = ETRow_HasPEC then
		return self.hasAnyCurrentPEC.String;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastQualifyingMovement" id="da615f58-1f40-4d08-baa5-d17021d9d15f">
        <source>getLastQualifyingMovement():HMS_VoyageMovement;
//-----------------------------------------------------------------------
//	Created:	02 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	movement : HMS_VoyageMovement;
	vesselData	: HMS_VesselData;
begin

	foreach movement in allMovements reversed do
		vesselData := movement.getMyHMSVesselData();
		if vesselData &lt;&gt; null then
			if vesselData.dim_GrossRegTonnes &gt; self.myHarbour.exemptMasterRequiredGTR then
				if self.loa &gt;= vesselData.dim_LengthOverall then
					return movement;
				endif;
			endif;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getPECforVessel" id="2fdeb935-ca1a-4de8-9f32-a9cab38f725a">
        <source>getPECforVessel( _harbour : HMS_Harbour; _vessel : CM_Vessel; _asAtDate : Date ): HMS_PilotExemptionCertificate;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2012	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	pilotExempt : HMS_PilotExemptionCertificate;
	today : Date;

begin

	// looking for a specific certificate...

	iter := self.allPilotExemptionCertificates.createIterator;
	while iter.next( pilotExempt ) do
	
		if pilotExempt.myHarbour &lt;&gt; _harbour then
			continue;
		endif;
		if pilotExempt.myVessel &lt;&gt; _vessel then
			continue;
		endif;
		if pilotExempt.expiryDate &lt; _asAtDate then
			continue;
		endif;
		if pilotExempt.revalidationDate &lt; _asAtDate then
			continue;
		endif;
		
		return pilotExempt;
		
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_asAtDate" type="Date"/>
        <ReturnType type="HMS_PilotExemptionCertificate"/>
    </JadeMethod>
    <JadeMethod name="hasAnyCurrentPEC" id="503ff830-822c-4e26-9fce-9ced9d7cc4ed">
        <source>hasAnyCurrentPEC():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496
// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

	iter : Iterator;
	pilotExempt : HMS_PilotExemptionCertificate;
	today : Date;

begin

	// looking for any current certificate...

	today := app.actualTimeServer.Date;// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	iter := self.allPilotExemptionCertificates.createIterator;
	while iter.next( pilotExempt ) do
		if pilotExempt.expiryDate &lt; today then
			continue;
		endif;
		if pilotExempt.revalidationDate &lt; today then
			continue;
		endif;
		return true;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasCurrentPECforVessel" id="1a5a6b54-4154-43b2-b4dc-c370925fa5dd">
        <source>hasCurrentPECforVessel( _harbour : HMS_Harbour; _vessel : CM_Vessel; _asAtDate : Date ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	pilotExempt : HMS_PilotExemptionCertificate;
	
begin
	// looking for a specific certificate...
	pilotExempt := self.getPECforVessel( _harbour, _vessel, _asAtDate );

	if pilotExempt &lt;&gt; null then	
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_asAtDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForVessel" id="ecfde8ea-cbba-4571-8b21-cf2c9cbd059a">
        <source>isValidForVessel(_harbour : HMS_Harbour; _vessel : CM_Vessel; _date : Date ): Boolean;
//-----------------------------------------------------------------------
//	Created:	31 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpVesselData	: HMS_VesselData;
begin

	if _vessel = null then
		return false;
	endif;

	tmpVesselData := _vessel.myHMSVesselData;
	if tmpVesselData = null then
		return false;
	endif;

/*	30 Apr 2012	NDL	Par 29496
	if _date &lt; self.dateCertified or _date &gt;= self.dateCertificateExpires  then
		return false;
	endif;
	
	if self.loa  &lt;= tmpVesselData.dim_LengthOverall then
		return false;
	endif;
	
	if self.allMovements.size &lt; self.myHarbour.exemptMasterMovementReq then
		return false;
	endif;
	
	return true; */
	
	return self.hasCurrentPECforVessel( _harbour, _vessel, _date );	//30 Apr 2012	NDL	Par 29496
	
epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForVoyage" id="339682d4-9c7c-4e2e-86e0-47fe9cf5a7d9">
        <source>isValidForVoyage(_voyage : CM_Voyage; _date : Date): Boolean;
//-----------------------------------------------------------------------
//	Created:	31 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpVessel : CM_Vessel;
begin
	if _voyage = null then
		return false;
	endif;

	tmpVessel := _voyage.getMyVessel();
	
	if tmpVessel = null then
		return false;
	endif;
	
	return self.isValidForVessel(self.myHarbour, tmpVessel, _date);

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="dc9a1735-130c-4126-80a1-eb49bc58fc59">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------------------------------------
//	Created:	28 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_Master;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a1d55b1a-d079-4103-a919-d20edc665a28">
        <updating/>
        <source>setForUpdate(_pxyMaster: HMS_Master; _passport: CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	28 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	inheritMethod(_pxyMaster, _passport);
	
	self.code						:= _pxyMaster.code.toUpper.trimBlanks;
	self.description				:= _pxyMaster.description;
	self.loa						:= _pxyMaster.loa;
	self.dateCertified				:= _pxyMaster.dateCertified;
//	self.dateCertificateExpires		:= _pxyMaster.dateCertificateExpires;	// this is a mapping method....Doh
	self.notAvailForEntry			:= _pxyMaster.notAvailForEntry;
	self.myHarbour					:= _pxyMaster.myHarbour;

	
end;</source>
        <Parameter name="_pxyMaster" type="HMS_Master"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2e443bed-3a72-41e2-a48c-b4e513707d9d">
        <updating/>
        <source>setProxy(_harbour : HMS_Harbour) updating;
//-----------------------------------------------------------------------
//	Created:	28 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myHarbour := _harbour;
epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="89ef19ca-879b-4d12-8e57-b3a40e7ca164">
        <source>validateMe(_passport: CM_Passport input);
//-----------------------------------------------------------------------
//	Created:	28 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//Date             Who        Reason
//14 Apr 2023      navmp20    Bug 57583: CAL - Master Field from the HSM error when creating a new entry.
//11 Aug 2023 	   navlc30 	  Bug 59489: PNL | Harbour Admin error 96020
//-----------------------------------------------------------------------
vars
	realMaster,
	otherMaster : HMS_Master;  //14.04.2023 navmp20 TFS 57583
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	//Start 14.04.2023 navmp20 TFS 57583
	otherMaster := self.myHarbour.allMasters[self.code];
	realMaster := self.pxyGetRealObject();												//11.8.2023 navlc30 #59489
	// if otherMaster &lt;&gt; null and otherMaster &lt;&gt; self  then								//11.8.2023 navlc30 #59489
	if otherMaster &lt;&gt; null and (realMaster = null or otherMaster &lt;&gt; realMaster)  then	//11.8.2023 navlc30 #59489
		app.raiseCMException(Code_Is_Invalid , ETRow_Code, null);
	endif;
	//End 14.04.2023 navmp20 TFS 57583
	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', null, null);
		app.raiseCMException(Input_required_field_harbour, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
