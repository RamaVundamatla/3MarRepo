    <JadeMethod name="cmbBusinessUnit_click" id="eaa33274-64cd-48fc-92c5-ff90020bbe0c">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBusinessUnit_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2019	jlgmp6	Initial creation	TFS42015
28 Oct 2021 navma1  ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/

vars
	invLineType		: CM_InvoiceLineDesc;
	combo			: CMUI_ComboBox;
	businessUnit	: CM_Bank;

begin
	combo := self.cmbInvoiceLineType;
	combo.clear();
	
	businessUnit := self.cmbBusinessUnit.listObject.CM_Bank;
	
	if businessUnit &lt;&gt; null then
		foreach invLineType in businessUnit.invoiceLineDescriptors where not invLineType.isNotAvailableForEntry do
			combo.addItemObject(invLineType.narration, invLineType);
		endforeach;
		self.cmbInvoiceLineType.listIndex := 1;
	endif;
	
epilog
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBusinessUnit_displayEntry" id="471779b6-dfae-48f2-90ec-8658a10f02f1">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBusinessUnit_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2019	jlgmp6	Initial creation

*/

vars

begin
	if obj = null then
		return null;
	endif;
	return obj.CM_Bank.code;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminal_click" id="facc0654-5641-4b1f-a679-86726d426ded">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2019	jlgmp6	Initial creation

*/

vars
	company			: CM_Bank;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
	terminal		: CM_Terminal;
begin
	
	combo := self.cmbBusinessUnit;
	combo.clear();
	self.allBusUnitsForTerminal.clear();
	terminal := self.cmbTerminal.listObject.CM_Terminal;
	currentBU := terminal.getAvailableCompanies(self.allBusUnitsForTerminal);
	combo.listCollection(self.allBusUnitsForTerminal, false, 0);

	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;

	self.cmbBusinessUnit_click(combo);
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
