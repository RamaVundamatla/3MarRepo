    <JadeMethod name="setupForm" id="395ca143-73fa-4224-be82-96abed7fa273">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	index : Integer;
	entTableDef	: EntTableDef;

begin

	self.caption := ( app.getErrorString(Vehicle_enquiry));
	self.weightType := app.getDefaultMeasurementForType(Type_Weight);

	self.setUpCombos();
	
	setupInputTable();
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupInputTable" id="a443c9a0-b7b0-4443-a8e5-8b1c9e7b0cab">
        <updating/>
        <source>setupInputTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	entTableDef	: EntTableDef;

begin

	self.tblInput1.left := 0;
	self.tblInput1.top := 0;
	self.tblInput1.height := self.tblInput1.parent.height;
	self.tblInput1.width := self.tblInput1.parent.width;
	self.tblInput1.parentAspect := 3;	//stretch both;
	
	self.tblInput1.rows := 0;
	entTableDef := app.myController.getEntTableDef( ETDef_VehicleMaint );
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; ETDef_VehicleMaint &amp; ') not found');
		return;
	endif;
	
	self.tblInput1.setEntTableDef( entTableDef, null, 'entTableDefSetupWarning' );
	
	self.tblInput1.hideRowByName( ETRow_NumberOfVisits, false );
	self.tblInput1.hideRowByName( ETRow_LatestVisitDate, false );
	
	self.resetMeasurementRows(self.tblInput1);																	
	self.loadMeasurementTypes(self.tblInput1, entTableDef.name, entTableDef.allEntTableRows, true);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="2160ff9a-d549-4815-b9c4-ceaaa4262929">
        <updating/>
        <source>showThumbnailData(_vehicle : CM_Vehicle) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars
	
	
	carrier : CM_Carrier;
	isNotAvailableForEntry : Boolean;
	regNumber : String;
	state : String;
	tareKilos : Decimal[14,4];
	maxGrossLadenWeight : Decimal[12,2];

begin

	if _vehicle &lt;&gt; null then
		carrier := _vehicle.carrier;
		isNotAvailableForEntry := _vehicle.isNotAvailableForEntry;
		regNumber := _vehicle.regNumber;
		state := _vehicle.state;
		tareKilos := _vehicle.tareKilos;
		maxGrossLadenWeight := _vehicle.maxGrossLadenWeight;
	endif;
	
	self.resetMeasurementRows(self.tblInput1);																	
	self.loadMeasurementTypes(self.tblInput1, self.tblInput1.myEntTableDef.name, self.tblInput1.myEntTableDef.allEntTableRows, true);

	self.tblInput1.setValueByName(ETRow_RegNumber, regNumber);
	self.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, isNotAvailableForEntry);
	self.tblInput1.setValueByName(ETRow_State, state);
	
	if carrier &lt;&gt; null then
		self.tblInput1.setValueByName(ETRow_Carrier, carrier.code &amp; "      " &amp; carrier.description);
		self.cmbCarrier.listIndex := self.cmbCarrier.findObject( carrier);
	else
		self.tblInput1.setValueByName(ETRow_Carrier, null);
		self.cmbCarrier.listIndex := -1;
	endif;

	self.setConvertedDisplayValue( self.tblInput1, ETRow_TareKilos,  tareKilos, self.weightType );
	self.setConvertedDisplayValue( self.tblInput1, ETRow_MaxGrossLadenWeight, maxGrossLadenWeight, self.weightType );
	
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b5639274-e309-451c-b997-bfcc0fa35819">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 November 2017 16:07:37.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022160, locale);
	mnuWeighVehicle.translateCaption(Xlat_0022161, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zDoDelete" id="fb72ffba-465b-4c15-a593-ea9041476ad1">
        <updating/>
        <source>zDoDelete() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
		self.multiSelect := CM_BaseTable.MultiSelect_Simple;
	endif;
	
	inheritMethod();

epilog

	self.multiSelect := CM_BaseTable.MultiSelect_None;
	self.allowMultiSelectDelete := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
