    <JadeMethod name="hasNotFailedforTwinLift" id="c804c9fb-01d7-478c-a440-31d35440c03e">
        <condition/>
        <source>hasNotFailedforTwinLift():Boolean condition;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2009	cnwer1	Initial creation

*/



begin
	return self.failedForTwinLift = false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="c4e6471c-8266-4622-8f33-14f702fd1297">
        <updating/>
        <source>init(_ti : CM_TrackedItem;
		_order : Integer; 
		_gridTA : String;
		_gridRow,
		_gridCol,
		_gridPos : Integer;
		_matchComm, _matchHaz, _matchWater, _matchRest, _matchWeight, _matchODim : Boolean;
		_cmifSlotRequest : CMIF_ShipPlanningSlotRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars

begin
	self.myTrackedItem:=_ti;
	
	self.matchesCommodityGroup:=false;
	self.matchesHazardous:=false;
	self.matchesODim := false;
	self.matchesWaterCooled:=false;
	self.matchesWeight:=false;
	self.matchesRest:=false;
	
	if self.matchesODim then
		self.matchesODim := _matchODim;
	elseif _matchComm then
		self.matchesCommodityGroup:=_matchComm;
	elseif _matchHaz then
		self.matchesHazardous:=_matchHaz;
	elseif _matchWater then
		self.matchesWaterCooled:=_matchWater;
	elseif _matchRest then
		self.matchesRest:=_matchRest;
	endif;
	
	self.matchesWeight:=_matchWeight;
	self.order:=_order;
	self.gridTA:=_gridTA;
	self.gridOrdRow:=_gridRow;
	self.gridOrdCol:=_gridCol;
	self.gridOrdStackPos:=_gridPos;
	self.myShipPlanningSlotRequest:=_cmifSlotRequest;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_gridTA" type="String"/>
        <Parameter name="_gridRow" type="Integer"/>
        <Parameter name="_gridCol" type="Integer"/>
        <Parameter name="_gridPos" type="Integer"/>
        <Parameter name="_matchComm" type="Boolean"/>
        <Parameter name="_matchHaz" type="Boolean"/>
        <Parameter name="_matchWater" type="Boolean"/>
        <Parameter name="_matchRest" type="Boolean"/>
        <Parameter name="_matchWeight" type="Boolean"/>
        <Parameter name="_matchODim" type="Boolean"/>
        <Parameter name="_cmifSlotRequest" type="CMIF_ShipPlanningSlotRequest"/>
    </JadeMethod>
