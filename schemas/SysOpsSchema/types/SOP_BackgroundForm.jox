    <JadeMethod name="tblRequest_contextMenu" id="093f4d92-bc9a-4d7a-a00e-c62296ed8be6">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRequest_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

// cnwdvb1 17 February 2003 

vars

begin
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	//epr TFS 4474 1/6/17 get the clear request to work with future actors
	self.mnuProcessRequest.visible:=true;
	self.mnuClear.visible:=true;
	self.mnuClearSingleRequest.visible:=true;
	if self.myBGPObject.isKindOf(BGP_FutureTimerController) then
		self.mnuClear.visible:=false;
	endif;
	return self.showContextMenu(mnuRequests, cntrl, conwin, mouse, x, y);
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblRequest_dblClick" id="9dead288-1b01-4a8f-965c-47d015e95f24">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRequest_dblClick(table: Table input) updating;

// cnwdvb1 17 February 2003 
 // TFS 2937 
vars
	theRow	: Integer;
begin


	//self.selectRequest(table.row, true);
	
	theRow := table.row;
	
	if theRow &gt; table.fixedRows then
		self.selectRequest(table.row, true);
		return;
	endif;
	


	if self.tblRequest.sortColumn[1] &gt; 0 then
		self.tblRequest.accessCell(1,self.tblRequest.sortColumn[1]).fontBold := false;
	endif;

	self.tblRequest.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="67424fb0-cd77-447f-adfb-fab685d87557">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Refresh any objects in the table that have been notified as updated

Parameters:			Timer event tag

Return Value:		None

Date		Who		Reason
29 Nov 2011	cnwkpd1	PAR #28753 - BGP form performance issues

*/

vars
	bgpObject		: BGP_Object;
	iter			: Iterator;
	invalid			: Boolean;
	edition			: Integer;
	
begin
	executeWhen JMTDevelopmentEnvironment;
	app.writeLog(method.qualifiedName &amp; ", eventTag="&amp;eventTag.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	endExecuteWhen;

	if eventTag = self.Notify_Timer_Event then
		on Exception do app.handleDeletedObject(exception, bgpObject, invalid);
		
		iter := self.allNotifiedBGPObjects.createIterator();
		while iter.next(bgpObject) do
			executeWhen JMTDevelopmentEnvironment;
			app.writeLog(method.qualifiedName &amp; ", bgpObject="&amp;bgpObject.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			endExecuteWhen;

			self.refreshBGPObject(bgpObject);
		endwhile;
		
		// If there were any objects not valid, then refresh the entire display
		if invalid then
			self.doDisplay();
		endif;
	endif;
	
epilog
	delete iter;
	if eventTag = self.Notify_Timer_Event then
		self.notesTimerStarted := false;
		self.allNotifiedBGPObjects.clear();
	endif;
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="42a51fab-4cbc-4a98-ae3e-7afd7a4bc5ae">
