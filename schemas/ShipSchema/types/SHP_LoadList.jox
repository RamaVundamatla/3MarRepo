    <JadeMethod name="allowsTableFilters" id="299f6492-625e-4fae-9056-008e67bba4af">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 25297

*/

vars

begin
	
	if _table = self.tblData
	or _table = self.tblPlanned
	or _table = self.tblDLR
	or _table = self.tblAll
	or _table = self.tblTranShip
	or _table = self.tblTBA // TFS 45590
	then
		return true;
	endif;	

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="3678b532-3e5b-4d3b-bf58-50ef69f90cae">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io):Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 25297

*/

vars

	visibleCount : Integer;

begin
	
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
			self.setFormCaption();
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
