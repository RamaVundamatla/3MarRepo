    <JadeMethod name="isRotatedLoadLayer" id="99655529-6485-413c-9472-48b4c09a9016">
        <source>isRotatedLoadLayer() : Boolean;
/*
Purpose:			
Date		Who		Reason
16 March 2012	cnwab1	Initial creation
*/

vars

begin
	if self.myLayout &lt;&gt; null
	and self.myLayout.myDeckLayer &lt;&gt; null then
		if self.myLayout.myDeckLayer.type = ROROLayerType_CCLoad then
