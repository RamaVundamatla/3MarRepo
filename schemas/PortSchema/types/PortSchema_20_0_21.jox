    <JadeMethod name="convertInvRoundLineTotalConfig" id="5dc62322-64cc-497f-b5f7-02adfe4dba3d">
        <source>convertInvRoundLineTotalConfig(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form

*/

vars
	term : CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Converting 'InvoiceRoundLineTotal' From Boolean to Integer", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting 'InvoiceRoundLineTotal' From Boolean to Integer'") ;	
	endif;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		if term.getConfig(InvoiceRoundLineTotal).Boolean then
			term.setConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_Zero );	// InvLineRound_Value_Zero   = 0
		else
			term.setConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound );	//InvLineRound_Value_NoRound = 6
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Converting 'InvoiceRoundLineTotal' From Boolean to Integer Complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting 'InvoiceRoundLineTotal' From Boolean to Integer Complete") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog

end;</source>
