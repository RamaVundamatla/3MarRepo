    <JadeMethod name="getArrivalAtGateInTime" id="ab231005-78a8-4939-bb76-2d020cfb9425">
        <source>getArrivalAtGateInTime() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     02 April 2008 by cnwrs2
//
// Purpose:     Used from Report Writer
// ---------------------------------------------------------------------------
/* 	Date		User	Reason
   ---------------------------------------------------------------------------
	19/05/2009	concms1	Par 19715 - Changed code to be compatible with changed collection keys
	06/06/2014	cnwdap1	PAR #34297 Cater for sites that don't have a P-Gate in, but only have an A-Gate
*/
vars
	tmpDtl		: CM_VehicleVisitRecordDetail;
	timeAtGate	: TimeStamp;											// PAR #34297
	
begin
	timeAtGate := null;													// PAR #34297
	foreach tmpDtl in self.allVehicleVisitRecordDetails do
		if tmpDtl.recordType = VisitRecord_Arrive_PGate_In then
			// return first in-gate (arrive p-gate (in)) that we find
			//return tmpDtl.timeStart;									// PAR #34297
			timeAtGate := tmpDtl.timeStart;								// PAR #34297
			break;														// PAR #34297
		endif;
	endforeach;
	
	if timeAtGate = null then											// PAR #34297
		foreach tmpDtl in self.allVehicleVisitRecordDetails do			// PAR #34297
			if tmpDtl.recordType = VisitRecord_Arrive_AGate then		// PAR #34297
				timeAtGate := tmpDtl.timeStart;							// PAR #34297
				break;													// PAR #34297
			endif;														// PAR #34297
		endforeach;														// PAR #34297
	endif;																// PAR #34297
	
	//return null;														// PAR #34297
	return timeAtGate;													// PAR #34297
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
