    <JadeMethod name="timerEvent" id="ae8b0cdc-4449-4bd7-a33f-87630b6c8b87">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.updateTableElapsedTimes();
		self.beginTimerForRefresh();
	endif;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
