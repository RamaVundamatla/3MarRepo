    <JadeMethod name="create" id="5a36cd69-1fa4-4404-b07d-59af57803768">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.permissionView  := PmGteMTReleaseView;
	self.permissionMaint := PmGteEmptyReleaseMaintAll;
	
	self.helpFileName := HelpFile_Gate;

end;</source>
