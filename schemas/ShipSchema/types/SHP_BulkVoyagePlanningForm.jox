    <JadeMethod name="initProgressDialog" id="1f5ab652-cae0-416a-93b3-e012d0f67a7c">
        <updating/>
        <source>initProgressDialog(_msg : String)updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	voyage : CM_Voyage;
	tmpStr : String;

begin
	voyage := self.myCurrentVoyage;
	
	if voyage &lt;&gt; null then
		tmpStr := self.myCurrentVoyage.code &amp; " - " &amp; self.myCurrentVoyage.vesselName;
