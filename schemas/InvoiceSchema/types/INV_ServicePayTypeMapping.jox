    <JadeMethod name="setTableAlignment" id="3036acb6-c789-49fc-ab56-e135ec8db8ab">
        <source>setTableAlignment();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	saveRow:    Integer;
	saveColumn: Integer;
	row:        Integer;
	rateTable : Table;

begin
	rateTable := self.tblData;

	saveRow := rateTable.row;
	saveColumn := rateTable.column;

	rateTable.accessMode := Table.AccessMode_Sheet;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.accessMode := Table.AccessMode_Column;
	rateTable.column := 1;
	rateTable.alignment := Table.Alignment_Left;

	rateTable.accessMode := Table.AccessMode_Row;
	row := 1;
	while row &lt;= rateTable.fixedRows do
		rateTable.row := row;
		rateTable.alignment := Table.Alignment_Left;
		row := row + 1;
	endwhile;

	rateTable.accessMode := Table.AccessMode_Cell;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.row := saveRow;
	rateTable.column := saveColumn;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="469c3023-1567-44d7-ac93-503b11accffd">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281
19 Oct     2018 cnwma1 ChangeRequest 41281: PEL1 - Payment Method on Services
*/

vars
	aDate : Date;
	
begin
	self.useCtrlScroll := true;
	
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
//	self.mode := self.Mode_Debtor;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.usesQueryFrame := true;
	self.useTableInfo := false;
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.mnuInvUpdate.visible := true;
	
	self.mnuInvUpdate.visible := false;
	self.doCmbBankBuild();
	
	inheritMethod();

	self.fldQuery.topSheet := self.shtQuery1;
	self.doComboDebtorBuild();
	self.doCmbDebtorBuild();                   
//	self.doCmbPaymentTypesBuild(null);
	self.doCmbServicesBuild();
	self.loadLines();
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE), Response_Continuous, null);
	
	self.setNavigatorHeading( self.caption );
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled:= false;
	endif;
	
	self.lblRefresh.visible := false;	//12 Dec 2018	NDL	TFS 42060
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="855b2148-13f2-4e2e-a57e-feaaaf328793">
        <source>showPropertyFrame();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	theFrame : Frame;
	
begin

	self.cmbDebtors.enabled := false;
	self.cmbServices.enabled := false;
	
	// do not show the debtors current default
	self.doCmbPaymentTypesBuild(self.myCurrentDebtor.CM_Debtor);

	theFrame := self.frmProperties;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3a65e290-5a04-4a56-8235-a08b68485a43">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 December 2018 08:08:51.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023029, locale);
	btnPropCancel.translateBubbleHelp(Xlat_0023030, locale);
	btnPropCancel.translateCaption(Xlat_0023031, locale);
	btnPropDelete.translateCaption(Xlat_0023032, locale);
	btnPropSave.translateBubbleHelp(Xlat_0023033, locale);
	btnPropSave.translateCaption(Xlat_0023034, locale);
	btnRefresh.translateBubbleHelp(Xlat_0023035, locale);
	btnRefresh.translateCaption(Xlat_0023036, locale);
	lblBank.translateCaption(Xlat_0023037, locale);
	lblDebtor.translateCaption(Xlat_0023038, locale);
	lblDebtorQ.translateCaption(Xlat_0023039, locale);
	lblPaymentType.translateCaption(Xlat_0023040, locale);
	lblRefresh.translateCaption(Xlat_0023123, locale);
	lblService.translateCaption(Xlat_0023041, locale);
	mnuAudits.translateCaption(Xlat_0023042, locale);
	mnuViewAudits.translateCaption(Xlat_0023043, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="0abd6116-83c8-4079-93e7-b7d9e2beaf9e">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _obj: CM_Object; _anyObject: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	paymentTypeMapping : CM_ServicePayTypeMapping;
	debtor : CM_Debtor;
	service : CM_Service;
	paymentType : Integer;
	idx : Integer;
	row : Integer;
	column : Integer;
	//defaultPaymentType : Integer;
	mapTable : Table;

begin

	if _anyObject = null then
		return;
	endif;
	if not _anyObject.isKindOf(CM_ServicePayTypeMapping) then
		return;
	endif;
	
	mapTable := self.tblData;
	
//	str := self.myService.getOidString &amp; "," &amp; self.myDebtor.getOidString;
//	term.causeEvent( term.getTerminalEvent(EVENT_MAPPING_DELETE), false, str );
	if _event = EVENT_MAPPING_DELETE then
		self.tblData.findObjectInCell( _anyObject, row, column );
		if row &gt; 0 then
			service := mapTable.accessRow(row).itemObject.CM_Service;
		endif;
		if column &gt; 0 then
			debtor := mapTable.accessColumn(column).itemObject.CM_Debtor;
		endif;
		
		paymentType := service.getPaymentType( debtor );
		
		if paymentType &lt;&gt; null then
			mapTable.accessCell(row,column).text := app.paymentTypeEnumToString( paymentType );
		else
			mapTable.accessCell(row,column).text := app.paymentTypeEnumToString( PaymentType_None );
		endif;
		mapTable.accessedCell.fontBold := false;
		mapTable.accessedCell.foreColor := DarkGray;
		mapTable.accessedCell.itemObject := null;
		
	endif;

	if _anyObject &lt;&gt; null 
	and (_event = EVENT_MAPPING_UPDATE or _event = EVENT_MAPPING_CREATE ) then
		paymentTypeMapping := _anyObject.CM_ServicePayTypeMapping;
		debtor := paymentTypeMapping.myDebtor;
		service := paymentTypeMapping.myService;
		//defaultPaymentType := service.getPaymentType( null );	
		paymentTypeMapping := service.bank.getServicePayTypeMapping( service, debtor, false );// the specific one for this debtor only.
		if paymentTypeMapping &lt;&gt; null then
			paymentType := paymentTypeMapping.paymentType;
		else
			paymentType := 0;
		endif;
		
		self.tblData.findObjectInRow(service,row);
		self.tblData.findObjectInColumn(debtor,column);

		if row &gt; 0 and
		   column &gt; 0 then
			self.tblData.accessCell(row,column).text :=  app.paymentTypeEnumToString(paymentType) ;
			if paymentTypeMapping &lt;&gt; null then
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
			else
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
			endif;
			self.tblData.accessedCell.itemObject := paymentTypeMapping;
		endif;
		return;
	endif;

epilog

	if debtor &lt;&gt; null and debtor.isKindOf( CM_VoidDebtor ) then
		self.lblRefresh.visible := true;	//12 Dec 2018	NDL	TFS 42060
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_anyObject" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
