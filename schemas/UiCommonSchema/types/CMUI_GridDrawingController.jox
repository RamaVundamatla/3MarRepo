    <JadeMethod name="translateRectanglePoints" id="7ddee257-fef3-4c5b-9f1e-3ef1c280192d">
        <source>translateRectanglePoints(_x1, _y1, _x2, _y2 : Real io; _originx, _originy : Real) protected;

/*

Purpose:			
	Translate the given rectanle points so that the top left of the rectangle is moved to _originx, _originy 
Parameters:			
		_x1			: Top-left x of rectangle
		_y1 		: Top-left y of rectangle
		_x2 		: Bottom-right x of rectangle
		_y2 		: Bottom-right y of rectangle
		_originx	: top-left x of destination rectangle 
		_originy	: top-left y of destination rectangle 
Return Value:		


Date		Who		Reason
01 December 2009	cnwjk3	ccms 1018

*/

vars
	xdif,
	ydif	: Real;
begin
	xdif := (_originx - _x1).abs();
	ydif := (_originy - _y1).abs();

	
	if _x1 &gt; _originx then
		_x1 := _x1 - xdif;
		_x2 := _x2 - xdif;
	else
		_x1 := _x1 + xdif;
		_x2 := _x2 + xdif;
	endif;

	if _y1 &gt; _originy then
		_y1 := _y1 - ydif;
		_y2 := _y2 - ydif;
	else
		_y1 := _y1 + ydif;
		_y2 := _y2 + ydif;
	endif;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
        <Parameter name="_originx" type="Real"/>
        <Parameter name="_originy" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateColourFromNote" id="dbe19874-56a0-4833-9b6a-8bf4527270f0">
        <updating/>
        <source>updateColourFromNote(theObject: Object;theCode : String;theColour : Integer;viewModeIndex : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theXML : String;
	aGridAttribute : CMUI_GridAttributes;
	doDrawSelf : Boolean;
	ldisplayMode,lviewMode : Integer;

begin
/*			
	ldisplayMode := self.displayMode;
	lviewMode := self.myGridArea.mySDF.viewMode;
	if viewModeIndex &gt; 0 then
		// ### REAL
		foreach aGridAttribute in self.allTrackedItemAttributes do
			if aGridAttribute.allDisplayObjects[viewModeIndex] = theObject then
				aGridAttribute.allDisplayColors[viewModeIndex] := theColour;
//if process.isCnwab1 then				
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. ldisplayMode " &amp; ldisplayMode.String &amp; " viewMode " &amp; viewMode.String &amp; " viewModeIndex " &amp; viewModeIndex.String);
//endif;
				if ldisplayMode = DISPLAY_MODE_ACTUAL and lviewMode = viewModeIndex then
					doDrawSelf := true;
				endif;
			endif;
		endforeach;
		// ### PLANNED
		foreach aGridAttribute in self.allPlanTrackedItemAttributes do
			if aGridAttribute.allDisplayObjects[viewModeIndex] = theObject then
				aGridAttribute.allDisplayColors[viewModeIndex] := theColour;
				if ldisplayMode = DISPLAY_MODE_PLAN and lviewMode = viewModeIndex then
					doDrawSelf := true;
				endif;
			endif;
		endforeach;
		// ### QUEUED
		foreach aGridAttribute in self.allQueuedTrackedItemAttributes do
			if aGridAttribute.allDisplayObjects[viewModeIndex] = theObject then
				aGridAttribute.allDisplayColors[viewModeIndex] := theColour;
				if ldisplayMode = DISPLAY_MODE_QUEUE and lviewMode = viewModeIndex then
					doDrawSelf := true;
				endif;
			endif;
		endforeach;
	endif;
*/
	return doDrawSelf;
end;</source>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="theCode" type="String"/>
        <Parameter name="theColour" type="Integer"/>
        <Parameter name="viewModeIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="aed1a2ac-25cb-4498-80a1-964f8d7aeb2a">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theMode		: Integer;
	userInfoStr		: String;
	noteRecord		: CMIF_NotificationRecord;
begin
	if self.currentlyMinimised then
		if userInfo.isKindOf(Object) then
			//userInfoStr := userInfo.Object.getOidString();
			userInfoStr := self.getOidStringForObject(userInfo.Object);
		else
			userInfoStr := userInfo.String;
		endif;
		
		noteRecord := self.allNotificationsReceived[eventType, theObject, eventTag, userInfoStr];
		if noteRecord = null then
			create noteRecord transient;
			noteRecord.eventType := eventType;
			noteRecord.myObject := theObject;
			noteRecord.eventTag := eventTag;
			noteRecord.userInfoString := userInfoStr;
			allNotificationsReceived.add(noteRecord);
		endif;
		
		return;//processed when minimised state ends
	endif;
	
	if eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate)
	or eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate)
	or eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate) then
		self.userNotificationYardAllocation(eventType, theObject, eventTag, userInfo);
	endif;
	
	if eventType = EVENT_CODE_COLOUR_CHANGE then
		theMode := userInfo.Integer;
		if theMode = self.viewMode then
			if self.allTerminalAreas.isEmpty() then
				self.drawSelf(false);
			else
				self.drawSelfALL();
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationYardAllocation" id="39f10182-7f8a-494b-8552-9a3567fb5187">
        <updating/>
