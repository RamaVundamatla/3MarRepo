    <JadeMethod name="changeEncoding" id="81fd864a-1ce8-46d5-ba8e-f398b6e7adde">
        <source>changeEncoding(controlName : String) protected;

begin
	if controlName = optNoEncode.name then
		if optNoEncode.value = true then
			txtUserEncoded.text := "";
		endif;
	elseif controlName = optBase64.name then
		if optBase64.value = true then
			txtUserEncoded.text := "";
		endif;
	elseif controlName = txtUserEncoded.name then
		if txtUserEncoded.text.trimBlanks &lt;&gt; "" then
			optNoEncode.value := false;	
			optBase64.value := false;
		endif;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="controlName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createEmail" id="4fcd9f00-bef1-4ccd-a0fd-a62255bca542">
        <updating/>
        <source>createEmail() updating, protected;

vars
	emailObj			: CnEcEmail;
	errorMsg			: String;
	ts					: TimeStamp;
	attachmentsArray	: StringArray;
	arrayPos			: Integer;
	contentType			: String;
	encodeType			: String;
	
begin
	create attachmentsArray transient;
	
	if lstAttachments.listCount &gt; 0 then
		foreach arrayPos in 1 to lstAttachments.listCount do
			attachmentsArray.add(lstAttachments.itemText[arrayPos]);
		endforeach;
	endif;
	
	if optNoEncode.value then
		encodeType := CnSmtpConnection.None;
	elseif optBase64.value then
		encodeType := CnSmtpConnection.Base64;
	elseif txtUserEncoded.text &lt;&gt; "" then
		encodeType := txtUserEncoded.text;
	endif;
	
	if optPlain.value then
		contentType := CnSmtpConnection.Plain;
	elseif optHtml.value then
		contentType := "html";
	endif;
	
	errorMsg := self.aMyTA.trxCnEcEmailCreate(	self.aMyEmailBaseData,	//pCnEcEmailBaseDataParent : CnEcEmailBaseData io;
												attachmentsArray,	//pAllAttachmentsArray:StringArray;
												txtBcc.text,	//pBccList:String;
												txtCc.text,	//pCcList:String;
												contentType,	//pContentType:String;
												encodeType,	//pEncodingType:String;
												txtMessage.text,	//pMessageBody:String;
												//txtMessage.textRTF.trimBlanks(),
												txtSubject.text,	//pMessageHeader:String;
												self.aMyEmailBaseData,	//pMyEmailBaseData:CnEcEmailBaseData;
												ts,	//pSentTime:TimeStamp;
												txtTo.text,	//pSentTo:String;
												emailObj	//pCnEcEmailNew : CnEcEmail output
												);
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, "Error", MsgBox_OK_Only);
	else
		self.sendEmail(emailObj);
	endif;
epilog
	delete attachmentsArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteAttachment" id="ad3432b3-c9e9-4b47-805a-a00746947cf2">
        <source>deleteAttachment() protected;

vars
	listPointer	: Integer;
	
begin
	listPointer	:=	lstAttachments.listIndex;
	
	if listPointer &gt; 0 then
		lstAttachments.removeItem(listPointer);
	endif;
	
	btnDelAttach.enabled := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteMyLastEmail" id="afbe09c5-ccda-4a8e-8eaf-9d17956070e8">
        <updating/>
        <source>deleteMyLastEmail() updating, protected;

vars
	errorMsg : String;
	
begin
	errorMsg := self.aMyTA.trxCnEcEmailDelete(self.aMyLastEmail);
		
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
	else
		self.aMyLastEmail := null;		
	endif;	
  
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="d9aab079-ec44-460e-9452-48482da9d7fd">
        <updating/>
        <source>doFormLoad() updating, protected;

vars
	agentObj		: CnEcEmailAgent;
	emailRootObj	: CnEcEmailRoot;
	emailRootNewObj	: CnEcEmailRoot;
	formObj			: CnEcEmailBaseDataForm;
	errorMsg		: String;
	
begin
	self.allowClose := false;
	self.centreWindow();

	create agentObj transient;
	self.aMyTA	:=	agentObj;
	
	emailRootObj	:=	CnEcEmailRoot.firstInstance();
	
	if not app.isValidObject(emailRootObj) or emailRootObj = null then
		errorMsg := self.aMyTA.trxCnEcEmailRootCreate(emailRootNewObj);
		if errorMsg &lt;&gt; null then
			app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
		else
			emailRootObj	:=	emailRootNewObj;
			errorMsg		:=	self.aMyTA.trxCnEcEmailBaseDataDefault(emailRootObj);
			
			if errorMsg &lt;&gt; null then
				app.msgBox(errorMsg, "Error", MsgBox_OK_Only);
			endif;
		endif;
	endif;
	
	self.aMyEmailBaseData	:=	emailRootObj.getEmailBaseData(app.computerName());
	
	if self.aMyEmailBaseData = emailRootObj.myDefaultBaseData then
		create formObj;
		formObj.showModal();
		
		self.aMyEmailBaseData	:=	emailRootObj.getEmailBaseData(app.computerName());
	endif;
	
	self.populateAddressPersonList();
	self.initializeForm();
	self.setStatusLine(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="dropAddress" id="38cfe105-9e83-4bc3-b421-c0b0e8854d9a">
        <source>dropAddress(textbox: CnEcTextBox io; index : Integer) protected;

vars
	emailAddressObj	: CnEcEmailAddress;
	
begin
	if index &gt; 0 then
		emailAddressObj	:=	lstAddressPerson.itemObject[index].CnEcEmailAddress;
		
		if emailAddressObj &lt;&gt; null then 
			self.putAddressInTextbox(textbox, emailAddressObj.emailAddress);
		endif;			
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="textbox" type="CnEcTextBox" usage="io"/>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAddress" id="dd8d9b50-29b3-4ab2-9e48-c1153f5ba072">
        <source>getAddress(pTextBoxObj : CnEcTextBox io) protected;

vars
	formObj			: CnEcEmailAddressesForm;
	firstValue		: String;
	secondValue		: String;
	
begin
	create formObj;
	formObj.aMyEmailSendForm	:=	self;
	formObj.showModal();
	
	if self.aSelectedPersonAddress &lt;&gt; "" then
		self.putAddressInTextbox(pTextBoxObj, aSelectedPersonAddress);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTextBoxObj" type="CnEcTextBox" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAttachment" id="cfa85ada-0b50-45e1-b0d5-dba6aa4b1887">
        <source>getAttachment() protected;

vars
	fileOpenObj	: CMDFileOpen;
	
begin
	create fileOpenObj;
	
	if fileOpenObj.open = 0 then
	    lstAttachments.addItem(fileOpenObj.fileName);
	endif;
epilog
	delete fileOpenObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeForm" id="576cbc4b-ee7a-4897-9fe9-9c276a038685">
        <source>initializeForm() protected;

begin
	lstAttachments.clear();
	btnDelAttach.enabled	:=	false;
	txtTo.text				:=	"";
	txtCc.text				:=	"";
	txtBcc.text				:=	"";
	txtSubject.text			:=	self.aEmailSubject;
	txtMessage.text			:=	self.aEmailBody;
	optNoEncode.value		:=	true;
	optPlain.value			:=	true;
	
	self.populateBaseDataLabel();		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="3ed4b74c-ba6d-4d4b-adbd-21d1c6aa819c">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	inheritMethod();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
