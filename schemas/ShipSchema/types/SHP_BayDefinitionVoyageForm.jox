    <JadeMethod name="underDeckCellChange" id="1bf55bbb-8446-4cc6-b98c-c9112915e165">
        <updating/>
        <source>underDeckCellChange() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTierOrder : String;
begin
	
	theTierOrder := self.txtOnDeckTier.text;
		
	if self.validateTierCellLabels('On Deck Tiers', theTierOrder) then
		self.doBuildComboBayString(self.cmbLashFrom,theTierOrder);
		self.doBuildComboBayString(self.cmbUnlashFrom,theTierOrder);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="7f075e70-15d4-4dc4-8427-8e2d0166e996">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.unloadForm();
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="3bd0eaad-3b26-411a-836c-7c528669e55e">
        <updating/>
        <source>unloadForm() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myProxyVoyage &lt;&gt; null then
		if global.isValidObject(self.myProxyVoyage) then
			if self.myProxyVoyage.isTransient then
				delete self.myProxyVoyage;
			endif;
		endif;
	endif;
	if self.myCurrentVoyage &lt;&gt; null then
		if global.isValidObject(self.myCurrentVoyage) then
			if self.myCurrentVoyage.isTransient then
				delete self.myCurrentVoyage;
			endif;
		endif;
	endif;
	if self.myCurrentBay &lt;&gt; null then
		if global.isValidObject(self.myCurrentBay) then
			if self.myCurrentBay.isTransient then
				delete self.myCurrentBay;
			endif;
		endif;
	endif;
	
	return inheritMethod();	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="954abe21-cfb9-4c31-8afe-7dd878c0b99f">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
//--------------------------------------------------
// Created:	02 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_cmifMonitor);
	self.pbProgressBar.doWindowEvents(0);
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTierCellLabels" id="0e29fb05-0ac7-4478-a115-bbb3c43ef527">
        <updating/>
        <source>validateTierCellLabels(_theHeading : String; _theValue : Any) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aLabel : String;
	theLabels : StringArray;
	idx : Integer;
begin
	aLabel := _theValue.String;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	idx := 0;
	
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		if aLabel.trimBlanks.length &gt; 2 then
			app.msgBox("The " &amp; _theHeading  &amp; " Label '" &amp; aLabel &amp; "' Is Too Long." 
				&amp; Cr &amp; "Labels Cannot Be Longer Than 2 Characters.",_theHeading &amp; " Label Error", MsgBox_OK_Only);
			return false;
		endif;
		if not aLabel.trimBlanks.isInteger then
			app.msgBox("The " &amp; _theHeading  &amp; " Label '" &amp; aLabel &amp; "' Must Be A Number." 
				&amp; Cr &amp; "Labels Cannot Be Alpha Numeric or Longer Than 2 Characters.",_theHeading &amp; " Label Error", MsgBox_OK_Only);
			return false;
		endif;
		if aLabel.trimBlanks.length = 1 then
			app.msgBox("The " &amp; _theHeading  &amp; " Label '" &amp; aLabel &amp; "' Is Too Short "
				&amp; Cr &amp; "Labels Should Be 2 Characters Long, Zero Filled.",_theHeading &amp; " Label Error", MsgBox_OK_Only);
			return false;
		endif;
	endforeach;

	return true;
epilog
	delete theLabels;
end;</source>
        <Parameter name="_theHeading" type="String"/>
        <Parameter name="_theValue" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
