    <JadeMethod name="btnClearTable_click" id="58bbbb16-9e69-4a46-8d0b-904cd8965562">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearTable_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jun 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024
02 Aug 2024	navhl20	Bug 65397: MTN - 14072 error when clicking clear in Future Timer Enquiry
*/

vars
	form : CM_BaseForm;
begin
	//clear out the UI
	self.cmbTerminal.listIndex := 1;
	self.cmbRequestType.listIndex := 1;
	self.cmbCargoType.listIndex := 1;
	self.mskDateFrom.setDate(null);
	self.mskTimeFrom.setTime(null);
	self.mskDateTo.setDate(null);
	self.mskTimeTo.setTime(null);
	self.txtCargoId.text := null;
	self.chkRegex.value := false;		//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	self.chkPagination.value := false;		//navra1 - TFS 60149/Task 64732 - 25th June 2024
	
	//clear out the actual search criteria	
	self.searchCargoId := null;
	self.searchCargoIdRegex := false;	//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	self.searchTerminalCode := '';
	self.searchCargoTypeId := null;	
	self.searchRequestType := "";
	
	if self.tableUsingDisplayCollection then						//02.08.2024 navhl20 #65397
		self.filterTable.visible 	:= true;	
		self.chkPagination.left		:=250;
	endif;
	self.lblCount.caption		:= '0 table entries';				//02.08.2024 navhl20 #65397
	
	if self.searchFromDT = null then
		create self.searchFromDT transient;
	endif;
	self.searchFromDT.dateTime.setDate(null);
	self.searchFromDT.dateTime.setTime(null);
	
	if self.searchToDT = null then
		create self.searchToDT transient;
	endif;
	self.searchToDT.dateTime.setDate(null);	
	self.searchToDT.dateTime.setDate(null);
	
	//clear the table
	if self.paginationEnabled then
		self.offlineFutureActors.clear();
		self.tblRequests.displayCollection(self.offlineFutureActors, false, Table.DisplayCollection_Forward, null);	
		self.tableUsingDisplayCollection := true;
		self.paginationEnabled := self.chkPagination.value;			//02.08.2024 navhl20 #65397
	else
		self.tblRequests.rows := 1;
		self.offlineFutureActors.clear();
		form := self;	
		tblRequests.getDataAndDisplayRowsMultith(self.offlineFutureActors, true, form, true);
		self.tableUsingDisplayCollection := false;
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
