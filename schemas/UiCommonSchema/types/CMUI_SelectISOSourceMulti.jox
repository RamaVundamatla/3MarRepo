    <JadeMethod name="addString" id="830a2407-e465-4872-a400-22a19e90cd89">
        <source>addString(msg : String; item : String) : String protected;
//	concatenate items in the message with a comma between them
vars
	result	: String;
begin
	if msg = "" then
		result := item;
	else
		result := msg &amp; ", " &amp; item;
	endif;
	return result;
end;
</source>
        <access>protected</access>
        <Parameter name="msg" type="String"/>
        <Parameter name="item" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
