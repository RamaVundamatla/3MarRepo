    <JadeMethod name="getDeleteReason" id="c9a9a577-3de3-4eac-a7b2-abbdd28ad4b8">
        <source>getDeleteReason( _extraInfo : String ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
*/

vars
	inputBox : CMUI_InputBox;
	errorSet : CM_ErrorSet;
	result 	 : String;
begin
	app.mousePointer := MousePointer_Default;
	
	create inputBox transient;
	create errorSet transient;
	
	inputBox.init(	app.getErrorString( Cancellation ),app.getErrorString( Road_cancellati_reason) &amp; _extraInfo,
					'', 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	inputBox.myTerminal := self.myTerminal;
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return '';
	endif;
	
	result := inputBox.txtInput.text.String;
	app.mousePointer := MousePointer_HourGlass;
	return result;
epilog

end;</source>
        <Parameter name="_extraInfo" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
