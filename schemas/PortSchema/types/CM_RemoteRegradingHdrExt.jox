    <JadeMethod name="processExternal" id="32534c9d-e643-4496-8807-5cea1ad517b6">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

// cnwdvb1 27 March 2003 

vars

	response		: String;
	err				: Integer;
	errTxt			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;

begin
	
	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createRegradeDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return self.doBuildMessage(self.xmlResponse(err, errTxt));
			endif;
		endif;
		response := app.getErrorString1(Err_XML, 'Regrade');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="6406ad90-7dfa-4cdc-b44e-91da552a9183">
        <source>runProcess(_errorSet: CM_ErrorSet input; _isBackGround: Boolean): Boolean;

// cnwdvb1 31 March 2003 

vars

	regradeDetail	: CM_RemoteDataDtl;

begin

	foreach regradeDetail in self.allRemoteDataDtl where not regradeDetail.isProcessed do
		regradeDetail.CM_RemoteRegradingDtlExt.doRegrading(_errorSet);
	endforeach;
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
