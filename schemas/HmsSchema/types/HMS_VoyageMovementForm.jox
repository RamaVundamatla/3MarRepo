    <JadeMethod name="includeObject" id="c2bf5d5b-dc62-4ee1-8a88-5e1f2315444c">
        <updating/>
        <source>includeObject(_movement: HMS_VoyageMovement; _passport: CM_Passport): Boolean updating;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.filterMoveType &lt;&gt; null 
	and self.filterMoveType &lt;&gt; app.getErrorString(AnyType) then
		if _movement.moveType &lt;&gt; self.filterMoveType then
			return false;
		endif;
	endif;
	
	if self.filterDateTo &lt;&gt; null
	and self.filterDateTo.date.isValid then
		if _movement.occursOnDTNEW.date &gt; self.filterDateTo.date then
			return false;
		endif;
	endif;
	return true;

end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initComboBoxes" id="f1e6caf5-d499-4b5a-95d2-fa9fdf7c5b44">
        <updating/>
        <source>initComboBoxes()updating;
//--------------------------------------------------
// Created:	27 October 2005 By: cnwgd1
// Changed On	By			Reason
// ----------	--------	------------------------
// 17/07/2018	jlgdap1		TFS 39658 PEL1 Pilots vs Harbours
//--------------------------------------------------
vars
	assist 	: CMUI_Assistant;
	tug		: HMS_Tug;
	pilot 	: HMS_Pilot;
	
begin
	assist := self.myAssistant;
	assist.comboBoxHMSLineCompany(self.cmbLineCompany, null);
	assist.comboBoxHMSBerth(self.cmbToBerth, self.myTerminal.myHarbour, null, true);

	self.isDisplayByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	self.cmbShippingAgent.isDisplayByName := self.myTerminal.getConfig(ComboByNameAgent).Boolean;
	self.cmbShippingLine.isDisplayByName := self.myTerminal.getConfig(ComboByNameLine).Boolean;		
	self.cmbShippingAgent.initialise(false);
	self.cmbShippingLine.initialise(false);

	self.cmbHMSVoyage.listCollection(self.myTerminal.myHarbour.allVoyageData, true, 0);
	
	assist.comboBoxHMSTidalClass(self.cmbTidalClass, null);	
	//assist.comboBoxHMSPilot(self.cmbPilot, null);											// TFS 39685
//	assist.comboBoxHMSPilot(self.cmbPilot, null, self.myTerminal.myHarbour);				// TFS 39685
	assist.comboBoxHMSMaster(self.cmbMaster, self.myTerminal.myHarbour, null);			
	//assist.comboBoxHMSPilotLaunch(self.cmbPilotLaunch, null);								// TFS 39685
	assist.comboBoxHMSPilotLaunch(self.cmbPilotLaunch, null, self.myTerminal.myHarbour);	// TFS 39685
	self.cbxOrientTo.addItem(app.getErrorString(PortSideToBerth));
	self.cbxOrientTo.addItem(app.getErrorString(StarboardSideToBerth));

	self.cbxLaunchPosn.addItem(app.getErrorString(HMS_Along_Side));
	self.cbxLaunchPosn.addItem(app.getErrorString(On_Station));	

	self.cbxTugPosn.addItem(app.getErrorString(HMS_Along_Side));
	self.cbxTugPosn.addItem(app.getErrorString(On_Station));
	
	//self.lstTugs.displayCollection(self.myTerminal.myHarbour.allTugs, true, 0, null);
	foreach tug in self.myTerminal.myHarbour.allTugs	 where not tug.isNotAvailableForEntry  do	// 08/05/2008 cnwar2 #16702  // cnwma1  3/7/2014   CCMS SFW 1328
		self.lstTugs.accessRow(self.lstTugs.addItem(Tab &amp; tug.description &amp; ' (' &amp; tug.code &amp; ')')).itemObject := tug;
	endforeach;
	
	//30 Oct 2018	NDL	TFS 41662
	foreach pilot in app.myRoot.allPilots discreteLock where not pilot.isNotAvailableForEntry do
		if pilot.myCurrentHarbour &lt;&gt; self.myTerminal.myHarbour then			
			continue;															
		endif;
		self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="fea2e627-db53-4284-a27c-d1fe4823a54e">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
// 01 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 28 Mar 2024	navnk30	Bug 63130: ATD - Movement Maintnance Error 14050
// navcs2 10/02/2025 MTN-32989 MTN - From Date doesn't open Date selector when trying to add a resource to a voyage
vars
	now : TimeStamp;
	tmpTable : CM_DataTable;
begin

	self.canUpdateFull := app.myCurrentUserCan(self.myTerminal, PmHMSResUsedFull); // ### PAR 10579
	self.canUpdatePartial := app.myCurrentUserCan(self.myTerminal, PmHMSResUsedPartial); // ### PAR 10579
	self.canViewOnly := app.myCurrentUserCan(self.myTerminal, PmHMSResUsedView); // ### PAR 10579

	self.btnShippingLine.enabled := false;
	self.btnShippingAgent.enabled := false;	
	self.btnCancelMove.enabled := false;	//19 Nov 2018	NDL	TFS 42043
				
	self.lstWharfServices.stretchHeight := true;
	self.lstWharfServices.stretchWidth := true;
	lstWharfServices.hasTreeLines := true;
	lstWharfServices.hasPlusMinus := true;
	lstWharfServices.hasPictures := false;	
	
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

	tmpTable := self.tblPilotLaunch; // --&gt; TFS 44438
	tmpTable.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSMvmntPilotDetails));
	tmpTable.userInputEnabled := false;
	tmpTable.parentTopMargin := VerticalSpacing;
	tmpTable.tabKey := J_key_Tab; // &lt;-- TFS 44438	

	if app.myCurrentUserCan(self.myTerminal, Mod_Invoicing) then
		tmpTable := self.tblResUsed;
		self.shtWharfServices.visible := false;
		self.shtResources.visible := true;	
		tmpTable.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSResourceUsedMvOnly));			// navcs2 10/02/2025 MTN-32989 
		self.setColumnIndex();
		tmpTable.userInputEnabled := false;
		tmpTable.tabKey := J_key_Tab;
		if self.colQtyUnits &gt; 0 then			//28.03.2024 navnk30 #63130
			tmpTable.accessColumn(self.colQtyUnits).enabled := false;
		endif;
		if self.colInvNo &gt; 0 then				//28.03.2024 navnk30 #63130
			tmpTable.accessColumn(self.colInvNo).enabled := false;
		endif;
		if self.colUnitsUsed &gt; 0 then			//28.03.2024 navnk30 #63130
			tmpTable.accessColumn(self.colUnitsUsed).alignment := Table.Alignment_Right;		
		endif;		
	else
		self.shtWharfServices.visible := true;
		self.shtResources.visible := false;
	endif;
		
	self.setNavigatorHeading(self.caption);									
						
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="fafc7da5-4605-4d33-aae7-e238778f76c5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = J_key_Delete
	and self.fldMain.topSheet = self.shtResources
	and self.tblResUsed.userInputEnabled
	and self.tblResUsed.row &gt; self.tblResUsed.fixedRows
	and self.tblResUsed.accessRow(self.tblResUsed.row).enabled
	and app.isControlKeyDown()
	and not app.isAltKeyDown()
	and not app.isShiftKeyDown()
	then
		self.tblResUsed.removeItem(self.tblResUsed.row);
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadContactsList" id="b10c06a3-209e-4df7-8338-e29315f5043f">
        <source>loadContactsList() protected;

vars
 	selectedAgent:			CM_ShippingAgent;
 	selectedShippingLine:	CM_ShippingLine;
begin
   	
   	self.cmbContact.clear;
	self.btnViewContact.enabled := false;
	self.cmbContact.enabled := false;	   	
 	// Set enabled state for agents and shippinglines
    
    if self.optAgent.value then
    	self.optShippingLine.value := false;
    	selectedAgent := self.cmbShippingAgent.listObject.CM_ShippingAgent;

    	if selectedAgent &lt;&gt; null then
    		// See if selectedAgent has any contacts
    		if selectedAgent.allContacts.size &gt; 0 then
    			// Load contacts list and default to first contact
    			cmbContact.listCollection(selectedAgent.allContacts, true, 0);
    		endif;
    	endif;	
    else
    	self.optAgent.value := false;
    	selectedShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine;
    	if selectedShippingLine &lt;&gt; null then
   	    	self.optShippingLine.value := true;
    		// See if selectedShippingLine has any contacts
    		if selectedShippingLine.allContacts.size &gt; 0 then
    			// Load contacts list and default to first contact
    			self.cmbContact.listCollection(selectedShippingLine.allContacts,true,0);
    		endif;
    	else
   	    	self.optShippingLine.value := false;
    	endif;
    endif;

	// Set "Contact"
	if self.myCurrentMovement &lt;&gt; null then
		if self.myCurrentMovement.myContact &lt;&gt; null then
			self.cmbContact.listIndex := self.cmbContact.findObject(self.myCurrentMovement.myContact);
		endif;
	endif;
	// No contacts - disable 'Contact Details...' button
	if self.cmbContact.listCount &gt; 0 then
		self.btnViewContact.enabled := true;
		self.cmbContact.enabled := true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d7820f0e-940f-4b6a-90c3-c45bf9a1ec43">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	voyageData : HMS_VoyageData;
	movement : HMS_VoyageMovement;
	viewModeSet : Boolean;	
begin
	inheritMethod();

	self.initComboBoxes();	

	movement := self.myCurrentMovement;

	if movement &lt;&gt; null then
		if movement.myHMSVoyageData &lt;&gt; null then
			self.cmbHMSVoyage.listIndex := self.cmbHMSVoyage.findObject(movement.myHMSVoyageData);
			if self.cmbHMSVoyage.listObject &lt;&gt; null then
				voyageData := self.cmbHMSVoyage.listObject.HMS_VoyageData;
						
			//	if voyageData.isArchived() then
			//		self.cmbMovements.listCollection(voyageData.allVoyagetMovementsArchived, true, 0);
			//	else
			//		self.cmbMovements.listCollection(voyageData.allVoyageMovements, true, 0);
			//	endif;
				self.populateCmbMovements( voyageData.myVoyage );	//19 Nov 2018	NDL	TFS 42043

				self.cmbMovements.listIndex := self.cmbMovements.findObject(movement);
				self.setMyCurrentMovement(self.cmbMovements.listObject.HMS_VoyageMovement);		
				viewModeSet := true;
			endif;
		endif;
	endif;

	if (not self.viewOnly) then
		// user has update rights
		if self.myCurrentMovement &lt;&gt; null then
			if self.mode = self.Mode_Update then
				self.doBtnEdit();
			endif;
		elseif self.mode = self.Mode_Add then
			self.doBtnNew();
		elseif (not viewModeSet) then
			self.setToViewMode();
			self.cmbHMSVoyage.setFocus();
		endif;
	elseif (not viewModeSet) then
		self.setToViewMode();
		self.cmbHMSVoyage.setFocus();
	endif;
	
	if self.myInitResourceUsed &lt;&gt; null then
		self.showWithObjectResourceUsed(self.myInitResourceUsed);
	endif;

	self.setNavigatorHeading(self.caption); 	
	self.doResize();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstWharfServices_click" id="ca8f135b-787e-4440-8933-ac559e2e5e9d">
