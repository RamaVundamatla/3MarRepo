    <JadeMethod name="translateConstantName" id="91427b42-7425-42a7-9d85-bc05ac3de750">
        <source>translateConstantName(pType, pName : String) : String;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     Enables the attribute name to be translated to a constant name.
//				This is typically done where the attribute name is &gt; 26 chars.
//
// Parameters:  type	GRP, DEF or ROW
//				name	The attribute name
//
// Returns:     The name, possibly shortened.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return pName;

end;</source>
        <Parameter name="pType" type="String"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="unloadAsSchemaFile" id="2571865a-e073-4b29-b3c4-6e429a756c91">
        <source>unloadAsSchemaFile(pFileName : String);
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	Hdr	: String = 	'jadeVersionNumber "5.2.08";' &amp; CrLf &amp;
					'schemaDefinition' &amp; CrLf &amp;
					'PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=802, patchVersioningEnabled = true;' &amp; CrLf &amp;
					'constantDefinitions';

vars
	f	: File;
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;

begin

	create f;
	f.openOutput(pFileName);

	baseScm := rootSchema.getSchema(self.schemaName);

	f.writeLine(Hdr);

	category := baseScm.getCategory(self.groupCategory);
	self.outputConstantCategory(category, f);

	category := baseScm.getCategory(self.defCategory);
	self.outputConstantCategory(category, f);

	category := baseScm.getCategory(self.rowCategory);
	self.outputConstantCategory(category, f);

	f.close;

epilog
	delete f;

end;</source>
        <Parameter name="pFileName" type="String"/>
    </JadeMethod>
</Class>
