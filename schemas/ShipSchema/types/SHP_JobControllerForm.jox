    <JadeMethod name="frmScrollingMain_contextMenu" id="a33139d4-bfc9-4048-8252-0305dc06e08b">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmScrollingMain_contextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	x1,y1, x2,y2	: Real;
	xLeft, 
	yTop : Real;
begin	
	xLeft := x;
	yTop := y;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.myJobController.displayJobBubbleAtXY(x,y);
	self.setupContextMenu(null,null,null);
	self.popupMenu(mnuContextMenu, xLeft.Integer, yTop.Integer);	

	
	return true;

epilog
	
end;</source>
