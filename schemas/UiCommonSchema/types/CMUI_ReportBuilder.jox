    <JadeMethod name="setMyDataClass" id="bdd92ad7-0efc-4110-9288-c9023550b15a">
        <updating/>
        <source>setMyDataClass() updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myDataClass := CM_QryReport;
end;</source>
    </JadeMethod>
    <JadeMethod name="setPxyReportFromTable" id="bc953a60-3e5e-4572-a718-b71acbcecf90">
        <updating/>
        <source>setPxyReportFromTable(_pxyReport : CM_QryReportUser input) : Boolean updating, protected;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	includedRows,
	visibleRows,
	jrwReports,
	jrwProfiles				: StringArray;
	numRows,
	row,
	index 					: Integer;
	viewName,
	qryReportName,
	reportDesc				: String;
	reportType				: Integer;
	selectorEnabled			: Boolean;
	menuUserQuery			: CM_MenuUserQuery;
	filterObject			: CMQF_FilterReports;
	tbl						: CMUI_ListTable;
	jrwRep					: CMUI_JRWEntityRepresentation;
	allReportFormats		: IntegerArray;
	reportProcessType,
	reportAvailability		: Integer;
	canBeRunInBackground	: Boolean;
	
begin
	create includedRows transient;
	create visibleRows transient;
	create jrwReports transient;
	create jrwProfiles transient;
	create allReportFormats transient;
	
	numRows := tblCriteria.rows;
	foreach index in tblCriteria.fixedRows + 1 to numRows do
		if tblCriteria.accessCell(index, self.Column_Include).text = '1' then
			includedRows.add(tblCriteria.accessRow(index).itemObject.EntTableRow.name);
			//its included - is it also visible (nested because it can't be visible without being included
			if tblCriteria.accessCell(index, self.Column_Visible).text = '1' then
				visibleRows.add(tblCriteria.accessRow(index).itemObject.EntTableRow.name);
			endif;
		endif;
	endforeach;

	//checkbox selected designs
	tbl := self.tblDesigns;
	numRows := tbl.rows;
	jrwReports.clear();
	foreach row in 1 to numRows do
		jrwRep := tbl.accessRow(row).itemObject.CMUI_JRWEntityRepresentation;
		if jrwRep = null then
			continue;
		endif;
		if tbl.getCellText(row, 1) = '1' then
			jrwReports.add(jrwRep.name);
		endif;
	endforeach;
	
	if jrwReports.isEmpty then
		app.msgBox('You must select at least one design to run against this report', 'Nothing Selected...', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	//self.tblDesigns.allSelectedObjects.copy(jrwReports);
	qryReportName	:= self.tblReportDtl.getValueByName(ETRow_ReportName).String;
	reportDesc		:= self.tblReportDtl.getValueByName(ETRow_ReportDescription).String;
	viewName 		:= self.tblReportDtl.getValueByName(ETRow_ReportView).String;
	
	//canBeRunInBackground := self.tblReportDtl.getValueByName((ETRow_IsAvailableInBackground)).Boolean;
	if self.cmbBackground.listIndex &gt; 0 then
		reportProcessType := self.cmbBackground.itemData[self.cmbBackground.listIndex];
	endif;
	
// cnwdad1 30/08/2006 - Constant is no longer used.
//	if self.tblReportDtl.isRowVisible(ETRow_SelectorEnabled) then
//		selectorEnabled := self.tblReportDtl.getValueByName(ETRow_SelectorEnabled).Boolean;
//	else
		selectorEnabled := false;
//	endif;
	
	if qryReportName = null then
		app.msgBox('You must enter a report name before continuing','Insufficient input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if viewName = null then
		app.msgBox('You must select a report view before continuing','Insufficient input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if self.cmbReportType.listIndex&gt;0 then
		
		reportType := self.cmbReportType.itemData[self.cmbReportType.listIndex].Integer;
		
		if reportType = null then
			app.msgBox('You must select a report type before continuing','Insufficient input', MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;

		if reportType = _pxyReport.ReportType_Selector then
			menuUserQuery := self.cmbSelector.listObject.CM_MenuUserQuery;
			if menuUserQuery = null then
				app.msgBox('You must select a selector query before continuing','Insufficient input', MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
		//Par13852 10/04/2007 Removed this as it was getting in the way of user defined reports.  Don't think it should ever have been here.
		//else
		
		//	app.msgBox('You must select a report type before continuing','Insufficient input', MsgBox_Exclamation_Mark_Icon);
		endif;
	endif;
	self.getSelectedFormats(allReportFormats);
	
	if allReportFormats.isEmpty() then
		app.msgBox('You must select at least one Report Format','Insufficient input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if self.cmbRptAvail.listIndex &gt; 0 then
		reportAvailability := self.cmbRptAvail.itemData[self.cmbRptAvail.listIndex];
	endif;
	
	_pxyReport.setUserReportProxy(	qryReportName,
									reportDesc,
									reportType,
									viewName,
									includedRows,
									visibleRows,
									jrwReports,
									jrwProfiles,
									reportProcessType,
									selectorEnabled,
									reportAvailability,
									allReportFormats,
									menuUserQuery);
							
	//proxy report object has been successfully setup - now assign all the defaults onto it's filterObject
	if _pxyReport.myFilterObject = null then //we're adding a new report - hasn't gone through pxyCreateUpdateProxy
		filterObject := _pxyReport.createFilter;
		_pxyReport.setMyFilterObject(filterObject);
	endif;

	if _pxyReport.myFilterObject &lt;&gt; null then
		_pxyReport.myFilterObject.setFromAgent(self.myReportAgent);
		_pxyReport.myFilterObject.initFields();												
	endif;
	return true;				
epilog
	delete includedRows;
	delete jrwReports;
	delete jrwProfiles;
	delete visibleRows;
	delete allReportFormats;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyReport" type="CM_QryReportUser" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setQueryParamFromTable" id="b98e477b-8759-429a-9752-73c361410a79">
        <source>setQueryParamFromTable(_qryParam : CM_QueryReportParam input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     GUI level validation required when editing sub-objects
//			 
// ----------   ----------  --------------------------------------------------
vars
	defaultValue		: Any;
	tbl					: CM_EntryTable;
	isVisible			: Boolean;
	displayName,
	paramName			: String;
	paramType			: Integer;
	entTableRow			: EntTableRow;
	existingParam		: CM_QueryReportParam;
	timeStamp			: TimeStamp;
	binary				: Binary;
begin
	tbl := self.tblParamEnt;
	//get values from table
	paramName := tbl.getValueByName(ETRow_ParamName).String;
	displayName := self.tblParamEnt.getValueByName(ETRow_DisplayName).String;
	isVisible := self.tblParamEnt.getValueByName(ETRow_IsVisible).Boolean;
	
	if self.cmbParamType.listIndex &gt; 0 then
		paramType := self.cmbParamType.itemData[self.cmbParamType.listIndex].Integer;
	endif;
	//validate - check for dups
	if paramName = null then
		app.msgBox('You must enter a parameter name', 'Insufficient Input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	//epr par 29987 9/1/14
	if self.myProxyObject &lt;&gt; null then
		existingParam := self.myProxyObject.CM_QryReport.allQueryReportParams[paramName];
	endif;
	if (existingParam &lt;&gt; null) and (existingParam &lt;&gt; _qryParam) then
		app.msgBox('A parameter with this name already exists', 'Duplicate parameter name', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if displayName = null then
		app.msgBox('You must enter a display name', 'Insufficient Input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if paramType = null then
		app.msgBox('You must select a parameter type', 'Insufficient Input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if paramType = Binary.number then		
		defaultValue := self.picDefault.picture;
	elseif paramType = Boolean.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValBoolean);
	elseif paramType = Character.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValChar);
	elseif paramType = Date.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValDate);
	elseif paramType = Decimal.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValDecimal);
	elseif paramType = Integer.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValInteger);
	elseif paramType = String.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValString);
	elseif paramType = Time.number then
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValTime);
	elseif paramType = TimeStamp.number then
		timeStamp.TimeStamp.setTime(self.tblParamEnt.getValueByName(ETRow_DefaultValTime).Time);
		timeStamp.TimeStamp.setDate(self.tblParamEnt.getValueByName(ETRow_DefaultValDate).Date);
		defaultValue := self.tblParamEnt.getValueByName(ETRow_DefaultValDate);
		defaultValue := timeStamp.TimeStamp;
	endif;

	_qryParam.setProxy(paramName,
						displayName,
						isVisible,
						paramType,
						defaultValue);
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_qryParam" type="CM_QueryReportParam" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelectedFormats" id="f24d1cc6-a70f-4533-8a86-65fdd79e7b7a">
        <source>setSelectedFormats(_formats : IntegerArray) protected;
// -------------------------------------------
// Created 29 October 2004 by cnwdvb1
// -------------------------------------------
vars

	i			: Integer;
	format		: Object;
	objArray	: ObjectArray;
	

begin

	create objArray transient;
	if not _formats.isEmpty then
		foreach i in _formats do
			foreach format in self.allFormats do
				if format.CMIF_ReportFormats.formatType = i then	
					objArray.add(format);
					break;
				endif;
			endforeach;
		endforeach;
	endif;
	self.lstFormats.setSelected(objArray);
	
epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_formats" type="IntegerArray"/>
    </JadeMethod>
