    <JadeMethod name="setupThumbnailDetails" id="470ee489-e5bc-41b3-8e30-e2194b619765">
        <updating/>
        <source>setupThumbnailDetails()updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_TempRangeTbl);
//	theForm.zAddColumn('TempRange Value', 'value', Table.InputType_None, 50);
//	theForm.zAddColumn('Colour','colour',Table.InputType_None,30);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Value, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_TempRangeMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="e2ed91ce-a5e3-4e05-b7d0-43c6c772e3af">
        <updating/>
        <source>showThumbnail(pTempRange : CM_TempRange) updating;

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Value, pTempRange.value);
	theForm.tblInput1.setValueByName(ETRow_Colour,pTempRange.colour);
	theForm.tblInput1.setValueByName(ETRow_Lower, pTempRange.lower);
	theForm.tblInput1.setValueByName(ETRow_Upper, pTempRange.upper);
end;</source>
        <Parameter name="pTempRange" type="CM_TempRange"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="890a86f4-f8df-4402-b729-72e6b1d6cd50">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	lTempRange:CM_TempRange;
	cell     :JadeTableCell;
begin

	lTempRange := _obj.CM_TempRange;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;
			cell.backColor := lTempRange.colour;
		endif;
	endif;
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
