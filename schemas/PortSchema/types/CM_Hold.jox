    <JadeMethod name="setOrdinalHold" id="9b132098-e515-46e1-9adf-c7e6d964974e">
        <updating/>
        <source>setOrdinalHold(_value : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwer1	Initial creation

*/

vars

begin
	self.ordinalHold :=_value;
