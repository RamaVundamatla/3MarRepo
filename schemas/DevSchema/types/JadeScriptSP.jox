    <JadeMethod name="addCargoOnsite" id="b5fd6e3f-df3b-49af-b428-41dfeb8952cd">
        <source>addCargoOnsite();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2025	navsp1	Initial creation

*/

vars
	terminal : CM_Terminal;
	int : Integer;
begin
	app.clearWriteWindow();
	terminal := app.myRoot.allTerminals["SPT"];
	if terminal = null then
		return;
	endif;
	int := 1;
	while int &lt;= 100 do
		write int;
		int+=1;
	endwhile;
epilog

end;</source>
    </JadeMethod>
