    <JadeMethod name="validateMe" id="b98ffcd2-c5f7-41dd-bcc8-72fe8e4196ba">
        <source>validateMe(_origTerminal : CM_Terminal; _origCargoType : Integer);
// ---------------------------------------------------------------------------
// Created:     14 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTerminal	: CM_Terminal;
begin

	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Id), ETRow_Id, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Id), ETRow_Id, null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.myLocation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
		app.raiseCMException(Input_required_field_location, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	tmpTerminal := self.myLocation.myTerminal;
	if tmpTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;
	if tmpTerminal &lt;&gt; _origTerminal then
		app.raiseCMException1(TISplitLocnInDifferentTerminal, self.id, null, null);
	endif;
	
	if tmpTerminal.lookupTrackedItem(self.id, _origCargoType, TI_STATE_NORMAL, null, false) &lt;&gt; null then
		app.raiseCMException1(UniqueIdRequired, self.id, null, null);
	endif;

	if self.length &lt; 0 then
		app.raiseCMException2(NUMBER_NEGATIVE, app.getErrorString(Length), self.id, null, null);
	endif;
	if self.quantity &lt; 0 then
		app.raiseCMException2(NUMBER_NEGATIVE, app.getErrorString(Quantity), self.id, null, null);
	endif;
	if self.weight &lt; 0 then
		app.raiseCMException2(NUMBER_NEGATIVE, app.getErrorString(Weight), self.id, null, null);
	endif;
	if self.volume &lt; 0 then
		app.raiseCMException2(NUMBER_NEGATIVE, app.getErrorString(Volume), self.id, null, null);
	endif;
	
	if self.length &gt; 0 and (not self.isSplitByLength) then
		app.raiseCMException2(SplitValueWhereSplitTypeFalse, app.getErrorString(Length), self.class.name &amp; '::' &amp; 'isSplitByLength', null, null);
	endif;
	if self.quantity &gt; 0 and (not self.isSplitByQuantity) then
		app.raiseCMException2(SplitValueWhereSplitTypeFalse, app.getErrorString(Quantity), self.class.name &amp; '::' &amp; 'isSplitByQuantity', null, null);
	endif;
	if self.volume &gt; 0 and (not self.isSplitByVolume) then
		app.raiseCMException2(SplitValueWhereSplitTypeFalse, app.getErrorString(Volume), self.class.name &amp; '::' &amp; 'isSplitByVolume', null, null);
	endif;
	if self.weight &gt; 0 and (not self.isSplitByWeight) then
		app.raiseCMException2(SplitValueWhereSplitTypeFalse, app.getErrorString(Weight), self.class.name &amp; '::' &amp; 'isSplitByWeight', null, null);
	endif;

end;</source>
        <Parameter name="_origTerminal" type="CM_Terminal"/>
        <Parameter name="_origCargoType" type="Integer"/>
    </JadeMethod>
</Class>
