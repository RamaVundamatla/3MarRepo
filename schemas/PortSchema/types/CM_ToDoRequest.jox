    <JadeMethod name="changeToDoTasksStatus" id="e2ed31c2-a4c8-4b5c-afa3-2678480dabc5">
        <updating/>
        <source>changeToDoTasksStatus(_newStatus : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	task : CM_ToDoTask;
	newTrans : CM_TITransaction;	//30 Dec 2009	NDL		MES CCMS 1006 - return transaction...
begin
	if _newStatus &lt;&gt; STATUS_COMPLETE then
		return;
	endif;
	foreach task in self.allToDoTasks do
		if task.status &lt;&gt; _newStatus then
			task.setTaskComplete(_passport, true, newTrans);
		endif;
	endforeach;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createWLE" id="55407c08-589d-4579-b8c7-96bd10d3b586">
        <source>createWLE();
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
