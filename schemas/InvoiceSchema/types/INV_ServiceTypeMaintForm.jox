    </JadeMethod>
    <JadeMethod name="doSave" id="0cb53a2e-2fb9-4d22-8a17-d9b756054b01">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	
	table 				: CM_EntryTable;
	pxyServiceType		: CM_ServiceType;
	selectedServices	: CM_ServiceByNameDict;
	theReturn 			: Integer;
	
begin
	
	table := self.tblEntDetail;
	
	if self.mode = Mode_Add then
		create pxyServiceType transient;
		
	elseif self.mode = Mode_Update then
		pxyServiceType := self.myProxyObject.CM_ServiceType;
	else
		return false;
	endif;
	
	create selectedServices transient;
	
	self.msgServices.getSelected(selectedServices);

	pxyServiceType.setProxy(table.getValueByName(ETRow_Code).String,
							table.getValueByName(ETRow_Description).String,
							selectedServices,
							myCurrentBank);
	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateServiceType(pxyServiceType, self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateServiceType(pxyServiceType, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			//global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("ServiceType", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;

epilog
	
	if self.mode = Mode_Add then
		delete pxyServiceType;
	endif;
	
	delete selectedServices;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="2c3d3e86-a585-4965-b151-93de77d1d2f7">
