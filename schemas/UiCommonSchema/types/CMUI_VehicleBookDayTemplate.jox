    <JadeMethod name="btnDelTime_click" id="029e2e65-b95a-4d78-aa22-f01418844913">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelTime_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	
	timeTemplates : CM_VehicleBookingTimeTempDict;
	timeTemp : CM_VehicleBookingTimeTemplate;
	rowIndex : Integer;
	
begin

	create timeTemplates transient;
	
	foreach rowIndex in self.tblTimes.fixedRows + 1 to self.tblTimes.rows do
		if self.tblTimes.accessRow( rowIndex ).selected then
			timeTemplates.add( self.tblTimes.accessRow( rowIndex ).itemObject.CM_VehicleBookingTimeTemplate );
		endif;
	endforeach;
	
	if timeTemplates.isEmpty then
		return;
	endif;

	if app.msgBox( app.getErrorString(ConfirmDeleteItems), app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	foreach timeTemp in timeTemplates do
		app.myTrxDA.trxDeleteVehicleTimeTemp(timeTemp, app.myPassport);
		if app.myPassport.hasErrors then
			break;
		endif;
	endforeach;
	
	
	self.initTblTimes();

	
epilog

	delete timeTemplates;

end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
