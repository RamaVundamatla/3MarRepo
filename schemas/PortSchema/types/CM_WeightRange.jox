    <JadeMethod name="cnEcGetDuplicate" id="e37bb138-053c-431d-9951-85578b164e0e">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2014	cnwndl1	Initial creation

*/

vars

	shortName : String;
	value : Integer;
	measure : CM_MeasurementType;
	range : CM_WeightRange;

begin

	shortName := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, "CM_MeasurementType", "shortName" ).String; 
	value := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, "CM_WeightRange", "value" ).Integer; 
	
	if shortName &lt;&gt; null then
		measure := app.myRoot.allMeasurementTypesByShortName.getAtKey( shortName );
		if measure &lt;&gt; null then
			range := app.myRoot.allWeightRanges.getAtKey( measure, value );
		endif;
	endif;

epilog

	return range;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
