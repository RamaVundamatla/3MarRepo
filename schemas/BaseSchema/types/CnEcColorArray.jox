    <DbClassMap file="basemap"/>
    <JadeMethod name="cnEcPopulateUniqueColors" id="7737ba01-22bb-4b61-9583-85d5f4034f7a">
        <lockReceiver/>
        <updating/>
        <source>cnEcPopulateUniqueColors(pNumberOfColors:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Populates the receiver array with a set of unique colors, up to
//				the number specified.   To be used by graphing controls to
//				represent any given number of discrete values.
//
//				Colours are allocated using "primary" first, followed by the
//				various mixtures later, with the differences getting more subtle
//				the further up the array.
//
// Parameters:	pNumberOfColors (Integer) - The number of colors to add.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/11/2001	cnwdad1		The array was only producing shades of black, so made
//							changes to use "while" loops &amp; add the increment after
//							each loop, and reset internal loop counters.
// --------------------------------------------------------------------------------
vars
	iteration	: Integer;
	newColour	: Integer;
	increment	: Decimal[8,5];
	colorRed	: Decimal[8,5];
	colorGreen	: Decimal[8,5];
	colorBlue	: Decimal[8,5];
		
begin
	self.clear();
	iteration	:=	0;
	
	while self.size() &lt; pNumberOfColors do : outerloop
		iteration	:=	iteration + 1;
		increment	:=	255 / iteration;
		colorRed	:=	0;
		
		while colorRed &lt;= 255 do
			colorGreen	:=	0;
			
			while colorGreen &lt;= 255 do
				colorBlue	:=	0;
				
				while colorBlue &lt;= 255 do
					newColour.cnEcSetColorFromRGB(colorRed.rounded, colorGreen.rounded, colorBlue.rounded);
					
					if (not self.includes(newColour)) then
						self.add(newColour);
						
						if self.size() &gt;= pNumberOfColors then
							break outerloop;
						endif;
					endif;
					
					colorBlue	:=	colorBlue + increment;
				endwhile;
				
				colorGreen	:=	colorGreen + increment;
			endwhile;
			
			colorRed	:=	colorRed + increment;
		endwhile;
	endwhile;
end;</source>
        <Parameter name="pNumberOfColors" type="Integer"/>
    </JadeMethod>
</CollClass>
