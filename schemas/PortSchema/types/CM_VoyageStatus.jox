    <JadeMethod name="setForUpdate" id="67e32ff5-d358-4de7-b06c-7f9be8230b16">
        <updating/>
        <source>setForUpdate(_pxyStatus : SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 19/03/2018	jlgdap1		TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 05/06/2018	jlgdap1		TFS 38851 PEL1 Voyage Statuses INAPORTNET
//
vars
	template : CM_EmailTemplate;

begin
	self.description := _pxyStatus.description;
	self.reportToRun := _pxyStatus.reportToRun;	//05 Jun 2018	NDL	TFS 38905
	self.priority := _pxyStatus.priority;									// TFS 38851
	self.requiresInaportnetAction := _pxyStatus.requiresInaportnetAction;	// TFS 38851
	self.autoApplyStatus:=_pxyStatus.autoApplyStatus; //epr TFS 51963 11/10/21
	
	if self.myEmailTemplate = null and _pxyStatus.myEmailTemplate &lt;&gt; null then
		create template persistent;
		template.setMyParent(self);
	endif;
	if self.myEmailTemplate &lt;&gt; null then
		if _pxyStatus.myEmailTemplate = null then				// TFS 37540
			self.myEmailTemplate.erase(NORMAL_ERASE);			// TFS 37540
		else													// TFS 37540
			self.myEmailTemplate.setForUpdate(_pxyStatus.myEmailTemplate);
		endif;													// TFS 37540
	endif;
	
	self.allEventsToCreate.clear;
	_pxyStatus.allEventsToCreate.copy(self.allEventsToCreate);
	self.allHMSResourcesAllowed.clear;
	_pxyStatus.allHMSResourcesAllowed.copy(self.allHMSResourcesAllowed);
	
	self.allHMSResourcesApproval.clear;
	_pxyStatus.allHMSResourcesApproval.copy(self.allHMSResourcesApproval);	//01 Aug 2018	NDL	TFS 39900
	
	self.myProcess := _pxyStatus.myProcess;
epilog

end;</source>
        <Parameter name="_pxyStatus" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f7694c39-1abd-415a-b2f9-68cb25db8ecd">
