    <JadeMethod name="displayInvoiceLine" id="bca8110b-5e8f-4881-ba5c-6956e5f117db">
        <source>displayInvoiceLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/
vars

	theTable   	: CM_DataTable;
	theNarrRow 	: Integer;
	invLine     : CM_InvoiceLine; 
	ti          : CM_TrackedItem;
begin

	if self.myCurrentInvoice = null then
		return;
	endif;
	
	theTable := self.tblResults;
	
	self.btnFindTi.visible 		  := true;       
	self.btnFindTi.enabled 		  := true;
 	
	self.btnSaveBase.enabled   :=  self.myCurrentInvoice &lt;&gt; null and self.myParentForm.INV_ListLines.getStatusGood();
	self.txtQuantity.text := "1.0000";
	self.mskStartDT.setDate(self.systemToLocalTime(app.actualTimeServer).date);
		 
	self.btnSaveBase.enabled    := true; 
		
end;</source>
    </JadeMethod>
