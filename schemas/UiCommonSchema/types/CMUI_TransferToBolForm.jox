    <JadeMethod name="doResize" id="0e771538-5b24-46dd-bde5-610514fc5257">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	self.grpMain.top := 1;
	self.grpMain.left := 1;

