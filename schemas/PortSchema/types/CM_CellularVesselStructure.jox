    <JadeMethod name="setProxyCellularVessel" id="a9271fef-be05-4cab-9701-2a8a5f8a1bd4">
        <updating/>
        <source>setProxyCellularVessel(_bridgeAfterBay : String; _use40Id, _useBayCellTierNumbering, _isoHalfHeights : Boolean; _numSlot : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.bridgeAfterBay := _bridgeAfterBay;
	self.use40Id := _use40Id;
	self.useBayCellTierNumbering := _useBayCellTierNumbering;
	self.isoHalfHeights := _isoHalfHeights;

	self.numSlotsExpected := _numSlot; // PAR 32286
	
	// Default to being created from Master Terminal
	if self.definitionSource = null then
		self.definitionSource := CM_CellularVesselStructure.DefinitionType_MTN;	// 16/03/21 navmd1 TFS 49052 MACS3 Vessel Library API
	endif;
end;</source>
        <Parameter name="_bridgeAfterBay" type="String"/>
        <Parameter name="_use40Id" type="Boolean"/>
        <Parameter name="_useBayCellTierNumbering" type="Boolean"/>
        <Parameter name="_isoHalfHeights" type="Boolean"/>
        <Parameter name="_numSlot" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyForMACS3" id="7cc847af-7dd1-41f4-a845-0c62bcb48f78">
        <updating/>
        <source>setProxyForMACS3(_fileVersion : Integer) updating;
/*

Purpose:			'Tag' the structure as having been generated 

Parameters:			

Return Value:		

Date				Who		Reason
04 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.definitionVersion	:= _fileVersion;
	self.definitionSource	:= CM_CellularVesselStructure.DefinitionType_MACS3;
	self.isImported			:= true;

epilog

end;</source>
        <Parameter name="_fileVersion" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyVesselFromXML" id="13bac2fc-f108-4517-88f4-d9f1a2256378">
        <updating/>
        <source>setProxyVesselFromXML(_theXML : String) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		pass in an XML string and create the whole bay cell tier slots etc structure
//				see getDefinitionXML for the export
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyBay, previousBayDefn : CM_BayDefn;
	aProxyHatch : CM_HatchLid;
	aProxyHold : CM_VesselHold ;
	pos, idx, theOrdinal, numberOfHolds : Integer;
	theBayXML, theXML, aLabel : String;
	theLabels : StringArray;
begin

	self.raiseExceptionIfNotTransient(method);
	
	if self.allBaysByOrdinal.isEmpty = false then
		app.raiseCMException2(ERR_INVALID_VALUE, "Bays", "This Vessel Already has Bays. XML Import must have an 'empty' Vessel", null, null);
	endif;
	
	self.isImported := true;
	self.bridgeAfterBay := _theXML.cnEcGetTagValueOfName("ba");
	self.use40Id := _theXML.cnEcGetTagValueOfName("40").Integer.Boolean;
	self.useBayCellTierNumbering := _theXML.cnEcGetTagValueOfName("sn").Integer.Boolean;
	self.isoHalfHeights := _theXML.cnEcGetTagValueOfName("hh").Integer.Boolean;

	theBayXML := _theXML.cnEcGetTagValueOfName("bo");
	theBayXML.replaceString(" ","|");
	theLabels := theBayXML.getTokens;

	// CREATE EMPTY BAYS
	foreach aLabel in theLabels do
		if aLabel.trimBlanks &lt;&gt; null then
			if self.allBaysByLabel[aLabel.trimBlanks] = null then
				create aProxyBay transient;
				
				theOrdinal := self.allBaysByLabel.size + 1;
				aProxyBay.setProxyBay(aLabel.trimBlanks,null,null,null,null,null,theOrdinal,null,null,null,null,null,null,null,null,null,null,null,null,null, null, null,true,true, self,null,0,false,false);
			endif;
		endif;
	endforeach;

	// CREATE THE HOLDS
	numberOfHolds := _theXML.cnEcGetTagValueOfName("nh").Integer;
	if numberOfHolds &gt; 0 then
		foreach idx in 1 to numberOfHolds do
			if self.allHolds[idx] = null then
				create aProxyHold transient;
				aProxyHold.setProxy(self,idx);
			endif;
	
		endforeach;
	endif;
			
	// ########################
	// THE BAYS
	pos := 1;
	while (pos &gt; 0) do
		theBayXML := _theXML.cnEcGetNextTagValueOfName("BAY",pos); 
		if theBayXML = null then
			break;
		endif;
		theOrdinal := theBayXML.cnEcGetTagValueOfName("bo").Integer;
		aProxyBay := self.allBaysByOrdinal[theOrdinal];
		if aProxyBay = null then
			continue;
		endif;

		
		aProxyBay.setProxyBayFromXML(theBayXML, self);
	endwhile;

	foreach aProxyBay in self.allBaysByLabel do
		if aProxyBay.id.trimBlanks = null then
			continue;
		endif;
		
		if previousBayDefn &lt;&gt; null then
			previousBayDefn.setMyAftBay(aProxyBay);
		endif;
		previousBayDefn := aProxyBay;
	endforeach;

	// HATCHES
	theXML := _theXML.cnEcGetTagValueOfName("HATCH");
	self.doCreateProxyHatchsFromXML(theXML, false);

	foreach aProxyBay in self.allBaysByLabel do
		foreach aProxyHatch in aProxyBay.allHatchLids do
			if aProxyHatch.isKindOf(CM_HatchLidVessel) then
				aProxyHatch.CM_HatchLidVessel.setMyVessel(self);
				
			endif;
		endforeach;
	endforeach;
	
epilog
	delete theLabels;	//Clean up stringArray. DQ.
end;</source>
        <Parameter name="_theXML" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateBayLinks" id="8247401b-3be9-4f34-ace9-a859a3c3c645">
        <updating/>
        <source>updateBayLinks() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realBayDefn,previousBayDefn:CM_Bay;
	aHold : CM_Hold;
begin
	previousBayDefn := null;
	
	foreach realBayDefn in self.allBaysByOrdinal do
		if previousBayDefn &lt;&gt; null then
			previousBayDefn.setMyAftBay(realBayDefn);
		endif;
		previousBayDefn := realBayDefn;
	endforeach;
	if realBayDefn &lt;&gt; null then
		realBayDefn.setMyAftBay(null); // make sure that it does not wrap around to the front
	endif;
	
	// PAR 7799 make the bay types for all the aft bays the same as the forward bays
	foreach aHold in self.allHolds do
		aHold.updateBayLinks();
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateBayIDs" id="cf26f34f-fb6d-481f-9d5a-c98dbda628a5">
        <source>validateBayIDs();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theBayIds : StringArray;
	aBay : CM_Bay;
	errorBayID : String;
	theHold : CM_Hold;
	sameID : Boolean;
begin
	// CHECK that the 20 and 40 bay ids are unique
	if self.allBaysByOrdinal.isEmpty then
		return;
		app.raiseCMException2(ERR_INVALID_VALUE,"No Bays to check", " Bay ID '" &amp; errorBayID &amp; "' so cannot create bays", null, null);
	endif;
	create theBayIds transient;
	errorBayID := "";
	foreach aBay in self.allBaysByOrdinal do
		if aBay.id &lt;&gt; null then
			//First check if we have a valid length which is 2 at the moment
			if aBay.id.length &gt; 2 then
				app.raiseCMException2(ERR_INVALID_VALUE, " bay " &amp; aBay.id.String,  "Bay IDs can only be a maximum length of 2.",null,   null);
			endif;
			if not theBayIds.includes(aBay.id) then
				theBayIds.add(aBay.id);
			else
				errorBayID := aBay.id;
				break;
			endif;
		endif;
	endforeach;
	if errorBayID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"20 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' is already is use, it must be unique", null, null);
	endif;
	errorBayID := "";
	foreach aBay in self.allBaysByOrdinal do
		if aBay.idBay40 &lt;&gt; null then
			if not theBayIds.includes(aBay.idBay40) then
				theBayIds.add(aBay.idBay40);
			elseif aBay.id = aBay.idBay40 
			and aBay.fortyFootOnly then		
				// PAR 13167. 20 and 40 id must be unique. If the same it stuffs up Planning Guide.
				//					If this is a forty only bay then the aft and forward 20 bays must be given 'dummy' IDs and the real 40 bay ID used for the 40 foot bay ID.
				sameID := true; // PAR 13167. 
				errorBayID := aBay.idBay40;
				break;
			else
				errorBayID := aBay.idBay40;
				break;
			endif;
		endif;
	endforeach;
	if errorBayID &lt;&gt; null then
		if aBay &lt;&gt; null then
			if sameID then
				app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' used on bay " &amp; aBay.id &amp; " cannot be used, The 20 foot and 40 foot bay IDs must be unique.", null, null);
			else
				app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' used on bay " &amp; aBay.id &amp; " is already is use, it must be unique", null, null);
			endif;
		else
			app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' is already is use, it must be unique", null, null);
		endif;	
	endif;
	
	// check for illegal blank 40 bay ids
	foreach aBay in self.allBaysByOrdinal do
		if aBay.bayType = BAY_TYPE_TWIN then
			if not aBay.isAftBay then
				if aBay.idBay40 = null then
					app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay " &amp; aBay.id &amp; " is a forward bay in a twin hold that does not have a 40 foot bay ID", null, null);
				endif;
			endif;
		elseif aBay.bayType = BAY_TYPE_TRIPLE then
			if aBay.myHold.allBays.indexOf(aBay) &lt;= 2 then
				if aBay.idBay40 = null and aBay.canHandle4045() then // PAR 7899
					app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay " &amp; aBay.id &amp; " is a forward bay in a triple hold that does not have a 40 foot bay ID", null, null);
				endif;
			endif;
		endif;
	endforeach;
	foreach aBay in self.allBaysByOrdinal do
		self.validateTierIDs(aBay);
		self.validateCellIDs(aBay);
	endforeach;
epilog
	delete theBayIds;


end;</source>
    </JadeMethod>
    <JadeMethod name="validateCellIDs" id="17503a4d-afbf-49aa-9528-8832cbc2b0ab">
        <source>validateCellIDs(_bay : CM_Bay);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theCellIds : StringArray;
	aCell : CM_CellDefn;
	errorCellID : String;

begin
	
	create theCellIds transient;
	
	// CHECK that the Cell ids are unique
	errorCellID := "";
	foreach aCell in _bay.allCellsOnDeck do
		if aCell.id &lt;&gt; null then
			if not theCellIds.includes(aCell.id) then
				theCellIds.add(aCell.id);
			else
				errorCellID := aCell.id;
				break;
			endif;
		endif;
	endforeach;
	if errorCellID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Bay " &amp; _bay.id &amp; " On Deck Cell IDs.", " Cell ID '" &amp; errorCellID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorCellID := "";
	theCellIds.clear;
	foreach aCell in _bay.allCellsUnderDeck do
		if aCell.id &lt;&gt; null then
			if not theCellIds.includes(aCell.id) then
				theCellIds.add(aCell.id);
			else
				errorCellID := aCell.id;
				break;
			endif;
		endif;
	endforeach;
	if errorCellID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Bay " &amp; _bay.id &amp; " Under Deck Cell IDs.", " Cell ID '" &amp; errorCellID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorCellID := "";
epilog
	delete theCellIds;


end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="bdeaae31-09a8-4c21-85b4-603d42526f4b">
        <source>validateCreate(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	31 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	self.validateBayIDs();	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7a5335bb-a62a-4df7-8710-7a4ffabca1ce">
        <source>validateMe(_passport : CM_Passport input) protected;

vars

	lid : CM_HatchLid;
	baySize, bayMax : Integer;
	aBay : CM_Bay;
	aString, bayName : String;
begin
	inheritMethod(_passport);
	
	// make sure that the hatch lids span the correct number of bays
	foreach lid in self.allHatchlids do
		baySize := lid.allBays.size;
		if baySize &gt; 0 then
			bayName := null;
			aString := null;
			foreach aBay in lid.allBays do
				aString := aString &amp; aBay.id &amp; " ";
			endforeach;
			aBay := lid.allBays.first;
			if aBay.bayType = BAY_TYPE_SINGLE and baySize &gt; 1 then
				bayName := "Single";
				bayMax := 1;
			endif;
			if aBay.bayType = BAY_TYPE_TWIN and baySize &gt; 2 then
				bayName := "Twin";
				bayMax := 2;
			endif;
			if aBay.bayType = BAY_TYPE_TRIPLE and baySize &gt; 3 then
				bayName := "Triple";
				bayMax := 3;
			endif;
			if bayName &lt;&gt; null then
			app.raiseCMException2(ERR_INVALID_VALUE, 'Hatch Lid',"Hatchlid for a " &amp; bayName &amp; " bay with more than " &amp; bayMax.String &amp; " bay specified. Bays " &amp; aString &amp; " have been specified for a " &amp; bayName &amp; " bay hatch", null, null);
			endif;
		endif;
	endforeach;
	self.validateBayIDs();	

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTierIDs" id="79741312-c3db-412b-9c79-79b71b2522e5">
        <source>validateTierIDs(_bay : CM_Bay);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTierIds : StringArray;
	aTier : CM_TierDefn;
	errorTierID : String;

begin
	
	create theTierIds transient;
	
	// CHECK that the 20 and 40 Tier ids are unique
	errorTierID := "";
	foreach aTier in _bay.allTiersOnDeck do
		if aTier.id &lt;&gt; null then
			if not theTierIds.includes(aTier.id) then
				theTierIds.add(aTier.id);
			else
				errorTierID := aTier.id;
				break;
			endif;
		endif;
	endforeach;
	foreach aTier in _bay.allTiersUnderDeck do
		if aTier.id &lt;&gt; null then
			if not theTierIds.includes(aTier.id) then
				theTierIds.add(aTier.id);
			else
				errorTierID := aTier.id;
				break;
			endif;
		endif;
	endforeach;
	if errorTierID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Bay " &amp; _bay.id &amp; " Tier IDs.", " Tier ID '" &amp; errorTierID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorTierID := "";
epilog
	delete theTierIds;


end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="validateUpdateForSLWS" id="b1b45dd0-d537-45f3-bdba-9b59a2dc7228">
        <source>validateUpdateForSLWS();
/*
Purpose:			
Date		Who		Reason
21 January 2014	cnwab1	Initial creation
*/

vars

begin

	if not self.hasBayItemLayouts() then
		app.raiseCMException2(ERR_INVALID_VALUE,"Vessel Update", "Vessel " &amp; self.myVessel.code &amp; " was not created using the JMT 8.2.2 LOLO Vessel Definition WIZARD. For this reason it cannot be edited.", null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
