    <JadeMethod name="setMyVessel" id="91db9476-a1ec-4fab-a9fe-5288edb0bc9b">
        <updating/>
        <source>setMyVessel( _vessel: CM_Vessel ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

begin

	self.myVessel := _vessel;
	self.myVoyage := null;
	
	

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="546e8db9-2241-4ddf-8fab-bdd000433672">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.btnSort.visible := false;	//10 May 2017	NDL	TFS 4351
	
	if self.myVessel = null then
		self.setCaption(app.getErrorString1(Vessel_location_definition,null));
	else
		self.setCaption(app.getErrorString1(Vessel_location_definition,self.myVessel.code));
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7999b2d4-4537-4dac-8743-28a7581377ca">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:50:53.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023448, locale);
end;</source>
    </JadeMethod>
</GUIClass>
