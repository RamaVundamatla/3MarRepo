    <JadeMethod name="getYADisplay" id="794a9878-66d1-436e-9c4e-67dd69c9aa70">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		09 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 01/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
//							If measurement type is kgs, perform current logic and return as T
//							Otherwise return as straight value with measurement type
// --------------------------------------------------------------------------------
vars
	lowerString : String;
	localLower : Integer;
	upperString : String;
	localUpper : Integer;
	workDecimal : Decimal[16,3];
	str1 : String;
	str2 : String;
	inKgs : Boolean;					// PAR #31155
	
begin

	//return (self.lower/1000).Integer.String &amp; "-" &amp; (self.upper/1000).Integer.String &amp; "t";

	inKgs := self.myMeasurementType.shortName = "kg";								// PAR #31155
	localLower := self.lower;
	lowerString := self.lower.String;
	//We are dealing with a range, round by one if appropriate.
	if lowerString[lowerString.length] = '1' then	
		localLower := localLower - 1;	//round down to get a value ending in zero. 
	elseif lowerString[lowerString.length] = '9' then
		localLower := localLower + 1;	//round up to get a value ending in zero.
	endif;
	
	if localLower = 0 then
		str1 := '0';
	else
		if inKgs then																// PAR #31155
			workDecimal := (localLower/1000);
			str1 := workDecimal.String.stripTrailingChar("0");
			str1 := str1.stripTrailingChar(".");
		else																		// PAR #31155
			//str1 := localLower.asStringJMTWithOptionalCommas(true, false);			// PAR #31155
			str1 := localLower.asStringJMT();			// PAR #31155
		endif;																		// PAR #31155
	endif;
	
	
	localUpper := self.upper;
	upperString := self.upper.String;
	if upperString[upperString.length] = '1' then
		localUpper := localUpper - 1;
	elseif upperString[upperString.length] = '9' then
		localUpper := localUpper + 1;
	endif;
	
	if inKgs then																	// PAR #31155
		workDecimal := (localUpper/1000);
		str2 := workDecimal.String.stripTrailingChar("0");
		str2 := str2.stripTrailingChar(".");
	else																			// PAR #31155
		//str2 := localUpper.asStringJMTWithOptionalCommas(true, false);				// PAR #31155
		str2 := localUpper.asStringJMT();				// PAR #31155
	endif;																			// PAR #31155
	
	if inKgs then																	// PAR #31155
		return str1 &amp; "-" &amp; str2 &amp; "t";
	else																			// PAR #31155
		return str1 &amp; "-" &amp; str2 &amp; Space &amp; self.myMeasurementType.shortName;		// PAR #31155
	endif;																			// PAR #31155
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
