end;</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="8765fca5-a447-48bc-8b2b-18774ff10c36">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 December 2016	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.commodityCode &lt;&gt; null then
		tmpStr := self.commodityCode;
		txt := txt &amp; app.getErrorString(Commodity) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.contentsMap &lt;&gt; null then
		tmpStr := self.contentsMap.contentsName;
		txt := txt &amp; app.getErrorString(Contents_statuses) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
		if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.contentsMap.getBank &lt;&gt; null then
		tmpStr := self.contentsMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
