// --------------------------------------------------------------------------------
begin
	btnOk_click(btnOk);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_displayEntry" id="d9d991a4-ca4a-483d-8a92-207e6b21ec74">
        <controlMethod name="CnEcDesignTable::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_displayEntry(table: CnEcDesignTable input; obj: Any; columnHeading: String input):String updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Purpose:		This method is called for each column of each row in the table control
//				to display a value in the appropriate cell for the object.
//
// Parameters:	table (JACDesignTable) - The table control.
//				obj (Any) - The object who's value we wish to display.
//				columnHeading (String) - The name of the table column.
// Returns:		String - The value to be displayed in the table cell.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/07/1999	cnwdad1		Added check for whether a Collection Class's memberType
//							property is null (returns object 'display' value if so).
//
// --------------------------------------------------------------------------------
begin
	if (columnHeading = 'Object OID') then
		return obj.getOidString;
	elseif (columnHeading = 'Class') then
		return obj.getName;
	elseif (self.myClass.isKindOf(CollClass)) then
		if (self.myClass.CollClass.memberType = null) then
			return obj.display();
		else
			if (self.myClass.CollClass.memberType.Class.findProperty(columnHeading).getType.name = 'Binary') then
				return self.BINARY_LITERAL;
			else
				return obj.Object.getPropertyValue(columnHeading).String;
			endif;
		endif;
	else
		return obj.Object.getPropertyValue(columnHeading).String;
	endif;
end;</source>
        <Parameter name="table" type="CnEcDesignTable" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="columnHeading" type="String" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_mouseDown" id="76b0a746-0a4f-49a5-8db7-7b60a3f4059c">
        <controlMethod name="CnEcDesignTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		12 July 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (table.row &gt; 1) and (table.row &lt;= table.rows) then
		if (table.column &gt; 0) and (table.column &lt;= table.columns) then
			if (table.cnEcGetCellObject(table.row, 1) &lt;&gt; null) then
				if (button = Window.MouseButton_Right) then
					popupMenu(mnuPopup, (x.Integer + table.left.Integer), (y.Integer + table.top.Integer));
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="9227a4a9-8661-470a-bf9c-f3a1729f401e">
        <updating/>
        <source>timerEvent(eventTag : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		16 July 1999 by cnwdad1
//
// Purpose:		Flashes the Manual Collection warning message.
//
// Parameters:	eventTag (Integer) - Identifies the timer event.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	warning	: Label;

begin
	warning	:=	lblManualWarning;

	if (warning.foreColor = Red) then
		warning.foreColor	:=	self.warningColor;
	else
		warning.foreColor	:=	Red;
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="2c746c1d-4c85-49f5-b5da-4d19d8597a1e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog
	endTimer(0);
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCollection" id="97c5a1f5-8f53-409a-ad5a-03e98832d493">
        <source>updateCollection() protected;
// --------------------------------------------------------------------------------
// Created:		16 January 1999 by cnwdad1
//
// Purpose:		Updates the source collection with the currently selected
//				instances in the JAC Design Table.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/05/2000	cnwdad1		The new version of the CnEcDesignTable control now has
//							the "selectedObjects" property protected and accessible
//							via the "getSelectedObjects" method.
//
// --------------------------------------------------------------------------------
begin
	self.myCollection.clear();
	tblObjects.getSelectedObjects().copy(self.myCollection);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateReference" id="b2a8baa4-6699-4dce-873d-d65ad5b7398a">
        <updating/>
        <source>updateReference() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 January 1999 by cnwdad1
//
// Purpose:		Updates the source Object with the selected instance in the JAC Design Table.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index	: Integer;
	count	: Integer;
	table	: CnEcDesignTable;
	object	: Object;

begin
	table	:=	tblObjects;
	index	:=	2;
	count	:=	table.rows;

	while (index &lt;= count) do
		if (table.getCellSelected(index, 2)) then
			self.myObject	:=	table.getRowObject();
			break;
		endif;

		index	:=	index + 1;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
