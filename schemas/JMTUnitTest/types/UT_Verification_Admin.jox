	xmlDocCurr					: JadeXMLDocument;
	unitTestResult 				: UM_UnitTestResult;
	association					: CM_Association;
	
	userSummaryDict				: CM_AssociationDict;
	detailsToOutput				: StringArray512;
	
	iter						: Iterator;
	
	startTS						: TimeStamp;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	resultStr					: String;
	tempStr						: String;
	str							: String;
	user						: String;
	
begin

	/*
	create detailsToOutput transient;
	create userSummaryDict transient;
	methStartTS := app.actualTimeServer;

	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	// get the last but one e.g. previous run
	startTS.setDate("31/12/2999".Date);
	startTS.setTime("23:59:59".Time);
	iter := root.allUnitTestRuns.createIterator;
	root.allUnitTestRuns.startKeyGeq(startTS, iter);
	iter.back(unitTestRun);
	iter.back(unitTestRun);
	
	self.assertNotNull(unitTestRun.endConfigDetails);
	
	create xmlDocPrev transient;
	xmlDocPrev.parseString(unitTestRun.getEndConfigDetails());
	
	if xmlDocPrev = null then
		return;
	endif;
	
	//create xmlDocCurr transient;
	//xmlDocCurr := _testController.currentConfigDetails;
	
	self.xCompareConfigDetails(xmlDocPrev, _testController.currentConfigDetails, detailsToOutput);
	
	// create the unit test result
	methEndTS := app.actualTimeServer;
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;

	// work out whether failed or passed
	if not detailsToOutput.isEmpty() then
		resultStr := "Fail";
		tempStr := CrLf &amp; "The following Config (Terminal / System) values are different from the last save:" &amp; CrLf;
		foreach str in detailsToOutput do
			tempStr := tempStr &amp; str;
		endforeach;
		userSummaryDict.addAssociation(app.getUTAdminUserCode(), resultStr &amp; method.getSchemaType().name &amp; " " &amp; method.name &amp; 
			" ADMIN  " &amp; (elapsedTime.getMilliseconds/1000).String &amp; " secs " &amp; methStartTS.date.String &amp; " " &amp; methStartTS.time.String &amp; CrLf &amp; tempStr);
		delete iter;
		iter := userSummaryDict.createIterator();
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
			app.emailReports(association.asStringWithoutFailures(), "Terminal / System Config has changed between this and previous run", 2, _testController);
		endwhile;
	else
		resultStr := "Pass";
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;										
	resultStr := resultStr.trimBlanks().toUpper();
	
	iter.next(unitTestRun);
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), resultStr, tempStr, methStartTS, unitTestRun);
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	
epilog

	//delete xmlDocCurr;
	//delete xmlDocPrev;
	delete iter;
	delete detailsToOutput;
	delete userSummaryDict;
	*/
end;</source>
        <Parameter name="_testController" type="JMTTestController"/>
    </JadeMethod>
    <JadeMethod name="vCheckConfigDetailsEnd" id="8d217769-683e-47cf-8a67-0a14d8b679bc">
        <source>vCheckConfigDetailsEnd(_testController : JMTTestController io; _unitTestRun : UM_UnitTestRun io; _userSummaryDict : CM_AssociationDict io);

/*

Purpose:		Check the Config (Terminal / System) haven't changed during the run

Date			Who		Reason
18/08/2014		cnwmh5	Initial creation

*/

vars

	unitTestRun					: UM_UnitTestRun;
	root						: UM_Root;
	xmlDocPrev					: JadeXMLDocument;
