    <JadeMethod name="updateHazardsFromDetailForm" id="2a738250-3803-4b07-a387-9c305eebb3bf">
        <updating/>
        <source>updateHazardsFromDetailForm(_hazDict: CM_HazardByCodeDict): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazrdous Details Enhancements
//
vars
	str : String;

begin
	self.lstHazardList.setSelected(_hazDict);
	str := self.lstHazardList.getSelectedString;
	self.tblEntry.setValueByName(ETRow_TbaHazards, str);
	
	return true;

epilog

end;</source>
