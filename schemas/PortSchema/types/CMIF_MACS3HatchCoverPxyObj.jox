    <JadeMethod name="endsMidCell" id="d7bda909-2361-4ad2-ae78-710c28fbd873">
        <source>endsMidCell(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin

	return self.stbdEdgeJointType &lt;&gt; "NoOverlap";

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="name" id="15a6f1bb-403c-4d39-94d3-45b00a93b059">
        <methodInvocation>mapping</methodInvocation>
        <source>name(set : Boolean; _value : String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 February 2021	navmd1	Initial creation

*/

vars

begin
	if set then
		// Considering we don't actually care what this is, just keep the first 30 chars
		_value := _value[1:30];
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
