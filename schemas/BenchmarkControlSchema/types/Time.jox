<PrimType name="Time">
    <JadeMethod name="logFormat" id="a6756b0d-4daa-4b7b-9422-faff0f931c59">
        <source>logFormat():String;

begin
	return self.format("HH:mm:ss.")&amp;self.milliSecond.padLeadingWith('0', 3);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
