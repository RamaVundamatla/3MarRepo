    <JadeMethod name="getExtraInfo" id="2b6cf6fd-c5eb-4bc4-b6c0-f7df37465d7d">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Aug 2009	cnwrd1	Initial creation
09 Aug 2018 cnwma1	ChangeRequest 40091: PEL1 - Adding new status at the Cash Receipt
09 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
08 Dec 2018 cnwma1  Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
*/


vars
	block 	    : CM_DataContainerBlock;
	cr 		    : CM_CashReceipt;
	invalidCR 	: Boolean;
	
begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, self);
	block.addNewItem(self.id, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Status), DC_Label, 1, self);
	block.addNewItem(self.getStatusString(), DC_Data, 1, self);

	// TFS 38524
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Description), DC_Label, 1, self);
	block.addNewItem(self.getDisplayString(), DC_Data, 1, self);

	//09 August 2018  cnwma1 40091
	if self.allCashReceipts.isNotEmpty then
		on Exception do app.handleDeletedObject(exception,cr, invalidCR);
		
		block := _dataContainer.addNewBlock;
		foreach cr in self.allCashReceipts discreteLock do
			if cr.getDebtor &lt;&gt; null then
				block.addNewItem(app.getErrorString(Cash_receipts), DC_Label, 1, cr);
				block.addNewItem(
				app.getErrorString(Debtor_GC) &amp;':'&amp;
				cr.getDebtor.name	&amp;Cr&amp;
				app.getErrorString(Estimation) &amp; ':' &amp;
				cr.externalInvoiceNumber &amp;Cr&amp; 
				app.getErrorString(Payment_type) &amp;':'&amp;
				app.paymentTypeEnumToString(cr.paymentType)	&amp;Cr&amp;
				app.getErrorString(Business_units) &amp;':'&amp;
				cr.getBankCode	&amp;Cr&amp;
				app.getErrorString(TYPE) &amp;':'&amp;                   //08.12.2018 cnwma1 Bug #42441
				cr.getInvoiceTypeDesc	&amp; Cr&amp;                    //08.12.2018 cnwma1 Bug #42441
				app.getErrorString(Credit_check_status) &amp;':' &amp;
				cr.getPaymentStatusStr(cr.paymentStatus) &amp; Cr&amp;   //29.09.2021 navma1 #51925
				app.getErrorString(Amount) &amp;':' &amp;                //29.09.2021 navma1 #51925
				cr.cashValue.asCurrencyJMT						 //29.09.2021 navma1 #51925							
				, DC_Data, 1, cr
				);
			endif;
		endforeach;
	endif;
	
	//16.12.2021 navma1 #52580
	if not self.allInvoices.isEmpty then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Invoice), DC_Label, 1, self.allInvoices.first);
		block.addNewItem(self.allInvoices.listString(Comma,CM_Invoice::sequenceNum.name) , DC_Data, 1, self.allInvoices.first);
	endif;
	
	//12.01.2023 navma1 #56141 Task#56147
	block := _dataContainer.addNewBlock;
	block.addNewItem('Requested By', DC_Label, 1, self);
	block.addNewItem(self.getEnteredByDisplay(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Requested By Date', DC_Label, 1, self);
	block.addNewItem(self.enteredByDT.asStringJMT, DC_Data, 1, self);
	
	if self.approvedBy &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Confirmed By', DC_Label, 1, self);
		block.addNewItem(self.approvedBy, DC_Data, 1, self);
	endif;
	//12.01.2023 navma1 #56141 Task#56147
	
	if app.isSpecial then														//08.02.2023 navma1 #56457:[56458]
		block.addNewItem('Use Yard Jobs', DC_Label, 1, self);
		block.addNewItem(self.getMyTerminal.isUseYardJobsForCargoWo().String, DC_Data, 1, self);
		
		block.addNewItem('Auto Action Cargo Allowed', DC_Label, 1, self);
		block.addNewItem(self.getMyTerminal.getConfig(AllowAutoActionCargoWo).Boolean.String, DC_Data, 1, self);
		
		block.addNewItem('Auto Action ToDo Allowed', DC_Label, 1, self);
		block.addNewItem(self.getMyTerminal.getConfig(AllowAutoActionToDoWO).Boolean.String, DC_Data, 1, self);
		
		block.addNewItem('Work Order Transactions', DC_Label, 1, self);
		block.addNewItem(self.allTransactions.size.String, DC_Data, 1, self);
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
