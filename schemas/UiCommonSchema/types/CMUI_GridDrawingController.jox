        <source>notableObjectRemove(_obj : Object);
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if self.allNotableObjects.includes(_obj) then
		self.allNotableObjects.remove(_obj);
		self.notableObjectEndNotes(_obj);
	endif;
