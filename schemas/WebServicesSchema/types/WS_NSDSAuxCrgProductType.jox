    <JadeMethod name="setProxyObject" id="897d968b-66e0-400a-9ad1-1d1bf69edbd2">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*
Purpose:			

Date		Who		Reason
20MAY2022	NAVAB1	TFS 53105
*/

vars
	helper 	: CMIF_AuxCrgProductType;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName	:= helper.tableName;
	self.gkey       := helper.gkey;
	self.client_id 	:= helper.client_id;
	self.id 		:= helper.id;
	self.description := helper.description;
	self.created	:= helper.created;
	self.creator := helper.creator;
	self.changed	:= helper.changed;
	self.changer := helper.changer;
	

epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
