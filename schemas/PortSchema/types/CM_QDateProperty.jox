<Class name="CM_QDateProperty" id="60c507c9-cba6-4816-bf7c-0007d74db19c">
    <superclass name="CM_QueryProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="23900aa8-ed33-4058-91ee-9b2070d2de01">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QDateRange persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateDayRange persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateDayEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateDayGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDateDayLessThan persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="47470506-1127-4803-8c32-cc45013ee673">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// ---------------------------------------------------------------------------
// Created:     03 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _op.isKindOf(CM_QDateRange) then
		return QueryControl_DateRange;
	elseif _op.isKindOf(CM_QDateEquals) then
		return QueryControl_Date;
	elseif _op.isKindOf(CM_QDateGreaterThan) then
		return QueryControl_Date;
	elseif _op.isKindOf(CM_QDateLessThan) then
		return QueryControl_Date;
	elseif _op.isKindOf(CM_QDateDayRange) then
		return QueryControl_NumTextBoxRange;
	elseif _op.isKindOf(CM_QDateDayEquals) then
		return QueryControl_TextBox;
	elseif _op.isKindOf(CM_QDateDayGreaterThan) then
		return QueryControl_TextBox;
	elseif _op.isKindOf(CM_QDateDayLessThan) then
		return QueryControl_TextBox;
	endif;

	return inheritMethod(_op);


end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
