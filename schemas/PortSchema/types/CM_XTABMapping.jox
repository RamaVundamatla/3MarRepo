    <JadeMethod name="cloneSelf" id="69997eee-eb9b-4254-b73c-320396e866ef">
        <source>cloneSelf(bTransient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	clone	:SelfType;
	line	:CM_XTABMappingLine;
begin
	clone := inheritMethod(bTransient);
	
	foreach line in self.allMappingLines do
		clone.allMappingLines.add (line.cloneSelf (bTransient));
	endforeach;

	return clone;
epilog

end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="create" id="04153375-92c1-479b-bd9f-3aca6f297595">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// default values
	self.order := CM_XTABMapping.ORDER_MAPPING;
	self.otherValues := CM_XTABMapping.OTHER_GROUPED;
	self.otherHeading := 'Other';
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllMappingLineValues" id="1a0b0033-9f16-4e81-8126-843f83933430">
        <source>getAllMappingLineValues(_array :StringArray input);
// ---------------------------------------------------------------------------
// Created:     03 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	line	:CM_XTABMappingLine;
	int		:Integer;
begin
	_array.clear;
	
	foreach line in self.allMappingLines do
		_array.add (line.getMappingLineValue);
	endforeach;
	
	if self.otherValues = self.OTHER_GROUPED then
		if self.order = self.ORDER_MAPPING_VALUE then
			_array.add (self.otherHeading);
		else
			_array.add (self.MAPPING_OTHER_VALUE);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMaxMappingValueLength" id="9e85663d-ba1f-4a8f-8f28-71ec63e4be9c">
        <source>getMaxMappingValueLength():Integer;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Get maximum length of any mapping values
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwcs5		Take into account the other value
// ---------------------------------------------------------------------------
vars
	obj		:Object;
	value	:Integer;
begin
	if self.order = self.ORDER_MAPPING then
		value := self.MAPPING_OTHER_VALUE.length;
	else
		foreach obj in self.allMappingLines do
			value := value.max (obj.CM_XTABMappingLine.mappedValue.length);
		endforeach;
	endif;
	
	if self.order = self.ORDER_MAPPING then 
		value := value.max (self.MAPPING_OTHER_VALUE.length);	
	elseif self.otherValues = self.OTHER_GROUPED then
		value := value.max (self.otherHeading.length);
	endif;
	
	return value;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryProperty" id="4d68b15f-1c66-4622-99d9-3c0fe4f279aa">
        <source>getQueryProperty():CM_QueryProperty;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	:Iterator;
	def		:CM_QueryDefinition;
	prop	:CM_QueryProperty;
begin
	// NOTE : we will look for the first query definition object with a matching type
	// 
	
	iter := app.myRoot.allQueryDefinitionObjects.createIterator;
	
	app.myRoot.allQueryDefinitionObjects.startKeyGeq(self.type, null, iter);
	
	while iter.next (def) do
		if def.type &lt;&gt; self.type then
			break;
		endif;
		
		prop := def.allQueryProperties[self.propertyName];
		
		if prop &lt;&gt; null then
			return prop;
		endif;
	endwhile;
	
	// can't find property for our type - what about other types
	// we are relying on the fact that if the same propertyName is used for different types
	// it will be the same property type (Integer) and that is all that matters
	iter.reset;
	while iter.next (def) do
		prop := def.allQueryProperties[self.propertyName];
		
		if prop &lt;&gt; null then
			return prop;
		endif;	
	endwhile;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
