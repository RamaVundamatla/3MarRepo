    <JadeMethod name="resetBOLType" id="aec427cb-2060-42e8-b21e-dc19c05aa332">
        <source>resetBOLType(pConstant : Constant; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     13 June 2002 by cnwsb1
//
// Purpose:     This is used as a "callBack" method from "resetBOLTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type BOLTypeConstants
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text			: String;
	descr			: String;
	abbr			: String;
	proxyBOLType	: CM_BOLType;
	realBOLType		: CM_BOLType;
	
begin

	if pConstant.valueAsInteger &lt;= BOLType_Min or
	   pConstant.valueAsInteger &gt;= BOLType_Max then
	   	return;
	endif;

	text := pConstant.text;
	
	descr 	  := text.cnEcGetTagValueOfName('Descr');
	abbr  	  := text.cnEcGetTagValueOfName('Abbr');
	
	if descr = null or abbr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid format for text for cargo type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	realBOLType := self.allBOLTypes[pConstant.valueAsInteger];
	
	if realBOLType = null then
		// treat as a create
		create proxyBOLType transient;
		proxyBOLType.setProxyFromXML(pConstant.valueAsInteger, text, true, self);
		app.myUtilityCA.utlCreateBOLType(proxyBOLType, realBOLType, app.myPassport);
	else
		proxyBOLType := app.createUpdateProxy(realBOLType).CM_BOLType;
		proxyBOLType.setProxyFromXML(pConstant.valueAsInteger, text, false, self);
		app.myUtilityUA.utlUpdateBOLType(proxyBOLType, app.myPassport);
	endif;

epilog
	delete proxyBOLType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
