    <JadeMethod name="isExtraDetailRequired" id="81dea7aa-3543-407a-8c6f-1b42c2641db3">
        <source>isExtraDetailRequired(_dataContainer: CM_DataContainer output): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	28 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	user	: CM_User;	
begin
	

	//cnwrd1 28.1.11 par 26837
	//very hacky this we need to check if this is for edi details and check security.	
	if self.description = EDIDetails then
		user := app.getMyUser();
		if not user.canDo(self.myTerminal, PmAdmEdiopersView) then
			return false;
		endif;
	endif;

	self.getEnquiryRowFullInfo(_dataContainer);
	return _dataContainer &lt;&gt; null;
end;
</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYAPlanInformation" id="88301a91-812b-4f8c-a84f-723becc3ca26">
        <source>isYAPlanInformation(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	//29 Nov 2013	NDL	Par 32991
	if self.description[1:16].toUpper = IsYardAllocationInfo then
		return true;
	endif;
	
	return false;
	
	// These were used here...  leave as areference, so they are easily found....
	if self.description = YardAllocationLogging  // duplicated, should have been YardAllocationAutoPlan
	or self.description = YardAllocationDirTaskPlan
	or self.description = YardAllocationLogging
	or self.description = YardAllocationOSLogging // this one is truncated on the way in and had lower case 'y'
	then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="fc481d5f-03f2-4a93-89e3-2423e257c46c">
        <updating/>
        <source>setForDelete(_reason: String) updating;
//
// par 16530 cnwrs1 May 2008
//
vars

begin
	if app.isGarbageCollectionProcess then
		delete self;
	else
		inheritMethod(_reason);
	endif;
end;
</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
