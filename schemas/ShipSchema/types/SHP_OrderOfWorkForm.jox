    <JadeMethod name="doOpenTransferWorkCraneFrm" id="f6fe7376-a152-4a36-b1a4-7c9f290d1f94">
        <source>doOpenTransferWorkCraneFrm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2019	jlgdap1		Initial creation TFS 47144 JMT Refactor OOW Job Split Transfer
//
vars
	allVoyageJobs : CM_JobArray;
	job : CM_Job;
	
begin
	create allVoyageJobs transient;
	self.getSelectedJobs(allVoyageJobs,false);
	
