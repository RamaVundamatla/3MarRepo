        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="d76d303a-de2c-49e6-8684-5e55bddb515a">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	proxySealCheck : CM_SealCheck;
	pxySealCheckDetail : CM_SealCheckDetail;
	realSealCheckDetail : CM_SealCheckDetail;

begin

	inheritMethod(_tiTransCntrl, _passport);
	
	proxySealCheck := _tiTransCntrl.myTITransaction.CM_SealCheck;
	
	if proxySealCheck &lt;&gt; null then
		foreach pxySealCheckDetail in proxySealCheck.allSealCheckDetails do
			create realSealCheckDetail;
			realSealCheckDetail.setFromProxy(pxySealCheckDetail);
			realSealCheckDetail.setMySealCheck(self);
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
