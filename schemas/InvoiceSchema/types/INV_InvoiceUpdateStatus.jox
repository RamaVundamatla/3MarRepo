    <JadeMethod name="mskEndDate_lostFocus" id="f370cebf-acf9-4472-88ae-15b7b0ff606d">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mskEndDate_lostFocus(editMask: JadeEditMask input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61332: UI - Invoice Post

*/

vars
	enddate : Date;
begin
	
	// self.tblInvProperties.setValueByName(ETRow_EndDate, self.mskInvoiceDate.getDate());
	enddate := self.mskEndDate.getDate();
	self.tblInvProperties.setValueByName(ETRow_EndDate,enddate ); // ### TFS BUG 63885 29APR2024 NAVAB1

	if not enddate.isValid() then
		return;
	endif;
	
	self.calculateDueDate(self.mskEndDate);
epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mskInvoiceDate_lostFocus" id="4f25da5d-671d-46de-8bce-ad37abf5785c">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mskInvoiceDate_lostFocus(editMask: JadeEditMask input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61332: UI - Invoice Post

*/

vars

begin

	self.tblInvProperties.setValueByName(ETRow_InvoiceDate, self.mskInvoiceDate.getDate());
	
	if not self.mskInvoiceDate.getDate().isValid() then
		return;
	endif;
	
	self.calculateDueDate(self.mskInvoiceDate);
epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCaption" id="2727d233-f8eb-4b54-a404-a1d8c979a62d">
        <updating/>
        <source>setMyCaption() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	theCaption : String;
	invNum		: String;
	invoice		: CM_Invoice;
	status		: String;
	
begin
	
	if self.newStatus = CM_Invoice.INVOICE_POSTED then
		status := " Post ";
	elseif self.newStatus = CM_Invoice.INVOICE_PENDING then
		status := " Pending ";
	endif;
	
	if self.isCreditNote then
		if self.isMulti then
			theCaption := "Multi-select" &amp; status &amp; self.allInvoices.size().String &amp; " Credit Note(s)";
		else
			theCaption := "Credit Note" &amp; status;
		endif;
	else
		if self.isMulti then
			theCaption := "Multi-select" &amp; status &amp; self.allInvoices.size().String &amp; " Invoice(s)";
		else
			theCaption := "Invoice" &amp; status;
		endif;
	endif;
	
	foreach invoice in self.allInvoices do
		if invNum &lt;&gt; null then
			invNum &amp;= ", " &amp; invoice.sequenceNum.String;
		else
			invNum := invoice.sequenceNum.String;
		endif;
	endforeach;
	
	if self.isMulti then
		theCaption &amp;= " " &amp; invNum;
	else
		theCaption &amp;= " " &amp; invNum &amp; " - " &amp; self.myCurrentInvoice.debtor.name;
	endif;
	
	self.caption := theCaption[1:255]; // ### TFS CR 62992 TASK 62994 02APR2024 NAVAB1

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fe3815c4-80d9-4662-aa2d-341a55bf5045">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

begin
	
	self.isMulti := self.allInvoices.size() &gt; 1;
	
	inheritMethod();
	
	self.initForStatus();
epilog

end;</source>
    </JadeMethod>
