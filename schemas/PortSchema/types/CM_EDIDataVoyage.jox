    <JadeMethod name="verifyEDIDataTIs" id="2ecfc604-c7c9-47a2-93b8-0a1f8dd8c5a0">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:	15 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Messina 1008 PAR 20320 
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/08/2025	navdap1		MTN-35604 NSW - Load Partial Voyage EDI
// ---------------------------------------------------------------------------

vars
	cmifVoyageConsist : CMIF_VoyageConsist;
	errorSet : CM_ErrorSet;			// MTN-35604
	allowPartialLoad : Boolean;		// MTN-35604
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	create cmifVoyageConsist transient;
	cmifVoyageConsist.myEDIData := self;

	self.setupProxies(Verifying_Loaded_Details, cmifVoyageConsist, _passport);
	
	allowPartialLoad := self.getMyTerminal.getConfig(EdiVoyageAllowPartial).Boolean;	// MTN-35604
	if _passport.hasErrors() and not allowPartialLoad then								// MTN-35604
		return _passport.allErrors.size();
	endif;
	
	// MTN-35604 Allow partial loading
	if allowPartialLoad then
		create errorSet transient;
		_passport.moveErrorsToSet(errorSet);
		app.myTrxUA.trxProcessEDIVoyageConsistPart(cmifVoyageConsist, true, errorSet, _passport);
	else
		app.myTrxUA.trxProcessEDIVoyageConsist(cmifVoyageConsist, true, _passport);
	endif;
	
	return _passport.allErrors.size();
epilog
	cmifVoyageConsist.purge();
	delete cmifVoyageConsist;
	delete errorSet;			// MTN-35604
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
