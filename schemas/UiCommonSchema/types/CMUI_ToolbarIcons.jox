        <source>btnUpdateDisFromIcon2021_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
13 August 2021	navab1	TFS 50669
*/

vars

	button : CMUI_ToolbarIcon;
	icon : CMUI_IconFile;
	idx : Integer;
begin


	icon := self.cmbIconFiles2021.listObject.CMUI_IconFile;
	
	foreach button in self.tblData.allSelectedObjects as CMUI_ToolbarIcon do
	
			beginTransaction;
				if icon &lt;&gt; null then
					button.disabledIconNameDisk := icon.name;
					button.disabledIconNew := icon.icon;
				else
					button.disabledIconNameDisk := null;
					button.disabledIconNew := null;
				
				endif;

			commitTransaction;
	
		// ### ENABLED KEY
		if button.enabledIconNew &lt;&gt; null then
			self.tblData.findObjectInRow(button,idx);
			self.tblData.accessCell(idx,10).picture := button.disabledIconNew;
			self.tblData.accessCell(idx,1).text := button.disabledIconNameDisk;
		endif;
	
	endforeach;
	
	self.tblData.deselectAll();

epilog

end;</source>
