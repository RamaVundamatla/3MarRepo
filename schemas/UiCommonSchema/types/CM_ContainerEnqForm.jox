    <JadeMethod name="getEditTableForSheet" id="888a420e-4566-4e4c-8551-8814e16f069b">
        <source>getEditTableForSheet(_sht : CMUI_Sheet) : CM_EntryTable protected;
// ---------------------------------------------------------------------------
// Created:     30 January 2003		cnwth2	
//
