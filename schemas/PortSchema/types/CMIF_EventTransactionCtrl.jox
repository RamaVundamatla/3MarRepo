    </PrimAttribute>
    <JadeMethod name="createEventTransaction" id="304465d7-acf4-453a-a469-95ad2565f5d1">
        <source>createEventTransaction(_eventType : CM_EventType) : CM_EventTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	eventTransaction			: CM_EventTransaction;
begin
	
	create eventTransaction as _eventType.myClassToCreate persistent;
	
	eventTransaction.setDetailsFromCMIF(_eventType, self);
	
	return eventTransaction;
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
</Class>
