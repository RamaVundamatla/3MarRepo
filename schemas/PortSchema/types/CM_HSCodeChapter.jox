    <JadeMethod name="getDisplayStringForAttribute" id="d302aff2-8126-4c6b-873e-62662d9dab4f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if _attrName = ETRow_Type then
		return app.getErrorString(Chapter);
	elseif _attrName = ETRow_HsParentSection then
		if self.myHSSection &lt;&gt; null then
			return self.myHSSection.id;			
		endif;
		return null;		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="c4046df4-77d2-4b2f-84f7-595545fafcc8">
        <source>getFullDescription() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if self.myHSSection = null then
		return inheritMethod;
	endif;
	
	return self.myHSSection.getFullDescription() &amp; ": " &amp; self.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
