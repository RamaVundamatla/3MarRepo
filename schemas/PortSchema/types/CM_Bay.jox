    <JadeMethod name="bayTypeString" id="a07cc98e-7bb0-4af9-882c-7bba9d491e9b">
        <methodInvocation>mapping</methodInvocation>
        <source>bayTypeString(set: Boolean; _value: String io) mapping;
/*
 ------------------------------------------------------------------------
Created:			16 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.bayType = BAY_TYPE_SINGLE then
		_value := "Single Bay";
	elseif self.bayType = BAY_TYPE_TWIN then
		_value :=  "Twin Bay";
	elseif self.bayType = BAY_TYPE_TRIPLE then
		_value := "Triple Bay";
	else
		_value := 'Unknown';
	endif;		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="canHandle4045" id="419ebfcd-f117-4583-aa68-7c2406248d7a">
        <source>canHandle4045() : Boolean;
// ---------------------------------------------------------------------------
// Created:		31 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return (self.fortyFiveFootBay or self.fortyFootBay);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAndResetOrdinals" id="27e27b49-2a71-4412-bdb6-78c311cbed44">
        <updating/>
        <source>checkAndResetOrdinals(_cellDefn : CM_CellDefn;_tierDefn : CM_TierDefn;_onDeck : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     March 2003 AKndrew Bishop
//
// Purpose:     If a cell or tier is inserted then we need to rejig the existing slot definitions
//              
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ordinalDeck : Integer;
	realSlotDefn, pxySlotDefn : CM_SlotDefn;
	cellId, tierId : String;
	ordinalSlot : Integer;
	onDeck,loadState,newCellTier:Boolean;
	theSlots : ObjectArray;
	anObject : Object;
begin
	newCellTier := false;
	foreach realSlotDefn in _tierDefn.allSlotDefinitions do : checkLoop
		if realSlotDefn.tierId = _tierDefn.id and realSlotDefn.ordinalTier &lt;&gt; _tierDefn.ordinal 
		or realSlotDefn.cellId = _cellDefn.id and realSlotDefn.ordinalCell &lt;&gt; _cellDefn.ordinal then
			newCellTier := true; // this should make sure that we only reset all the ordinal once and only if we have to
			break checkLoop;
		endif;
	endforeach;
	if newCellTier then
		create theSlots transient;
		if _onDeck then
			self.allSlotsOnDeck.copy(theSlots);
		else
			self.allSlotsUnderDeck.copy(theSlots);
		endif;
		
		// we put them into an array so that we can change the ordinals. Other wise this will loop
		// so move all the slots out of the way, so that we can then go through as a wave and attach them to the correct cell and tier
		foreach anObject in theSlots do
			
			realSlotDefn := anObject .CM_SlotDefn;
			/*realSlotDefn:=self.allSlotsByOrdinal[realSlotDefn.ordinalDeck,realSlotDefn.ordinalCell,realSlotDefn.ordinalTier];
			if realSlotDefn = null then
				continue;
			endif;*/
			realSlotDefn.setForUpdateOrdinals(realSlotDefn.ordinalDeck, realSlotDefn.ordinalCell + 200, realSlotDefn.ordinalTier + 200);
		endforeach;
		foreach anObject in theSlots do
			realSlotDefn := anObject.CM_SlotDefn;
			realSlotDefn.setForUpdateOrdinals(realSlotDefn.ordinalDeck, realSlotDefn.myCellDefinition.ordinal, realSlotDefn.myTierDefinition.ordinal);
		endforeach;

	endif;
epilog
	if theSlots &lt;&gt; null then
		delete theSlots;
	endif;
	
	return newCellTier;
end;</source>
        <Parameter name="_cellDefn" type="CM_CellDefn"/>
        <Parameter name="_tierDefn" type="CM_TierDefn"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSlots" id="6b52c4b8-63b9-4363-9e22-449268d63963">
        <updating/>
        <source>createSlots() updating;
// ---------------------------------------------------------------------------
// Created:     22 March 2002 by cnwdwq1
//
// Purpose:     Creates the slots for the cells and tiers of this bay.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyBay : SelfType;
	pxySlotDefn : CM_SlotDefn;
begin

	exclusiveLock(self);

//	self.eraseSlots(); //Remove any existing ones PAR TIERS removed
	self.allSlotsByOrdinal.purge(); // PAR TIERS added

	self.internalCreateSlots(true);
	self.internalCreateSlots(false);
	self.setSequenceNums();


end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateProxyCellsFromXML" id="a72641f0-323e-4137-8a48-0e2a43f90bff">
        <source>doCreateProxyCellsFromXML(_theXML : String; _onDeck : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyCell : CM_CellDefn;
	pos, theOrdinal,  theHiCubeHeight : Integer;
	theXML  : String;
	theAlignment : Real;
begin
	pos := 1;
	while (pos &gt; 0) do
		theXML := _theXML.cnEcGetNextTagValueOfName("id",pos); 
		if theXML = null then
			break;
		endif;
		theOrdinal := _theXML.cnEcGetNextTagValueOfName("ord",pos).Integer; 
		theAlignment := _theXML.cnEcGetNextTagValueOfName("al",pos).Real; 
		theHiCubeHeight := _theXML.cnEcGetNextTagValueOfName("hi",pos).Integer; 
		create aProxyCell transient;
		// the alignment allows users to move a cell, graphically, away from its neighbour
		if _onDeck then
			aProxyCell.setProxy(theXML.trimBlanks,theAlignment,theOrdinal,self,null,null);
		else
			aProxyCell.setProxy(theXML.trimBlanks,theAlignment,theOrdinal,null,self,theHiCubeHeight);
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateProxySlotsFromXML" id="9870eb5c-37c0-4af4-b79c-e64e88c629ee">
        <source>doCreateProxySlotsFromXML(_theXML : String; _onDeck : Boolean) protected;
// ######################################################
// ######################################################
// ######################################################

// please note that if you are adding a new attribute, you MUST add them in 
//	the same position that they are in the export. Also see PAR 19443 below if adding new attributes

// ######################################################
// ######################################################
// ######################################################
// ######################################################





// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxySlot : CM_SlotDefnVessel;
	pos,  voltage : Integer;
	theordinalCell,theordinalDeck,theordinalTier,thesequenceNumPortDis,thesequenceNumPortLoad,thesequenceNumStarDis,thesequenceNumStarLoad:Integer;
	thedoors20Aft,thedoors40Aft,thefortyBack,thefortyFront,themotor20Aft,themotor40Aft,thepower,thereefer,themtOnly,theunavailable,thewatercooled, heavy:Boolean;
	sdIs30, sdIs45, sdIs53 : Boolean;
	thecellId,thetierId:String;
	has40Set : Boolean;
	is40, savedPos : Integer;
begin

	pos := 1;
	while (pos &gt; 0) do

		// new method getNextTagValueOfName() //PAR13045
		theordinalCell := _theXML.cnEcGetNextTagValueOfName("oc",pos).Integer; 
		if theordinalCell = 0 then
			break;
		endif;
		
		theordinalTier:= _theXML.cnEcGetNextTagValueOfName("ot",pos).Integer; 
		
		
		theunavailable:= _theXML.cnEcGetNextTagValueOfName("na",pos).Integer.Boolean; 
		
		thewatercooled:= _theXML.cnEcGetNextTagValueOfName("wc",pos).Integer.Boolean; 
		
		thedoors20Aft := _theXML.cnEcGetNextTagValueOfName("d20",pos).Integer.Boolean; 
		
		thedoors40Aft := _theXML.cnEcGetNextTagValueOfName("d40",pos).Integer.Boolean; 
		
		is40 			:= _theXML.cnEcGetNextTagValueOfName("f40",pos).Integer;
		
		has40Set := is40.Boolean; 
		themotor20Aft	:= _theXML.cnEcGetNextTagValueOfName("m20",pos).Integer.Boolean;
		
		themotor40Aft	:= _theXML.cnEcGetNextTagValueOfName("m40",pos).Integer.Boolean; 
		
		themtOnly		:= _theXML.cnEcGetNextTagValueOfName("mt",pos).Integer.Boolean; 

		voltage := _theXML.cnEcGetNextTagValueOfName("vt",pos).Integer; 
		heavy 		:= _theXML.cnEcGetNextTagValueOfName("hv",pos).Integer.Boolean; 
		
		thepower		:= _theXML.cnEcGetNextTagValueOfName("pw",pos).Integer.Boolean; 
		
		thereefer		:= _theXML.cnEcGetNextTagValueOfName("rf",pos).Integer.Boolean; 
		
		
		
		
		
		
		savedPos := pos;// PAR 19443
		sdIs30		:= _theXML.cnEcGetNextTagValueOfName("is30",pos).Integer.Boolean; // PAR 18682
		
		// PAR 19443 if old file is being loaded then this tag will not be found.
		if pos = 0 then
			pos := savedPos;
		else
			sdIs45		:= _theXML.cnEcGetNextTagValueOfName("is45",pos).Integer.Boolean; // PAR 18682 
			sdIs53		:= _theXML.cnEcGetNextTagValueOfName("is53",pos).Integer.Boolean;  // PAR 18682
		endif;
	
	
		// If adding a new attribute check for a POS of zero see above for example
		// #############################################
		// #############################################
		// #############################################
		// #############################################
		
	
	
	
	
		if _onDeck then
//			theRowOrdinal := (self.allTiersOnDeck.size - theordinalTier) + 1; // &lt;&lt;&lt;&lt; REMOVE THIS
//			theordinalTier := theRowOrdinal;
			
			theordinalDeck := DeckOnDeck; 
			thecellId := self.allCellsOnDeckByOrdinal[theordinalCell].id; 
			thetierId := self.allTiersOnDeck[theordinalTier].id; 
		else
//			theRowOrdinal := (self.allTiersUnderDeck.size - theordinalTier) + 1; // &lt;&lt;&lt;&lt; REMOVE THIS
//			theordinalTier := theRowOrdinal;

			theordinalDeck := DeckUnderDeck; 
			thecellId := self.allCellsUnderDeckByOrdinal[theordinalCell].id; 
			thetierId := self.allTiersUnderDeck[theordinalTier].id; 
		endif;

		thefortyBack := false;
		thefortyFront := false;
		if has40Set then
			if self.isForwardBay then
				thefortyFront := true;
			else
				thefortyBack := true;
			endif;
		endif;

		
		create aProxySlot transient;
		aProxySlot.setProxy(theordinalCell,theordinalDeck,theordinalTier,thesequenceNumPortDis,thesequenceNumPortLoad,thesequenceNumStarDis,
				thesequenceNumStarLoad,voltage,thedoors20Aft,thedoors40Aft,thefortyBack,thefortyFront,themotor20Aft,themotor40Aft,thepower,thereefer,
				themtOnly,theunavailable,thewatercooled,heavy,thecellId,thetierId, sdIs30, sdIs45, sdIs53); // PAR 18682
		if _onDeck then
			aProxySlot.setMyBay(self, _onDeck);
			aProxySlot.setCellAndTierDefn(self.allCellsOnDeckByOrdinal[theordinalCell],self.allTiersOnDeck[theordinalTier]);
		else
			aProxySlot.setMyBay(self, _onDeck);
			aProxySlot.setCellAndTierDefn(self.allCellsUnderDeckByOrdinal[theordinalCell],self.allTiersUnderDeck[theordinalTier]);
		
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateProxyTiersFromXML" id="fef2fa90-c453-47e2-82d6-a3ccefc41e44">
        <source>doCreateProxyTiersFromXML(_theXML : String; _onDeck : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyTier : CM_TierDefn;
	pos, theOrdinal : Integer;
	theXML : String;
begin
	pos := 1;
	while (pos &gt; 0) do
		theXML := _theXML.cnEcGetNextTagValueOfName("id",pos); 
		if theXML = null then
			break;
		endif;
		theOrdinal := _theXML.cnEcGetNextTagValueOfName("ord",pos).Integer; 
		create aProxyTier transient;
		// the alignment allows users to move a cell, graphically, away from its neighbour
		if _onDeck then
			aProxyTier.setProxy(theXML.trimBlanks,theOrdinal,theOrdinal,self,null);
		else
			aProxyTier.setProxy(theXML.trimBlanks,theOrdinal,theOrdinal,null,self);
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="b38a232b-331f-43d6-ba57-ef450c4683ad">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	inheritMethod(_converter, _logIndent);

	_converter.doChangeVolatilityOfObject(self.allCellsOnDeck, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allCellsOnDeckByOrdinal, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allCellsUnderDeck, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allCellsUnderDeckByOrdinal, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allHatchLids, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allSlotsByOrdinal, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allSlotsOnDeck, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allSlotsUnderDeck, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allTiersOnDeck, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allTiersOnDeckByLabel, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allTiersUnderDeck, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allTiersUnderDeckByLabel, _logIndent);
	
	
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doValidateCellTierLabels" id="d4118f65-19dc-4cf2-897d-0fe5d65d7877">
        <source>doValidateCellTierLabels(	_newLabels : String;
							_messageLabel : String;
							_oldLabels : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:	
//
// ---------------------------------------------------------------------------

vars

	aLabel, oldLabels : String;
	theLabels,theoldLabels, tmpLabels : StringArray;
	idx,theReturn : Integer;
	bayID : String;
	newLabelSize, oldLabelSize : Integer;
begin
	
	bayID := self.id;

	aLabel := _newLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	idx := 0;
	oldLabels := _oldLabels;
	oldLabels.replaceString(" ","|");
	theoldLabels := oldLabels.getTokens;

	newLabelSize := theLabels.size;
	oldLabelSize := theoldLabels.size;
	
	//epr par 34819 removed validation for adding more than one bay at a time - this now works without errors

	// ### CHECK FOR DUPLICATES
	create tmpLabels transient;
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		// PAR 16323 &amp; 17208
		if aLabel.length()  &gt; 2 then
			app.msgBox(app.getErrorString2(Bay_ID_too_long,_messageLabel,aLabel ), _messageLabel &amp; app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		idx := idx + 1;

		if tmpLabels.includes(aLabel.trimBlanks) then
			app.msgBox(app.getErrorString2(Duplicate_ID_For,_messageLabel, aLabel),_messageLabel,MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		else
			tmpLabels.add(aLabel.trimBlanks);
		endif;
	endforeach;


	// ## CONFIRM CHANGES
	if oldLabelSize &gt; newLabelSize
	or (_newLabels &lt;&gt; oldLabels and oldLabels &lt;&gt; null)  then
		theReturn := app.msgBox("Are You Sure That You Want To Change " &amp; _messageLabel &amp; "s From Bay " &amp; bayID &amp; "?",_messageLabel &amp; " Delete",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		return (theReturn = MsgBox_Return_Yes);
	endif;
	
	return true;
epilog
	delete theLabels;
	delete tmpLabels;
	delete theoldLabels;

end;</source>
        <Parameter name="_newLabels" type="String"/>
        <Parameter name="_messageLabel" type="String"/>
        <Parameter name="_oldLabels" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateTotalHiCubesUDCells" id="a39fcdbb-3f54-4a08-929b-deedbaa73e10">
        <source>doValidateTotalHiCubesUDCells(_newLabels : String; _messageLabel : String): Boolean;
// ---------------------------------------------------------------------------
// Created:		11/08/2008 2004 By  cnwaer1
//
// Purpose:		Par 13608 - Validation for "Total HiCubes UD Per Cell" field
//
// ---------------------------------------------------------------------------
vars
	aLabel : String;
	theLabels :StringArray;
begin
	aLabel := _newLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		if aLabel.length() &gt; 2 then
			app.msgBox(	app.getErrorString2(Bay_ID_too_long,_messageLabel,aLabel ), _messageLabel &amp; " ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endforeach;
	return true;
epilog
	delete theLabels;
end;
</source>
        <Parameter name="_newLabels" type="String"/>
        <Parameter name="_messageLabel" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b3b3372a-6ef8-44e5-b928-70eaaca0c273">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	exclusiveLock(self);
	if self.myForwardBay &lt;&gt; null then
		exclusiveLock(self.myForwardBay);
	endif;
	if self.myAftBay &lt;&gt; null then
		exclusiveLock(self.myAftBay);
	endif;
	if self.myForwardBay &lt;&gt; null then
		self.myForwardBay.myAftBay := self.myAftBay;
	endif;
	if self.myAftBay &lt;&gt; null then
// WAS		self.myAftBay.myForwardBay := self.myForwardBay;
		self.myAftBay.myAftBay := self;
	endif;
		
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="545b428f-5c4e-41af-8a10-9927ec9d10f2">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input) : Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_Bay::myAftBay then
		return CM_Bay::id;
	elseif _property = CM_Bay::myForwardBay then
		return CM_Bay::id;
	elseif _property = CM_Bay::myHold then
		return CM_VesselHold::ordinalHold;
	elseif _property = CM_HatchLid::allBays then
		return CM_Bay::id;
	endif;
	
	return inheritMethod(_property);
	

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
