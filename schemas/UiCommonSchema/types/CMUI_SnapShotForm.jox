        <updating/>
        <source>btnOK_click(btn: Button input) updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.cmbLGDOperators.listObject = null then
		app.msgBox("You must select an Operator from the" &amp;
					CrLf &amp; "list before a new snap shot can be added.", self.caption, 0);
		return;
	endif;	

	self.doAddCargoItem(self.cmbLGDOperators.listObject.CM_Operator);

	self.hideOpPicker();
epilog

end;</source>
