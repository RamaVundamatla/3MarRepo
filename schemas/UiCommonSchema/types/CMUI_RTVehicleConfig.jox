	chkTaskGetNext.translateCaption(Xlat_0015014, locale);
	chkTaskList.translateCaption(Xlat_0015015, locale);
	chkWarnChgSet.translateCaption(Xlat_0024400, locale);
	grpIdleandDelay.translateCaption(Xlat_0025119, locale);
