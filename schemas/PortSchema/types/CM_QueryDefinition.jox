    <JadeMethod name="getSelectorColumns" id="1444d576-db5c-4de3-a647-b5caf37b6022">
        <source>getSelectorColumns(_sa : StringArray input);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries, build the equivalent of CM_CargoBOLType allSelectorColumns
vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	foreach qProp in self.allQueryProperties do
		_sa.add(qProp.propertyName);
	endforeach;

end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="b2785b7f-8c70-4a36-96f1-a15e0ee77408">
        <source>getSelectorVisibleColumns(_sa : StringArray input);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries - hard-coded list equivalent to CM_CargoBOLType allSelectorVisibleColumns - 
//	re-implement in sub-classes
vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties['id'];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
