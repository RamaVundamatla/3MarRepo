    <JadeMethod name="clearForm" id="f3cb6607-31a8-4805-a00a-00c4707be13e">
        <updating/>
        <source>clearForm() updating;
// ---------------------------------------------------------------------------
// Created:      09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------

// ---------------------------------------------------------------------------

vars

begin
	self.clearSavedWarnings();			
	self.enableFieldsAfterClear();
	
	self.setNotifications(false);
	self.tblItems.clear;
	
	self.initTable();
	self.loadDataForFirstTime();

	self.cmbGateLanes.clear();
	
	self.setDefaultGate();
		
	if self.cmbGateLanes.listCount() &gt; 0 and not self.myBulkGateAgent.gateAndLaneSet then
		self.cmbGateLanes.enabled := true;
	else
		self.cmbGateLanes.enabled := false;	
	endif;
	
//	if not self.printerIsUserSelected then	//	NDL	Par 30286 - If the user has set the printer, leave it be...
//		self.cmbPrinter.listIndex := -1;
//	endif;

	self.txtRegno.text := null;
	self.txtRegno.setFocus();				// PAR #35805
	
	//29 Nov 2012	NDL	Par 30745
	self.chkReceiptReq.value := self.myTerminal.getConfig(GateReceiptCopies).Integer &gt; 0;
	
	self.txtWeightOUT.text := null;																		// PAR #32536
	self.txtWeightOUT.setValues("" &amp; Space &amp; app.getDefaultMeasurementForType(Type_Weight).shortName);
	
	//05 Dec 2017	NDL	TFS 7993
	self.txtWeightOUT.row := 1;
	self.txtWeightOUT.column := 1;
	
	self.lblCargoWeight.caption := null;
	
	self.resetFirstChange();
epilog

end;</source>
    </JadeMethod>
