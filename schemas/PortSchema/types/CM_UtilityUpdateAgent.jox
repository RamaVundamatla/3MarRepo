    <JadeMethod name="utlUpdateStopsForBOL" id="a2415ef8-8da2-402b-b75c-633e80bb3a45">
        <source>utlUpdateStopsForBOL(_pxyBol : CM_BOL input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
