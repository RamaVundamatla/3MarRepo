    <JadeMethod name="doBarGraph" id="a8a9d339-e178-474e-9676-3d83df9f0262">
        <source>doBarGraph() protected;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Generate the bar graph.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	managerObj		: CnEcBackShedManager;
	graphObj		: CnEcBarGraph;
	prequeued		: Integer;
	prequeuedReady	: Integer;
	queued			: Integer;
	active			: Integer;
	completed		: Integer;
	failed			: Integer;
	
begin
	managerObj	:=	app.myBackShedManager;
	graphObj	:=	basTasks;
	graphObj.clearGraph();
	graphObj.graphTitle	:=	"Tasks";
	
	managerObj.getTaskCounts(prequeued, prequeuedReady, queued, active, completed, failed);
	graphObj.allGraphValues.add(prequeued);
	graphObj.allGraphValues.add(prequeuedReady);
	graphObj.allGraphValues.add(queued);
	graphObj.allGraphValues.add(active);
	graphObj.allGraphValues.add(completed);
	graphObj.allGraphValues.add(failed);
	
	graphObj.allGraphColors.add(managerObj.getColorPrequeued());
	graphObj.allGraphColors.add(managerObj.getColorPrequeuedReady());
	graphObj.allGraphColors.add(managerObj.getColorQueued());
	graphObj.allGraphColors.add(managerObj.getColorActive());
	graphObj.allGraphColors.add(managerObj.getColorCompleted());
	graphObj.allGraphColors.add(managerObj.getColorFailed());
	
	graphObj.allGraphLegends.add("Prequeued");
	graphObj.allGraphLegends.add("Prequeued &amp; Ready");
	graphObj.allGraphLegends.add("Queued");
	graphObj.allGraphLegends.add("Active");
	graphObj.allGraphLegends.add("Completed");
	graphObj.allGraphLegends.add("Failed");
	
	graphObj.myLegend		:=	basTaskLegend;
	graphObj.drawGraph();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="6eca22ae-1cd5-4766-bd08-bf3c52b795c3">
        <updating/>
        <source>doFormLoad() updating, protected;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	centreWindow();
	
	self.doLoadApplications();
	self.doInitializeTable();
	self.doFormRefresh();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormRefresh" id="9fcf04cf-e551-4f0d-8fea-bbd801e850e8">
        <source>doFormRefresh() protected;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Refresh the form details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.doLoadManagers();
	self.doBarGraph();
	self.enableControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doInitializeTable" id="e6f4a327-5024-46ac-8646-9a9c9ce637f7">
        <source>doInitializeTable() protected;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Initialize the data table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	tableObj	: Table;
	
begin
	tableObj		:=	tblManagers;
	tableObj.rows	:=	1;
	tableObj.setCellText(1, 1, "Process Name" &amp; Tab &amp; "Schema" &amp; Tab &amp; "Started");
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadApplications" id="e9d57d3a-f247-425f-9e61-e9c69db57f96">
        <source>doLoadApplications() protected;
// --------------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Populate the application combobox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allApplications	: AppNameDict;
	applicationObj	: Application;
	comboboxObj		: CnEcComboBox;
	listIndex		: Integer;
	
begin
	allApplications	:=	currentSchema.cnGetApplications();
	comboboxObj		:=	cmbApplications;
	
	foreach applicationObj in allApplications
	where applicationObj.applicationType = app.ApplicationType_Non_GUI
	do
		listIndex							:=	comboboxObj.addItem(applicationObj.name);
		comboboxObj.itemObject[listIndex]	:=	applicationObj;
	endforeach;
	
	if comboboxObj.listCount = 1 then
		comboboxObj.listIndex	:=	1;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadManagers" id="01ad035b-6bdd-4050-8381-2ea00394fd91">
        <source>doLoadManagers() protected;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Populate the task schedule managers table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 03 Aug 2009	cnwkpd1		Upgrade to CardSchema 3.4.01 - System::cnGetNodes and
//							Node::cnGetProcesses de-implemented
// -----------------------------------------------------------------------------

vars
	tableObj				: Table;
	managerApplicationObj	: Application;
	processObj				: Process;
	processIteratorObj		: Iterator;
	nodeObj					: Node;
	nodeIteratorObj			: Iterator;
	rowIndex				: Integer;
	rowDisplay				: String;
	localNodes				: NodeDict;
	localProcs				: ProcessDict;
	invalidNode				: Boolean;
	invalidProc				: Boolean;
	
begin
	tableObj				:=	tblManagers;
	tableObj.rows			:=	1;
	managerApplicationObj	:=	cmbApplications.listObject.Application;
	
	on Exception do app.cnEcXhandlerInvalidRef(exception, nodeObj, invalidNode);
	on Exception do app.cnEcXhandlerInvalidRef(exception, processObj, invalidProc);
	
	localNodes := system.nodes.cloneSelf(true);
	nodeIteratorObj := localNodes.createIterator();
	
	while nodeIteratorObj.next(nodeObj) do
		delete localProcs;
		
		invalidNode := false;
		localProcs := nodeObj.processes.cloneSelf(true);
		if invalidNode then
			continue;
		endif;
		
		processIteratorObj := localProcs.createIterator();
		
		while processIteratorObj.next(processObj) do
			if processObj.persistentApp = managerApplicationObj then
				rowDisplay	:=	self.getManagerDisplay(processObj);
				rowIndex	:=	tableObj.addItem(rowDisplay);
				tableObj.accessRow(rowIndex).itemObject	:=	processObj;
			endif;
		endwhile;
		
		delete processIteratorObj;
	endwhile;
	
epilog
	delete processIteratorObj;
	delete nodeIteratorObj;
	delete localNodes;
	delete localProcs;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartManagerApplication" id="5d90cb1e-b7c0-41c0-8013-f3faf90117fb">
        <executionLocation>server</executionLocation>
        <source>doStartManagerApplication(pApplicationObj:Application) serverExecution, protected;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Start a schedule manager application.
//
// Parameters:	pApplicationObj
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if pApplicationObj.applicationType = app.ApplicationType_Non_GUI then
		app.startApplication(currentSchema.name, pApplicationObj.name);
	else
		app.msgBox(	pApplicationObj.name &amp; " is not valid as a server application.",
					"Startup Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pApplicationObj" type="Application"/>
    </JadeMethod>
    <JadeMethod name="doStopManagerApplication" id="2e583ddf-8c94-4564-add3-e2a431e2f4b0">
        <source>doStopManagerApplication() protected;
// --------------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Stop a schedule manager application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	processObj	: Process;
	tableObj	: Table;
	rowIndex	: Integer;
	
begin
	tableObj	:=	tblManagers;
	rowIndex	:=	tableObj.row;
	
	if rowIndex &gt; tableObj.fixedRows and rowIndex &lt;= tableObj.rows then
		processObj	:=	tableObj.accessRow(rowIndex).itemObject.Process;
		
		app.myBackShedManager.causeEvent(CNEC_SHED_MANAGER_STOP, true, processObj.getOidString());
	else
		app.msgBox(	"Please select the Manager Application to stop.",
					"Stop Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableControls" id="76e8436e-5b14-48d6-a4de-cb84ce362780">
        <source>enableControls() protected;
// --------------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Set currently enabled controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	
begin
	tableObj	:=	tblManagers;
	
	if tableObj.row &gt; tableObj.fixedRows and tableObj.row &lt;= tableObj.rows then
		btnStop.enabled	:=	true;
	else
		btnStop.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getManagerDisplay" id="8b627444-daab-4223-960a-33418421490c">
        <source>getManagerDisplay(pProcessObj:Process):String protected;
// --------------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Return a display value for the specified application process.
//
// Parameters:	pProcessObj - The application process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	pProcessObj.persistentApp.name &amp;
			" (" &amp; pProcessObj.getOidString() &amp; ")" &amp; Tab &amp;
			pProcessObj.schema.name &amp; Tab &amp;
			pProcessObj.signOnTime.String;
end;</source>
        <access>protected</access>
        <Parameter name="pProcessObj" type="Process"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="376e4c37-4088-4203-9d60-f2ff46f5696f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
