    <JadeMethod name="addJobs" id="c2f9837f-2c2f-43e5-b7b2-a4148af3ea60">
        <updating/>
        <source>addJobs(_jobs : CM_JobArray) updating;
// ---------------------------------------------------------------------------
// Created:		13 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpJob : CM_Job;
	vJob : CM_VoyageJob;
begin
	self.allJobs.clear;
	foreach tmpJob in _jobs do
		vJob := tmpJob.CM_VoyageJob;
		if vJob.isHatchLidJob() then
			continue;
		endif;
		
		if vJob.isDischarge then // DISCHARGE JOBS 'R' NOT US
			continue;
		endif;
		
		self.allJobs.add(tmpJob);
		
		if not self.jobHasHeavies then
			if self.useWeights then
				self.jobHasHeavies := vJob.hasJobGotHeavies();
			else
				self.jobHasHeavies := false;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_jobs" type="CM_JobArray"/>
    </JadeMethod>
    <JadeMethod name="addTI" id="7c663871-fb6f-47fc-addc-9aa23b6c06f8">
        <source>addTI(_theTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		Add TI to dictionary with order of where they are in Gridded Area
//				so Straddle Carrier can pick up top row (horizontally) first and then 
//				through the rows vertically.  ie:
//				1 2 3
//				4 6 8
//				5 7 9

// Updated:		cnwjo3 par 26193. If useLCOut use the Decking Rules YA Location Cells Out
//				to determine how the machine picks up items
//

// ---------------------------------------------------------------------------
vars
	dischPortCode,
	commGrpCode,
	contentStatus,
	taID				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos, tmpTopPosition, variedWeight: Integer;
	theTI : CM_TrackedItem;
	 specialStow : Boolean;
	iter : Iterator;
	
	primaryActual : CM_GridController;
	tmpTI : CM_TrackedItem;
	tmpStackPos : Integer;
	o : Object;
	yaLocationCell : CM_YALocationCell;
	ta : CM_TerminalArea;
	deckingOptions : CM_YADeckingOptionsTA;
	priority : Integer;
	yaLCOut : CM_YALocationCell;
begin
	theTI := _theTI;
	
	dischPortCode := theTI.dischargePort;
	if theTI.isAttributeTrue(TI_Attrib_IsEmpty) then
		contentStatus := "MT";
	else
		contentStatus := "FULL";
	endif;
	
	/*PAR 16714
	specialStow := theTI.isSpecialStow();// PAR 13939
	if specialStow then
		commGrpCode := theTI.commodityGroup; 
	endif;
	NOW */
	commGrpCode := theTI.getAutoLoadPlanCommodityCode();

	powerType := theTI.getShipPlanningPowerType(); // YES or NO
	tiLength := theTI.getActualLength().Integer; // 20 40 or 45
	tiHeight := theTI.isAttributeTrue(TI_Attrib_IsHiCubed).Integer; // zero or one
	
	if self.useWeights and self.jobHasHeavies then
		variedWeight := (theTI.totalWeight + (theTI.totalWeight * (self.wieghtPC /100))).Integer; // increase by leeway percentage
		if variedWeight &gt;= self.weightAve then
			tiWeight := Req_Weight_Heavy;
		else
			tiWeight := Req_Weight_Light;
		endif;
	else
		tiWeight := 0;
		
	endif;
	if self.doSelTopHeight then
		tmpTopPosition := self.topPosition;
	endif;

	if self.useLCOut = false then//continue to use default machine ship loading order
		tiSelStatus := theTI.getShipPlanningSelectionStatus(tmpTopPosition, self.doSelTopHeight, self.doSelGround, self.doSelDiffPort, self.doSelDiffVoyage);
		tiSelStatus := self.selectionOrder.indexOf(tiSelStatus);
		if tiSelStatus = 0 then
			tiSelStatus := VoyageFullPlanNone;
		endif;
		
		theTI.getShipPlanningRowColumn(gridRowOrd, gridColOrd, gridStackPos, self.flippedH, self.flippedV);
		if gridRowOrd &gt; 0 then
			taID := theTI.myTerminalArea.id;
		else
			taID := "ZZZZZZ" &amp; theTI.myTerminalArea.id; // BLOCK STACKS AT THE END
			gridStackPos := self.allTrackedItems.size + 1;//added by cnwad1 for par 12924
		endif;
		
	else //use decking rules to order machine ship loading order
		ta := theTI.myTerminalArea;
		
		if ta &lt;&gt; null 
		and ta.isKindOf(CM_GridArea) then
			deckingOptions := ta.myYADeckingOptions;
		
			if deckingOptions &lt;&gt; null then
				taID := theTI.myTerminalArea.id;
				primaryActual := theTI.myPrimaryActualLocation.CM_GridController;
				
				//find vertical position of TI
				tmpStackPos := 1;
				foreach tmpTI in primaryActual.allTrackedItems discreteLock do
					if tmpTI = theTI then
						break;
					endif;
					tmpStackPos := tmpStackPos + 1;
				endforeach;
	
				if tmpStackPos &lt;= primaryActual.allYAYardLocationCells.size then
					//find the LocationCell from LocationController  eg: each LC has 3 YALocationCells if it has a height of 3
					o := primaryActual.allYAYardLocationCells[tmpStackPos];
					yaLocationCell := o.CM_YALocationCell;
					
					//find that YALocationCell in the collection of allYAClocationCellsOut.  If its the first instance it has a
					//priority of 1 (ie: first item to load onto ship).  If instance is found at the end then it is the last carog item
					//to be loaded onto ship
					priority := 1;
					foreach yaLCOut in deckingOptions.allYALocationCellsOut discreteLock do
						if yaLCOut = yaLocationCell then
							break;
						endif;
						priority := priority + 1;
					endforeach;
					
					//effectively we are ordering items in by imaginary stack height
					gridRowOrd := 1;
					gridColOrd := 1;
					gridStackPos := priority;
					
					tiSelStatus := VoyageFullPlanNone;		
				endif;
			endif;
		endif;
		if gridRowOrd = 0 then
			taID := "ZZZZZZ" &amp; theTI.myTerminalArea.id; // BLOCK STACKS AT THE END
			gridStackPos := self.allTrackedItems.size + 1;//added by cnwad1 for par 12924
		endif;

	endif;

	self.allTrackedItems.putAtKey(dischPortCode, contentStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos, null, theTI);

	if app.isSpecial then
		app.writeStatement(_theTI.id &amp; "," &amp; dischPortCode &amp; "," &amp; contentStatus &amp; "," &amp; commGrpCode &amp; "," &amp; powerType.String 
								&amp; "," &amp; tiLength.String &amp; "," &amp; tiHeight.String &amp; "," &amp; tiSelStatus.String &amp; "," &amp;  taID &amp; "," &amp; gridRowOrd.String 
								&amp; "," &amp; gridColOrd.String &amp; " ," &amp; gridStackPos.String);
	endif;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addTIToPlannedColl" id="5494ecac-5b31-43ca-8406-44f78289279f">
        <source>addTIToPlannedColl(_theTI : CM_TrackedItem;_cmif_ShipPlanningSlotRequest : CMIF_ShipPlanningSlotRequest);
/*

Purpose:      add ti to  planned collection and remove it from collection of available tracked items		

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2009	cnwer1	Initial creation

*/

vars
	slotReq : CM_SlotRequest;
	roroReq : CM_RORORequest;
begin
	slotReq:=_cmif_ShipPlanningSlotRequest.mySlotRequest;
	if slotReq &lt;&gt; null then
		self.allRequestsPlanned.add(slotReq);
		self.allTIsForPlanning.add(_theTI);
		self.removeTI(_theTI); 
		_cmif_ShipPlanningSlotRequest.removeNonPlannedTrackedItems(_theTI);
	else
		roroReq:=_cmif_ShipPlanningSlotRequest.myRORORequest;
		if roroReq &lt;&gt; null then
			self.allROROReqsPlanned.add(roroReq);
			self.allTIsForPlanning.add(_theTI);
			self.removeTI(_theTI); 
			_cmif_ShipPlanningSlotRequest.removeNonPlannedTrackedItems(_theTI);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_cmif_ShipPlanningSlotRequest" type="CMIF_ShipPlanningSlotRequest"/>
    </JadeMethod>
    <JadeMethod name="changeColumnInDict" id="b836739b-9270-4c74-bb61-513a9625c6c0">
        <source>changeColumnInDict(_theTI : CM_TrackedItem; _col : Integer; _clearTA : Boolean);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dischPortCode,
	commGrpCode,
	taID, taID2, contents				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos: Integer;
	theTI : CM_TrackedItem;
begin
	if not self.allTrackedItems.includes(_theTI) then // PAR 17118
		return; // PAR 17118
	endif;

	theTI := _theTI;
	
	self.myIterator.startAtObject(theTI);
	self.allTrackedItems.getIteratorKeys(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos,taID2, self.myIterator);
	self.allTrackedItems.removeKeyEntry(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos,taID2, theTI);
	
	if _clearTA and taID[1:6] &lt;&gt; "ZZZZZZ" then
		taID2 := taID;
		taID := null;
	endif;
	
	self.allTrackedItems.putAtKey(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, _col, gridStackPos,taID2, theTI);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_clearTA" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeRowColInDict" id="2bd52bc9-5276-4abe-ab71-95c9dd6e10d2">
        <source>changeRowColInDict(_theTI : CM_TrackedItem; _row, _col : Integer; _clearTA : Boolean);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dischPortCode,
	commGrpCode,
	taID, taID2, contents				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos: Integer;
	theTI : CM_TrackedItem;
begin
	if not self.allTrackedItems.includes(_theTI) then // PAR 17118
		return; // PAR 17118
	endif;

	theTI := _theTI;
	
	self.myIterator.startAtObject(theTI);
	self.allTrackedItems.getIteratorKeys(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos,taID2, self.myIterator);
	self.allTrackedItems.removeKeyEntry(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos,taID2, theTI);
	
	if _clearTA and taID[1:6] &lt;&gt; "ZZZZZZ" then
		taID2 := taID;
		taID := null;
	endif;
	
	self.allTrackedItems.putAtKey(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, _row, _col, gridStackPos,taID2, theTI);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_clearTA" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTwinDoorDirections" id="999383b4-b6e5-4803-b917-cf5c8e9c8c4f">
        <source>checkTwinDoorDirections(	_firstSlotRequest,
							_twinSlotRequest : CM_SlotRequest;
							_firstGridController,
							_twinGridController : CM_GridController) : Boolean;


/*				

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2009	cnwer1	Initial creation

*/

vars
	theDoorDir,
	twinDoorDir : Integer;
	tiFailedForTwinLift : Boolean;
begin

	tiFailedForTwinLift :=false;
	theDoorDir:=_firstGridController.doorDirection;
	twinDoorDir:=_twinGridController.doorDirection;
	///ARGHHHHHHHH
	//door direction rules if flippedH then both containers will need to face forward else both will need to face aft
	//direction depends on 
	if self.flippedH then
		if _firstSlotRequest.getDoorsDirection  = TI_DOORSDIRN_AFT then
			if (not theDoorDir = DoorDirectionForward)then 
				tiFailedForTwinLift:=true;
			endif;
		else
			if (not theDoorDir = DoorDirectionAft) then
				tiFailedForTwinLift:=true;
			endif;
		endif;
		
		if _twinSlotRequest.getDoorsDirection = TI_DOORSDIRN_AFT then
			if (not twinDoorDir = DoorDirectionForward) then
				tiFailedForTwinLift:=true;
			endif;
		else
			if (not twinDoorDir = DoorDirectionAft) then
				tiFailedForTwinLift:=true;
			endif;
		endif;
		
	else
		if _firstSlotRequest.getDoorsDirection  = TI_DOORSDIRN_AFT then
			if (not theDoorDir = DoorDirectionAft) then
				tiFailedForTwinLift:=true;
			endif;
		else
			if (not theDoorDir = DoorDirectionForward) then
				tiFailedForTwinLift:=true;
			endif;
		endif;
		
		if _twinSlotRequest.getDoorsDirection = TI_DOORSDIRN_AFT then
			if (not twinDoorDir = DoorDirectionAft) then
				tiFailedForTwinLift:=true;
			endif;
		else
			if (not twinDoorDir = DoorDirectionForward) then
				tiFailedForTwinLift:=true;
			endif;
		endif;
		
	endif;
		
	return tiFailedForTwinLift;
epilog

end;</source>
        <Parameter name="_firstSlotRequest" type="CM_SlotRequest"/>
        <Parameter name="_twinSlotRequest" type="CM_SlotRequest"/>
        <Parameter name="_firstGridController" type="CM_GridController"/>
        <Parameter name="_twinGridController" type="CM_GridController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="23fa382e-2ceb-4535-91b8-903cc8082d5e">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2008	cnwer1	Initial creation par 18417

*/

vars

begin
	if self.myIterator &lt;&gt; null then
		delete self.myIterator;
	endif;
	if self.myQuery &lt;&gt; null then
		delete self.myQuery;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="a89bbfbd-22e0-446f-be20-ba521f58fe58">
        <updating/>
        <source>doQuery(_mon : CMIF_Monitor) updating;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	partsInJob, partsDone, idx : Integer;
begin
	self.myMonitor := _mon;
	self.doSelTopHeight := (self.selectionOrder.includes(VoyageFullPlanThirdHeight));
	self.doSelDiffPort := (self.selectionOrder.includes(VoyageFullPlanOSDischPort));
	self.doSelDiffVoyage := (self.selectionOrder.includes(VoyageFullPlanOSVoyage));
	self.doSelGround := (self.selectionOrder.includes(VoyageFullPlanGroundHeight));
	self.getTIs();

	//epr CCMS 1032 for unit testing need to make sure it worked without needing montior
	if self.myMonitor &lt;&gt; null then
		// ### INIT MONITOR
		partsInJob := self.allJobs.getTotalRequests(true);
		self.myMonitor.partsInJob := partsInJob;
	endif;
	//if app.myPassport.getUserCode="CNWER1" then
		
		self.initCMIF_PlanningSlotRequests();
		self.processRequestsNew();
		self.planTIsLOLO();
		self.processRequestsRORO();
		self.planTIsRORO();

	/*else
		self.processRequests(self.Type_CommodityGroup,partsDone);
		self.processRequests(self.Type_Hazardous,partsDone);
		self.processRequests(self.Type_WaterCooled,partsDone);
		self.processRequests(self.Type_All,partsDone);
	endif;*/
	if self.myMonitor &lt;&gt; null then
		self.myMonitor.updateProgress("Finished", 100,100);
	endif;
	
	if self.myMonitor &lt;&gt; null then
		self.myMonitor.updateProgress("Finished", 100,100);
	endif;
	app.myPassport.setMyCMIFMonitor(null);
	
end;</source>
        <Parameter name="_mon" type="CMIF_Monitor"/>
    </JadeMethod>
    <JadeMethod name="doQueryInitFilter" id="66ca82b8-d71a-44c3-888d-1616aa21b85e">
        <updating/>
        <source>doQueryInitFilter() updating;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFilter				: CMQF_ShipLoadListTIs;
	
begin

	// ### SET FILTER INITIALISE
	if self.myQuery = null then
		create theFilter transient;
		self.myQuery := theFilter;
	endif;
	theFilter := self.myQuery;
	theFilter.reset;	
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.allVoyages.add(self.myVoyage);
//	self.getPortsForQuery(theFilter); // do not do this, we need all TIS so that we can see if there is a mix within 1 row.
	theFilter.isGroundPos := false;
	theFilter.isOverDiffVoy := false;
	theFilter.isOverstowed := false;
	theFilter.topPosition := null;
	theFilter.useTopPosition := false;

	theFilter.plannedToShip := false;
	theFilter.transhipOnly := false;	
	theFilter.tbaOnly := false;	// TFS 45590
	theFilter.onSiteOnly := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSwitchRow" id="4cfe678a-a545-4005-9661-c2f510b844c7">
        <updating/>
        <source>doSwitchRow(_keyTaID : String; _keyGridRowOrd, _keyGridColOrd : Integer; _resetRow : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		14 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.isDoingRowSep then
		if self.sortTA &lt;&gt; null and _keyTaID &lt;&gt; self.sortTA then
			self.sortTA := null;
			self.sortRow := 0;
		else
			self.sortTA := _keyTaID;
			
			if _resetRow or (self.sortRow &gt; 0 and self.sortRow &lt;&gt; _keyGridRowOrd) then
				self.sortRow := 0;
			else
				self.sortRow := _keyGridRowOrd;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_keyTaID" type="String"/>
        <Parameter name="_keyGridRowOrd" type="Integer"/>
        <Parameter name="_keyGridColOrd" type="Integer"/>
        <Parameter name="_resetRow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTestKeys" id="8a0e81fd-9313-425e-8159-00f1c5cf1e54">
        <source>doTestKeys(_theTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dischPortCode,
	commGrpCode,
	taID, taID2, contents				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos: Integer;
	theTI : CM_TrackedItem;
begin
	theTI := _theTI;
	
	self.myIterator.startAtObject(theTI);
	self.allTrackedItems.getIteratorKeys(dischPortCode, contents, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos,taID2, self.myIterator);
	
	app.writeStatement(theTI.id &amp; "," &amp; dischPortCode &amp; "," &amp; contents &amp; "," &amp; commGrpCode &amp; "," &amp; powerType.String 
								&amp; "," &amp; tiLength.String &amp; "," &amp; tiHeight.String &amp; "," &amp; tiWeight.String &amp; "," &amp; tiSelStatus.String &amp; "," &amp;  taID &amp; "," &amp; gridRowOrd.String 
								&amp; "," &amp; gridColOrd.String &amp; "," &amp; gridStackPos.String &amp; "," &amp; taID2);
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doesTIMatchColourCodingReqd" id="49c16d0b-e7c0-4a95-a650-0a10526ed0b0">
        <source>doesTIMatchColourCodingReqd(_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		20 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	reqDischPortCode,
	reqCommGrpCode,
	reqContentStatus,
	taID				: String;
	reqPowerType,
	reqLength,
	reqHeight,
	reqSelStatus,
	gridRowOrd,
	gridColOrd, endIdx		: Integer;
	tmpJob : CM_Job;
	voyJob : CM_VoyageJob;
	aReq : CM_Request;
	srReq : CM_SlotRequest;
	tiDischPortCode,
	tiCommGrpCode,
	tiContentStatus
					: String;
	tiPowerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus: Integer;
	theTI : CM_TrackedItem;
	 specialStow : Boolean;
	iter : Iterator;
begin
	theTI := _theTI;

	tiDischPortCode := theTI.dischargePort;
	if theTI.isAttributeTrue(TI_Attrib_IsEmpty) then
		tiContentStatus := "MT";
	else
		tiContentStatus := "FULL";
	endif;
	tiPowerType := theTI.getShipPlanningPowerType(); // YES or NO
	tiLength := theTI.getActualLength().Integer; // 20 40 or 45

	foreach tmpJob in self.allJobs discreteLock do : jobLoop
		voyJob := tmpJob.CM_VoyageJob;
		if voyJob.isHatchLidJob() then
			continue;
		endif;
		if voyJob.isDischarge then
			continue;
		endif;
		if voyJob.isJobComplete() then
			continue;
		endif;
		
		foreach aReq in tmpJob.allRequests discreteLock do : reqLoop
			srReq := aReq.CM_SlotRequest;
			
			if self.requestProcessed(srReq) then
				continue;
			endif;
			
			if aReq.hasTIsOfMode(PLANNING_MODE) then
				continue;
			endif;
			
			// ### GET THE REQUEST DATA
			reqDischPortCode := srReq.dischargePort;

			if srReq.getAttrEmpty() then
				reqContentStatus := "MT";
			else
				reqContentStatus := "FULL";
			endif;
				
			reqPowerType := srReq.getShipPlanningPowerType();
			reqLength := srReq.getActualLength().Integer; // 20 40 or 45
//			reqHeight := srReq.highCubed.Integer; // zero or one

			if tiDischPortCode = reqDischPortCode
			and reqContentStatus = tiContentStatus  
			and reqPowerType = tiPowerType 
			and reqLength  = tiLength  then
				return true;
			endif;

		endforeach;
	endforeach;
	return false;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEstimateFinString" id="7eba1551-24a5-4caa-8d43-bbf5e2c5040b">
        <source>getEstimateFinString(_started : TimeStamp; _parts : Integer; _done : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		08 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
	pcDone, pcToDo, diffSeconds, todoSeconds : Integer;
	hours, minutes, seconds : Integer;
	etc : String;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		diffSeconds := (now.cnEcDiff(_started) / 1000).Integer;
		
		pcDone := ((_done / _parts) * 100).Integer;
		pcToDo := 100 - pcDone;
		
		todoSeconds := (diffSeconds * (pcToDo / pcDone)).Integer;
		
		etc := todoSeconds.getHMS();
		
		return "(" &amp; etc &amp; " ETC)";
			
end;</source>
        <Parameter name="_started" type="TimeStamp"/>
        <Parameter name="_parts" type="Integer"/>
        <Parameter name="_done" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPortsForQuery" id="0c6583c3-af9f-40c5-8949-290c0ac024bd">
        <source>getPortsForQuery(_filter : CMQF_ShipLoadListTIs input);
// ---------------------------------------------------------------------------
// Created:		26 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	vJob : CM_VoyageJob;
	aPort : CM_Port;
	req : CM_Request;
begin
	if self.allJobs.size &lt;&gt; 1 then
		return;
	endif;
	
	aJob := self.allJobs.first;
	if aJob = null then
		return;
	endif;
	
	foreach req in aJob.allRequests discreteLock do
		aPort := req.getAttrDischargePort();
		_filter.allPortsDischarge.addNoDuplicates(aPort,false);
	endforeach;
	
		

end;</source>
        <Parameter name="_filter" type="CMQF_ShipLoadListTIs" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReqsWeight" id="4b348a8d-85cb-4f94-a2cc-b0447071c66a">
        <source>getReqsWeight(_req : CM_SlotRequest) : Integer;
// ---------------------------------------------------------------------------
// Created:		17 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	reqWeight : Integer;
begin
	if self.useWeights and self.jobHasHeavies then // if current job has no slots defined for heavies then ignore
		if _req.mySlotDefinition.heavy then
			reqWeight := Req_Weight_Heavy;
		else
			reqWeight := Req_Weight_Light;
		endif;
	else
		reqWeight := 0;
	endif;
	return reqWeight;
end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRequestData" id="e9c66b32-b659-460b-88a1-e8ec93cd00a1">
        <source>getRequestData(_req : CM_SlotRequest;
				_reqDischPortCode,
				_reqCommGrpCode 	: String output ;
				_reqPowerType,
				_reqLength,
				_reqHeight,
				_reqWeight : Integer output;
				_reqContentStatus : String output ;
				_reqIsDLR : Boolean output;
				_reqSelStatus : Integer output;
				_taID : String output;
				_gridRowOrd,
				_gridColOrd : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2008	cnwer1	Initial creation

*/

vars

begin
	// ### GET THE REQUEST DATA
	_reqDischPortCode := _req.dischargePort;
	
	_reqCommGrpCode := _req.getAutoLoadPlanCommodityCode();
	_reqPowerType := _req.getShipPlanningPowerType();
	_reqLength := _req.getActualLength().Integer; // 20 40 or 45
	_reqHeight := _req.getAttrHiCubed().Integer; // zero or one
	_reqWeight := self.getReqsWeight(_req);
	if _req.getAttrEmpty() then
		_reqContentStatus := "MT";
	else
		_reqContentStatus := "FULL";
	endif;
	
	_reqIsDLR := _req.isRehandle();
	
	_reqSelStatus := 0;
	
	// ## Row Seperation
	if self.currentType = self.Type_All and self.isDoingRowSep then
		_taID := self.sortTA;
		_gridRowOrd := 0;
		if self.sortRow &gt; 0 then
			_gridRowOrd := self.sortRow + self.rowsSeperation + 1;
		endif;
		_gridColOrd := self.sortCol;
	// ### No Seperation
	else
		_taID := "";
		_gridRowOrd := 0;
		_gridColOrd := 0;
	endif;
epilog

end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <Parameter name="_reqDischPortCode" type="String" usage="output"/>
        <Parameter name="_reqCommGrpCode" type="String" usage="output"/>
        <Parameter name="_reqPowerType" type="Integer" usage="output"/>
        <Parameter name="_reqLength" type="Integer" usage="output"/>
        <Parameter name="_reqHeight" type="Integer" usage="output"/>
        <Parameter name="_reqWeight" type="Integer" usage="output"/>
        <Parameter name="_reqContentStatus" type="String" usage="output"/>
        <Parameter name="_reqIsDLR" type="Boolean" usage="output"/>
        <Parameter name="_reqSelStatus" type="Integer" usage="output"/>
        <Parameter name="_taID" type="String" usage="output"/>
        <Parameter name="_gridRowOrd" type="Integer" usage="output"/>
        <Parameter name="_gridColOrd" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="cede44b8-634b-42be-9906-58cc0bd2b844">
        <updating/>
        <source>getTI(_req : CM_SlotRequest) : CM_TrackedItem updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		Get TI that matches Colour Coding
//
// ---------------------------------------------------------------------------
vars
	reqDischPortCode,
	reqCommGrpCode,
	reqContentStatus,
	taID				: String;
	reqPowerType,
	reqLength,
	reqHeight,
	reqSelStatus,
	gridRowOrd,
	gridColOrd, endIdx		: Integer;
	theTI, theFoundTI, foundDLRTI : CM_TrackedItem;
	idx, selectionType, reqWeight : Integer; 
	
	keyDischPortCode,
	keyCommGrpCode,
	keyContentsStatus,
	keyTaID, keyTaID2				: String;
	keyPowerType,
	keyTiLength,
	keyTiHeight,
	keyTiWeight,
	keyTiSelStatus,
	keyGridRowOrd,
	keyGridColOrd,
	keyGridStackPos: Integer;
	resetRow, tiMatches, reqIsDLR, reqIsHaz : Boolean;
begin

	// ### GET THE REQUEST DATA
	reqDischPortCode := _req.dischargePort;
	/* WAS PAR 16714
	if _req.isSpecialStow() then
		reqCommGrpCode := _req.commodity; // this is comm group
	endif;
	*/
	reqCommGrpCode := _req.getAutoLoadPlanCommodityCode();
	
	if _req.getAttrEmpty() then
		reqContentStatus := "MT";
	else
		reqContentStatus := "FULL";
	endif;
	
	reqIsDLR := _req.isRehandle();
	reqIsHaz := _req.getAttrHazardous();
	
	reqPowerType := _req.getShipPlanningPowerType();
	reqLength := _req.getActualLength().Integer; // 20 40 or 45
	reqHeight := _req.getAttrHiCubed().Integer; // zero or one
	reqSelStatus := 0;
	reqWeight := self.getReqsWeight(_req);

	// ## Row Seperation
	if self.isDoingRowSep then
		taID := self.sortTA;
		gridRowOrd := 0;
		if self.sortRow &gt; 0 then
			gridRowOrd := self.sortRow + self.rowsSeperation + 1;
			resetRow := true;
		endif;
		gridColOrd := self.sortCol;
	// ### No Seperation
	else
		taID := "";
		gridRowOrd := 0;
		gridColOrd := 0;
	endif;
	
	// ### get first ti that basically matches
	theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, reqHeight, reqWeight, reqSelStatus, taID, gridRowOrd, gridColOrd,0,null);
	if theTI &lt;&gt; null then
		if self.useWeights and self.jobHasHeavies then
			self.myIterator.startAtObject(theTI);
			self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,self.myIterator);
			tiMatches := ((reqWeight = keyTiWeight) and (reqDischPortCode = keyDischPortCode) and (reqContentStatus = keyContentsStatus) and (reqPowerType = keyPowerType)	and (reqLength = keyTiLength)	and (reqHeight = keyTiHeight));
			if not tiMatches then
				// we have tried to match by heavy or light weight so now ignore the weight
				theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, reqHeight, 0, reqSelStatus, taID, gridRowOrd, gridColOrd,0, null);
			endif;
		endif;
//	app.writeStatement(_req.String &amp; "," &amp; reqDischPortCode &amp; "," &amp; reqCommGrpCode &amp; "," &amp; reqPowerType.String 
	//				&amp; "," &amp; reqLength.String &amp; "," &amp; reqHeight.String &amp; "," &amp; reqSelStatus.String &amp; "," &amp;  taID &amp; "," &amp; gridRowOrd.String 
		//						&amp; "," &amp; gridColOrd.String);


		theFoundTI := theTI; // save this for later
		
		// ### get the KEYS back for the found TI
		self.myIterator.startAtObject(theTI);
		self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,self.myIterator);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp;  ' 1. gridRowOrd: ' &amp; gridRowOrd.String &amp; " " &amp; self.isDoingRowSep.String &amp; " "  &amp; theTI.id &amp; " " &amp; keyDischPortCode &amp; " " &amp; keyContentsStatus  &amp; " " &amp; keyCommGrpCode  &amp; " " &amp; keyPowerType.String  &amp; " " &amp; keyTiLength.String  &amp; " " &amp;
//							keyTiHeight.String  &amp; " " &amp; keyTiWeight.String &amp; " " &amp; keyTiSelStatus.String &amp; " " &amp; keyTaID &amp; " " &amp; keyGridRowOrd.String &amp; " " &amp; keyGridColOrd.String &amp; " " &amp; keyGridStackPos.String &amp; " " &amp; keyTaID2);

		if self.isDoingRowSep then
			// ## the found TI is not in the correct row for seperation, whizz thru until we find one.
			if gridRowOrd &lt;&gt; 0 and gridRowOrd &lt;&gt; keyGridRowOrd then
				while self.myIterator.next(theTI) do
					// ### get the KEYS back for the found TI
					self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2, self.myIterator);
					if gridRowOrd = keyGridRowOrd then
						break;
					endif;
					
				endwhile;
				if theTI = null then
					theTI := theFoundTI; // switch back to the one that possibly does match the colour coding, but was just in the wrong row
				
					// ### get the KEYS back for the found TI
					self.myIterator.startAtObject(theTI);
					self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2, self.myIterator);

				elseif reqIsDLR then
					if not theTI.isRehandle then // done row sep but the TI is not a DLR so switch to a definant DLR match
						theTI := theFoundTI;
						self.myIterator.startAtObject(theTI);
						self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID, self.myIterator);
					endif;
				endif;
			endif;
		endif;
		
		// ### compare the TI's basic keys with the requests keys, double check with colour code that this is basically the right one.
		tiMatches := ((reqDischPortCode = keyDischPortCode) and (reqContentStatus = keyContentsStatus) and (reqPowerType = keyPowerType)	and (reqLength = keyTiLength)	and (reqHeight = keyTiHeight));
		if tiMatches then
			self.doSwitchRow(keyTaID, keyGridRowOrd, keyGridColOrd, resetRow); // ## Row Seperation
			if reqIsDLR and not theTI.isRehandle then
				return null;
			endif;
			return theTI; // THIS IS THE ONE!
		elseif theTI &lt;&gt; theFoundTI then
			theTI := theFoundTI; // switch back to the one that possibly does match the colour coding, but was just in the wrong row
			self.myIterator.startAtObject(theTI);
			self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID,self.myIterator);
			tiMatches := ((reqDischPortCode = keyDischPortCode) and (reqContentStatus = keyContentsStatus) and (reqPowerType = keyPowerType)	and (reqLength = keyTiLength)	and (reqHeight = keyTiHeight));
			if tiMatches then
				self.doSwitchRow(keyTaID, keyGridRowOrd, keyGridColOrd, resetRow); // ## Row Seperation
				return theTI;// THIS IS THE ONE!
			endif;
		endif;
	else
		self.sortTA := null;
		self.sortRow := null;
	endif;

	return null;
end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTINoSeperation" id="bcf99b90-7035-4ea4-bb7c-1cb3b3b94dc9">
        <updating/>
        <source>getTINoSeperation(_req : CM_SlotRequest) : CM_TrackedItem updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		Get TI that matches Colour Coding
//
// ---------------------------------------------------------------------------
vars
	reqDischPortCode,
	reqCommGrpCode,
	reqContentStatus,
	taID, taID2				: String;
	reqPowerType,
	reqLength,
	reqHeight,
	
	reqSelStatus,
	gridRowOrd,
	gridColOrd, endIdx,reqWeight		: Integer;
	theTI, theFoundTI, foundDLRTI : CM_TrackedItem;
	idx, selectionType : Integer; 
	
	keyDischPortCode,
	keyCommGrpCode,
	keyContentsStatus,
	keyTaID2, keyTaID				: String;
	keyPowerType,
	keyTiLength,
	keyTiHeight,
	keyTiWeight,
	keyTiSelStatus,
	keyGridRowOrd,
	keyGridColOrd,
	keyGridStackPos: Integer;
	resetRow, tiMatches, reqIsDLR, reqIsHaz : Boolean;
begin

	// ### GET THE REQUEST DATA
	reqDischPortCode := _req.dischargePort;
	/* WAS PAR 16714
	if _req.isSpecialStow() then
		reqCommGrpCode := _req.commodity; // this is comm group
	endif;
	*/
	reqCommGrpCode := _req.getAutoLoadPlanCommodityCode();
	
	if _req.getAttrEmpty() then
		reqContentStatus := "MT";
	else
		reqContentStatus := "FULL";
	endif;
	
	reqIsDLR := _req.isRehandle();
	reqIsHaz := _req.getAttrHazardous();
	
	reqPowerType := _req.getShipPlanningPowerType();
	reqLength := _req.getActualLength().Integer; // 20 40 or 45
	reqHeight := _req.getAttrHiCubed().Integer; // zero or one
	
	reqSelStatus := 0;
	reqWeight := self.getReqsWeight(_req);


	taID := "";
	gridRowOrd := 0;
	gridColOrd := 0;
	
	// ### get first ti that basically matches
	theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, reqHeight, reqWeight, reqSelStatus, taID, gridRowOrd, gridColOrd, 0,taID2);
	if theTI &lt;&gt; null then
		if self.useWeights and self.jobHasHeavies then
			self.myIterator.startAtObject(theTI);
			self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2, self.myIterator);
			tiMatches := ((reqWeight = keyTiWeight) and (reqDischPortCode = keyDischPortCode) and (reqContentStatus = keyContentsStatus) and (reqPowerType = keyPowerType)	and (reqLength = keyTiLength)	and (reqHeight = keyTiHeight));
			if not tiMatches then
				// we have tried to match by heavy or light weight so now ignore the weight
				theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, reqHeight, 0, reqSelStatus, taID, gridRowOrd, gridColOrd,0, taID2);
			endif;
		endif;

	
	
	
	


/*		
if theTI.id = "WGHT6767651" then		
	app.writeStatement(theTI.id &amp; "," &amp; _req.String &amp; "," &amp; reqDischPortCode &amp; "," &amp; reqContentStatus &amp; "," &amp; reqPowerType.String 
					&amp; "," &amp; reqLength.String &amp; "," &amp; reqHeight.String &amp; "," &amp; reqSelStatus.String &amp; "," &amp;  taID &amp; "," &amp; gridRowOrd.String 
								&amp; "," &amp; gridColOrd.String);
endif;
*/


		// ### we are close, but if this request is for a DLR so scoot through until we get a DLR

		// ### get the KEYS back for the found TI
		self.myIterator.startAtObject(theTI);
		self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2, self.myIterator);

		// ### compare the TI's basic keys with the requests keys, double check with colour code that this is basically the right one.
		tiMatches := ((reqDischPortCode = keyDischPortCode) and (reqContentStatus = keyContentsStatus) and (reqPowerType = keyPowerType)	and (reqLength = keyTiLength)	and (reqHeight = keyTiHeight));
		if tiMatches then
			if reqIsDLR and not theTI.isRehandle then
				return null;
			endif;
			return theTI; // THIS IS THE ONE!
		endif;
	else
		self.sortTA := null;
		self.sortRow := null;
	endif;

	return null;
end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTISpecial" id="16bda81a-6420-43e1-add5-89f5b988f7f6">
        <source>getTISpecial( _req : CM_SlotRequest) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		check that the TI  has correct DLR, HAZ and CommGroup settings.
//					move through dict until it all matches
//
// ---------------------------------------------------------------------------
vars
	reqIsDLR, reqIsHAZ, reqHasComm, ddMatches : Boolean;
	theTI, dTI : CM_TrackedItem;
	keyDischPortCode,
	keyCommGrpCode,
	keyContentsStatus,
	keyTaID,keyTaID2,
	reqDischPortCode,
	reqCommGrpCode,
	reqContentStatus: String;
	keyPowerType,
	keyTiLength,
	keyTiHeight,
	keyTiWeight,
	keyTiSelStatus,
	keyGridRowOrd,
	keyGridColOrd,
	keyGridStackPos, reqPowerType, reqLength, reqHeight, reqWeight: Integer;
	tiMatches : Boolean;
	iter : Iterator;
	ddDischPort, ddCommGroup : String;
	specialStow, ddHaz, ddDLR : Boolean;
begin
	
	// ### GET REQUESTS' DATA
	reqDischPortCode := _req.dischargePort;

	/* WAS PAR 16714
	if _req.isSpecialStow() then
		reqCommGrpCode := _req.commodity; // this is comm group
	endif;
	*/
	reqCommGrpCode := _req.getAutoLoadPlanCommodityCode();
	
	reqPowerType := _req.getShipPlanningPowerType(); // YES or NO
	reqLength := _req.getActualLength().Integer; // 20 40 or 45
	reqHeight := _req.getAttrHiCubed().Integer; // zero or one
	if _req.getAttrEmpty() then
		reqContentStatus := "MT";
	else
		reqContentStatus := "FULL";
	endif;

	reqIsDLR := _req.isRehandle();
	reqHasComm := reqCommGrpCode &lt;&gt; null;
	reqWeight := self.getReqsWeight(_req);

	// ### get first ti that basically matches
	/* WAS PAR 14959
	theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, 0, 0, 0, null, 0, 0,0,null);
	NOW */
	theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, reqHeight, reqWeight, 0, null, 0, 0,0,null);
	
	if theTI &lt;&gt; null then
		//  PAR 14959 added this weight check
		if self.useWeights and self.jobHasHeavies then
			self.myIterator.startAtObject(theTI);
			self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,self.myIterator);
			tiMatches := ((reqWeight = keyTiWeight) and (reqDischPortCode = keyDischPortCode) and (reqContentStatus = keyContentsStatus) and (reqPowerType = keyPowerType)	and (reqLength = keyTiLength)	and (reqHeight = keyTiHeight));
			if not tiMatches then
				// we have tried to match by heavy or light weight so now ignore the weight
				theTI := self.allTrackedItems.getAtKeyGeq(reqDischPortCode, reqContentStatus, reqCommGrpCode, reqPowerType, reqLength, reqHeight, 0, 0, null, 0, 0,0,null);
			endif;
		endif;

//	app.writeStatement(_req.String &amp; "," &amp; dischPortCode &amp; "," &amp; commGrpCode &amp; "," &amp; reqPowerType.String 
//					&amp; "," &amp; reqLength.String &amp; "," &amp; reqHeight.String &amp; "," &amp; tiSelStatus.String &amp; "," &amp;  taID &amp; "," &amp; gridRowOrd.String 
//								&amp; "," &amp; gridColOrd.String);

		self.myIterator.startAtObject(theTI);
		
		// ################################
		// ### CHECK WHETHER THE FIRST TI  MATCHES
		// ################################
		self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,self.myIterator);

		tiMatches := ((reqDischPortCode = keyDischPortCode) and 
								(reqContentStatus = keyContentsStatus) and 
								(reqPowerType = keyPowerType)	and 
								(reqLength = keyTiLength)	and 
								(reqHeight = keyTiHeight));

		// ## CHECK THAT IT MATCHES SPECIAL STUFF
		if tiMatches then
			tiMatches := (reqIsDLR = theTI.isRehandle);
			if tiMatches then
				if self.currentType = self.Type_WaterCooled then
					tiMatches := theTI.isAttributeTrue(TI_Attrib_IsWaterCooled);
				elseif self.currentType = self.Type_Hazardous then
					tiMatches := theTI.isHazardous;
				elseif self.currentType = self.Type_CommodityGroup then
					tiMatches := (theTI.commodityGroup = reqCommGrpCode);
				endif;
			endif;
		endif;
		
		if tiMatches then
			return theTI; // GOT IT!
		endif;
		
		// ###################################################
		// ### first one does not match so work through until we find our special item
		// ###################################################

		self.myIterator.startAtObject(theTI); // all Unplanned
		while self.myIterator.next(theTI) do
			// ### get the KEYS back for the found TI
			self.allTrackedItems.getIteratorKeys(keyDischPortCode, keyContentsStatus, keyCommGrpCode, keyPowerType, keyTiLength, keyTiHeight, keyTiWeight, keyTiSelStatus, keyTaID, keyGridRowOrd, keyGridColOrd, keyGridStackPos,keyTaID2,self.myIterator);
	
			tiMatches := ((reqDischPortCode = keyDischPortCode) and 
									(reqContentStatus = keyContentsStatus) and 
									(reqPowerType = keyPowerType)	and 
									(reqLength = keyTiLength)	and 
									(reqHeight = keyTiHeight));
			
			// ## CHECK THAT IT MATCHES SPECIAL STUFF
			if tiMatches then
				tiMatches := (reqIsDLR = theTI.isRehandle);
				if tiMatches then
					if self.currentType = self.Type_WaterCooled then
						tiMatches := theTI.isAttributeTrue(TI_Attrib_IsWaterCooled);
					elseif self.currentType = self.Type_Hazardous then
						tiMatches := theTI.isHazardous;
					elseif self.currentType = self.Type_CommodityGroup then
						tiMatches := (theTI.commodityGroup = reqCommGrpCode);
					endif;
				endif;
			endif;
			
			if tiMatches then
				return theTI;
			endif;
		endwhile;
	endif;

	return null;
end;
</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="34a8c59b-f932-4d15-9f49-021761398d53">
        <updating/>
        <source>getTIs() updating;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	 ls : Boolean;
	tmpTI : CM_TrackedItem;
	iter : Iterator;
	tmpTerm : String;
	rowOrd, colOrd: Integer;
	addToTopStow : Boolean;
	
begin
	addToTopStow := (self.autoLoadPlanAt3Height or self.isDoingEndSep);
	
	app.cmsBeginLoad(ls);
	foreach tmpTI in self.myQuery.allQryTrackedItems discreteLock do
		if self.ignoreTIsWithErrors and tmpTI.validateForAutoLoadPlanning() then
			continue;
		endif;
		
		if tmpTI.myPrimaryActualLocation &lt;&gt; null and (not tmpTI.myPrimaryActualLocation.isAllowedForAutoPlanning) then
			continue;
		endif;
		
// PAR 16606 take this out as we need all the TIs		
//		if not self.doesTIMatchColourCodingReqd(tmpTI) then
//			continue; 
//		endif;
	
		self.addTI(tmpTI); // ADD
		
		if addToTopStow then
			if self.doSelTopHeight then
				if tmpTI.isTopPositionCargo(self.topPosition) then
					tmpTI.getTopStowKeys(tmpTerm, rowOrd, colOrd);
					self.allTrackItemsTopStow.putAtKey(tmpTerm, rowOrd, colOrd, self.topPosition, tmpTI);
				endif;
			endif;
		endif;

	endforeach;

	self.sortCargoForParams();
	self.sortCargoForCrossAreas();
epilog
	app.cmsEndLoad(ls);

end;</source>
    </JadeMethod>
    <JadeMethod name="getUnplannedOverStowing" id="e694bc5e-d2b0-4a5a-b2c2-483afa192802">
        <source>getUnplannedOverStowing(_matchingTI : CM_TrackedItem) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		22 January 2007 By Andrew Bishop cnwab1
//
// Purpose:		The idea here is that we have got a TI that matches, but
//					for whatever reason it is over stowed by a matching item that has
//					not been planned. Else return same TI that was passed in.
//
// ---------------------------------------------------------------------------
vars
	lc	 			: CM_LocationsController;
	osTI : CM_TrackedItem;
	mtchCS, osCS : String;
begin
	

	// not overstowed
	if _matchingTI.isTopPositionCargo(0) then
		return _matchingTI;
	endif;

	lc := _matchingTI.myPrimaryActualLocation;
	
	if  lc = null then
		return _matchingTI;
	endif;
	
	if lc &lt;&gt; null and lc.myTerminalArea &lt;&gt; null and lc.myTerminalArea.isTransferArea then
		return _matchingTI;
	endif;
	
//	osTI := lc.allTrackedItems.last;// PAR 16690
	
	// PAR 16690
	// check if there is anything on top of the passed in TI that is unplanned for this voyage.
	foreach osTI in lc.allTrackedItems reversed do
		if osTI = _matchingTI then // stop at passed in TI
			break;
		endif;
		if osTI.myVoyage = _matchingTI.myVoyage 
		and self.allTrackedItems.includes(osTI) then // not already in line for planning
			break;
		endif;

	endforeach;
	if osTI = _matchingTI 
	or osTI.myVoyage &lt;&gt; _matchingTI.myVoyage then
		return _matchingTI;
	endif;
	
	
	
	// not planned and it's ontop of our TI!!!!!
	if osTI.myPrimaryPlannedLocation = null then
		if self.allTrackedItems.includes(osTI) then
		
			if osTI.isAttributeTrue(TI_Attrib_IsEmpty) then
				osCS := "MT";
			else
				osCS := "FULL";
			endif;
			if _matchingTI.isAttributeTrue(TI_Attrib_IsEmpty) then
				mtchCS := "MT";
			else
				mtchCS := "FULL";
			endif;

			if osTI.dischargePort = _matchingTI.dischargePort
			and mtchCS = osCS
			and osTI.getShipPlanningPowerType() = _matchingTI.getShipPlanningPowerType() 
			and osTI.getActualLength().Integer = _matchingTI.getActualLength().Integer 
			and osTI.isAttributeTrue(TI_Attrib_IsHiCubed).Integer = _matchingTI.isAttributeTrue(TI_Attrib_IsHiCubed).Integer then 
			
				// PAR 17590. Check that the overstowing item has the 'special' attributes
				if self.currentType = self.Type_WaterCooled then
					if osTI.isAttributeTrue(TI_Attrib_IsWaterCooled) &lt;&gt; _matchingTI.isAttributeTrue(TI_Attrib_IsWaterCooled) then
						return _matchingTI;
					endif;
				elseif self.currentType = self.Type_Hazardous then
					if osTI.isHazardous &lt;&gt; _matchingTI.isHazardous then
						return _matchingTI;
					endif;

				elseif self.currentType = self.Type_CommodityGroup then
					if osTI.commodityGroup &lt;&gt; _matchingTI.commodityGroup then
						return _matchingTI;
					endif;
				endif;
			
			
				// is not planned because it has a stop etc.				
				if osTI.validateForAutoLoadPlanning() then
					return _matchingTI;
				endif;
				return osTI;
			endif;
		endif;
	endif;
	
	return _matchingTI;
end;</source>
        <Parameter name="_matchingTI" type="CM_TrackedItem"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getUseWeights" id="5eab55a7-698c-4553-a9ce-e7bded0f04eb">
        <source>getUseWeights() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2009	cnwer1	Initial creation CCMS1032

*/

vars

begin
	return self.useWeights;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUserFlipped" id="7f65e2a2-3b7e-44d8-beca-0551acbb9188">
        <source>hasUserFlipped(_flipH, _flipV : Boolean io);
// ---------------------------------------------------------------------------
// Created:		06 June 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, revTicked,hideT,hideM : Boolean;
	zoomScale : Real;
begin
	if self.myForm &lt;&gt; null then
		revTicked := self.myForm.sendMsg("isReversedTicked").Boolean;
	endif;
	
	if revTicked then
		_flipH := not self.flippedH;
	else
		_flipH := self.flippedH;
	endif;
	_flipV := self.flippedV;

end;</source>
        <Parameter name="_flipH" type="Boolean" usage="io"/>
        <Parameter name="_flipV" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="init" id="2808641c-3142-4d07-8971-863de66fc33e">
        <updating/>
        <source>init(_term : CM_Terminal; _mode : Integer; _jobs : CM_JobArray; _js : CM_VoyageJobSheet; _voy : CM_Voyage; _ignoreTIsWithErrors : Boolean;
		_selection : IntegerArray; _topPos : Integer; _useRowEnd : Boolean; _rowsSep : Integer; _form : Form; _useWeights : Boolean; _wave, _wpc : Integer;
		_isDoingTASepByInd, _isDoingTASepByCol : Boolean; _ignore : Boolean;_twinlift : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	a : Integer;
	b : String;
begin
	a := PmShipCanFullyPlan;
	a := VoyageFullPlanThirdHeight;
	a := VoyageFullPlanGroundHeight;
	a := VoyageFullPlanOSVoyage;
	a := VoyageFullPlanOSDischPort;
	b := VoyageFullPlanThirdHeightStr;
	b := VoyageFullPlanGroundHeightStr; 
	b := VoyageFullPlanOSVoyageStr; 
	b := VoyageFullPlanOSDischPortStr; 
	

	self.ignoreWarnings := _ignore;
	self.allTrackedItems.clear;
	self.allTrackItemsTopStow.clear;
	self.allTIsForPlanning.clear;
	self.allRequestsPlanned.clear;
	self.allRequestsNotplanned.clear;
	self.allROROReqsNotPlanned.clear;
	self.allROROReqsPlanned.clear;
	
	self.isDoingTASepByCol := _isDoingTASepByCol;
	self.isDoingTASepByInd := _isDoingTASepByInd;
	
	self.myForm := _form;
	self.myTerminal := _term;
	self.mode := _mode;
	self.myVoyage := _voy;
	self.myJobSheet := _js;
	self.useRowEnds := _useRowEnd;
	self.isDoingEndSep := _useRowEnd;
	self.useWeights := _useWeights;
//	self.weightAve := (_wave - (_wave * (_wpc /100))).Integer; // reduce by leeway percentage
	self.weightAve := _wave;
	self.wieghtPC := _wpc;
	self.ignoreTIsWithErrors := _ignoreTIsWithErrors;
	self.doSelTopHeight := false;
	self.doPlanTwinLift := _twinlift;
	if not self.myVoyage.hasVoyageGotHeavies() then
		self.useWeights := false; // turn this off if voyage has not load colour code that is defined as heavy
	endif;
	
	self.rowsSeperation := _rowsSep;
	self.isDoingRowSep := (self.rowsSeperation &gt; 0);
	
	if self.isDoingTASepByCol or self.isDoingTASepByInd then
		self.isDoingRowSep := false;
	endif;
	
	self.selectionOrder.clear;
	if _selection &lt;&gt; null then
		_selection.copy(self.selectionOrder);
	endif;
	

	if _jobs &lt;&gt; null then
		self.addJobs(_jobs);
	endif;
	self.topPosition := _topPos;
	
	if self.myVoyage = null and _js &lt;&gt; null then
		self.myVoyage := _js.myVoyage;
	else
		aJob := self.allJobs.first;
		if aJob &lt;&gt; null then
			self.myVoyage := aJob.CM_VoyageJob.myVoyage;
		endif;
	endif;
	
	if self.myTerminal = null and self.myVoyage &lt;&gt; null then
		self.myTerminal := self.myVoyage.myTerminal;
	endif;
	
	if self.myIterator = null then
		self.myIterator := self.allTrackedItems.createIterator();
	endif;
	
	self.allRequestsNotplanned.clear;
	self.allRequestsPlanned.clear;
	self.allTrackedItems.clear;
	self.allROROReqsNotPlanned.clear;
	self.allROROReqsPlanned.clear;
	
	self.autoLoadPlanAt3Height := self.myTerminal.getConfig(AutoLoadPlanAt3Height).Boolean;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_jobs" type="CM_JobArray"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_ignoreTIsWithErrors" type="Boolean"/>
        <Parameter name="_selection" type="IntegerArray"/>
        <Parameter name="_topPos" type="Integer"/>
        <Parameter name="_useRowEnd" type="Boolean"/>
        <Parameter name="_rowsSep" type="Integer"/>
        <Parameter name="_form" type="Form"/>
        <Parameter name="_useWeights" type="Boolean"/>
        <Parameter name="_wave" type="Integer"/>
        <Parameter name="_wpc" type="Integer"/>
        <Parameter name="_isDoingTASepByInd" type="Boolean"/>
        <Parameter name="_isDoingTASepByCol" type="Boolean"/>
        <Parameter name="_ignore" type="Boolean"/>
        <Parameter name="_twinlift" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCMIF_PlanningSlotRequests" id="e82faaab-9658-41f8-9f81-79c9518470ee">
        <source>initCMIF_PlanningSlotRequests();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2009	cnwer1	Initial creation

*/

vars

	tmpJob : CM_Job;
	voyJob : CM_VoyageJob;
	reqs : CM_SlotRequestArray;
	aReq : CM_Request;
	srReq : CM_SlotRequest;
	roroReq : CM_RORORequest;
	cmifPlanningSlotRequest,
	priorPlanningSlotRequest : CMIF_ShipPlanningSlotRequest;
	twinSC : CM_SlotController;
	isTwin,
	setTwin,
	doneWrite : Boolean;
	iter : Iterator;
	spTI : CMIF_ShipPlanningTI;
begin
	self.allCMIF_PlanningSlotRequests.purge;
	create reqs transient;
	
	foreach tmpJob in self.allJobs discreteLock do : jobLoop
		voyJob := tmpJob.CM_VoyageJob;
		if voyJob.isHatchLidJob() then
			continue;
		endif;
		if voyJob.isDischarge then
			continue;
		endif;
		if voyJob.isJobComplete() then
			continue;
		endif;
		
		isTwin:= voyJob.isTwinLift;
		
		if voyJob.isKindOf(CM_VoyageDeckJob) then
			foreach aReq in voyJob.allRequests discreteLock do 
				roroReq:=aReq.CM_RORORequest;
				if roroReq.hasTIsOfMode(PLANNING_MODE) then
					continue;
				endif;
				if self.allCMIF_PlanningSlotRequests.size &gt; 0 then
					priorPlanningSlotRequest:=self.allCMIF_PlanningSlotRequests.last;
				endif;
				create cmifPlanningSlotRequest transient;
				cmifPlanningSlotRequest.initRORO(roroReq,self);
			endforeach;
		else
			reqs.clear;
			voyJob.doSortReqsInToSeqOrder(reqs);
		
			foreach aReq in reqs discreteLock do 
				srReq:=aReq.CM_SlotRequest;
				if aReq.hasTIsOfMode(PLANNING_MODE) then
					continue;
				endif;
				if self.allCMIF_PlanningSlotRequests.size &gt; 0 then
					priorPlanningSlotRequest:=self.allCMIF_PlanningSlotRequests.last;
				endif;
				create cmifPlanningSlotRequest transient;
				cmifPlanningSlotRequest.init(srReq,self);
				
				
				if isTwin then
					twinSC:=srReq.getTwinController;
					if twinSC &lt;&gt; null and priorPlanningSlotRequest &lt;&gt; null then
						if twinSC.mySlotRequestLoad = priorPlanningSlotRequest.mySlotRequest then
							cmifPlanningSlotRequest.setMyAftTwinCMIFPlanningSR(priorPlanningSlotRequest);
						endif;		
					endif;
				endif;
				
					
			endforeach;
		endif;
	endforeach;
epilog
	delete reqs;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="initQuery" id="e93ca843-af76-4f45-aa39-60a1e03c43df">
        <updating/>
        <source>initQuery() updating;
// ---------------------------------------------------------------------------
// Created:		11 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
vars
	ls : Boolean;
begin
		self.doQueryInitFilter();
	
		app.cmsBeginLoad(ls);
		app.myQAFilter.qryTerminalTIs(self.myQuery, app.myPassport);
		
epilog			// 08/04/2011 cnwmh5 #27347
		app.cmsEndLoad(ls);

end;</source>
    </JadeMethod>
    <JadeMethod name="planTI" id="d1c6a1f7-42ce-47c7-bd62-94471e8d39df">
        <source>planTI(_req : CM_SlotRequest; _theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theMoveController	: CMIF_MoveController;
	lTI : CM_TrackedItem;
	lController : CM_LocationsController;
	result,
	theReturn : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	create theMoveController transient;
	theMoveController.setMyToPrimaryLocation(_req.mySlotController);
	theMoveController.setMoveMode(PLANNING_MODE);
	theMoveController.isSystemMove := true;
	theMoveController.isForcedMove := true;
	theMoveController.setMyWorkListEntry(_req.allWorkListEntries.first);
	theMoveController.setMyTrackedItem(_theTI);
	
	app.myTrxUA.trxMoveTrackedItemAssignToJob(theMoveController, app.myPassport);
	
	if app.isDevelopmentSystem() or app.isSpecial() then	
		app.myPassport.dumpErrorWarnings();
	endif;
	
	return _theTI.isPlanned(PLANNING_MODE);
	
epilog
	delete theMoveController;
	endLoad;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="planTIsLOLO" id="359491f9-975f-4e6f-84c2-30aa933ad74b">
        <updating/>
        <source>planTIsLOLO() updating;
// ---------------------------------------------------------------------------
// Created:		14 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	theSlotRequest : CM_SlotRequest;
	theTIs : CM_TIArray;
	theLCs : CM_LCArray;
	tmpErr	: CM_Error;
	tmpString : String;
begin


	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	create moveController transient;

	create theLCs transient;
	
	moveController.isRehandleMove := false;
	moveController.mySlotRequest := self.allRequestsPlanned.first;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	foreach theSlotRequest in 	self.allRequestsPlanned do
		theLCs.add(theSlotRequest.mySlotController);
	endforeach;

	app.myPassport.setWarningsIgnored(self.ignoreWarnings);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(self.allTIsForPlanning, theLCs, moveController, app.myPassport);
	
	self.errorsWarnings := null;
	if not app.myPassport.allErrorWarnings.isEmpty then
		foreach tmpErr in app.myPassport.allErrorWarnings do
			if tmpErr.warningOnly then
				errorsWarnings := errorsWarnings &amp; app.getErrorString(Warning) &amp; ' - '  &amp; tmpErr.text &amp; CrLf;
			else
				errorsWarnings := errorsWarnings &amp; app.getErrorString(Error) &amp; ' - '  &amp; tmpErr.text &amp; CrLf;
			endif;
		endforeach;
	endif;
	
epilog
	app.myPassport.clearErrorsWarnings();
	delete theTIs;
	delete theLCs;
	delete moveController; //epr par 18417
	app.mousePointer := Window.MousePointer_Default;


end;</source>
    </JadeMethod>
    <JadeMethod name="planTIsRORO" id="e714c636-b853-48bc-bbba-cc91326d48e1">
        <updating/>
        <source>planTIsRORO() updating;
// ---------------------------------------------------------------------------
// Created:		14 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	theSlotRequest : CM_RORORequest;
	theTIs : CM_TIArray;
	theLCs : CM_LCArray;
	tmpErr	: CM_Error;
	tmpString : String;
begin


	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	create moveController transient;

	create theLCs transient;
	
	moveController.isRehandleMove := false;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	foreach theSlotRequest in 	self.allROROReqsPlanned do
		moveController.myVoyageRequest := theSlotRequest;
		theLCs.add(theSlotRequest.myROROController);
	endforeach;

	app.myPassport.setWarningsIgnored(self.ignoreWarnings);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(self.allTIsForPlanning, theLCs, moveController, app.myPassport);
	
	//self.errorsWarnings := null;			// 14/12/2011 cnwmh5 #28830 - Stopping LOLO messages from appearing
	if not app.myPassport.allErrorWarnings.isEmpty then
		foreach tmpErr in app.myPassport.allErrorWarnings do
			if tmpErr.warningOnly then
				errorsWarnings := errorsWarnings &amp; app.getErrorString(Warning) &amp; ' - '  &amp; tmpErr.text &amp; CrLf;
			else
				errorsWarnings := errorsWarnings &amp; app.getErrorString(Error) &amp; ' - '  &amp; tmpErr.text &amp; CrLf;
			endif;
		endforeach;
	endif;
	
epilog
	app.myPassport.clearErrorsWarnings();
	delete theTIs;
	delete theLCs;
	delete moveController; //epr par 18417
	app.mousePointer := Window.MousePointer_Default;


end;</source>
    </JadeMethod>
    <JadeMethod name="processRequests" id="7e4e6f77-f300-4832-8868-1f8f8bfd6abf">
        <updating/>
        <source>processRequests(_type : Integer; _partsDone : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars
	tmpMonitor 					: CMIF_Monitor;
	partsInJob, partsDone, idx 	: Integer;
	message 					: String;
	tmpJob 						: CM_Job;
	voyJob 						: CM_VoyageJob;
	aReq 						: CM_Request;
	srReq						: CM_SlotRequest;
	theTI 						: CM_TrackedItem;
	reqs 						: CM_SlotRequestArray;
	tmpLbl 						: String;
	commodityGroup 				: CM_CommodityGroup; 		//cnwas3 PAR 24273
begin
	tmpMonitor := self.myMonitor;
	partsDone := _partsDone;
	self.currentType := _type;

	if _type = self.Type_CommodityGroup then
		tmpLbl := "Special Stows";
	endif;
	if _type = self.Type_Hazardous  then
		tmpLbl := "Hazardous Stows";
	endif;
	if _type = self.Type_WaterCooled then
		tmpLbl := "Watercooled Stows";
	endif;
	
	if not self.validateQuery() then
		return;
	endif;
	
	create reqs transient;

	self.myIterator.reset();
	partsInJob := self.allJobs.getTotalRequests(true);
	
	//beginLock;			// PAR #34422
	
	foreach tmpJob in self.allJobs discreteLock do : jobLoop
		voyJob := tmpJob.CM_VoyageJob;
		if voyJob.isHatchLidJob() then
			continue;
		endif;
		if voyJob.isDischarge then
			continue;
		endif;
		if voyJob.isJobComplete() then
			continue;
		endif;
		
	
		reqs.clear;
		voyJob.doSortReqsInToSeqOrder(reqs);
		
		foreach aReq in reqs discreteLock do : reqLoop
			partsDone := partsDone + 1; // PAR 16604
			srReq := aReq.CM_SlotRequest;
			
			if self.requestProcessed(srReq) then
				continue;
			endif;
			
			if aReq.hasTIsOfMode(PLANNING_MODE) then
				continue;
			endif;
			
			// special stows only
/* WAS	PAR 14938		if _type = self.Type_CommodityGroup and srReq.commodity.trimBlanks() = null then 
NOW */
			// special stows only
			if _type = self.Type_CommodityGroup then 
				commodityGroup := srReq.getAttrCommodityGroup();		//cnwas3 PAR 24273
				if commodityGroup = null then							//cnwas3 PAR 24273
					continue;
				endif;
				if not commodityGroup.isSpecialStow then				//cnwas3 PAR 24273
					continue;
				endif;
			endif;
			if _type = self.Type_Hazardous and not srReq.getAttrHazardous() then
				continue;
			endif;
			if _type = self.Type_WaterCooled and not srReq.getAttrWaterCooled() then
				continue;
			endif;
//			partsDone := partsDone + 1;
			
			message := tmpLbl &amp; " Colour Coding " &amp; srReq.mySlotController.getFullId();
			if tmpMonitor &lt;&gt; null then	
				if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
					return;
				endif;
			endif;
			
			if _type = self.Type_All then
				if not self.isDoingRowSep then
					theTI := self.getTINoSeperation(srReq);
					if theTI &lt;&gt; null then
						theTI := self.getUnplannedOverStowing(theTI);
					endif;
				else
					theTI := self.getTI(srReq);
					if theTI &lt;&gt; null then
						theTI := self.getUnplannedOverStowing(theTI);
					endif;
				endif;
			else
				theTI := self.getTISpecial(srReq);
				if theTI &lt;&gt; null then
					theTI := self.getUnplannedOverStowing(theTI);
				endif;
			endif;
			
			// ### NO MATCH
			if theTI = null then
				self.allRequestsNotplanned.add(srReq);
				continue reqLoop;
			else
				// MATCHES
				self.allRequestsPlanned.add(srReq);
				self.allTIsForPlanning.add(theTI);

				self.removeTI(theTI); // REMOVE
				continue reqLoop;
			endif;
		endforeach;
	endforeach;
epilog
	_partsDone := partsDone;
	delete reqs;
	//endLock;				// PAR #34422
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_partsDone" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processRequestsNew" id="f73c7102-3a72-4f03-a7c6-148932069f0f">
        <source>processRequestsNew();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation

*/
vars
	cmif_ShipPlanningSlotRequest,
	prevShipPlanningSlotRequest : CMIF_ShipPlanningSlotRequest;
	shipPlanningTI,
	theShipPlanningTI,
	lastShipPlanningTI,
	twinShipPlanningTI,
	osShipPlanningTI: CMIF_ShipPlanningTI;
	srReq		: CM_SlotRequest;
	theTI,
	osTI,
	twinTI: CM_TrackedItem;
	theTIDD,
	twinTIDD : Integer; //DD = Door Direction
	iter,
	slotRequestIter: Iterator;
	currentStackHeight,
	index 	: Integer;
	currentGridController,
	nextGridController : CM_GridController;  
	testTwinLift,
	tiFailedForTwinLift: Boolean;
begin

	testTwinLift:=self.doPlanTwinLift;	
	slotRequestIter:=self.allCMIF_PlanningSlotRequests.createIterator;
	while slotRequestIter.next( cmif_ShipPlanningSlotRequest)do
		twinTI:=null;
		theTI:=null;
		tiFailedForTwinLift:=false;
		delete iter;
		srReq:=cmif_ShipPlanningSlotRequest.mySlotRequest;
		if srReq = null then // might be a roro req
			continue;
		endif;
		if self.requestProcessed(srReq) then
			continue;
		endif;
			
		if srReq.hasTIsOfMode(PLANNING_MODE) then
			self.allRequestsNotplanned.add(srReq);
			continue;
		endif;
		
		if cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI.isEmpty then
			self.allRequestsNotplanned.add(srReq);
			continue;
		endif;
		
		index:=self.allCMIF_PlanningSlotRequests.indexOf(cmif_ShipPlanningSlotRequest);
		
		lastShipPlanningTI:=null;
		if index &gt; 1 then
			prevShipPlanningSlotRequest:=self.allCMIF_PlanningSlotRequests[index-1].CMIF_ShipPlanningSlotRequest;
			lastShipPlanningTI:=prevShipPlanningSlotRequest.allShipPlanningTIArray.first;		
		endif;
		theShipPlanningTI:=cmif_ShipPlanningSlotRequest.getFirstMatchingTI(lastShipPlanningTI,self.isDoingRowSep);
		
		if theShipPlanningTI &lt;&gt; null then
			theTI:=theShipPlanningTI.myTrackedItem;
			osTI := self.getUnplannedOverStowing(theTI);	
			osShipPlanningTI:=cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI[osTI];
			if (osShipPlanningTI &lt;&gt; null)then
				if ( not testTwinLift) or (testTwinLift and not osShipPlanningTI.failedForTwinLift) then
					theTI:=osTI;
					theShipPlanningTI:=osShipPlanningTI;
				endif;
			endif;
			
		endif;
		
		if theTI &lt;&gt; null then
						
			if testTwinLift then
				// no don't remove just mark as failed for twin lift
				if  not theTI.isTwinLiftCapable then
					theShipPlanningTI.setFailedForTwinLift(true);
					slotRequestIter.back(cmif_ShipPlanningSlotRequest);
					continue;
				endif;
				//get the adjacent container and slot request
				if cmif_ShipPlanningSlotRequest.myForwardTwinCMIFPlanningSR &lt;&gt; null then
					//get the adjacent container 
					currentStackHeight:=theTI.getPositionInStack(REAL_MODE);
					
					if theTI.myPrimaryActualLocation.isKindOf(CM_GridController) then
						currentGridController:= theTI.myPrimaryActualLocation.CM_GridController;
						theTIDD := currentGridController.doorDirection;
						//if planning reversed then the next grid controller will be the previous
						if not self.flippedH then
							//check can twin lift from this location 
							tiFailedForTwinLift:= not currentGridController.canTwinLiftWithNextController;
							nextGridController:=theTI.myPrimaryActualLocation.CM_GridController.myNextController;
						else
							//check can twin lift from this location 
							tiFailedForTwinLift:= not currentGridController.canTwinLiftWithPrevController;
							nextGridController:=theTI.myPrimaryActualLocation.CM_GridController.myPreviousController;
						endif;
						tiFailedForTwinLift:=tiFailedForTwinLift or nextGridController = null;
						
						if (not tiFailedForTwinLift) and nextGridController &lt;&gt; null and nextGridController.allTrackedItems.size &gt;= currentStackHeight then	
							twinTI:= nextGridController.allTrackedItems[currentStackHeight];
							
							if not self.flippedH  then
								tiFailedForTwinLift:=tiFailedForTwinLift or not nextGridController.canTwinLiftWithPrevController;
							else
								tiFailedForTwinLift:=tiFailedForTwinLift or not nextGridController.canTwinLiftWithNextController;
							endif;
						endif;
						
						//check that the twin TI is in the forward slot requests list of matching tracked items
						if twinTI &lt;&gt; null then 
							twinShipPlanningTI:=cmif_ShipPlanningSlotRequest.myForwardTwinCMIFPlanningSR.allShipPlanningTIsByTI[twinTI];
							if twinShipPlanningTI = null then
								twinTI:=null;
							endif;
							if twinTI &lt;&gt; null and not twinTI.isTwinLiftCapable then
								tiFailedForTwinLift:=true;
							endif;
						endif;
						tiFailedForTwinLift:=tiFailedForTwinLift or twinTI = null;
						
						///ARGHHHHHHHH
						//door direction rules if flippedH then both containers will need to face forward else both will need to face aft
						//direction depends on 
						if not tiFailedForTwinLift then
						
							tiFailedForTwinLift:=self.checkTwinDoorDirections(cmif_ShipPlanningSlotRequest.mySlotRequest,cmif_ShipPlanningSlotRequest.myForwardTwinCMIFPlanningSR.mySlotRequest,currentGridController  ,nextGridController);							
						endif;
						
						//we have found the one
						if not tiFailedForTwinLift then
						
							self.addTIToPlannedColl(theTI,cmif_ShipPlanningSlotRequest);
							self.addTIToPlannedColl(twinTI,cmif_ShipPlanningSlotRequest.myForwardTwinCMIFPlanningSR);
						
							lastShipPlanningTI:=theShipPlanningTI;//cmif_ShipPlanningSlotRequest.allShipPlanningTIArray.first.CMIF_ShipPlanningTI;
							
						
						
						else
							// no don't remove just mark as failed for twin lift
							theShipPlanningTI.setFailedForTwinLift(true);
							slotRequestIter.back(cmif_ShipPlanningSlotRequest);
							continue;
						endif;
					elseif theTI.myPrimaryActualLocation.isKindOf(CM_BlockController) then
						//its a block stack then just allow it and the next one in this block stack
						// get the cmif_ShipPlanningSlotRequest.myForwardTwinCMIFPlanningSR get the any of the matching tis is in this location not just the first
						// if this is in same primary actual location the ok else it failed for twin lifting 
						
						twinShipPlanningTI:=cmif_ShipPlanningSlotRequest.getFirstPlannedTIInTA(theShipPlanningTI);
						if twinShipPlanningTI &lt;&gt; null then
							twinTI:=twinShipPlanningTI.myTrackedItem;
						endif;
						//no need to test anything else 
						if twinTI &lt;&gt; null then
						
						else
							theShipPlanningTI.setFailedForTwinLift(true);
							slotRequestIter.back(cmif_ShipPlanningSlotRequest);
							continue;
						endif;
					else
						// anywhere else we know can't be twin lifted from	
						self.allRequestsNotplanned.add(srReq);
					endif;
				else
					self.addTIToPlannedColl(theTI,cmif_ShipPlanningSlotRequest);
					lastShipPlanningTI:= theShipPlanningTI;
				
				endif;
			else
				self.addTIToPlannedColl(theTI,cmif_ShipPlanningSlotRequest);
				
				
			endif;
			
		else	
		
			//see if we have been testing twin lift and ran out of viable twin lift tis but have good single lift tis 
			if self.doPlanTwinLift and cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI.size &gt; 0 then
				testTwinLift:=false;
				iter :=cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI.createIterator;
				while iter.next(shipPlanningTI) do
					shipPlanningTI.setFailedForTwinLift(false);
				endwhile;
				lastShipPlanningTI:=null;
				slotRequestIter.back(cmif_ShipPlanningSlotRequest);
				delete iter;
				continue;
			else
				self.allRequestsNotplanned.add(srReq);
				
			endif;
				
		endif;
		testTwinLift:=self.doPlanTwinLift;	
	endwhile;
				
epilog
	delete iter;
	delete slotRequestIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="processRequestsRORO" id="066b1643-6013-4965-b23e-d7b5c7aa5b55">
        <source>processRequestsRORO();
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	cmif_ShipPlanningSlotRequest,
	prevShipPlanningSlotRequest : CMIF_ShipPlanningSlotRequest;
	shipPlanningTI,
	theShipPlanningTI,
	lastShipPlanningTI,
	twinShipPlanningTI,
	osShipPlanningTI: CMIF_ShipPlanningTI;
	srReq		: CM_RORORequest;
	theTI,
	osTI,
	twinTI: CM_TrackedItem;
	theTIDD,
	twinTIDD : Integer; //DD = Door Direction
	iter,
	slotRequestIter: Iterator;
	currentStackHeight,
	index 	: Integer;
	currentGridController,
	nextGridController : CM_GridController;  
	testTwinLift,
	tiFailedForTwinLift: Boolean;
begin
	self.allTIsForPlanning.clear;
	testTwinLift:=false; //self.doPlanTwinLift;	
	slotRequestIter:=self.allCMIF_PlanningSlotRequests.createIterator;
	

	
	while slotRequestIter.next( cmif_ShipPlanningSlotRequest)do
		twinTI:=null;
		theTI:=null;
		tiFailedForTwinLift:=false;
		delete iter;
		srReq:=cmif_ShipPlanningSlotRequest.myRORORequest;
		if srReq = null then // might be a LOLO req
			continue;
		endif;
		

		if self.requestProcessedRORO(srReq) then
			continue;
		endif;
			
		if srReq.hasTIsOfMode(PLANNING_MODE) then
			self.allROROReqsNotPlanned.add(srReq);
			continue;
		endif;
		
		if cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI.isEmpty then
			self.allROROReqsNotPlanned.add(srReq);
			continue;
		endif;
		index:=self.allCMIF_PlanningSlotRequests.indexOf(cmif_ShipPlanningSlotRequest);
		
		lastShipPlanningTI:=null;
		if index &gt; 1 then
			prevShipPlanningSlotRequest:=self.allCMIF_PlanningSlotRequests[index-1].CMIF_ShipPlanningSlotRequest;
			lastShipPlanningTI:=prevShipPlanningSlotRequest.allShipPlanningTIArray.first;		
		endif;
		theShipPlanningTI:=cmif_ShipPlanningSlotRequest.getFirstMatchingTI(lastShipPlanningTI,self.isDoingRowSep);
		
		if theShipPlanningTI &lt;&gt; null then
			theTI:=theShipPlanningTI.myTrackedItem;
			osTI := self.getUnplannedOverStowing(theTI);	
			osShipPlanningTI:=cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI[osTI];
			if (osShipPlanningTI &lt;&gt; null)then
				if ( not testTwinLift) or (testTwinLift and not osShipPlanningTI.failedForTwinLift) then
					theTI:=osTI;
					theShipPlanningTI:=osShipPlanningTI;
				endif;
			endif;
			
		endif;
		if theTI &lt;&gt; null then
			self.addTIToPlannedColl(theTI,cmif_ShipPlanningSlotRequest);
			
		else	
			//see if we have been testing twin lift and ran out of viable twin lift tis but have good single lift tis 
			if self.doPlanTwinLift and cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI.size &gt; 0 then
				testTwinLift:=false;
				iter :=cmif_ShipPlanningSlotRequest.allShipPlanningTIsByTI.createIterator;
				while iter.next(shipPlanningTI) do
					shipPlanningTI.setFailedForTwinLift(false);
				endwhile;
				lastShipPlanningTI:=null;
				slotRequestIter.back(cmif_ShipPlanningSlotRequest);
				delete iter;
				continue;
			else
				self.allROROReqsNotPlanned.add(srReq);
				
			endif;
				
		endif;
		testTwinLift:=false; //self.doPlanTwinLift;	
	endwhile;
	

				
epilog
	delete iter;
	delete slotRequestIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTI" id="5218029a-71b5-4339-b63d-cd79255e1332">
        <source>removeTI(_theTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dischPortCode,
	commGrpCode,
	taID, taID2, contentsStatus				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos: Integer;
	theTI : CM_TrackedItem;
begin
	theTI := _theTI;
	
	self.myIterator.startAtObject(theTI);
	self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd, gridStackPos,taID2,self.myIterator);
	self.allTrackedItems.removeKeyEntry(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID, gridRowOrd, gridColOrd,gridStackPos, taID2, _theTI);
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="requestProcessed" id="c85bfda7-9794-4006-a555-740eb4eb7c3b">
        <source>requestProcessed(_slotReq : CM_SlotRequest) : Boolean;

vars

begin
	if _slotReq = null then
		return true;
	else
		return (self.allRequestsNotplanned.includes(_slotReq) or self.allRequestsPlanned.includes(_slotReq) );
	endif;

end;
</source>
        <Parameter name="_slotReq" type="CM_SlotRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requestProcessedRORO" id="2ba308cc-29da-4dc1-a97a-25f024642756">
        <source>requestProcessedRORO(_slotReq : CM_RORORequest) : Boolean;

vars

begin
	if _slotReq = null then
		return true;
	else
		return (self.allROROReqsNotPlanned.includes(_slotReq) or self.allROROReqsPlanned.includes(_slotReq) );
	endif;

end;
</source>
        <Parameter name="_slotReq" type="CM_RORORequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setYardAreaFlipped" id="0a1f4952-a365-45d1-bc5f-06fefe96c641">
        <updating/>
        <source>setYardAreaFlipped(_fh, _fv : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		09 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.flippedH := _fh;
	self.flippedV := _fv;
end;</source>
        <Parameter name="_fh" type="Boolean"/>
        <Parameter name="_fv" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortCargoForCrossAreas" id="145f69a7-77bc-49c0-9bce-be0a562a9a6f">
        <source>sortCargoForCrossAreas();
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1063
// 					What we do in here is basically to re assign a new row and column value so that depending on teh params the cargo is in teh right order.
//					If they have specified in teh params to have temrinal area seperation and row seperation then we tak ethat into account.
//					we put teh cargo into a tmp dyna dict, and record all teh terminal areas and rows taht are used.
//					If they want row seperation we take all teh rows for a termianl areas and seperate out by teh param but we on
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	tmpObj : Object;
	termAreasRows : StringArray;
	iterAllTIs,  iterDyna : Iterator;
	tmpTerm : String;
	rowOrd, colOrd, idx, idxTo: Integer;
	gridRowOrd, gridColOrd, gridStackPos : Integer;
	dischPortCode,
	commGrpCode,
	tiid, taID, taID2, tmpTAID, contentsStatus				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	taIDX : Integer;
	dynaDict, rowSepDict				: DynaDictionary;
	currentRow, theRow, rowOrd2, rowKey : Integer;
	sameTA : String;
	sameRow, sameCol, sameRow2 : Integer;
	aTA : CM_TerminalArea;
	allCurrentRows, rowArray : IntegerArray;
	allRowArrays : ObjectArray;
begin
	if not self.isDoingTASepByCol and not self.isDoingTASepByInd then
		return;
	endif;
	
	create dynaDict transient;	
	create rowSepDict transient;
	create termAreasRows transient;
	
	rowSepDict.setMembership(CM_TrackedItem);
	rowSepDict.addExternalKey(String, 20, false, true); // TERMINAL AREA
	rowSepDict.addExternalKey(Integer, 8, false, true); // ROW
	rowSepDict.endKeys(false);

	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addExternalKey(String, 20, false, true); // TERMINAL AREA
	dynaDict.addExternalKey(Integer, 8, false, true); // ROW
	dynaDict.addExternalKey(String, 20, false, true); // dischPortCode
	dynaDict.addExternalKey(String, 20, false, true); // contentsStatus
	dynaDict.addExternalKey(String, 20, false, true); // commGrpCode
	dynaDict.addExternalKey(Integer, 20, false, true); // powerType
	dynaDict.addExternalKey(Integer, 20, false, true); // tiLength
	dynaDict.addExternalKey(Integer, 20, false, true); // tiHeight
	dynaDict.addExternalKey(Integer, 8, false, true); // ROW
	dynaDict.addExternalKey(Integer, 8, false, true); // COL
	dynaDict.addExternalKey(Integer, 8, false, true); // STACK POS
	
	dynaDict.endKeys(true);
	
	iterDyna := dynaDict.createIterator();
	iterAllTIs := self.myIterator;
	iterAllTIs.reset();
	// get all TIS and add to dyna dict to sort as necessary
	while iterAllTIs.next(tmpTI) do
		self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, taID,	rowOrd, colOrd, gridStackPos,taID2,iterAllTIs);
		if self.rowsSeperation &gt; 0 then
			rowKey := rowOrd;
		else
			rowKey := 0;
		endif;
		dynaDict.putAtKey(taID, rowKey, dischPortCode, contentsStatus, commGrpCode,powerType,  tiLength, tiHeight, rowOrd,  colOrd, gridStackPos, tmpTI);
		
		tmpObj := rowSepDict.getAtKey(taID, rowKey);
		if tmpObj = null then
			rowSepDict.putAtKey(taID, rowKey, tmpTI);
		endif;
		// build a list of all the terminal areas, since we want to seperate cargo across terminal areas
		if not termAreasRows.includes(taID) then
			termAreasRows.add(taID);
		endif;
	endwhile;

	// get all the row ordinals by seperation for each TA
	termAreasRows.cnEcSort(false);
	create allRowArrays transient;
	create allCurrentRows transient;
	foreach tmpTAID in termAreasRows do
		create rowArray transient;
		allRowArrays.add(rowArray);
		allCurrentRows.add(1);
		aTA := self.myTerminal.allTerminalAreas[tmpTAID];
		if aTA = null then // probably a blockstack, we put 'ZZZZZ' on the front
			continue;
		endif;
		if not aTA.isGridArea() then
			continue;
		endif;
		
		aTA.getRowOrdinalsBySeperation(rowArray , self.rowsSeperation + 1, true, rowSepDict);
	endforeach;
	
	// resort TIs
	idx := 0;
	iterDyna.reset();
	
	while not dynaDict.isEmpty do
		idx := idx + 1;
		
		taIDX := taIDX + 1;
		if taIDX &gt; termAreasRows.size then
			taIDX := 1;
		endif;
		
		tmpTAID := termAreasRows[taIDX];
		tmpTI := null;
		if self.rowsSeperation &gt; 0 then
			// get the next Terminal Area ID plus its row array and next row to work on
			rowArray := allRowArrays[taIDX].IntegerArray;
			currentRow := allCurrentRows[taIDX];
			theRow := 0;
			if currentRow &lt;= rowArray.size and currentRow &gt; 0 then // PAR 15478
				theRow := rowArray[currentRow];
				// get the first TI for this terminal area
				tmpTI := dynaDict.getAtKeyGeq(tmpTAID, theRow, null, null, null, null,  null, null, null,null, null).CM_TrackedItem;
				if tmpTI &lt;&gt; null then
					// If we are looking for the next item in a particular row and there is nothing there, remove the row so that the seperation is better
					tmpTI.getShipPlanningRowColumn(gridRowOrd, gridColOrd, gridStackPos, self.flippedH, self.flippedV);
					if gridRowOrd &lt;&gt; theRow then
						rowArray.removeAt(currentRow);
					endif;
				endif;
			endif;
		else
			theRow := 0;
		endif;
		// get the first TI for this terminal area
		if tmpTI = null then
			tmpTI := dynaDict.getAtKeyGeq(tmpTAID, theRow, null, null, null, null,  null, null, null,null, null).CM_TrackedItem;
		endif;
		
		if tmpTI &lt;&gt; null then
			iterDyna.startAtObject(tmpTI);
			dynaDict.getIteratorKeys(tmpTerm, rowOrd, dischPortCode, contentsStatus, commGrpCode, powerType,tiLength, tiHeight, rowOrd2,  colOrd, gridStackPos, iterDyna);
			if tmpTerm = tmpTAID then
			
				self.changeRowColInDict(tmpTI,idx, colOrd, true);
				iterDyna.startAtObject(tmpTI);
				dynaDict.removeKeyEntry(tmpTerm,  rowOrd, dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight,  rowOrd2, colOrd, gridStackPos, tmpTI);
				
				// they want to do all the ti in this location, so loop until they are all amended
				if self.isDoingTASepByCol then
					while true do : dynaLoop
						iterDyna.next(tmpTI);
						if tmpTI &lt;&gt; null then
							dynaDict.getIteratorKeys(sameTA,  sameRow, dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, sameRow2, sameCol, gridStackPos, iterDyna);
							if sameTA = tmpTerm
							and sameRow = rowOrd
							and sameRow2 = rowOrd2
							and sameCol = colOrd then
								idx := idx + 1;
								self.changeRowColInDict(tmpTI,idx, colOrd, true);
								iterDyna.startAtObject(tmpTI);
								dynaDict.removeKeyEntry(sameTA,  sameRow, dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, sameRow2, sameCol, gridStackPos, tmpTI);
							else
								break dynaLoop;
							endif;
						else
							break dynaLoop;
						endif;
					endwhile;
				endif;
				
				// set the next row for this terminal area
				if self.rowsSeperation &gt; 0 then
					if (theRow = rowOrd) then 
						currentRow := currentRow + 1;
					else
						currentRow := rowArray.indexOf(rowOrd) + 1; //PAR 15597
					endif;
					if currentRow &gt; rowArray.size then
						currentRow := 1;
					endif;
					allCurrentRows[taIDX] := 	currentRow;
				endif;
			endif;
		else // ti = null PAR 15597
			if self.rowsSeperation &gt; 0 then
				currentRow := currentRow + 1;
				if currentRow &gt; rowArray.size then
					currentRow := 1;
				endif;
				allCurrentRows[taIDX] := 	currentRow;
			endif;
		endif;
		
		if idx &gt; 10000 then  // just in case
			break;
		endif;
		
	endwhile;
	
epilog
	delete dynaDict;
	delete iterDyna;
	delete termAreasRows;
	if allRowArrays &lt;&gt; null then
		allRowArrays.purge;
	endif;
	delete allRowArrays;
	delete allCurrentRows;
	delete rowSepDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="sortCargoForParams" id="a89628a1-77c8-492a-b6ff-65024dd3c2e4">
        <source>sortCargoForParams();
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// WHO 		WHY 													WHEN
// ---------------------------------------------------------------------------
//	AKB		PAR 16606/16690/16689						06JUN2008
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
	termAreasRows : StringArray;
	iterAllTIs, iterRowTIs, iterTopStow : Iterator;
	tmpTerm, tmpString, termKey : String;
	tmpR,tmpCOL, tmpC,rowOrd, colOrd,rowKey, idx, idxTo , pos: Integer;
	termArea : CM_TerminalArea;
	rowTIs : CM_TIForShipFullPlanningTopSto;
	tmpRow : CM_GridRow;
	aGC : CM_GridController;
	tmpVoy : CM_Voyage;
	tmpDPort : String;
	topStowFullAccessNonMixed, topStowFullAccessMixedEndSep, getFirst, allSameTopHeight, guiFlippedH,guiFlippedV : Boolean;
//
	dischPortCode,
	commGrpCode,
	taID, taID2, contentsStatus				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos, colChanged, lastRowOrdinal: Integer;
	theTI : CM_TrackedItem;
begin
	if self.isDoingTASepByCol or self.isDoingTASepByInd then
		return;
	endif;
	
	if not self.isDoingEndSep then // no row end seperation so nothing to do
		return;
	endif;
	
	self.hasUserFlipped(guiFlippedH, guiFlippedV);
	create termAreasRows transient;
	create  rowTIs transient;
	iterRowTIs := rowTIs.createIterator();
	iterTopStow := self.allTrackItemsTopStow.createIterator();
	iterAllTIs := self.myIterator;
	iterAllTIs.reset();
	
	// get all rows
	while iterAllTIs.next(tmpTI) do
		self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, tmpTerm,	rowOrd, colOrd, gridStackPos,taID2,iterAllTIs);

		tmpString := tmpTerm &amp; "/" &amp; 	rowOrd.String;
		if not termAreasRows.includes(tmpString) then
			termAreasRows.add(tmpString);
		endif;
	endwhile;
	
	idxTo := termAreasRows.size;
	
	// One row at a time
	foreach tmpString in termAreasRows do
		pos := tmpString.pos("/",1);
		termKey := tmpString[1:pos -1];
		rowKey := tmpString[pos +1:end].Integer;
		termArea := self.myTerminal.allTerminalAreas[termKey];
		if not termArea.isKindOf(CM_GridArea) then
			continue;
		endif;
		// get TIs for row
		rowTIs.clear;
		
		if self.flippedV then
			rowKey := (termArea.CM_GridArea.allGridRows.last.row - (rowKey - 1));
		endif;
		tmpRow := termArea.CM_GridArea.allGridRows[rowKey];

		allSameTopHeight := tmpRow.isAllTopHeightSame(self.topPosition, colChanged);
		
		topStowFullAccessNonMixed := (self.doSelTopHeight and allSameTopHeight and termArea.hasAccessFull());
		topStowFullAccessMixedEndSep := (self.isDoingEndSep and self.doSelTopHeight and not allSameTopHeight and not self.autoLoadPlanAt3Height );
		
		// TOP STOW ONLY all the same in the row
		if topStowFullAccessNonMixed then
			iterTopStow.reset;
			while iterTopStow.next(tmpTI) do
				self.allTrackItemsTopStow.getIteratorKeys(tmpTerm,	rowOrd, colOrd, gridStackPos, iterTopStow);
				if termKey = tmpTerm and rowKey = rowOrd then
					rowTIs.putAtKey(tmpTerm, rowOrd, colOrd, gridStackPos,tmpTI);
				endif;
			endwhile;
		else // ALL TIs IN ROW
			// include all the TIs in the row so that we can detect is we have a different voyage stack at full height.
			foreach aGC in tmpRow.allControllersByColumn discreteLock do
				foreach tmpTI in  aGC.allTrackedItems discreteLock do
					if tmpTI.myPrimaryActualLocation &lt;&gt; aGC then
						continue;
					endif;
					tmpTI.getShipPlanningRowColumn(rowOrd, colOrd, gridStackPos, false, false);
					if  (colOrd &gt;= colChanged) or (not termArea.hasAccessLeft()) then
						gridStackPos := tmpTI.getPositionInStack(REAL_MODE);
					endif;
					rowTIs.putAtKey(termKey, rowOrd, colOrd, gridStackPos,tmpTI);
					
				endforeach;
			endforeach;
				/* PAR 16606 was AKBJUNE2008
			else
				iterAllTIs.reset;
				while iterAllTIs.next(tmpTI) do
					self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, tmpTerm,	rowOrd, colOrd, gridStackPos,taID2,iterAllTIs);
					if self.flippedV then
						rowOrd := (termArea.CM_GridArea.allGridRows.last.row - (rowOrd - 1));
					endif;
					if termKey = tmpTerm and rowKey = rowOrd then
						// if the row has mixed items, by dis port etc, then get the stack position cos the one in the dict is reversed.
						if  (colOrd &gt;= colChanged) or (not termArea.hasAccessLeft()) then
							gridStackPos := tmpTI.getPositionInStack(REAL_MODE);
						endif;
						rowTIs.putAtKey(tmpTerm, rowOrd, colOrd, gridStackPos,tmpTI);
					endif;
				endwhile;
			endif;*/
		endif;
		// this row is the same height right through
		if not termArea.hasAccessLeft() then
			
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if guiFlippedH then // PAR 14653
					tmpTI := rowTIs.last;	// PAR 16689
				else
					tmpTI := rowTIs.first; 	// PAR 16689
				endif;
				iterRowTIs.startAtObject(tmpTI);
				rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
				rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);

				
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		elseif not termArea.hasAccessRight() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if guiFlippedH then // PAR 14653
					tmpTI := rowTIs.last; // PAR 14653
				else
					tmpTI := rowTIs.first; // PAR 14653
				endif;

				iterRowTIs.startAtObject(tmpTI);
				rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
				rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		else // no restriction on access so alternate from either end
			// Top height has a priority and the rowis not mixed so alternate the top height from either end
			if topStowFullAccessNonMixed  then 
				if self.doSelTopHeight then
					// need to alternate from each end
					idx := 0;
					while rowTIs.size &gt; 0 do
						idx := idx + 1;
						tmpTI := rowTIs.first;
						if tmpTI &lt;&gt; null then
							iterRowTIs.startAtObject(tmpTI);
							rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
							rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
							self.changeColumnInDict(tmpTI,idx, false);
						endif;
						
						idx := idx + 1;
						tmpTI := rowTIs.last;
						if tmpTI &lt;&gt; null then
							iterRowTIs.startAtObject(tmpTI);
							rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
							rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
							self.changeColumnInDict(tmpTI,idx, false);
						endif;
					endwhile;
				endif;
			else // Mixed row stacked to top height
			
				// If autoLoadPlanAt3Height is set then they want it to check whether the top height items in the same row are mixed, i.e. diff voy or discharge port.
				// if they are then we do not do normal row end seperation instead we plan the top height  in order from either end. 
				// Then remaining head top to bottom  from the same end as the top height
				if self.autoLoadPlanAt3Height and not allSameTopHeight then
					idx := 0;
					// work from the left until  the voyage or discharge port changes.
					while rowTIs.size &gt; 0 do
						idx := idx + 1;
						if self.flippedH then // PAR 14653
							tmpTI := rowTIs.first; // PAR 16606
						else
							tmpTI := rowTIs.last; // PAR 16606
						endif;
						tmpTI := rowTIs.first; // PAR 16606
						if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; tmpTI.myVoyage then
							break;
						endif;
						if tmpDPort &lt;&gt; null and tmpTI.dischargePort &lt;&gt; tmpDPort then
							break;
						endif;
						
						iterRowTIs.startAtObject(tmpTI);
						rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
						rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
						self.changeColumnInDict(tmpTI,idx, false);
						
						tmpVoy := tmpTI.myVoyage;
						tmpDPort := tmpTI.dischargePort;
					endwhile;
					// now do what is left, if any, from the other end;
					while rowTIs.size &gt; 0 do
						idx := idx + 1;
						if self.flippedH then // PAR 14653
							tmpTI := rowTIs.last; // PAR 14653
						else
							tmpTI := rowTIs.first; // PAR 14653
						endif;
						tmpTI := rowTIs.last; // PAR 14653

						iterRowTIs.startAtObject(tmpTI);
						rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
						rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
						self.changeColumnInDict(tmpTI,idx, false);
					endwhile;
				elseif (self.isDoingEndSep and self.doSelTopHeight and not self.autoLoadPlanAt3Height ) then
				endif;
			endif;
		endif;
	endforeach;
	
	
epilog
	delete termAreasRows;
	delete rowTIs;
	delete iterRowTIs;
	delete iterTopStow;
end;</source>
    </JadeMethod>
    <JadeMethod name="sortCargoForParamsOLD" id="e5f65d3d-dd91-44ef-9c84-d774831b5686">
        <source>sortCargoForParamsOLD();
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	termAreasRows : StringArray;
	iterAllTIs, iterRowTIs, iterTopStow : Iterator;
	tmpTerm, tmpString, termKey : String;
	tmpR,tmpCOL, tmpC,rowOrd, colOrd,rowKey, idx, idxTo , pos: Integer;
	termArea : CM_TerminalArea;
	rowTIs : CM_TIForShipFullPlanningTopSto;
	tmpRow : CM_GridRow;
	tmpVoy : CM_Voyage;
	tmpDPort : String;
	topStowFullAccessNonMixed, topStowFullAccessMixedEndSep, getFirst, allSameTopHeight : Boolean;
//
	dischPortCode,
	commGrpCode,
	taID, taID2, contentsStatus				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos, colChanged, lastRowOrdinal: Integer;
	theTI : CM_TrackedItem;
begin
	if self.isDoingTASepByCol or self.isDoingTASepByInd then
		return;
	endif;
	
	if not self.isDoingEndSep then // no row end seperation so nothing to do
		return;
	endif;

	create termAreasRows transient;
	create  rowTIs transient;
	iterRowTIs := rowTIs.createIterator();
	iterTopStow := self.allTrackItemsTopStow.createIterator();
	iterAllTIs := self.myIterator;
	iterAllTIs.reset();
	
	// get all rows
	while iterAllTIs.next(tmpTI) do
		self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, tmpTerm,	rowOrd, colOrd, gridStackPos,taID2,iterAllTIs);

		tmpString := tmpTerm &amp; "/" &amp; 	rowOrd.String;
		if not termAreasRows.includes(tmpString) then
			termAreasRows.add(tmpString);
		endif;
	endwhile;
	
	idxTo := termAreasRows.size;
	
	// One row at a time
	foreach tmpString in termAreasRows do
		pos := tmpString.pos("/",1);
		termKey := tmpString[1:pos -1];
		rowKey := tmpString[pos +1:end].Integer;
		termArea := self.myTerminal.allTerminalAreas[termKey];
		if not termArea.isKindOf(CM_GridArea) then
			continue;
		endif;
		// get TIs for row
		rowTIs.clear;
		
		if self.flippedV then
			rowKey := (termArea.CM_GridArea.allGridRows.last.row - (rowKey - 1));
		endif;
		tmpRow := termArea.CM_GridArea.allGridRows[rowKey];
//if tmpRow = null then
//	app.msgBox( rowKey.String &amp; " " &amp; termArea.id, "debug", MsgBox_OK_Only);
//endif;		

		allSameTopHeight := tmpRow.isAllTopHeightSame(self.topPosition, colChanged);
		
		topStowFullAccessNonMixed := (self.doSelTopHeight and allSameTopHeight and termArea.hasAccessFull());
		topStowFullAccessMixedEndSep := (self.isDoingEndSep and self.doSelTopHeight and not allSameTopHeight and not self.autoLoadPlanAt3Height );
		
		// TOP STOW ONLY all the same in the row
		if topStowFullAccessNonMixed then
			iterTopStow.reset;
			while iterTopStow.next(tmpTI) do
				self.allTrackItemsTopStow.getIteratorKeys(tmpTerm,	rowOrd, colOrd, gridStackPos, iterTopStow);
				if termKey = tmpTerm and rowKey = rowOrd then
					rowTIs.putAtKey(tmpTerm, rowOrd, colOrd, gridStackPos,tmpTI);
				endif;
			endwhile;
		else // ALL TIs IN ROW
			iterAllTIs.reset;
			while iterAllTIs.next(tmpTI) do
				self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, tmpTerm,	rowOrd, colOrd, gridStackPos,taID2,iterAllTIs);
				if self.flippedV then
					rowOrd := (termArea.CM_GridArea.allGridRows.last.row - (rowOrd - 1));
				endif;
				if termKey = tmpTerm and rowKey = rowOrd then
					// if the row has mixed items, by dis port etc, then get the stack position cos the one in the dict is reversed.
					if  (colOrd &gt;= colChanged) or (not termArea.hasAccessLeft()) then
						gridStackPos := tmpTI.getPositionInStack(REAL_MODE);
					endif;
					rowTIs.putAtKey(tmpTerm, rowOrd, colOrd, gridStackPos,tmpTI);
				endif;
			endwhile;
		
		endif;
		// this row is the same height right through
		if not termArea.hasAccessLeft() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if self.flippedH then // PAR 14653
					tmpTI := rowTIs.first;	// PAR 16689
				else
					tmpTI := rowTIs.last; 	// PAR 16689
				endif;
				iterRowTIs.startAtObject(tmpTI);
				rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
				rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. " &amp; tmpTI.id &amp; " " &amp; tmpTerm &amp;"/" &amp; rowOrd.String &amp; "/" &amp; idx.String);

				
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		elseif not termArea.hasAccessRight() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if self.flippedH then // PAR 14653
					tmpTI := rowTIs.first; // PAR 14653
				else
					tmpTI := rowTIs.last; // PAR 14653
				endif;
				iterRowTIs.startAtObject(tmpTI);
				rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
				rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		else // no restriction on access so alternate from either end
			// Top height has a priority and the rowis not mixed so alternate the top height from either end
			if topStowFullAccessNonMixed  then 
				if self.doSelTopHeight then
					// need to alternate from each end
					idx := 0;
					while rowTIs.size &gt; 0 do
						idx := idx + 1;
						tmpTI := rowTIs.first;
						if tmpTI &lt;&gt; null then
							iterRowTIs.startAtObject(tmpTI);
							rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
							rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
							self.changeColumnInDict(tmpTI,idx, false);
						endif;
						
						idx := idx + 1;
						tmpTI := rowTIs.last;
						if tmpTI &lt;&gt; null then
							iterRowTIs.startAtObject(tmpTI);
							rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
							rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
							self.changeColumnInDict(tmpTI,idx, false);
						endif;
					endwhile;
				endif;
			else // Mixed row stacked to top height
			
				// If autoLoadPlanAt3Height is set then they want it to check whether the top height items in the same row are mixed, i.e. diff voy or discharge port.
				// if they are then we do not do normal row end seperation instead we plan the top height  in order from either end. 
				// Then remaining head top to bottom  from teh same end as teh top height
				if self.autoLoadPlanAt3Height and not allSameTopHeight then
					idx := 0;
					// work from the left until  the voyage or discharge port changes.
					while rowTIs.size &gt; 0 do
						idx := idx + 1;
						if self.flippedH then // PAR 14653
							tmpTI := rowTIs.last; // PAR 14653
						else
							tmpTI := rowTIs.first; // PAR 14653
						endif;
					
						if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; tmpTI.myVoyage then
							break;
						endif;
						if tmpDPort &lt;&gt; null and tmpTI.dischargePort &lt;&gt; tmpDPort then
							break;
						endif;
						
						iterRowTIs.startAtObject(tmpTI);
						rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
						rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
						self.changeColumnInDict(tmpTI,idx, false);
						
						tmpVoy := tmpTI.myVoyage;
						tmpDPort := tmpTI.dischargePort;
					endwhile;
					// now do what is left, if any, from the other end;
					while rowTIs.size &gt; 0 do
						idx := idx + 1;
						if self.flippedH then // PAR 14653
							tmpTI := rowTIs.first; // PAR 14653
						else
							tmpTI := rowTIs.last; // PAR 14653
						endif;
						iterRowTIs.startAtObject(tmpTI);
						rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iterRowTIs);
						rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
						self.changeColumnInDict(tmpTI,idx, false);
					endwhile;
				elseif (self.isDoingEndSep and self.doSelTopHeight and not self.autoLoadPlanAt3Height ) then
				endif;
			endif;
		endif;
	endforeach;
	
	
epilog
	delete termAreasRows;
	delete rowTIs;
	delete iterRowTIs;
	delete iterTopStow;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateQuery" id="ad3f7603-a457-49a8-88ca-9a97f7b83fd9">
        <source>validateQuery() : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mess : String;
begin
	if self.allJobs.isEmpty then
		mess := mess &amp; "Cannot plan, there are no jobs!" &amp; Cr;
	endif;
	
	if self.allTrackedItems.isEmpty then
		mess := mess &amp; "Cannot plan, there is no cargo!" &amp; Cr;
	endif;
	if self.myVoyage = null then
		mess := mess &amp; "Cannot plan, there is no voyage!" &amp; Cr;
	endif;
	
	
	if mess = null then
		return true;
	endif;
	
	app.msgBox(mess,"Problems",MsgBox_Exclamation_Mark_Icon);
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xxxsortPlanFromEnds" id="e0b01cfd-515c-4410-a45d-8c5a45d3f225">
        <source>xxxsortPlanFromEnds();
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	tmpTI : CM_TrackedItem;
	termAreasRows : StringArray;
	iter, iter2 : Iterator;
	tmpTerm, tmpString, termKey : String;
	tmpR,tmpCOL, tmpC,rowOrd, colOrd,rowKey, idx, idxTo , pos: Integer;
	termArea : CM_TerminalArea;
	rowTIs : CM_TIForShipFullPlanningTopSto;
	tmpRow : CM_GridRow;
	tmpVoy : CM_Voyage;
	tmpDPort : String;
	getFirst, allSameTopHeight : Boolean;
//
	dischPortCode,
	commGrpCode,
	taID, taID2, contentsStatus				: String;
	powerType,
	tiLength,
	tiHeight,
	tiWeight,
	tiSelStatus,
	gridRowOrd,
	gridColOrd,
	gridStackPos, colChanged: Integer;
	theTI : CM_TrackedItem;
begin
	if not self.isDoingEndSep then // no row end seperation so nothing to do
		return;
	endif;

	if self.doSelTopHeight then
		return;
	endif;
	
	create termAreasRows transient;
	create  rowTIs transient;
	iter2 := rowTIs.createIterator();
	iter := self.myIterator;
	iter.reset();
	
	// get all rows
	while iter.next(tmpTI) do
		self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, tmpTerm,	rowOrd, colOrd, gridStackPos,taID2,iter);

		tmpString := tmpTerm &amp; "/" &amp; 	rowOrd.String;
		if not termAreasRows.includes(tmpString) then
			termAreasRows.add(tmpString);
		endif;
	endwhile;
	
	idxTo := termAreasRows.size;
	
	// One row at a time
	foreach tmpString in termAreasRows do
		pos := tmpString.pos("/",1);
		termKey := tmpString[1:pos -1];
		rowKey := tmpString[pos +1:end].Integer;
		
		termArea := self.myTerminal.allTerminalAreas[termKey];
		if not termArea.isKindOf(CM_GridArea) then
			continue;
		endif;
		
		// get TIs for row
		rowTIs.clear;
		tmpRow := termArea.CM_GridArea.allGridRows[rowKey];
		allSameTopHeight := tmpRow.isAllTopHeightSame(self.topPosition, colChanged);
		iter.reset;
		while iter.next(tmpTI) do
			self.allTrackedItems.getIteratorKeys(dischPortCode, contentsStatus, commGrpCode, powerType, tiLength, tiHeight, tiWeight, tiSelStatus, tmpTerm,	rowOrd, colOrd, gridStackPos,taID2,self.myIterator);
			if termKey = tmpTerm and rowKey = rowOrd then
				if allSameTopHeight then
				else
					if  colOrd &gt;= colChanged then
						gridStackPos := tmpTI.getPositionInStack(REAL_MODE);
					endif;
				endif;
				rowTIs.putAtKey(tmpTerm, rowOrd, colOrd, gridStackPos,tmpTI);
			endif;
		endwhile;
		
		// this row is the same height right through
		if not termArea.hasAccessLeft() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if self.flippedH then // PAR 14653
					tmpTI := rowTIs.last; // PAR 14653
				else
					tmpTI := rowTIs.first; // PAR 14653
				endif;
				iter2.startAtObject(tmpTI);
				rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iter2);
				rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);

				
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		elseif not termArea.hasAccessRight() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if self.flippedH then // PAR 14653
					tmpTI := rowTIs.first; // PAR 14653
				else
					tmpTI := rowTIs.last; // PAR 14653
				endif;
				iter2.startAtObject(tmpTI);
				rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iter2);
				rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		else // no restriction on access so alternate from either end
			if self.doSelTopHeight and allSameTopHeight then //tmpRow.isAllTopHeightSame(self.topPosition) then
				// need to alternate from each end
				idx := 1;
				getFirst := true;
				while rowTIs.size &gt; 0 do
					if getFirst then
						tmpTI := rowTIs.first;
					else
						tmpTI := rowTIs.last;
					endif;
					tmpTI.getMyRowColOrdinal(tmpR,tmpC);
					
					if tmpCOL &lt;&gt; null and tmpCOL &lt;&gt; tmpC then
						idx := idx + 1;
						getFirst := not getFirst;
						if getFirst then
							tmpTI := rowTIs.first;
						else
							tmpTI := rowTIs.last;
						endif;
						tmpTI.getMyRowColOrdinal(tmpR,tmpC);
					endif;
					tmpCOL := tmpC;
					iter2.startAtObject(tmpTI);
					rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iter2);
					rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
					self.changeColumnInDict(tmpTI,idx, false);
				endwhile;	
			elseif self.autoLoadPlanAt3Height then
				idx := 0;
				// work from the left until  the voyage or discharge port changes.
				while rowTIs.size &gt; 0 do
					idx := idx + 1;
					if self.flippedH then // PAR 14653
						tmpTI := rowTIs.last; // PAR 14653
					else
						tmpTI := rowTIs.first; // PAR 14653
					endif;
				
					if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; tmpTI.myVoyage then
						break;
					endif;
					if tmpDPort &lt;&gt; null and tmpTI.dischargePort &lt;&gt; tmpDPort then
						break;
					endif;
					
					iter2.startAtObject(tmpTI);
					rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iter2);
					rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
					self.changeColumnInDict(tmpTI,idx, false);
					
					tmpVoy := tmpTI.myVoyage;
					tmpDPort := tmpTI.dischargePort;
				endwhile;
				// now do what is left, if any, from the other end;
				while rowTIs.size &gt; 0 do
					idx := idx + 1;
					if self.flippedH then // PAR 14653
						tmpTI := rowTIs.first; // PAR 14653
					else
						tmpTI := rowTIs.last; // PAR 14653
					endif;
					iter2.startAtObject(tmpTI);
					rowTIs.getIteratorKeys(tmpTerm, rowOrd, colOrd, gridStackPos,iter2);
					rowTIs.removeKeyEntry(tmpTerm, rowOrd, colOrd, gridStackPos, tmpTI);
					self.changeColumnInDict(tmpTI,idx, false);
				endwhile;
			endif;
		endif;
	endforeach;
	
	
epilog
	delete termAreasRows;
	delete rowTIs;
	delete iter2;			// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xxxsortTopHeightCargoOLD" id="da4add59-c793-498b-993c-989a887eeaee">
        <source>xxxsortTopHeightCargoOLD();
// ---------------------------------------------------------------------------
// Created:		28 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	tmpTI : CM_TrackedItem;
	termAreasRows : StringArray;
	iter : Iterator;
	tmpTerm, tmpString, termKey : String;
	rowOrd, colOrd,rowKey, stackPos, idx, idxTo , pos: Integer;
	termArea : CM_TerminalArea;
	rowTIs : CM_TIArray;
	tmpRow : CM_GridRow;
	tmpVoy : CM_Voyage;
	tmpDPort : String;
	colChanged : Integer;
begin
	if not self.isDoingEndSep then // no row end seperation so nothing to do
		return;
	endif;
	if not self.doSelTopHeight then
		return;
	endif;

	create termAreasRows transient;
	create  rowTIs transient;
	
	iter := self.allTrackItemsTopStow.createIterator();
	
	// get all rows
	while iter.next(tmpTI) do
		self.allTrackItemsTopStow.getIteratorKeys(tmpTerm,	rowOrd, colOrd,stackPos, iter);
		tmpString := tmpTerm &amp; "/" &amp; 	rowOrd.String;
		
		if not termAreasRows.includes(tmpString) then
			termAreasRows.add(tmpString);
		endif;
	endwhile;
	
	idxTo := termAreasRows.size;
	
	// One row at a time
	foreach tmpString in termAreasRows do
		pos := tmpString.pos("/",1);
		termKey := tmpString[1:pos -1];
		rowKey := tmpString[pos +1:end].Integer;
		
		termArea := self.myTerminal.allTerminalAreas[termKey];
		if not termArea.isKindOf(CM_GridArea) then
			continue;
		endif;
//app.writeStatement("rowKey: " &amp; rowKey.String);
		
		// get TIs for row
		rowTIs.clear;
		tmpRow := termArea.CM_GridArea.allGridRows[rowKey];
		iter.reset;
		while iter.next(tmpTI) do
			self.allTrackItemsTopStow.getIteratorKeys(tmpTerm,	rowOrd, colOrd, stackPos,iter);
			
			if termKey = tmpTerm and rowKey = rowOrd then
//app.writeStatement(tmpTI.id &amp; " ROW: " &amp; rowOrd.String &amp; " COL: " &amp; colOrd.String);			
				rowTIs.add(tmpTI);
			endif;
		endwhile;

		
		// this row is the same height right through
		if not termArea.hasAccessLeft() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if self.flippedH then // PAR 14653
					tmpTI := rowTIs.last; // PAR 14653
				else
					tmpTI := rowTIs.first; // PAR 14653
				endif;
				rowTIs.remove(tmpTI);
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		elseif not termArea.hasAccessRight() then
			idx := 0;
			while rowTIs.size &gt; 0 do
				idx := idx + 1;
				if self.flippedH then // PAR 14653
					tmpTI := rowTIs.first; // PAR 14653
				else
					tmpTI := rowTIs.last; // PAR 14653
				endif;
				rowTIs.remove(tmpTI);
				self.changeColumnInDict(tmpTI,idx, false);
			endwhile;
		else // no restriction on access so alternate from either end
			if tmpRow.isAllTopHeightSame(self.topPosition, colChanged) then
				// need to alternate from each end
				idx := 0;
				while rowTIs.size &gt; 0 do
					idx := idx + 1;
					tmpTI := rowTIs.first;
					rowTIs.remove(tmpTI);
					self.changeColumnInDict(tmpTI,idx, false);
					
					idx := idx + 1;
					tmpTI := rowTIs.last;
					if tmpTI &lt;&gt; null then
						rowTIs.remove(tmpTI);
						self.changeColumnInDict(tmpTI,idx, false);
					endif;
				endwhile;
			// this means that we have amixed row stacked to top height
			// we are only re sorting the top height items
			// If autoLoadPlanAt3Height is set then they want it to check whether the top height items in the same row are mixed, i.e. diff voy or discharge port.
			//if they are then we do not do normal row end seperation instead we plan the top height  in order from either end.
			elseif self.autoLoadPlanAt3Height then
				idx := 0;
				// work from the left until  the voyage or discharge port changes.
				while rowTIs.size &gt; 0 do
					idx := idx + 1;
					if self.flippedH then // PAR 14653
						tmpTI := rowTIs.last; // PAR 14653
					else
						tmpTI := rowTIs.first; // PAR 14653
					endif;
					
					if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; tmpTI.myVoyage then
						break;
					endif;
					if tmpDPort &lt;&gt; null and tmpTI.dischargePort &lt;&gt; tmpDPort then
						break;
					endif;
					
					rowTIs.remove(tmpTI);
					self.changeColumnInDict(tmpTI,idx, false);
					
					tmpVoy := tmpTI.myVoyage;
					tmpDPort := tmpTI.dischargePort;
				endwhile;
	
				// now do what is left, if any, from the other end;
				idx := 0;
				while rowTIs.size &gt; 0 do
					idx := idx + 1;
					if self.flippedH then // PAR 14653
						tmpTI := rowTIs.first; // PAR 14653
					else
						tmpTI := rowTIs.last; // PAR 14653
					endif;
					rowTIs.remove(tmpTI);
					self.changeColumnInDict(tmpTI,idx, false);
				endwhile;
			endif;
		endif;
	endforeach;
	
	
epilog
	delete termAreasRows;
	delete rowTIs;
	delete iter;		// PAR #26678
	
end;</source>
    </JadeMethod>
</Class>
