    <JadeMethod name="doSearch" id="65093ac3-6c1f-4be2-9a44-bad8f89b8969">
        <updating/>
        <source>doSearch()updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------
// 15/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
// 03/06/2020	cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 04 Apr 2022  navhl20     TFS 53352 EUP - Voyage External Reference Field Usability - UI
vars
	now 	  : Date;
	rowIndex  : Integer;
	voyStatus : CM_VoyageStatus;
begin
	self.filterCode		:=	self.txtVoyageCode.text;
	self.filterVessel	:=	self.cmbFilterVessel.listObject.CM_Vessel;
	self.filterGroupCode:=  self.txtVoyageGroupCode.text;				//03/06/2020 cnwma1 Tfs #49400
	self.filterExtCode := self.txtVoyageExtCode.text;					//04 Apr 2022 navhl20 TFS 53352
	self.filterExtRef := self.txtVoyageExtRef.text;						//04 Apr 2022 navhl20 TFS 53352
//	self.filterStatus	:=	-1;
	

	
	//if self.cmbVoyageStatus.text.trimBlanks() &lt;&gt; null then								// TFS 37427
	//	self.filterStatus	:=	app.voyageStatusStringToEnum(self.cmbVoyageStatus.text);	// TFS 37427
	//endif;																				// TFS 37427
	//if self.cmbVoyageStatus.listIndex &gt; 1 then												// TFS 37427
	//	self.filterStatus := self.cmbVoyageStatus.listObject.CM_VoyageStatus.id;			// TFS 37427
	//endif;																					// TFS 37427
	//02 Jun 2010	NDL	TFS 49417
	self.filterStatuses.clear();
	foreach rowIndex in 1 to self.lstStatus.rows do
		if self.lstStatus.accessCell(rowIndex,1).text = "1" then
			voyStatus := self.lstStatus.accessRow(rowIndex).itemObject.CM_VoyageStatus;
			if voyStatus &lt;&gt; null then
				self.filterStatuses.add( voyStatus.id );
			endif;
		endif;
	endforeach;
	
	self.filterArchivedVoyages	:=	self.ckbArchived.value;
	self.filterIsNoDates		:=	self.chkNoDates.value;
	now	:=	app.actualTimeServer.date;
	
	// set in port date range
	self.filterDateInPortFrom	:=	self.dateInPortFrom.getDate();
	self.filterDateInPortTo		:=	self.dateInPortTo.getDate();

	// set arrivals date range
	self.filterDateArrivalsFrom	:=	self.dateArrivalsFrom.getDate();
	self.filterDateArrivalsTo	:=	self.dateArrivalsTo.getDate();

	// set departures date range
	self.filterDateDeparturesFrom	:=	self.dateDepartFrom.getDate();
	self.filterDateDeparturesTo		:=	self.dateDepartTo.getDate();
	
	self.allSelectedTerminals.clear();
	self.lstTerminals.allSelectedObjects.copy(self.allSelectedTerminals);
	
	self.displayVoyages();
	
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.frmSearch.visible	:=	false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
