    <JadeMethod name="validateForUpdate" id="8cf0552c-5624-4b8c-a86a-7008951be52c">
        <source>validateForUpdate(_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwsb1
