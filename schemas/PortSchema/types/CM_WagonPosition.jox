<Class name="CM_WagonPosition" id="25f15a4f-a034-41b2-9521-f87c78118b3d">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="wagonPosition"/>
    <PrimAttribute name="cargoLength" id="512a0e0a-3855-46ca-b150-5b8b205fd1cc">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="deckHeight" id="a3eb4495-7a9c-4522-bca9-e66d63e31403">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxWeight" id="24f56146-3bc9-4a1d-bd22-49c4cbe203bc">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myWagonPositionalRule" id="a71a7f33-6dea-4adf-a0a5-42bbc5d2f8b8">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_WagonPositionalRule"/>
        <access>readonly</access>
        <Inverse name="CM_WagonPositionalRule::allWagonPositions"/>
    </ExplicitInverseRef>
    <PrimAttribute name="position" id="749cad69-ab7a-4fd1-b2d3-0f4af6d0470b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="extendsBeyondPosition" id="9fc6100e-9f99-4267-90a8-61b37723bdb8">
        <source>extendsBeyondPosition():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwndl1	Initial creation

*/

vars

	previousPosition : CM_WagonPosition;
	previousExtend : Integer;
	
begin

	if cargoLength &gt; 20 then
		// cargo is longer than this 20 foot position
		return cargoLength - 20;
	elseif cargoLength &gt; 0 then
		// some value between 0 and 20, so it doesn't extend beyond this position
		return 0;
	elseif position &gt; 1 then
		// check the previous position
		previousPosition := myWagonPositionalRule.allWagonPositions.getAtKey( position - 1 );
		if previousPosition &lt;&gt; null then
			previousExtend := previousPosition.extendsBeyondPosition;
			if previousExtend &gt; 20 then
				// previous positions cargo over extension is longer than my 20 foot position
				return ( previousExtend - 20 );
			endif;
		endif;	
	endif;
	
	return 0;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxCargoHeight" id="8d5c3db8-cac5-4156-8d04-a1b9efeafe92">
        <source>getMaxCargoHeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwndl1	Initial creation

*/

vars

	maxWagonHeight : Decimal [12,2];
	maxCargoHeight : Decimal [12,2];
	
begin

	maxWagonHeight := myWagonPositionalRule.getMaxWagonHeight;
	maxCargoHeight := maxWagonHeight - deckHeight;
	
	return maxCargoHeight;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isEmpty" id="82d8b3d3-e031-4367-969e-f5de8d734050">
        <source>isEmpty():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwndl1	Initial creation

*/

vars

	previousPosition : CM_WagonPosition;
	
begin

	if cargoLength &gt; 0 then
		return false;
	endif;
	
	if position &gt; 1 then
		previousPosition := myWagonPositionalRule.allWagonPositions.getAtKey( position - 1 );
		if previousPosition &lt;&gt; null then
			if previousPosition.extendsBeyondPosition &gt; 0 then
				return false;
			endif;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="baf361c8-d668-4ba4-ba1a-3341124f707f">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
01 July 2009	cnwndl1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	tmpPosi : CM_WagonPosition;
	completedOK		: Boolean;
begin
	tmpPosi := inheritMethod();
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpPosi;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpPosi;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="506a3aed-7547-4888-8957-a6bacf147936">
        <updating/>
        <source>setForUpdate( pxyWagonPosition : CM_WagonPosition ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars

begin

	self.cargoLength := pxyWagonPosition.cargoLength;
	self.maxWeight := pxyWagonPosition.maxWeight;
	self.position := pxyWagonPosition.position;
	if self.cargoLength &gt; 0 or self.maxWeight &gt; 0 then
		self.deckHeight := pxyWagonPosition.deckHeight;
	else
		self.deckHeight := 0;
	endif;
	
epilog

end;</source>
        <Parameter name="pxyWagonPosition" type="CM_WagonPosition"/>
    </JadeMethod>
    <JadeMethod name="setMyWagonPositionalRule" id="0383eee9-62ef-4440-a94e-c2c590de96b3">
        <updating/>
        <source>setMyWagonPositionalRule( _myWagonPositionalRule : CM_WagonPositionalRule ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars

begin
	self.myWagonPositionalRule := _myWagonPositionalRule;
epilog

end;</source>
        <Parameter name="_myWagonPositionalRule" type="CM_WagonPositionalRule"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="08881a4a-4da8-4f57-928f-7fd302ee9c2d">
        <updating/>
        <source>setProxy(	_cargoLength : Integer;
			_deckHeight : Decimal;
			_maxWeight : Decimal;
			_position : Integer;
			_myWagonPositionalRule : CM_WagonPositionalRule
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

begin

	self.cargoLength := _cargoLength;
	self.deckHeight := _deckHeight;
	self.maxWeight := _maxWeight;
	self.position := _position;
	self.setMyWagonPositionalRule( _myWagonPositionalRule );
			
epilog

end;</source>
        <Parameter name="_cargoLength" type="Integer"/>
        <Parameter name="_deckHeight" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_myWagonPositionalRule" type="CM_WagonPositionalRule"/>
    </JadeMethod>
