    <JadeMethod name="cmbNewOperator_click" id="dbf50b54-6f3b-40be-a878-e069f42032a4">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbNewOperator_click(combobox: ComboBox input) updating;
/*
Purpose:			

Date		Who		Reason
20 July 2023	navab1	  CR 58239 TASK 58241 
*/

vars
	newOperator : CM_Operator;												//navra1 - TFS 64874 - 14th Aug 2024
	debtorInvoiceContracts : CM_InvContractByBankIdDict;					//navra1 - TFS 64874 - 14th Aug 2024
	invoiceContract : CM_InvoiceContract;									//navra1 - TFS 64874 - 14th Aug 2024
	invoiceContractExists : Boolean;										//navra1 - TFS 64874 - 14th Aug 2024
begin
	self.getFreeStorageForNewOperator();
	self.enableForCargoReview(); // ### TFS BUG 64115 13MAY2024 NAVAB1
	
	//navra1 - TFS 64874 - 14th Aug 2024 - start
	self.cmbInvoiceContract.clear();
	newOperator := self.cmbNewOperator.listObject.CM_Operator;
	if newOperator &lt;&gt; null and newOperator.debtor &lt;&gt; null then
		debtorInvoiceContracts  := newOperator.debtor.allInvoiceContracts;
		foreach invoiceContract in debtorInvoiceContracts where invoiceContract.myTerminal.code = self.myTerminal.code do				//navra1 - DEFECT 65798 - 29th Aug 2024
			if invoiceContract.active = true then
				self.cmbInvoiceContract.addItemObject(invoiceContract.contractId, invoiceContract);
				invoiceContractExists := true;
			endif;
		endforeach;
	endif;
	if not invoiceContractExists then		
		//app.msgBox("No active invoice contracts exist for the operator's debtor!", "WARNING", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.cmbInvoiceContract.listIndex := -1;
	else
		self.cmbInvoiceContract.listIndex := 1;
	endif;
	//navra1 - TFS 64874 - 14th Aug 2024 - end
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="9744dd55-efa1-4c5c-9567-b0f271b8240c">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars

begin
	self.permissionView := PmInvOwnershipChangeMaintView ;
	self.permissionMaint := PmInvOwnershipChangeMaintMaint;
epilog

end;</source>
