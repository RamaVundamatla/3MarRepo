    <JadeMethod name="contractShipTermCreate" id="f0693c99-7051-4831-bc92-ebd4577055ef">
        <source>contractShipTermCreate(_realInvoiceContractShipTerm:CM_InvoiceContractShipTerm output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2022 navtnr20	TFS CR 55622 Task 55691: Jade - Shipping Terms Unit Tests

*/

vars
