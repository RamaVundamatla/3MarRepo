    <JadeMethod name="setForCreate" id="92228caf-a279-46ec-a6a5-3051cef099a7">
        <updating/>
        <source>setForCreate(_pxyVesselRampPositionType : CM_VesselRampPositionType) updating;
/*
Date		    Who			Reason
13 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.myRoot := _pxyVesselRampPositionType.myRoot;
	
	_pxyVesselRampPositionType.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_pxyVesselRampPositionType);	
epilog

end;</source>
        <Parameter name="_pxyVesselRampPositionType" type="CM_VesselRampPositionType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="202cf93d-5ea1-4af5-ba3d-f89772e5b5e8">
        <updating/>
        <source>setForUpdate(_pxyVesselRampPositionType : CM_VesselRampPositionType) updating;
/*
Date		    Who			Reason
13 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.code := _pxyVesselRampPositionType.code;
	self.description := _pxyVesselRampPositionType.description;
	self.remarks := _pxyVesselRampPositionType.remarks;	
	self.isAvailableForEntry := _pxyVesselRampPositionType.isAvailableForEntry;
epilog

end;</source>
        <Parameter name="_pxyVesselRampPositionType" type="CM_VesselRampPositionType"/>
    </JadeMethod>
    <JadeMethod name="setProxyForRampPositionType" id="9ff56d75-6cd2-4e29-b5d5-c6f18db906a2">
        <updating/>
        <source>setProxyForRampPositionType(_code,_description,_remarks : String; _isAvailableForEntry : Boolean; _root : CM_Root) updating;
/*
Date		    Who			Reason
18 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.code := _code;
	self.description := _description;
	self.isAvailableForEntry := _isAvailableForEntry;
	self.myRoot := _root;
	self.remarks := _remarks;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_isAvailableForEntry" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="8af0c209-2cea-4f98-b0a9-4492775b1905">
        <source>validateForCreate();
/*
Date		    Who			Reason
13 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if self.code = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	

	 if app.myRoot.allVesselRampPositionTypes[self.code] &lt;&gt; null then
		 app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	 endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a1bb5aa4-80d5-41a4-bf80-55d7784318c6">
        <source>validateForDelete();
/*
Date		    Who			Reason
13 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	
begin
		
	if not self.allRamps.isEmpty then
		app.raiseCMException1(Ramp_position_type_not_delete,self.description,null, self);
	endif;
	
end;</source>
    </JadeMethod>
