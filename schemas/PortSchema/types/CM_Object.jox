    <JadeMethod name="importXML" id="539cab29-8c5d-4201-aac2-d498562c57b0">
        <updating/>
        <source>importXML(_classXMLname, _classBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	attributeBlock,
	referencesBlock,
	collectionsBlock,
	subScript,
	attributeName: String;
	attributeValue: Any;
	prop: Property;
	propColl: PropertyNDict;
	tempStrArray: StringArray;
	tempIntArray: IntegerArray;
	tempTimeArray: TimeArray;
	tempDecimalArray: DecimalArray;
	tempBooleanArray: BooleanArray;
	tempBinaryArray: BinaryArray;
	strLength, pos: Integer;
	decimal: Decimal[5,2];
begin
	attributeBlock := _classBlock.cnEcGetTagValueOfName(_classXMLname &amp; 'Attributes');		
	referencesBlock := _classBlock.cnEcGetTagValueOfName(_classXMLname &amp; 'References');
	collectionsBlock := _classBlock.cnEcGetTagValueOfName(_classXMLname &amp; 'Collections');
			
	if attributeBlock = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attribute block is null');
		return;
	endif;
	
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	
	foreach prop in propColl do
		if (not prop.isKindOf(Attribute)) or
		   (not self.shouldAuditProperty(self.class, prop)) or
		   (prop.virtual) then
			continue;
		endif;
		
		attributeName := self.importXMLAttrName(prop.name);
		attributeValue := attributeBlock.cnEcGetTagValueOfName(attributeName);

		if (not self.importMeXMLValidateProperty(attributeName, attributeValue)) then
			continue;
		endif;
	
		if prop.type = StringArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempStrArray := self.getPropertyValue(prop.name).StringArray;
			while pos &lt;= strLength do
				tempStrArray.add(attributeValue.String.getNextToken(pos));
			endwhile;
		elseif prop.type = IntegerArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempIntArray := self.getPropertyValue(prop.name).IntegerArray;
			while pos &lt;= strLength do
				tempIntArray.add(attributeValue.String.getNextToken(pos).Integer);
			endwhile;
		elseif prop.type = TimeArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempTimeArray := self.getPropertyValue(prop.name).TimeArray;
			while pos &lt;= strLength do
				tempTimeArray.add(attributeValue.String.getNextToken(pos).Time);
			endwhile;
		elseif prop.type = DecimalArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempDecimalArray := self.getPropertyValue(prop.name).DecimalArray;
			while pos &lt;= strLength do
				tempDecimalArray.add(attributeValue.String.getNextToken(pos).Decimal);
			endwhile;
		elseif prop.type = BooleanArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempBooleanArray := self.getPropertyValue(prop.name).BooleanArray;
			while pos &lt;= strLength do
				tempBooleanArray.add(attributeValue.String.getNextToken(pos).Boolean);
			endwhile;
		elseif prop.type = BinaryArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempBinaryArray := self.getPropertyValue(prop.name).BinaryArray;
			while pos &lt;= strLength do
				tempBinaryArray.add(attributeValue.String.getNextToken(pos).Binary);
			endwhile;
		elseif prop.type = Boolean then
			self.setPropertyValue(prop.name, attributeValue.Boolean);
		elseif prop.type = Character then
			self.setPropertyValue(prop.name, attributeValue.Character);
		elseif prop.type = Date then
			self.setPropertyValue(prop.name, attributeValue.Date);
		elseif prop.type = Decimal then
			self.setPropertyValue(prop.name, attributeValue.Decimal);
		elseif prop.type = Integer then
			self.setPropertyValue(prop.name, attributeValue.Integer);
		elseif prop.type = Point then
			self.setPropertyValue(prop.name, attributeValue.Point);
		elseif prop.type = Real then
			self.setPropertyValue(prop.name, attributeValue.Real);
		elseif prop.type = Time then
			self.setPropertyValue(prop.name, attributeValue.Time);
		elseif prop.type = TimeStamp then
			self.setPropertyValue(prop.name, attributeValue.TimeStamp);
		elseif prop.type = Binary then
			self.setPropertyValue(prop.name, attributeValue.Binary);
		else
			self.setPropertyValue(prop.name, attributeValue);
		endif;		
	endforeach;

	self.importXMLFixupPre;
		
	if referencesBlock &lt;&gt; null then
		self.importMyReferencesXML(referencesBlock);
	endif;
	
	if collectionsBlock &lt;&gt; null then
		self.importMyCollectionsXML(collectionsBlock);
	endif;

	self.importXMLFixupPost;
epilog
	delete propColl;
end;</source>
        <Parameter name="_classXMLname" type="String"/>
        <Parameter name="_classBlock" type="String"/>
    </JadeMethod>
