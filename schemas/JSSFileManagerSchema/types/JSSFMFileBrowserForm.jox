//
// Returns:		True if the OS is Unix, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.getUnixFlag();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
