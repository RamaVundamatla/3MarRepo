    <JadeMethod name="tblNNData_click" id="12a8a4b1-b46a-49b4-a24c-79de71d7cb52">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNNData_click(table: Table input) updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row : Integer;
begin
	foreach row in 2 to self.tblNNData.rows do
		if row = self.tblNNData.row then
			continue;
		endif;
		self.tblNNData.accessCell(row, 1).text := '0';
	endforeach;
end;</source>
