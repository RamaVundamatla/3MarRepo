    <JadeMethod name="comboBoxDamageSeverity" id="0101d579-7913-4364-8aac-dd1390228d9d">
        <source>comboBoxDamageSeverity(_comboBox : ComboBox input);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 July 2009
//
// Implemented version: 7.7.3
//28 June 2022 navak20 TFS 53862 EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	defaultSeverity, severity : CM_DamageSeverity;
begin	
	foreach severity in self.myTerminal.allDamageSeverities do
		if not severity.isNotAvalableForEntry then
			 // ### TFS 55240 28OCT2022 NAVAB1_comboBox.itemObject[_comboBox.addItem(severity.level.String &amp; Tab &amp;  severity.code)] := severity;
			_comboBox.itemObject[_comboBox.addItem(severity.code &amp; Tab &amp;  severity.description)] := severity;
		endif;
	endforeach;
	
	 // ### TFS BUG 58862 27JUN2023 NAVAB1
	defaultSeverity  := self.myTerminal.getConfig(DamageSeverityDefault).CM_DamageSeverity;
	if defaultSeverity &lt;&gt; null then
		if _comboBox.findObject(defaultSeverity) &gt; 0 then
		_comboBox.listObject := defaultSeverity;
		endif;
	endif;
	
epilog
end;</source>
        <Parameter name="_comboBox" type="ComboBox" usage="input"/>
    </JadeMethod>
