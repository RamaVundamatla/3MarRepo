    <JadeMethod name="activate" id="f9764956-3720-4167-b41e-7f6f0d758b09">
        <updating/>
        <source>activate() updating;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.status &lt;&gt; EventRequestCargoDeleted then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid status for activate');
	endif;
	
	self.status	:= EventRequestPending;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="46e0c1a9-47b2-4155-8a39-f21c4cede10e">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.myTrackedItem &lt;&gt; null then
		if (not self.myTrackedItem.canUserAccessSelf(_user, _failedDAC, _passport)) then
			return false;
		endif;
	endif;
	return inheritMethod(_user, _failedDAC, _passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="5222c030-42fc-4259-852b-9080fcf9f6de">
        <source>getDisplayDetails(_short: Boolean): String;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.cargoId;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2529ade7-77b3-41f2-8e93-500bd70fe9b8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_MyCargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsClearStop then
		return app.getYesNo(self.isClear);
	elseif _attrName = ETRow_MyTrackedItem then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.id;
		else
			return null;
		endif;		
	elseif _attrName = ETRow_UpdateType then
		return self.typeString;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
