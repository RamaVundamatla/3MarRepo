    <JadeMethod name="getBerthCodeForDateTime" id="42b81b89-541d-4415-be5a-c630845735af">
        <source>getBerthCodeForDateTime(_dateTime : TimeStamp) : String;
/* ---------------------------------------------------------------------------
Usage:		THIS IS USED IN CUSTOMER REPORTS.  DO NOT RENAME OR REMOVE

Created:     13 July 2009 by cnwrs2

Purpose:     CCMS-JMH-1022.  See HMS_VoyageData::getBerthForDateTime for more details
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	hmsBerth : HMS_Berth;
	newTime : TimeStamp;
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	hmsBerth := self.myHMSVoyageData.getBerthForDateTime(_dateTime);
	
	if hmsBerth = null then
		return null;
	else
		return hmsBerth.code;
	endif;
epilog

end;</source>
