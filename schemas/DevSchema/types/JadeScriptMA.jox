    <JadeMethod name="machineHistory" id="f1e3b876-4765-48f9-a497-2d2db5d20a27">
        <source>machineHistory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2025		navma1	Initial creation

*/

vars
	term 		: CM_Terminal;
	machine		: CM_Machine;
	history	    : CM_MachineHistory;
	lFile   	: File;

begin
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\machineHistory.01.csv";
    lFile.open;
	lFile.writeLine(
					"Terminal"      		 &amp; "," &amp;
					"Id" 			 		 &amp; "," &amp;
					"Description" 			 &amp; "," &amp;
					"Machine Type"     		 &amp; "," &amp;
					"History"	   );
	
	foreach term in app.myRoot.allTerminals discreteLock do
		
		foreach machine in term.machines discreteLock do
			
			lFile.writeLine(term.code												&amp; "," &amp;
						machine.id		 			 								&amp; "," &amp;
						machine.description											&amp; "," &amp;
						machine.machineTypeString								    &amp; "," &amp;
						machine.history.size.String   				);
			
		endforeach;
	
	endforeach;
	lFile.close;
epilog
	delete lFile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="mawodtl" id="8eb6a029-050f-4e11-8d9b-f13a44240bbd">
        <source>mawodtl();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2022		navma1	Initial creation

*/

