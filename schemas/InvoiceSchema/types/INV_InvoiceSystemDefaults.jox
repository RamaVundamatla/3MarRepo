    <JadeMethod name="btnProfConfig_click" id="1e9f6a68-772b-437d-bc1f-30f528da8aed">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnProfConfig_click(btn: Button input) updating;
// TEMPORARY prototyping
vars
	configForm	: INV_CashModuleConfigForm;
begin
	configForm := app.loadForm(INV_CashModuleConfigForm, INV_Assistant, false, false, false, self.myTerminal, null).INV_CashModuleConfigForm;
	if configForm = null then
		return;
	endif;
	configForm.myTerminal := self.myTerminal;
	configForm.setPropertyValue("proformaConfigurationOnly", true);
	configForm.show;

end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
