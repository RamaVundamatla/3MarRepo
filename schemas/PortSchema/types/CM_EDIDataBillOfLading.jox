    <JadeMethod name="canUserSet" id="6bd413ec-03b3-42a4-b1f9-bb8f5d52abdc">
        <source>canUserSet(_propName: String): Boolean;
//
// 05 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//
vars

begin
	if _propName = CM_EDIDataBillOfLading::ediFileVoyageCode.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="d180a03e-dfe9-4db2-801c-3efd13a29825">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars

begin
	//since the receipt transport mode would be TI_TRANSMODE_SHIP_STR for a bill of lading edi file
	if _receiptTransportMode.toUpper().compareEql(TI_TRANSMODE_SHIP_STR.toUpper(), true, false, null) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActionString" id="bbc660ec-4bf7-4dea-a5cf-058b2e08e384">
        <source>getActionString() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		23 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars

begin
	if self.action = EDIX12AmendmentAdd then
		return app.getErrorString(AddUpper);
	elseif self.action = EDIX12AmendmentDelete then
		return app.getErrorString(Delete2);
	endif;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2b231d21-aa1f-407e-ac2d-177ad63a3d1f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 27 February 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
// 22/04/2010	cnwcs5	ccms sfw 1118 / par 23580
vars

begin
	if _attrName = ETRow_VoyageCodeSystem then
		return self.voyageCode;
	elseif _attrName = ETRow_EdiFileVoyage then
		return self.ediFileVoyageCode;
	elseif _attrName = ETRow_Bol then
		return self.billOfLading;
	elseif _attrName = ETRow_DischargePort then
		return self.portCode;
	elseif _attrName = ETRow_DestinationPort then
		return null;
	elseif _attrName = ETRow_Bol then
		return self.billOfLading;
	elseif _attrName = ETRow_Vessel then
		return self.vesselName;
	elseif _attrName = ETRow_FileAction then
		return self.getActionString();
// start 22/04/2010 cnwcs5 ccms sfw 1118/par 23580
	elseif _attrName = ETRow_VoyageCode then
		return self.voyageCode;
	elseif _attrName = ETRow_VesselName then
		return self.vesselName;
// end 22/04/2010 cnwcs5 ccms sfw 1118/par 23580
	endif;
		
	return inheritMethod(_attrName, _short);

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
