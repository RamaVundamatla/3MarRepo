    <JadeMethod name="getTaxAmountProformaForVoyage" id="36909fc2-64f8-4ff0-b82b-086367e0f12a">
        <source>getTaxAmountProformaForVoyage(_workOrder : CM_WorkOrder) : Real;
//
// Purpose:			Used in Cash Payment calculation so we can get a voyage for this charge to check tax-free voyage settings
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/11/2018	jlgdap1		Initial creation TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
// 13/10/2022   navmv20     ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
// 18 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
vars
	effectiveDate	: TimeStamp;
	taxCode 		: CM_TaxCode;
	taxRateAmount,
	taxAmount 		: Real;
	taxRateObject 	: CM_TaxRate;
	theInvoice 		: CM_Invoice;
	theBank 		: CM_Bank;
	terminal 		: CM_Terminal;
	blurb 			: String;

begin
	//epr TFS 44550 refactored as part of
	if self.isTaxExempt(_workOrder) then
		return 0;
	endif;
	
	theBank := self.invoiceLine.bank;
	theInvoice := self.invoiceLine.invoice;
	
	
	if theBank = null and self.service &lt;&gt; null then
		theBank := self.service.bank;
	endif;
	
	if theBank.terminal.getConfig(InvoiceMultiTaxRates).Boolean then
		if self.service &lt;&gt; null then
			// START - 13/10/2022 navmv20 TFS 55005
			//taxCode := self.service.myTaxCode; 
			if self.myOverrideTaxCode &lt;&gt; null then 
				taxCode := self.myOverrideTaxCode; 
			else
				taxCode := self.service.myTaxCode;
			endif; 
			// END - 13/10/2022 navmv20 TFS 55005
		endif;
		if taxCode &lt;&gt; null then
			if theInvoice = null or  not app.isValidObject(theInvoice) then
				effectiveDate.setDate(self.invoiceLine.getChargeDate());
			else
				effectiveDate := theInvoice.toDT;
				if not effectiveDate.isValid() then
					effectiveDate := theInvoice.postedDT;
				endif;
				if not effectiveDate.isValid() then
					effectiveDate := theInvoice.createdTime;
				endif;
			endif;
			taxRateObject := taxCode.getTimeRate(effectiveDate);
			if taxRateObject &lt;&gt; null then
				taxRateAmount := taxRateObject.rate;
			else
				taxRateAmount := 0;
			endif;
		endif;
	else
		taxRateAmount := theBank.taxPercentageRate;
	endif;
	
	taxAmount := (self.total * (taxRateAmount /100));

	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null and terminal.getConfig(InvoiceRoundDownLineTax).Boolean then		// 20/8/18 MAP TFS40270
		if taxAmount &lt; 999999999 then // ### JIRA 35966 08DEC2025 NAVAB1
			blurb := method.qualifiedName &amp; Space &amp; self.invoiceLine.sequenceNum.String &amp; " Tax rounded from " &amp; taxAmount.String;
			taxAmount := taxAmount.Integer;
			app.invLog(blurb &amp; " to " &amp; taxAmount.String, LogINFO.String);
		else
			app.invLog(method.qualifiedName &amp; Space &amp; self.invoiceLine.sequenceNum.String &amp; " NOT ROUND DOWN is TOO LARGE (" &amp; taxAmount.String &amp; ")", LogINFO.String); // ### JIRA 35966 08DEC2025 NAVAB1

		endif;
		
	endif;

	return taxAmount;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTaxCode" id="a9379984-713c-4ed7-af96-8fb4c05b5e2c">
        <source>getTaxCode(_description: Boolean) : String;
/*
Purpose:			
Date		Who		Reason
05 August 2015	cnwab1	Initial creation
3/11/17		MAP		Description option
13/10/2022 navmv20  ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
*/

vars
	taxCode : String;
	theBank : CM_Bank;
begin
	theBank := self.invoiceLine.bank;
	
	if theBank = null and self.service &lt;&gt; null then
		theBank := self.service.bank;
	endif;
	
	if self.service &lt;&gt; null then
		//START - 13/10/2022 navmv20 TFS 55005
		//taxCode := self.service.getTaxCode(_description);
		if self.myOverrideTaxCode &lt;&gt; null then 
			taxCode := self.myOverrideTaxCode.getDescription(_description);
		else 
			taxCode := self.service.getTaxCode(_description);
		endif; 
		//START - 13/10/2022 navmv20 TFS 55005
	else
		taxCode := theBank.parentCompany.taxNarration;
	endif;
	
	
	return taxCode;
end;</source>
        <Parameter name="_description" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxCodeObject" id="fc8d0bff-828a-461d-9aaa-3c67002a35aa">
        <source>getTaxCodeObject():CM_TaxCode;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	taxCode : CM_TaxCode;
begin
	
	if self.service &lt;&gt; null then
		if self.myOverrideTaxCode &lt;&gt; null then 
			taxCode := self.myOverrideTaxCode;
		else
			taxCode := self.service.myTaxCode;
		endif;
	endif;
	
	return taxCode;
epilog

end;</source>
        <ReturnType type="CM_TaxCode"/>
    </JadeMethod>
    <JadeMethod name="getTaxDescription" id="6fcb1b0a-70f9-480e-836e-a1fc66c1150f">
        <source>getTaxDescription(_description : Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export

*/
