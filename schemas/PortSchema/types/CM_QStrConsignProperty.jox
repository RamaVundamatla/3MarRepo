    <JadeMethod name="create" id="7940e491-593e-418d-9107-8c1b3c19a658">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2015	cnwma1	Initial creation

*/

vars
	consign 		: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create consign as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(consign);

	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="06fe9d96-cb7f-40d5-b583-2746d02b3255">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
// ---------------------------------------------------------------------------
// Created:     16 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbConsignee';
	endif;


end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="9f49660f-9668-48ca-a29b-d4dc339ab9ea">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
