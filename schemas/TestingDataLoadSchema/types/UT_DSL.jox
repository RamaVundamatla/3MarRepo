    <JadeMethod name="addCannonAtLocation" id="82da295c-29b2-4711-8d9e-e276af000005">
        <source>addCannonAtLocation(_id: String; _operator: CM_Operator; _location: Any): CM_TrackedItem;
//30 May 2008	cnwdw1	
// Create a Cannon and put it at a specified location
// 18/02/2016	cnwmh5	Change to return ti so can check for errors before returning, add test created by
vars
	cargoType: CM_CargoType;
	location: CM_LocationsController;
	ti : CM_TrackedItem;
begin
	location := getLocationsController(_location);
	cargoType := self.getCargoType("CANNON");
	self.deleteCargo(_id, cargoType);
	ti := location.createCargoAtLocation(cargoType, cargoType.mySystemProductType, _operator, _id);
	self.assertNoTrxErrorsOrWarnings();
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);					// 15/09/2015 cnwmh5
	commitTransaction;
	return ti;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="Any"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoAtLocation" id="50256cd3-7deb-4bcb-91f2-79800db69511">
        <source>addCargoAtLocation(_id: String; _cargoType: Any; _operator: CM_Operator; _location: CM_LocationsController): CM_TrackedItem;
//30 May 2008	cnwdw1	
// Create Cargo and put it at a specified location
vars
	cargo: CM_Cargo;
	product: CM_Product;
	cargoType: CM_CargoType;
	ti : CM_TrackedItem;
begin
	if _cargoType.isKindOf(CM_Product) then
		product := _cargoType.CM_Product;
		cargoType := product.myCargoType;
	elseif _cargoType.isKindOf(CM_CargoType) then
		product := _cargoType.CM_CargoType.mySystemProductType;
		cargoType := _cargoType.CM_CargoType;
	elseif _cargoType.isKindOf(String) then
		cargoType := self.getCargoType(_cargoType.String);
		product := cargoType.mySystemProductType;
	endif;	
	
	ti := _location.createNewCargoForLocation(cargoType, product, _id, _operator);
	
	beginTransaction;
		if self.opts.includesKey("CargoComodity") then
			ti.setCommodity(opts.str("CargoComodity"));
		endif;
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);					// 15/09/2015 cnwmh5
	commitTransaction;	
	self.assertNoTrxErrorsOrWarnings();	
	
	return ti;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoAtLocationDetailed" id="24834bf8-21ae-4f38-8172-d30ff360821f">
        <source>addCargoAtLocationDetailed(_id: String; 
							_cargoType : CM_CargoType;
							_product: CM_Product; _location: CM_LocationsController;_dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator): CM_Cargo;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

// Create Cargo and put it at a specified location
vars
	cargo: CM_Cargo;
	qty : Integer;
begin

	qty := 1;
	
	if self.opts.includesKey("TotalQuantity") then
		qty := self.opts.int("TotalQuantity");
	endif;
	
	if qty &lt;= 0 then
		qty := 1;
	endif;

	cargo := _location.createNewCargoForLCDetailed(_cargoType,_product, _id, _dPort, _imex, _voyage, _op, qty, null).CM_Cargo;
	self.assertNoTrxErrorsOrWarnings();										// 18/02/2016 cwmh5
	beginTransaction;														// 10/09/2015 cnwmh5
	cargo.setRemarks(self.createdByUnitTest(cargo.remarks), false);
	commitTransaction;
	return cargo;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_dPort" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_op" type="CM_Operator"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="addCargoBreakBulkAtLocation" id="82d746b7-10ec-4eae-a33b-a7619bf812eb">
        <source>addCargoBreakBulkAtLocation(_id: String; _cargoType : CM_CargoType;	_quantity: Integer; _location: CM_LocationsController;
		_dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator): CM_Cargo;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

// Create Cargo and put it at a specified location
vars
	cargo: CM_Cargo;
begin
	cargo := _location.createNewCargoForLCDetailed(_cargoType,null, _id, _dPort, _imex, _voyage, _op, 1, null).CM_Cargo;
	self.assertNoTrxErrorsOrWarnings();													// 18/02/2016 cnwmh5
	beginTransaction;
	cargo.setTotalQuantity(_quantity);
	cargo.setRemarks(self.createdByUnitTest(cargo.remarks), false);						// 09/09/2015 cnwmh5
	commitTransaction;
	return cargo;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_dPort" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_op" type="CM_Operator"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="addCargoBulkAtLocation" id="fb11a5d6-8e2a-4d09-91d9-3fd2d7d8f269">
        <source>addCargoBulkAtLocation(_id: String; _cargoType : CM_CargoType;	_weight: Integer; _location: CM_LocationsController;
		_dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator): CM_Cargo;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

// Create Cargo and put it at a specified location
vars
	cargo: CM_Cargo;
begin
	cargo := _location.createNewCargoForLCDetailed(_cargoType,null, _id, _dPort, _imex, _voyage, _op, 1, null).CM_Cargo;
	self.assertNoTrxErrorsOrWarnings();											// 18/02/2016 cnwmh5
	beginTransaction;
		cargo.setTotalWeightWithoutTrans(_weight);
	commitTransaction;
	return cargo;
epilog
	abortTransaction;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_dPort" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_op" type="CM_Operator"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="addCargoCheck" id="cf454692-3e6d-40c7-8a95-668102df4cfd">
        <source>addCargoCheck(_context : Integer; _isNotAvailable : Boolean; _cargoCheckItems : CM_CargoCheckItemSet) : CM_CargoCheck;

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	cargoCheck					: CM_CargoCheck;
	pxyCargoCheck				: CM_CargoCheck;

begin

	self.deleteCargoCheck(_context);

	create pxyCargoCheck transient;
	pxyCargoCheck.setProxy(_context, _isNotAvailable, _cargoCheckItems, app.myPassport);

	app.myTrxCA.trxCreateCargoCheck(pxyCargoCheck, cargoCheck, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return cargoCheck;

epilog

	delete pxyCargoCheck;

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_isNotAvailable" type="Boolean"/>
        <Parameter name="_cargoCheckItems" type="CM_CargoCheckItemSet"/>
        <ReturnType type="CM_CargoCheck"/>
    </JadeMethod>
    <JadeMethod name="addCargoCheckItem" id="9711336a-7337-4267-ba58-1485cde42ff2">
        <source>addCargoCheckItem(_cargoCheck : CM_CargoCheck; _name, _requiredExtraInfo : String; _toDoTaskDesc : CM_ToDoTaskDesc; 
		_toDoTask : CM_ToDoTask; _required : Boolean) : CM_CargoCheckItem;

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	cargoCheck							: CM_CargoCheck;
	cargoCheckItem						: CM_CargoCheckItem;
	pxyCargoCheckItem					: CM_CargoCheckItem;
	
	cmifArray							: CMIF_Array;

begin

	create pxyCargoCheckItem transient;
	pxyCargoCheckItem.setProxy(_name, _toDoTaskDesc, _toDoTask, _requiredExtraInfo, _required, _cargoCheck);
	
	create cmifArray transient;
	
	cargoCheck := _cargoCheck;
	
	app.myTrxCA.trxCreateCargoCheckItem(pxyCargoCheckItem, cmifArray, cargoCheck, cargoCheckItem, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return cargoCheckItem;

epilog

	delete pxyCargoCheckItem;
	delete cmifArray;

end;</source>
        <Parameter name="_cargoCheck" type="CM_CargoCheck"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_requiredExtraInfo" type="String"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
        <Parameter name="_required" type="Boolean"/>
        <ReturnType type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoForVoyage" id="9bd5dcd1-e05b-43e2-ac55-12195c3fb64d">
        <source>addCargoForVoyage(_voyage: CM_Voyage; _id: String) : CM_TrackedItem;
// 03/02/2010	cnwjre1	
//	general cargo, to ship block stack
vars
	ifArray: CMIF_TIObjectArray;
	ifPreNote: CMIF_PreNote;
begin
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := TI_CargoType_BreakBulk;
	ifPreNote.commodity := "TYRE";
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	ifPreNote.operatorCode := _voyage.operatorCode;
	ifPreNote.weightTotal := 1000;
	ifPreNote.voyageCode := _voyage.code;
	ifPreNote.transportMode := TI_TRANSMODE_SHIP_STR;
	ifPreNote.remarks := self.createdByUnitTest(null);							// 07/09/2015 cnwmh5
	ifArray.add(ifPreNote);
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	return ifPreNote.myPersistentTrackedItem;
epilog
	delete ifArray;
	delete ifPreNote;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoGroup" id="7d18cbc9-4c97-444a-99f0-b04d4f688323">
        <source>addCargoGroup( _id : String; _allCargoToAssign : CM_TISet ):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	pxyCargoGroup : CM_TrackedItem;
	realCargoGroup : CM_TrackedItem;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	remarks : String;
	term : CM_Terminal;
	subT : CM_SubTerminal;
	ti : CM_TrackedItem;
	bulkRel : CM_BulkRelease;
	minWeight : Decimal[14,4];
	maxWeight : Decimal[14,4];

begin

	term := self.getTerminal;

	self.assertTrueMsg( app.isCargoGroupEnabled, "'Cargo Group' not licensed!" );

	if self.opts.includesKey("CargoType") then
		cargoType := self.opts.obj("CargoType").CM_CargoType;
	else
		cargoType := term.getDefaultCargoGroupCargoType();
	endif;	
	self.assertTrueMsg( cargoType &lt;&gt; null, "No default 'Cargo Group' cargo type found!" );
	self.assertTrueMsg( cargoType.isCargoGroup, "Cargo Type '" &amp; cargoType.abbreviation &amp; " is not track as 'Cargo Group'!" );
	
	if self.opts.includesKey("Operator") then
		operator := self.opts.obj("Operator").CM_Operator;
	else
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;
	self.assertTrueMsg( operator &lt;&gt; null, "No operator found!" );
	if self.opts.includesKey(UTTI_Remarks) then
		remarks := self.opts.str(UTTI_Remarks);
	endif;
	

	pxyCargoGroup := term.createTI(cargoType, true);
	pxyCargoGroup.zSetPxyTerminal(term);
	pxyCargoGroup.setCargoType(cargoType.id);
	pxyCargoGroup.setMyOperator(operator);		
	pxyCargoGroup.setImExStatus(TI_IMEX_STATUS_STORAGE);
	pxyCargoGroup.zSetPxyCompany(term.getDefaultCompanyBank);
	
	if self.opts.includesKey("MinWeight") then				// 10/05/2016 cnwmh5
		minWeight := self.opts.dec("MinWeight");
	endif;
	if self.opts.includesKey("MaxWeight") then				// 10/05/2016 cnwmh5
		maxWeight := self.opts.dec("MaxWeight");
	endif;
	if minWeight &gt; 0.00 or maxWeight &gt; 0.0 then				// 10/05/2016 cnwmh5
		pxyCargoGroup.CM_CargoGroup.setPxyMinMaxWeights(minWeight, maxWeight);
	endif;
		
	if app.isSubTerminalsOn(term) then
		if self.opts.includesKey(ETRow_MySubTerminal) then
			subT := self.opts.obj(ETRow_MySubTerminal).CM_SubTerminal;
		else
			subT := term.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false);
		endif;
		pxyCargoGroup.setSubTerminal(subT,null);
	endif;
	pxyCargoGroup.zSetPxyId( _id );
	pxyCargoGroup.setRemarks( remarks, false );
	

	app.myTrxCA.trxCreateCargoGroup(pxyCargoGroup, realCargoGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	if realCargoGroup &lt;&gt; null then
		beginTransaction;
		global.setExtraData(realCargoGroup.allExtraData, realCargoGroup, "createdByUnitTest" , self.getClassMethodCreatedBy());
		// 13/07/015 cnwmh5
		remarks := realCargoGroup.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realCargoGroup.setRemarks(remarks &amp; self.createdByUnitTest(remarks), false);
		commitTransaction;
	endif;
	
	if _allCargoToAssign &lt;&gt; null and not _allCargoToAssign.isEmpty then
		foreach ti in _allCargoToAssign do
			app.myTrxUA.trxCargoGroupAddTi(realCargoGroup.CM_CargoGroup, ti, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
	endif;
	
epilog

	if realCargoGroup &lt;&gt; null then
		return realCargoGroup.CM_CargoGroup;
	else
		return null;
	endif;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_allCargoToAssign" type="CM_TISet"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="addCargoOpts" id="b3fd4c33-fcc1-4152-bc89-36f3721bc722">
        <source>addCargoOpts(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _ct : Integer) : CM_TrackedItem;
//29 August 2008	cnwdw1	
// 29/06/2012		cwnmh5	Fix issue with sealNumShipper
// 11/06/3015		cnwdap1	PAR #36421 Changed signature for CM_TIHazard::setProxy
vars
	pxyTI			: CM_TrackedItem;	
	voyage			: CM_Voyage;
	tmpCustomsAgent	: CM_CustomsAgent;
	tmpBR			: CM_BulkRelease;
	trailerType		: CM_TILCType;
	product			: CM_Product;			// aka CargoSubtype
	operator		: CM_Operator;
	hazard			: CM_TIHazard;
	wagonClass		: CM_WagonClass;
	bookingItem		: CM_BookingRefItem;
	
begin
	self.deleteContainer(_id);
	operator := _operator;
	if self.opts.includesKey("Operator") then
		operator := self.opts.obj("Operator").CM_Operator;
	endif;
	pxyTI := self.createCargo(_id, _isoType, _commodity, operator, true, _ct);
	//pxyTI.setWeight(4000, null, null);						//-cnwml2 MSL CCMS 1017
	pxyTI.setTotalWeight(4000, null, null);						//+cnwml2 MSL CCMS 1017
	pxyTI.setWeightTare(4000);
	
	if self.opts.includesKey(UTTI_VoyageCode) then
		voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.opts.str(UTTI_VoyageCode), null);
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	
	
	if self.opts.includesKey("Temperature") then // PAR 35502
		pxyTI.setTemperature(self.opts.dec("Temperature")); // PAR 35502
	endif;
	
	if self.opts.includesKey(UTTI_Width) then
		pxyTI.setWidth(self.opts.str(UTTI_Width).Decimal);
	endif;
	if self.opts.includesKey(UTTI_Length) then
		pxyTI.setLength(self.opts.dec(UTTI_Length)); // PAR 31615
	endif;
	if self.opts.includesKey(UTTI_Height) then
		pxyTI.setHeight(self.opts.str(UTTI_Height).Decimal);
	endif;	
	if self.opts.includesKey(UTTI_Volume) then
		pxyTI.setMyTotalVolume(self.opts.int(UTTI_Volume));
	endif;
	if self.opts.includesKey("TotalVolume") then
		pxyTI.setMyTotalVolume(self.opts.int("TotalVolume"));
	endif;
	if self.opts.includesKey("CargoVolume") then
		pxyTI.setMyCargoVolume(self.opts.int("CargoVolume"));
	endif;
	
	if self.opts.includesKey("Hazard") then
		create hazard transient;
		hazard.setProxy(self.opts.str("Hazard"), self.opts.strDef("HazardDescription", "Hazardous"),
						//"", pxyTI, false);					// PAR #36421
						"", pxyTI, false, null,					// PAR #36421
						NULL_TEMPERATURE, MarinePollutant_Null, null);		// TFS 2842
	endif;
		
	if self.opts.includesKey("OverDimension") then
		pxyTI.setIsOverDimensions(self.opts.bool("OverDimension"));
	endif;
	
	if self.opts.includesKey ("operImportReleasePin") then
		pxyTI.setOperatorImportReleasePIN  (self.opts.str ("operImportReleasePin"));
	endif;
	
	if self.opts.includesKey(UTTI_AvailabilityGrade) then
		pxyTI.CM_Container.setPropertyValue(CM_Container::availabilityGrade.name, self.opts.int(UTTI_AvailabilityGrade));
	endif;
	if self.opts.includesKey(UTTI_BOL) then
		pxyTI.setBOL(self.opts.str(UTTI_BOL));
	endif;
	if self.opts.includesKey(UTTI_BookingRef) then
		pxyTI.setBookingReference(self.opts.str(UTTI_BookingRef));
	endif;
	if self.opts.includesKey("BookingItem") then
		bookingItem := self.opts.obj("BookingItem").CM_BookingRefItem;
		pxyTI.setBookingRefAndItem(bookingItem.myBookingReference, bookingItem, true, null);
	endif;
	if self.opts.includesKey(UTTI_BulkRelease) then
		if self.opts.str(UTTI_BulkRelease) &lt;&gt; null then
			tmpBR := self.getTerminal.getBulkReleaseFromCode(self.opts.str(UTTI_BulkRelease));
			self.assertNotNullMsg(tmpBR, 'Bulk Release (' &amp; self.opts.str(UTTI_BulkRelease) &amp; ')');
		endif;
		if tmpBR &lt;&gt; null then
			// not strictly correct as really needs to add to a reserve detail as well.
			// If need ti implement then look at CM_BulkRelease.assignTIToBulkRelease (requires a persistent ti)
			pxyTI.allBulkReleasesAssigned.add(tmpBR);
		endif;
	endif;
	if self.opts.includesKey(UTTI_Consignee) then
		pxyTI.setPropertyValue(CM_TrackedItem::consignee.name, self.opts.str(UTTI_Consignee));
	endif;
	if self.opts.includesKey(UTTI_Consignor) then
		pxyTI.setPropertyValue(CM_TrackedItem::consignor.name, self.opts.str(UTTI_Consignor));
	endif;
	if self.opts.includesKey(UTTI_CustomsAgent) then
		if self.opts.str(UTTI_CustomsAgent) &lt;&gt; null then
			tmpCustomsAgent := app.myRoot.allCustomsAgents[self.opts.str(UTTI_CustomsAgent)];
			self.assertNotNullMsg(tmpCustomsAgent, 'Customs Agent (' &amp; self.opts.str(UTTI_CustomsAgent) &amp; ')');
		endif;
		pxyTI.zSetPxyCustomsAgent(tmpCustomsAgent);
	endif;
	if self.opts.includesKey(UTTI_CustomsEntryNumber) then
		pxyTI.zSetPxyCustomsEntryNumber(self.opts.str(UTTI_CustomsEntryNumber));
	endif;
	if self.opts.includesKey(UTTI_CustomsExportEntryNumber) then
		pxyTI.zSetPxyCustomExportEntryNumber(self.opts.str(UTTI_CustomsExportEntryNumber), app.myPassport);
	endif;
	if self.opts.includesKey( ETRow_CustomsReference ) then
		pxyTI.zSetPxyCustomsReference( self.opts.str( ETRow_CustomsReference ) );
	endif;
	if self.opts.includesKey(UTTI_DeliveryRelease) then	// cnwcs5 April 2012
		pxyTI.setDeliveryRelease(self.opts.str(UTTI_DeliveryRelease));
	endif;
	if self.opts.includesKey ("DeliveryReleaseReason") then
		pxyTI.zSetPxyDeliveryReleaseReason (self.opts.int ("DeliveryReleaseReason"));
	endif;
	
	if self.opts.includesKey(UTTI_DestinationPort) then
		pxyTI.setDestinationPort(self.opts.str(UTTI_DestinationPort));
	endif;
	if self.opts.includesKey(UTTI_DischargePort) then
		pxyTI.setDischargePort(self.opts.str(UTTI_DischargePort));
	endif;
	if self.opts.includesKey(UTTI_FreightForwarder) then
		pxyTI.setPropertyValue(CM_TrackedItem::freightForwarderCode.name, self.opts.str(UTTI_FreightForwarder));
	endif;

	pxyTI.zSetPxyImexStatus(self.opts.intDef(UTTI_IMEX, TI_IMEX_STATUS_EXPORT));
	if self.opts.includesKey(UTTI_IntendedReleaseMode) then
		pxyTI.setPropertyValue(CM_TrackedItem::intendedReleaseMode.name, self.opts.str(UTTI_IntendedReleaseMode).Integer);
	endif;

	if self.opts.includesKey(UTTI_OverHeight) then // AKB2010JUN
		pxyTI.CM_Container.setOverHeight(self.opts.int(UTTI_OverHeight), null, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_OverWidthLeft) then // AKB2011DEC
		pxyTI.CM_Container.setOverWidthLeft(self.opts.int(UTTI_OverWidthLeft), null, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_Remarks) then
		pxyTI.setPropertyValue(CM_TrackedItem::remarks.name, self.opts.str(UTTI_Remarks));
	endif;
	if pxyTI.remarks &lt;&gt; null then																	// 07/09/2015 cnwmh5
		pxyTI.setPropertyValue(CM_TrackedItem::remarks.name, pxyTI.remarks &amp; CrLf);
	endif;
	if not pxyTI.remarks.cnContains(self.createdByUnitTest(pxyTI.remarks)) then								// 07/09/2015 cnwmh5
		pxyTI.setPropertyValue(CM_TrackedItem::remarks.name, pxyTI.remarks &amp; self.createdByUnitTest(null));
	endif;
	if self.opts.includesKey(UTTI_ReceiptMode) then
		pxyTI.setReceiptTransportMode(self.opts.int(UTTI_ReceiptMode));
	endif;
	if self.opts.includesKey(UTTI_ShipperSeal) then
		//pxyTI.setPropertyValue(CM_Container::sealNumShippers.name, self.opts.str(UTTI_ShipperSeal));
		///pxyTI.setPropertyValue(SealNumShippers, self.opts.str(UTTI_ShipperSeal));	//17 Sep 2010	NDL	Par 25608
		pxyTI.setSealNumShippers(self.opts.str(UTTI_ShipperSeal));				// 29/06/2012 cnwmh5
	endif;
	if self.opts.includesKey(UTTI_State) then
		pxyTI.setStatePxy(self.opts.int(UTTI_State));
	endif;
	if self.opts.includesKey(UTTI_TotalWeight) then
		pxyTI.setPropertyValue(CM_TrackedItem::totalWeight.name, self.opts.int(UTTI_TotalWeight).Decimal);
	endif;
	if self.opts.includesKey("totalQuantity") then
		pxyTI.setPropertyValue(CM_TrackedItem::totalQuantity.name, self.opts.int("totalQuantity"));
	endif;
	if self.opts.includesKey(UTTI_Wagon) then
		if self.opts.includesKey(UTTI_WagonClass) then
			wagonClass := self.getTerminal.myRoot.allWagonClasses[self.opts.str(UTTI_WagonClass)];
		endif;
	//	pxyTI.setWagon(self.opts.str(UTTI_Wagon),null);
		pxyTI.setWagon(self.opts.str(UTTI_Wagon),null, wagonClass, false );	//12 May 2014	NDL	Par 33615
	endif;

	if self.opts.includesKey("quantity") then
		pxyTI.zSetPxyQuantity(self.opts.int("quantity"));
	endif;
	
	if self.opts.includesKey( ETRow_TrailerType ) then
		trailerType	:= self.getTrailerType( self.opts.str( ETRow_TrailerType ) );
		pxyTI.setMyType( trailerType );
	endif;	
	if self.opts.includesKey( ETRow_MyProduct ) then		
		product	:= pxyTI.myCargoType.getProductFromCode( self.opts.str( ETRow_MyProduct ) );
		pxyTI.setMyProduct( product );
	endif;
	if self.opts.includesKey( "directDelivery" ) then		
		pxyTI.zSetPxyDirectDelivery(self.opts.bool( "directDelivery" ));
	endif;
	
	if self.opts.includesKey( "SpecialStow" ) then		
		pxyTI.zSetPxySpecialStow(self.opts.obj( "SpecialStow" ).CM_SpecialStow.code);
	endif;
	
	if _ct = TI_CargoType_Generator then												//05/04/2016	cnwmk3- For UT_ToDoTasks: tTransactionsForUserDefinedTasks
		pxyTI.CM_Generator.setMyGeneratorType(app.myRoot.allGeneratorTypes.first);
	endif;
	
	return self.addContainerFromProxy(pxyTI);

epilog

end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ct" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoPhoto" id="67e98952-63e6-4376-9310-ff792b5d6a77">
        <source>addCargoPhoto(_trackedItem:CM_TrackedItem; _description:String; _binary:Binary) : CM_Photo;
//30 November 2009	cnwdz2	 
// Add a photo to a tracked item par 21808
//21 Nov      2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
vars
	proxyPhoto, 
	newPhoto   : CM_Photo;
begin
	create proxyPhoto transient;
	proxyPhoto.setDescription(_description);
	proxyPhoto.setMyParent(_trackedItem);
	
	proxyPhoto.setPhotoContent(_binary);
	//proxyPhoto.setThumbnailContent(_binary);          //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, newPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return newPhoto;
epilog
	delete proxyPhoto;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_binary" type="Binary"/>
        <ReturnType type="CM_Photo"/>
    </JadeMethod>
    <JadeMethod name="addCargoType" id="95ca34a7-08bd-4b9a-be82-d50a3f0dda4a">
        <source>addCargoType(_code: String; _hasSubCargo: Boolean): CM_CargoType;
//06 August 2009	cnwdw1	
//
// 29/07/2011	cnwmh5		Remove use of _opts from signature as not used
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 07/03/2019	jlgdap1		TFS 41570 PNL No PIN for Cargo Type
//18 May 2022   navnk20 	ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
//10/08/2022    navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
//11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
// 06/09/2024	jlizm1		TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references
vars
	selectedTerminals			: CM_TerminalSet;
	pxyCargoType,cargoType		: CM_CargoType;
	pxySystemProductType		: CM_Product;
	handlingType				: CM_HandlingType;
			
	showDamageCodes 			: Boolean;
	canBeWeighted			 	: Boolean;
	description					: String;
	trackAs 					: Integer;
	createClass					: String;
	useTareCargoWeight			: Boolean; 
	canBeWeightCertified 		: Boolean;
	checkMaxMachineLiftWeight 	: Boolean;
	allowDuplicateId 			: Boolean;
	allowCreationRsltGroupage 	: Boolean;
	commodityRequired 			: Boolean;
	trackBy						: Integer;						// PAR #33606
	weightType					: CM_MeasurementType;			// PAR #33606
	volumeType					: CM_MeasurementType;			// PAR #33606
	
	notAvailableForEntry		: Boolean;						// 18/02/2016 cnwmh5
	desc						: String;						// 18/02/2016 cnwmh5
	allComodities				: CM_CommodityByCodeDict;
	defaultComodity :String;
	handlingSubType : CM_HandlingSubType;
	tokens						: StringArray;
	commodityStr				: String;
	commodity					: CM_Commodity;
	allowWeightCalc				: Boolean;
	includeStorageCalc			: Boolean;
	autoTareCargoWeightCalc		: Boolean;	//navra1 - TFS 63624 - 15th Apr 2024
	externalReference			: String;
	
begin

	self.deleteCargoType(_code);
		
	create pxyCargoType transient;
	
	create selectedTerminals transient;
	if self.opts.includesKey("Terminals") then
		self.opts.obj("Terminals").CM_TerminalSet.copy(selectedTerminals);
	else
		///selectedTerminals.add(self.getTerminal());
		selectedTerminals.add(CM_Terminal.firstInstance);
	endif;
	
	pxyCargoType.addSelectedUserTerminals(selectedTerminals);
	
	if self.opts.includesKey("ShowDamageCodes") then
		showDamageCodes := self.opts.bool("ShowDamageCodes");
	endif;
	description := _code;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	if self.opts.includesKey("CanBeWeighed") then
		canBeWeighted := self.opts.bool("CanBeWeighed");
	endif;
	
	if self.opts.includesKey("UseTareCargoWeight") then
		useTareCargoWeight := self.opts.bool("UseTareCargoWeight");
	endif;
	
	//navra1 - TFS 63624 - 15th Apr 2024 - start
	if self.opts.includesKey("AutoTareCargoWeightCalc") then
		autoTareCargoWeightCalc := self.opts.bool("AutoTareCargoWeightCalc");
	endif;
	//navra1 - TFS 63624 - 15th Apr 2024 - end
		
	if self.opts.includesKey("CanBeWeightCertified") then
		canBeWeightCertified := self.opts.bool("CanBeWeightCertified");
	endif;	
	
	createClass := "CM_BreakBulkGeneric";
	if self.opts.includesKey("CreateClass") then
		createClass := self.opts.str("CreateClass");
	endif;
		
	trackAs := ProductType_BreakBulk;
	if self.opts.includesKey("TrackAs") then
		trackAs := self.opts.int("TrackAs");
	endif;
	
	handlingType := null;
	if self.opts.includesKey("HandlingType") then
		handlingType := app.myRoot.allHandlingTypes[self.opts.int("HandlingType")];
	endif;
	//if self.opts.includesKey("HandlingType") then
	///	handlingType := self.opts.obj("HandlingType").CM_HandlingType;
	//endif;
	
	if self.opts.includesKey("CheckMaxMachineLiftWeight") then
		checkMaxMachineLiftWeight := self.opts.bool("CheckMaxMachineLiftWeight");
	endif;
	
	if self.opts.includesKey("AllowDuplicateId") then
		allowDuplicateId := self.opts.bool("AllowDuplicateId");
	endif;	
	
	if self.opts.includesKey("AllowCreationResultGroupage") then
		allowCreationRsltGroupage := self.opts.bool("AllowCreationResultGroupage");
	endif;
	
	if self.opts.includesKey("NotAvailableForEntry") then
		notAvailableForEntry := self.opts.bool("NotAvailableForEntry");
	endif;
	
	// 06/03/2018 jlgmh5
	if self.opts.includesKey("AllowWeightCalc") then 
		allowWeightCalc := self.opts.bool("AllowWeightCalc");
	endif;
	
	if self.opts.includesKey("ExternalReference") then
		externalReference := self.opts.str("ExternalReference");
	endif;
	
	/*
	// 05/03/2018 jlgmh5 - replaced
	if self.opts.includesKey("Commodities") then
		//allComodities := self.opts.obj("Commodities").CM_CommodityByCodeDict;
		create allComodities transient;
		self.opts.obj("Commodities").CM_CommodityByCodeDict.copy(allComodities);
		if allComodities &lt;&gt; null then
			commodityRequired := true;
			defaultComodity := allComodities.first().code;
		endif;
	endif;
	*/
	
	if self.opts.includesKey("Commodities") then
		commodityStr := self.opts.str("Commodities");
		create tokens transient;
		commodityStr.getTokensForDelimiter(";", tokens);
		create allComodities transient;
		foreach commodityStr in tokens do
			commodity := app.myRoot.allCommodities[commodityStr];
			if commodity &lt;&gt; null then
				allComodities.add(commodity);
			endif;
		endforeach;
		if allComodities &lt;&gt; null and not allComodities.isEmpty() then
			commodityRequired := true;
			////defaultComodity := allComodities.first().code;
		endif;
	endif;
	
	//allComodities
	
	trackBy := CargoType_TrackByWeight;									// PAR #33606
	weightType := app.getDefaultMeasurementForType(Type_Weight);		// PAR #33606
	volumeType := app.getDefaultMeasurementForType(Type_Volume);		// PAR #33606
	
	// 18/02/2016 cnwmh5
	desc := _code;
	if self.opts.includesKey("Description") then
		desc := self.opts.str("Description");
	endif;
	
	// 14/03/2018 jlgmh5
	if self.opts.includesKey("IncludeInStorageCalc") then
		includeStorageCalc := self.opts.bool("IncludeInStorageCalc").Boolean;
	endif;
	
	pxyCargoType.setProxy(pxyCargoType.getNewId,
						_code,
						desc, 							// 18/02/2016 cnwmh5
						trackAs,
						canBeWeighted,
						checkMaxMachineLiftWeight,
						includeStorageCalc,
						showDamageCodes,	
						allowCreationRsltGroupage,
						false,
						allowDuplicateId,
						//ProductType_BreakBulk,					
						null,
						handlingType,
						handlingSubType,
						false,
						_hasSubCargo,
						commodityRequired,
						notAvailableForEntry,
						defaultComodity,
						allComodities,
						null,
						null,
						null, 
						useTareCargoWeight, 
						canBeWeightCertified,
						null,
						trackBy,										//PAR #33606
						weightType,										//PAR #33606
						volumeType,									//PAR #33606
						false,	//24 Apr 2015	NDL	Par 36111
						false,	//_allowAutoVolumeCalc : Boolean	//10 Jun 2016	NDL	TFS 2141
						allowWeightCalc,
						true,						// TFS 41570
						false,	//_requiresWeighing : Boolean	//05 Jul 2019	NDL	TFS 44965
						false,
						false,  // 18 May 2022 navnk20 TFS 53508
						false,
						false,  //10/08/2022 navds20 TFS 54219
						false, //11/07/2023 navmv20 CR 58244 Task 58245
						autoTareCargoWeightCalc,	//navra1 - TFS 63624 - 15th Apr 2024
						externalReference
						);
						
						
	pxyCargoType.setForUpdateTEUSettings(1,null);
	
	if not _hasSubCargo and trackAs &lt;&gt; ProductType_Trailer then
		create pxySystemProductType transient;
		pxySystemProductType.setAsSystemForCargoTypeUserDef();
		pxySystemProductType.setProductDefaults(pxyCargoType);
		pxySystemProductType.setProxyAsSystemDummyProduct(pxyCargoType);
		pxyCargoType.setSystemProductType(pxySystemProductType);
	endif;
	
	// This is a some naughty hard coding
	if trackAs &lt;&gt; ProductType_Trailer then
		pxyCargoType.allAttributesOnProduct.add("myWidthString");
		pxyCargoType.allAttributesOnProduct.add("myHeightString");
		pxyCargoType.allAttributesOnProduct.add("myLengthString");
		pxyCargoType.allAttributesOnProduct.add("myWidth");
		pxyCargoType.allAttributesOnProduct.add("myHeight");
		pxyCargoType.allAttributesOnProduct.add("myLength");
		pxyCargoType.allAttributesOnProduct.add("myQuantity");
		pxyCargoType.allAttributesOnProduct.add("myVolume");
		pxyCargoType.allAttributesOnProduct.add("myDensity");
		pxyCargoType.allAttributesOnProduct.add("myDensityDec"); // ### TFS 52193 22Nov2021 NAVPW1
		pxyCargoType.allAttributesOnProduct.add("myWeight");
		pxyCargoType.allAttributesOnProduct.add("myType");
		pxyCargoType.allAttributesOnProduct.add("myStowageFactor");
	endif;
	
	app.myTrxCA.trxCreateCargoType(pxyCargoType,  cargoType, null, pxySystemProductType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	if self.opts.includesKey("CommodityRequired") then
		beginTransaction;
		cargoType.setPropertyValue("isCommodityRequired", self.opts.bool("CommodityRequired"));
		commitTransaction;
	endif;
	
	return cargoType;
epilog
	///sdself.opts.removeAssoc("Commodities");
	delete allComodities;
	delete selectedTerminals;
	delete pxyCargoType;
	delete tokens;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_hasSubCargo" type="Boolean"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="addCargoUpdateStopRequest" id="b8877306-95d9-45d4-ba6b-71d2dfa390b3">
        <source>addCargoUpdateStopRequest(_cargoId : String;
							_cargoType :Integer;
							_remarks : String;
							_stopID : Integer;
							_isRemove : Boolean;
							_additionalInfo : String;
							_expiryDate: Date
							);
/*

Date		Who		Reason
22 February 2016	cnwer1	Initial creation PAR
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/

vars
	pxyRequestStops : CM_EventRequestStops;	
	cargoType : CM_CargoType;
	org : CM_Organisation;
	stop : CM_StopsTable;
	cmifEventReq : CMIF_EventRequestController;
begin
	
	if _cargoType &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[_cargoType];
	else
		cargoType:=app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;
		
	create cmifEventReq transient;
	//stop:= app.myRoot.allStopsTable[get
	org := self.getOrganisation();
	create pxyRequestStops transient;
		
	stop:=app.myRoot.allStopsTable[_stopID];
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeStops,
												null, //addressess
												_remarks	,
												_cargoId,
												app.myPassport.myUser,
												cargoType,
												org,
												self.getTerminal(),
												EventRequestPending,
												_isRemove,
												false,												
												null,
												true,
												stop,
												_additionalInfo,
												_expiryDate,
												false,
												null,null,null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,   // 16/01/2017 cnwma1 TFS #2885
												null,   // 16/01/2017 cnwma1 TFS #2885
												null    // 16/01/2017 cnwma1 TFS #2885
												);
												
	cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);
	
	self.assertNoTrxErrorsPassport("Cargo Update Stop Request failed");
epilog

	delete pxyRequestStops;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_stopID" type="Integer"/>
        <Parameter name="_isRemove" type="Boolean"/>
        <Parameter name="_additionalInfo" type="String"/>
        <Parameter name="_expiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="addCarrier" id="05fe17ae-fd48-46d7-b4cc-07e732bfd1c8">
        <source>addCarrier(_code, _description: String; _pinEmailAddresses: CM_EmailEntityByTypeNameDict; _isNotAvailableForEntry, _isRail, _isRoad : Boolean; _debtor : CM_Debtor): CM_Carrier;
//09 September 2010	by cnwvu1
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars
	pxyCarrier, newCarrier	: CM_Carrier;
	dacRec					: CM_DataAccessController;
	dacRel					: CM_DataAccessController;
	
begin

	self.deleteCarrier(_code);				// 06/12/2011 cnwmh5
	
	dacRec := self.opts.obj("DACRec").CM_DataAccessController;
	dacRel := self.opts.obj("DACRel").CM_DataAccessController;
	
	create pxyCarrier transient;
	
	//pxyCarrier.setProxy(_code, _description, _pinEmailAddresses, _isNotAvailableForEntry, _isRail, _isRoad, _debtor, null, dacRel, dacRec);		//12/05/2022 navhl20 TFS 53430
	pxyCarrier.setProxy(_code, _description, _pinEmailAddresses, _isNotAvailableForEntry, _isRail, _isRoad, false, _debtor, null, dacRel, dacRec);		//12/05/2022 navhl20 TFS 53430

	app.myTrxCA.trxCreateCarrier(pxyCarrier, newCarrier, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();

	return newCarrier;
	
epilog

	delete pxyCarrier;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_pinEmailAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isRail" type="Boolean"/>
        <Parameter name="_isRoad" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="addCashDebtor" id="73789493-73f7-4441-bdfa-a0ff54bd5bf3">
        <source>addCashDebtor(_name : String; _address : String; _decfinName : String; _terminal : CM_Terminal) : CM_DebtorNode;
// add a cash-only debtor for a single terminal, populating the essential properties only
// 09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
vars
	debtorTermDetail : CMIF_DebtorTerminalDetail;
	term : CM_Terminal;
	root	: CM_Root;
	bank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;

	debtorNode	: CM_DebtorNode;
	proxyDebtor	: CM_Debtor;
	debtorNodeController	: CMIF_DebtorNode;

begin
	create debtorNodeController transient;
	create proxyDebtor transient;
	root := app.myRoot;
	bank := root.myRootCompany;
	rdg := bank.getRootDebtorGroup();
	
	debtorNodeController.billingAddress := _address;
	debtorNodeController.decfinName := _decfinName;
	debtorNodeController.isSuspended := false;
	debtorNodeController.isZeroRated := false;
	debtorNodeController.badDebtor := false;
	debtorNodeController.myBank := bank;
	debtorNodeController.myTermsOfTrade := null ;
	// parent is root debtor
	debtorNodeController.myParentDebtorNode := rdg;

	debtorNodeController.myPxyDebtorNode := proxyDebtor;
	debtorNodeController.name := _name;
 // ### TFS 52237 27OCT2021 NAVAB1	if _terminal &lt;&gt; null then
 // ### TFS 52237 27OCT2021 NAVAB1		debtorNodeController.allCashOnlyTerminals.add( _terminal );
 // ### TFS 52237 27OCT2021 NAVAB1	endif;
	
	
	 // ### TFS 52237 02NOV2021 NAVAB1 add debtor terminal for all terminals
	foreach term in root.allTerminals do
		create debtorTermDetail transient;
		
		debtorTermDetail.setMyTerminal(term);
		debtorTermDetail.setPaymentType(PaymentType_PostPay);
		debtorTermDetail.setCashOnly(term = _terminal);
		debtorNodeController.allDebtorTerminalDetails.add(debtorTermDetail);
	endforeach;
	
	
	//proxyDebtor.setProxy(debtorNodeController.name);									// TFS 40092
	proxyDebtor.setProxy(debtorNodeController.name, debtorNodeController.code);			// TFS 40092
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return debtorNode;
epilog
	debtorNodeController.allDebtorTerminalDetails.purge(); // ### TFS 52237 27OCT2021 NAVAB1
	delete debtorNodeController;
	delete proxyDebtor;
end;

</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_address" type="String"/>
        <Parameter name="_decfinName" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="addCheckPoint" id="c5d344ea-5ede-4063-898a-b6bd15975e0f">
        <source>addCheckPoint(_checkPointId, _checkPointDesc, _hiLoTideReference, _hiLoTideReference2 : String; _harbour : HMS_Harbour; _tidalModel : HMS_TidalModelDefinition; 
			_checkPointType, _hiLoRelativeTimeFrom, _hiLoRelativeTimeTo, _hiLoRelativeTimeFrom2, _hiLoRelativeTimeTo2, 
			_tideRangeAmount, _tideRangeAmount2, _tideState: Integer) : HMS_CheckPoint;

/*

Purpose:		Add Check Point / Restriction	

Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

*/

vars

	pxyCheckPoint				: HMS_CheckPoint;
	checkPointObj				: HMS_Object;
	checkPoint					: HMS_CheckPoint;

begin

	self.deleteCheckPoint(_checkPointId, _harbour);

	create pxyCheckPoint transient;
	pxyCheckPoint.setProxy(app.myRoot,							// root 		: CM_Root; 
						  _harbour, 				 			// harbour : HMS_Harbour;
						  _checkPointType,						// checkpoint type : Integer;
						  _tidalModel, 							// tidal model : HMS_TidalModelDefinition;
						  _hiLoTideReference, 					//  : String;
						  _hiLoRelativeTimeTo, 					// : Integer;
						  _hiLoRelativeTimeFrom, 				// : Integer;
						  _hiLoTideReference2, 					// : String;
						  _hiLoRelativeTimeTo2, 				// : Integer;
						  _hiLoRelativeTimeFrom2, 				// : Integer;
						  null,									//_tideRangeReference : String;
						  _tideRangeAmount,						//_tideRangeAmount : Integer;
						  null,									//_tideRangeReference2 : String;
						  _tideRangeAmount2,					//_tideRangeAmount2 : Integer;
						  0,									//_gapTimeDifference : Integer;
						  null,									//_shipsDepartTimings : String;
						  false,								//_timeGapCheckArrivals : Boolean;
						  false,								//_timeGapCheckDepartures : Boolean;
						  null,									// _timeGapToCheckRegion : HMS_HarbourRegion;
						  _tideState,							//_tideState : Integer;
						  null, 								// jadeCode : String
						  null);								// user code : String
						  
	pxyCheckPoint.setPropertyValue("code", _checkPointId);
	pxyCheckPoint.setPropertyValue("description", _checkPointDesc);
	
	app.myTrxCA.trxCreateHMSObject(pxyCheckPoint, checkPointObj, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	if self.opts.includesKey("OverrideCheckPointType") then
		beginTransaction;
		checkPointObj.HMS_CheckPoint.setPropertyValue("checkPointType", self.opts.int("OverrideCheckPointType"));
		commitTransaction;
	endif;
	
	if self.opts.includesKey("HookCode") then
		checkPoint := checkPointObj.HMS_CheckPoint;
		if checkPoint.myHookCode &lt;&gt; null then
			beginTransaction;
			if checkPoint.myHookCode.myHookType &lt;&gt; null then
				checkPoint.myHookCode.myHookType.setPropertyValue("hookMethodTemplate", self.opts.str("HookCode"));
			endif;
			checkPoint.myHookCode.setPropertyValue("code", checkPoint.code);
			if not checkPoint.myHookCode.allHookCodeHistory.isEmpty() then
				checkPoint.myHookCode.allHookCodeHistory.first.CM_HookCodeHistory.setPropertyValue("jadeCode", self.opts.str("HookCode"));
			endif;
			commitTransaction;
		endif;
	endif;
	
	return checkPointObj.HMS_CheckPoint;
	
epilog

	delete pxyCheckPoint;

end;</source>
        <Parameter name="_checkPointId" type="String"/>
        <Parameter name="_checkPointDesc" type="String"/>
        <Parameter name="_hiLoTideReference" type="String"/>
        <Parameter name="_hiLoTideReference2" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_checkPointType" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeFrom" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeTo" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeFrom2" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeTo2" type="Integer"/>
        <Parameter name="_tideRangeAmount" type="Integer"/>
        <Parameter name="_tideRangeAmount2" type="Integer"/>
        <Parameter name="_tideState" type="Integer"/>
        <ReturnType type="HMS_CheckPoint"/>
    </JadeMethod>
    <JadeMethod name="addCodeGroup" id="7469508e-312c-4642-9512-6da34201924d">
        <source>addCodeGroup(_codeGroupName: String; _codeGroupType: Integer) : CM_CodeGroup;
//03 September 2010	by cnwvu1

vars
	newCodeGroup	: CM_CodeGroup;
	pxyCodeGroup	: CM_CodeGroup;
	
begin


	if _codeGroupType = CodeGroup_LogSpecs then	// Log Specs case
		create pxyCodeGroup as CM_CodeGroupLogSpecs transient;	
	
	elseif _codeGroupType = CodeGroup_SourceLocation then	// Source Locations
		create pxyCodeGroup transient;
	else	
		// for other code groups put code here for proxy objects
	endif;
	
	pxyCodeGroup.setProxy( _codeGroupType, _codeGroupName, app.myRoot);
								
	app.myTrxCA.trxCreateCodeGroup(pxyCodeGroup, newCodeGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newCodeGroup;

epilog
	delete pxyCodeGroup;
	
end;</source>
        <Parameter name="_codeGroupName" type="String"/>
        <Parameter name="_codeGroupType" type="Integer"/>
        <ReturnType type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="addCommodity" id="335486e5-c9e2-48b6-b6b6-2ec815ae0916">
        <source>addCommodity(_commodityId, _commodityDesc : String; _selectedCargoTypes : ObjectArray) : CM_Commodity;

/*

Purpose:		Add a commodity	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation
25/03/2015		cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
*/

vars

	pxyCommodity					: CM_Commodity;
	commodity						: CM_Commodity;
	specialStow						: CM_SpecialStow;
	
	selectedCargoTypes				: ObjectArray;
	
	requiresTemp					: Boolean;
	maxTemp							: Real;
	minTemp							: Real;
	isEmptyCommodityForContainer	: Boolean;
	requiresPower					: Boolean;
	requiresPackDetailsMAF			: Boolean;
	codeToPrintBayPlan				: String;
	selectedCargoCreatedHere		: Boolean;
	shortDescription				: String;
	colour							: Integer;
	id 								: String;
	
begin

	self.deleteCommodity(_commodityId);
	
	id := _commodityId;
	if self.opts.includesKey("CommodityCode") then
		id := self.opts.str("CommodityCode");
	endif;

	create pxyCommodity transient;
	
	// no cargo types then default to ISO Container
	selectedCargoTypes := _selectedCargoTypes;
	if selectedCargoTypes = null then
		create selectedCargoTypes transient;
		selectedCargoCreatedHere := true;
	endif;
	if selectedCargoTypes.isEmpty() then
		selectedCargoTypes.add(app.myRoot.getCargoTypeForID(1));
	endif;
	
	if self.opts.includesKey("RequiresTemp") then
		requiresTemp := self.opts.bool("RequiresTemp");
	endif;
	if self.opts.includesKey("MaxTemp") then
		maxTemp := self.opts.real("MaxTemp");
	endif;
	if self.opts.includesKey("MinTemp") then
		minTemp := self.opts.real("MinTemp");
	endif;
	if self.opts.includesKey("RequiresPower") then
		requiresPower := self.opts.bool("RequiresPower");
	endif;
	if self.opts.includesKey("RequiresPackDetailsMAF") then
		requiresPackDetailsMAF := self.opts.bool("RequiresPackDetailsMAF");
	endif;
	if self.opts.includesKey("IsEmptyCommodityForContainer") then
		isEmptyCommodityForContainer := self.opts.bool("IsEmptyCommodityForContainer");
	endif;
	if self.opts.includesKey("CodeToPrintBayPlan") then
		codeToPrintBayPlan := self.opts.str("CodeToPrintBayPlan");
	endif;
	if self.opts.includesKey("SpecialStow") then
		specialStow := app.myRoot.allSpecialStows[self.opts.str("SpecialStow")].CM_SpecialStow;
	endif;
	if self.opts.includesKey("ShortDesc") then
		shortDescription := self.opts.str("ShortDesc");
	endif;
	
	if self.opts.includesKey("Colour") then
		colour := self.opts.int("Colour");
	endif;
	
	
	pxyCommodity.setProxy(id,					//_commodityId,				// Id / Code
						  _commodityDesc,			// Description
						  shortDescription, 					// Short Description
						  codeToPrintBayPlan,		// Bayplan Print As
						  requiresTemp,				// has temp
						  requiresPower,			// requeires power
						  requiresPackDetailsMAF,	// requires pack details
						  false, 					// not available for enty
						  isEmptyCommodityForContainer,	// is empty
						  colour, 						// colour
						  maxTemp,					// max temp
						  minTemp, 					// min temp
						  null, 					// Commodity Group
						  specialStow,						// Special stow
						  false,					// Is Used For Packing				// PAR #35895
						  selectedCargoTypes,		// all cargo Types
						  false
						  );		
						  
	app.myTrxCA.trxCreateCommodity(pxyCommodity, commodity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return commodity;

epilog
	delete pxyCommodity;
	if selectedCargoCreatedHere then
		delete selectedCargoTypes;
	endif;
end;</source>
        <Parameter name="_commodityId" type="String"/>
        <Parameter name="_commodityDesc" type="String"/>
        <Parameter name="_selectedCargoTypes" type="ObjectArray"/>
        <ReturnType type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="addCommodityGroup" id="5432e578-40db-4fa4-8866-9213d366e0db">
        <source>addCommodityGroup(_commodityGroupCode,_commodityGroupDesc : String): CM_CommodityGroup;
/*

Purpose:	Add a Commodity Group			

Parameters:			
upup
Date		Who		Reason
20/02/2014	cnwma1	Initial creation

*/

vars
	pxyCommodityGroup	: CM_CommodityGroup;
	commodityGroup		: CM_CommodityGroup;
	commodities			: CM_CommodityByCodeDict;

begin

	// Delete commodityGroup
	self.deleteCommodityGroup(_commodityGroupCode);

	create pxyCommodityGroup transient;
	create commodities transient;

	if self.opts.includesKey("Commodity") then
		self.opts.obj("Commodity").ObjectArray.copy(commodities);
	endif;	
	
	pxyCommodityGroup.setProxy(_commodityGroupCode,
							   _commodityGroupDesc,
							   1,
							   true,
							   6,
							   5,
							   commodities,
							   true,
							   true);

	app.myTrxCA.trxCreateCommodityGroup(pxyCommodityGroup,commodityGroup,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return commodityGroup;

epilog
	delete commodities;
	delete pxyCommodityGroup;

end;</source>
        <Parameter name="_commodityGroupCode" type="String"/>
        <Parameter name="_commodityGroupDesc" type="String"/>
        <ReturnType type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="addConsignGroup" id="ae43c030-802f-4f13-a795-4a71b85fc514">
        <source>addConsignGroup(_consignGroupID, _consignGroupDesc : String; _consignColl : CM_ConsignByCodeDict) : CM_ConsigneeConsignorGroup;

/*

Purpose:		Add a consignor / consignee / freight forwarder group

Date			Who		Reason
18/02/2013		cnwmh5	Initial creation

*/

vars

	pxyConsignGroup				: CM_ConsigneeConsignorGroup;
	consignGroup				: CM_ConsigneeConsignorGroup;
	
	consignColl					: CM_ConsignByCodeDict;
	
	description					: String;

begin

	self.deleteConsignGroup(_consignGroupID);
	
	if _consignColl = null then
		create consignColl transient;
	else
		_consignColl.copy(consignColl);
	endif;	
	
	create pxyConsignGroup transient;
	pxyConsignGroup.setProxy(_consignGroupID, _consignGroupDesc, consignColl);
	
	app.myTrxCA.trxCreateConsignGroup(pxyConsignGroup, consignGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	return consignGroup;

epilog

	delete pxyConsignGroup;
	delete consignColl;

end;</source>
        <Parameter name="_consignGroupID" type="String"/>
        <Parameter name="_consignGroupDesc" type="String"/>
        <Parameter name="_consignColl" type="CM_ConsignByCodeDict"/>
        <ReturnType type="CM_ConsigneeConsignorGroup"/>
    </JadeMethod>
    <JadeMethod name="addConsigneeConsignor" id="ec95f0ef-f728-45bf-b935-a5d0d0bb5caf">
        <source>addConsigneeConsignor(_code, _desc : String; _isConsignee, _isConsignor, _isFreightFwdr : Boolean) : CM_ConsigneeConsignor;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/08/2011	cnwmh5	Initial creation
25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 added isUsedForPacking attribute
02 Aug 2017	cnwma1	TFS #5209:PEN - Release Request Stop
*/

vars
	consignGroup			: CM_ConsigneeConsignorGroup;
	debtor					: CM_Debtor;
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	newConsigneeConsignor	: CM_ConsigneeConsignor;
	passport				: CM_Passport;
	license : String;
	licenseExpiryDate : Date;
	isUsedForPacking		: Boolean;				// PAR #35895
	isRestricted			: Boolean;	// 2.8.2017 cnwma1 TFS #5209
begin
	
	self.deleteConsigneeConsignor(_code);						// 18/09/2012 cnwmh5
	
	if self.opts.str( ETRow_ConsignGroupStr ) &lt;&gt; null then
		consignGroup	:= app.myRoot.allConsignGroups[ self.opts.str( ETRow_ConsignGroupStr ) ];
	endif;
	
	if self.opts.str( ETRow_DebtorStr ) &lt;&gt; null then
		debtor	:= app.myRoot.myRootCompany.debtors[ self.opts.str( ETRow_DebtorStr ) ];
	endif;
		
	if self.opts.includesKey( ETRow_License ) then
		license	:= opts.str(ETRow_License);
	endif;
	
	licenseExpiryDate := null;
	if opts.includesKey(ETRow_LicenseExpiryDate) then
		licenseExpiryDate := opts.str(ETRow_LicenseExpiryDate).Date;
	endif;
	
	isUsedForPacking := false;
	if opts.includesKey (ETRow_IsUsedForPacking) then
		isUsedForPacking := opts.str(ETRow_IsUsedForPacking).Boolean;
	endif;
	
	// 3.8.2017 cnwma1 TFS #5209
	if opts.includesKey (ETRow_IsRestricted) then
		isRestricted := opts.str(ETRow_IsRestricted).Boolean;
	endif;
	
	create proxyConsigneeConsignor transient;
	proxyConsigneeConsignor.setProxy( _code,												// Code
									  _desc,												// Description
									  self.opts.bool( ETRow_IsNotAvailableForEntry ),		// Available for entry
									  false,												// secure export partner
									  null,													// derogation number
									  null,													// email address
									  0,													// colour
									  0,													// order is always zero!
									  consignGroup,											// consignee/consignor group
									  debtor,												// debtor
									  false,												// show OOW remarks
									  _isConsignee,											// is consignee
									  _isConsignor,											// is consignor
									  _isFreightFwdr,										// is freight forwarder
									  null,													// PIN notify email address
									  license,												//cnwmc5 - 19/12/2012 - HAT 2198
									  licenseExpiryDate,									//cnwmc5 - 19/12/2012 - HAT 2198
									  isUsedForPacking,									// PAR #35895
									  isRestricted,
									  false); // 3.8.2017 cnwma1 TFS #5209
	
	app.myTrxCA.trxCreateConsigneeConsignor( proxyConsigneeConsignor, newConsigneeConsignor, app.myPassport );
	self.assertNoTrxErrorsOrWarnings();
	
	return newConsigneeConsignor;
	
epilog
	delete proxyConsigneeConsignor;
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_isConsignee" type="Boolean"/>
        <Parameter name="_isConsignor" type="Boolean"/>
        <Parameter name="_isFreightFwdr" type="Boolean"/>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="addConsigneeConsignorAddress" id="5462d0c3-c990-4841-8bff-4e94b1d0d484">
        <source>addConsigneeConsignorAddress(_code, _desc : String; _isConsignee, _isConsignor, _isFreightFwdr : Boolean;
							 _address1, _address2, _address3, _postCode, _region, _countryCode : String) : CM_ConsigneeConsignor;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/08/2011	cnwmh5	Initial creation
25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedforPacking attribute
*/

vars
	addressDetailsEntered	: Boolean;
	consignGroup			: CM_ConsigneeConsignorGroup;
	debtor					: CM_Debtor;
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	newConsigneeConsignor	: CM_ConsigneeConsignor;
	proxyAddress			: CM_Address;
	passport				: CM_Passport;

begin
	
	self.deleteConsigneeConsignor(_code);						// 18/09/2012 cnwmh5
	
	if self.opts.str( ETRow_ConsignGroupStr ) &lt;&gt; null then
		consignGroup	:= app.myRoot.allConsignGroups[ self.opts.str( ETRow_ConsignGroupStr ) ];
	endif;
	
	if self.opts.str( ETRow_DebtorStr ) &lt;&gt; null then
		debtor	:= app.myRoot.myRootCompany.debtors[ self.opts.str( ETRow_DebtorStr ) ];
	endif;

	if _address1 &lt;&gt; null or
	   _address2 &lt;&gt; null or
	   _address3 &lt;&gt; null or
	   _postCode &lt;&gt; null or
	   _region &lt;&gt; null or
	   _countryCode &lt;&gt; null then
		addressDetailsEntered := true;
	endif;
	// don't create a CM_Address if no address details entered
	if addressDetailsEntered then
		create proxyAddress transient;
		proxyAddress.update(_address1, _address2, _address3, _postCode, _region, _countryCode);
	endif;
	
	create proxyConsigneeConsignor transient;

	proxyConsigneeConsignor.setMyAddress(proxyAddress);
	proxyConsigneeConsignor.setProxy( _code,												// Code
									  _desc,												// Description
									  self.opts.bool( ETRow_IsNotAvailableForEntry ),		// Available for entry
									  false,												// secure export partner
									  null,													// derogation number
									  null,													// email address
									  0,													// colour
									  0,													// order is always zero!
									  consignGroup,											// consignee/consignor group
									  debtor,												// debtor
									  false,												// show OOW remarks
									  _isConsignee,											// is consignee
									  _isConsignor,											// is consignor
									  _isFreightFwdr,										// is freight forwarder
									  null,													// PIN notify email address
									  null,													//cnwmc5 - 19/12/2012 - HAT 2198
									  null,													//cnwmc5 - 19/12/2012 - HAT 2198
									  false,												// PAR #35895
									  false,
									  false); 												// 3.8.2017 cnwma1 TFS #5209
	
	app.myTrxCA.trxCreateConsigneeConsignor( proxyConsigneeConsignor, newConsigneeConsignor, app.myPassport );
	self.assertNoTrxErrorsOrWarnings();
	
	return newConsigneeConsignor;
	
epilog
	delete proxyConsigneeConsignor;
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_isConsignee" type="Boolean"/>
        <Parameter name="_isConsignor" type="Boolean"/>
        <Parameter name="_isFreightFwdr" type="Boolean"/>
        <Parameter name="_address1" type="String"/>
        <Parameter name="_address2" type="String"/>
        <Parameter name="_address3" type="String"/>
        <Parameter name="_postCode" type="String"/>
        <Parameter name="_region" type="String"/>
