    <JadeMethod name="setNoteForVoyage" id="767ef5aa-bef2-4798-9efa-636c8a19939d">
        <source>setNoteForVoyage(_oldVoyage, _voyage : CM_Voyage);
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
*/

vars
	tmpTermEvent : Integer;
	theDeck, oldDeck : CM_Deck;
begin
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; _voyage.String);
	

	tmpTermEvent := self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	if _oldVoyage &lt;&gt; null then
		self.endNotification(_oldVoyage, tmpTermEvent);
	endif;
	
	self.beginNotification(_voyage, tmpTermEvent, Response_Continuous, null);

	
	// PAR 28990
	tmpTermEvent := self.myTerminal.getTerminalEvent(EVENT_RORORotationUpdate);
	theDeck := self.getMyDeck();
	if theDeck &lt;&gt; null then
		self.beginNotification(theDeck, tmpTermEvent, Response_Continuous, null);
	endif;
epilog

end;</source>
        <Parameter name="_oldVoyage" type="CM_Voyage"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setScale" id="ece98bd3-9a65-4e92-806b-fc5591800f74">
        <updating/>
        <source>setScale(_scale : Real) updating;
/*
Date		    Who			Reason
14 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/
constants
	MaxZoom = 1.5;
	MinZoom = 1.0;
vars
	pc : Decimal[12,2];
begin	
	
	self.btnZoomPlus.enabled := (_scale &lt;&gt; MaxZoom);
	self.btnZoomMinus.enabled := (_scale &lt;&gt; MinZoom);
	pc := (100/(1/_scale));
	self.lblScale.caption := " " &amp; pc.asStringJMTWithPrecision(2, false) &amp; "%";
	
	self.scaleFactor := _scale;
	
epilog

end;</source>
        <Parameter name="_scale" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setStatusCaption" id="682502fb-37f5-4dc5-88e8-ca34888c318e">
        <source>setStatusCaption(_label : String; _suffix : Boolean);
/*
Purpose:			
Date			Who		Reason
02 August 2011	cnwab1	Initial creation
19/07/2012		cnwmh5	#29966 - Change to get details from Drawing Controller rather than slot
*/

vars
	tiTxt, tmpTxt, preTxt, sufTxt : String;
begin

	//if self.myCurrentROROSlotDefn &lt;&gt; null then
		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_Actual then
			//tiTxt := self.myCurrentROROSlotDefn.CM_ROROSlotDefnVoyage.mySlotController.getCargoDetail(REAL_MODE);
			tiTxt := self.getCargoDetailsSideView(REAL_MODE);
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_Proposed then
			//tiTxt := self.myCurrentROROSlotDefn.CM_ROROSlotDefnVoyage.mySlotController.getCargoDetail(PLANNING_MODE);
			tiTxt := self.getCargoDetailsSideView(PLANNING_MODE);
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			tiTxt := self.getCargoDetailsSideView(PLANNING_MODE);
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch then
			tiTxt := self.getCargoDetailsSideView(REAL_MODE);
		endif;
	//endif;
	
	if _label &lt;&gt; null  then
		if _suffix then
			sufTxt := _label;
		else
			preTxt := _label;
		endif;
	else
	endif;
	tmpTxt := preTxt &amp; " |  " &amp; app.getErrorString(Selected) &amp; ": " &amp; self.myROROLocnDrawingController.getNumSelected().asStringJMT() &amp; " | " &amp; tiTxt &amp; " | " &amp; sufTxt;
	self.frmStatus.caption := tmpTxt;

epilog

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_suffix" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUpPlannedToLCs" id="9428f99c-2fd8-4aca-940d-143d4bda5935">
        <updating/>
        <source>setUpPlannedToLCs() updating;
/*
Purpose:			
Date		Who		Reason
30 August 2011	cnwab1	Initial creation
*/

vars
	isLoad : Boolean;
	theLCs : CM_LCArray;
	theObj : Object;
	mcSet : Boolean;
	tmpController : SHP_ROROLocnDrawingController;
begin
	tmpController := self.myROROLocnDrawingController;


	isLoad := (tmpController.modeView = ShpDisplayMode_ColCodeLoad);
	
	if tmpController &lt;&gt; null 
	and tmpController.modeWork = SHP_ROROPlanningForm.WorkMode_Plan
	and tmpController.allSelectedObjects.size &gt; 0 then


		create theLCs transient;
		foreach theObj in tmpController.allSelectedObjects do
			if theObj.isKindOf(CM_VoyageROROController) then
				if isLoad then
					if theObj.CM_VoyageROROController.myRORORequestLoad = null then
						continue;
					endif;
				else
					if theObj.CM_VoyageROROController.myRORORequestDischarge = null then
						continue;
					endif;

				endif;
				
				theLCs.add(theObj.CM_VoyageROROController);
				if not mcSet then
					mcSet := true;
					if isLoad then
						self.setMoveControllerTarget(theObj.CM_VoyageROROController.myRORORequestLoad);
					else
						self.setMoveControllerTarget(theObj.CM_VoyageROROController.myRORORequestDischarge);
						
					endif;
				endif;
			elseif theObj.isKindOf(CM_RORORequest) then
				theLCs.add(theObj.CM_RORORequest.myROROController);
				if not mcSet then
					mcSet := true;
					self.setMoveControllerTarget(theObj.CM_RORORequest);
				endif;
			endif;
		endforeach;
		if isLoad and app.myMoveController &lt;&gt; null then		//cnwmc5 - 23 July 2013 - PAR 31350
			app.myMoveController.updateAllToLocations(theLCs);
		endif;
	endif;
	
epilog
	delete theLCs;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5ad75e95-3831-43e2-b0f5-c12546155cbf">
        <updating/>
        <source>setupForm() updating;
/*
Date		    Who			Reason
07 July 2011	cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
31 July 2012	cnwcs5		par 29124 - edi stowage remarks
*/

vars
	ti 			: CM_TrackedItem;
	array 		: CM_RORODeckItemLayoutArray;
	tmpUser 	: CM_User;
	terminal	: CM_Terminal;			// par 29124 July 2012	
	form		: SHP_ROROPlanningForm;	// par 29124 July 2012
begin
	inheritMethod();
	
	self.frmToolbar.alignContainer 	:= Frame.AlignContainer_Top;
	self.toolbarStyle 				:= self.ToolbarStyle_ShowNoHide;	
		
	self.mnuFile.visible 		:= false;
	self.mnuOptions.visible 	:= false;
	self.mnuTerminal.visible 	:= false;
	self.mnuHelp.visible 		:= false;
	self.mnuView1.visible 		:= false;
	self.mnuWindows.visible 	:= false;	
	
	self.doArrangeFramesAndGroups();
	
	form					:= self.myParentForm.SHP_ROROPlanningForm;
	self.myROROPlanningForm	:= form;
			
	create self.myROROLocnDrawingController transient;
	create array transient;
	create self.allOrderedROROLocns transient;

	self.setScale(1);
	self.allDeckItemLayouts.copy(array);
	
	tmpUser 	:= app.getMyUser();
	terminal	:= self.myTerminal;
	
	self.canAccessTodoTasksAddRemove	:= tmpUser.canAccessTodoTasksAddRemove(terminal);
	self.canAccessTodoTasksComplete 	:= tmpUser.canAccessTodoTasksComplete(terminal);
	
	self.doOrderROROLocns(array);
 	self.myROROLocnDrawingController.initFrames();
	self.changeViewMode(form.modeView);
	self.setNoteForVoyage(null, form.myCurrentVoyage);
	
	self.beginNotification(form, terminal.getTerminalEvent(ShowHide_CargoSideView), Response_Continuous, null);
	
	if self.btnViewExport.value then
		self.myROROLocnDrawingController.modeViewSubSub := ShpDisplayModeSub_ExportsShow; // PAR 31073
	else
		self.myROROLocnDrawingController.modeViewSubSub := ShpDisplayModeSub_ExportsHide; // PAR 31073
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCCModeDisch.enabled:= false;
		self.btnCCModeDLR.enabled:= false;
		self.btnCCModeErase.enabled:= false;
		self.btnCCModeSOB.enabled:= false;
		self.btnCCPalette.enabled:= false;
		self.btnCargoEdit.enabled:= false;
		
	endif;

epilog
	delete array;
end;</source>
    </JadeMethod>
    <JadeMethod name="showReturnCargoToYardForm" id="9d109eef-6044-4040-8c67-69a5bd6ce24e">
        <updating/>
        <source>showReturnCargoToYardForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2012	cnwmc5	Initial creation - PAR 29306

*/

vars
	tiArray : CM_TIArray;
begin
	
	create tiArray transient;
	
	self.getSelectedCellsTIs(tiArray);				//only the ones selected within the side view form
	
	
	if tiArray.isEmpty() then		
		app.msgBox("Select some cargo to return", "Return To Yard", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;
		
	self.myAssistant.showReturnCargoToYardForm(self.myROROPlanningForm.myCurrentVoyage, tiArray, self.myMasterMenuAction, true);
	
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="switchLocnDefns" id="5b88d16c-fb19-4c29-ab33-71cd1f43c8d0">
        <updating/>
        <source>switchLocnDefns(_it : Iterator; _locnDefn : CM_ROROLocnDefnVoyage; _row, _column : Integer; _locnDefnDict : CM_RORODeckItemByOrd1Ord2 io) updating;
/*
Date		    Who			Reason
23 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form 
*/

vars
	switchLocnDefn1,
	switchLocnDefn2,
	locnDefn			: CM_ROROLocnDefnVoyage;	
	iterator 			: Iterator;	
	row1,
	column1,
	row2,
	column2,
	row,
	column	 			: Integer;	
	stopLookingForRow,stopSkipping,
	stopLookingForColumn: Boolean;
	
begin
	iterator := _locnDefnDict.createIterator();
	
		while iterator.next(locnDefn) do
			_locnDefnDict.getIteratorKeys(row,column,iterator);
			if (row &lt;&gt; _row or column &lt;&gt; _column) and not stopSkipping then
				continue;
			elseif row=_row and column=_column and not stopSkipping then
				stopSkipping := true;
				continue;
			endif;
			if column = _column and not stopLookingForColumn then
				switchLocnDefn1 := locnDefn;
				row1 	:= row;
				column1 := column;
				stopLookingForColumn := true;
			elseif not stopLookingForRow then				
				if locnDefn.hasBeenFortyFootPlannedAft() then
					return;
				endif;
				switchLocnDefn2 := locnDefn;
				row2 	:= row;
				column2 := column;
				stopLookingForRow := true;			
			endif;
			if stopLookingForRow and stopLookingForColumn then
				_locnDefnDict.removeKeyEntry(row2,column2,switchLocnDefn2);
				_locnDefnDict.removeKeyEntry(row1,column1,switchLocnDefn1);
				_locnDefnDict.putAtKey(row1,column1,switchLocnDefn2);
				_locnDefnDict.putAtKey(row2,column2,switchLocnDefn1);
				return;
			endif;		
		endwhile;	
		if stopLookingForColumn then
			_locnDefnDict.removeKeyEntry(row1,column1,switchLocnDefn1);
			_locnDefnDict.putAtKey(_row,_column+1,switchLocnDefn1);
		endif;
epilog
	delete iterator;
end;</source>
        <Parameter name="_it" type="Iterator"/>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_locnDefnDict" type="CM_RORODeckItemByOrd1Ord2" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3dbfc418-aa68-43ab-95ed-2243880d3e65">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 November 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016644, locale);
	btnCCModeDLR.translateBubbleHelp(Xlat_0016645, locale);
	btnCCModeDLR.translateCaption(Xlat_0016646, locale);
