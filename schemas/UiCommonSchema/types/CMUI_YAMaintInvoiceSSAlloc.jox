    <JadeMethod name="doSave" id="5c4fce69-88cc-4c9b-95ff-a4c3e4267ee8">
        <updating/>
        <source>doSave() updating;

/*

Purpose:		TFS 6536	

Parameters:			

Return Value:		


Date			Who		Reason
04 Feb 2019	NDL	TFS 43153

*/

vars
	saveOk: Boolean;
	saveAs : Boolean;
	invalidYA	: Boolean;
	ya : CM_YardAllocation;
begin
	//par 19363
	invalidYA := false;
	on Exception do app.handleDeletedObject(exception, self.myYardAllocation, invalidYA);

	if self.myYardAllocation &lt;&gt; null then  //creating new YA
		if not self.isBulkEdit() then  //check self.myYardAllocation is single allocation edit
			create ya transient;
			//par 19363 if self.myYardAllocation is invalid exception occurs and invalidYA set to true
			ya.setCode(self.myYardAllocation.code);  
			
			if invalidYA = true then
				saveAs := true;
			else
				saveAs := false;
			endif;
		endif;
	endif;

	if self.isBulkEdit() then
		saveOk := self.saveDataBulk(false);
	else
		saveOk := self.saveData(saveAs);  //originally 'false', but set to saveAs if invalid object or not
	endif;
	
	if saveOk then
		self.unloadForm();
	endif;
epilog
	delete ya;
end;</source>
    </JadeMethod>
    <JadeMethod name="formatDescription" id="d87bd8f7-1f21-4e95-ad55-3c164693a351">
        <source>formatDescription();
/*
Purpose:			
Date				Who			Reason
04 Feb 2019	NDL	TFS 43153
*/

vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaValue	: Any;
	i				: Integer;
	groupName		: String;
	yaTemplate		: CM_YATemplate;
	bValue 			: Any;

	yaConfig: CM_YAConfig;
	yaIMEXConfig: CM_YAIMEXConfig;
	yaCriteriaType : CM_YACriteriaType;

	term : CM_Terminal;
	
	existingName : String;
	
begin
	term := self.getTerminal();
	
	//09 Jan 2016	NDL	TFS 3174 - This week Steve says, don't regenerate an existing name..
	if self.myYardAllocation &lt;&gt; null and self.txtDescription.text.trimBlanks &lt;&gt; null then
		existingName := self.myYardAllocation.description;
	endif;

	if existingName &lt;&gt; null then//09 Jan 2016	NDL	TFS 3174
		groupName := existingName;
		
	else
		while true do
			i := i + 1;
			criteriaCtrl := self.frmCriteria.getControl(i);
			if criteriaCtrl = null then
				break;
			endif;
			if criteriaCtrl.visible then
				criteriaValue := criteriaCtrl.getDisplayForGroupNameNumbers();
				if criteriaValue &lt;&gt; null then
					bValue := criteriaCtrl.getValue();
					if bValue &lt;&gt; null then
						if (bValue &lt;&gt; criteriaValue and bValue.Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE) 
						or	bValue = criteriaValue then
							if groupName = "" then // TFS 7496 was putting a blank at the begging of each description
								groupName := criteriaValue.String; // TFS 7496
							else
								groupName := groupName &amp; " " &amp; criteriaValue.String;
							endif;
						endif;
					endif;
				endif;
			endif;
		endwhile;
	endif;

	
	txtGroupName.text := groupName;
	
	yaTemplate := cmbYATemplate.listObject.CM_YATemplate;

	if yaTemplate = null then
		txtDescription.text := groupName;
	else
		txtDescription.text := groupName &amp; " - " &amp; yaTemplate.code;
	endif;
epilog

end;</source>
    </JadeMethod>
