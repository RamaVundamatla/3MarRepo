    <JadeMethod name="doCreateCriteriaLine" id="f40a52ff-1be3-4f7b-98d6-779b135c10ef">
        <source>doCreateCriteriaLine(	_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	criteriaLine : CM_SelectorCriteriaLine;

begin

	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="tCashPaymentQuery" id="6ef71d46-3399-461b-84c2-596596ce8381">
        <source>tCashPaymentQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerCashPayment;
	cashPayment : CM_CashPayment;
	dr : CM_Debtor;
	bank : CM_Bank;
	term : CM_Terminal;
	drTerm : CM_DebtorTerminal;

begin

	self.opts.addAssoc("Terminal","CASH");
	term := self.getTerminal;

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Cash_Query_Type,CM_QueryDefinition.CashPayment_Query_Mode];
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CM_CashPaymentSet transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	// Add some basic criteria
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_CashPayment::myTerminal.name, CM_QReferenceLookup.Operator_Equal, term);
	
//	dr := app.myRoot.myRootCompany.debtors["UT_CashDebtor1"];
//	self.assertTrueMsg( dr &lt;&gt; null, "Debtor UT_CashDebtor1 not found. Pre-test.");
	dr := app.myRoot.myRootCompany.debtors["CA- Salam"];
	self.assertTrueMsg( dr &lt;&gt; null, "Debtor CA- Salam not found. Pre-test.");
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_CashPayment::getDebtor.name, CM_QueryOperator.Operator_Equal, dr);
	
	drTerm := term.allDebtorTerminals.getAtKey( dr );
	
	// call the query
	myEnqController.doQuery( qDef );
	
	//check we found some.
	self.assertTrueMsg( not myEnqController.allObjects.CM_CashPaymentSet.isEmpty, "Did not find any Cash Payments. Possible error.");
	
	//check each of the ones we got is correct
	foreach cashPayment in myEnqController.allObjects.CM_CashPaymentSet do
		if cashPayment.myTerminal &lt;&gt; self.getTerminal then
			self.assertTrueMsg( false, "Cash Payment " &amp; cashPayment.getDescription &amp; " terminal not " &amp; self.getTerminal.code );
		endif;
		if cashPayment.getDebtor &lt;&gt; dr then
			self.assertTrueMsg( false, "Cash Payment " &amp; cashPayment.getDescription &amp; " debtor not " &amp; dr.name );
		endif;
	endforeach;
	
	//check we got all we should have.
	foreach cashPayment in term.allCashPayments do
		if cashPayment.myTerminal &lt;&gt; self.getTerminal then
			continue;
		endif;
		if cashPayment.getDebtor &lt;&gt; dr then
			continue;
		endif;
		if cashPayment.myDebtorTerminal &lt;&gt; drTerm then
			continue;
		endif;
		if not myEnqController.allObjects.CM_CashPaymentSet.includes( cashPayment ) then
			self.assertTrueMsg( false, "Cash Payment " &amp; cashPayment.getDescription &amp;  " should have been in the query results." );
		endif;
	endforeach; 
	

epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptQuery" id="bd0bc382-8f8d-4a26-8df8-1b18f16f8a91">
        <source>tCashReceiptQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerCashReceipt;
	cashReceipt : CM_CashReceipt;
	dr : CM_Debtor;
	bank : CM_Bank;
	obj : Object;
	iter : Iterator;
	drTerm : CM_DebtorTerminal;
	
begin

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Cash_Query_Type,CM_QueryDefinition.CashReceipt_Query_Mode];
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  ObjectSet transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	// Add some basic criteria
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_CashReceipt::myTerminal.name, CM_QReferenceLookup.Operator_Equal, self.getTerminal);
	
//	dr := app.myRoot.myRootCompany.debtors["UT_CashDebtor1"];
//	self.assertTrueMsg( dr &lt;&gt; null, "Debtor UT_CashDebtor1 not found. Pre-test.");
//	dr := app.myRoot.myRootCompany.debtors["UT_Cash3"];
//	self.assertTrueMsg( dr &lt;&gt; null, "Debtor UT_Cash3 not found. Pre-test.");
	
	//find a debtor with cash receipts.
	iter := self.getTerminal.allDebtorTerminals.createIterator;
	while iter.next( drTerm ) do
		if drTerm.allCashReceipts.isEmpty then
			continue;
		endif;
		dr := drTerm.myDebtor;
		break;
	endwhile;
	self.assertTrueMsg( dr &lt;&gt; null, "No Debtor with Cash receipts found. Pre-test.");
	
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_CashReceipt::getDebtor.name, CM_QueryOperator.Operator_Equal, dr);
	
	// call the query
	myEnqController.doQuery( qDef );
	
	//check we found some.
	self.assertTrueMsg( not myEnqController.allObjects.ObjectSet.isEmpty, "Did not find any Cash Receipts. Possible error.");
	
	//check each of the ones we got is correct
	foreach obj in myEnqController.allObjects.ObjectSet do
		cashReceipt := obj.CM_CashReceipt;
		if cashReceipt.myTerminal &lt;&gt; self.getTerminal then
			self.assertTrueMsg( false, "Cash Receipt " &amp; cashReceipt.getDescription &amp; " terminal not " &amp; self.getTerminal.code );
		endif;
		if cashReceipt.getDebtor &lt;&gt; dr then
			self.assertTrueMsg( false, "Cash Receipt " &amp; cashReceipt.getDescription &amp; " debtor not " &amp; dr.name );
		endif;
	endforeach;
	
	//check we got all we should have.
	foreach cashReceipt in self.getTerminal.allCashReceipts do
		if cashReceipt.myTerminal &lt;&gt; self.getTerminal then
			continue;
		endif;
		if cashReceipt.getDebtor &lt;&gt; dr then
			continue;
		endif;
		if not myEnqController.allObjects.ObjectSet.includes( cashReceipt ) then
			self.assertTrueMsg( false, "Cash Receipt " &amp; cashReceipt.getDescription &amp;  " should have been in the query results." );
		endif;
	endforeach; 
	

epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCollectionQueryIncludesAllOf" id="70c19f0c-bee7-4dd9-8721-b2a5ed9f767e">
        <updating/>
        <source>tCollectionQueryIncludesAllOf() updating;
// cnwns1
// cnwjre1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwpjs1	Initial creation  PAr # 31237

*/

vars
	agent 				: CM_QueryBuilderAgent;
	ti1, ti2			: CM_TrackedItem;
	realTI				: CM_TrackedItem;
	results				: CM_TISet;
	obj					: Object;
	msg					: String;
	ids					: StringArray;
	iter				: Iterator;
	trans				: CM_TITransaction;
	now					: Date;
	sl1					: CM_SpecialLift;
	sl2					: CM_SpecialLift;
	specialLifts		: CM_SpecialLiftByCodeDict;
	objSet				: ObjectSet;
	
begin

	sl1 := app.myRoot.allSpecialLifts.first;
	sl2 := app.myRoot.allSpecialLifts.last;

	// bale out of test if we dont have two Special lifts available
	if sl1 = null or sl2 = null or (sl1 = sl2) then
		return;
	endif;
	
	create specialLifts transient;

	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000011");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	
	specialLifts.clear;
	specialLifts.add(sl1);
	specialLifts.add(sl2);
	self.opts.purge;
	self.opts.addAssoc(UTTI_SpecialLifts, specialLifts);
	ti1 := self.addContainer("UUTU0000011", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.opts.purge;
	self.deleteContainer("UUTU0000012");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	specialLifts.clear;
	specialLifts.add(sl1);
	self.opts.addAssoc(UTTI_SpecialLifts, specialLifts);
	ti2 := self.addContainer("UUTU0000012", self.getOperator('UTO2'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	// UT0000011 includes SL1 and Sl2   UT0000012 only has SL1
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	
	create objSet transient;
	objSet.add(sl1);
	objSet.add(sl2);
	
	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('allSpecialLifts', CM_QueryOperator.Operator_IncludesAllOf, objSet);
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	create ids transient;
	iter := results.createIterator;
	
	while iter.next(obj) do
		msg := msg &amp; CrLf &amp; obj.String &amp; ":" &amp; obj.CM_TrackedItem.id;
	endwhile;

	assertTrueMsg(results.includes(ti1), msg &amp; CrLf &amp; CrLf &amp; "Missing " &amp; ti1.String&amp;":"&amp;ti1.CM_TrackedItem.id);
	
	assertFalseMsg(results.includes(ti2), msg &amp; CrLf &amp; CrLf &amp; "Should not include " &amp; ti2.String&amp;":"&amp;ti2.CM_TrackedItem.id);
		
epilog

	delete agent;
	delete results;
	delete iter;
	delete ids;
	delete specialLifts;
	delete objSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCollectionQueryIncludesNoneOf" id="2396d29e-73e0-4fae-913b-effc18a88fa1">
        <updating/>
        <source>tCollectionQueryIncludesNoneOf() updating;
// cnwndl1
// cnwjre1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwpjs1	Initial creation  PAr # 31237

*/

vars
	agent 				: CM_QueryBuilderAgent;
	ti1, ti2			: CM_TrackedItem;
	realTI				: CM_TrackedItem;
	results				: CM_TISet;
	obj					: Object;
	msg					: String;
	ids					: StringArray;
	iter				: Iterator;
	trans				: CM_TITransaction;
	now					: Date;
	sl1					: CM_SpecialLift;
	sl2					: CM_SpecialLift;
	specialLifts		: CM_SpecialLiftByCodeDict;
	objSet				: ObjectSet;
	
begin

	sl1 := app.myRoot.allSpecialLifts.first;
	

	// bale out of test if we dont have a Special lifts available
	if sl1 = null then
		return;
	endif;
	
	create specialLifts transient;

	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000011");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	
	specialLifts.clear;
	specialLifts.add(sl1);
	
	self.opts.purge;
	self.opts.addAssoc(UTTI_SpecialLifts, specialLifts);
	ti1 := self.addContainer("UUTU0000011", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.opts.purge;
	self.deleteContainer("UUTU0000012");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);

	ti2 := self.addContainer("UUTU0000012", self.getOperator('UTO2'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	// UT0000011 includes SL1   UT0000012 does not have any
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	
	create objSet transient;
	objSet.add(sl1);

	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('allSpecialLifts', CM_QueryOperator.Operator_IncludesNoneOf, objSet);
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	create ids transient;
	iter := results.createIterator;
	
	// dont include outoput.. picks up all other containerss
//	while iter.next(obj) do
//		msg := msg &amp; CrLf &amp; obj.String &amp; ":" &amp; obj.CM_TrackedItem.id;
//	endwhile;

	assertFalseMsg(results.includes(ti1), "Should not include " &amp; ti1.String&amp;":"&amp;ti1.CM_TrackedItem.id);
	
	assertTrueMsg(results.includes(ti2), "Missing " &amp; ti2.String&amp;":"&amp;ti2.CM_TrackedItem.id);
		
epilog

	delete agent;
	delete results;
	delete iter;
	delete ids;
	delete specialLifts;
	delete objSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCollectionQueryIncludesOneOf" id="6db67de9-52ac-4ca2-bced-0f61a8691404">
        <updating/>
        <source>tCollectionQueryIncludesOneOf()  updating;
// cnwns1
// cnwjre1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2013	cnwpjs1	Initial creation  PAR #31327

*/

vars
	agent 				: CM_QueryBuilderAgent;
	ti1, ti2			: CM_TrackedItem;
	realTI				: CM_TrackedItem;
	results				: CM_TISet;
	obj					: Object;
	msg					: String;
	ids					: StringArray;
	iter				: Iterator;
	trans				: CM_TITransaction;
	now					: Date;
	sl1					: CM_SpecialLift;
	sl2					: CM_SpecialLift;
	specialLifts		: CM_SpecialLiftByCodeDict;
	objSet				: ObjectSet;
	
begin

	sl1 := app.myRoot.allSpecialLifts.first;
	
	// bale out of test if not Special lifts defined
	if sl1 = null then
		return;
	endif;
	
	create specialLifts transient;

	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000011");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	
	specialLifts.clear;
	specialLifts.add(sl1);
	self.opts.purge;
	self.opts.addAssoc(UTTI_SpecialLifts, specialLifts);
	ti1 := self.addContainer("UUTU0000011", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.opts.purge;
	self.deleteContainer("UUTU0000012");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti2 := self.addContainer("UUTU0000012", self.getOperator('UTO2'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	// UT0000011 includes SL1
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	
	create objSet transient;
	objSet.add(sl1);
	
	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('allSpecialLifts', CM_QueryOperator.Operator_IncludesOneOf, objSet);
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	create ids transient;
	iter := results.createIterator;
	
	while iter.next(obj) do
		msg := msg &amp; CrLf &amp; obj.String &amp; ":" &amp; obj.CM_TrackedItem.id;
	endwhile;

	assertTrueMsg(results.includes(ti1), msg &amp; CrLf &amp; CrLf &amp; "Missing " &amp; ti1.String&amp;":"&amp;ti1.CM_TrackedItem.id);
		
epilog

	delete agent;
	delete results;
	delete iter;
	delete ids;
	delete specialLifts;
	delete objSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCriteriaYardAllocation" id="d621a8fb-e6b4-4067-bbd2-18065ba5f5ac">
        <updating/>
        <source>tCriteriaYardAllocation() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars
	agent : CM_QueryBuilderAgent;
	ti1, ti2, ti3, ti4: CM_TrackedItem;
	results: CM_TISet;
	obj: Object;
	msg: String;
	iter: Iterator;
	term : CM_Terminal;
	ya : CM_YardAllocation;
	yaNot : CM_YardAllocation;
	yaDict : ObjectSet;
	cargoType : CM_CargoType;
	locations: CM_LCArray;
	bsNot : CM_BlockStack;
begin

	term := getTerminal;

	self.deleteYA("UTQUERY_YA");
	self.deleteYA("UTQUERY_YANOT");
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	self.deleteTerminalArea("BS_30S");
	
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	bsNot := addBlockStack("BS_30S", 100, null);
	create locations transient;
	locations.add( bs.myLocationsController );
	ya := self.addYA1("UTQUERY_YA", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	locations.clear();
	locations.add( bsNot.myLocationsController );
	yaNot := self.addYA1("UTQUERY_YANOT", YACriteriaType_IsThirty, true, locations);

	self.deleteContainer("UTYA0000001");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	ti1 := self.addContainer("UTYA0000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.deleteContainer("UTYA0000002");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti2 := self.addContainer("UTYA0000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	self.deleteContainer("UTYA0000003");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	ti3 := self.addContainer("UTYA0000003", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("UTYA0000004");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti4 := self.addContainer("UTYA0000004", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti4, bs);
	assertTrue(ti4.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti4.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	
	create results transient;
	create yaDict transient;
	yaDict.add(ya);
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
	create agent transient;	
	agent.setResultArray(results);
	agent.setQueryMode(cargoType);
	agent.addCriteria('site', 'equal to', TI_SITE_ONSITE);
	agent.addCriteria('myTerminal', 'equal to', term);
	agent.addCriteria('cargoType', 'equal to', cargoType);
	agent.addCriteria('getAllocationsForMyTermArea', 'is one of', yaDict);
	agent.doQuery();	
	assertTrueMsg(results.size &gt; 0, "Test 1 results empty!!");	
	assertTrueMsg(results.includes(ti1), "Test 1 results should include " &amp; ti1.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti2), "Test 1 results should include " &amp; ti2.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti3), "Test 1 results should include " &amp; ti3.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti4), "Test 1 results should include " &amp; ti4.CM_TrackedItem.id);	
	delete agent;
	results.clear();
	yaDict.clear();
	
	create agent transient;	
	agent.setResultArray(results);
	agent.setQueryMode(cargoType);
	agent.addCriteria('site', 'equal to', TI_SITE_ONSITE);
	agent.addCriteria('myTerminal', 'equal to', term);
	agent.addCriteria('cargoType', 'equal to', cargoType);
	agent.addCriteria('getAllocationsForMyTermArea', 'contains', "TQUER");
	agent.doQuery();	
	assertTrueMsg(results.size &gt; 0, "Test 2 results empty!!");	
	assertTrueMsg(results.includes(ti1), "Test 2 results should include " &amp; ti1.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti2), "Test 2 results should include "  &amp; ti2.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti3), "Test 2 results should include "  &amp; ti3.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti4), "Test 2 results should include "  &amp; ti4.CM_TrackedItem.id);	
	delete agent;
	results.clear();
	
	yaDict.add(yaNot);
	create agent transient;	
	agent.setResultArray(results);
	agent.setQueryMode(cargoType);
	agent.addCriteria('site', 'equal to', TI_SITE_ONSITE);
	agent.addCriteria('myTerminal', 'equal to', term);
	agent.addCriteria('cargoType', 'equal to', cargoType);
	agent.addCriteria('getAllocationsForMyTermArea', 'is one of', yaDict);
	agent.doQuery();	
	assertTrueMsg(results.size = 0, "Test 3 results NOT empty!!");	
	assertTrueMsg(not results.includes(ti1), "Test 3 results should NOT include " &amp; ti1.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti2), "Test 3 results should NOT include "  &amp; ti2.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti3), "Test 3 results should NOT include "  &amp; ti3.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti4), "Test 3 results should NOT include " &amp; ti4.CM_TrackedItem.id);	
	delete agent;
	results.clear();
	yaDict.clear();
	
	self.move(ti1, bsNot);
	yaDict.add(yaNot);
	create agent transient;	
	agent.setResultArray(results);
	agent.setQueryMode(cargoType);
	agent.addCriteria('site', 'equal to', TI_SITE_ONSITE);
	agent.addCriteria('myTerminal', 'equal to', term);
	agent.addCriteria('cargoType', 'equal to', cargoType);
	agent.addCriteria('getAllocationsForMyTermArea', 'is one of', yaDict);
	agent.doQuery();
	assertTrueMsg(results.size &gt; 0, "Test 4 results empty!!");	
	assertTrueMsg(results.includes(ti1), "Test 4 results should include " &amp; ti1.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti2), "Test 4 results should NOT include "  &amp; ti2.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti3), "Test 4 results should NOT include "  &amp; ti3.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti4), "Test 4 results should NOT include " &amp; ti4.CM_TrackedItem.id);	
	delete agent;
	results.clear();
	yaDict.clear();
	
	create agent transient;	
	agent.setResultArray(results);
	agent.setQueryMode(cargoType);
	agent.addCriteria('site', 'equal to', TI_SITE_ONSITE);
	agent.addCriteria('myTerminal', 'equal to', term);
	agent.addCriteria('cargoType', 'equal to', cargoType);
	agent.addCriteria('isInAllocation', 'equal to', true);
	agent.doQuery();	
	assertTrueMsg(results.size &gt; 0, "Test 5 results empty!!");	
	assertTrueMsg(results.includes(ti1), "Test 5 results should include " &amp; ti1.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti2), "Test 5 results should NOT include " &amp; ti2.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti3), "Test 5 results should NOT include " &amp; ti3.CM_TrackedItem.id);
	assertTrueMsg(not results.includes(ti4), "Test 5 results should NOT include " &amp; ti4.CM_TrackedItem.id);	
	delete agent;
	results.clear();
	yaDict.clear();
	
epilog
	delete agent;
	delete results;
	delete iter;
	delete yaDict;
	delete locations;
end;</source>
