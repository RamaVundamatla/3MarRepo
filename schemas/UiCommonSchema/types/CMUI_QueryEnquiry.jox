    <JadeMethod name="doTblInfoContextMenu" id="7de0049c-7ef4-4021-ab1d-706b417406b7">
        <updating/>
        <source>doTblInfoContextMenu(_cntrl: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By cnwyl1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars

	xLeft 	: Real;
	yTop	: Real;
begin
	xLeft := _x;
	yTop := _y;

	_conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   

	self.mnuContextTable.visible := true;
	self.mnuContextHide.visible := true;

	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);

end;</source>
        <Parameter name="_cntrl" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblInfoDbClick" id="0efaa2fe-8b6b-48c5-a1c3-2edea707f0b7">
        <updating/>
        <source>doTblInfoDbClick(table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29 Nov 2024 navtr3 CR 14783: CUX - Wagon Enquiry Insufficient Permission.
vars

	obj	: Object;
begin
	if table.row &lt;= table.fixedRows or table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then

		if obj.isKindOf(CM_GridController) then
			self.myAssistant.showTerminalAreaForm(obj.CM_LocationsController.myTerminalArea, self.myMasterMenuAction);
		elseif obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		elseif obj.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(obj.CM_Voyage, self.myMasterMenuAction, false, false);
		elseif obj.isKindOf(CM_Wagon) then //29.11.2024 navtr3 #14783
			self.myAssistant.showCargoEnquiryForTIs(obj.CM_Wagon.allTIsReceived.first.CM_TrackedItem, obj.CM_Wagon.allTIsReceived, self.myMasterMenuAction, false);
		elseif obj.isKindOf(CM_SlotController) or 
			   obj.isKindOf(CM_SlotDefn) or 
			   obj.isKindOf(CMUI_GridPoint) or 
			   obj.isKindOf(CM_SlotRequest) or 
			   obj.isKindOf(CM_Bay) or 
			   obj.isKindOf(CM_WorkListEntry) or
			   obj.isKindOf(CM_Transaction) or
			   obj.isKindOf(CM_FinancialObject) or
			   obj.isKindOf(CM_VoyageJob) then  //par 18255
			if app.isAllowedToInspect() then
				obj.inspect;
			endif;

		elseif obj.isKindOf(CM_Object) then
			if app.isAllowedToInspect() then
				obj.inspect;
			endif;
			self.myAssistant.showTableMaintForm(obj.CM_Object, self.myMasterMenuAction, true, true);
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
