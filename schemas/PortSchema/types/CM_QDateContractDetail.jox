<Class name="CM_QDateContractDetail" id="1d93e6a3-0e63-4977-b148-ca97a8101129">
    <superclass name="CM_QDateProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="8c790cec-046b-4313-93f4-0e0ae4e7eae6">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
// -----------------------------------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.clear;
	
	create oper as CM_QDateRangeArray persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="5eaeae60-6c01-4b87-ad39-2b91bc70d344">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars

begin
	return _obj.sendMsg(self.propertyName).DateArray;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
