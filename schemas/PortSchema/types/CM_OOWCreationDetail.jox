		return true;
	elseif self.loadEXP40 &lt;&gt; null then
		return true;
	elseif self.loadREF40 &lt;&gt; null then
		return true;
	elseif self.loadSOB40 &lt;&gt; null then
		return true;
	elseif self.loadTSH40 &lt;&gt; null then
		return true;
 // PAR 16415 CCMS 1029
	elseif self.loadDLR30 &lt;&gt; null then
		return true;
	elseif self.loadEXP30 &lt;&gt; null then
		return true;
	elseif self.loadREF30 &lt;&gt; null then
		return true;
	elseif self.loadSOB30 &lt;&gt; null then
		return true;
	elseif self.loadTSH30 &lt;&gt; null then
		return true;
		
	elseif self.loadDLR53 &lt;&gt; null then
		return true;
	elseif self.loadEXP53 &lt;&gt; null then
		return true;
	elseif self.loadREF53 &lt;&gt; null then
		return true;
	elseif self.loadSOB53 &lt;&gt; null then
		return true;
	elseif self.loadTSH53 &lt;&gt; null then
