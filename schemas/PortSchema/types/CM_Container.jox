    <JadeMethod name="assignToDoTaskCheck" id="cee2f541-dd36-439d-9bc6-b47558493fc7">
        <source>assignToDoTaskCheck(_theTaskDesc: CM_ToDoTaskDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		certain parts of todo task temple do not apply. In this case set all the todo tasks excpet maybe Requires washing and requries PTI
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	taskDescW,taskDescP 	: CM_ToDoTaskDesc;
	task		: CM_ToDoTask;
	lToDoTaskWashed, 
	lToDoTaskPTI : String;
	lToDoTaskTO : Boolean;
	startPos : Integer;
begin

	// CCMS 1029 get these todo tasks, then check whether we are automatically generating these tasks for this TI
	lToDoTaskPTI := self.myTerminal.getConfig(ToDoTaskPTI).String;
	lToDoTaskWashed := self.myTerminal.getConfig(ToDoTaskWashed).String;
	
	// PAR 7185 NOTE these are stored as oids but with the class name prefixed i.e. CM_ToDoTaskDesc/2632.19
	// so we need to strip the class name off.
	if lToDoTaskWashed &lt;&gt; null then
		startPos := lToDoTaskWashed.pos("/",1);
		if startPos &gt; 0 then
			lToDoTaskWashed := lToDoTaskWashed[startPos + 1:end];
		endif;
		taskDescW := lToDoTaskWashed.asOid.CM_ToDoTaskDesc;
	endif;
	if lToDoTaskPTI &lt;&gt; null then
		startPos := lToDoTaskPTI.pos("/",1);
		if startPos &gt; 0 then
			lToDoTaskPTI := lToDoTaskPTI[startPos + 1:end];
		endif;
		taskDescP := lToDoTaskPTI.asOid.CM_ToDoTaskDesc;
	endif;
	// is the system setup to do this
	lToDoTaskTO := self.myTerminal.getConfig(ToDoTaskTemplateOffsite).Boolean;

	if lToDoTaskTO then
		if taskDescW = _theTaskDesc and self.offsiteCleaned then
			return false;
		//PAR16426 this should be checking the offsitePreTrip flag, not the offsiteCleaned. Changed 10/4/2008
		elseif taskDescP = _theTaskDesc and self.offsitePreTrip then//offsiteCleaned then
			return false;
		endif;
	endif;

	return inheritMethod(_theTaskDesc);
	//return true;
	
end;</source>
        <Parameter name="_theTaskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignToDoTasksFromTemplate" id="fd5f362c-414c-48eb-a3c4-883580ec002d">
        <updating/>
        <source>assignToDoTasksFromTemplate(pTemplate: CM_ToDoTemplate; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pTemplate, _passport);

	// Par 9178. Otago do not want availability grades over ridden if they have
	// already been set during the receival process. 
	
	//Par 9996.  Changed again so that users can set which ava grades are valid to update (checked in self.isMatchedToDoTemplate)
	
	if pTemplate.availabilityGradeToApply &lt;&gt; null then
		self.availabilityGrade := pTemplate.availabilityGradeToApply.code;
	endif;	

end;</source>
        <Parameter name="pTemplate" type="CM_ToDoTemplate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="attachCOU" id="9ca48cee-8b29-43f1-84b3-eee19e3eb90c">
        <updating/>
        <source>attachCOU(theCOU: CM_ClipOnUnit input; _passport : CM_Passport input) updating;
/* This attaches the COU. Note that the COU is not a child item as it is not within
the container. Use a property 'myReefer' on the COU

29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
*/
vars
	lTask : CM_ToDoTaskDesc;
	lDesc : String;
begin

	exclusiveLock(self);
	
	if self.isTransient and self.getCou = theCOU then
		return;
	endif;

	// Check that COU is allowed to be attached. Rule - must be a portHole
	if not self.isPortHole() then	// added as a bug fix Xpose 1192 RDD 26/7/01
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_NOT_A_PORTHOLE, self.id, "and cannot have a COU attached", null, null);
		// modified ERR_NOT_A_PORTHOLE to accept second parameter
	endif;

	// Check that we don't already have a COU...
	if self.getCou &lt;&gt; null and self.getCou &lt;&gt; theCOU then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ALREADY_ATTACHED, self.id, "has COU " &amp; self.getCou.id, null, null);
	endif;

	// Check that the child is a COU..
	if not theCOU.isKindOf(CM_ClipOnUnit) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_TI_TYPE, null, null);
	endif;

	exclusiveLock(theCOU);

	// Check that the cou is not already attached or inside something else...
	if theCOU.myParent &lt;&gt; null or 
	   theCOU.CM_ClipOnUnit.myReefer &lt;&gt; null and 
	   theCOU.CM_ClipOnUnit.myReefer &lt;&gt; self then 
		if self.getCou &lt;&gt; null then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_ALREADY_ATTACHED, self.id, "has COU " &amp; self.getCou.id, null, null);
		else 
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_ALREADY_ATTACHED, theCOU.id, theCOU.CM_ClipOnUnit.myReefer.id, null, null);
		endif;
	endif;

	//Set links between items
	self.setCou(theCOU.CM_ClipOnUnit);	//cou.myReefer is auto inverse
  	//Update location strings. Note that a COU is not known to
  	//the location controller in which the parent is held, so this
  	//code will suffice
	theCOU.locationId := self.locationId;
	theCOU.plannedLocnId := self.plannedLocnId;
	theCOU.rehandleLocnId := self.rehandleLocnId;
	
	// CCMS 1010 AKB2002JAN from here
	if (not self.isTransient) and self.getTemperature = NULL_TEMPERATURE then
		lDesc := null;
		foreach lTask in app.myRoot.allToDoTaskDescriptions 
			where lTask.type = TODO_TYPE_GROUP_TI do 						// ### TFS #56634[54259] 22NOV2022 NAVAB1
			
			if lTask.trxTypeOnCompletion = TRANS_TYPE_TEMP_SET then
				lDesc := lTask.description.trimBlanks;
			endif;
		endforeach;
		
		if lDesc &lt;&gt; null then
			self.addToDoTask(lDesc, _passport);
		endif;
	endif;
	// CCMS 1010 AKB2002JAN to here

	if (not self.isTransient) then		//Don't add transients to terminal dicts
		//Update Voyage of COU
		if theCOU.myVoyage &lt;&gt; self.myVoyage and self.myVoyage &lt;&gt; null then
			theCOU.changeVoyage(self.myVoyage, _passport);
		endif;

		//Last thing. Make SURE our STATE is correct. DQ 23/10/97
		//This fixes a bug in EDI load, where any COU's/Children are NOT
		//added to the EDI bayplans ti dict.
		theCOU.changeState(self.state, _passport);

		self.updateObjectEdition(self);	// par 30292
	else								//Just set the properties directly
		theCOU.myVoyage := self.myVoyage;
		theCOU.state 	:= self.state;

	endif;
end;</source>
        <Parameter name="theCOU" type="CM_ClipOnUnit" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="attachChild" id="1acfc4a2-a849-4f2d-bd53-0846c0d58b91">
        <updating/>
        <source>attachChild(theChild: CM_TrackedItem input;
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.getCou = theChild then // Xpose 1439 AKB2001NOV - a COU that is refereced in the TI.COU reference cannot be in the childrens collection
		return;
	endif;

	inheritMethod(theChild, _passport);


end;</source>
        <Parameter name="theChild" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="attachGenerator" id="a8a304c4-858c-4757-bbf3-0b3012b980e9">
        <updating/>
        <source>attachGenerator(theGenerator: CM_Generator input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:      18 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
// 21 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking

vars
	lTask	: CM_ToDoTaskDesc;
	lDesc	: String;
	task	: CM_ToDoTask;
	tmpPriorLocation : CM_LocationsController;
	
begin
	exclusiveLock(self);
	
	if self.isTransient and self.getGenerator = theGenerator then
		return;
	endif;

	// Check that we don't already have a generator...
	if self.getGenerator &lt;&gt; null and self.getGenerator &lt;&gt; theGenerator then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ALREADY_ATTACHED, self.id, "generator " &amp; self.generator.id, null, null);
	endif;

	exclusiveLock(theGenerator);

	tmpPriorLocation := theGenerator.myPrimaryActualLocation;	//Par17972. We have to save prior location for generator

	//Set links between items
	self.setGenerator(theGenerator);
  	//Update location strings. Note that a generator is not known to
  	//the location controller in which the parent is held, so this
  	//code will suffice
	theGenerator.locationId := self.locationId;
	theGenerator.plannedLocnId := self.plannedLocnId;
	theGenerator.rehandleLocnId := self.rehandleLocnId;
	
	// Par17775. ccms1405. APM Yard Ops, new generator types. 
	self.attachGeneratorNoseMounted( theGenerator, tmpPriorLocation, _passport );
	
	// CCMS 1010 AKB2002JAN from here
	if (not self.isTransient) and self.getTemperature = NULL_TEMPERATURE then
		if	theGenerator.isNoseMounted() or theGenerator.isUnderSlung() then
			// when attaching nose-mountes or under-slung generator to the container, we don't require set temperature. Par17775.ccms1045
		else
			lDesc := null;
			foreach lTask in app.myRoot.allToDoTaskDescriptions 
				where lTask.type = TODO_TYPE_GROUP_TI do 						// ### TFS  #56634[54259] 22NOV2022 NAVAB1
				if lTask.trxTypeOnCompletion = TRANS_TYPE_TEMP_SET then
					lDesc := lTask.description.trimBlanks;
				endif;
			endforeach;
			if lDesc &lt;&gt; null then
				self.addToDoTask(lDesc, _passport);
			endif;
		endif;
	endif;
	// CCMS 1010 AKB2002JAN to here
	
	if (not self.isTransient) then		//Don't add transients to terminal dicts
		//Update Voyage of COU
		if theGenerator.myVoyage &lt;&gt; self.myVoyage and self.myVoyage &lt;&gt; null then
			theGenerator.changeVoyage(self.myVoyage, _passport);
		endif;

		//Last thing. Make SURE our STATE is correct. DQ 23/10/97
		//This fixes a bug in EDI load, where any COU's/Children are NOT
		//added to the EDI bayplans ti dict.
		theGenerator.changeState(self.state, _passport);

		self.updateObjectEdition(self);	// par 30292
	else								//Just set the properties directly
		theGenerator.myVoyage := self.myVoyage;
		theGenerator.state 	:= self.state;

	endif;
	
	//21 July 2021	NDL	TFS 51570
	self.doAutoLinkDelinkGeneratorCont(	true,	//_attach : Boolean;	
										theGenerator,	//_generator : CM_TrackedItem input;
										self	//_container : CM_TrackedItem input
										);

/*	if not app.myRoot.getConfig(AutoLinkRefTraGen).Boolean then // --&gt; TFS 46767
		return;
	endif;
	
	//08 Jan 2020	NDL	TFS 48220
	if self.myTiMaster = null then
		self.autoCreateTIMaster();
	endif;
	//08 Jan 2020	NDL	TFS 48220
	if theGenerator.myTiMaster = null then
		theGenerator.autoCreateTIMaster();
	endif;

	if self.myTiMaster &lt;&gt; null and theGenerator.myTiMaster &lt;&gt; null then // 07/11/2019 - if self *and* generator TIMasters exist,
		self.myTiMaster.allTIMasterAttachees.clear; // remove any attached TIMasterGenerator
		self.myTiMaster.allTIMasterAttachees.add(theGenerator.myTiMaster);
		theGenerator.myTiMaster.allTIMasterAttachers.clear; // converse for theGenerator
		theGenerator.myTiMaster.allTIMasterAttachers.add(self.myTiMaster);
	endif; // &lt;-- TFS 46767  */
	

end;</source>
        <Parameter name="theGenerator" type="CM_Generator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="attachGeneratorNoseMounted" id="1a45ae9c-4353-4c43-b394-e861bace419b">
        <updating/>
        <source>attachGeneratorNoseMounted( _generator : CM_Generator input; _priorLocation : CM_LocationsController; _passport : CM_Passport input ) updating, protected;
/* ---------------------------------------------------------------------------
Created:	28 August 2008	by cnwvu1

Purpose:	Attach Nose-mounted generator to a container. 
			Remove To Do Task "Attach Generator Set" if it is active.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	desc : String;
	task	: CM_ToDoTask;
	control : CMIF_MoveController;
	
begin

	if _generator.isTransient() then
		return;
	endif;

	if not _generator.isNoseMounted() then
		return;
	endif;
	
	// when detaching a generator Nose-mounted, we should complete the To Do Task "Detach Generator Set" automatically
	desc := null;
	foreach task in self.allToDoTasksToDo do
		if task.toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_AttachGenerator then
			desc	:= task.toDoTaskDesc.description.trimBlanks;
			break;
		endif;
	endforeach;
	if desc &lt;&gt; null then
		self.completeToDoTaskForBulk( task.toDoTaskDesc, null, _passport);	
	endif;
	
	// changing nose-mounted generator's locations
	_generator.myPrimaryActualLocation	:= self.myPrimaryActualLocation;
	_generator.myPrimaryPlannedLocation	:= self.myPrimaryPlannedLocation;
	_generator.myPrimaryQueuedLocation	:= self.myPrimaryQueuedLocation;
	_generator.allLocations.clear();
	//_generator.locationId 	:= self.locationId;		//it has been changed in the attachGenerator()
	//_generator.plannedLocnId	:= self.plannedLocnId;	//it has been changed in the attachGenerator()
	//_generator.rehandleLocnId	:= self.rehandleLocnId;	//it has been changed in the attachGenerator()
	
	//setting priorLocation
	create control transient;
	control.setMoveMode(REAL_MODE);
	control.setMyOriginatingLocation( _priorLocation );
	control.setMyTrackedItem( _generator );	//08 Jan 2020	NDL	TFS 48183
	_generator.setPriorLocation(control);
	
epilog
	if control &lt;&gt; null then
		delete control;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_generator" type="CM_Generator" usage="input"/>
        <Parameter name="_priorLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoCreateTIMaster" id="f1c7eb81-38d3-4224-bf72-4d817e840f60">
        <updating/>
        <source>autoCreateTIMaster() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
*/
vars
//	tiMaster : CM_TIMaster;
	proxyTiMaster, realTiMaster : CM_TIMasterContainer;
	isotype : CM_ISOType;
	tareWeight : Decimal[23,2];
begin
	if not self.isReefer then
		return;
	endif;
	
	//21 Jul 2021	NDL	TFS 51570 - already checked in caller
//	if not app.myRoot.getConfig(AutoLinkRefTraGen).Boolean then
//		return;
//	endif;
	
	realTiMaster := app.myRoot.findTIMasterByCargoType(self.cargoType, self.id).CM_TIMasterContainer;
	if realTiMaster = null then
		isotype := self.getISOTypeObject();
		if isotype &lt;&gt; null then
			tareWeight := isotype.maxTareWeight;
		else
			isotype := self.myCargoType.allISOTypes.first;
			if isotype &lt;&gt; null then
				tareWeight := isotype.maxTareWeight;
			endif;
		endif;
		
		create proxyTiMaster transient;
		proxyTiMaster.setForProxyMasterContainer(self.id,
				false,false,0,0,tareWeight,
				0,0,0,0,0,0,0,0,
				self.myOperator,
				self.myOperator,
				isotype,
				null,
				null,
				null);
		app.myUtilityCA.utlCreateTiMasterContainer(proxyTiMaster, realTiMaster, false, app.myPassport);
	//	tiMaster := realTiMaster;
	endif;

	if realTiMaster &lt;&gt; null then
		self.myTiMaster := realTiMaster;
	endif;
epilog
	delete proxyTiMaster;
end;</source>
    </JadeMethod>
    <JadeMethod name="autoCreateToDoTask" id="0e935890-4849-4564-b970-8fe9eadf7f71">
        <updating/>
        <source>autoCreateToDoTask(_toDoTaskDesc : CM_ToDoTaskDesc; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tiTask		: CM_TiToDoTask;
	trxClassObj	: Class;
begin
	inheritMethod(_toDoTaskDesc, _passport);
	
//	if _toDoTaskDesc.transactionToCreate = PRETRIP then
	if _toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_PRETRIP then
		self.setPTIDetails(false); // Reset self.preTripDT to null
//	elseif _toDoTaskDesc.transactionToCreate = WASH then
	elseif _toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_WASH then
		self.setWashDetails(false);
	else
		//this will probably never happen but...
//		app.raiseCMException2(WARN_TASK_TRANS_WRONG, _toDoTaskDesc.transactionToCreate, "Should be " &amp; WASH &amp; " or " &amp; PRETRIP &amp; ".", null, null);
		app.raiseCMException2(WARN_TASK_TRANS_WRONG, _toDoTaskDesc.getTrxTypeOnCompleteClassName(), "Should be " &amp; WASH &amp; " or " &amp; PRETRIP &amp; ".", null, null);
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled To To Task.');
		return;
	endif;
	
	create tiTask persistent; // Add new to do task for _toDoTaskDesc	
	tiTask.setForCreate(STATUS_TODO, _toDoTaskDesc, null, _passport, self); 
	app.writeLog(self.id &amp; ' Added To Do Task: ' &amp; tiTask.toDoTaskDescDesc, LogINFO);
end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="availabilityGradeDescription" id="5c5ca5a4-9579-4ef0-8078-2d52fd4ac7e9">
        <methodInvocation>mapping</methodInvocation>
        <source>availabilityGradeDescription(set: Boolean; _value: String io) mapping;
//Simply returns the availability grade description
// 31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
vars
	grade		: CM_MTGrade;
	code		: CM_MTGradeCode;
	canDisplay	: Boolean;

begin

	if set then 
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

   	grade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];   					//31.10.2023 navma1 #60920	

	if grade = null then
    	_value := "Undefined";
    else
    	grade.getTranslationForOperator(grade, self.myOperator, null, code, canDisplay);    	
    	if code &lt;&gt; null then
    		_value := code.description;
    	elseif canDisplay then
    		_value := grade.description.trimBlanks;
    	else
    		_value := null;
    	endif;
    endif; 	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="canBeIncludedInChilledDict" id="1ffaddc8-0d74-43d5-924f-fcaaf36b2d15">
