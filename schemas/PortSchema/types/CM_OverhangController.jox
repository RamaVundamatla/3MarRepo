    <JadeMethod name="updateFromCMIF_GridRegion" id="74c29b24-d9c2-40af-bbb3-35e1991c40c3">
        <updating/>
        <source>updateFromCMIF_GridRegion(_controller : CMIF_GridTARegion) updating;
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
		self.availability := _controller.availability;
		if self.availability = PAD_AVAILABLE and self.usage = UNAVAILABLE_USE then
			self.usage := NORMAL_USE;
		endif;
end;</source>
        <Parameter name="_controller" type="CMIF_GridTARegion"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="14f358d0-890d-44a9-8ecb-bce6c0863699">
        <source>validateForCreate(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     07 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_passport);
	
	if self.myGridRow.allControllersByColumn.last &lt;&gt; self
	and self.myGridRow.allControllersByColumn.first &lt;&gt; self then
		app.raiseCMException2(ERR_OVERHANG_ONENDS, self.getFullId(),null, null, self);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="527a3380-5dbb-4d18-889d-a796c9c4d786">
