    <JadeMethod name="utlCreateCopiedContractDtl" id="c8d7cf4b-8925-4cde-8d5f-ef0ac28a6a21">
        <source>utlCreateCopiedContractDtl(_pxyObject : CM_InvoiceContractDetails; _realObject : CM_InvoiceContractDetails output; _newService : CM_Service; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2023	navkc1 Bug 61578: EUP | FR 54089 - Invoice Contracts - Copy function extended

*/

vars
	pxyRateEntry,
	realRateEntry		: CM_InvoiceContractRateEntry;
	
	pxyRate,
	realRate			: CM_InvoiceContractRate;
	
	transientToDelete	: ObjectArray;
	allProcessedRates	: CM_InvoiceContractRateSet;
	allProcessRateEntry	: CM_InvoiceContractRteEntByFrom;
	desc,
	critDesc,
	revDesc				: String;
	count				: Integer;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myUtilityCA.utlCreateInvContractDtl(_pxyObject, _realObject, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	create transientToDelete transient;
	create allProcessedRates transient;
	create allProcessRateEntry transient;
	
	foreach pxyRate in _pxyObject.allInvoiceContractRates do
		transientToDelete.add(pxyRate);
		allProcessedRates.add(pxyRate);
		
		if _realObject &lt;&gt; null then
			pxyRate.setMyInvoiceContractDetails(_realObject);
		endif;
		
		if _newService &lt;&gt; null then
			pxyRate.setMyService(_newService);
		endif;
		
		app.myUtilityCA.utlCreateInvContractDtlRt(pxyRate, realRate, _passport);
		
		if (not self.checkValidationWithPassport(_passport)) then
			// Reset the reference to the proxy
			foreach pxyRate in allProcessedRates do
				pxyRate.setMyInvoiceContractDetails(_pxyObject);
			endforeach;
			// Continue instead of return so we display all errors at once
			continue;
		endif;
		
		foreach pxyRateEntry in pxyRate.allInvoiceContractRateEntries do
			transientToDelete.add(pxyRateEntry);
			allProcessRateEntry.add(pxyRateEntry);
			if realRate &lt;&gt; null then
				pxyRateEntry.setMyInvoiceContractRate(realRate);
			endif;
			app.myUtilityCA.utlCreateInvContractDtlRtEntry(pxyRateEntry, realRateEntry, _passport);
			
			if (not self.checkValidationWithPassport(_passport)) then
				// Reset the reference to the proxy
				foreach pxyRate in allProcessedRates do
					pxyRate.setMyInvoiceContractDetails(_pxyObject);
				endforeach;
				
				foreach pxyRateEntry in allProcessRateEntry do
					pxyRateEntry.setMyInvoiceContractRate(pxyRate);
				endforeach;
				// Continue instead of return so we display all errors at once
				continue;
			endif;
		endforeach;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _realObject.myInvoiceContractCriteria &lt;&gt; null then
		critDesc := _realObject.myInvoiceContractCriteria.description;
		if critDesc.pos("COPY",1) &lt; 1 then
			desc := critDesc &amp; Space &amp; "COPY 1";
		else
			revDesc := critDesc.reverse;
			count := revDesc[1].Integer;
			count := count + 1;
			revDesc.replaceChar(revDesc[1],count.Character);
			desc := revDesc.reverse;
		endif;
		_realObject.myInvoiceContractCriteria.setDescription(desc);
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
	endif;
	
	if _passport.noErrors() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvContractDtlCreate), false, _realObject);
		transientToDelete.purge();
	endif;
	
epilog
	delete transientToDelete;
	delete allProcessedRates;
	delete allProcessRateEntry;
end;</source>
        <Parameter name="_pxyObject" type="CM_InvoiceContractDetails"/>
        <Parameter name="_realObject" type="CM_InvoiceContractDetails" usage="output"/>
        <Parameter name="_newService" type="CM_Service"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCountry" id="d1d63455-1cb8-4d78-b9cd-60331cc3ce07">
        <source>utlCreateCountry(_intCountry:CMIF_Country; pNewCountry:CM_Country output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	pProxyCountry:CM_Country;
	aPort : CM_Port;
	itemAudit	: CM_UpdateTransactionAuditAgent;
begin

	self.initialiseActivity();
	pProxyCountry := _intCountry.myProxyCountry;
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCountry(pProxyCountry);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	//03/08/2023	navkc1	CR 59552   Task 59554
	if pProxyCountry.myCountryRegion &lt;&gt; null then
		create itemAudit transient;
		itemAudit.audUpdateGeneric(pProxyCountry.myCountryRegion, true);
	endif;
	
	create pNewCountry persistent;
	pNewCountry.setForCreate(pProxyCountry);
	if pNewCountry &lt;&gt; null then
		foreach aPort in pNewCountry.ports do
			aPort.setMyCountry(null);
		endforeach;
	endif;
	foreach aPort in _intCountry.allRealPorts do
		aPort.setMyCountry(pNewCountry);
	endforeach;
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewCountry);
		//03/08/2023	navkc1	CR 59552   Task 59554
		if pProxyCountry.myCountryRegion &lt;&gt; null then
			itemAudit.audUpdateGeneric(pProxyCountry.myCountryRegion, false);
		endif;
	endif;	

epilog
	delete itemAudit;
end;
</source>
        <Parameter name="_intCountry" type="CMIF_Country"/>
        <Parameter name="pNewCountry" type="CM_Country" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCountryRegion" id="d18fb4e3-a606-47eb-8dec-e3dd4821915f">
        <source>utlCreateCountryRegion(	_pxyCountryRegion : CM_CountryRegion;
						_newCountryRegion : CM_CountryRegion output;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars
	itemAudit	: CM_UpdateTransactionAuditAgent;
	country		: CM_Country;
	allAudits	: ObjectArray;
	index		: Integer;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCountryRegion(_pxyCountryRegion);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create allAudits transient;
	
	// Audit Country
	foreach country in _pxyCountryRegion.allCountries do
		create itemAudit transient;
		itemAudit.audUpdateGeneric(country, true);
		allAudits.add(itemAudit);
	endforeach;
	
	create _newCountryRegion persistent;
	
	_newCountryRegion.setForCreate(_pxyCountryRegion);
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_newCountryRegion);
		
		// Audit Country
		foreach country in _pxyCountryRegion.allCountries do
			index += 1;
			itemAudit := allAudits[index].CM_UpdateTransactionAuditAgent;
			itemAudit.audUpdateGeneric(country, false);
			delete itemAudit;
		endforeach;
	endif;
epilog
	delete allAudits;
end;</source>
        <Parameter name="_pxyCountryRegion" type="CM_CountryRegion"/>
        <Parameter name="_newCountryRegion" type="CM_CountryRegion" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCraneMoveRates" id="0b8a8c37-b0c0-449d-abeb-1dd277dadd23">
