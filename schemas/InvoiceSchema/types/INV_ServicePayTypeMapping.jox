    <JadeMethod name="doCmbBankBuild" id="611487cb-4203-42d6-ac09-83be47fb4052">
        <source>doCmbBankBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;

begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;

epilog

	delete businessUnits;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="bd23aae3-0042-43cb-ba1f-f9c4f1cda33b">
        <source>doCmbDebtorBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281
19 Oct     2018 cnwma1 ChangeRequest 41281: PEL1 - Payment Method on Services
*/

vars

	idx : Integer;
	aDebtor : CM_Debtor;

begin

	self.cmbDebtors.clear;
	foreach aDebtor in app.myRoot.myRootCompany.debtors do
		
		if aDebtor.isRDT then  //19.10.2018 cnwma1 TFS #41281
			idx := self.cmbDebtors.addItem(app.getErrorString(Default));
		else
			idx := self.cmbDebtors.addItem(aDebtor.name);
		endif;
		
		self.cmbDebtors.itemObject[idx] := aDebtor;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbPaymentTypesBuild" id="177f4a17-5022-4df6-b4eb-b9d0fad0705d">
        <source>doCmbPaymentTypesBuild(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars
	paymentType : Integer;
begin
	paymentType:= -1;
	if _debtor &lt;&gt; null then
		paymentType := _debtor.getDefaultPaymentType( self.getMyTerminal );
	endif;
	self.cmbPaymentTypes.clear;

	if paymentType &lt;&gt; PaymentType_None then
		self.cmbPaymentTypes.itemData [ self.cmbPaymentTypes.addItem( app.paymentTypeEnumToString(PaymentType_None) ) ] := PaymentType_None;
	endif;
	if paymentType &lt;&gt; PaymentType_AutoCollection then
		self.cmbPaymentTypes.itemData [ self.cmbPaymentTypes.addItem( app.paymentTypeEnumToString(PaymentType_AutoCollection) ) ] := PaymentType_AutoCollection;
	endif;
	if paymentType &lt;&gt; PaymentType_PrePay then
		self.cmbPaymentTypes.itemData [ self.cmbPaymentTypes.addItem( app.paymentTypeEnumToString(PaymentType_PrePay) ) ] := PaymentType_PrePay;
	endif;
	if paymentType &lt;&gt; PaymentType_PostPay then
		self.cmbPaymentTypes.itemData [ self.cmbPaymentTypes.addItem( app.paymentTypeEnumToString(PaymentType_PostPay) ) ] := PaymentType_PostPay;
	endif;
	if paymentType &lt;&gt; PaymentType_NoCharge then
		self.cmbPaymentTypes.itemData [ self.cmbPaymentTypes.addItem( app.paymentTypeEnumToString(PaymentType_NoCharge) ) ] := PaymentType_NoCharge;
	endif;
	self.cmbPaymentTypes.listIndex := self.cmbPaymentTypes.findStringExact( 1, app.paymentTypeEnumToString( self.myCurrentPaymentType ) );

epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbServicesBuild" id="1bca7ae9-f370-4758-8465-71ed777a839c">
        <source>doCmbServicesBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	idx : Integer;
	service : CM_Service;
	bank : CM_Bank;

begin

	bank := self.myCurrentBank;
	self.cmbServices.clear();
	
	foreach service in bank.services where not service.isNotAvailableForEntry do
		idx := self.cmbServices.addItem(service.name);
		self.cmbServices.itemObject[idx] := service;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboDebtorBuild" id="8c43f1c8-396f-4e70-abc7-7b203b1ff9a4">
        <source>doComboDebtorBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation
19 Oct     2018 cnwma1 ChangeRequest 41281: PEL1 - Payment Method on Services
*/

vars

	debtor 		  : CM_DebtorNode;
	defaultDebtor : CM_DebtorNode;
begin

	self.cmbDebtor.clear;
	self.cmbDebtor.sorted := true;
	self.cmbDebtor.addItem( " " &amp; app.getErrorString(CM_All_Debtors) );
	
	foreach debtor in app.myRoot.myRootCompany.debtorNodes do
		if debtor.isRootDebtorGroup then  //19.10.2018 cnwma1 TFS #41281
			continue;
		endif;
		
		if debtor.isRDT then              //19.10.2018 cnwma1 TFS #41281
			defaultDebtor := debtor;
			continue;
		endif;
		
		self.cmbDebtor.addItem(debtor.name);
		self.cmbDebtor.itemObject[self.cmbDebtor.newIndex] := debtor;
	endforeach;
	
	if defaultDebtor &lt;&gt; null then         //19.10.2018 cnwma1 TFS #41281                     
		self.cmbDebtor.addItem(' '&amp; app.getErrorString(Default));
		self.cmbDebtor.itemObject[2] := defaultDebtor;
	endif;
	
	
	self.cmbDebtor.listIndex := 1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboDebtorUpdateBuild" id="26c1ecf3-a8ab-46e1-9598-ed1c17a33edb">
        <source>doComboDebtorUpdateBuild(_theDebtors : CM_DebtorNodeByNameDict);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281
19 Oct     2018 cnwma1 ChangeRequest 41281: PEL1 - Payment Method on Services
*/

vars
	debtor : CM_DebtorNode;
begin

	self.cmbDebtors.clear;
	self.cmbDebtors.sorted := true;
	
	foreach debtor in _theDebtors do
		if debtor.isKindOf(CM_DebtorGroup) then
			continue;
		endif;
		
		if debtor.isRDT then     //19.10.2018 cnwma1 TFS #41281
			self.cmbDebtors.addItem(app.getErrorString(Default));
		else
			self.cmbDebtors.addItem(debtor.name);
		endif;
		
		self.cmbDebtors.itemObject[self.cmbDebtors.newIndex] := debtor;
	endforeach;

epilog

end;</source>
        <Parameter name="_theDebtors" type="CM_DebtorNodeByNameDict"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e2acfeb9-3b23-4732-951b-96dfbc5ee0f7">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	paymentTypeMapping : CM_ServicePayTypeMapping;
	obj : CM_Object;
	theReturn : Integer;

begin

	paymentTypeMapping := self.myCurrentBank.getServicePayTypeMapping( self.myCurrentService, self.myCurrentDebtor.CM_Debtor, false ); // the specific one for this debtor only.
	
	if paymentTypeMapping = null then	
		return;
	else
		obj := paymentTypeMapping;
	endif;
	while true do
		app.myTrxDA.trxDeleteCMObject(obj, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			break;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(Payment_mapping_remove), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
