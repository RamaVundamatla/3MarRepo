    <JadeMethod name="setupForm" id="8970e48e-ef3a-4ece-915f-04899777d982">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars

begin
	inheritMethod();
	self.doPermissions();
	self.handleMenusForModalDisplay();
	if self.mode then
		self.populateINCOterms();	
	endif;
	self.initTblINCOMapping(ETDef_IncoMappingList);
	self.tblDisplayRow();
	self.setBusinessUnit();
	self.setNavigatorHeading(self.caption);
	
epilog

end;</source>
