    <JadeMethod name="txtCargoIDvalue_lostFocus" id="a33c6e5e-4a5d-4090-9fd8-91e2f21716ad">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoIDvalue_lostFocus(textbox: TextBox input) updating;
// -----------------------------------------------------------------------------
// Created:		01 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	str : String;

begin
	str := self.txtCargoIDvalue.text.trimBlanks();
	
	// 23/09/2014 cnwar2 #34499
	str := str[1:20];
	self.txtCargoIDvalue.text := str;

	if self.updateMode = self.Mode_Add then
		if str = null and
		   app.activeControl = self.lstCargoIDvalues then
			return;
		endif;
		self.lstCargoIDvalues.visible := false;
		self.lblCargoIDfiller.visible := false;
	endif;
	
	self.onContainerIdChange(str, null);
	
epilog

end;</source>
