<GUIClass name="MOB_TimeTextBox" id="eb4efab8-34cc-49b1-a910-b5fabb102f49">
    <superclass name="TextBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Added for CCMS POL 2059</text>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="time" id="3effbe5f-cc65-422a-84d5-cfa4bce8182f">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getTime" id="91d00bd5-c709-4ced-a954-817ffbde0289">
        <updating/>
        <source>getTime(_errorMsg : String output) : Time updating;

vars
	inError	: Boolean;
	hh,
	mm	: Integer;
	timeString	: String;
	part1,
	part2	: String;
	fmt		: String;
begin
	timeString := self.text;
	if timeString  = null then
		return null;
	endif;

	if timeString.length &lt;&gt; 4 or
	   not timeString.isInteger then
		inError := true;
	else
		part1 := timeString[1:2];
		part2 := timeString[3:2];
		hh := part1.Integer;
		mm := part2.Integer;
		if hh &lt; 0 or
		   hh &gt; 23 then
			inError := true;
		endif;
		if mm &lt; 0 or
		   mm &gt; 59 then
			inError := true;
		endif;
		if not inError then
			self.time.setTime(hh, mm, 0, 0);
			inError := not self.time.isValid();
		endif;
	endif;
		
	if inError then
		fmt := app.getErrorString(Format_hhmm);
		_errorMsg := app.getErrorString1(Invalid_time_expect_format, fmt);
	endif;
	
	return self.time;
end;</source>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="setTime" id="01728e19-2188-49dd-bb89-0a94baee2055">
        <updating/>
        <source>setTime(_time : Time) updating;

vars

begin
	self.time := _time;
	self.text := self.time.format('HHmm');
end;
</source>
        <Parameter name="_time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="ce77b50e-5abb-4b3a-91ce-2f9fd788f2f0">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.dataType := DataType_Numeric;
	self.maxLength := 4;
	if self.isInPainter() then
		self.width := 40;
	endif;
end;
</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
