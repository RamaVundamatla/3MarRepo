    <JadeMethod name="cb_alarmT_scrolled" id="f384c52e-0fd1-4a6b-ba23-dcb917a753db">
        <controlMethod name="ComboBox::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cb_alarmT_scrolled(combobox: ComboBox input; scrollBar: Integer) updating;

vars
   hrs, mins, p : Integer;
   realMins : Real;
begin
	 p := combobox.text.pos(":", 1);
	 hrs := combobox.text[1:p].Integer;			
	 mins := combobox.text[p+1:end].Integer;

   alarmThreshold.setTime(hrs,mins,0,0);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cb_checkT_scrolled" id="77ee19c2-9e3f-44f3-8883-d9412efb66c1">
        <controlMethod name="ComboBox::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cb_checkT_scrolled(combobox: ComboBox input; scrollBar: Integer) updating;
//This gets called in two places: when we scroll the check interval box and
//after we have just done a check on the chilled boxes
vars
   now : Time;
   interval : Time;
begin
	now := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
   checkInterval := cb_checkT.text.Integer;
   timerMinutes := 0;					//reset the clock, it's easier !
	 interval.setTime(0,checkInterval,0,0);
 	 statusLine2.caption := "Next check at: " &amp; (now + interval).format("HH:mm");		
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminal_click" id="dbd40bdf-b11c-4e05-97a7-b9732242dac8">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_click(combobox: ComboBox input) updating;
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	terminal	: CM_Terminal;
	idx			: Integer;
begin
	idx := combobox.listIndex;
	if idx &lt; 1 then
		return;
	endif;
	
	terminal := combobox.itemObject[idx].CM_Terminal;

	self.setMyTerminal(terminal);


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="7bbae69e-a0cb-4cba-b66e-42a70e3d2f8d">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
   	now			: Time;
 	interval	: Time;
   	i,
   	mins,
   	a			: Integer;
begin
//	self.show;

	app.niceName := "Reefer Alarm Monitor";

	self.loadCmbTerminal();

	cb_alarmT.addItemAt("05:00", 1);
	cb_alarmT.addItemAt("04:30", 2);
	cb_alarmT.addItemAt("04:00", 3);
	cb_alarmT.addItemAt("03:30", 4);
	cb_alarmT.addItemAt("03:00", 5);
	cb_alarmT.addItemAt("02:30", 6);
	cb_alarmT.addItemAt("02:00", 7);
	cb_alarmT.addItemAt("01:45", 8);
	cb_alarmT.addItemAt("01:30", 9);
	cb_alarmT.addItemAt("01:15", 10);
	cb_alarmT.addItemAt("01:00", 11);
	cb_alarmT.addItemAt("00:45", 12);
	cb_alarmT.addItemAt("00:30", 13);
	cb_alarmT.addItemAt("00:15", 14);
	//cb_alarmT.addItemAt("00:01", 15);			//debug purposes !

	cb_alarmT.listIndex := 13;
	alarmThreshold.setTime(0,30,0,0);			//default is 30 minutes

  cb_checkT.addItemAt("60", 1);
  cb_checkT.addItemAt("55", 2);
  cb_checkT.addItemAt("50", 3);
  cb_checkT.addItemAt("45", 4);
  cb_checkT.addItemAt("40", 5);
  cb_checkT.addItemAt("35", 6);
  cb_checkT.addItemAt("30", 7);
  cb_checkT.addItemAt("25", 8);
  cb_checkT.addItemAt("20", 9);
  cb_checkT.addItemAt("15", 10);
  cb_checkT.addItemAt("10", 11);
  cb_checkT.addItemAt("5", 12);
  cb_checkT.addItemAt("1",13);				//debug purposes !!
  cb_checkT.listIndex := 11;

	checkInterval := 10;
	interval.setTime(0,10,0,0);			//default is 10 minutes
	statusLine2.caption := "Next Check at: " &amp; (now + interval).format("HH:mm");
	useCommodity.value := true; // AKB 08Mar2001 PAR 3803
	menuFileLogin.enabled := false;
	menuFilePassword.enabled := false;
	menuFilePrintSetup.enabled := false;
	self.menuHelp.visible := false;
	self.menuWindow.visible := false;
	
	//Rebuild the chilled off powerTIs dict. After this is done any
	//additions / deletions are called from the transactions concerned
	

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbTerminal" id="a7875e37-1b56-44f9-b692-3a1a2297561c">
        <updating/>
        <source>loadCmbTerminal() updating;
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx		: Integer;
	term	: CM_Terminal;
begin
	self.cmbTerminal.clear;
	self.cmbTerminal.sorted := false;
	
	foreach term in app.myRoot.allTerminals do
		idx := self.cmbTerminal.addItem(term.code &amp; " - " &amp; term.name);		
		self.cmbTerminal.itemObject[idx] := term;
	endforeach;
	
	//if only one then the choice is inevitably 1
	if idx = 1 then
		self.cmbTerminal.listIndex := idx;
		self.setMyTerminal(self.cmbTerminal.itemObject[idx].CM_Terminal);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="okToStartTimer" id="fd967762-1208-4050-94a3-a10c60b424ca">
        <source>okToStartTimer(): Boolean;
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myTerminal = null then
		app.msgBox(app.getErrorString(Select_Terminal), app.getErrorString(InsufficientInput), MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//if self.  then
	//	app.msgBox(, app.getErrorString(InsufficientInput), MsgBox_OK_Only + MsgBox_Information_Icon);
	//	return false;
	//endif;
	
	return true;		
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rebuildOffPowerDict" id="142ff7eb-5a4a-468c-b96d-8637cbdb56a7">
        <source>rebuildOffPowerDict();
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 20 Nov 2017	jlgkpd1		TFS 7466 - Make update of chilled dict more consistent
// 22 Nov 2017	jlgkpd1		TFS 7466 - Fix potential issue where Cargo Subtype can be a reefer

vars
	iter		: Iterator;
   	ti			: CM_TrackedItem;
	err			: CM_Error;
	msg 		: String;
	ct			: CM_CargoType;
	
begin
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
	while iter.next(ti) do
		if ti.canBeIncludedInChilledDict() then
			app.myTrxUA.trxUpdateChilledDict(ti, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				foreach err in app.myPassport.allErrorWarnings do
					msg := err.errorCode.String &amp; " " &amp; err.text;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
				endforeach;
				msg := 'Error adding/removing tracked item from chilled dictionary (' &amp; ti.id &amp; ').';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				app.myPassport.clearErrorsWarnings();
			endif;
		else
			ct := ti.myCargoType;
			if ct = null or not ct.hasProductTypes() then
				// Skip over all tracked items of this cargo type, as none of them can be in the collection
				self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(ti.cargoType + 1, null, iter);
			endif;
		endif;
	endwhile;

epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="startMonitoring" id="505b69ba-61e3-484f-ab76-e2122dbfb366">
        <source>startMonitoring();
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;
	
	if self.okToStartTimer() then
		
		beginTransaction;
		self.myTerminal.chilledTIsOffPower.clear;
		app.cmsCommitTransaction(app.myPassport);
		
		self.rebuildOffPowerDict();
		
		//create timer for 1 minute intervals
		beginTimer(60000, Timer_Continuous, 0);

		self.btnStart.enabled := false; 
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="5ed5f3db-9afc-42ed-ae7a-50fa89711980">
        <updating/>
        <source>timerEvent(eventTag : Integer) updating;
//Goes off every minute, but only does any work if this is the right check interval
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
    iter	: Iterator;
    ti		: CM_TrackedItem;
	reefer	: CM_Container;
begin
	
	if timerMinutes &gt;= 15999 then		//safety
		timerMinutes := 1;
	else		
   		timerMinutes := timerMinutes + 1 ;
   	endif;

   	if timerMinutes mod checkInterval = 0 then
   		//Time to get busy
   		iter := self.myTerminal.chilledTIsOffPower.createIterator;
   		while iter.next(ti) do
   			if ti.isKindOf(CM_Container) then
   				reefer := ti.CM_Container;
	      	//remove reference	reefer.offPowerAlert(alarmThreshold,useCommodity.value, self.myTerminal);	 // AKB 08Mar2001 PAR3803 added useCommodity
	      	endif;
   		endwhile;

   		cb_checkT.scrolled(cb_checkT, 1);
   	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
