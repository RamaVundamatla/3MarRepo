    <JadeMethod name="select40BackEnd" id="cf959ee9-212a-4d1c-8cef-5afe9d8b3a85">
        <updating/>
        <source>select40BackEnd(y : Real; _lc : CM_LocationsController) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cellHeight, y1,y2,tiIndex : Integer;
	theTI : CM_TrackedItem;
begin
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		theTI := self.get40FooterFromBackEnd(y,_lc,REAL_MODE);
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		theTI := self.get40FooterFromBackEnd(y,_lc,QUEUE_MODE);
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		theTI := self.get40FooterFromBackEnd(y,_lc,PLANNING_MODE);
	endif;


	if theTI &lt;&gt; null then
//		self.heightOfStack := _lc.CM_GridController.myGridRow.myGridArea.heightOfStack;
		self.myDrawingFrame.selectObject(theTI, self.myDrawingFrame.myStartObject, false);
		self.myYardGridEnqForm.showExtraInfo(theTI);
		self.myYardGridEnqForm.picCargo.picture := self.myYardGridEnqForm.showCargoPicture(theTI);
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="y" type="Real"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="7d8d35f0-d476-4ff1-9fcf-0a12306ff407">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		20 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anLC : CM_LocationsController;
	userInfoStr		: String;
	noteRecord		: CMIF_NotificationRecord;
begin
	if self.currentlyMinimised then
		if userInfo.isKindOf(Object) then
			//userInfoStr := userInfo.Object.getOidString();
			userInfoStr := self.getOidStringForObject(userInfo.Object);
		else
			userInfoStr := userInfo.String;
		endif;
		
		noteRecord := self.allNotificationsReceived[eventType, theObject, eventTag, userInfoStr];
		if noteRecord = null then
			create noteRecord transient;
			noteRecord.eventType := eventType;
			noteRecord.myObject := theObject;
			noteRecord.eventTag := eventTag;
			noteRecord.userInfoString := userInfoStr;
			allNotificationsReceived.add(noteRecord);
		endif;
		
		return;//processed when minimised state ends
	endif;
	 // PAR 11144
	if userInfo.isKindOf(CM_LocationsController) then
		anLC := userInfo.CM_LocationsController;
		if anLC &lt;&gt; null then
			if not self.allGridObjects.includes(anLC) then
				return;
			endif;
		endif;
	endif;

	inheritMethod(eventType, theObject, eventTag, userInfo);

epilog
	// belts and braces to ensure any possible locks are cleared.
	// We should not be in loadstate anyway
	endLoad;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationHandleSelector" id="769ff50c-b7b8-4649-9854-60677f1e559e">
        <updating/>
        <source>userNotificationHandleSelector(aTI : CM_TrackedItem; breakOut : Boolean io) updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
 selForm : CMUI_Selector ;
 	theform : YRD_GridAreaEnquiryForm;
begin
	theform := self.myYardGridEnqForm;
	if theform &lt;&gt; null then
		selForm := theform.mySelectorForm;
	endif;
	// PAR 11208
	if not global.isValidObject(self.mySelectorEnquiryController) then
		self.mySelectorEnquiryController := null;
	endif;
	if self.mySelectorEnquiryController &lt;&gt; null then
//					if not selForm.myEnqController.includesObject(aTI,breakOut,app.myPassport) then
		if not self.mySelectorEnquiryController.includesObject(aTI,breakOut,app.myPassport) then
			if self.allSelectorTIs.includes(aTI) then
				self.allSelectorTIs.remove(aTI);
				if self.allSelectedObjects.includes(aTI) then
					self.allSelectedObjects.remove(aTI); // PAR 11180
				endif;
				if selForm &lt;&gt; null then
					selForm.doRemoveTIObject(aTI);
				endif;
				if self.mySelectorEnquiryController.allObjects.includes(aTI) then
					self.mySelectorEnquiryController.allObjects.remove(aTI);
				endif;
			endif;
		else // does match selector query
			if theform &lt;&gt; null then
				// if this TI is not one of my originals sent to the form then ignore it.
				if not theform.allTIs.includes(aTI) then
					return;
				endif;
			endif;

			if not self.allSelectorTIs.includes(aTI) then
				self.allSelectorTIs.add(aTI);
				if selForm &lt;&gt; null then
					selForm.doAddTIObject(aTI);
				endif;
			endif;
		endif;
		self.doPostSelector();
	endif;

epilog
	// belts and braces to ensure any possible locks are cleared.
	// We should not be in loadstate anyway
	endLoad;
end;</source>
        <Parameter name="aTI" type="CM_TrackedItem"/>
