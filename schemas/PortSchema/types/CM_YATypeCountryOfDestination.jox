    <JadeMethod name="isCMIFDataMatch" id="fe6d65f4-6394-4ded-b2fd-7eb4bdae4a10">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

