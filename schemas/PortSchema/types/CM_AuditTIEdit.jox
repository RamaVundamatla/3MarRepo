    <JadeMethod name="setRemarks" id="cb084212-0eba-49f6-8c4e-c19bb96234ae">
        <updating/>
        <source>setRemarks() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
Bug 48219: JMT - Audits for Edit transactions not working properly
*/

vars
	arrEditFields	: HugeStringArray;
	str				: String;
	remstr			: String;
	
begin
	if transaction = null then
		return;
	endif;

	create arrEditFields transient;
	transaction.fieldsValues.getStrings(arrEditFields);


	remstr := "Edit: ";

	str := arrEditFields.concatenate(',');
	

	self.remarks := remstr &amp; str;

epilog
	delete arrEditFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="a88c610e-36fe-4d7b-ab5a-57d2db66f06f">
