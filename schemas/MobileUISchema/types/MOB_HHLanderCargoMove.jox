    <JadeMethod name="doClickChangeJob" id="b62544c2-2a7c-4281-b1f7-458cb7877eeb">
        <updating/>
        <source>doClickChangeJob() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	Par 30842

*/

vars

begin

	if self.myTrackedItem = null then
	
		return;
	
	else

		self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
		self.gotoForm( MOB_HHLanderChangeJob, false );
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickInTransit" id="7cfbea3d-da93-4537-b9fd-7926f1821957">
        <updating/>
        <source>doClickInTransit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwndl1	Initial creation	Par 29961

*/

vars

	errMess : String;

begin

	if not self.myMobileGenericAgent.hhLanderGroundingOpt = BothOpts 
	and not self.myMobileGenericAgent.hhLanderGroundingOpt = GroundInTransit 
	then
		errMess := "Invalid Ground option to be here!";
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return;
	endif;
	
	if self.doCompleteGround( GroundInTransit ) then
		//clear fields ready for the the next item..
		self.setMyTrackedItem(	null, null );	//23 Sep 2013	NDL	Par 32479
		self.populateTrackedItem();
		
	endif;

epilog

end;</source>
    </JadeMethod>
