<Class name="WS_EventRequestTI" id="0b7a91ec-6f39-4883-b709-3960988fca74">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>The Cargo Notification Request used  to register/Find what you want to be notified when an event occurs to a specified cargo item.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="allNotifyTimesString" id="3c6f0e8e-a698-47d2-81ae-821d7e0ce9d8">
        <type name="String"/>
        <access>readonly</access>
        <text>A collection of event request timestamps</text>
    </PrimAttribute>
    <PrimAttribute name="cargoId" id="27260f0f-94b0-441e-8088-e3b70f9cd580">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The Cargo ID for the event request</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="20f4392d-fb08-47a7-8982-585b94a1e893">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="emailAddresses" id="01672390-01dd-4b41-96a8-d159095738e4">
        <type name="String"/>
        <access>readonly</access>
        <text>Delimited string of email addresses which receive notifications</text>
    </PrimAttribute>
    <ImplicitInverseRef name="myCargoType" id="b9e1f131-1d67-4a6e-855a-ef4c89f3e99e">
        <embedded/>
        <type name="WS_CargoType"/>
        <access>readonly</access>
        <text>The Cargo Type for the Events Cargo.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myOrganisation" id="af0dde7c-f710-41b3-b90a-b2425c1903a8">
        <embedded/>
        <type name="WS_Organisation"/>
        <access>readonly</access>
        <text>The Organisation requesting the event</text>
    </ImplicitInverseRef>
    <PrimAttribute name="reference" id="2a6099b1-9c9d-4541-a01b-2b648850dcf5">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>A free text information field</text>
    </PrimAttribute>
    <PrimAttribute name="remarks" id="322879d8-56bf-4187-8142-539fe84c521c">
        <type name="String"/>
        <access>readonly</access>
        <text>A free text information field</text>
    </PrimAttribute>
    <ImplicitInverseRef name="status" id="626ebee6-ebca-4964-b0d0-cf0a38395220">
        <embedded/>
        <type name="WS_EventStatus"/>
        <access>readonly</access>
        <text>The Status of the event request.
EventRequestPending = 0: Not matched
EventRequestMatched = 1: Matched but not actioned.
EventRequestActioned = 2: Matched and actioned.
EventRequestEmailed = 3: Matched and Email sent via BGP but not necessarily actioned.
EventRequestCargoDeleted = 4: Stop requests only - Cargo has been deleted after stop was actioned </text>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="62f77b68-1a9c-4538-a1c9-1b55cc96b961">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwkao1	Initial creation

*/

vars

begin
	delete self.myCargoType;
	delete self.myOrganisation;
	delete self.status;  //epr TFS 7521 10/11/17
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getEmailAddresses" id="77dd1d98-d570-4666-a298-31143142e309">
        <source>getEmailAddresses(eventRequest : CM_EventRequest) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwkao1	Initial creation

*/
constants
	Delimiter	: String = "; ";
	
vars
	email		: String;
	retVal		: String;
	delimLen	: Integer;
	
begin
	delimLen := Delimiter.length() + 1; 
	foreach email in eventRequest.allEmailAddresses do
		retVal := retVal &amp; Delimiter &amp; email;
	endforeach;	
	
	if retVal.length() &lt; delimLen then
		return null;
	else
		return retVal[delimLen:end]; //remove the first delimiter 
	endif;
epilog

end;</source>
        <Parameter name="eventRequest" type="CM_EventRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNotifyTimes" id="c0086372-e8e7-4c4b-a16f-af447e914b68">
        <source>getNotifyTimes(eventRequest : CM_EventRequest) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2008	cnwkao1	Initial creation

*/
constants
	Delimiter	: String = "; ";

vars
	time		: Time;
	retVal		: String;
	delimLen	: Integer;
begin
	delimLen := Delimiter.length() + 1;
	
	if eventRequest.myEventRequestEmail &lt;&gt; null then
		foreach time in eventRequest.myEventRequestEmail.allRunTimes do
			retVal := retVal &amp; Delimiter &amp; time.formatAsHHmmSS();
		endforeach;
	endif;
	
	if retVal.length() &lt; delimLen then
		return null;
	else
		return retVal[delimLen:end]; //remove the first delimiter 
	endif;	
epilog

end;</source>
        <Parameter name="eventRequest" type="CM_EventRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="427f5b5e-f5a0-4683-a95d-cea8265c351a">
        <updating/>
        <source>setProxyFromObject(_object: CM_EventRequestTI) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars
	
begin
	inheritMethod(_object);
	
	self.cargoId		:= _object.cargoId;	
	
	create self.myCargoType transient;	
	if _object.myCargoType &lt;&gt; null then
		self.myCargoType.id				:= _object.myCargoType.id;
		self.myCargoType.description	:= _object.myCargoType.description;
		//self.myCargoType.setProxyFromObject(_object.myCargoType.CM_CargoType);
	endif;
	
	create self.myOrganisation transient;
	if _object.myOrganisation &lt;&gt; null then
		self.myOrganisation.name := _object.myOrganisation.name;
		//self.myOrganisation.setProxyFromObject(_object.myOrganisation);
	endif;
	
	self.reference	:= _object.reference;	
	self.remarks	:= _object.remarks;
	
	//cnwmc5 - 4 March 2015 - PAR 33796
	create self.status transient;
	if self.status &lt;&gt; null then
		self.status.id			:= _object.status;
		self.status.description := _object.statusString();
	endif;
	
	self.allNotifyTimesString	:= self.getNotifyTimes(_object);
	self.emailAddresses			:= self.getEmailAddresses(_object);	
	
epilog

	
end;
</source>
        <Parameter name="_object" type="CM_EventRequestTI"/>
    </JadeMethod>
</Class>
