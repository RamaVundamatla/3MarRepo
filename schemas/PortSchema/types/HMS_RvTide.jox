<Class name="HMS_RvTide" id="36aa94ad-6d83-4727-b070-2bdf7dfed605">
    <superclass name="HMS_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <PrimAttribute name="tidalModel" id="a3423f1f-411a-4661-8eb9-81709a0ca2c1">
        <length>31</length>
