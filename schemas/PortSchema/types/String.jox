    <JadeMethod name="asRGB" id="ea18b49d-e291-4164-92c7-2ed2ad1b7759">
        <source>asRGB() : Integer;
//21 August 2008	cnwdw1	
//
vars
	tokens: StringArray;
begin
	create tokens transient;
	self.asStringArrayByDelimiter(tokens, ",");
	return (tokens[3].Integer * 256 * 256) + (tokens[2].Integer * 256) + tokens[1].Integer;
epilog
	delete tokens;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="asRealFromWebInterface" id="57173e3c-4e14-40e7-9912-db9f11e8243c">
        <source>asRealFromWebInterface():Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation	Par 30622

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to known format at both ends.
				
				See Real::asStringForWebInterface

