    <JadeMethod name="validateForCreate" id="802db3ca-64e8-4d27-b90f-b82a29956d9f">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.myUser.allUserQuickAccess[self.shortCode] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortCode, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0633aa85-a3ca-44c5-a33e-a49bb3aec932">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

	existing : CM_QuickAccessUser;

begin

	inheritMethod();
	
	if not self.isTransient then
	
		existing := self.myUser.allUserQuickAccess[self.shortCode];
		
		if existing &lt;&gt; null and existing &lt;&gt; self then 
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortCode, null, null);
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="9bb9ead1-ec2d-4e0e-9112-ada0e6f5f575">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	if self.myUser = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'User', null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
