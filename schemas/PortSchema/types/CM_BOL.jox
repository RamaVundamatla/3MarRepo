    <JadeMethod name="updateBOLStops" id="78a904ed-66a5-45b5-831f-2fd525a28e74">
        <updating/>
        <source>updateBOLStops( _allPxyStops : CM_StopsByIdDict; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2015	cnwndl1	Initial creation

*/

vars

	pxyStop : CM_Stops;
	stop : CM_Stops;
	delStops : CM_StopSet;

begin

	create delStops transient;
	foreach stop in self.allStops do
		pxyStop := _allPxyStops[stop.id];
		if pxyStop = null then
			//need to delete the real one.
			delStops.add(stop);
		endif;
	endforeach;
	foreach stop in delStops do
		self.removeAStop( stop.myStopsTable, true, _passport );
	endforeach;

	foreach pxyStop in _allPxyStops do
		stop := self.allStops[pxyStop.id];
		if stop = null then
			//need to add one.
			self.createAStop( pxyStop.myStopsTable, true, _passport );
		else
			//update real one if required
			stop.setClearanceExpiryDate( pxyStop.clearanceExpiryDate );
		endif;
	endforeach;

epilog

	delete delStops;

end;</source>
        <Parameter name="_allPxyStops" type="CM_StopsByIdDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateBOLNumber" id="44269770-8e9a-4443-8208-809826d3c6eb">
        <source>validateBOLNumber(pControl: CMIF_TIUpdateController);
//--------------------------------------------------------------
//Created: 03 December 2002 By: cnwgd1
// 11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
//--------------------------------------------------------------
vars
	iter		: Iterator;
	bolDict		: CM_BOLByTypeNumberDTDict;
	bol			: CM_BOL;
	typeKey		: Integer;
	numKey		: String;
	tsKey,
	ts			: TimeStamp;
	realBOL		: CM_BOL;

begin
	
	if self.isTransient then
		realBOL := self.pxyGetRealObject();
		if realBOL &lt;&gt; null and realBOL.number = self.number then
		//This is an update and the number has not changed, so nothing to do here
			return;
		endif;
	endif;
	
	if  app.myRoot.getConfig(StrictBOLNumberCheck).Boolean then  // cnwrd1 par 31250
		if not self.number.containsOnlyUppAlphaAndNumeric then
			app.raiseCMException1(Docket_number_error, self.number, ETRow_Number, null);
		endif;
	endif;
				
	//check the BOL number is not duplicate within the Terminal config BOL duplcate period
	ts := app.serverTimestampAtTrxStart;
	bolDict := self.getAllBolsForNumValidation();
	iter := bolDict.createIterator;
	bolDict.startKeyLeq(self.bolType, self.number, ts, iter);
	if iter.next(bol) then
		if bol.myOperator = self.myOperator then
			iter.getCurrentKeys(typeKey,numKey,tsKey); //MTN-35226
			if typeKey = self.bolType and
			   numKey = self.number then
				// Number has been need used previously so need to check dates
				if (not self.myTerminal.validateBOLInDate(tsKey)) then
					app.raiseCMException1(BOLDuplicateWithinCheckPeriod, self.number, ETRow_Number, null);
				endif;
			endif;
		endif;
	endif;
epilog
delete iter;
	
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b5c0ad92-cea6-446c-83ac-9146059c8173">
