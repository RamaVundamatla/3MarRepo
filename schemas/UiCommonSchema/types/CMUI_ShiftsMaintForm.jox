    <JadeMethod name="btnSaveShiftDay_click" id="744e71aa-459c-47d8-bdfc-13d315682fd8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveShiftDay_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		21 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.mode &lt;&gt; self.MODE_ADD then
		if self.myCurrentShift.isTransient then
			self.myProxyShift := self.myCurrentShift;
			self.mode := self.MODE_ADD;
		else
			self.myProxyShift := self.createProxiesForEdit();
			self.mode := self.MODE_EDIT;
		endif;
	endif;
	
	self.doBtnSaveClick();

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSaveShift_click" id="efe9398a-1272-459d-aa45-7c09afd0ca9e">
