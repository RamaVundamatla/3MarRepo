Date			Who		Reason
29 March 2023	navpw1	Initial creation TFS: 57198

*/

vars
	tis	: CM_TISet;
	ti	: CM_TrackedItem;

begin
	tis := self.allAssignedTrackedItems;
	if not tis.isEmpty then
		ti := tis.first;
		if ti &lt;&gt; null then
			return ti.operatorDescription;
		endif;
	endif;
	
	return null;

end;</source>
