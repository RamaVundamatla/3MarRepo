    <JadeMethod name="checkHeightAlterationOnTA" id="5dbbcc5c-477a-4a6c-8737-b1f77b754be5">
        <source>checkHeightAlterationOnTA();
// ---------------------------------------------------------------------------
// Created:    MAY 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realController,																						//+cnwml2 PAR19197
	controller	: CM_GridController;

begin

	foreach controller in self.allGridControllersByRowColumn do
		realController := controller.pxyGetRealObject;													//+cnwml2 PAR19197
		if realController &lt;&gt; null and realController.getTotalHeight() &gt; self.heightOfStack * 2 then		//+cnwml2 PAR19197
			//controller.getTotalHeight() &gt; self.heightOfStack * 2 then									//-cnwml2 PAR19197
			app.raiseCMException(ERR_STACK_OVER_HEIGHT, null, null);
			break;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="checkReduceSize" id="27879f63-7dc2-4cff-83e8-b0d8a94bec1a">
        <source>checkReduceSize(_realTA: CM_GridArea ): Boolean;
/*

Purpose:			
Stops user from reducing the size of a grid Area if it will leave cargo with a null location  
Parameters:			

Return Value:		
Boolian: is change ok
Date		Who		Reason
20 September 2017 	jlgns1	Initial creation
//20 September 2017 jlgns1 TFS 6956 QNS - RT Queue error
*/

vars
	locController : CM_LocationsController;
	lMaxHeight : Integer;
	lMaxWidth  : Integer;
	lMaxLength : Integer;
begin
	
	if not _realTA.hasGridAreaDecreased(self) then
		return true;
	endif;
	
	foreach locController in _realTA.allLocationsControllers discreteLock do
		if not locController.allTrackedItems.isEmpty or 
			not locController.allPlannedFutureMoves.isEmpty or 
			not locController.allQueuedFutureMoves.isEmpty then
			lMaxHeight := lMaxHeight.max(locController.allTrackedItems.size);
			lMaxWidth := lMaxWidth.max(locController.CM_GridController.column);
			lMaxLength := lMaxLength.max(locController.CM_GridController.row);
		endif;	
	endforeach;

	if lMaxHeight &gt; self.heightOfStack
		or lMaxWidth &gt; self.allGridColumns.size 
		or lMaxLength &gt; self.allGridRows.size then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_realTA" type="CM_GridArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convStackToSubBlock" id="f02c7ceb-222a-4c83-929e-c905c2771373">
        <updating/>
        <source>convStackToSubBlock(pGrid : CMIF_GridTARegion input; _theRealSubBlock : CM_SubBlockStack output;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:    August 2002 By Andrew Bishop cnwab1
//
// Purpose:    Method that converts a specified range of locationControllers
//			  into a sub-block stack. 
 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	controller 		: CM_LocationsController;
	theBlockStack 	: CM_SubBlockStack;
begin
	theBlockStack := self.allSubBlockStacks[pGrid.idOriginal];
	if theBlockStack = null then
		theBlockStack := self.createSubBlock(pGrid, _passport);
	endif;
	
	//------------------
	//check decking options exists
	//------------------
	theBlockStack.createDeckingOptions();
	
	exclusiveLock(theBlockStack);
	// remove any that need removing
	foreach controller in theBlockStack.allByPassedControllers do
		sharedLock(controller);
		if not pGrid.allLocationControllers.includes(controller) then // remove
			controller.CM_GridController.setMySubBlockStack(null); // this does an inverse to the subs 'allbypassedControllers'
		endif;
	endforeach;
	
	// add new ones
	foreach controller in pGrid.allLocationControllers do
		sharedLock(controller);
		if controller.CM_GridController.mySubBlockStack = null then // NEW
			controller.CM_GridController.setMySubBlockStack(theBlockStack); // this does an inverse to the subs 'allbypassedControllers'
		endif;
	endforeach;
	theBlockStack.autoRestrictionsEnabled := pGrid.autoRestrictionsEnabled;
	_theRealSubBlock := theBlockStack;
	_theRealSubBlock.hideFromOverView := pGrid.hideFromOverView;
	_theRealSubBlock.isStockControlled := pGrid.isStockControlled;
	if _theRealSubBlock.myLayoutGraphic &lt;&gt; null then //PAR7455 added
	_theRealSubBlock.myLayoutGraphic.setColour(pGrid.colour);//PAR7455 added
	endif;
	_theRealSubBlock.maxCapacity := pGrid.maxCapacity;  //par18840 cnwjo3
epilog
	sharedLock(theBlockStack);

end;</source>
        <Parameter name="pGrid" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_theRealSubBlock" type="CM_SubBlockStack" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convSubBlockToStack" id="c8e229f0-54d8-455c-8df2-9921e2faa217">
        <updating/>
        <source>convSubBlockToStack(pGrid : CMIF_GridTARegion input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
constants
		VB_TA_ID_LEN : Integer = 12;
vars
	sbsKey			: String;
	theBlockStack	: CM_BlockStack;
	aController		: CM_LocationsController;
begin
	theBlockStack := self.allSubBlockStacks[pGrid.idOriginal];
	
	if theBlockStack = null then
		app.raiseCMException(ERR_NO_BLOCKSTACK, null, null);
	endif;

	exclusiveLock(theBlockStack);

	//This object has the list of dereferenced LC's we have to free up.
	//It also has its own lists of TI's we must check to make sure that
	//the block stack is MT.
	
/*	DO NEED TO DO THIS AS IT IS AUTO INVERSED UP, deleting the sub block frees the controllers.
	if global.isValidObject(theBlockStack.locationsController) then
		sharedLock(theBlockStack.locationsController);

		// go through all of the stack controllers that we now want back and get rid of their reference to us, so that they pop back into use.
		foreach	aController in theBlockStack.allByPassedControllers do
			aController.CM_GridController.mySubBlockStack := null;
		endforeach;
	endif;		
*/		
	theBlockStack.erase(NORMAL_ERASE);
	self.updateObjectEdition (self);	// par 30292

end;</source>
        <Parameter name="pGrid" type="CMIF_GridTARegion" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargo" id="272ea437-9ca2-4a55-b339-5d928dea534d">
        <updating/>
        <source>createQuickCargo(_numItems : Integer; _is40 : Boolean; _startLC : CM_GridController) updating;
// ---------------------------------------------------------------------------
// Created:     1 DEC 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx, numItems : Integer;
begin

 
	aTerm := self.myTerminal;
	aVoy	:= aTerm.getNullVoyage();
 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	cargoType	:= app.myRoot.allCargoTypesById[TI_CargoType_Container];
	state := TI_STATE_NORMAL;
	numItems := _numItems.min(500);
	
	create moveController transient;
	foreach idx in 1 to numItems do
		moveController.setMyToPrimaryLocation(self.getNextAvailableLocation(_startLC));
		if moveController.myToPrimaryLocation = null then
			break;
			endif;
		tmpID := self.getNextQuickCargoID(TI_CargoType_Container);
		
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyOperator(app.myRoot.allOperators["MSC"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		pxyTI.setCommodity("MT");
		pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
		if _is40 then
			pxyTI.changeISOType("4200", null, app.myPassport);
		else
			pxyTI.changeISOType("2200", null, app.myPassport);
		endif;
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	"MT",
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		
		passport.warningsAcknowledged := true; // BISH15FEB2022
				
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_startLC" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoWithAlloc" id="2039b7d6-4a4b-4775-8d72-df248ff637d1">
        <updating/>
        <source>createQuickCargoWithAlloc(_alloc : CM_VoyageAllocation) updating;
// ---------------------------------------------------------------------------
// Created:     1 DEC 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	startLC : CM_GridController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx, numItems : Integer;
	isoGroup : CM_ISOTypeGroup;
	isoType : CM_ISOType;
begin

 
	aTerm := self.myTerminal;
	aVoy	:= _alloc.myVoyage;
 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	cargoType	:= _alloc.getCargotype();
	state := TI_STATE_NORMAL;
	numItems := _alloc.getNumSlotReqs();
	
	create moveController transient;
	foreach idx in 1 to numItems do
		moveController.setMyToPrimaryLocation(self.getNextAvailableLocation(startLC));
		if moveController.myToPrimaryLocation = null then
			break;
			endif;
		tmpID := self.getNextQuickCargoID(TI_CargoType_Container);
		
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyOperator(app.myRoot.allOperators["MSC"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		
		if cargoType.allCommodities.first &lt;&gt; null then
		
			pxyTI.setCommodity(cargoType.allCommodities.first.code);
		else
		
			pxyTI.setCommodity("GENL");
		
		endif;
		pxyTI.setImExStatus(_alloc.getIMEXStatus().code);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		
		pxyTI.zSetPxyDischargePort(_alloc.getDischargePort().code);
		
		isoGroup := _alloc.getISOGroup();
		if isoGroup &lt;&gt; null then
			isoType := isoGroup.allISOTypes.first;
		endif;
		
		if isoType &lt;&gt; null then
			pxyTI.changeISOType(isoType.code, null, app.myPassport);
		endif;
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	"MT",
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_alloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="createSubBlock" id="95cec8f0-aeca-417b-a445-c4d136a71b23">
        <updating/>
        <source>createSubBlock(pGrid : CMIF_GridTARegion input; _passport : CM_Passport input) : CM_SubBlockStack updating;
// ---------------------------------------------------------------------------
// Created:    August 2002 By Andrew Bishop cnwab1
//
// Purpose:		Method that creates a sub-block stack Terminal Area
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------

vars
	theSubBlockStack: CM_SubBlockStack;
begin
	exclusiveLock(self);

	create theSubBlockStack persistent;
	theSubBlockStack.initForSubBlockStack(pGrid, self);

	self.updateObjectEdition (self);	// par 30292

	return theSubBlockStack;
end;</source>
        <Parameter name="pGrid" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SubBlockStack"/>
    </JadeMethod>
    <JadeMethod name="deckingLocations" id="8103d27c-191d-4257-abdd-ac65dbbf289a">
        <source>deckingLocations(_locations: CM_LCArray io);
//05 January 2009	cnwdw1	
//
vars
    gridRow: CM_GridRow;
    rowCount: Integer;
begin
    foreach gridRow in self.allGridRows where gridRow.isDeckable do
        gridRow.allControllersByColumn.copy(_locations);
        rowCount := rowCount + 1;
        if rowCount &gt; self.numberOfDeckingRows then
            break;
        endif;
    endforeach;
end;
</source>
        <Parameter name="_locations" type="CM_LCArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doExportGPS" id="01c8f448-91eb-45d1-9eba-b700d03095ed">
        <source>doExportGPS() : String;
// ---------------------------------------------------------------------------
// Created:		22 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gr : CM_GridRow;
	gc : CM_GridColumn;
	export : String;
begin
	foreach gr in self.allGridRowsByLabel do
	
		if gr.hasGap then
			continue;
		endif;
		export := export &amp; "ROW, " &amp; self.allGridRowsByLabel.indexOf(gr).String &amp; "," &amp; gr.gpsY.String &amp; CrLf;
 	endforeach;

	foreach gc in self.allGridColumnsByLabel do

		if gc.hasGap then
			continue;
		endif;
		export := export &amp; "COL, " &amp; self.allGridColumnsByLabel.indexOf(gc).String &amp; ", " &amp; gc.gpsX.String &amp; CrLf;
 	endforeach;
	return export;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="21b7c194-c052-408c-9f0c-2eebd06c81e8">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allGridColumns, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridColumnsByGPSX, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridColumnsByLabel, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridControllersBy40ftId, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridControllersByName, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridControllersByRowColumn, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridRows, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridRowsByGPSY, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allGridRowsByLabel, _logIndent);
	
		
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
