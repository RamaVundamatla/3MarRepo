    <JadeMethod name="startDoingConnection" id="a7b95705-8821-4b4c-b98a-e8e6224b7679">
        <source>startDoingConnection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwrh7	Initial creation

*/

vars
	ti 												: 		CM_TrackedItem;
	tcpWeightController			:		CM_TCPWeightIntController;
	
begin
	tcpWeightController := self.myTCPWeightInterfaceController;				//already created tranisent in forsetup form method
	// Warning if there is no ToDo Task or the weight is not Forced    
	if self.myVMAgent.myMachine.getCurrentTwinTask() = null then    //15/08/2016 cnwma1 TFS #2475 (similar in doMOveFramesRefresh)
		ti := self.myVMAgent.myMachine.currentQueueTask.ti;
		if ti &lt;&gt; null then
			if ti.isKindOf(CM_Container) and ti.weighStatus &lt;&gt; WEIGH_STATUS_FORCED then       
				if not ti.CM_Container.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then
					app.msgBox(app.getErrorString1(Contai_not_marked_weighi_requi,null),"Warnning",MsgBox_OK_Only);
				endif;	
			endif;
		endif;
	endif;
	
	if self.myTCPWeightInterfaceController.tcpConnectReady then			//has been set to trun in interface setup/ false when delete myTCPWeightInterfaceController
		self.myTCPWeightInterfaceController.closeConnection();					//to be sure that Connection is closed
		self.myTCPWeightInterfaceController.doOpen();
	endif;
	
epilog

end;</source>
    </JadeMethod>
