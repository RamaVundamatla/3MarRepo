    <JadeMethod name="valDeleteRestAuthTokens" id="0a1588e1-217a-4bed-b0f7-479c314b6dc8">
        <source>valDeleteRestAuthTokens(_tokensToDelete : ObjectArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/04/2021	navdap1		Initial creation TFS 50491 MTN Reefer Jobs: Auto-create when Externally Monitored changes
//
vars
	obj : Object;
	token : CM_RestAuthToken;
	result : String;
	response : String;

begin
	foreach obj in _tokensToDelete do
		token := obj.CM_RestAuthToken;
		result := token.validateForDelete;
		if result &lt;&gt; null then
			if response = null then
				response := result;
			else
				response := CrLf &amp; result;
			endif;
		endif;
	endforeach;
	
	if response &lt;&gt; null then
		app.raiseCMException1(Machine_Logger_Errors, response, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_tokensToDelete" type="ObjectArray"/>
    </JadeMethod>
