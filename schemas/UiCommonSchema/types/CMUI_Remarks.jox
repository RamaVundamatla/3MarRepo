        <source>doComboBox(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lStr : String;
begin
	lStr := combobox.text;
	lStr.replaceChar(Tab, " ");
	self.tblMain.accessCell(self.tblMain.row,self.tblMain.column).text := lStr;
	self.tblMain.accessedCell.itemObject := combobox.itemObject[combobox.listIndex];

end;</source>
