    <JadeMethod name="zLstTreeDragOverEvent" id="0ad70bd8-0e26-43c9-bae6-520c1765fbff">
        <final/>
        <updating/>
        <source>zLstTreeDragOverEvent(listBox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating, protected, final;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	menuEntity				: CM_MenuEntity;
	listIdx					: Integer;
begin
	if app.myMoveController &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;
	
	listIdx := listBox.dragListIndex;
	
	if listIdx = self.dragOverIndex then
		return;
	endif;
	
	self.endTimer(self.TIMER_OPENFOLDER);
	self.beginTimer(1000,  Timer_OneShot, self.TIMER_OPENFOLDER);
	self.dragOverIndex	:=	listIdx;
	listBox.listIndex	:=	listIdx;

end;


</source>
        <access>protected</access>
        <Parameter name="listBox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
