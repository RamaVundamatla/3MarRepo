    <JadeMethod name="shouldAuditProperty" id="e067a7e3-e81d-44d9-b732-3dccf56d7f30">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_WorkOrderServiceBroker::myChildQuantityMap.name  
	or propName = CM_WorkOrderServiceBroker::workOrderType.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
