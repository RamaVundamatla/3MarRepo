    <JadeMethod name="getNextSystemVoyageCode" id="1e07694a-039e-4f04-87e2-a91b21d2d77b">
        <updating/>
        <source>getNextSystemVoyageCode(_terminal : CM_Terminal) : String updating;
//--------------------------------------------------
// Created:	23 August 2004 By: cnwgd1
//--------------------------------------------------
//was vesselCode 25 + 4 digit number = 29 characters, but voyage code only 20 characters long
//changed to use 4 digit prefix (terminal code or config setting) + key series sequence number
vars
 	prefix,
 	tmpVoyageCode : String;
begin

	if self.systemVoyageCodeRoot &gt; 0 then
	 	prefix := _terminal.getConfig(HMSVoyageCodePrefix).String;
	 	if prefix = null then
	 		prefix := _terminal.code;
	 	endif;
		tmpVoyageCode := prefix &amp; self.systemVoyageCodeRoot.String;
	else	
		app.myTrxUA.trxHMSGetNextSystemVoyageCode(_terminal, tmpVoyageCode, app.myPassport);
		self.systemVoyageCodeRoot := tmpVoyageCode.getTrailingInteger();
	endif;
	
	return tmpVoyageCode;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationForHMSVoyage" id="7f30dccd-89c8-4c5b-91dd-4099cec69b4d">
        <updating/>
        <source>handleNotificationForHMSVoyage(eventType: Integer; _hmsVoyage: HMS_VoyageData)updating;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if eventType = Object_Create_Event then
		self.voyage_AddToView(_hmsVoyage);		
	elseif eventType = Object_Delete_Event then
		self.voyage_RemoveFromView(_hmsVoyage);			
	elseif eventType = Object_Update_Event then
		self.voyage_UpdateView(_hmsVoyage);					
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="haveAnyMovementTimesChanged" id="69aaa7a0-1983-4796-ac11-026dafd60a73">
        <source>haveAnyMovementTimesChanged() : Boolean;
/*
Purpose:			Determine whether any of the working movements have had their dates / times changed
					The result of this will be used to kludge / suppress an error message to do with
					dates / times when the only things tht have been changed on the movements are tugs etc

Parameters:			

Return Value:		

Date		Who		Reason
30/01/2012	cnwdap1	Initial creation PAR #29019
*/
vars
	workingMovement		: CMIF_HMS_WorkingMovement;
	realMovement		: HMS_VoyageMovement;

begin
	foreach workingMovement in self.allMovementsInViewByDT discreteLock do
		if workingMovement.myPersistentMovement &lt;&gt; null then
			realMovement := workingMovement.myPersistentMovement;
			
			// has the date/time of this movement changed?
			if realMovement.occursOnDTNEW &lt;&gt; workingMovement.occursOnDT then
				return true;
			endif;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeVoyageInView" id="16158d88-acff-416b-892e-a786d70a6432">
        <source>includeVoyageInView(_voyage : CM_Voyage) : Boolean;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
17 Sep 2008	cnwkpd1	PAR #17956 - Improve performance of Graphical view load

*/

vars
	movement 			: HMS_Movement;
	hmsVoyageData 		: HMS_VoyageData;
	includeInView 		: Boolean;
//	allPhysicalWharfs 	: HMS_WharfByCodeDict;
	wharf 				: HMS_Wharf;
	
begin
	if _voyage = null 
	or _voyage.archived
	or _voyage.isCancelled  //jlier1 TFS 51963 5/10/21
	or _voyage.myHMSVoyageData = null then
		return false;
	endif;
	
	// PAR #17956 - Rework to check for exclusions by date first
	// Voyage departs before the start date, exclude it
	if _voyage.departedDT &lt; self.viewStartDT then
		return false;
	endif;
	
	// Voyage arrives after the end date, exclude it
	if _voyage.arrivedDT &gt; self.viewFinishDT then
		return false;
	endif;

	// PAR 15959, and moved up for PAR #17956
	if (not self.myHarbour.allTerminalsByCode.includes(_voyage.myTerminal)) then
		return false;
	endif;

/*	PAR #17956 - rework wharf check to remove transient dictionary create and populate
	
	// check if this voyage berths in the terminal
	create allPhysicalWharfs transient;
	foreach wharf in self.allWharves do
		if wharf.isLogicalWharf then
			continue;
		endif;
		allPhysicalWharfs.add(wharf);
	endforeach;
*/	
	//epr par 16808 29/5/08 we shouldn't be able to see any other voyages 

	hmsVoyageData := _voyage.myHMSVoyageData;
	includeInView := false;
	wharf := null;
	foreach movement in hmsVoyageData.allVoyageMovements do
		wharf := movement.getMyWharf;
		if wharf = null then
			continue;
		endif;
		// PAR #17956 - rework condition without local dictionary
		//if not wharf.isLogicalWharf and self.allWharves.includes(wharf) then	//comented by PAR 21734 Dec 2009
		if self.allWharves.includes(wharf) then	//need to show ships on logical wharf - Anchorage. PAR 21734 Dec 2009
//		if allPhysicalWharfs.includes(wharf) then
			includeInView := true;
			break;
		endif;
	endforeach;
	
	if not includeInView then
		return false;
	endif;
	
	if hmsVoyageData.allVoyageMovements.isEmpty then
		//Hmm... something wrong with this voyage
		return false;
	endif;

/*	PAR #17956 - old code replaced
	// voyage arrives after the start date and before the end date
	if (_voyage.arrivedDT &gt;= self.viewStartDT and _voyage.arrivedDT &lt;= self.viewFinishDT)
	
	// voyage departs after the start date and before the end date
	or (_voyage.departedDT &gt;= self.viewStartDT and _voyage.departedDT &lt;= self.viewFinishDT)
	
	// voyage arrives before the start date and departs after the end date
	or (_voyage.arrivedDT &lt;= self.viewStartDT and _voyage.departedDT &gt;= self.viewFinishDT) then
        //This voyage should be included the view

		return true;
	endif; 
	return false;
*/

	// Got to here, must be OK
	return true;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialiseController" id="24dc143a-aa82-4427-a7f9-76ade15a446b">
        <updating/>
        <source>initialiseController(_terminal : CM_Terminal; _startDT, _finishDT : TimeStamp) updating;

vars
begin

	self.setMyTerminal(_terminal);
	
	// Set default start and finish dates for the view
	self.setDefaultDateRangeForView(_startDT, _finishDT);

	// Temporary code to set default dates for demo system
	// ------------------------------------------------------------------------
	//viewStartDT:=("18/02/99".Date.String &amp; ",00:00:00").TimeStamp;
	//viewFinishDT:=((viewStartDT.Date+7).Date.String &amp; ",00:00:00").TimeStamp;
   	// ------------------------------------------------------------------------


	// Build default collections
//	self.buildView_WorkingVoyageAndMove();


end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_finishDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="isNotifyObjectMyObject" id="0e7829f3-a876-4d48-8845-c10707661f72">
        <source>isNotifyObjectMyObject(_notifyObject : Object) : Boolean;
// AKB2002MAY
// Checks whether the object that raised a causeEvent on this controller is the same object that I am currently updating
vars
	aOK : Boolean;
	workingVoyage : CMIF_HMS_WorkingVoyage;
	workingMovement : CMIF_HMS_WorkingMovement;
	anObject : Object;
	theObject : Object;
	theString : String;
begin

	aOK := false;
	// ########################################
	// MOVEMENTS
	theObject := null;
	if _notifyObject.isKindOf(HMS_VoyageMovement) then
		theString := _notifyObject.String;
		//check throught he list of changes to see whether this updated object is part of my changes
		if self.allChanges.size &gt; 0 then
				foreach anObject in self.allChanges do
					if anObject.isKindOf(CMIF_HMS_MovementAdd) then
						theObject := anObject.CMIF_HMS_MovementAdd.appliesToMovement.myPersistentMovement;
					endif;
					if anObject.isKindOf(CMIF_HMS_MovementEdit) then
						theObject := anObject.CMIF_HMS_MovementEdit.appliesToMovement.myPersistentMovement;
					endif;
					if anObject.isKindOf(CMIF_HMS_MovementDelete) then
						theObject := anObject.CMIF_HMS_MovementDelete.appliesToMovement.myPersistentMovement;
					endif;
				endforeach;

		endif;
		// else check if the current selected is the same
		if theObject = null then
			theObject := self.myCurrentWorkingMovement.myPersistentMovement;
		endif;
	endif;

	// ########################################
	// VOYAGES
	if _notifyObject.isKindOf(CM_Voyage) then
		//check throught he list of changes to see whether this updated object is part of my changes
		if self.allChanges.size &gt; 0 then
				foreach anObject in self.allChanges do
					if anObject.isKindOf(CMIF_HMS_VoyageAdd) then
						theObject := anObject.CMIF_HMS_VoyageAdd.appliesToVoyage.ofPermanentVoyage;
					endif;
					if anObject.isKindOf(CMIF_HMS_VoyageEdit) then
						theObject := anObject.CMIF_HMS_VoyageEdit.appliesToVoyage.ofPermanentVoyage;
					endif;
					if anObject.isKindOf(CMIF_HMS_VoyageDelete) then
						theObject := anObject.CMIF_HMS_VoyageDelete.appliesToVoyage.ofPermanentVoyage;
					endif;
				endforeach;

		endif;
		// else check if the current selected is the same
		if theObject = null and self.myCurrentWorkingVoyage &lt;&gt; null then
			theObject := self.myCurrentWorkingVoyage.ofPermanentVoyage;
		endif;
	endif;


	if theObject = _notifyObject then
		aOK := true;
	endif;

	return aOK;
end;</source>
        <Parameter name="_notifyObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="recalc_Clearances" id="796c2f46-458f-4834-805f-667ab81a0d36">
        <updating/>
        <source>recalc_Clearances(changeToApply:CMIF_HMS_StackChange; mode:Integer) updating;

/*

Date		Who		Reason
15 Apr 2008	cnwkpd1	PAR #16513 - Restrict the scope of the clearance recalculation to movements in the
					view in the range of the change

*/

vars
 	workingMovement,
 	closestMoveUpWharf,
 	closestMoveDownWharf,
 	arrivalMovement,
 	movement,
 	movementPrevious,
 	movementNext,
 	movVerPrev:				CMIF_HMS_WorkingMovement;
 	voyage:					CMIF_HMS_WorkingVoyage;
 	wharvesToCheck:			ObjectArray;
 	startDT:				TimeStamp;
 	endDT:					TimeStamp;
	iter:					Iterator;
	
begin
	// This method checks to see if a movement needs to have its clearances recalculated 
	// due to the fact that another movement has changed its position in the plan - ie date 
	// or time.

	create wharvesToCheck transient;

	// Determine whether the date or position of a movement has changed	
	if changeToApply.isKindOf(CMIF_HMS_VoyageAdd) then
		// Check to see if arrival movement is to a physical berth
		if mode = RecalcClearance_Mode_Apply then
			voyage	:=	changeToApply.CMIF_HMS_VoyageAdd.appliesToVoyage;
		else
			voyage	:=	changeToApply.CMIF_HMS_VoyageAdd.appliesToVoyage.versionPrevious;
		endif;
		
		if voyage &lt;&gt; null then
			arrivalMovement	:=	voyage.allWorkingMovements.first();
			
			if arrivalMovement.moveType = $MoveTypeArrival and (not arrivalMovement.isLogicalBerth()) then
				startDT	:=	voyage.arrivedDT;
				endDT	:=	voyage.departedDT;
				wharvesToCheck.add(arrivalMovement.myBerth.myWharf);
			endif;
		endif;
			
	elseif changeToApply.isKindOf(CMIF_HMS_VoyageDelete) then 
		// Check to see if arrival movement is to a physical berth
		if mode = RecalcClearance_Mode_Apply then
			voyage	:=	changeToApply.CMIF_HMS_VoyageDelete.appliesToVoyage;
		else
			voyage	:=	changeToApply.CMIF_HMS_VoyageDelete.appliesToVoyage.versionPrevious;
		endif;
		
		if voyage &lt;&gt; null then
			foreach movement in voyage.allWorkingMovements do
				if (not movement.isLogicalBerth()) then
					wharvesToCheck.add(movement.myBerth.myWharf);
				endif;
			endforeach;
			
			startDT	:=	voyage.arrivedDT;
			endDT	:=	voyage.departedDT;
		endif;
			
	elseif changeToApply.isKindOf(CMIF_HMS_VoyageEdit) then
 		// Nothing to check - No position or date changes
 	elseif changeToApply.isKindOf(CMIF_HMS_MovementAdd) then
 		if mode = RecalcClearance_Mode_Apply then
			movement	:=	changeToApply.CMIF_HMS_MovementAdd.appliesToMovement;
		else
			movement	:=	changeToApply.CMIF_HMS_MovementAdd.appliesToMovement.versionPrevious;
		endif;
		
		if movement &lt;&gt; null then
	 		startDT	:=	movement.getMovementPrevious.occursOnDT;
	 		endDT	:=	movement.getMovementNext().occursOnDT;
			
	 		if (not movement.isLogicalBerth()) then
				wharvesToCheck.add(movement.myBerth.myWharf);
			endif; 
			
			if (movement.getMovementPrevious.isLogicalBerth()) then
				wharvesToCheck.add(movement.getMovementPrevious().myBerth.myWharf);
			endif;
		endif;
		
	elseif changeToApply.isKindOf(CMIF_HMS_MovementEdit) then
		if mode = RecalcClearance_Mode_Apply then
			movement	:=	changeToApply.CMIF_HMS_MovementEdit.appliesToMovement;
			movVerPrev	:=	changeToApply.CMIF_HMS_MovementEdit.appliesToMovement.versionPrevious;
		else
			movement	:=	changeToApply.CMIF_HMS_MovementEdit.appliesToMovement.versionPrevious;
			movVerPrev	:=	changeToApply.CMIF_HMS_MovementEdit.appliesToMovement;
		endif;
		
    	//movement:=changeToApply.CMIF_HMS_MovementEdit.appliesToMovement;	
    	//movVerPrev:=changeToApply.CMIF_HMS_MovementEdit.appliesToMovement.versionPrevious;
    	// Check to see if date or position have changed
    	if movement &lt;&gt; null then
	   		if movement.moveType = $MoveTypeDeparture then
	   			// Departure movement
	   			if movement.occursOnDT &lt;&gt; movVerPrev.occursOnDT then
	    			movementPrevious	:=	movement.getMovementPrevious();
					
	    			if (not movementPrevious.isLogicalBerth()) then
	    				startDT	:=	movementPrevious.occursOnDT;
						
	    				// Set end date to later of the two dates
	    				if movement.occursOnDT &gt; movVerPrev.occursOnDT then
	    					endDT	:=	movement.occursOnDT;
	    				else
	    					endDT	:=	movVerPrev.occursOnDT;
	    				endif;
						
	    				wharvesToCheck.add(movementPrevious.myBerth.myWharf);
	    			endif;
	    		else 
	    			// Dates haven't changed - nothing to check
	   			endif;
	   		else
	   			// Shift or Arrival 
	   			// Check that the movement berths (new and old movements) are physical
	   			if (not movement.isLogicalBerth()) then
	   				wharvesToCheck.add(movement.myBerth.myWharf);	
	   			endif;
				
	   			if (not movVerPrev.isLogicalBerth()) then
	   				// if different to movement.myBerth.ofWharf then add
	   				if movVerPrev.myBerth.myWharf &lt;&gt; movement.myBerth.myWharf then
	   					wharvesToCheck.add(movVerPrev.myBerth.myWharf);	
	   				endif;
	   			endif;
				
	   			if wharvesToCheck.size &gt; 0 then
	   				// Check to see if DT or position has changed
	   				if movement.occursOnDT &lt;&gt; movVerPrev.occursOnDT then
	   					// Date has changed - check extremes of time changes
	   					// Set start date to earlier of the two dates
	    				if movement.occursOnDT &gt; movVerPrev.occursOnDT then
	    					startDT	:=	movement.occursOnDT;
	    				else
	    					startDT	:=	movVerPrev.occursOnDT;
	    				endif;
						
	   					movementNext	:=	movement.getMovementNext();
						
// cnwdad1 26/06/2007 - If "movementNext" was null, a 1090 exception occurred.
						if movementNext &lt;&gt; null then
							endDT	:=	movementNext.occursOnDT;
						endif;
	   				else
	   					// Check to see if position has changed - dates still the same
	   					startDT			:=	movement.occursOnDT;
	   					movementNext	:=	movement.getMovementNext();	
	   					endDT			:=	movementNext.occursOnDT;
						
						// Check to see if wharf has changed
	   					if movement.myBerth.myWharf &lt;&gt; movVerPrev.myBerth.myWharf then
	   						// Wharf has changed
	   					else
	   						// Check to see if marks have changed
	   						if movement.bowMarkTo &lt;&gt; movVerPrev.bowMarkTo then
	   							// Marks have changed
	   						else
	   							// Marks still the same - no need to check
	   							wharvesToCheck.clear();
	   						endif;
	   					endif;
	   				endif;
	   			endif;
	    	endif;
	    endif;
	    
    elseif changeToApply.isKindOf(CMIF_HMS_MovementDelete) then
    	if mode = RecalcClearance_Mode_Apply then
			movement	:=	changeToApply.CMIF_HMS_MovementDelete.appliesToMovement;
		else
			movement	:=	changeToApply.CMIF_HMS_MovementDelete.appliesToMovement.versionPrevious;
		endif;
		
		if movement &lt;&gt; null then
	 		startDT	:=	movement.getMovementPrevious().occursOnDT;
	 		endDT	:=	movement.getMovementNext().occursOnDT;
			
	 		if (not movement.isLogicalBerth()) then
				wharvesToCheck.add(movement.myBerth.myWharf);
			endif;
			
			if (not movement.getMovementPrevious().isLogicalBerth()) then
				wharvesToCheck.add(movement.getMovementPrevious().myBerth.myWharf);
			endif;
		endif;
    endif;
	
    if wharvesToCheck.size &gt; 0 then
    	// movements need to be checked
		
		// PAR #16513 - check only the movements between startDT and endDT
		iter := self.allMovementsInViewByDT.createIterator;
		self.allMovementsInViewByDT.startKeyGeq(startDT, iter);
		
//    	foreach workingMovement in allMovementsInViewByDT where wharvesToCheck.includes(workingMovement.myBerth.myWharf) = true do
		while iter.next(workingMovement) do
			if workingMovement.occursOnDT &gt; endDT then
				break;
			endif;
			
			if wharvesToCheck.includes(workingMovement.myBerth.myWharf) then
				// ie. check only movements on the same wharf as the changed movement
				workingMovement.calc_Clearances(closestMoveUpWharf, closestMoveDownWharf);
			endif;
		endwhile;
	
	endif;

	
epilog
	delete wharvesToCheck;
	delete iter;
	
end;</source>
        <Parameter name="changeToApply" type="CMIF_HMS_StackChange"/>
        <Parameter name="mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveChangesToDatabase" id="593b4371-765d-4a7a-a02d-bc7a6ee73c8b">
        <updating/>
        <source>saveChangesToDatabase(_passport : CM_Passport input)updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
30/01/2012	cnwdap1	PAR #29019 	Detect if any dates/times have changed on any movements
								If no dates/times have changed, skip validation of the waiting time(s)
23/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
19/08/2022	navpw1	TFS: 54162	SAL - ERROR : Voyage no./ Rotation - Changed automatic and assigned to another
============================================================================*/
vars
	workingMovement			: CMIF_HMS_WorkingMovement;
	nextTransientMovement	: CMIF_HMS_WorkingMovement;
	workingVoyage			: CMIF_HMS_WorkingVoyage;
	permanentMovement		: HMS_VoyageMovement;
	tmpPermVoyage,
	permanentVoyage			: CM_Voyage;
	hmsVoyageData			: HMS_VoyageData;
	updateVoyage			: Boolean;
	now 					: TimeStamp;
	createError 			: Boolean;
	msgStr 					: String;
	time 					: Time;
	toDelete 				: HMS_ViewVoyageByCodeArrDTDict;
	iter					: Iterator;
	tmpVoyage				: CM_Voyage;
	tmpAllVoyagesUpdated	: CM_VoyageSet;
	tmpGlobalVoyagesUpdated	: CM_VoyageGlobalSet;
	tmpGlobalVoyage			: CM_VoyageGlobal;
	datesTimesChanged		: Boolean;							// PAR #29019
	deleteAuditAgent		: CM_DeleteTransactionAuditAgent;	// ### TFS 54162 19Aug2022 NAVPW1
begin

	create tmpAllVoyagesUpdated transient;
	create tmpGlobalVoyagesUpdated transient;
	create deleteAuditAgent transient; // ### TFS 54162 19Aug2022 NAVPW1
	
 	// This method updates the persistant database with the transient changes
 	// when the graphical view save button is clicked
	
	// Delete all voyages and movements that have been marked for deletion
	foreach tmpPermVoyage in self.allDeletedVoyages do
		permanentVoyage := tmpPermVoyage;
		if (not self.exclusiveLockObjectToUpdate(permanentVoyage)) then
			return;
		endif;
		// Make all movements for this voyage archived
		if self.allNotableObjects.includes(permanentVoyage.myHMSVoyageData) then
			self.allNotableObjects.remove(permanentVoyage.myHMSVoyageData);
		endif;
		
		// ### TFS 54162 19Aug2022 NAVPW1
		if _passport.noErrors then
			deleteAuditAgent.audDeleteGeneric(permanentVoyage);
		endif;
		// ### TFS 54162 19Aug2022 NAVPW1
		
		permanentVoyage.causeEvent(permanentVoyage.myTerminal.getTerminalEvent(Voyage_Delete_Event), false, permanentVoyage);			
		permanentVoyage.erase(NORMAL_ERASE);
	endforeach;

	// Delete all movements that have been marked for deletion
	foreach permanentMovement in self.allDeletedMovements do
		if (not self.exclusiveLockObjectToUpdate(permanentMovement)) then
			return;
		endif;
		if self.allNotableObjects.includes(permanentMovement.myHMSVoyageData) then
			self.allNotableObjects.remove(permanentMovement.myHMSVoyageData);
		endif;
		tmpVoyage := permanentMovement.getMyVoyage();
		if tmpVoyage &lt;&gt; null and (not tmpAllVoyagesUpdated.includes(tmpVoyage)) then
			tmpAllVoyagesUpdated.add(tmpVoyage);
		endif;
		permanentMovement.erase(NORMAL_ERASE);		
    endforeach;
	
	create toDelete transient;
 	
 	// Update all voyages that have changed
    foreach workingVoyage in self.allVoyagesViewedByCode 
    where (workingVoyage.notYetSaved 
    or workingVoyage.voyageStatusHasChanged)do
    	
    	updateVoyage := true;
    	
    	if (not workingVoyage.notYetSaved) 
    	and workingVoyage.voyageStatusHasChanged then
    		// Voyage status change only
    		if workingVoyage.myHMSVoyageData &lt;&gt; null then
    			// Check to see is voyage status's are different
    			if workingVoyage.myHMSVoyageData.voyageStatus = workingVoyage.voyageStatus then
    				// Perm:Working voyage status the same - don't update.
    				updateVoyage := false;
    			endif;
    		endif;
    	endif;
    	
    	if updateVoyage then
	    	if workingVoyage.ofPermanentVoyage &lt;&gt; null then
				// Update permanent movement
				permanentVoyage := workingVoyage.ofPermanentVoyage;
				if (not self.exclusiveLockObjectToUpdate(permanentVoyage)) then
					toDelete.clear();
					return;
				endif;
				hmsVoyageData := permanentVoyage.myHMSVoyageData;
				// Copy workingVoyage to permanentVoyage
				hmsVoyageData.copyFromWorkingVoyage(workingVoyage, _passport);
			else
				// Create new permanentVoyage
				hmsVoyageData := workingVoyage.myHMSVoyageData.cloneSelf(false);
				// Copy workingVoyage to permanentVoyage
				hmsVoyageData.copyFromWorkingVoyage(workingVoyage, _passport);
				toDelete.add(workingVoyage);
			endif;
			
			tmpVoyage := hmsVoyageData.myVoyage;
			if tmpVoyage &lt;&gt; null and (not tmpAllVoyagesUpdated.includes(tmpVoyage)) then
				tmpAllVoyagesUpdated.add(tmpVoyage);
			endif;
		endif;
	endforeach;
	
	// PAR #29019 Check if dates/times on any movements have changed
	datesTimesChanged := self.haveAnyMovementTimesChanged();
	
 	// Find all movements in the current view - ie. allMovementsInViewByDT
 	// that have their 'notYetSaved' property set to true. Update their permanent 
 	// movement object where it exists, else create a new permanent movement
	
	iter := allMovementsInViewByDT.createIterator();
	
	foreach workingMovement in allMovementsInViewByDT 
	where workingMovement.CMIF_HMS_WorkingMovement.notYetSaved do
		if workingMovement.myPersistentMovement &lt;&gt; null then
			// Update permanent movement
			permanentMovement := workingMovement.myPersistentMovement;
			if (not self.exclusiveLockObjectToUpdate(permanentMovement)) then
				toDelete.clear();			
				return;
			endif;
			tmpVoyage := permanentMovement.getMyVoyage();
			if tmpVoyage &lt;&gt; null and (not tmpAllVoyagesUpdated.includes(tmpVoyage)) then
				tmpAllVoyagesUpdated.add(tmpVoyage);
			endif;
			// Copy workingMovement to permanent movement
			// Cause notification on voyage
			iter.startAtObject(workingMovement);
			iter.next(nextTransientMovement);
			iter.next(nextTransientMovement); // need to do this twicew to get the 'real' next object
			permanentMovement.copyMovement(workingMovement, nextTransientMovement, null, TRANS_TYPE_EditMovement, _passport);
		else
			// PAR 3400 AJA 20/03/00: Try to trap duplicate arrival/departure movements
			if workingMovement.myWorkingVoyage.ofPermanentVoyage &lt;&gt; null
			and workingMovement.myWorkingVoyage.ofPermanentVoyage.myHMSVoyageData.allVoyageMovements.size &gt; 0 then
				if workingMovement.moveType = HMSMovementTypeArrival then			//Check that we don't already have one of these
					if workingMovement.myWorkingVoyage.ofPermanentVoyage.myHMSVoyageData.allVoyageMovements.first.moveType = HMSMovementTypeArrival then
						//Error !!! We already have an arrival movement
						createError := true;
					endif;
				endif;
				if workingMovement.moveType = HMSMovementTypeDeparture then			//Check that we don't already have one of these
					if workingMovement.myWorkingVoyage.ofPermanentVoyage.myHMSVoyageData.allVoyageMovements.last.moveType = HMSMovementTypeDeparture then
						//Error !!! We already have a departure movement
						createError := true;
					endif;
				endif;
			endif;
			if not createError then			
				create permanentMovement persistent;
				// Copy workingMovement to permanent movement
				// Cause notification on voyage
				permanentMovement.copyMovement(workingMovement, null, null, TRANS_TYPE_AddMovement, _passport);

				tmpVoyage := permanentMovement.getMyVoyage();
				if tmpVoyage &lt;&gt; null and (not tmpAllVoyagesUpdated.includes(tmpVoyage)) then
					tmpAllVoyagesUpdated.add(tmpVoyage);
				endif;

			else
				toDelete.clear();
				app.raiseCMException(HMSMovementDuplicated, null, null);
				return;
			endif;
		endif;
	endforeach;

	// Modified by Russell 30/08/99
	// -------------------------------------------------------------------------------------
	// Save all movements that have had their clearances recalculated, and the movement has
	// not already been saved (ie notYetSaved=true or a voyage add), and that the clearances
	// are different from the persistant movement
	foreach workingMovement in allMovementsInViewByDT where workingMovement.notYetSaved=false do
		if workingMovement.myPersistentMovement&lt;&gt;null and workingMovement.clearancesHaveChanged=true then 
			// Check new clearances against persistant movement
			permanentMovement:=workingMovement.myPersistentMovement;
			if workingMovement.aftClearanceTo &lt;&gt; permanentMovement.aftClearanceTo 
			or workingMovement.foreClearanceTo &lt;&gt; permanentMovement.foreClearanceTo then
				// Clearances have changed - update permanent movement
				if (not self.exclusiveLockObjectToUpdate(permanentMovement)) then
					toDelete.clear();				
					return;
				endif;
				tmpVoyage := permanentMovement.getMyVoyage();
				if tmpVoyage &lt;&gt; null and (not tmpAllVoyagesUpdated.includes(tmpVoyage)) then
					tmpAllVoyagesUpdated.add(tmpVoyage);
				endif;
				permanentMovement.copyMovement(workingMovement, null, null, TRANS_TYPE_EditMovement, _passport);
			endif;
		endif;
	endforeach;
	// -------------------------------------------------------------------------------------
	
	if self.deleteSavedChanges(toDelete, _passport) then
		// interface objects and view drag pictures have been deleted successfully
	else			
		foreach workingVoyage in toDelete do
			if workingVoyage.myHMSVoyageData.isTransient then
				delete workingVoyage.myHMSVoyageData;
			endif;
		endforeach;
		toDelete.purge();
	endif;
	
	foreach tmpVoyage in tmpAllVoyagesUpdated do
		tmpGlobalVoyage := tmpVoyage.myVoyageGlobalArrival;
		if tmpGlobalVoyage &lt;&gt; null then
			if (not tmpGlobalVoyagesUpdated.includes(tmpGlobalVoyage)) then
				tmpGlobalVoyagesUpdated.add(tmpGlobalVoyage);
				tmpGlobalVoyage.valMovementsBeforeLinkListUpd();
			endif;
		endif;
		tmpGlobalVoyage := tmpVoyage.myVoyageGlobalDeparture;
		if tmpGlobalVoyage &lt;&gt; null then
			if (not tmpGlobalVoyagesUpdated.includes(tmpGlobalVoyage)) then
				tmpGlobalVoyagesUpdated.add(tmpGlobalVoyage);
				tmpGlobalVoyage.valMovementsBeforeLinkListUpd();
			endif;
		endif;
		
		tmpVoyage.maintainMovementLinkedList();
	endforeach;
	
	foreach tmpGlobalVoyage in tmpGlobalVoyagesUpdated do
		tmpGlobalVoyage.valMovementsAfterLinkListUpd();
		//jlgka1 TFS 45620 --&gt;
		// PAR #29019 if no dates/times on any movements have changed, we don't need to perform this validation
		/*if datesTimesChanged then
			// PAR 16489
			tmpGlobalVoyage.validateMovementsAfterUpdate();
		endif;*/
		// PAR #29019 end
		//jlgka1 TFS 45620 &lt;--
	endforeach;
	
	self.state_ViewUpdatePending := false; // AKB2002MAY
	self.causeEventForObjects();

	allDeletedVoyages.clear;
	allDeletedMovements.clear;
	// Clear all changes
	allChanges.purge;
	allNotableObjects.clear;
	currentChangeStackPosition:=0;

epilog
	delete toDelete;
	delete iter;
	delete tmpAllVoyagesUpdated;
	delete tmpGlobalVoyagesUpdated;
	delete deleteAuditAgent; // ### TFS 54162 19Aug2022 NAVPW1
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveViewChanges" id="70d99d33-c646-412e-83bf-dd9e9eaf8e5e">
        <updating/>
        <source>saveViewChanges() : Boolean updating;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars

begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultDateRangeForView" id="fa628622-0e96-4f5c-934b-37c16e8afc08">
        <updating/>
        <source>setDefaultDateRangeForView(_startDT, _finishDT : TimeStamp) updating;

// 27/5/16 cnwmp6 TFS 488 - Multi timezone support

vars
	now,
	startLocal,
	endLocal: TimeStamp;
begin
	// Set default start and finish dates for the view
	// NOTE: These dates are used to initialise the ViewRangeSelector
	
	self.viewStartDT := _startDT;
	self.viewFinishDT := _finishDT;
	
	if (not viewStartDT.isValid) then
		now := self.systemToLocalTime(app.actualTimeServer());
		// Default startDT = midnight today
		// Default finishDT = midnight one week from today	
//		viewStartDT:=(currentDate.Date.String &amp; ",00:00:00").TimeStamp;
		startLocal.setDate(now.Date);
		startLocal.setTime(null);
//		viewFinishDT:=((currentDate.Date+7).Date.String &amp; ",00:00:00").TimeStamp;
		endLocal.setDate(now.Date + 7);
		endLocal.setTime(null);
		
		viewStartDT := self.localToSystemTime(startLocal);
		viewFinishDT := self.localToSystemTime(endLocal);
		
	endif;
end;</source>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_finishDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setEditModeActiveState" id="ecacbd19-8b67-45d6-bb94-72ef539a2d2c">
        <updating/>
        <source>setEditModeActiveState(active:Boolean) updating;

vars

begin
	// This method is called when the user enters and leave an editing/adding/deleting state 
	// for a voyage or movement
	state_AddEditMovementActive:=active;

	// Process pending update if there is one
	if state_ViewUpdatePending=true then
		// Reset state
		state_ViewUpdatePending:=false;
		// Rebuild view
		buildView_WorkingVoyageAndMove;
		view_BuildEntireForeground();
	endif;

end;</source>
        <Parameter name="active" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyHarbour" id="3e010b26-4988-40fc-ba90-6610e56c7e79">
        <updating/>
        <source>setMyHarbour() updating;
//--------------------------------------------------
// Created:	06 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	saveHarbour : HMS_Harbour;
begin
	saveHarbour := self.myHarbour;
	
	self.myHarbour := null;

	if self.myTerminal &lt;&gt; null then
		self.myHarbour := self.myTerminal.myHarbour;
	endif;
	
	if saveHarbour &lt;&gt; self.myHarbour then
		//Harbour has changed so updated terminals
		self.setTerminalsAvailableToSelect();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMySelectedMovement" id="1bfe051c-bf80-41ae-bc4a-454205f42715">
        <updating/>
        <source>setMySelectedMovement(_workingMovement : CMIF_HMS_WorkingMovement) updating;
// ---------------------------------------------------------------------------
// Created:     02 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	
	self.myCurrentWorkingMovement := null;
	self.myCurrentWorkingVoyage := null;
	
	if global.isValidObject(_workingMovement) then							
		self.myCurrentWorkingMovement := _workingMovement;
		self.myCurrentWorkingVoyage := _workingMovement.myWorkingVoyage;
	endif;
	
end;</source>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="c01ad219-a5b3-4689-9a34-de7fa8ee4a1e">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
//--------------------------------------------------
// Created:	06 January 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.myTerminal := _terminal;

	self.setMyHarbour();
		
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setSelectedTerminals" id="1c49418f-8c62-4c43-8568-f97bdc74e939">
        <updating/>
        <source>setSelectedTerminals(_selectedTerminals : Collection) updating;
//--------------------------------------------------
// Created:	23 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _selectedTerminals &lt;&gt; null then
		self.allTerminalsSelectedForView.clear();
		_selectedTerminals.copy(self.allTerminalsSelectedForView);
	endif;				
end;</source>
        <Parameter name="_selectedTerminals" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setTerminalsAvailableToSelect" id="7b1e1fdc-552b-4d2c-8ddd-94f8903b4ceb">
        <updating/>
        <source>setTerminalsAvailableToSelect() updating, protected;
//--------------------------------------------------
// Created:	06 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	termCol : CM_TerminalByCodeDict;
	term : CM_Terminal;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
begin

	passport := app.myPassport;

	self.allTerminalsSelectedForView.clear();
	
	if self.myHarbour &lt;&gt; null then
		termCol := self.myHarbour.allTerminalsByCode;
		
		foreach term in termCol do
			if (not term.canUserAccessSelf(null, failedDAC, passport)) then
				continue;
			endif;	
			self.allTerminalsSelectedForView.add(term);
		endforeach;

	elseif self.myTerminal &lt;&gt; null then
		self.allTerminalsSelectedForView.add(self.myTerminal);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="set_AddEditMovementActiveState" id="033549dc-5164-4aa9-90f8-5e6fc8d836a3">
        <updating/>
        <source>set_AddEditMovementActiveState(_active : Boolean) updating;

vars

begin
  	// This method is called when the user enters and leave an editing/adding state 
	// for a movement
	self.state_AddEditMovementActive := _active;

	// Process pending update if there is one
	if self.state_ViewUpdatePending
	and (not state_AddEditMovementActive)
	and (not state_AddEditVoyageActive) then
		// Rebuild view
		self.buildView_WorkingVoyageAndMove;
		self.view_BuildEntireForeground();

		// Reset state
		self.state_ViewUpdatePending := false;
	endif;
end;</source>
        <Parameter name="_active" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set_AddEditVoyageActiveState" id="061c6b80-167a-43b2-9493-39f86393a234">
        <updating/>
        <source>set_AddEditVoyageActiveState(active:Boolean) updating;

vars

begin
  	// This method is called when the user enters and leave an editing/adding state 
	// for a voyage
	state_AddEditVoyageActive:=active;

	// Process pending update if there is one
	if state_ViewUpdatePending=true 
	and state_AddEditMovementActive=false 
	and state_AddEditVoyageActive=false then
		// Rebuild view
		buildView_WorkingVoyageAndMove;
		view_BuildEntireForeground();
		// Reset state
		state_ViewUpdatePending:=false;
	endif;
end;</source>
        <Parameter name="active" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="aea349ee-d854-41b8-9bd4-b41839e53137">
        <updating/>
        <source>sysNotification(eventType : Integer; theObject : Object; eventTag : Integer) updating;

vars
	msgString : String;
begin

	if theObject.isKindOf(HMS_VoyageMovement) then
		if eventType=Object_Update_Event or eventType=Object_Create_Event or eventType=Object_Delete_Event then
	 		if state_AddEditMovementActive=true and not state_ViewUpdatePending then
				// Delay view changes
				state_ViewUpdatePending := self.isNotifyObjectMyObject(theObject);
			elseif self.myCurrentWorkingMovement &lt;&gt; null and self.myCurrentWorkingMovement.myPersistentMovement = theObject then
				state_ViewUpdatePending := true;
			endif;
		endif;

	elseif theObject.isKindOf(CM_Voyage) then
		if state_AddEditVoyageActive=true  and not state_ViewUpdatePending then
			// Delay view changes
			state_ViewUpdatePending := self.isNotifyObjectMyObject(theObject);
		elseif self.myCurrentWorkingVoyage &lt;&gt; null and self.myCurrentWorkingVoyage.ofPermanentVoyage = theObject then
			state_ViewUpdatePending := true;
		endif;
	endif;

	/* NOTE: This code is currently inactive. This is because when the database is updated by any system user,
	// all other users completely rebuild their views - ie at this stage there is no checking to see what changes have been
	// made and whether the any/all of the current users changes have been invalidated
	if state_EditModeActive=true then
		// Delay view changes
		state_ViewUpdatePending:=true;
	else
		// Make view changes immediately
		if eventType=Object_Update_Event then
			buildView_WorkingVoyageAndMove;
			view_BuildEntireForeground;
		elseif eventType=Object_Create_Event then
			buildView_WorkingVoyageAndMove;
			view_BuildEntireForeground;
		elseif eventType=Object_Delete_Event then
			buildView_WorkingVoyageAndMove;
 			view_BuildEntireForeground;
		endif;
	endif;
	*/
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
