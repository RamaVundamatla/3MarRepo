    <JadeMethod name="isValueUsed" id="a1cdb26a-2d0c-4d48-bd25-f8dcc2292161">
        <source>isValueUsed(pAllValues: Any): Boolean;
// --------------------------------------------------------------------------------
// Created:		13 June 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramValue	: Integer;
	
begin
	foreach paramValue in pAllValues.IntegerArray do
		if paramValue = self.value then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="pAllValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
