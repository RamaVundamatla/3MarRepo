    <JadeMethod name="trxDeleteFPDateTimeBulk" id="59f5f6e6-0c22-441f-a8c3-85c3ec972ff0">
        <updating/>
        <source>trxDeleteFPDateTimeBulk(_financialPeriodEnd:CM_FinancialPeriodEnd input; _allProxyDates : CM_FinancialPeriodDateTimeDict) updating;
/*
Purpose:			
Date				Who			Reason
