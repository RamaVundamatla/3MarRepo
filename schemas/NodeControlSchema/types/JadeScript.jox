    <JadeMethod name="jhpJommonToCsvFull" id="97fa2766-8216-4081-9011-247634057c58">
        <source>jhpJommonToCsvFull();
//	creates a csv file with all stats counters
vars
	s,t,u,v,counter,folderName,folderMask,include,exclude:String;
	i,j,k,l,dateLength,counterlength,starttime,tottime,subcount,totcount:Integer;
	presentationFileSystem,foundSection:Boolean;
	ts,tsStart,tsEnd:TimeStamp;
	tt,tt2,tt3:Time;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	counter:=" s Server Executions";  // last one in the list
	counterlength:=counter.length;
	
	create f;
	create g;
	f.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	g.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	f.fileName:="C:\a\cmis\bo\20080613\jommonA.log";
	g.fileName:=f.fileName.replace(".log", ".csv");
	
	// find length of date
	s:=f.readLine;
	j:=1;
	foreach i in 1 to 4 do
		j:=s.pos(" ", j); j:=j+1;
	endforeach;
	dateLength:=j-2;

	// find starting timestamp, build header line
	t:="Time,";
	while not f.endOfFile do
		s:=f.readLine;
		if s.length &lt; dateLength+5 or s[dateLength+1:3] &lt;&gt; " s " then continue; endif;
		j:=dateLength+4;
		t:=t&amp;s.scanUntil(" ",j)&amp;" "; j:=j+1;
		if s[j] = " " then j:=j+1; endif;  // queued locks has two spaces
		t:=t&amp;s.scanUntil(" "&amp;Tab,j)&amp;","; j:=j+1;

		if s.length &lt; dateLength or s[dateLength+1:counterlength] &lt;&gt; counter then continue; endif;

		tsStart:=s[1:dateLength].TimeStamp;  // get timestamp of prior sample
		tsStart:=tsEnd;
//		if s[dateLength+1:15] =  " s  -- Interval" then
			g.writeLine(t);
			break;
//		endif;
	endwhile;
	
	// process lines
	while not f.endOfFile do
		s:=f.readLine;
		if s.length &lt; dateLength or s[dateLength+1:3] &lt;&gt; " s " or s.contains("-- Interval") then continue; endif;

		k:=k+1;
		if tsStart = tsEnd then
			tsEnd:=s[1:dateLength].TimeStamp;
			t:=s[1:dateLength];
		endif;
		i:=1;
		u:=s.scanUntil(Tab, i); i:=i+1;
		u:=s.scanUntil(Tab, i); i:=i+1;
		u:=s.scanUntil(Tab, i); i:=i+1;
		tottime:=tsEnd.time-tsStart.time;
		j:=(u.Integer/tottime*1000).rounded;
		t:=t&amp;","&amp;j.String;

		// last counter in list - write line
		if s[dateLength+1:counterlength] = counter then
			g.writeLine(t);
			tsStart:=tsEnd;
		endif;
		//if k &gt; 12 then break; endif;/**/
	endwhile;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpJommonToCsvSingle" id="3eff21b8-4926-4b60-9007-09c49cc255c9">
        <source>jhpJommonToCsvSingle();
//	creates a csv file with one stats counter
vars
	s,t,u,v,counter,folderName,folderMask,include,exclude:String;
	i,j,k,l,dateLength,counterlength,starttime,tottime,subcount,totcount:Integer;
	presentationFileSystem,foundSection:Boolean;
	ts,tsStart,tsEnd:TimeStamp;
	tt,tt2,tt3:Time;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	counter:=" s Get Objects";
	counter:=" s Objects Created";
	counter:=" s Objects Deleted";
	counter:=" s Objects Locked";
	counter:=" s Objects Unlocked";
	counter:=" s Objects Updated";
	counter:=" s Queued  Locks";
	counter:=" s Committed Trans";
	counter:=" s Aborted Trans";
	counter:=" s Begin Notifications";
	counter:=" s End Notifications";
	counter:=" s Delivered Notifications";
	counter:=" s Server Executions";
	counterlength:=counter.length;
	
	create f;
	create g;
	g.mode:=File.Mode_Output;
	f.fileName:="C:\a\cmis\bo\20080605\overnight\jommonA.log";
	g.fileName:=f.fileName.replace(".log", ".csv");
	f.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	if folderName.toLower.contains('cmis') or folderName.contains('\jcm') then
		//f.kind:=File.Kind_Unicode; g.kind:=File.Kind_Unicode;
	endif;

	// find length of date
	s:=f.readLine;
	j:=1;
	foreach i in 1 to 4 do
		j:=s.pos(" ", j); j:=j+1;
	endforeach;
	dateLength:=j-2;
	
	// find starting timestamp
	while not f.endOfFile do
		s:=f.readLine;
		if s.length &lt; dateLength or s[dateLength+1:counterlength] &lt;&gt; counter then continue; endif;

		tsStart:=s[1:dateLength].TimeStamp;  // get timestamp of prior sample
		break;
	endwhile;
	
	// process lines
	while not f.endOfFile do
		s:=f.readLine;
		if s.length &lt; dateLength or s[dateLength+1:counterlength] &lt;&gt; counter then continue; endif;

		k:=k+1;
		tsEnd:=s[1:dateLength].TimeStamp;
		i:=1;
		u:=s.scanUntil(Tab, i); i:=i+1;
		u:=s.scanUntil(Tab, i); i:=i+1;
		u:=s.scanUntil(Tab, i); i:=i+1;
		tottime:=tsEnd.time-tsStart.time;
		j:=(u.Integer/tottime*1000).rounded;
		t:=s[1:dateLength]&amp;","&amp;j.String;

		g.writeLine(t);
		//if k &gt; 12 then break; endif;/**/
		tsStart:=tsEnd;
	endwhile;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpLogTimeCalc" id="bccdd6aa-d281-426a-86a9-b73b2911691c">
        <source>jhpLogTimeCalc();
vars
	s,t,u,v,folderName,folderMask,include,exclude:String;
	i,j,k,l,starttime,tottime,subcount,totcount:Integer;
	presentationFileSystem,foundSection:Boolean;
	ts,tsStart,tsEnd:TimeStamp;
	tt,tt2,tt3:Time;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	create f;
	create g;
	f.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	f.fileName:="C:\a\Jade pars\44755\test\s121_msg1.log";
	//g.fileName:=f.fileName.replace(".log","_long.log");
	g.fileName:=f.fileName.replace(".log","_short.log");
	g.mode:=File.Mode_Output;
	while not f.endOfFile do
		while not f.endOfFile do
			s:=f.readLine; k:=k+1;
			//if not s.contains("starting collection") then g.writeLine(s); continue; endif;
			if not s.contains("starting collection") then continue; endif;
			tsStart:=s[1:23].TimeStamp;
			//g.writeLine(s);
			break;
		endwhile;
		while not f.endOfFile do
			s:=f.readLine; k:=k+1;
			//if not s.contains("done") then g.writeLine(s); continue; endif;
			if not s.contains("done") then continue; endif;
			tsEnd:=s[1:23].TimeStamp;
			//g.writeLine(s&amp;" "&amp;(tsEnd).String);
			g.writeLine(s&amp;" "&amp;(tsEnd.time-tsStart.time).String);
			break;
		endwhile;
	endwhile;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="logGrep" id="4b5ef648-b8d9-464c-a50e-9b635073d605">
        <source>logGrep();
vars
	s,t,folderName,folderMask,include,exclude:String;
	i,j,k,l,hits,hitsmax:Integer;
	presentationFileSystem,firstOnly:Boolean;
	ts:TimeStamp;
	f,g:File; fn:FileNode; ff:FileFolder;
begin
	folderName:="S:\BenchMarkResults\CMIS\20071119_s46";
	folderName:="\\Cnwchcs46\u$\jcmi6213\logs";
	folderName:="G:\BenchMarkResults\jmt\20080227_s46\26b vs 27a";
	folderName:="U:\jcmi6110\logs";
	folderName:="C:\a\work\c3";
	folderName:="C:\a\cmis\bo\20080605\overnight";

	folderMask:="*lockinfo*.log";
	folderMask:="*.*";
	folderMask:="msg*.log";
	folderMask:="JadeOutCmisJ.log";
	folderMask:="jommonA.log";
	include:="";
	include:="} *(";
	include:="INVALID SEQUENCE NUMBER";
	include:="all ServerThreads busy";
	include:="Profiled Time";
	include:="JadApp: Client Tcp address";
	include:="Thin Client read first request timed out";
	include:="Local process sign-on";
	include:=" q ";

	hitsmax:=29999;
	exclude:="asasasQueued";
	
	create f;
	f.mode:=File.Mode_Input;
	create g;
	g.mode:=File.Mode_Output;
	f.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version

	if folderName.contains('CMIS') or folderName.contains('\jcm') then
		f.kind:=File.Kind_Unicode; g.kind:=File.Kind_Unicode;
	else
		//f.shareMode:=File.Share_Read;  // "optimisation" for static files
	endif;
	create ff;
	ff.fileName:=folderName;
	ff.mask:=folderMask;
	ff.usePresentationFileSystem:=presentationFileSystem;
//	g.fileName:=folderName&amp;"\grep_"&amp;ts.date.format("yyyyMMdd")&amp;"_"&amp;ts.time.format("HHmmss")&amp;".log";
	g.fileName:=folderName&amp;"\grep_"&amp;include.replace(":","_").replace("/","_").replace("\","_").replace("*","_")&amp;"_"&amp;ts.date.format("yyyyMMdd")&amp;"_"&amp;ts.time.format("HHmmss")&amp;".log";
	g.usePresentationFileSystem:=true;
	g.writeLine("searching "&amp;folderName&amp;"\"&amp;folderMask&amp;" for '"&amp;include&amp;"'"&amp;CrLf);
	foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName
	and fn.name[1:5]&lt;&gt;"grep_"
	do
		f.fileName:=fn.fileName;
//		f.maxRecordSize:=64*1024;  // kills static file optimisation
		f.usePresentationFileSystem:=presentationFileSystem;
		if not f.isAvailable then continue; endif;
//		write f.fileName;
//		g.writeLine(CrLf&amp;fn.name&amp;":");
		hits:=0;
		while not f.endOfFile do
//			s:=f.readLine;
			s:=f.readLine&amp;" ";
			if s.pos(include,1)&lt;&gt;0
			and s.pos(exclude,1)=0
//			or s[1]="["
			then
				g.writeLine(fn.name&amp;": "&amp;s);
//				g.writeLine(s);
//				write fn.name&amp;": "&amp;s;
				hits:=hits+1;
				if hits &gt;= hitsmax then break; endif;
			endif;
		endwhile;
		f.close;
	endforeach;
	g.close;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="renameFolder" id="c0e0d8e8-8386-487a-b735-a391bb4039eb">
        <source>renameFolder();

vars
	s,t,location,oldName,newName:String;
	i,j,fileCount:Integer;
	ff:FileFolder;  fn:FileNode;  f,g:File;
	ss:SpoolerServer;
begin
	location:="\\cnwchcs73\s$\BenchMarkResults\skidemo\20060907_s46\";
	location:="\\cnwchcm24\cnwjbl$\BenchMarkResults\skidemo\20060907_s46\";
	oldName:="6108.17a";
	newName:="6108.17aa";

	create ss;
	create ff;
	ff.fileName:=location&amp;oldName;
	ff.usePresentationFileSystem:=false;
	if not ff.isAvailable then write "can't find folder"; return; endif;
	foreach fn in ff.files where fn.isKindOf(File) do
		f:=fn.File;
		ss.rename(f.fileName,f.fileName.replace(oldName,newName));
	endforeach;
//	ff.rename(ff.fileName.replace(oldName,newName));
epilog
	delete ss;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="startAppServers" id="7fcc9380-4f84-4845-a736-53e4b070e88e">
        <source>startAppServers();

vars
	path,iniFile:String;
	i,port,retCode,result:Integer;
	sa:StringArray;
begin
	path:=app.getJadeInstallDirAppServer;
	iniFile:=app.getIniFileNameAppServer;
	create sa transient;
	sa[1]:="path="&amp;app.dbPath;
	sa[2]:="ini="&amp;iniFile;

//	foreach port in 51824 to 51824 do
	foreach port in 51700 to 51702 do
		sa[3]:="AppServerPort="&amp;port.String;
		sa[4]:="server=multiuser";
		retCode:=node.createExternalProcess(path,path&amp;"\jadapp.exe",sa,null,false,false,result);
		if retCode&lt;&gt;0 and retCode&lt;&gt;4 then write "startup failed, retCode="&amp;retCode.String&amp;CrLf&amp;sa.display; endif;
	endforeach;
epilog
	delete sa;
end;</source>
    </JadeMethod>
</Class>
