    <JadeMethod name="setFromCraneMoveTxn" id="699f878b-bde9-4f8a-a53b-235b24482019">
        <updating/>
        <source>setFromCraneMoveTxn(_setdown: CM_SetDown; _craneMoveTxn: CM_Move) updating;

vars

begin
	self.myTerminal := _setdown.myTerminal;
	self.myTrackedItem := _setdown.myTrackedItem;
	self.dateTime := _setdown.dateTime;
	self.voyageCode := _setdown.voyageCode;
	self.machineId := _setdown.machineId;
	self.sourceLocn :=  _setdown.sourceLocn;
	self.targetLocn := _craneMoveTxn.sourceLocn;
end;
</source>
        <Parameter name="_setdown" type="CM_SetDown"/>
        <Parameter name="_craneMoveTxn" type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="baa7f291-1111-4536-9045-b9fc51c0ec4e">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			19 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	inheritMethod(_passport);			//cnwmc5 - 17 April 2015 - PAR 35925
	
	if self.myTrackedItem = null then
		return;
	endif;
	self.myTrackedItem.setMovedDT(TI_SetDown);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
