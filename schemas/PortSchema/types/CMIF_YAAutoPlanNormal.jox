    <JadeMethod name="isConsignee_Match" id="e91e4a01-514a-4859-92ff-0d44763c4b4d">
        <source>isConsignee_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	consignee : CM_ConsigneeConsignor;
	
begin

	consignee := self.myTrackedItem.myConsignee;
	if consignee = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(consignee);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isConsignor_Match" id="01889279-5882-4ef4-a194-744a3b6b5b6a">
        <source>isConsignor_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------

vars

	consignor : CM_ConsigneeConsignor;
	
begin

	if self.myTrackedItem.consignor = null then
		return false;
	endif;
	
	consignor := app.myRoot.allConsigneeConsignors[self.myTrackedItem.consignor];
	
	if consignor = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
