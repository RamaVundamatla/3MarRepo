    <JadeMethod name="getReqAvailGrade" id="bc2f6374-159a-4187-b555-5fb9ce398a2a">
        <source>getReqAvailGrade():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2

*/

vars
	resDtl 	: CM_ReserveDetail;
	relReq	: CM_BulkRelease;
	objSet 	: ObjectSet;
	str	   	: String;
begin
	resDtl := self.myReserveDetail;
	if resDtl &lt;&gt; null then						
		relReq := resDtl.myReserveHeader;
		if relReq &lt;&gt; null then
			resDtl := relReq.allReserveDetails.first;
		endif;
		if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
			return resDtl.CM_ReserveSelection.getAvailabilityGradesDescr();
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReqCargoType" id="6c7db0e8-bd7d-48f2-bb01-5da088043f75">
        <source>getReqCargoType(_isParent : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
*/

vars
	resDtl 	: CM_ReserveDetail;
	relReq	: CM_BulkRelease;
begin
	resDtl := self.myReserveDetail;
	if resDtl &lt;&gt; null then
		if _isParent then
			relReq := resDtl.myReserveHeader;							//25.03.2024 navhl20 #62300
			if relReq &lt;&gt; null then										//25.03.2024 navhl20 #62300
				resDtl := relReq.allReserveDetails.first;
			endif;
			if resDtl &lt;&gt; null then
				return resDtl.getCargoTypeDescr();
			endif;
		else
			if resDtl.packType = CM_ReserveDetail.PackType_Child then
				return resDtl.getCargoTypeDescr();
			endif;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_isParent" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReqCommodity" id="dea03199-d05a-4625-a4c1-fccc83755e82">
        <source>getReqCommodity(_isParent : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/

vars
	resDtl	: CM_ReserveDetail;
	relReq	: CM_BulkRelease;
begin
	resDtl := self.myReserveDetail;
	if resDtl &lt;&gt; null then
		if _isParent then
			relReq := resDtl.myReserveHeader;							//25.03.2024 navhl20 #62300
			if relReq &lt;&gt; null then										//25.03.2024 navhl20 #62300
				resDtl := relReq.allReserveDetails.first;
			endif;
			if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
				return resDtl.CM_ReserveSelection.getMatchingCriteriaAsString(Comma,YACriteriaType_Commodity);
			endif;
		else
			if resDtl.packType = CM_ReserveDetail.PackType_Child and resDtl.getMyCommodityCriteriaDesc() &lt;&gt; null then
				return resDtl.CM_ReserveSelection.getMatchingCriteriaAsString(Comma,YACriteriaType_Commodity);
			endif;
		endif;
				
		if resDtl.myCargoGroup &lt;&gt; null then								//29.03.2024 navhl20 #63251
			return resDtl.myCargoGroup.commodity;
		endif;
	endif;
	return null;
epilog
	
end;</source>
        <Parameter name="_isParent" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
