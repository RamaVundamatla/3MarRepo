    <JadeMethod name="getDisplayStringForAttribute" id="03ef34ea-503d-4711-a5ee-f7248c1923c7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//18 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
//09 Aug 2023	navra1  TFS 59666 - EUP - CallOff fields not available in the column organiser
//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
//02/12/2024	navcs2		MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations

vars
	rowName	 	: String;
	type 		: String;
	ediTI 		: CM_EDITrackedItem;				// TFS 58923
	sortingName : String;							// TFS 58923
	yaSorting 	: CM_YATypeSortingMethod;			// TFS 58923
begin

	// ### TFS 53953 14July2022 NAVPW1
	if _attrName = ETRow_CargoMtchClientReference then
		return self.cargoMatchClientReference;
	// ### TFS 53953 14July2022 NAVPW1
	// TFS 58923 start
	elseif _attrName = ETRow_SortingMethod then
		// Sorting Method is an extra criteria
		create yaSorting transient;
		sortingName := yaSorting.getTypeName();
		foreach ediTI in self.myEDIData.allEDITrackedItems where ediTI.isKindOf(CM_EDIRequestCriteriaTI) do
			if ediTI.CM_EDIRequestCriteriaTI.requestDetailID = self.requestDetailID 
			and ediTI.CM_EDIRequestCriteriaTI.criteriaName = sortingName then
				return ediTI.CM_EDIRequestCriteriaTI.criteriaValue;
			endif;
		endforeach;
		return null;

	elseif _attrName = ETRow_DeliveryAddress then									//navra1 - TFS 59666 - 9th Aug 2023
		return self.addressStreet1													//navra1 - TFS 59666 - 9th Aug 2023
				&amp; " " &amp; self.addressStreet2 										//navra1 - TFS 59666 - 9th Aug 2023
				&amp; " " &amp; self.addressCity 											//navra1 - TFS 59666 - 9th Aug 2023
				&amp; " " &amp; self.addressCounty 											//navra1 - TFS 59666 - 9th Aug 2023
				&amp; " " &amp; self.addressPostCode 										//navra1 - TFS 59666 - 9th Aug 2023
				&amp; " " &amp; self.addressCountry 										//navra1 - TFS 59666 - 9th Aug 2023
				&amp; " " &amp; self.addressCountryCode;									//navra1 - TFS 59666 - 9th Aug 2023
				
	elseif _attrName = ETRow_ByTypeByWeight then		//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
		return app.getYesNo(self.getByTypeByWeight());
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
	elseif _attrName = ETRow_QuantityPieces then				//02/12/2024	navcs2		MTN-33047
		return self.quantityPieces.asStringJMT;					//02/12/2024	navcs2		MTN-33047
	endif;														//02/12/2024	navcs2		MTN-33047
	
	return inheritMethod(_attrName, _short);
	
epilog
	delete yaSorting;		// TFS 58923
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="11918c45-82b5-4fc7-9453-e7308bb813c4">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars

begin
	if _attrName = ETRow_Weight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);
epilog

end;</source>
