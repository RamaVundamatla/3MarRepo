    <JadeMethod name="resetFirstRowCase" id="e056baad-ccbd-4f24-8413-8dda9f67ec5d">
        <source>resetFirstRowCase() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/08/2016	cnwdap1		Initial creation TFS #2447 First row of ent table was failing to be 
//								initialised correctly if an edit had been cancelled, leading to 
//								lower case being allowed in upper-case-only fields
//
vars
	row 			: Integer;
	obj 			: Object;
	entRowTrans 	: EntTableRowTransient;
	entTableControl : EntTableCellControl;
	cell 			: JadeTableCell;

begin
	row := self.tblInput1.fixedRows+1;
	obj := self.tblInput1.accessRow(row).itemObject;	
	
	if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
		return;
	endif;
	
	entRowTrans := obj.EntTableRowTransient;
	entTableControl := entRowTrans.myEntTableCellControl;
	cell := self.tblInput1.accessCell(row, self.tblInput1.ColumnValue);
	if entTableControl &lt;&gt; null and global.isValidObject(entTableControl) then
		// Initialise the cell attributes
		entTableControl.initialiseCellControl(cell);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
