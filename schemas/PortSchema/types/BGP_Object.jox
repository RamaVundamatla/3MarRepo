// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if _cmif &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPControllerSetup(_controller, _cmif, app.myPassport);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="BGP_Controller" usage="input"/>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
