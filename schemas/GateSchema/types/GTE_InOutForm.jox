    <JadeMethod name="initShtLogDocketData" id="6c65c5e2-7e5e-424e-b700-1d68bfb61fbf">
        <updating/>
        <source>initShtLogDocketData() updating;
// ---------------------------------------------------------------------------
// Created:     30 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entDef 			: EntTableDef;
begin
	entDef := self.getLogDocketDataDef();
	
	//cnwmc5 - 2 April 2014 - CCMS 1127
	//tblWeighBridge.setTblDataEntRowsFromDef(entDef);
	if self.xmlStringTblLogDocketData &lt;&gt; null then
		self.tblLogDocketData.setTblDataEntRowsArray(entDef, null, self.xmlStringTblLogDocketData);	
	else	
		self.tblLogDocketData.setTblDataEntRowsFromDef(entDef);
	endif;

	
	if self.myTerminal.getConfig(WeighBridgeEnabled).Boolean then
		self.shtLogDocketData.visible := true;
	else
		self.shtLogDocketData.visible := false;
		return;
	endif;
	
	tblLogDocketData.top 	:= 7;
	tblLogDocketData.left	:= 5;
	tblLogDocketData.setDistanceFromRight(5);
	tblLogDocketData.setDistanceFromBottom(btnActionJob.height + 5 + 2);

	tblLogDocketData.lockBottom 		:= false;
	tblLogDocketData.lockRight		:= false;
	tblLogDocketData.stretchHeight 	:= true;
	tblLogDocketData.stretchWidth 	:= true;
	tblLogDocketData.fixedRows 		:= 1;
	tblLogDocketData.fixedColumns		:= 0;
	tblLogDocketData.selectionType 	:= CM_DataTable.SelectionType_Row;
	//self.fldLeft.topSheet := self.shtWeighBridge;

	btnActionWeigh.lockRight := true;
	btnActionWeigh.lockBottom := true;
	btnActionWeigh.distanceFromRight := tblLogDocketData.distanceFromRight;
	btnActionWeigh.distanceFromBottom := 5;
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtTransfers" id="d0ff56a2-6570-4910-b1a8-d82631a777da">
        <source>initShtTransfers();
//----------------------------------------------------------------
