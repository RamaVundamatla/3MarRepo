    <JadeMethod name="displayCriteria" id="5e2725dd-a17f-440b-9979-282ee76c7649">
        <updating/>
        <source>displayCriteria()protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*
Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks
06 Mat 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	criteriaLine			: CM_SelectorCriteriaLine;
	queryProperty			: CM_QueryProperty;
	queryOperator			: CM_QueryOperator;
//	controlArray			: ObjectArray;
	tblSheet				: JadeTableSheet;
	
begin

	self.btnDown.enabled := false;	//02 Sep 2019	NDL	TFS 45891
	self.btnUp.enabled := false;	//02 Sep 2019	NDL	TFS 45891
	
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	
	if tblSheet = null then
		return;
	endif;
	
	if tblSheet.row = null then
		return;
	endif;
	
//	create controlArray transient;		PAR #18009
	
	criteriaLine := tblSheet.accessRow(tblSheet.row).itemObject.CM_SelectorCriteriaLine;
	
	if criteriaLine = null then
		return;
	endif;
	
	queryProperty := self.myQDef.allQueryProperties[criteriaLine.myQueryProperty.propertyName];
	
	if queryProperty = null then
		//probably a deleted stop or todo task
		//query will still run but we can't set the controls below
		return;
	endif;
	
	queryOperator := queryProperty.allAllowedOperators[criteriaLine.myQueryOperator.description];
	self.chkUnavailable.value := criteriaLine.isUnavailableAtRunTime;

//	if criteriaLine.isUnavailableAtRunTime then
//		self.tblCriteria.accessedRow.backColor := self.ROW_COLOUR_UNAVAILABLE;
//	else
	//	self.tblCriteria.accessedRow.backColor := self.ROW_COLOUR_AVAILABLE;
		self.tblCriteria.accessedRow.backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891
//	endif;
	
	self.loadMeasureCombo(criteriaLine.myQueryProperty);								// PAR #31155
	self.cmbAttr.listObject := queryProperty;
	self.loadOperationCombo(queryProperty);
	self.cmbOperator.text := queryOperator.description;
	self.doCmbOperatorClick(criteriaLine.myQueryOperator);
	self.queryLineChanged := false;
	
	self.evaluateUpDown();	//02 Sep 2019	NDL	TFS 45891
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayResultColumns" id="371a3734-0728-4dc0-9dc8-9e17492cdcce">
        <source>displayResultColumns(_allColumns : StringArray; _theCargoBOLType : CM_CargoBOLType) protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars

	currentCol		: Integer;
	termStr,
	attrName		: String;
	queryProp		: CM_QueryProperty;
	tbl				: CM_DataTable;
	propDict		: CM_QueryPropertyDict;
	pos, revPos		: Integer;									// PAR #31155
	niceName		: String;									// PAR #31155
	measure			: String;									// PAR #31155
	fixedRowColour	: Integer;	//03 Sep 2019	NDL	TFS 4589
begin

	if self.myQDef = null then
		return;
	endif;
	
	propDict := self.myQDef.allQueryProperties;

	tbl := self.tblResults;
	tbl.columns := 0;
	if tbl.rows = 0 then
		tbl.rows := 1;
	endif;
	
	tbl.fixedRows := 1;
	
	foreach attrName in _allColumns do
		measure := null;										// PAR #31155
		if attrName.isMeasurementType then						// PAR #31155
			pos := attrName.pos("_", 1);						// PAR #31155
			revPos := attrName.reversePos("_");					// PAR #31155
			measure := attrName[revPos+1:end];					// PAR #31155
			attrName := attrName[pos+1:revPos-pos-1];			// PAR #31155
		endif;													// PAR #31155
		
		
		queryProp := propDict[attrName];
		if queryProp = null then
			continue;			
		endif;

//		par 10009 -  if cargoType changes so should terminology 		
		termStr := app.getTerminologyAlternate(_theCargoBOLType, self.myTerminal, queryProp.niceName, CM_TermExpressionSingular, queryProp.niceName);	// PAR #31155
		if measure &lt;&gt; null then									// PAR #31155
			termStr := termStr &amp; Space &amp; measure;				// PAR #31155
		endif;													// PAR #31155
						
		currentCol := currentCol + 1;
		tbl.columns := currentCol;
		tbl.accessColumn(currentCol).itemObject := queryProp;
//		par 10009 -  if cargoType changes so should terminology 
		tbl.setCellText(1, currentCol, termStr);
		fixedRowColour := queryProp.getPerformanceColour();	//02 Sep 2019	NDL	TFS 45891
		if fixedRowColour = CM_QueryProperty.ComplexColour then	//02 Sep 2019	NDL	TFS 45891
			tbl.accessCell(1, currentCol).backColor := queryProp.getPerformanceColour();	
		endif;
		//		tbl.setCellText(1, currentCol, queryProp.niceName);
		
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_allColumns" type="StringArray"/>
        <Parameter name="_theCargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="displayResults" id="e66b01b5-6ee7-4af4-bc09-31fa46f3169f">
        <updating/>
        <source>displayResults() protected, updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-count based
vars
	any				: Any;
	partsDone,
	partsInJob		: Integer;
	monitor			: CMIF_Monitor;
	fixedRows		: Integer;
	lastUpdated		: Decimal [20];								// PAR #35843
begin
	// JIRA 14794 - NAVAB1 30OCT2024
	if self.useEntDefColumns then
		self.displayResultsEntDef();
		return;
	endif;


	if not self.doMaxTableSizeCheck(self.myEnqController.numItemsFound, null) then
		return;
	endif;
  	
	self.modalDialogReturnValue := null;
	self.modalDialogShow(null, null, null, app.getErrorString(Cancel), app.getErrorString(CMUI_Displaying_Data), null);
	self.tblResults.rows := self.tblResults.fixedRows;
	partsInJob := self.myEnqController.numItemsFound;
	self.pbProgressBar.partsInJob := partsInJob;
	self.pbProgressBar.visible := true;
	fixedRows := self.tblResults.fixedRows;
	
	if app.myPassport.myCMIFMonitor = null then
		create monitor transient;
		app.myPassport.setMyCMIFMonitor(monitor);
	endif;	
	
	//foreach any in self.myEnqController.allObjects do
	foreach any in self.myEnqController.allObjects discreteLock do
		//if (partsDone mod 200) = 0 																	// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			self.modalDialogUpdateInfo(app.getErrorString2(Displaying_items, partsDone.String, partsInJob.String));
			self.pbProgressBar.partsDone := partsDone;
			self.btnModalOpt2.doWindowEvents(0);
			self.frmModalDialog.refreshNow();
			if self.modalDialogReturnValue = self.ModalDialogReturn_Option2 then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;
		
		self.addResultsRow(any.Object);
		partsDone := partsDone + 1;
		
		if partsDone + fixedRows &gt;= JadeTableRowLimit then
			//user agreed earlier they only want first NNN
			break;
		endif;
	endforeach;
	
// cnwdad1 20/12/2005 - PAR #11151.
//	self.lblItemsFound.caption := partsDone.String &amp; ' ' &amp; $CMUI_Items_Displayed;
	self.updateStatus();
epilog
	delete monitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayResultsEntDef" id="401d0913-3922-4fc1-8f2b-dea73b5a506f">
        <updating/>
        <source>displayResultsEntDef() protected, updating;
// JIRA 14794 - NAVAB1 30OCT2024
vars
	any				: Any;
	partsDone,
	partsInJob		: Integer;
	monitor			: CMIF_Monitor;
	fixedRows		: Integer;
	lastUpdated		: Decimal [20];
begin
	if not self.doMaxTableSizeCheck(self.myEnqController.numItemsFound, null) then
		return;
	endif;
  	
	self.modalDialogReturnValue := null;
	self.modalDialogShow(null, null, null, app.getErrorString(Cancel), app.getErrorString(CMUI_Displaying_Data), null);
	self.tblResults.rows := self.tblResults.fixedRows;
	partsInJob := self.myEnqController.numItemsFound;
	self.pbProgressBar.partsInJob := partsInJob;
	self.pbProgressBar.visible := true;
	fixedRows := self.tblResults.fixedRows;
	
	if app.myPassport.myCMIFMonitor = null then
		create monitor transient;
		app.myPassport.setMyCMIFMonitor(monitor);
	endif;	
	
	foreach any in self.myEnqController.allObjects discreteLock do
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
			self.modalDialogUpdateInfo(app.getErrorString2(Displaying_items, partsDone.String, partsInJob.String));
			self.pbProgressBar.partsDone := partsDone;
			self.btnModalOpt2.doWindowEvents(0);
			self.frmModalDialog.refreshNow();
			if self.modalDialogReturnValue = self.ModalDialogReturn_Option2 then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;	
		endif;
		
		self.tblResults.addObject(any.CM_Object);
		
		partsDone := partsDone + 1;
		
		if partsDone + fixedRows &gt;= JadeTableRowLimit then
			//user agreed earlier they only want first NNN
			break;
		endif;
	endforeach;
	self.updateStatus();
epilog
	delete monitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddMeasurementsToColOrg" id="2927934f-e168-4078-bad7-1241950e6b44">
        <updating/>
        <source>doAddMeasurementsToColOrg(_visibleCols, _allCols : StringArray io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars
	str 		: String;
	measure		: CM_MeasurementType;
	default		: CM_MeasurementType;
	idx			: Integer;
	allCols		: StringArray;

begin
	create allCols transient;
	_allCols.copy(allCols);
	
	foreach str in allCols do
		if str.isOneOf(ETRow_Volume, CM_TrackedItem::getMyTotalVolume.name) then
			default := app.getDefaultMeasurementForType(Type_Volume);
			idx := null;
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = Type_Volume do
				if measure = default or not measure.isAvailableForEntry or not measure.isDisplay then
					continue;
				endif;
				idx := idx + 1;
				if _visibleCols.includes(str) then
					_visibleCols.insert(_visibleCols.indexOf(str)+idx, Prefix_Volume &amp; str &amp; "_" &amp; measure.shortName);
				endif;
				if _allCols.includes(str) then
					_allCols.insert(_allCols.indexOf(str)+idx, Prefix_Volume &amp; str &amp; "_" &amp; measure.shortName);
				endif;
			endforeach;
			if _visibleCols.includes(str) then
				_visibleCols.replace(_visibleCols.indexOf(str), Prefix_Volume &amp; str &amp; "_" &amp; default.shortName);
			endif;
			if _allCols.includes(str) then
				_allCols.replace(_allCols.indexOf(str), Prefix_Volume &amp; str &amp; "_" &amp; default.shortName);
			endif;
		
		elseif str.isOneOf(ETRow_WeightCargo, ETRow_WeightDeclared, ETRow_WeightTare, ETRow_TotalWeight) then
			default := app.getDefaultMeasurementForType(Type_Weight);
			idx := null;
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = Type_Weight do
				if measure = default or not measure.isAvailableForEntry or not measure.isDisplay then
					continue;
				endif;
				idx := idx + 1;
				if _visibleCols.includes(str) then
					_visibleCols.insert(_visibleCols.indexOf(str)+idx, Prefix_Weight &amp; str &amp; "_" &amp; measure.shortName);
				endif;
				if _allCols.includes(str) then
					_allCols.insert(_allCols.indexOf(str)+idx, Prefix_Weight &amp; str &amp; "_" &amp; measure.shortName);
				endif;
			endforeach;
			if _visibleCols.includes(str) then
				_visibleCols.replace(_visibleCols.indexOf(str), Prefix_Weight &amp; str &amp; "_" &amp; default.shortName);
			endif;
			if _allCols.includes(str) then
				_allCols.replace(_allCols.indexOf(str), Prefix_Weight &amp; str &amp; "_" &amp; default.shortName);
			endif;
			
		elseif str.isOneOf(ETRow_Length, ETRow_OverLengthFront, "overLengthRear") then
			default := app.getDefaultMeasurementForType(Type_Length);
			idx := null;
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.isLinear() do
				if measure = default or not measure.isAvailableForEntry or not measure.isDisplay then
					continue;
				endif;
				idx := idx + 1;
				if _visibleCols.includes(str) then
					_visibleCols.insert(_visibleCols.indexOf(str)+idx, Prefix_Linear &amp; str &amp; "_" &amp; measure.shortName);
				endif;
				if _allCols.includes(str) then
					_allCols.insert(_allCols.indexOf(str)+idx, Prefix_Linear &amp; str &amp; "_" &amp; measure.shortName);
				endif;
			endforeach;
			if _visibleCols.includes(str) then
				_visibleCols.replace(_visibleCols.indexOf(str), Prefix_Linear &amp; str &amp; "_" &amp; default.shortName);
			endif;
			if _allCols.includes(str) then
				_allCols.replace(_allCols.indexOf(str), Prefix_Linear &amp; str &amp; "_" &amp; default.shortName);
			endif;
			
		elseif str.isOneOf( ETRow_OverWidthLeft, ETRow_OverWidthRight, ETRow_Width) then
			default := app.getDefaultMeasurementForType(Type_Width);
			idx := null;
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.isLinear() do
				if measure = default or not measure.isAvailableForEntry or not measure.isDisplay then
					continue;
				endif;
				idx := idx + 1;
				if _visibleCols.includes(str) then
					_visibleCols.insert(_visibleCols.indexOf(str)+idx, Prefix_Linear &amp; str &amp; "_" &amp; measure.shortName);
				endif;
				if _allCols.includes(str) then
					_allCols.insert(_allCols.indexOf(str)+idx, Prefix_Linear &amp; str &amp; "_" &amp; measure.shortName);
				endif;
			endforeach;
			if _visibleCols.includes(str) then
				_visibleCols.replace(_visibleCols.indexOf(str), Prefix_Linear &amp; str &amp; "_" &amp; default.shortName);
			endif;
			if _allCols.includes(str) then
				_allCols.replace(_allCols.indexOf(str), Prefix_Linear &amp; str &amp; "_" &amp; default.shortName);
			endif;
			
		elseif str.isOneOf(ETRow_Height, ETRow_OverHeight) then
			default := app.getDefaultMeasurementForType(Type_Height);
			idx := null;
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.isLinear() do
				if measure = default or not measure.isAvailableForEntry or not measure.isDisplay then
					continue;
				endif;
				idx := idx + 1;
				if _visibleCols.includes(str) then
					_visibleCols.insert(_visibleCols.indexOf(str)+idx, Prefix_Linear &amp; str &amp; "_" &amp; measure.shortName);
				endif;
				if _allCols.includes(str) then
					_allCols.insert(_allCols.indexOf(str)+idx, Prefix_Linear &amp; str &amp; "_" &amp; measure.shortName);
				endif;
			endforeach;
			if _visibleCols.includes(str) then
				_visibleCols.replace(_visibleCols.indexOf(str), Prefix_Linear &amp; str &amp; "_" &amp; default.shortName);
			endif;
			if _allCols.includes(str) then
				_allCols.replace(_allCols.indexOf(str), Prefix_Linear &amp; str &amp; "_" &amp; default.shortName);
			endif;
			
		elseif str = CM_TrackedItem::getVentilation.name then
			default := app.getDefaultMeasurementForType(Type_Displacement);
			idx := null;
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = Type_Displacement do
				if measure = default or not measure.isAvailableForEntry or not measure.isDisplay then
					continue;
				endif;
				idx := idx + 1;
				if _visibleCols.includes(str) then
					_visibleCols.insert(_visibleCols.indexOf(str)+idx, Prefix_Displacement &amp; str &amp; "_" &amp; measure.shortName);
				endif;
				if _allCols.includes(str) then
					_allCols.insert(_allCols.indexOf(str)+idx, Prefix_Displacement &amp; str &amp; "_" &amp; measure.shortName);
				endif;
			endforeach;
			if _visibleCols.includes(str) then
				_visibleCols.replace(_visibleCols.indexOf(str), Prefix_Displacement &amp; str &amp; "_" &amp; default.shortName);
			endif;
			if _allCols.includes(str) then
				_allCols.replace(_allCols.indexOf(str), Prefix_Displacement &amp; str &amp; "_" &amp; default.shortName);
			endif;
		endif;
	endforeach;
epilog
	delete allCols;
end;</source>
        <Parameter name="_visibleCols" type="StringArray" usage="io"/>
        <Parameter name="_allCols" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doAddSheet" id="cace43d2-a4a7-47d6-b991-015be9a4f038">
        <source>doAddSheet();
// ---------------------------------------------------------------------------
// Created:     22 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sheet		 		: JadeTableSheet;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
	tbl					: CM_DataTable;
	idx,
	numSheets			: Integer;
begin
	tbl := self.tblCriteria;

	numSheets := tbl.sheets + 1;
	tbl.sheets := numSheets;
	tbl.topSheet := numSheets;
	sheet := self.tblCriteria.accessSheet(numSheets);
	sheet.caption := 'or Sheet ' &amp; numSheets.String;
	sheet.columns := 1;
	sheet.rows := 0;
	create criteriaHolder transient;
	sheet.itemObject := criteriaHolder;
	
	self.btnRemoveSheet.enabled := (not self.tblCriteria.sheets = 1);
end;</source>
    </JadeMethod>
