    <JadeMethod name="allowsGriddedStackHeightCrit" id="031479a2-7549-4d2c-9a52-4c793968b07f">
        <source>allowsGriddedStackHeightCrit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
