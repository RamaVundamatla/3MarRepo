    <JadeMethod name="raiseExNoEditionForUpdateObj" id="910c9bd5-9b1b-4828-a03a-6246cbad3ecc">
        <updating/>
        <source>raiseExNoEditionForUpdateObj(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFileName	: String;
begin

	self.writeLog('======== Stackdump for ErrNoEditionForUpdateObject follows ========', LogINFO);
	self.writeLog('No edition found for ' &amp; _obj.String, LogINFO);
	self.writeLogProcessStack();
	self.writeLog('===================================================================', LogINFO);

	if self.myLogFile &lt;&gt; null then
		theFileName := self.myLogFile.filePath &amp; self.myLogFile.fileName;
	endif;

	self.raiseCMException2(ErrNoEditionForUpdateObject, _obj.String, 'Stackdump in ' &amp; theFileName, null, null);

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="raiseMultiReasonExcOrWarning" id="bb1afa4c-f5e9-4e77-8ce9-7d866c620098">
        <source>raiseMultiReasonExcOrWarning( errNos : IntegerArray; errString : String; 
				  _asWarning : Boolean; pAttrNameString : String; pGuiObject : Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2012	cnwndl1	Initial creation	Par 30366 - To handle where full replacment style
						errors/warnings were being raised that contained multile error types.

*/

vars

	consolidatedErrNos : IntegerArray;
	index : Integer;
	errNo : Integer;
	firstErrNo : Integer;
	multiErrsString : String;
	exObj	: CM_Exception;

begin

	// consolidate the error codes, so we only show each unique code once.
	create consolidatedErrNos transient;
	firstErrNo :=  errNos[1];
	if errNos.size &gt; 1 then
		foreach index in 2 to errNos.size do
			errNo := errNos[index];
			if errNo = firstErrNo then
				continue;
			endif;
			if consolidatedErrNos.isEmpty or not consolidatedErrNos.includes(errNo) then
				consolidatedErrNos.add(errNo);
			endif;
		endforeach;
	endif;
	
	if not consolidatedErrNos.isEmpty then
		// there were more than one type of error in this message.
		// List all the numbers so the user who translate messages know which ones to do.
		// And developers have a fighting chance of tracking errors...
		foreach index in 1 to consolidatedErrNos.size do
			errNo := consolidatedErrNos[index];
			if multiErrsString &lt;&gt; null then
				multiErrsString := multiErrsString &amp; ", ";
			endif;
			multiErrsString := multiErrsString &amp; errNo.String;
		endforeach;
		multiErrsString := "[" &amp; multiErrsString &amp; "] " &amp; errString;
	else
		// there was just the one.  Nothing more to add.
		multiErrsString := errString;
	endif;

	create exObj transient;

	exObj.set(firstErrNo, multiErrsString, _asWarning, pAttrNameString, pGuiObject, null);

	raise exObj;

epilog

	delete consolidatedErrNos;

end;</source>
        <Parameter name="errNos" type="IntegerArray"/>
        <Parameter name="errString" type="String"/>
        <Parameter name="_asWarning" type="Boolean"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="raiseSetVirtualError" id="c8dc1f18-9350-4b7b-8bfe-79c337c3d399">
        <source>raiseSetVirtualError(pClassName, pMethodName : String);
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     Raise an exception where a programmer is trying to set
//				a virtual property that cannot be set.
//
// Parameters:  Class name and Method name
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.setContinueCMExceptions(false);
	app.raiseCMException2(SetVirtualError, pClassName, pMethodName, null, null);

end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseUnexpectedProgramError" id="e1d51120-b80a-4ab1-81a0-2283b72c8df2">
        <source>raiseUnexpectedProgramError(pClassName, pMethodName, pMessage : String);
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     Raise an error for an unexpected exception. That indicate a
//				programming error, rather than a user input error.
//				ie. when a value is null that should never be null.
//
// Parameters:  Class name, Method name, Error message string
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.setContinueCMExceptions(false);
	app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, pClassName, pMethodName, pMessage, null, null);

end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="randomRange" id="4256ede6-b727-4d61-99e1-cdcce9a221a3">
        <source>randomRange(_min: Integer ; _max : Integer) : Integer;
/*

Purpose:			
	Returns a random value from a specified range
Parameters:			

Return Value:		

Date		Who		Reason
04 November 2014	cnwdb2	Initial creation

*/

vars
	min : Integer ; 
	max : Integer ; 
	value  :Integer ; 
	bool : Boolean ; 
begin
	min := _min ; 
	max := _max ; 

	value := 0 ; 
	bool := false ; 
	while (bool = false) do
		value := app.random(max) ; 
		if value &gt; min and value &lt; max then
			return value ; 
			bool := true ; 
		endif ; 
	endwhile ; 	
epilog

end;</source>
        <Parameter name="_min" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="reconcileBookingRefsToVoyage" id="9d466b1d-1eb3-428d-b4e8-961627161e41">
        <source>reconcileBookingRefsToVoyage(_voyage : CM_Voyage; _translatedVoyageCode : String; _translationOperator : String);
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2007 By cnwth2

Changed On   Changed By  Reason
cnwrs1 apr 2009 Par19398 remove the duplicate booking ref dialog and only update is a duplicate will not occur
07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures
	
----------   ----------  --------------------------------------------------
*/

vars
	terminal	: CM_Terminal;
	bookingRef	: CM_BookingRef;
	voyCode		: String;
	vesselCode	: String;
	operator	: CM_Operator; //Par 19171 cnwgb1 19.3.03
	foundMatch	: Boolean;
begin
	if _voyage = null or _voyage.myTerminal = null then
		return;
	endif;
			
	foreach bookingRef in _voyage.myTerminal.allBookingRefsByRef 
	   where bookingRef.myVoyage = null or bookingRef.myVoyage.isNullVoyage() do //cnwrs1 par17529 Sept 2008
	   
		voyCode 	:= bookingRef.getEDIVoyageCode();
		vesselCode 	:= bookingRef.getEDIVesselCode(); //Checking for corresponding vessel. Par 18876 Feb 2009
		operator 	:= bookingRef.myOperator;  //Par 19171 cnwgb1 19.3.03
		
		if voyCode = null or vesselCode = null or operator = null then
			continue;
		endif;
		
		if (voyCode = _translatedVoyageCode or voyCode = _voyage.code)
		   and (vesselCode = _voyage.vesselName.toUpper() or app.myRoot.getXlationSystemCode(vesselCode, XLATION_TYPE_VESSEL, foundMatch) = _voyage.vesselName.toUpper())// Par 18876 Feb 2009, PAR 19171 cnwgb1 19.3.09	// par 31259 March 2013
		   and (operator.code = _translationOperator) then
			 // if Structure modified Par 19171 cnwgb1 19.3.03
			 // cnwrs1 Apr 2009 Par19398
			if _voyage.myTerminal.allBookingRefsByOperatorRef.getAtKey(bookingRef.myOperator.code, bookingRef.bookingReference, _voyage) = null then //par 18616 cnwrs1 Nov 2008
				bookingRef.setMyVoyage(_voyage);
			endif;
		endif;
	endforeach;
end;


</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_translatedVoyageCode" type="String"/>
