    <JadeMethod name="doNoteHandlingAll" id="af505ff2-a3a6-43e9-af97-7e63cdba81aa">
        <updating/>
        <source>doNoteHandlingAll() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/03/2025	navkc1 JIRA Story MTN-34219: MTN | Notification Framework
28/04/2025  jlier1 MTN-34677
*/

vars
	noteRecord		: CMIF_NotificationRecord;
	notes : ObjectSet;
	object : Object;
begin
	
	// you need to do the notes in the order they came in - not the note number - because all the objects are transient can copy to set so they are oid order
	// if you don't  do in order you get issues e.g. if the create note is done after update note even though they came in they other way round
	create notes transient;
	self.allNoteRecords.copy(notes);
	
	//foreach noteRecord in self.allNoteRecords discreteLock do
	foreach object in notes  do
		noteRecord:=object.CMIF_NotificationRecord;
		self.doNoteHandlingObject(noteRecord);	
	endforeach;
	
epilog
	delete notes;
end;</source>
    </JadeMethod>
