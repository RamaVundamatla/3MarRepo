    <JadeMethod name="holdDrawWidth" id="b528fece-cd68-4843-bf9c-957b4b6b08f2">
        <methodInvocation>mapping</methodInvocation>
        <source>holdDrawWidth(set : Boolean; _value : Integer io) mapping;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
