    <JadeMethod name="populateTable" id="eac727a2-c628-4931-8d63-e09058de759c">
        <updating/>
        <source>populateTable() updating;

/*

Purpose:		Initialise and populate table

Parameters:			

Return Value:		


Date			Who		Reason
25 August 2008	consw1	Initial creation
30/11/2009		cnwmh5	PAR 21660 - change so yaDisplay filters correctly
01/05/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
27/09/2022      navds21 ChangeRequest 54936: MTN - YA Dwell Days Sort Logically
14/10/2022 		navhl20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17 Oct 2022 	navhl20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars
	altColour		: Boolean;
	criteriaColl 	: ObjectSet;
	criteriaObj		: Object;
	hasDescription	: Boolean;
	identifierColl	: StringArray;
	row				: Integer;
	rowMin,	rowMax	: Integer;
	selectedColl 	: ObjectSet;
	voyage			: CM_Voyage;
	voyageCritColl 	: ObjectSet;
	topRow			: Integer;
	searchVal		: String; // cnwrd1 par 19072 18.3.09
	str				: String;	// 30/11/2009 cnwmh5 #21660
	criteriaValue	: String;
	
	allObjs			: CM_ObjectArray;		//cnwmc5 - PAR 31255
	contCargoType : CM_CargoType;	//21 Oct 2019	NDL	TFS 46911
	carrier			: CM_Carrier;	//17.10.2022 navhl20 TFS 53697
	bolType 		: CM_BOLType;   //14.10.2022 navhl20 TFS 53862
	criteriaLineForm : CMUI_ObjectCriteriaLineForm;	//22 Oct 2019	NDL	TFS 46911
begin
	hasDescription := self.chkByDescription.visible;

	//+cnwml2 PAR23882
	if self.myCriteriaType.isKindOf(CM_YATypeBOL) then
		self.lblByVoyage.visible := true;
		self.cmbVoyage.visible := true;
		self.lblByWeight.visible := false;						// PAR #31155
		self.cmbWeight.visible := false;						// PAR #31155
		
		self.setCmbVoyage();
		self.doCmbVoyageLostFocus();
		return;
	elseif self.myCriteriaType.isKindOf(CM_YATypeWeight) then	// PAR #31155
		optAll.visible := false;
		optSelected.visible := false;
		optVoyage.visible := false;
		self.lblByVoyage.visible := false;						// PAR #31155
		self.cmbVoyage.visible := false;						// PAR #31155
		self.lblByWeight.visible := true;						// PAR #31155
		self.cmbWeight.visible := true;							// PAR #31155
		self.lblByWeight.move(self.lblByVoyage.left - 20, self.lblByVoyage.top, self.lblByWeight.width, self.lblByWeight.height);	// PAR #31155
		self.cmbWeight.move(self.cmbVoyage.left, self.cmbVoyage.top, self.cmbWeight.width, self.cmbWeight.height);					// PAR #31155
																// PAR #31155
		self.setCmbWeight();									// PAR #31155
		self.doCmbWeightLostFocus();							// PAR #31155
		return;													// PAR #31155
	else
		self.lblByVoyage.visible := false;
		self.cmbVoyage.visible := false;
		self.lblByWeight.visible := false;						// PAR #31155
		self.cmbWeight.visible := false;						// PAR #31155
	endif;
	//  Initialise table

	tblAvailable.rows := 0;	
	tblAvailable.columns := 3;
	tblAvailable.fixedColumns := 0;
	tblAvailable.gridLines := false;
	tblAvailable.accessColumn(1).alignment := Table.Alignment_Center_Middle;

	tblAvailable.accessColumn(1).width := 25;
	tblAvailable.accessColumn(2).width := 120;

	self.setSortOrder();

	//  Get criteria
	
	create criteriaColl transient;
	create voyageCritColl transient;
	create selectedColl transient;
	create identifierColl transient;
	
	//cnwmc5 - PAR 32155
	create allObjs transient;
	self.getTypeDependencies(allObjs);
	
	if self.myCriteriaType.getAllYAIdentifiers( identifierColl ) then
		self.createTransients( identifierColl, criteriaColl, selectedColl );
		optAll.visible := false;
		optSelected.visible := false;
		optVoyage.visible := false;

	elseif optVoyage.value then
		foreach voyage in self.allVoyages do
			self.myCriteriaType.getCriteriaValuesForVoyage( voyage, voyageCritColl );
			if criteriaColl.isEmpty then
				voyageCritColl.copy( criteriaColl );
			else
				foreach criteriaObj in voyageCritColl where not criteriaColl.includes( criteriaObj ) do
					criteriaColl.add( criteriaObj );
				endforeach;
			endif;
		endforeach;
		if criteriaColl.isEmpty then
			optAll.value := true;
			optVoyage.visible := false;
			self.myCriteriaType.getAllCriteriaValues(self.myTerminal, criteriaColl, self.filter, allObjs);	//cnwmc5 - PAR 32155
		endif;
		criteriaValue := self.getCriteriaValue();		// 12/07/2011 cnwmh5 #27772
		if criteriaValue &lt;&gt; null then		
			//par 19794... this part of code only get run if optVoyage option is selection
			//but it doesn't appear to be visible.  Just in case altered this code anyways.
			self.myCriteriaType.resolvePattern( criteriaValue, selectedColl, false );
		endif;
		foreach criteriaObj in selectedColl where not criteriaColl.includes( criteriaObj ) do
			criteriaColl.add( criteriaObj );
		endforeach;

	elseif optSelected.value then
		criteriaValue := self.getCriteriaValue();		// 12/07/2011 cnwmh5 #27772
		if criteriaValue &lt;&gt; null then
			//par 19794
			self.myCriteriaType.resolvePattern( criteriaValue, selectedColl, false );
		endif;
		selectedColl.copy( criteriaColl );

	else
		//25 Nov 2013	NDL	Par 33064 - For Operators, don't show unavailable unless already selected.
		if self.myCriteriaType.isKindOf( CM_YATypeOperatorItem ) then
			criteriaValue := self.getCriteriaValue();
			if criteriaValue &lt;&gt; null then
				self.myCriteriaType.resolvePattern( criteriaValue, selectedColl, false );
				if not selectedColl.isEmpty then
					selectedColl.copy( allObjs );
				endif;
			endif;
		endif;
	
		self.myCriteriaType.getAllCriteriaValues(self.myTerminal, criteriaColl, self.filter, allObjs);	//cnwmc5 - PAR 32155
		
		//21 Oct 2019	NDL	TFS 46911
		if self.myCriteriaType.isKindOf( CM_YATypeCargoType ) then
			if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf( CMUI_ObjectCriteriaLineForm ) then
				criteriaLineForm := self.myParentForm.CMUI_ObjectCriteriaLineForm;
				if criteriaLineForm.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then
					contCargoType := app.myRoot.allCargoTypesById[ TI_CargoType_Container ];
					if criteriaColl.includes( contCargoType ) then
						 criteriaColl.remove( contCargoType );
					endif;
				endif;
				//Start 14.10.2022 navhl20 TFS 53862
				if criteriaLineForm.context = CM_ObjectMatchCriteria.StopCriteriaInt then
					foreach bolType in app.myRoot.allBOLTypes do
						criteriaColl.add(bolType);
					endforeach;
				endif;
				//End 14.10.2022 navhl20 TFS 53862
			endif;
		endif;
		
		//Start 17.10.2022 navhl20 TFS 53697
		if self.myCriteriaType.isKindOf( CM_YATypeCarrier ) then
			if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf( CMUI_ObjectCriteriaLineForm ) then
				criteriaLineForm := self.myParentForm.CMUI_ObjectCriteriaLineForm;
				if criteriaLineForm.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then
					criteriaColl.clear();
					foreach carrier in app.myRoot.allCarriersRoad do
						criteriaColl.add(carrier);
					endforeach;
				endif;
			endif;
		endif;
		//End 17.10.2022 navhl20 TFS 53697
		
		criteriaValue := self.getCriteriaValue();		// 12/07/2011 cnwmh5 #27772
		if criteriaValue &lt;&gt; null then
					//par 19794
			self.myCriteriaType.resolvePattern( criteriaValue, selectedColl, false );
		endif;
		foreach criteriaObj in selectedColl where not criteriaColl.includes( criteriaObj ) do
			criteriaColl.add( criteriaObj );
		endforeach;
	endif;

	//  Populate table
	
	//Start 27.09.2022 navds21 TFS 54936
	if criteriaColl.size &gt; 0 and criteriaColl.first.isKindOf(CM_DwellDayRange) then
		self.tblAvailable.sortType[1] := self.tblAvailable.SortType_Numeric;
	endif;
	//End 27.09.2022 navds21 TFS 54936
	foreach criteriaObj in criteriaColl do
		str := criteriaObj.getYADisplay();		// 30/11/2009 cnwmh5 #21660
		if str &lt;&gt; null then
			row := tblAvailable.addItemObject( str, criteriaObj );
			
			if not hasDescription then												//+cnwml2 PAR22042
				hasDescription := tblAvailable.accessCell(row, 3).text &lt;&gt; null;		//+cnwml2 PAR22042
			endif;																	//+cnwml2 PAR22042
		endif;
	endforeach;

	tblAvailable.setSelected( selectedColl );
	
	//  Colour row etc.
	rowMax := tblAvailable.rows;
	foreach row in tblAvailable.fixedRows + 1 to rowMax do
		if not hasDescription then
			tblAvailable.accessCell(row, 2).mergeCells := Table.MergeCells_Merge;
		endif;
		altColour := not altColour;
		if altColour then
			tblAvailable.accessRow(row).backColor := self.colorRow1;
		else
			tblAvailable.accessRow(row).backColor := self.colorRow2;
		endif;
	endforeach;
	
	//  Position display
	
	if tblAvailable.rows &gt;= 1 then
		tblAvailable.row := 1;
	endif;

	if not self.tblAvailable.allSelectedObjects.isEmpty then
		tblAvailable.findObjectInRow(self.tblAvailable.allSelectedObjects.first, tblAvailable.row);
		self.positionDisplay();
	endif;

	self.chkByDescription.visible := hasDescription;
	self.tblAvailable.leftColumn := 1;	//12 Apr 2012	NDL	Par 29334
	
	self.txtFind.setFocus();
	
epilog
	
	delete criteriaColl;
	delete voyageCritColl;
	delete selectedColl;
	delete identifierColl;
	
	delete allObjs; //cnwmc5 - PAR 32155
end;</source>
    </JadeMethod>
    <JadeMethod name="positionDisplay" id="e2822ea9-7c64-433f-949a-ce019563ccaf">
        <source>positionDisplay();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
03 November 2008	consw1	Initial creation

*/

vars
	topRow : Integer;
	
begin
	topRow := tblAvailable.row - 3;
	
	if topRow &gt; tblAvailable.fixedRows then
		tblAvailable.topRow := topRow;
	elseif tblAvailable.rows &gt; tblAvailable.fixedRows then
		tblAvailable.topRow := tblAvailable.fixedRows + 1;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="set" id="7182e4f2-bd4d-4339-b6bd-55e5d204e4c1">
        <updating/>
        <source>set( _criteriaType : CM_YACriteriaType; _criteriaValue : String; _voyages : CM_VoyageSet; _filter : Integer; _masterControl : CMUI_YACriteriaCntl ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
25 August 2008	consw1	Initial creation
12/07/2011  	cnwmh5	#27772 - Add criteriaValueOids
17 September2013 cnwmc5 PAR 32155
29/4/2016 		cnwer1 tfs 1822 - remove criteriaValueOids
*/

vars
	
begin
	//cnwmc5 - PAR 32155
	self.masterControl := _masterControl;
	
	self.myCriteriaType := _criteriaType;
	self.criteriaValue := _criteriaValue;
	
	self.allVoyages.clear;
	if _voyages &lt;&gt; null then
		_voyages.copy( self.allVoyages );
	endif;
	
	if self.allVoyages.isEmpty then
		optAll.value := true;
		optVoyage.visible := false;
	else
		optVoyage.value := true;
	endif;
	
	self.filter := _filter; //+ cnwmd1, Par 21178
	
epilog

end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_criteriaValue" type="String"/>
        <Parameter name="_voyages" type="CM_VoyageSet"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_masterControl" type="CMUI_YACriteriaCntl"/>
    </JadeMethod>
    <JadeMethod name="setCmbVoyage" id="001b1034-0f94-43e6-b786-a3862b2663eb">
        <source>setCmbVoyage();
//08 June 2010	cnwml2
//+cnwml2 PAR23882
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	
	obj : Object;
	voyageCmb : CM_Voyage;
	cmifArray : CMIF_Array;
	strVoy : String;
	iter : Iterator;
	found : Boolean;
begin
	if self.myParentForm.isKindOf(CMUI_YACriteriaMaintForm) then
		create cmifArray transient;
		self.myParentForm.CMUI_YACriteriaMaintForm.getOperationalCriteria (cmifArray);
		foreach obj in cmifArray do
			if obj.CMIF_YACriteriaPriority.myProxy.code = "Voyage" then
				strVoy := obj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria.myYAData.getYAIdentifier;
				
				delete iter;		// PAR #26678
				iter := self.myTerminal.allVoyagesByCode.createIterator;
				found := false;
				while iter.next(voyageCmb) do
					if voyageCmb.code = strVoy then
						found := true;
						break;
					endif;
				endwhile;
				
				if found then
					self.cmbVoyage.setObject(voyageCmb);
					break;
				endif;
			endif;
		endforeach;			
	endif;
epilog
	delete cmifArray;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCmbWeight" id="ecb090e1-38b5-44ba-ab88-f6cef6bdbd78">
        <updating/>
        <source>setCmbWeight() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
01/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	measure 	: CM_MeasurementType;
	cmifArray	: CMIF_Array;
	obj			: Object;
	strWeight	: String;
	iter		: Iterator;
	found		: Boolean;
	range		: CM_WeightRange;
	strArray	: StringArray;
	str			: String;
	pattern		: CMIF_YAPattern;
	criteriaCol	: ObjectSet;
	selectedCol	: ObjectSet;

begin
	// load combo with weight-type measures
	self.cmbWeight.clear;
	foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = Type_Weight do
		self.cmbWeight.addItemObject(measure.name, measure);
	endforeach;
	
	// check parent form for any selected weight range
	measure := app.getDefaultMeasurementForType(Type_Weight);
	self.cmbWeight.setIndexFromObject(measure);
	
	if self.myParentForm.isKindOf(CMUI_YACriteriaMaintForm) or self.myParentForm.isKindOf(CMUI_YAMaintForm) then
		create cmifArray transient;
		create strArray transient;
		if self.myParentForm.isKindOf(CMUI_YACriteriaMaintForm) then
			self.myParentForm.CMUI_YACriteriaMaintForm.getOperationalCriteria(cmifArray);
		elseif self.myParentForm.isKindOf(CMUI_YAMaintForm) then
			self.getYAMaintOperationalCriteria(cmifArray);
		endif;
		//self.getWeightCriteria(cmifArray, null);
		foreach obj in cmifArray where obj.CMIF_YACriteriaPriority.myProxy.code = "Weight" do
			strWeight := obj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria.myYAData.getYAIdentifier;
			
			strArray.clear;
			if strWeight.containsOneOf(",") then
				create pattern transient;
				pattern.getTokens(strWeight, strArray);
				delete pattern;
			else
				strArray.add(strWeight);
			endif;
			
			delete iter;
			iter := app.myRoot.allWeightRanges.createIterator;
			while iter.next(range) do
				foreach str in strArray do
					if range.getYAIdentifier = str then
						found := true;
						break;
					endif;
				endforeach;
				if found then
					break;
				endif;
			endwhile;
		
			if found then
				self.cmbWeight.setIndexFromObject(range.myMeasurementType);
				break;
			endif;
		endforeach;
	endif;
	if not found then
		create criteriaCol transient;
		create selectedCol transient;
		self.getWeightCriteria(criteriaCol, selectedCol);
		if not selectedCol.isEmpty then
			range := selectedCol.first.CM_WeightRange;
			self.cmbWeight.setIndexFromObject(range.myMeasurementType);
		endif;
	endif;
epilog
	delete strArray;
	delete cmifArray;
	delete iter;
	delete criteriaCol;
	delete selectedCol;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="ac42007e-202f-44a4-bc1c-1b67a7312212">
