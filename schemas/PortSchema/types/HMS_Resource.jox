    <JadeMethod name="getCalcTypeDescription" id="ba921292-0720-4e40-8b4d-d0a4541a2dce">
        <source>getCalcTypeDescription() : String;
/*

Date		Who		Reason
13 March 2017	cnwer1	Initial creation TFS 3418

*/

vars

begin
	if self.myCalculationTypeQuantity &lt;&gt; null then
		return self.myCalculationTypeQuantity.description;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultQuantityForProforma" id="68998831-468f-43f6-8a77-743736f8006a">
        <source>getDefaultQuantityForProforma(_voyage : CM_Voyage; _movementType : String) : Integer;
/*

Purpose:		TFS 37963	

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2018	jlgab1	Initial creation

*/

vars
	resFor : HMS_ResourceForObject;
	resMove : HMS_ResourceTypeForMovement;
begin
	if _voyage = null then
		return 1;
	endif;
	if _voyage.myHMSVoyageData = null then
		return 1;
	endif;
		
	
	if not self.myResourceType.isMarineService then
		return 1;
	endif;
	
	foreach resFor in self.allHMSObjectsWithResources	discreteLock do
		if resFor.isForTug() then
			resMove := _voyage.myHMSVoyageData.allDefaultMovementResources[_movementType];
			
			if resMove&lt;&gt; null then
				return resMove.numTugsForMovement;
			endif;
		endif;
		
	endforeach;
	
	return 1;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_movementType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="6545ac9d-3e28-4f8f-9748-5a0349725db8">
        <source>getDisplayDetails(_short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/04/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Updates
//
vars

begin
	//epr TFS 43374 confusion when harbour has more than one terminal
	if self.myHarbour &lt;&gt; null then
		return self.description &amp; " (" &amp; self.myHarbour.code &amp; ")";
	endif;
	
	return self.description ;
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="df97843c-44d8-4270-8b03-ca214d58fc99">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:		TFS 37963	

Parameters:			

Return Value:		

Date		Who		Reason
07 Jul 2005 cnwab1  Initial creation
21 Jan 2019 cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details
29 Sep 2022 navsj20 ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
*/
vars

begin
	if _attrName = ETRow_CalcType then
		//epr TFS 3418 13/3/17
		return self.getCalcTypeDescription();
	elseif _attrName = ETRow_Wharf then
		if self.myWharf &lt;&gt; null then
			return self.myWharf.code;
		endif;
	elseif _attrName = ETRow_ExternalRef1 then  //21.01.2019 cnwma1 TFS #41980
		return self.externalReference1;
	// START 29 Sep 2022	navsj20	TFS 54739
	elseif _attrName = ETRow_Berth then	
		if self.myBerth &lt;&gt; null then
			return self.myBerth.code;	
		endif;
		return null;
	// END 29 Sep 2022	navsj20	TFS 54739
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="e3b7882c-9b92-43c8-8f12-b4c5739573c4">
        <source>getFullDescription() : String;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.code &amp; ' ' &amp; self.description;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMappedInvoiceCalcType" id="9759890a-b24f-47e6-8fbe-f1f4b4fc4b80">
        <source>getMappedInvoiceCalcType(_voyage : CM_Voyage; _poc : Boolean) : CM_CalculationType;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aService : CM_Service;
begin
	aService := self.getMappedInvoiceService(_voyage,_poc);
	
	if aService = null then
		return null;
	endif;
	
	return aService.myCalculationType;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="getMappedInvoiceLine" id="fcd7400d-8cd7-48eb-9a39-6205cf87a57f">
        <source>getMappedInvoiceLine(_voyage : CM_Voyage; _poc : Boolean) : CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	sb:             CM_ResourceServiceBroker;
	il : CM_InvoiceLineDesc;
	theBank : CM_Bank;
	theTM : CM_TranMapVoyage;
begin
	if _voyage = null then
		return null;
	endif;
	
	theBank := _voyage.myDischargeCompany;
	if theBank = null then
		return null;
	endif;
	
	theTM := theBank.myCurrentTranMapVoyage;
	if theTM = null then
		return null;
	endif;

	sb := theTM.getServiceBrokerFromResource(self);
	if sb = null then
		return null;
	endif;	

	il := sb.getInvoiceLineDescVTMIS(_voyage.myDebtor,_poc);

	return il;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getMappedInvoiceService" id="d65f3417-4dc5-45ce-9a9a-64b91cf6c291">
        <source>getMappedInvoiceService(_voyage : CM_Voyage; _poc : Boolean) : CM_Service;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ild : CM_InvoiceLineDesc;
begin
	ild := self.getMappedInvoiceLine(_voyage,_poc);
	
	if ild = null then
		return null;
	endif;
	
	return ild.services.first;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="getTimeBlockFromResource" id="36fae3bc-c841-4229-9f2e-96e8d13d2ce3">
        <source>getTimeBlockFromResource(_move : HMS_VoyageMovement; _partOfContract : Boolean) : Decimal;
/*
Purpose:			
Date		Who		Reason
31 December 2014	cnwab1	Initial creation
*/

vars
	resType : HMS_ResourceType;
	resUsed : 	 HMS_ResourceUsed;
	resTran : HMS_VTMISTransaction;
	calcType : CM_CalculationType;
	numBlock : Decimal[8,2];
	voy : CM_Voyage;
begin
	
	resType := self.myResourceType;
	
	if resType = null then
		return null;
	endif;
	
	voy := _move.getMyVoyage();
	
	create resUsed transient;


	resUsed.setPropertyValue(HMS_ResourceUsed::myVoyageMovement.name,_move);
	
	resUsed.setDefaultForMovement(_partOfContract,self,resType,app.myPassport);
	
	calcType := resUsed.myResource.getMappedInvoiceCalcType(voy,_partOfContract);
	
	if calcType= null then
		return null;
	endif;
	
	numBlock := calcType.hoursBlock;
	
	
	return numBlock;
	
epilog
	delete resUsed;
	delete resTran;
end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement"/>
        <Parameter name="_partOfContract" type="Boolean"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isResourceForClass" id="6b4b47f4-72c5-4099-aeff-ad7cfff5e575">
        <source>isResourceForClass(_class : Class) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		Used to tell if a resource is for tugs, pilots etc.
//
// ---------------------------------------------------------------------------

vars
	hmsObj : HMS_ResourceForObject;
begin

	hmsObj := self.allHMSObjectsWithResources.first;
	
	if hmsObj = null then
		return false;
	endif;
	
	return  hmsObj.isKindOf(_class);
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d42d32e4-a6e6-4c9a-baf5-dd6c1a4d3aa3">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
//29/09/2022 	navgm20 ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
	proxy : HMS_Resource;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myWharf := self.myWharf;
	proxy.myHarbour := self.myHarbour;
	proxy.myResourceType := self.myResourceType;
	proxy.myCalculationTypeQuantity := self.myCalculationTypeQuantity;
	proxy.myBerth := self.myBerth;	//29/09/2022 navgm20 TFS 54739
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeHMSObject" id="794118ab-3ea1-4636-a774-9866d1521952">
        <updating/>
        <source>removeHMSObject(_obj : HMS_ResourceForObject) updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.allHMSObjectsWithResources.getAtKey(_obj.myHMSObject)  &lt;&gt; null then
		if self.allHMSObjectsWithResources.includes(_obj) then
			self.allHMSObjectsWithResources.remove(_obj);	
		endif;
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_ResourceForObject"/>
    </JadeMethod>
    <JadeMethod name="setExternalReference1" id="8ca2f663-26d6-42c3-a6c7-33841b3ec591">
        <updating/>
        <source>setExternalReference1( _value : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2019	cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details

*/

vars

begin

	self.externalReference1 := _value[1:100];

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="33d686ff-1e14-493b-a422-8390d717939f">
        <updating/>
        <source>setForUpdate(_pxyResource : HMS_Resource; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2003 cnwdg1	Intial Creation
22 Jan 2019 cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details
09/09/2022	 navgm20 	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
*/

vars
	oldStartRange : Integer;
begin
	inheritMethod(_pxyResource, _passport);
	
	self.code 					   := _pxyResource.code.toUpper.trimBlanks;
	self.description 			   := _pxyResource.description;
	self.endPosnAlongWharf 		   := _pxyResource.endPosnAlongWharf;
	self.myHarbour 				   := _pxyResource.myHarbour;
	self.myResourceType 		   := _pxyResource.myResourceType;
	self.myWharf 				   := _pxyResource.myWharf;
	self.startPosnAlongWharf       := _pxyResource.startPosnAlongWharf;
	self.myCalculationTypeQuantity := _pxyResource.myCalculationTypeQuantity;
	self.isNotAvailableForEntry    := _pxyResource.isNotAvailableForEntry; // CCMS 1350
	self.externalReference1        := _pxyResource.externalReference1;     // 22.01.2019 cnwma1 TFS #41980
	self.myBerth				   := _pxyResource.myBerth;		//09/09/2022 navgm20 TFS 54739
    if self.startPosnAlongWharf &lt;&gt; self.endPosnAlongWharf then
    	if self.startPosnAlongWharf &gt; self.endPosnAlongWharf then
    		// Swap ranges around if user has entered them in the wrong way
    		oldStartRange := self.startPosnAlongWharf;
    		self.startPosnAlongWharf := self.endPosnAlongWharf;
    		self.endPosnAlongWharf := oldStartRange;
    	endif;
    endif;
    	
end;</source>
        <Parameter name="_pxyResource" type="HMS_Resource"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHMSObject" id="2d9836a1-1cec-4594-963a-1eb424d1865e">
        <updating/>
        <source>setHMSObject(_obj : HMS_ResourceForObject) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allHMSObjectsWithResources.getAtKey(_obj.myHMSObject)  = null then
		self.allHMSObjectsWithResources.add(_obj);	
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_ResourceForObject"/>
    </JadeMethod>
    <JadeMethod name="setMyBerth" id="f7fa1fb5-a9e9-4309-9e95-f8be65cc2f7b">
        <updating/>
        <source>setMyBerth(_berth : HMS_Berth) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 September 2022	navgm20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

*/

vars

begin
	self.myBerth := _berth;
	
epilog

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="dff94eee-6df9-43b0-a0a3-7920f1f46681">
        <updating/>
        <source>setProxy(_harbour : HMS_Harbour; _wharf : HMS_Wharf; _calcTypeQty : CM_CalculationType)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myHarbour := _harbour;
	self.myWharf := _wharf;
	self.myCalculationTypeQuantity := _calcTypeQty;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <Parameter name="_calcTypeQty" type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a72bf7f9-9f21-462e-9717-f96ee42b7b8f">
        <source>validateForDelete(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     22 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	strObjDescipt : String;
	resourceForTug : HMS_ResourceForTug;
	resourceForPilot : HMS_ResourceForPilot;
	resourceForPilotLaunch : HMS_ResourceForPilotLaunch;
	resourceForLineCompany : HMS_ResourceForLineCompany;
	resourceForObject,
	tmpResourceForObject : HMS_ResourceForObject;
	resourceForWharf 	: HMS_ResourceForWharf;
	wharfDict			: HMS_ResourceForWharfDict;
	tugDict				: HMS_ResourceForTugDict;
	pilotDict			: HMS_ResourceForPilotDict;
	pilotLaunchDict		: HMS_ResourceForPilotLaunchDict;
	lineCompanyDict		: HMS_ResourceForLineCompanyDict;
begin
	inheritMethod(_passport);
	
	if not self.allHMSObjectsWithResources.isEmpty() then
	
		create tugDict transient;
		create pilotDict transient;
		create pilotLaunchDict transient;
		create lineCompanyDict transient;
		create wharfDict transient;
		
		foreach resourceForObject in self.allHMSObjectsWithResources do
			tmpResourceForObject := resourceForObject;
			if resourceForObject.isKindOf(HMS_ResourceForTug) then 
				tugDict.add(resourceForObject.HMS_ResourceForTug);
			elseif resourceForObject.isKindOf(HMS_ResourceForPilot) then 
				pilotDict.add(resourceForObject.HMS_ResourceForPilot);
			elseif resourceForObject.isKindOf(HMS_ResourceForPilotLaunch) then 
				pilotLaunchDict.add(resourceForObject.HMS_ResourceForPilotLaunch);
			elseif resourceForObject.isKindOf(HMS_ResourceForLineCompany) then 
				lineCompanyDict.add(resourceForObject.HMS_ResourceForLineCompany);
			elseif resourceForObject.isKindOf(HMS_ResourceForWharf) then 
				wharfDict.add(resourceForObject.HMS_ResourceForWharf);
			endif;	
		endforeach;
	
		foreach resourceForTug in tugDict do 
			if resourceForTug.myArrivalResource = self then
				strObjDescipt := 'TUG - ' &amp; resourceForTug.getObjectDescription &amp; " as Arrival Resource.  "; 	
			elseif resourceForTug.myDepartResource = self then
				strObjDescipt := strObjDescipt &amp; 'TUG - ' &amp; resourceForTug.getObjectDescription &amp; " as Departure Resource.  "; 
			elseif resourceForTug.myShiftResource = self then
				strObjDescipt := strObjDescipt &amp; 'TUG - ' &amp; resourceForTug.getObjectDescription &amp; " as Shift Resource.  "; 
			endif;
		endforeach;

		foreach resourceForPilot in pilotDict do 
			if resourceForPilot.myArrivalResource = self then
				strObjDescipt := strObjDescipt &amp; 'PILOT - ' &amp; resourceForPilot.getObjectDescription &amp; " as Arrival Resource.  "; 	
			elseif resourceForPilot.myDepartResource = self then
				strObjDescipt := strObjDescipt &amp; 'PILOT - ' &amp; resourceForPilot.getObjectDescription &amp; " as Departure Resource.  "; 
			elseif resourceForPilot.myShiftResource = self then
				strObjDescipt := strObjDescipt &amp; 'PILOT - ' &amp; resourceForPilot.getObjectDescription &amp; " as Shift Resource.  "; 
			endif;
		endforeach;
	
		foreach resourceForPilotLaunch in pilotLaunchDict do 
			if resourceForPilotLaunch.myArrivalResource = self then
				strObjDescipt := strObjDescipt &amp; 'PILOT LAUNCH - ' &amp; resourceForPilotLaunch.getObjectDescription &amp; " as Arrival Resource.  "; 
			elseif resourceForPilotLaunch.myDepartResource = self then
				strObjDescipt := strObjDescipt &amp; 'PILOT LAUNCH - ' &amp; resourceForPilotLaunch.getObjectDescription &amp; " as Departure Resource.  "; 
			elseif resourceForPilotLaunch.myShiftResource = self then
				strObjDescipt := strObjDescipt &amp; 'PILOT LAUNCH - ' &amp; resourceForPilotLaunch.getObjectDescription &amp; " as Shift Resource.  "; 
			endif;
		endforeach;
	
		foreach resourceForLineCompany in lineCompanyDict do 
			if resourceForLineCompany.myArrivalResource = self then
				strObjDescipt := strObjDescipt &amp; 'LINE COMPANY - ' &amp; resourceForLineCompany.getObjectDescription &amp; " as Arrival Resource.  "; 
			elseif resourceForLineCompany.myDepartResource = self then
				strObjDescipt := strObjDescipt &amp; 'LINE COMPANY - ' &amp; resourceForLineCompany.getObjectDescription &amp; " as Departure Resource.  "; 
			elseif resourceForLineCompany.myShiftResource = self then
				strObjDescipt := strObjDescipt &amp; 'LINE COMPANY - ' &amp;  resourceForLineCompany.getObjectDescription &amp; " as Shift Resource.  "; 
			endif;
		endforeach;
		
		foreach resourceForWharf in wharfDict do 
			if resourceForWharf.myArrivalResource = self then
				strObjDescipt := strObjDescipt &amp; 'WHARF - ' &amp; resourceForWharf.getObjectDescription &amp; " as Arrival Resource.  "; 	
			elseif resourceForWharf.myDepartResource = self then
				strObjDescipt := strObjDescipt &amp; 'WHARF - ' &amp; resourceForWharf.getObjectDescription &amp; " as Departure Resource.  "; 
			elseif resourceForWharf.myShiftResource = self then
				strObjDescipt := strObjDescipt &amp; 'WHARF - ' &amp; resourceForWharf.getObjectDescription &amp; " as Shift Resource.  "; 
			endif;
		endforeach;		
	endif;
	

	
	if not self.allResourceUsed.isEmpty 
	or not self.allResourceUsedArchived.isEmpty then
			strObjDescipt := strObjDescipt &amp; 'RESOURCE USED. Has been used for resource USED. '; 
	endif;
	if 	strObjDescipt &lt;&gt; null then 
		app.raiseCMException2(ERR_CANNOT_DELETE_BANK, self.description, strObjDescipt, null, null);	
	endif;

epilog
		delete tugDict;
		delete pilotDict;
		delete pilotLaunchDict;
		delete lineCompanyDict;
		delete wharfDict;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b1d1a7b7-2949-4fd5-879b-3a37fb597b67">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//16/09/2022 	navsj20		ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

//--------------------------------------------------------------
vars
	tmpResource : HMS_Resource;
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_Desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour,  null); // cnwdb2	PAR 35364


	endif;

	if self.myResourceType = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', ETRow_MyResourceType,  null);
		app.raiseCMException(Input_required_field_resrcType, ETRow_MyResourceType,  null); // cnwdb2	PAR 35364
	endif;
	
	/*CCMS1299 - Reources do not have to be assigned to a wharf
	if self.myWharf = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Wharf', ETRow_MyWharf,  null);
	endif;
	*/
	
	/*if self.endPosnAlongWharf = null then
		app.raiseCMException1(REQUIRED_FIELD, 'End Posn Along Wharf', ETRow_EndPosnAlongWharf,  null);
	endif;
	if self.startPosnAlongWharf = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Start Posn Along Wharf', ETRow_StartPosnAlongWharf,  null);
	endif;*/
								
	if _passport.hasErrors then
		return;
	endif;
	
	if not self.myResourceType.isBollard then 	//09/09/2022 navgm20 TFS 54739
		tmpResource := self.myHarbour.allResources.getAtKey(self.code);
			if tmpResource &lt;&gt; null then
				if self.isTransient and tmpResource &lt;&gt; self.pxyGetRealObject() then
					//app.raiseCMException2(DuplicateItem, 'Resource', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
					app.raiseCMException1(Resourcealready_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
				endif;
			endif;
	endif;	//09/09/2022 navgm20 TFS 54739
	//09/09/2022 navgm20 TFS 54739 - Start
	if self.myResourceType.isBollard and self.myBerth = null then
		app.raiseCMException1(Bolla_type_resou_must_have_ber, self.code, ETRow_Code, null);
	endif;
	//09/09/2022 navgm20 TFS 54739 - End
	// START 16 Sep 2022	navsj20	TFS 54739
	if self.myBerth &lt;&gt; null then 
		tmpResource := self.myBerth.allBerthResources[self.code];
		if tmpResource &lt;&gt; null and self.isTransient and tmpResource &lt;&gt; self.pxyGetRealObject then
				app.raiseCMException1(Resourcealready_exists, self.myBerth.description, ETRow_MyBerth, null); 
		endif;
	endif;
	// END 16 Sep 2022	navsj20	TFS 54739
	 
	//28 Feb 2019	NDL	TFS 43577
	if self.myCalculationTypeQuantity &lt;&gt; null then
		tmpResource := self.myCalculationTypeQuantity.allResourceQuantity.getAtKey(self.code);
		if tmpResource &lt;&gt; null then
			if self.isTransient and tmpResource &lt;&gt; self.pxyGetRealObject() then
				//app.raiseCMException2(DuplicateItem, 'Resource / Calculation Type', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
				app.raiseCMException1(Resour_calcul_type_alread_exis, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			endif;
		endif;
	endif;

	self.validateRange(_passport);	

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRange" id="037722dd-ade3-48ed-93ef-a62254cc47fe">
        <source>validateRange(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//23 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

//--------------------------------------------------------------
vars
 	/*minRange,
 	maxRange : Integer;*/
begin
  	// This method checks to see if the resource ranges entered are valid for the wharf 
	if self.myWharf &lt;&gt; null then
		self.myWharf.validateRangeForResource(self.startPosnAlongWharf, self.endPosnAlongWharf, 'Resource ' &amp; self.code, _passport);	
	endif;
	// START 23 Sep 2022	navsj20	TFS 54739
	if self.myBerth &lt;&gt; null then
		self.myBerth.validateRangeForResource(self.startPosnAlongWharf, self.endPosnAlongWharf, self.code, _passport);	
	endif;
	// END 23 Sep 2022	navsj20	TFS 54739
	/*minRange:=(0-self.myWharf.overhangZeroMetreEnd);
	maxRange:=(self.myWharf.length+self.myWharf.overhangMaxMetreEnd);

	if self.startPosnAlongWharf &lt; minRange or self.startPosnAlongWharf &gt; maxRange then
		// Start of range outside valid metre range for the wharf
		app.raiseCMException4(ResourceStartRangeInvalid, self.startPosnAlongWharf.String,
							self.code, minRange.String &amp; ' to ' &amp; maxRange.String,
							self.myWharf.code, ETRow_StartPosnAlongWharf, null);
		return;
	endif;
	
	if self.endPosnAlongWharf &lt; minRange or self.endPosnAlongWharf &gt; maxRange then
		// End of range outside valid metre range for the wharf
		app.raiseCMException4(ResourceEndRangeInvalid, self.endPosnAlongWharf.String,
							self.code, minRange.String &amp; ' to ' &amp; maxRange.String,
							self.myWharf.code, ETRow_EndPosnAlongWharf, null);		
		return;
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
