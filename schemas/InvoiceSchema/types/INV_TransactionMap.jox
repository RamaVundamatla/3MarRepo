	ls : Boolean;
	theReturn : Integer;
begin
	
	//aCode := self.tblProperties.getValueByName(ETRow_Name).String;
	//aDesc := self.tblProperties.getValueByName(ETRow_Description).String;
	
	aCode := self.tblProperties.getValueByName(ETRow_Code30).String; //03/04/2025	navkc1 JIRA Bug MTN-34244
	aDesc := self.tblProperties.getValueByName(ETRow_Description60).String; //03/04/2025	navkc1 JIRA Bug MTN-34244
	
	if self.updateMode = self.UpdateMode_New then
		create pxyBOLTM transient;
	else
		app.cmsBeginLoad(ls);
		pxyBOLTM := app.createUpdateProxy(self.myCurrentMapTMBOL).CM_TranMapBOL;
		app.cmsEndLoad(ls);
	endif;

	pxyBOLTM.setProxy(self.myCurrentBank, aCode, aDesc);
		
	while true do
		if self.updateMode = self.UpdateMode_New then
			app.myTrxCA.trxCreateInvoiceTranMapBOL(pxyBOLTM,realBOLTM,app.myPassport);
		else
			app.myTrxUA.trxUpdateInvoiceTranMapBOL(pxyBOLTM,app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
