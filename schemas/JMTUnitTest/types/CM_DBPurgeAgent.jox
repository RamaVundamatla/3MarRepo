    <JadeMethod name="doDevOffsiteItems" id="9f42dc10-4c62-498e-86c5-b82f5de3c0b0">
        <source>doDevOffsiteItems();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	ti : CM_TrackedItem;
    dict : CM_TIArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Offsite Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	iter := app.getMyTerminalDO_NOT_USE().allOffsiteTIsByCargoTypeId.createIterator;

	size := app.getMyTerminalDO_NOT_USE().allOffsiteTIsByCargoTypeId.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " TIs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	
	while iter.next(ti) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("TIs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". TIs to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if not ti.isChild then
			if ti.releasedDT.date &lt; self.date then
				if global.isValidObject(ti) then
					dict.add(ti);
				endif;
			endif;
		endif;
	endwhile;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	delete iter;
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(ti) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Offsite TIs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;ti.id&amp;" releasedDT on "&amp;ti.releasedDT.String&amp;" "&amp;ti.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		ti.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TI's erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevOldSlotControllers" id="0786e5c4-3d88-47af-99c0-752416a63b8d">
        <source>doDevOldSlotControllers();
//
//26 June 2018	jlgrs1	Initial creation
//
// no self.date use
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
