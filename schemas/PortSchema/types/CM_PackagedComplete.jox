    <JadeMethod name="getLocationTA" id="d36cb0ae-56b0-4726-82b3-bb0bc53e5f83">
        <source>getLocationTA() : CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin
	self.myTerminal.findLocationFromString(self.location, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC &lt;&gt; null then
		return tmpFoundLC.myTerminalArea;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="0d66b76b-8966-45d5-bd3c-f09ba89bb7a0">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars

begin

	inheritMethod(pTI, _tiTransCntrl);
	
	self.location := pTI.locationId;

epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
