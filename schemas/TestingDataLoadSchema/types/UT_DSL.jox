    <JadeMethod name="move" id="28f4570a-63c9-4611-ac74-1f217a955e11">
        <source>move(_ti: CM_TrackedItem; _destination: Any);
//02 September 2008	cnwdw1	
// 02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
vars
	moveController	: CMIF_MoveController;
	destination: CM_LocationsController;
	vehicle			: CM_Vehicle;
	terminalArea	: CM_TerminalArea;
	expectErrors : Boolean;
	ignoreWarnings : Boolean;
	targetType		: String;
	locationId		: String;
	terminalAreaId	: String;
	startingPos		: Integer;
begin

	expectErrors := self.opts.bool("ExpectErrors");
	ignoreWarnings := not self.opts.bool("DontIgnoreWarnings");					// 23/07/2015 cnwmh5
	
	// 13/11/2017 jlgmh5 - Simplify so that you only have to pass the location as a string
	// and let this method work it out based on the type passed with it
	
	
	if _destination.isKindOf(CM_LocationsController) then
		destination := _destination.CM_LocationsController;
	elseif _destination.isKindOf(CM_TerminalArea) then
		destination := _destination.CM_TerminalArea.allLocationsControllers.first;
	elseif _destination.isKindOf(CM_Vehicle) then						// 29/09/2011 cnwmh5
		destination := _destination.CM_Vehicle.locationsController;
	elseif _destination.isKindOf(String) then
		targetType := self.opts.str('TargetType');
		self.assertNotNull(targetType);
		if targetType.toUpper() = "TerminalArea".toUpper() then
			locationId := _destination.String;
			startingPos := 1;
			startingPos := locationId.pos(" ", startingPos);
			if startingPos = 0 then
				terminalAreaId := locationId;
			else
				terminalAreaId := locationId[1:startingPos-1];
				locationId := locationId[terminalAreaId.length + 1: end].trimBlanks();			// 05/03/2017 jlgmh5
			endif;
			terminalArea := self.getTerminalArea(terminalAreaId);
			destination := terminalArea.getLocationsControllerFromId(locationId);
		elseif targetType.toUpper() = "Vehicle".toUpper() then
			vehicle := self.getVehicle(_destination.String);
			destination := vehicle.locationsController;
		elseif targetType.toUpper() = "Wagon".toUpper() then
		
		elseif targetType.toUpper() = "Voyage".toUpper() then
		
		endif;
	endif;
	
//	assertNotNull(destination);
	
	assertTrueMsg(destination &lt;&gt; null, _destination.String &amp; " Cannot Be Used - " &amp; _ti.id);
	
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(destination);
	moveController.setMoveMode(REAL_MODE);
	if self.opts.includesKey("MoveMode") then
		moveController.setMoveMode(self.opts.int("MoveMode"));									// 22/04/2014 cnmwh5
	endif;
	if self.opts.includesKey("IsForcedMove") then			// 02/08/2011 cnwmh5 
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	endif;
	if self.opts.includesKey("SetWorkListEntry") then					// 29/09/2011 cnwmh5 
		moveController.setMyWorkListEntry(self.opts.obj("SetWorkListEntry").CM_WorkListEntry);
	endif;
	if self.opts.includesKey("TotalQuantity") then			
		moveController.setQuantity(self.opts.int("TotalQuantity"));
	endif;
	if self.opts.includesKey("TotalWeight") then			
		moveController.setWeight(self.opts.int("TotalWeight"));
	endif;
	
	ignoreTrxWarnings(ignoreWarnings);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();						// 02/08/2011 cnwmh5
	endif;
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="Any"/>
    </JadeMethod>
    <JadeMethod name="moveAllCargoOnVoyage" id="a7ce5e3b-f3cf-4caf-b571-a8b29cc99898">
        <source>moveAllCargoOnVoyage(_voyage: CM_Voyage; _mode: Integer);
// 05/08/2011 cnwmh5	Change to use UT_UnitTest's opts
vars
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	wlesToMove, wlesWithWarnings : CM_WLEArray;
	completedDate : TimeStamp;
	sleep: Integer;
	doWPOpHrs : Integer;	// create CM_WorkPointHrs every 'n' jobs.
	jobCount : Integer;
begin
	create wlesToMove transient;
	create wlesWithWarnings transient;
	
	sleep := self.opts.int("Sleep");
	doWPOpHrs := self.opts.int("WPOpHrs");
	
	foreach job in _voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		if job.CM_VoyageJob.status = JOB_COMPLETE then					// 14/05/2013 cnwmh5
			continue;
		endif;
		
		
		self.moveCargoForVoyageJobExtra(job);
		self.moveCargoForVoyageJob(job, _mode);
		
		if doWPOpHrs &lt;&gt; 0 then
			jobCount := jobCount + 1;
			if jobCount mod doWPOpHrs = 0 then
				self.addWPOpHrs( _voyage, job.CM_VoyageJob, 50000 );
			endif;
		endif;
		
		if sleep &lt;&gt; 0 then
			process.sleep(sleep);
		endif;
	endforeach;
	

epilog
	delete wlesToMove;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveAllCargoOnVoyage2" id="9e1377a8-3b5e-4a18-99a2-0b39d5bac508">
        <source>moveAllCargoOnVoyage2(_voyage: CM_Voyage; _yardLocation : CM_LocationsController);
// move using instant move not planning
vars
	obj	: Object;
	ti	: CM_TrackedItem;
	onShip,
	onSite	: CM_TIArray;
begin
	create onShip transient;
	create onSite transient;
	_voyage.allOnshipTIsByIdCargoType.copy(onShip);
	_voyage.allOnsiteTIsByCargoTypeId.copy(onSite);
	
	foreach obj in onShip do
		ti := obj.CM_TrackedItem;
		self.deleteStops(ti);
		self.instantMove(ti, _yardLocation);
	endforeach;
	
	foreach obj in onSite do
		ti := obj.CM_TrackedItem;
		self.deleteStops(ti);
		self.instantMove(ti, _voyage.myShipBlockStack);
	endforeach;
epilog
	delete onShip;
	delete onSite;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_yardLocation" type="CM_LocationsController"/>
    </JadeMethod>
