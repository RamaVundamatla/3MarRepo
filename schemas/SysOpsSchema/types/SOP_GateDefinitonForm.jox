        <source>cmbICArea_click(_combo: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myProxyObject = null then
		return;
	endif;
	
	self.myProxyObject.CM_Gate.setMyDefaultInterchangeArea (_combo.listObject.CM_YardInterchangeArea);
epilog

end;</source>
