    <JadeMethod name="displaySchedule" id="5c8ad461-b108-4695-9bde-3c77484d188b">
        <updating/>
        <source>displaySchedule(_schedule : CM_WorkOrderSchedule; _row, _col : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	numberActioned : Integer;
	numberComplete : Integer;
	scheduledDT : TimeStamp;
	rowColour : Integer;
	editColour : Integer;
begin

	scheduledDT := self.getScheduledDT(_row);
	
	if scheduledDT &gt; self.currentTS then
		if scheduledDT.date.day mod 2 = 1 then
			rowColour := self.colorRow1;
			editColour:= self.colorRow2;
		else
			rowColour := self.colorRow2;
			editColour:= self.colorRow1;
		endif;
	else
	rowColour := self.colorControlBack;
	editColour:= self.colorControlBack;
	endif;
	
	if _schedule = null then
		tblSchedule.accessCell(_row, _col).text := '';
		tblSchedule.accessedCell.itemObject := null;
		tblSchedule.accessCell(_row, _col+1).text := null;
		tblSchedule.accessCell(_row, _col+2).text := null;
	else
		if _schedule.numberScheduled &gt; 0 then
			tblSchedule.accessCell(_row, _col).text := _schedule.numberScheduled.asStringJMT();
		else
			tblSchedule.accessCell(_row, _col).text := '';
		endif;		
		
		tblSchedule.accessedCell.itemObject := _schedule;
		numberActioned := _schedule.getNumberActioned();
		numberComplete := _schedule.getNumberComplete();
		
		if (_schedule.numberScheduled - numberActioned) &gt; 0 then
			tblSchedule.accessCell(_row, _col+1).text := (_schedule.numberScheduled - numberActioned).asStringJMT();
			else
			tblSchedule.accessCell(_row, _col+1).text := '';
		endif;
		if numberActioned &gt; 0 then
			tblSchedule.accessCell(_row, _col+2).text := numberActioned.asStringJMT();
			else
			tblSchedule.accessCell(_row, _col+2).text := '';
		endif;
		
		if numberComplete &gt; 0 then
			tblSchedule.accessCell(_row, _col+3).text := numberComplete.asStringJMT();
			else
			tblSchedule.accessCell(_row, _col+3).text := '';
		endif;
		
	endif;
	
//	tblSchedule.accessCell(_row, _col).backColor := editColour;
	tblSchedule.accessCell(_row, _col+1).backColor := rowColour;
	tblSchedule.accessCell(_row, _col+2).backColor := rowColour;
	tblSchedule.accessCell(_row, _col+3).backColor := rowColour;
	

epilog

end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doActionSome" id="22f45c3e-5c4d-4eeb-80f6-222f8da3a73d">
        <source>doActionSome( _schedule : CM_WorkOrderSchedule);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwrd1	Initial creation

*/

vars
	actionForm 		: YRD_WorkOrderAction;
//	workOrder,
//	realWorkOrder 	: CM_WorkOrder;
	task 			: CM_WorkOrderDtl;
	selObj 			: Object;
begin

	if _schedule = null then
		return;
	endif;
	
	task := _schedule.myParent;
	
	if task = null then
		return;
	endif;
	
	
	actionForm := app.getForm(YRD_WorkOrderAction.name).YRD_WorkOrderAction;
	if actionForm = null then
		actionForm := app.loadForm(YRD_WorkOrderAction, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderAction;
	endif;
	
	if actionForm = null then
		return;
	endif;
	
	actionForm.centreWindow;
	actionForm.setMyTerminal(self.myTerminal);
	//taskForm.initialise(workOrder, YRD_TaskJobSourceForm.Mode_Update, workOrder.getProxyTask(task));
	actionForm.setWorkOrderTask( task );
	actionForm.setWorkOrderSchedule( _schedule );
	actionForm.showModal();
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
    </JadeMethod>
    <JadeMethod name="doActionWorkSchedule" id="6acb1c52-e803-4ede-8b4c-d6238eb658b7">
        <updating/>
        <source>doActionWorkSchedule(_schedule : CM_WorkOrderSchedule; _total : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwrd1	Initial creation

*/

vars
	parent : CM_WorkOrderTIDtl;
	woActionIF : CMIF_WorkOrderAction;
	result : Integer;
begin


	if _schedule.myParent.hasRBTToAction() then  // first task with some Request by type element to action.
	
		// just show the some form because we have RBT for now
		self.doActionSome( _schedule );
		return;
	endif;

	//else go ahead and action the work.
	
	create woActionIF transient;

	
	self.populateIFObject( _schedule, _total, woActionIF);
	
	while true do
		
		app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport); 

		if app.myPassport.trxCompletedOK then
			return ;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


epilog
	delete woActionIF;
	
end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_total" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddDates" id="12869e0d-8200-4868-8768-eb74cf15f8d3">
        <updating/>
        <source>doAddDates() updating;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	frm : YRD_WorkOrderScheduleDatesForm;
	
begin
	frm := app.loadForm(YRD_WorkOrderScheduleDatesForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderScheduleDatesForm;
	
	if frm = null then
		return;
	endif;

	frm.set(self.myWorkOrder);
	frm.myParentForm := self;
	
	frm.showModal();
	
	if frm.modalResult = IDOK then
		frm.getDateTimes( self.allDateTimes );
		self.loadSchedule();
		endif;
	
epilog
	delete frm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddDatesNext" id="f87d38d6-88e0-4657-b6da-ab210b96a9e5">
        <updating/>
        <source>doAddDatesNext(	_frm : YRD_WorkOrderScheduleDatesForm) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwrd1	Initial creation

*/

vars

begin

	_frm.getDateTimes( self.allDateTimes );
	self.loadSchedule();
		
epilog

end;</source>
        <Parameter name="_frm" type="YRD_WorkOrderScheduleDatesForm"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="fd7c5d0a-3d06-4833-9dde-b2d3d97da5af">
        <updating/>
        <source>doSave() : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	number : Integer;
	parent : CM_WorkOrderTIDtl;
	proxySchedule : CM_WorkOrderSchedule;
	schedule,
	loopSchedule : CM_WorkOrderSchedule;
	scheduledDT : TimeStamp;
	numberActioned : Integer;
	numberRemainingToPlan : Integer;
	numberStillToDo : Integer;
	totalActioned : Integer;
	totalNotActioned : Integer;
	totalRequired : Integer;
	totalStillToDo : Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin

	if self.inputRow = 0 or self.inputColumn = 0 then
		return true;
	endif;
	
	number := self.tblSchedule.accessCell(self.inputRow, self.inputColumn).text.asIntegerJMT();
	schedule := self.tblSchedule.accessedCell.itemObject.CM_WorkOrderSchedule;
	
	//if (schedule = null and number = 0)
	if (schedule &lt;&gt; null and schedule.numberScheduled = number) then
		return true;
	endif;
	
	
	parent := self.tblSchedule.accessColumn(self.inputColumn).itemObject.CM_WorkOrderTIDtl;
	scheduledDT := self.localToSystemTime( self.getScheduledDT(self.inputRow));//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach loopSchedule in parent.CM_WorkOrderTIDtl.allSchedules  where loopSchedule &lt;&gt; schedule do
		numberActioned := loopSchedule.getNumberActioned();
		numberStillToDo := loopSchedule.numberScheduled - numberActioned;
		if self.systemToLocalTime(loopSchedule.scheduledDT) &gt; self.currentTS then//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
			totalStillToDo := totalStillToDo + numberStillToDo;
		else
			totalNotActioned := totalNotActioned + numberStillToDo;
		endif;
		totalActioned := totalActioned + numberActioned;
	endforeach;

	totalRequired := parent.myParent.getTotalRequired();
	numberRemainingToPlan := totalRequired -( totalStillToDo + totalActioned);
	
	

	if numberRemainingToPlan &lt; number then
		number := numberRemainingToPlan;	
		if number &gt;= 0 then //cnwrd1 par 29058 9.2.2012
			self.txtEditable.text := number.asStringJMT();
			self.tblSchedule.accessCell(self.inputRow, self.inputColumn).text := number.asStringJMT();
		endif;
	endif;


	if number &lt; 0 then
		number := 0;
	endif;
	
	if schedule = null then
		create proxySchedule transient;
		proxySchedule.setProxy( number, scheduledDT);
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateWorkOrderSchedule(proxySchedule, schedule,parent, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				return true;
				break;
			else
				theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	else
		proxySchedule := app.createUpdateProxy(schedule).CM_WorkOrderSchedule;
		proxySchedule.setProxy( number, scheduledDT);
		app.myTrxUA.trxUpdateWorkOrderSchedule(proxySchedule, app.myPassport);

	endif;
	
	return false;

epilog
	delete proxySchedule;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doScheduleTableContextMenu" id="95b55b73-a665-4c3b-b1b6-00a239550f8f">
        <updating/>
        <source>doScheduleTableContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Dec 2009	cnwrd1	Initial creation
16 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	theRow,
	theColumn 	: Integer;
	allValue,
	theseValue : Integer;
	theTI	: CM_TrackedItem;
	number : Integer;
	parent : CM_WorkOrderTIDtl;
	schedule : CM_WorkOrderSchedule;
begin


	if cntrl.CM_BaseTable.getCellFromPosition(x,y,theRow,theColumn) then
		if cntrl.cnEcIsValidRow(theRow) and cntrl.cnEcIsValidColumn(theColumn) then
		
			schedule := cntrl.CM_BaseTable.accessCell(theRow,theColumn).JadeTableCell.itemObject.CM_WorkOrderSchedule;
			
			self.mnuActionAll.userObject   := schedule;
			self.mnuActionThese.userObject := schedule;
			self.mnuActionSome.userObject  := schedule;
		
			if schedule &lt;&gt; null then // we can proceed
			
			
				// build action menu
				parent := schedule.myParent;
				
				if not parent.canActionTask()  then					//16.03.2023 navma1 #56457:[56458]
					return false;
				endif;
						
				allValue := parent.totalUnactioned;
				
				theseValue := schedule.numberScheduled - schedule.getNumberActioned();
				
				if theseValue &lt; 0 then 
					theseValue := 0;
				endif;
				
				if theseValue &gt; allValue then							
					theseValue := allValue;
				endif;
				
				
				
				self.mnuActionAll.caption := app.getErrorString1(Wo_Action_All, allValue.asStringJMT() );
				self.mnuActionThese.caption := app.getErrorString1(Wo_Action_These, theseValue.asStringJMT() );
				
			
				self.mnuActionThese.visible := not theseValue = 0 ;
			
	
			
			return self.showContextMenu(self.mnuAction,cntrl,conwin,mouse,x,y);
			

			endif;
			
		
		else
		// no schedule so show the other context menu
		return self.showContextMenu(self.mnuDateColumn,cntrl,conwin,mouse,x,y);		
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectTask" id="35aaaeb6-e1d9-41b2-8b5c-7274a7368267">
