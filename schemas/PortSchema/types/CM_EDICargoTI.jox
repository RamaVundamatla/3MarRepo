    <JadeMethod name="setPropertyByName" id="bb3fd66e-6241-4fbb-8cc9-09d3ebac81f8">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
/* Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
   10/07/2023	navdap1		Initial creation TFS 58813 EUP Manifest Instructions and Work Orders
   19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
   07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
   21 Nov 2023	jlika1	TFS 61135 61013 CUX | Cargo Priority - User Defined ED
*/
vars

begin
	if _columnName = ETRow_InstructionType then
		self.instructionType := _value;
	elseif _columnName = ETRow_InstructionExternal then
		self.instructionExternal := _value;
	elseif _columnName = ETRow_InstructionInternal then
		self.instructionInternal := _value;
	elseif _columnName = ETRow_ContainerNumberText then			//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		self.setContainerNumberText(_value);
	elseif _columnName = ETRow_PortOfOrigin then				//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
		self.setPortOfOrigin(_value);
	elseif _columnName = ETRow_CustomerPriorityCode then
		self.setCustomerPriorityCode(_value, null);
	else
		return inheritMethod(_columnName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
