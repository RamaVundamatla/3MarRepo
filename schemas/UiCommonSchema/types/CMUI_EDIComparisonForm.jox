epilog
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComparePorts" id="b7f64808-49c3-4fc0-80a0-3d204faf7c5f">
        <source>doComparePorts(_rowName :String; _release :CM_BulkRelease; _ediTI :CM_EDIReleaseRequestTI):Boolean protected;
/*
Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	port	:CM_Port;
	ediPort	:String;
begin
	if _rowName = ETRow_DischargePort then
		ediPort := _ediTI.dischargePort;
		port	:= _release.myDischargePort;
		
	elseif _rowName = ETRow_LoadPort then
		ediPort := _ediTI.loadPort;
		port	:= _release.myLoadPort;
		
	elseif _rowName = ETRow_DestinationPort then
		ediPort := _ediTI.destinationPort;
		port	:= _release.myDestinationPort;
	endif;
	
	if port &lt;&gt; null and port.code = ediPort then
		// match
		return true;
	endif;

	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEdit" id="13ba09ad-42f9-41a6-b50f-e96992eb87f8">
        <updating/>
        <source>doEdit(_inEdit : Boolean) updating;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update
*/

vars
	row,
	idx : Integer;
	ediTI : CM_EDITrackedItem;
	str : String;
	reserveDetail : CM_ReserveDetail;
begin
	if _inEdit then
		if self.tblData.allSelectedObjects.isEmpty or self.tblData.allSelectedObjects.size &gt; 1 then //epr TFS 2606 10/3/17 make sure only one is selected
			return;
		endif;
	endif;
	
	self.btnRefresh.enabled := not _inEdit;
	self.btnEdit.enabled:=not _inEdit;
	self.btnSaveBase.enabled:=_inEdit;
	self.btnSaveVerify.enabled:=_inEdit;
	self.tblData.readOnly := not _inEdit;	
	self.tblData.userInputEnabled 	:=_inEdit;
	if _inEdit then		
		self.btnCancelBase.enabled:=true;
		foreach idx in self.tblData.fixedColumns to self.tblData.columns do
			self.tblData.accessColumn(idx).inputType := Table.InputType_TextBox;	// ie 2
		endforeach;		
		// for each column that has been defined as read only
		// (ie input type of none) make sure the column is disabled.
		self.tblData.disableReadOnlyColumns();		// cnwrl1 20/11/2009 PAR 21009		
		//self.tblData.clearAllSelected();
		self.tblData.selectionType := CM_DataTable.SelectionType_None;
		
		row:=self.tblData.accessedRow.row;
		ediTI:= self.tblData.accessedRow.itemObject.CM_EDITrackedItem;
		if ediTI &lt;&gt; null then
			str:=self.tblData.accessCell(row,1).text &amp; Tab &amp; self.SOURCE_EDI &amp; Tab &amp; ediTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessCell(row,1).text:= str; 
			self.tblData.accessRow(row);
		endif;
		
	else
		self.tblData.selectionType 	:= CM_EntryTable.SelectionType_Row;
		self.frmError.visible:=false;
		self.frmData.height :=self.clientHeight - self.frmToolbar.clientHeight - self.staStatusBar.clientHeight;
		row:=self.tblData.accessedRow.row;
		ediTI:= self.tblData.accessedRow.itemObject.CM_EDITrackedItem;
		if ediTI &lt;&gt; null then
			reserveDetail:=ediTI.CM_EDIReleaseRequestTI.findReserveDetail();
			if reserveDetail = null then
				idx:= allEDITIs.indexOf(ediTI);
				if idx&lt;= allDBObjects.size then		// 17.8.2017 cnwma1 TFS #4596
					reserveDetail:=allDBObjects[idx].CM_ReserveDetail;
				endif;
			endif;
			self.showChangesEDITrackedItem(self.tblData,ediTI.CM_EDIReleaseRequestTI, reserveDetail);
			self.tblData.accessRow(row);
		endif;
		self.btnCancelBase.enabled:=false;
		self.doResize();
	endif;
	
	
epilog

end;</source>
        <Parameter name="_inEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExport" id="fa9da3c5-3cc8-4cb7-9da5-88bef5fd01ea">
        <source>doExport()protected;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	table	:CM_DataTable;
begin
	table := self.tblData;
	
	if table.rows &lt;= table.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, self.caption, table);
		return;
	endif;
	
	table.outputAsCSV(null);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doIgnoreEDIItem" id="1863814b-7afb-4f45-9d18-0d1d6d709011">
        <source>doIgnoreEDIItem()protected;
/*
Purpose;	Set status of selected EDI Tracked ITe to Will not be Processed

Date		Who		Reason
31 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	obj		:Object;
	coll 	:CM_EDITISet;
	result	:Integer;
begin
	create coll transient;

	foreach obj in self.tblData.allSelectedObjects do
		if not obj.isKindOf (CM_EDITrackedItem) then
			continue;
		endif;
		
		coll.add (obj.CM_EDITrackedItem);
	endforeach;
	
	while true do
		app.myTrxUA.trxEDIIgnoreEDITrackedItem (coll, app.myPassport);
		
		if not app.myPassport.trxCompletedOK() then
			result := app.showErrorWarningDialog( app.getErrorString(Road_exit), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
				result = IDOK then
				
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
		endif;

		break;
	endwhile;
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadDB" id="910898c0-5e44-4dbe-a14b-b8c06694e4d5">
        <updating/>
        <source>doLoadDB() updating;
/*

Date		Who		Reason
12 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
	ediAgent : CMUI_EDIAgent;
	obj 	: Object;
	allErrors : CM_ErrorSet;
	err : CM_Error;
begin
	
	//epr TFS 2606 10/3/17 multi select load and verify
	create allErrors transient;
	foreach obj in tblData.allSelectedObjects discreteLock do
			if not obj.isKindOf (CM_EDIReleaseRequestTI) then
				continue;
			endif;	
			//can load if already verified 
			if obj.CM_EDITrackedItem.status = CM_EDIFile.EDI_STATUS_VERIFIED then
				//do load
				obj.CM_EDIReleaseRequestTI.loadDB(false,app.myPassport);
				if app.myPassport.hasErrors then
					foreach err in app.myPassport.allErrors do 
						allErrors.add(err);
						err.removeFromPassport;					
					endforeach;				
				endif;
			endif;
	endforeach;
	
	app.myPassport.addErrorsFromSet(allErrors);
		
	if app.myPassport.hasErrors then
		self.tblErrors.clearAllData;
		create ediAgent transient;
		ediAgent.showVerifyErrors(null,self.tblErrors,false,app.myPassport);
	
		self.frmError.visible:=true;
		self.doResize();
	endif;
	
	
epilog
	delete ediAgent;
	delete ediAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="fd70787f-c15e-496b-a0d6-5c514a608743">
        <source>doNotableAdd(_object :Object)protected;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars

begin
	self.allNotableObjects.addNoDuplicates(_object, false);
	
	self.beginNotification(_object, Object_Update_Event, Response_Continuous, null);
	self.beginNotification(_object, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="0ed15c50-d8cd-4368-bec0-8fcf2207097a">
        <source>doNotableClear();
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars

begin
	self.endNotificationForSubscriber (self);
	self.allNotableObjects.clear;
epilog
	
end;
