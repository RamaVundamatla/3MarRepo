        <source>valSegregationMatrix(_segMatrixAgent : CMIF_SegregationMatrixAgent; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	29 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	matrixTrans			: CM_SegregationMatrixTrans;
begin
	foreach matrixTrans in _segMatrixAgent.allSegMatrixTransByRowCol do
		if matrixTrans.myPxySegregationRule &lt;&gt; null then
			matrixTrans.myPxySegregationRule.validateForUpdate();
		endif;
	endforeach;

end;


</source>
