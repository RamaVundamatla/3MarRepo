    <JadeMethod name="checkEntriesDict" id="d79bff9b-0aab-40fb-81f5-6041f25eaa8d">
        <source>checkEntriesDict();

vars
	commodity:CM_Commodity;
	object:Object;
begin
	if entries.size &lt;&gt; allCommodities.size then
		app.writeStatement( "Commodity size mismatch by " &amp; (entries.size - allCommodities.size).String);
	endif;
	foreach object in entries do
		commodity := object.CM_Commodity;
		if not allCommodities.includes(commodity) then
			app.writeStatement( "Commodity " &amp;  commodity.code &amp; " is not in old entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
	foreach commodity in allCommodities do
		if not entries.includes(commodity) then
			app.writeStatement( "Commodity " &amp;  commodity.code &amp; " is not in new entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="c0b85593-6a99-4ba0-a422-fbc87cdbacc3">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	commod  : CM_Commodity;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach commod in self.allCommodities do
		if tmpStr = null then
			tmpStr := commod.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; commod.code;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Commodities' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8eacb1ec-b143-4994-aa07-d2e7063f3812">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     28 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_NotAvailableForEntry then // PAR 10008
		return (self.isAvailableForEntry).String;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmptyCommodity" id="f86db18e-2ad5-4fc0-be39-01a162a9ac8b">
        <source>getEmptyCommodity() : CM_Commodity;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	comm : CM_Commodity;
begin
	comm := self.allCommodities.first;
	if comm &lt;&gt; null and comm.isEmpty then
		return comm;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="ba662c09-1e9f-4984-879c-e6b43acbece5">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.code &amp; Tab &amp; self.description;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="17a62158-1673-4f80-a1f7-8b37abc7c4f4">
        <source>getYAIdentifier(): String;

/*

Purpose:		Refer to superclass implementation.

Date			Who		Reason
26 August 2008	consw1	Initial creation

*/

vars

begin
	return self.code.toUpper();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasTemp" id="5089c596-4ffa-4bd7-a14f-2d30e1ea4c6a">
        <source>hasTemp() : Boolean;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	doesTemp : Boolean;
	aComm : CM_Commodity;
begin
	if self.allCommodities.isEmpty then
		doesTemp := false;
	else
		aComm := self.allCommodities.first;
		if aComm &lt;&gt; null then
			doesTemp := aComm.hasTemp;
		else
			doesTemp := false;
		endif;
	endif;
	return doesTemp;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEmptyCommodity" id="584f48c5-547f-47f8-8054-317cc619e071">
        <source>isEmptyCommodity() : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	comm : CM_Commodity;
begin
	comm := self.allCommodities.first;
	if comm &lt;&gt; null and comm.isEmpty then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEmptyCommodityForTerminal" id="e147f1e1-7290-4961-bc23-df27bf065ed6">
        <source>isEmptyCommodityForTerminal(_terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theMTCode	: String;
	theMTCommodity	: CM_Commodity;
begin

	if _terminal = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_terminal', null, null);
		return false;
	endif;

	theMTCode := _terminal.getDefaultEmptyCommodity();
	theMTCommodity := app.myRoot.allCommodities[theMTCode];
	if theMTCommodity &lt;&gt; null then
		return (self = theMTCommodity.myCommodityGroup);
	endif;

	return false;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="11d9a57f-8658-433c-bee1-98f5c16bf9ec">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     01 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	grp	: CM_CommodityGroup;
	completedOK		: Boolean;
		
begin
	grp := inheritMethod();
	
	self.allCommodities.copy(grp.allCommodities);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return grp;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete grp;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="30300bca-45dc-4fe4-8ae1-23c794d2278c">
        <updating/>
        <source>setForCreate(pProxyCommodityGroup:CM_CommodityGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin


	setForUpdate(pProxyCommodityGroup);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyCommodityGroup" type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="40395493-5b68-497c-a211-dbba25b1d111">
        <updating/>
        <source>setForUpdate(pProxyCommodityGroup:CM_CommodityGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	commodity	:	CM_Commodity;
begin
	self.code := pProxyCommodityGroup.code[1:4].trimBlanks;
	self.description := pProxyCommodityGroup.description[1:30].trimBlanks;
	self.colour		:= pProxyCommodityGroup.colour;
	self.reeferAlerts := pProxyCommodityGroup.reeferAlerts;
	self.timeAlert := pProxyCommodityGroup.timeAlert;
	self.timeMax := pProxyCommodityGroup.timeMax;
	self.timeReadings := pProxyCommodityGroup.timeReadings;
	self.isAvailableForEntry := pProxyCommodityGroup.isAvailableForEntry; // PAR 10008
	self.isSpecialStow := pProxyCommodityGroup.isSpecialStow;

//Clearing the collection and updating the collection from the proxy Commodity Group.
	self.allCommodities.clear;

//Update has to done from the commodity end.  
	foreach commodity in pProxyCommodityGroup.allCommodities do
		commodity.setMyCommodityGroup(self);
	endforeach;
	
	
end;</source>
        <Parameter name="pProxyCommodityGroup" type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="abec8c08-1c68-4271-adbb-fc19559bcfb7">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a17c564d-6684-400b-8ced-d4cec45e44f5">
        <updating/>
        <source>setProxy( pCode, pDescription 	: 	String;
          pColour 				:	Integer;
          pReeferAlerts			:	Boolean;
          pTimeAlert, pTimeMax	:	Integer; 
          pCommodityCol 		: 	CM_CommodityByCodeDict;
          _isSpecialStow,
          _availForEntry : Boolean) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode[1:4];
	self.description := pDescription[1:30];
	self.colour := pColour;
	self.myRoot	:= app.myRoot;
	self.reeferAlerts := pReeferAlerts;
	self.timeAlert := pTimeAlert;
	self.timeMax := pTimeMax;
	self.isAvailableForEntry := _availForEntry; // PAR 10008
	self.isSpecialStow := _isSpecialStow;
	
//Copy the commodity collection of the proxy.	
	self.allCommodities.clear;
	pCommodityCol.copy(self.allCommodities);
 end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pReeferAlerts" type="Boolean"/>
        <Parameter name="pTimeAlert" type="Integer"/>
        <Parameter name="pTimeMax" type="Integer"/>
        <Parameter name="pCommodityCol" type="CM_CommodityByCodeDict"/>
        <Parameter name="_isSpecialStow" type="Boolean"/>
        <Parameter name="_availForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsUsedInAttributePlan" id="0dd509ee-0e2b-4678-bf86-b92cc61ed112">
        <source>testIsUsedInAttributePlan();
//Test the attribute plans, make sure none are referencing us!
vars
	ap	:	CM_CargoTypeAttribPlan;
begin
	foreach ap in CM_CargoTypeAttribPlan.instances do
		if ap.commodityGroup = self then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_USED_IN_ATTRIB_PLAN, "Commodity Group code "&amp; code.trimRight, "Tracked Item Type "&amp; ap.id.trimRight, null, null);
			return;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="04910296-890b-419b-bdcc-09e0ead02b97">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
if app.myRoot.allCommodityGroups[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ccc3e362-c3c0-4e58-80a4-0e4547dfa971">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allCommodities.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Commodity", null, null);
	endif;
	
	if self.allCargoTypeAttribPlams.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Attribute Plan", null, null);
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="52f9dcff-672a-4246-bb50-350910fb0164">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'CommodityGroup Code', null, null);
		app.raiseCMException(Input_required_field_comGrpCod, null, null); // cnwdb2	PAR 35364
		
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'CommodityGroup Description', null, null);
		app.raiseCMException(Input_required_field_ComGrpDes, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
