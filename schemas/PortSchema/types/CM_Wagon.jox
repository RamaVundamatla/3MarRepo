    <JadeMethod name="cleanupAllJobsForRelease" id="14fbcd9e-e76a-4507-ac9e-5f2f0068927c">
        <source>cleanupAllJobsForRelease(_passport : CM_Passport input);
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars
	newJob,
	job						: CM_Job;
	tiArray					: CM_TIArray;
	ti						: CM_TrackedItem;
begin
	exclusiveLock(self);
	
	foreach job in self.allRailJobs do
		exclusiveLock(job);
		
		if not job.isRelease() then
			// Cleanup receipt job first
			if job.status = JOB_COMPLETE or job.isTransitJob then
				job.erase(NORMAL_ERASE);
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException1(VB_UNACTIONED_RECEIPT, job.jobId, null, null);
				return;
			endif;
			
		elseif job.status = JOB_COMPLETE then
			// Sets TI release data, releases TIs offsite and erases job if no entries remain
			self.cleanupJobForRelease(job, _passport);
		elseif job.status = JOB_PART_COMPLETE then // PAR 21441

			// Split off the unactioned part and try again
			newJob := null;
		//	job.splitUnactionedRequests(newJob,null,null,null,null);
			job.splitUnactionedRequests(newJob,null,null,null,null,null);
			
			
			if job.status = JOB_COMPLETE then
				// Sets TI release data, releases TIs offsite and erases job if no entries remain
				self.cleanupJobForRelease(job, _passport);
			//th2 build priority obsolete
			//elseif job.status = JOB_UNACTIONED and
			//	app.getMyTerminal.getConfig(RailUseBuildPriority).Boolean then
				// return the job to build priority for redistribution
			//	job.CM_RailJob.returnJobToBuildPriority(null, _passport);				
			
			else // Must be part complete then. Cannot clear rake there is a part complete job.
				app.setContinueCMExceptions(false);
				app.raiseCMException1(VB_UNACTIONED_RELEASE, job.jobId &amp; ' (' &amp; app.getErrorString(CM_Status) &amp; ': ' &amp; job.statusString &amp; ')', null, null);
				return;
			endif;
			
			if newJob &lt;&gt; null then
				newJob.causeTerminalEvent(newJob.Event_Mode_Create);
			endif;
		endif;
	endforeach;
	
	//th2 for PAR 14602 - move any cargo on the wagon not associated with a rail job offsite
	create tiArray transient;
//	self.getAllTrackedItems(false, tiArray, false);
	self.getAllTrackedItems(false, tiArray, true);	//09 May 2013	NDL	Par 31537 - Cargo worked off and back on the same wagon was missed.
	
	foreach ti in tiArray do
		if not ti.isOffSite then  //cnwrd1 par 28436 11.10.2011
			//ti.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,  false,null,null, _passport);		// TFS 2651
			ti.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,  false,null,null,null,null,null, _passport);	// TFS 2651
		endif;
	endforeach;

epilog
	delete tiArray;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanupJobForRelease" id="60159921-2cdf-4505-a91f-748e8f9f38dc">
        <source>cleanupJobForRelease(_theJob : CM_Job input; _passport : CM_Passport input)protected;
//-----------------------------------------
//Created: January 2005 By: cnwgd1
//-----------------------------------------
//Date					Who		Reason
//03 October 2023		jlizm1	Initial creation TFS 59730 Kiosk Load Sequence
vars
	wle 	: CM_WorkListEntry;
	wles	: CM_WLEArray;
	iter 	: Iterator;
	ti		: CM_TrackedItem;
begin
	if _theJob = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Null_Job));
		return;
	endif;
	
	if _theJob.status &lt;&gt; JOB_COMPLETE then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Job with invalid status for release'); //- cnwmd1, CCMS 1067, Par 19710
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(With_invalid_status_release)); //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	// Sets TI release data, releases TIs offsite and erases _theJob
	create wles transient;
	_theJob.workListEntries.copy(wles);
	iter := wles.createIterator();
	
	while iter.next(wle) do
		//Only process entries that are on this wagon
		ti := wle.myTrackedItem; 
		if ti = null then
			//_theJob is complete, just erase the wle
			wle.erase(NORMAL_ERASE);
			continue;
		endif;
		if ti.getMyWagon = self then
			wle.departureProcess(_passport);
			//ti is going offsite NOW
			//ti.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,  false, null,null,_passport);		// TFS 2651
			//ti.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,  false, null,null,null,null,null,_passport);	// TFS 2651
			ti.moveToLocation(null, _theJob, null, null, REAL_MODE, true, false, false, false, false,  false, null,null,null,null,null,_passport);	// ### TFS 62859 (62860) 10Mar2024 NAVPW1
		endif;
							
	endwhile;

	if _theJob.workListEntries.isEmpty then
		//All entries have been processed and erased so we can erase the job as well.
		_theJob.departureProcess(_passport);
	else
		//There must be an entry for this job that is on a wagon on another part of the rail area
		//that is not been cleared as part of this clear rake process. Don't erase the job
		_theJob.causeTerminalEvent(_theJob.Event_Mode_Update);				
	endif;

epilog
	delete iter;
	delete wles;
	
end;</source>
        <access>protected</access>
        <Parameter name="_theJob" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanupUnactionedWLEs" id="4e9d971a-3716-41ad-93c9-981d718972a4">
        <source>cleanupUnactionedWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 November 2022	jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons

*/

vars
	
	iter : Iterator;
	lc : CM_LocationsController;
	wc : CM_WagonController;
	delWles : CM_WLEArray;
	rtQueueEntry : CM_RTQueueEntry;
	wle : CM_WorkListEntry;
	jobs : CM_JobArray;
	job : CM_Job;
	invalid : Boolean;
	
begin

	create delWles transient;
	create jobs transient;
	iter := self.allLocationsControllers.createIterator;
	
	on Exception do app.handleDeletedObject( exception, wle, invalid );
	while iter.next(lc) do
		
		if not lc.isWagon then	
			continue;
		endif;
		wc := lc.CM_WagonController;
		
		foreach wle in wc.allRailWLELoad do
			invalid := false;
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			
			if invalid then
				continue;
			endif;
			
			rtQueueEntry := wle.allRTQueueEntries.first;
			if rtQueueEntry &lt;&gt; null then
				app.myUtilityDA.utlDeleteQueueEntry(rtQueueEntry, false, null, app.myPassport);
			endif;
			
			delWles.add( wle );
			jobs.addExclusive( wle.job );
		endforeach;
	endwhile;
	
	foreach wle in delWles do
		wle.erase(NORMAL_ERASE);
	endforeach;
	
	foreach job in jobs do
		job.rebuildStatus();
	endforeach;
	
epilog

	delete delWles;
	delete jobs;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="confirmWagonInwards" id="067fdb96-90b3-47af-9d94-69f31a87d7f5">
        <updating/>
        <source>confirmWagonInwards( _moveController : CMIF_WagonMoveController; _autoPlan : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Mar 2024	navpw1		TFS: 62857 (62858) - Changed signature of createRailReceiveJob
// ---------------------------------------------------------------------------
vars
	iter 	: Iterator;
	ti 		: CM_TrackedItem;
	allTIs	: CM_TIArray;
	railJob : CM_RailJob;
	term	: CM_Terminal;
	wagControl : CMIF_WagonMoveController;
	iHaveCargo : Boolean;
	checkTI : CM_TrackedItem;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;

	term := self.getTerminal(); // PAR 21182
	
	create wagControl transient; // PAR 20384
	wagControl.setEffectiveTimeStampOverride( effectiveDate );
	
	if _moveController &lt;&gt; null and _moveController.retrospectiveDT.isValid then
		wagControl.retrospectiveDT := _moveController.retrospectiveDT;
	endif;
	
	create allTIs transient;
	self.getAllTrackedItems(true, allTIs, false);
	self.createTransaction(effectiveDate, EVT_WagonConfirmed, self.myRailLine, self.myRailLine.allWagons.indexOf(self), null, true, null, null, null);
	
	iHaveCargo := not allTIs.isEmpty;
	
	if iHaveCargo then // 25980
		railJob := self.createRailReceiveJob(_passport, wagControl.retrospectiveDT);
		//th2 31/05/2007 for PAR14154 - may be warnings that should be continuable raised here
		if not app.myPassport.checkValidation then
			return;
		endif;
		
		if railJob = null then
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Railjob_null_contact_develop));	//+ cnwmd1, CCMS 1067, Par 19710
			return;
		endif;
		railJob.causeTerminalEvent(railJob.Event_Mode_Create);	// PAR 21740		made UPDATE		
	endif;
	
	iter  := allTIs.createIterator;
		
	while iter.back(ti) do
	
		if ( not ti.canMergeBreakBulk ) then	//12 Sep 2013	NDL	Par 32479 - multi pre-note break bulk on train
			//08 Mar 2013	NDL	Par 31181
			checkTI := ti.myTerminal.allOnsiteTIsByCargoTypeId[ti.cargoType, ti.id];
			if checkTI &lt;&gt; null and checkTI &lt;&gt; ti then
				app.raiseCMException1(ERR_ALREADY_ONSITE, ti.id, ETRow_Id, null);
			endif;
		endif;
	
		if ti.checkNotRecvdForInwardsWagon(self) then	// 07/12/2010 cnwmh5 #26452
			app.raiseCMException1(ERR_Cargo_Received, ti.id, null, null);
		endif;
		ti.confirmWagon( wagControl, TI_STATE_NORMAL, _passport);
		ti.matchTBA();
		//epr par 34466 7/7/14 new quantity/weight param
		railJob.addJobRequest(ti, true, null,null, _passport);		
		if _autoPlan then 
			if not ti.isInTransitOnShip then	//01 Nov 2012	NDL	30478
				ti.autoPlan(QUEUE_MODE, railJob, null, null, _passport);
			endif;
		endif;
	endwhile;

	self.confirmed := true;
	app.myEventManager.createSingleObjInfoNoteEvt(self, term.getTerminalEvent(Wagon_Update_Event), self);			// PAR 21740		made UPDATE		
	// 25980(move this up /\ /\ /\                  railJob.causeTerminalEvent(railJob.Event_Mode_Create);	// PAR 21740		made UPDATE		
	
	self.arrivalProcess(); // PAR 19710
	
	self.setCargoRestrictionsFromMaster();	//07 Feb 2014	NDL	Par 33439 / CCMS2311
	
	if self.myTrainOutwards &lt;&gt; null then
		// PAR 26445 This wagon was inward on train A but is being edited to be outward on train B.
		 // 				Train B has a jobsheet of release jobs, the jobs need to be moved to the rail area job sheet so that they can be worked.
		if self.confirmed // INWARD
		and self.myRailLine &lt;&gt; null 
		and self.myTrainOutwards.myJobSheet &lt;&gt; null // train job sheet is only used for planning release jobs
		and not self.myTrainOutwards.myJobSheet.allJobsByOrder.isEmpty() then // still has release jobs
		 
			create wagControl transient; // PAR 26445
			wagControl.myTargetRailLine := self.myRailLine;
			wagControl.allWagons.add(self);
			self.myTrainOutwards.moveOutwardJobsToRail(wagControl, app.myPassport);
		endif;
	endif;

	// ### TFS BUG 58951 19JUL2023 NAVAB1
	if self.confirmed
	and self.allPlannedFutureMoves.isNotEmpty() then
		delete wagControl;
		create wagControl transient;
		wagControl.allWagons.add(self);
		wagControl.setMoveMode(UNPLAN_MODE);
		app.myUtilityUA.utlMoveWagons(wagControl, app.myPassport);
	endif;


epilog
	delete allTIs;	//09 Nov 2009	NDL	Par 21519
	delete iter;
	delete wagControl; // PAR 20384
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_autoPlan" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="confirmWagonOutwards" id="8ed1d162-3cac-446a-b7ea-4d009c96a361">
        <updating/>
        <source>confirmWagonOutwards( _moveController : CMIF_WagonMoveController; _passport : CM_Passport input) updating;
/*
----------  ----------  --------------------------------------------------
Created:	01 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
09/10/2017	jlgmd1		Fixed 1090 when the train no longer exists
----------  ----------  --------------------------------------------------
*/
vars

	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837
	wagControl : CMIF_WagonMoveController;

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;

	//09/10/2017 MPD
	if self.myTrainOutwards = null then
		app.raiseCMException(Confirm_wagon_out_NoTrain, null, null);
	endif;

	//25 Feb 2009	NDL Par 22469
	if self.myTrainInwards.isNullTrain then
		app.raiseCMException2(Confirm_wagon_out_NullTrain, self.id, self.myTrainInwards.getCodeDateString, null, null);
	elseif self.myTrainOutwards.isNullTrain then
		app.raiseCMException2(Confirm_wagon_out_NullTrain, self.id, self.myTrainOutwards.getCodeDateString, null, null);
	endif;
	
	self.confirmedOutwards := true;
	
	//19 Jan 2017	NDL	TFS 3198/2877
	self.createTransaction( effectiveDate, EVT_WagonConfirmedOut, self.myRailLine, self.myRailLine.allWagons.indexOf(self), null, false, null, null, null);
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.getTerminal().getTerminalEvent(Wagon_Update_Event), self);  // PAR 21182 // PAR 21740			made UPDATE

	// ### TFS BUG 58951 19JUL2023 NAVAB1
	if self.confirmedOutwards
	and self.allPlannedFutureMoves.isNotEmpty() then
		delete wagControl;
		create wagControl transient;
		wagControl.allWagons.add(self);
		wagControl.setMoveMode(UNPLAN_MODE);
		app.myUtilityUA.utlMoveWagons(wagControl, app.myPassport);
	endif;

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertToNewStr_PrenoteTI" id="8e3af2f2-d6a5-454b-b3a0-00c523e68cba">
        <updating/>
        <source>convertToNewStr_PrenoteTI(_ti : CM_TrackedItem input) updating, protected;
//--------------------------------------------------
// Created:	02 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	toLocn : CM_WagonController;
	currentWagon : CM_Wagon;
begin

	if _ti.state &lt;&gt; TI_STATE_NOTIFIED then
		return;
	endif;
				
	//Move TI off old wagon if required
	currentWagon := _ti.getMyWagon();
	if currentWagon &lt;&gt; null then
		if currentWagon.confirmed then
			//app.raiseCMException2(ERR_TI_WAGON_ON_SITE, self.id, self.wagon, null, null);
			return;
		endif;
	endif;

	//toLocn := self.getNextFreeWagonController(_ti, REAL_MODE, null, false);
	toLocn := self.getNextFreeWagonController(_ti, REAL_MODE, null, null, false);//10 May 2010	NDL Par 24064
	
	if toLocn &lt;&gt; null then
		// remove ti from currentWagon and/or shift the _newWagon
		toLocn.setController(_ti, false, false, false, app.myPassport);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertToNewStr_addTrackedItem" id="d83475f0-df56-4139-8bcb-d2bf5dfa8e72">
        <source>convertToNewStr_addTrackedItem(_ti: CM_TrackedItem io; _pos: Integer) protected;
// add a ti on a wagon at a spefic position
vars
	wagonController: CM_WagonController;
	count, lengthInUnits: Real;
begin
	if _ti.isKindOf(CM_Container) then
		lengthInUnits := _ti.CM_Container.getLengthInUnits;
	elseif _ti.isKindOf(CM_ClipOnUnit) then
		lengthInUnits := _ti.CM_ClipOnUnit.getLengthInUnits;
	elseif _ti.isKindOf(CM_Generator) then
		lengthInUnits := _ti.CM_Generator.getLengthInUnits;
	endif;
	foreach wagonController in allLocationsControllersArray do
		count := count + 1;
		if count = _pos then
			wagonController.setController(_ti, false, false, false, app.myPassport);
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="86549012-fe46-4f35-be87-80b5b954c12b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     29 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	msg : String;

begin

	//15 Mar 2013	NDl	Par 31278
/*	if not self.isBoxcar and not self.isFlatcar then
		msg := app.getCallingMethod(3);
		app.raiseCMException1(Attem_creat_insta_cm_wa_shoul_,msg,null,null);
	endif;
*/
	self.dateTime := app.actualTimeServer;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createNewTIFromHandHeld" id="1d1253ca-0b99-4d7f-adc8-90adf02ec3de">
        <source>createNewTIFromHandHeld(	_id : String;
							_firstLocationsController : CM_LocationsController;
							_isoText : String;
							_callingClass : Class;
							_mess : String output
							):CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2017	cnwndl1	Initial creation	TFS 2314

*/

vars

	ti : CM_TrackedItem;
	id : String;
	cargoMustBePrenoted : Boolean;
	pxyTI : CM_TrackedItem;
	isoType : CM_ISOType;
	wagon : CM_Wagon;
	moveController : CMIF_MoveController;
	cmifID : CMIF_IDConversion;
	invalid : Boolean;
	
begin
	
	create cmifID transient;
	cmifID.scannedValue := _id;
	cmifID.myTerminal := self.myTerminal;
	cmifID.cargoType := TI_CargoType_Container;
	cmifID.callerName := _callingClass.name;	
	id := app.convertScannedCargoId( null, null, false, cmifID );	
	
	if id = null then
		_mess := app.getErrorString( ERR_INVALID_TI_ID );
		return null;
	endif;
	
	// look to see if we can find an onsite container with this id.
	ti := self.myTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NORMAL, null, false); 
	if ti = null then
		// ok how about a pre note container.
		ti := self.myTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NOTIFIED, null, false);
	endif;
	
	if ti = null then
		// ok how about an on site generator.
		ti := self.myTerminal.lookupTrackedItem(id, TI_CargoType_Generator, TI_STATE_NORMAL, null, false);
	endif;
	if ti = null then
		// ok how about a pre note generator.
		ti := self.myTerminal.lookupTrackedItem(id, TI_CargoType_Generator, TI_STATE_NOTIFIED, null, false);
	endif;
	
	//look up by alternative id 29/4/22 jlier1 TFS 53249
	if ti = null then
		ti:=self.myTerminal.allOnsiteTIsByAlternativeId[id];
		if ti &lt;&gt; null and ( ti.cargoType &lt;&gt; TI_CargoType_Container and ti.cargoType &lt;&gt;  TI_CargoType_Generator) then
			ti:=null;
		endif;
	endif;
	//look up by alternative id 29/4/22 jlier1 TFS 53249
	if ti = null then
		//look up by alternative id 29/4/22 jlier1 TFS 53249
		ti:=self.myTerminal.allNotifiedTIsByAlternativeId[id];
		if ti &lt;&gt; null and  ( ti.cargoType &lt;&gt; TI_CargoType_Container and ti.cargoType &lt;&gt;  TI_CargoType_Generator) then
			ti:=null;
		endif;
	endif;
	
	
	
	if _firstLocationsController = null then
		_mess := app.getErrorString(Please_select_positionPOP);
		return null;
	endif;
	
	
	if ti &lt;&gt; null then
		if ti &lt;&gt; null and ti.myPrimaryActualLocation = _firstLocationsController then
			//already here cool
			return ti;
		endif;
		
		if not self.isThereRoomForTi(_firstLocationsController.CM_WagonController, ti) then
			_mess := app.getErrorString2(No_room_start_position, ti.id, _firstLocationsController.CM_WagonController.getLabel );
			return null;
		endif;
		
		// we found an existing TI just move it
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(_firstLocationsController);
		moveController.isSystemMove := true;
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if (not app.myPassport.noErrors) then
			_mess := app.getErrorString(ERR_MOVE_RT_ERR);
			return null;
		endif;
		
	else
		//no existing ti , have to create and move it.
		cargoMustBePrenoted := self.myTerminal.getConfig(RailHHCargoMustPrenote).Boolean;
		if cargoMustBePrenoted and ti = null then
			_mess := app.getErrorString(Inward_cargo_must_be_prenoted);
			return null;
		endif;
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		
		// OK we are going to create one...
		if _isoText = "GEN" then
			// creating a generator
			create pxyTI as CM_Generator transient;	
			pxyTI.setPxyFromDefaultTI( self.myTerminal, TI_CargoType_Generator, id, null, null); 
			pxyTI.CM_Generator.setMyGeneratorTypeDefault(app.myPassport);
			pxyTI.setReceiptTransportMode(TI_TRANSMODE_RAIL);
			
			_mess := app.myPassport.getAllErrorsWarningsAsString;
			if _mess &lt;&gt; null then
				return null;
			endif;
		
		else
			isoType := app.myRoot.allISOTypes[_isoText];
			if isoType = null then
				_mess := app.getErrorString3( ERR_INVALID_ISOTYPE, _isoText, null, id );
				return null;
			endif;
			
			create pxyTI as CM_Container transient;	
			pxyTI.setPxyFromDefaultTI( self.myTerminal, TI_CargoType_Container, id, null, null); 
			pxyTI.CM_Container.zSetPxyISOType(_isoText);
			pxyTI.setSizeAndTypeAttibutesYA(isoType);
			pxyTI.setReceiptTransportMode(TI_TRANSMODE_RAIL);
			
			if not self.isThereRoomForTi(_firstLocationsController.CM_WagonController, pxyTI) then
				_mess := app.getErrorString2(No_room_start_position, _isoText, _firstLocationsController.CM_WagonController.getLabel );
				return null;
			endif;
	
		endif;
		
		create moveController transient;
		moveController.setMyToPrimaryLocation(_firstLocationsController);
		
		app.myPassport.clearErrorsWarnings;
		app.myPassport.setWarningsIgnored(true);
		
		on Exception do app.handleDeletedObject( exception, pxyTI, invalid );
		
		while true do
			app.myTrxCA.trxCreateTIWithMove(pxyTI, ti, moveController, app.myPassport);
	
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings;
				_mess := null;
				break;
			elseif app.myPassport.hasErrors then
				_mess := app.myPassport.getAllErrorsWarningsAsString;
				return null;
			else
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endwhile;
	
	endif;
	
	return ti;
		
epilog

	delete pxyTI;
	delete cmifID;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_firstLocationsController" type="CM_LocationsController"/>
        <Parameter name="_isoText" type="String"/>
        <Parameter name="_callingClass" type="Class"/>
        <Parameter name="_mess" type="String" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createPxyDamageInstance" id="e4036244-88e8-40e6-b3a0-b4fc55f3f7b7">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_DamageDetails::createPxyDamageInstance"/>
        </interfaceImplements>
        <source>createPxyDamageInstance(	_code : CM_DamageDefinitionCode;
							_position : CM_DamagePosition;
							_remarks : String;
							_isNew : Boolean;
							_quantity : Integer;
							//_severity : Integer;
							//_repaired : Boolean;
							//_locationStr : String	// 01 Mar 2016	TFS 1593 The Location Controller id
							_severity : CM_DamageSeverity;	// 11.07.2022 navak20 TFS 53862
							_locationStr : String;	// 01 Mar 2016	TFS 1593 The Location Controller id
							_damagePlace	: CM_DamagePlace;	// July 1, 2022 navak20 TFS 53862
							_damageParty	: CM_DamageParty;	// July 1, 2022 navak20 TFS 53862
							_damageReason	: CM_DamageReason;	// July 1, 2022 navak20 TFS 53862
							_repairReason	: CM_RepairReason;	// July 1, 2022 navak20 TFS 53862
							_damageSize		: Decimal;	// July 1, 2022 navak20 TFS 53862
							_damageDateTime	: TimeStamp;		// July 1, 2022 navak20 TFS 53862
							_status			: Integer;	// July 1, 2022 navak20 TFS 53862
							_repairRemarks	: String;		// July 1, 2022 navak20 TFS 53862	
							_repairedDateTime : TimeStamp	// July 1, 2022 navak20 TFS 53862
							) : CM_DamageInstance;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwer1	Initial creation

*/

vars
	damageInstance		: CM_DamageInstance;
begin
	
	
	create damageInstance transient;
	damageInstance.setProxy(	null, 
								null,
								_code, 
								_position,
								_remarks,
								_isNew,
								_quantity,
								_severity,
								//_repaired,	// July 1, 2022 navak20 TFS 53862
								null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
								_damagePlace,	// July 1, 2022 navak20 TFS 53862
								_damageParty,	// July 1, 2022 navak20 TFS 53862
								_damageReason,	// July 1, 2022 navak20 TFS 53862
								_repairReason,	// July 1, 2022 navak20 TFS 53862
								_damageSize,	// July 1, 2022 navak20 TFS 53862
								_damageDateTime,	// July 1, 2022 navak20 TFS 53862
								_status,		// July 1, 2022 navak20 TFS 53862
								_repairRemarks,	// July 1, 2022 navak20 TFS 53862
								_repairedDateTime	// July 1, 2022 navak20 TFS 53862
								);
	if self.isTransient  then
		damageInstance.setMySubject(self);
	endif;
	
	return damageInstance;
epilog

end;</source>
        <Parameter name="_code" type="CM_DamageDefinitionCode"/>
        <Parameter name="_position" type="CM_DamagePosition"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_isNew" type="Boolean"/>
