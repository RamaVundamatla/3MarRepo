    <JadeMethod name="getXMLSettingsForSave" id="6564de1f-013a-48b8-8638-a1b514c5820a">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
	hideMacro : Boolean;
begin
	hideMacro :=  (self.mnuContextHide.caption = self.MNU_MACRO_SHOW);
	

	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML("HM",hideMacro.Integer.String);
	theXML := theXML &amp; self.tblData.getXmlStrForColumns(true);
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="be05ef77-fc1d-4399-8faf-9bd1165fbdcd">
        <source>getXMLSettingsForSetup();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	hideM : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName("HM");
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	
 	if hideM then
 		self.splMain.hideRightControl(true);
 		self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
 	endif;
 

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="46bccc08-5c2e-4f2f-9586-ff56f449a516">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.useTableInfo := true;
	self.useTableSorting := true;
	inheritMethod();

//	self.addToolbarControls();

	//self.setCurrentBank();	35872 not needed now
	self.setNavigatorHeading(self.caption);
	self.initTableData(ETDef_InvAuditDataTable);

	self.btnPrint.bubbleHelp := app.getErrorString(INV_Print);
	self.mnuContextTable.visible := true;
	self.mnuContextTable.caption := app.getErrorString(INV_Audit_Review);
	self.setContextMenus();
	self.usesQueryFrame := false;

	if self.mode = 0 then
		self.mode := Mode_Unqualified;
		self.btnQueryUnQual.myToolbarButton.drawButtonDown();
	elseif self.mode = Mode_Unqualified then
		self.btnQueryUnQual.click(self.btnQueryUnQual);
	elseif self.mode = Mode_Qualified then
		self.btnQueryQual.click(self.btnQueryQual);
	endif;
	
	if self.myCurrentInvoice &lt;&gt; null 
	or self.myCurrentRate &lt;&gt; null
	or self.myCurrentRateEntry &lt;&gt; null
	or self.myCurrentInvoiceLine &lt;&gt; null
	or self.myCurrentCashPayment &lt;&gt; null
	or self.myCurrentCashReceipt &lt;&gt; null
	or self.myCurrentService &lt;&gt; null
	then
		self.doQuery();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
