    <JadeMethod name="showHideToolbars" id="6526753e-9f05-4077-b696-6364f095e14f">
        <updating/>
        <source>showHideToolbars(_hide: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin


	if _hide then
		self.frmToolbar.visible := false;
		self.frmToolbar2.visible := false;
	else

		// need to do this to get toolbars correct
		self.frmToolbar2.alignContainer := Frame.AlignContainer_None; 
		self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 
		self.frmToolbar2.top := self.frmToolbar.height;
		self.frmToolbar2.alignContainer := Frame.AlignContainer_Top; 

		self.frmToolbar.visible := true;
		self.frmToolbar2.visible := true;

	endif;

	self.doResize();
end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHoldSelector" id="2edae524-9d72-4af7-bb37-7206d4931eb0">
        <updating/>
        <source>showHoldSelector(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	frame : CMUI_MoveableFrame;
begin
	frame := self.frmSelectVoyage; 
	
	if _mode = self.SelectModeHold then
		self.msgHolds.availableHeading := 'Available Holds';
		self.msgHolds.selectedHeading := 'Selected Holds';
	elseif _mode = self.SelectModeMulti then
		self.msgHolds.availableHeading := 'Available Bays';
		self.msgHolds.selectedHeading := 'Selected Bays';
	else
		return;
	endif;

	frame.centreWindow();
	frame.cnEcResizeContents();
	self.btnSelectVoyOK.bubbleHelp := "Show Selected Voyage";
	frame.visible := true;
	frame.zOrder(1);
	self.cmbVoyage.setFocus();

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showMagnifyFrame" id="5b1a7a2c-80d3-4e15-a718-e0b328479c51">
        <source>showMagnifyFrame();
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.frmMagnify.visible then
		self.frmMagnify.visible := false;
	else
		self.frmMagnify.zOrder(1);
		self.frmMagnify.autoRedraw := true;
		self.frmMagnify.clearGraphics();
		self.frmMagnify.drawPictureAt(self.picMagnify.picture,0,0);
		self.frmMagnify.transparent := true;
		
		self.frmMagnify.myDrawingController := self.myBayDrawingController;
		self.frmMagnify.parent := self;
		self.frmMagnify.width :=200; //230; //355;
		self.frmMagnify.height := 200; //350; //355;
		self.frmMagnify.centreHorizontallyInParent();
		self.frmMagnify.centreVerticallyInParent();
		self.frmMagnifyDraw.visible := false;
		self.frmMagnify.setFrame(self.frmMagnifyDraw);
		self.frmMagnify.setFrameOverlay(self.frmMagnifyOver);
	self.frmMagnify.bevelInnerWidth := 0;
	self.frmMagnify.bevelOuterWidth := 0;
	self.frmMagnify.borderStyle := Frame.BorderStyle_None;
	self.frmMagnify.boundaryBrush := 0;
	self.frmMagnify.boundaryWidth := 0;
	self.frmMagnify.caption := null;

		self.frmMagnify.visible := true;
		self.frmMagnify.move(self.frmMagnify.left + 10, self.frmMagnify.top + 10, self.frmMagnify.clientWidth, self.frmMagnify.clientHeight);


	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMessageForBigUpdate" id="6ce4439b-b4c7-4102-a53e-fa3bfc283ef1">
        <source>showMessageForBigUpdate(_visibleNow : Boolean; _stringOne : String);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		call back from SDF::doEventRefreshVoyageArea
// ---------------------------------------------------------------------------
vars

begin
	self.frmModalDialog.visible := _visibleNow;
	
	if not _visibleNow then
		return;
	endif;
	
	self.lblModalInfo.visible := true;
	self.lblModalMessage.caption := _stringOne &amp; "Voyage - " &amp; self.myCurrentVoyage.code.trimBlanks;
	self.frmModalDialog.refreshNow();
	self.lblModalInfo.refreshNow();

	self.lblModalInfo.caption := null;

	self.lblModalInfo.refreshNow();

end;</source>
        <Parameter name="_visibleNow" type="Boolean"/>
        <Parameter name="_stringOne" type="String"/>
    </JadeMethod>
    <JadeMethod name="showPreferences" id="bc9d422b-95cb-4704-b557-9aaa50a7322f">
        <updating/>
        <source>showPreferences() updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpConfig	: CMIF_Config; //UserVoyagePlanning;
	entTableDef	: EntTableDef;
begin

	tmpConfig := self.myConfig;
	// reload data to get latest copy
	tmpConfig.setFromPersistentData(app.getMyUser);

	entTableDef := app.myController.getEntTableDef(ETDef_UserVoyagePlanning);
	self.tblPreferences.setEntTableDef(entTableDef, null, null);

	self.tblPreferences.setTableFromObject(tmpConfig, 'setTblPreferFromObjSpecial');

	inheritMethod();
	
	
	self.frmPreferences.height := 260;
	self.frmPreferences.width := 400;
	self.tblPreferences.height := 210;
	self.tblPreferences.width := 380;
	self.btnPreferSave.top := self.tblPreferences.top + self.tblPreferences.height + 5;
	self.btnPreferCancel.top := self.btnPreferSave.top;
	
	self.btnPreferCancel.left := self.frmPreferences.width - self.btnPreferCancel.width - 20;
	self.btnPreferSave.left := btnPreferCancel.left - 10 - btnPreferSave.width;
	self.tblPreferences.accessColumn(1).width := 300;
	self.tblPreferences.accessColumn(2).width := 80;
end;</source>
    </JadeMethod>
    <JadeMethod name="showPrintFrame" id="630e5f3a-3210-431b-a4e4-19159de7bcc3">
        <source>showPrintFrame(_top : Integer; _left : Integer) ;
// ---------------------------------------------------------------------------
// Created:     12 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	msg			: String;
	theTop , theLeft : Integer;
begin
	if self.frmPrintConfirm.visible then
		return;
	endif;
	
	if _top = 0 then
		theTop := (self.frmToolbar2.top +  self.frmToolbar2.height + 1).Integer;
		theLeft := 100;
	else
		theTop := _top;
		theLeft := _left;
	endif;
	self.frmPrintConfirm.visible := true;

	self.frmPrintConfirm.zOrder(1);
	self.frmPrintConfirm.top := theTop;
	self.frmPrintConfirm.left := theLeft;
	self.lblPrintProgress.caption := null;
	
	self.grpPrintWorked.enabled := self.chkPrintWorked.value;	//09 Feb 2018	NDL	TFS 36914
	
	if self.myCurrentVoyage.useVoyageAllocations 
	and self.myCurrentVoyage.isUsingCriteriaType(YACriteriaType_CommodityGroup) then
		self.grpPrintWorkedColour.enabled := self.chkPrintWorked.value;
	else
		self.frmPrintWorked.height := 95;
		self.grpPrintWorkedColour.visible := false;
		self.optPrintDischPort.value := true;
		self.btnPrintPrint.top := self.frmPrintWorked.top + self.frmPrintWorked.height;
		self.btnPrintCancel.top := self.btnPrintPrint.top ;
		self.frmPrintConfirm.height := 300;
	endif;
	
	
end;</source>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="_left" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showPrintScanPlan" id="5ec9baf9-6e1f-40c8-b78f-6d888bff7f73">
        <source>showPrintScanPlan();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	selectedBays : CM_BayVoyageByOrdinalBayDict;

begin

	self.myAssistant.showPrintScanPlan(	self, 
										self.myCurrentVoyage,
										self.allSelectedHolds,
										self.allSelectedBays,
										self.displayMode,
										self.myBayDrawingController.viewMode
										);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showRequestLinker" id="a85629e4-c38b-4e64-b285-589f0a9d2302">
        <updating/>
        <source>showRequestLinker(_linkMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	theForm : Form;
	theLeftRequests: CM_RequestArray;
	tmpSlotController	: CM_LocationsController;
	aRequest : CM_Request;
	tmpObj		: Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	create theLeftRequests transient;

	foreach tmpObj in self.myBayDrawingController.allSelectedObjects do
		if (not tmpObj.isKindOf(CM_SlotController)) then
			continue;
		endif;
		tmpSlotController := tmpObj.CM_SlotController;		
		
		aRequest := null;
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			aRequest := tmpSlotController.getRequest(false); // PAR 28968 mySlotRequestDischarge;
		else
			aRequest := tmpSlotController.getRequest(true); // PAR 28968 mySlotRequestLoad;
		endif;
		//13/07/2010 cnwdz2 24599
		if aRequest = null then
			continue;
		endif;
		
		if aRequest.getMoveType() &lt;&gt; DLR_MOVETYPE and aRequest.getMoveType() &lt;&gt; SOB_MOVETYPE then
			aRequest := null;
		endif;
		if aRequest &lt;&gt; null then
			theLeftRequests.add(aRequest);
		endif;
	endforeach;

	// Now create the form
	theForm := app.getForm(SHP_LinkSlotRequestsForm.name);
	if theForm = null then
		create theForm as SHP_LinkSlotRequestsForm;
	endif;

	theForm.SHP_LinkSlotRequestsForm.myTerminal := self.myTerminal;
	theForm.SHP_LinkSlotRequestsForm.magRequests.formDisplayEntryMethodName := "displayStuff";
	theForm.SHP_LinkSlotRequestsForm.myVoyage := self.myCurrentVoyage;
	
	// pass through and validate the collection of requests
	if theForm.SHP_LinkSlotRequestsForm.setCollections(theLeftRequests, _linkMode) then
		theForm.showModal();
	endif;
epilog
	delete theLeftRequests;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_linkMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showReturnCargoToYardForm" id="181e6d5e-97d1-4c70-a82b-94e952d58b92">
        <source>showReturnCargoToYardForm() protected;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
//------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	tiArray : CM_TIArray;
	obj : Object;
begin
	inheritMethod();
	if self.myBayDrawingController &lt;&gt; null then
		create tiArray transient;
		self.myBayDrawingController.getAllSelectedTIs(tiArray);
		self.myAssistant.showReturnCargoToYardForm(self.myCurrentVoyage, tiArray, self.myMasterMenuAction, false);
	endif;
epilog
	delete tiArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showSelectBays" id="133488f5-59d8-4220-b52c-9598cd34b3e8">
        <updating/>
        <source>showSelectBays(_top : Integer; _left : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTop , theLeft : Integer;
begin
	if self.frmSelectBay.visible then
		return;
	endif;
	
	// Do not show layout if in this mode
	self.showHideLayout(false);

	self.frmSelectBay.visible := true;

	self.frmSelectBay.zOrder(1);
	self.frmSelectBay.top := 100;
	self.frmSelectBay.left := 75;
	self.frmSelectBay.width := 350; // ### TFS 50421 27OCT2021 NAVAB1
	self.frmToolbarBays.positionToolbarControls();
	self.cmbBayVoyage.setFocus();
end;</source>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="_left" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showSetJobSeedFrame" id="f6c4af30-dca4-4f6d-bfed-3e6f210d445e">
        <source>showSetJobSeedFrame(_top : Integer; _left : Integer);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTop , theLeft 	: Integer;
	crane				: CM_Crane;
begin

	if self.frmSeedJob.visible then
		return;
	endif;
	
	if _top = 0 then
		theTop := (self.frmToolbar2.top +  self.frmToolbar2.height + 1).Integer;
		theLeft := 100;
	else
		theTop := _top;
		theLeft := _left;
	endif;
	self.frmSeedJob.visible := true;

	self.frmSeedJob.zOrder(1);
	self.frmSeedJob.top := theTop;
	self.frmSeedJob.left := theLeft;
	crane := self.cmbCrane.listObject.CM_Crane;
	
	if crane &lt;&gt; null then
		self.cmbCraneJS.listObject := crane;
		self.txtSeedJob.text := crane.jobSeed.asStringJMT;//self.myCurrentVoyage.seedJobNumLoad.asStringJMT;
	else
		self.txtSeedJob.text := '0';
	endif;
	
	self.txtSeedJob.setFocus();
	self.txtSeedJob.selStart := 0;
	self.txtSeedJob.selLength := self.txtSeedJob.text.length;
end;</source>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="_left" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showShuffleSelector" id="113c85a9-cce1-4198-90be-f7aaac189bae">
        <updating/>
        <source>showShuffleSelector() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theForm : Form;
	theLeftTrackedItems: CM_TIArray;
	theSlotController : CM_SlotController;
	allMoves, tmpMoves : CM_FutureMoveArray;
	tmpObj		: Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	// first go get all the selected slot TrackedItems
	create theLeftTrackedItems transient;

	tmpObj := self.myBayDrawingController.allSelectedObjects.first;

	if tmpObj = null then
		return;
	endif;
	if (not tmpObj.isKindOf(CM_SlotController)) then
		return;
	endif;

	theSlotController := tmpObj.CM_SlotController;

	// Now create the form
	theForm := app.getForm(SHP_ShuffleTIs.name);
	if theForm = null then
		create theForm as SHP_ShuffleTIs;
	endif;

	
	if self.displayMode = ShpDisplayMode_Actual or 
	   self.displayMode = ShpDisplayMode_EDI then
		theSlotController.allTrackedItems.copy(theLeftTrackedItems);
		theForm.SHP_ShuffleTIs.mode := SHP_ShuffleTIs.Mode_TIs;
 	elseif (self.displayMode = ShpDisplayMode_ColCodeLoad and theSlotController.allPlannedFutureMoves.size &gt; 1) then
		create allMoves transient;
		create tmpMoves transient;
		theSlotController.getAllFutureMovesOfType(PLANNING_MODE, TI_FutureMovePlanned, tmpMoves);
		tmpMoves.copy(allMoves);
		theSlotController.getAllFutureMovesOfType(PLANNING_MODE, TI_FutureMoveDLRLoad, tmpMoves);
		tmpMoves.copy(allMoves);
		theForm.SHP_ShuffleTIs.mode := SHP_ShuffleTIs.Mode_FutureMoves;
 	elseif self.displayMode = ShpDisplayMode_Proposed then
		// proposed is actual and planned cargo
		theSlotController.getAllPlannedTrackedItems(theLeftTrackedItems, true, false);
		theSlotController.allTrackedItems.copy(theLeftTrackedItems);
		theForm.SHP_ShuffleTIs.mode := SHP_ShuffleTIs.Mode_TIs;
	endif;
	
	theForm.SHP_ShuffleTIs.myTerminal := self.myTerminal;
	theForm.SHP_ShuffleTIs.magCargo.formDisplayEntryMethodName := "displayStuff";
	
	if theForm.SHP_ShuffleTIs.mode = SHP_ShuffleTIs.Mode_TIs then
		// pass through and validate the collection of TrackedItems
		if theForm.SHP_ShuffleTIs.setCollections(theLeftTrackedItems) then
			theForm.showModal();
		endif;
	else
		if allMoves = null then
			app.msgBox("There is no planned cargo in slot " &amp; theSlotController.getFullId &amp; ".","Shuffle Cargo Error",MsgBox_OK_Only);
		else
			theForm.SHP_ShuffleTIs.setCollectionsFM(allMoves);
			theForm.SHP_ShuffleTIs.myLocationsController := theSlotController;
			theForm.showModal();
		endif;
	endif;
epilog
	delete theLeftTrackedItems;
	delete allMoves;
	delete tmpMoves;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="showTranshipForm" id="22b3de44-4470-4309-8dad-41a78f3884cb">
        <source>showTranshipForm();

vars
	tiArray : CM_TIArray;
begin
	if self.myBayDrawingController &lt;&gt; null then
		create tiArray transient;
		self.myBayDrawingController.getAllSelectedTIs(tiArray);		
	endif;
	
	if tiArray &lt;&gt; null and tiArray.size &gt; 0 then
		self.myAssistant.showTranshipDetailForm(tiArray);
	endif;
	
	
epilog
	if tiArray &lt;&gt; null then
		delete tiArray;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showVoyAllocScreens" id="f6d78c45-0c54-467c-aa20-c0f93832e305">
        <source>showVoyAllocScreens();
// ---------------------------------------------------------------------------
// Created:     01 February 2010 by cnwab1
//
// Changed On   Changed By  	Reason
// ----------   ----------  	--------------------------------------------------
// 02/03/2011	cnwmh5			#25151 - Change to check display mode being discharge rather than load
// ---------------------------------------------------------------------------

vars
	isExport : Boolean;
begin
	if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.useVoyageAllocations then		
		
		if self.myCCScreen = null then // or not global.isValidObject(self.myCCScreen) then
			self.myAssistant.SHP_Assistant.showCCVoyage(self,self.myCurrentVoyage, self.myMasterMenuAction,null, (self.displayMode = ShpDisplayMode_ColCodeLoad));	//+cnwas3 par 27507	
			//self.myAssistant.SHP_Assistant.showCCVoyage(self,self.myCurrentVoyage, self.myMasterMenuAction,null, (self.displayMode = ShpDisplayMode_ColCodeDisch));		// 02/03/2011 cnwmh5 #25151
		else
			self.myCCScreen.visible := true;
		endif;
		
		//24 Jan 2012	NDL	Par 28896
		isExport := (self.displayMode = ShpDisplayMode_ColCodeLoad);
		if isExport then
			if self.myCCPaletteLoad = null then 
				self.myAssistant.SHP_Assistant.showCCPallette(self,self.myCurrentVoyage, self.myMasterMenuAction,null, isExport);
			else
				self.myCCPaletteLoad.visible := true;
			endif;
		elseif not isExport then
			if self.myCCPalette = null then 
				self.myAssistant.SHP_Assistant.showCCPallette(self,self.myCurrentVoyage, self.myMasterMenuAction,null, isExport);
			else
				self.myCCPalette.visible := true;
			endif;
		endif;
		/*
		if self.myCCPalette = null then //or not global.isValidObject(self.myCCPalette) then
			self.myAssistant.SHP_Assistant.showCCPallette(self,self.myCurrentVoyage, self.myMasterMenuAction,null, (self.displayMode = ShpDisplayMode_ColCodeLoad)); //+cnwas3 par 27507
			//self.myAssistant.SHP_Assistant.showCCPallette(self,self.myCurrentVoyage, self.myMasterMenuAction,null, (self.displayMode = ShpDisplayMode_ColCodeDisch));	// 02/03/2011 cnwmh5 #25151
		else
			self.myCCPalette.visible := true;
		endif;
		*/
		
		
		
		
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showVoyageJobForm" id="ec3a7911-bd5b-4486-a4c7-eeae1eeabb26">
        <source>showVoyageJobForm(_new : Boolean;_initBay : CM_Bay; _initHatchLids : CM_HatchLidSet);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
//
// 08 Nov 2012	PJS		PAR #30631 Voyage Rationalisation
// ---------------------------------------------------------------------------
vars
	voyJobForm : SHP_VoyageJobForm;
	menuAction : CMUI_MenuAction;
begin

	self.myAssistant.SHP_Assistant.showVoyageJobForm(myCurrentVoyage,myCurrentJob);



	/*
	if self.myCurrentVoyage = null then
		return;
	endif;

	menuAction := app.myController.createMenuAction(PmShipVoyageJobView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	voyJobForm := menuAction.goToObject(null, null, false, null).SHP_VoyageJobForm;

	if voyJobForm = null then
		return;
	endif;
	
	if _new then // not implemented
		voyJobForm.doSetInitProperties(_initBay, _initHatchLids);
	elseif self.myCurrentJob &lt;&gt; null then			
		voyJobForm.showWithObject(self.myCurrentJob, true, true);	
	else
		voyJobForm.showWithObject(self.myCurrentVoyage, false, false);	
	endif;
	*/

end;</source>
        <Parameter name="_new" type="Boolean"/>
        <Parameter name="_initBay" type="CM_Bay"/>
        <Parameter name="_initHatchLids" type="CM_HatchLidSet"/>
    </JadeMethod>
    <JadeMethod name="showVoyagePlanningForm" id="f9677980-f328-4330-9b5e-732d81f0fe75">
        <source>showVoyagePlanningForm();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	voyageFrm 	: Form; 
	menuAction 		: CMUI_MenuAction;
	isOld	: Boolean;
begin

/*	
	if app.isSpecial() then
		if app.msgBox(class.name &amp; "::" &amp; method.name &amp; CrLf &amp; CrLf &amp; 
				'Do you want to run the *NEW* RORO Planning instead?', 
				'Special User Question', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			voyageFrm := app.loadForm(SHP_ROROPlanningForm, SHP_Assistant, false, true, false, self.myTerminal, null).SHP_ROROPlanningForm;
			if voyageFrm &lt;&gt; null then
				voyageFrm.show();
				return;
			endif;
			
			isOld := true;
		endif;
	endif;
	*/
	menuAction := app.myController.createMenuAction(PmVoyagePlanningView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;

	if (not isOld) then
		voyageFrm := menuAction.goToObject(null, null, false, null); 
	endif;

	if voyageFrm = null then
		return;
	endif;

	self.allSelectedHolds.copy(	voyageFrm.SHP_VoyageAreaForm2.allSelectedHolds); // PAR 9032
//	voyageFrm.SHP_VoyageAreaForm2.displayMode := self.displayMode; // PAR 10518 removed
	
	voyageFrm.SHP_VoyageAreaForm2.displayModeHistory := self.displayMode; // PAR 9147
	voyageFrm.SHP_VoyageAreaForm2.myCurrentVoyage := self.myCurrentVoyage; // PAR 9032

	voyageFrm.show;	

end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="80ca998d-9169-42fa-9a39-1fd0076ad4e4">
        <updating/>
        <source>showWithObject(_bay : CM_Bay; _voyage : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCranes : Collection;
begin
	if _bay = null then
		return;
	endif;
	
	self.show;

	self.frmSelectVoyage.visible := false;
	self.setupVoyageCombo(self.cmbVoyage, false);
	self.setupVoyageCombo(self.cmbBayVoyage, false);

	self.cmbVoyage.listObject := _voyage;
	self.cmbBayVoyage.listObject := _voyage;
	self.myCurrentVoyage := _voyage;
	self.allSelectedHolds.add(_bay.myHold);
	self.msgHolds.setSelected(self.allSelectedHolds);
	
	if (not self.voyageLoad(ShpDisplayMode_Actual)) then
		// reshow the selector
		self.frmSelectVoyage.visible := true;
	endif;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="switchDisplayMode" id="9c117525-00ef-43e6-9b8d-1b2df375aae5">
        <updating/>
        <source>switchDisplayMode(_newMode : Integer; _doDraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 13/08/2020	jlgdap1		TFS 49824 GPHA Show Proposed cargo mode not refreshing correctly
vars
	oldMode	: Integer;
	
begin
	oldMode := self.displayMode;
	if oldMode = _newMode and _newMode &lt;&gt; ShpDisplayMode_EDI then
		return;
	endif;

	if self.hasChanged then
		// user has made some changes to need to warn
		if self.workingMode = self.WorkMode_CustomSeq then
			if (not self.giveCustSeqNeedSaveWarning(null, null, 0, 0, 0, 0)) then
				if self.displayMode = ShpDisplayMode_ColCodeLoad then
					self.btnColorCodeLoad.value := true;
				elseif self.displayMode = ShpDisplayMode_ColCodeDisch then
					self.btnColorCodeDish.value := true;
				endif;
				return;
			endif;
		endif;
	endif;
	self.btnPenHeavy.visible		:= false;
	self.btnPenVoltage.visible		:= false;
	self.btnTwinLiftCrane.visible := false;
	self.hasChanged := false;
	self.displayMode := _newMode;
	self.setCaptionForModes(_newMode);
	
	self.btnTranship.visible := (_newMode = ShpDisplayMode_Actual); //ccms 1011 epr 20/7/06
	
	
	if oldMode = ShpDisplayMode_EDI and 
	   _newMode &lt;&gt; ShpDisplayMode_EDI then	//don't null bayPlan on getAll
		self.myCurrentEDIBayPlan := null;
		self.doMnuEDIEnable(false);
	endif;

	if _newMode &lt;&gt; ShpDisplayMode_VoyGlobActual
	and _newMode &lt;&gt; ShpDisplayMode_VoyGlobProposed then
		self.myCurrentVoyageInterTerm := null;
		self.myBayDrawingController.setVoyageInterTerminal(null);
		self.frmVoyGlobalMode.visible := false;
	endif;
	
	self.displayMode := _newMode;
	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a
	endif;
	//self.showHideCC(false);
	// summarise will only be enabled for display mode of actual.
	self.btnSummariseAll.enabled	:= false;	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
	if _newMode = ShpDisplayMode_Actual then
		self.switchWorkingMode(WorkMode_None);
		
		self.displayModeActual(true);
		//self.btnActual.myToolbarButton.drawButtonDown;
		self.doResetWorkingButtons(true,true,true);
		self.myBayDrawingController.setViewMode(VIEW_DISPORT); // PAR 25833

	elseif _newMode = ShpDisplayMode_ColCodeDisch then
		//24 Jan 2012	NDL	Par 28896
		if self.myCCPaletteLoad &lt;&gt; null then
			self.myCCPaletteLoad.unloadForm();
			self.myCCPaletteLoad := null;
		endif;
		
		if self.workingMode = self.WorkMode_CustomSeq then // PAR 8766 added
			self.showHideSequenceToolbar(true); // PAR 8766 added
		endif;
		if self.workingMode = self.WorkMode_None and self.myCurrentVoyage &lt;&gt; null then // PAR 23216 this is colour code mode only, not jobs, planning etc
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,true);//cnwas3 par26840a	
			//self.showHideCC(true);
		endif;
		self.btnColorCodeDish.value := true;

		self.enableDisableWorkModes(true, true);
		self.myBayDrawingController.setViewMode(VIEW_DISPORT);

		self.mnuWorkCCMain.visible := true;
		self.doMnuWorkCCVisible(true);
		self.mnuWorkCCLoadAtt.visible := false;
		self.mnuWorkCCDrawL.visible := false;
		self.mnuWorkCCJobMain.visible := false;
		self.mnuWorkViewMain.visible := false;
		self.mnuWorkDisplayMain.visible := true;
		self.txtJobLinkLoad.visible := (self.workingMode =  self.WorkMode_Job);
		//epr par 33070 30/12/13
		self.chkOutOfSequence.enabled:=false;
		self.chkOutOfSequence.value:=false;
		
		if self.workingMode &lt;&gt; WorkMode_Job then
			self.displayModeColourDischarge();
		else
			self.setToolbarCombosWidth();
		endif;

		self.tblGridAreaInfo.rows := 0;
		self.doNotesForLegendStartStop(VIEW_DISPORT); 

	elseif _newMode = ShpDisplayMode_ColCodeLoad then
		//24 Jan 2012	NDL	Par 28896
		if self.myCCPalette &lt;&gt; null then
			self.myCCPalette.unloadForm();
			self.myCCPalette := null;
		endif;
	
		self.myBayDrawingController.myDrawingAttrController.handleVoyageAllocationsLoad(self.myCurrentVoyage); // TFS 7719 changed to use handleVoyageAllocationsLoad

		if self.workingMode = self.WorkMode_CustomSeq then // PAR 8766 added
			self.showHideSequenceToolbar(true); // PAR 8766 added
		endif;
		if self.workingMode = self.WorkMode_None and self.myCurrentVoyage &lt;&gt; null then 
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,true);//cnwas3 par26840a
			//self.showHideCC(true);
		endif;
		self.btnColorCodeLoad.value := true;
		self.enableDisableWorkModes(true, true);
		self.txtJobLinkLoad.visible := false;
		if self.myCurrentVoyage.useVoyageAllocations then // PAR 23426
			self.myBayDrawingController.setViewMode(VIEW_YARD_ALLOC);
		else
			self.myBayDrawingController.setViewMode(VIEW_DISPORT);
		endif;

		self.mnuWorkCCMain.visible := true;
		self.doMnuWorkCCVisible(true);
		self.mnuWorkCCDrawD.visible := false;
		self.mnuWorkCCJobMain.visible := false;
		self.mnuWorkViewMain.visible := false;
		self.mnuWorkDisplayMain.visible := true;
		//epr par 33070 30/12/13
		self.chkOutOfSequence.enabled:=true;
		self.chkOutOfSequence.value:=self.myCurrentVoyage.createOutOfSequenceLoadJobs();
		
		if self.workingMode &lt;&gt; WorkMode_Job then
			self.displayModeColourLoad();
		else
			self.setToolbarCombosWidth();
		endif;
		
		self.tblGridAreaInfo.rows := 0;
		if self.myCurrentVoyage.useVoyageAllocations then  // PAR 23426
			self.doNotesForLegendStartStop(VIEW_YARD_ALLOC);
		else
			self.doNotesForLegendStartStop(VIEW_DISPORT); 
		endif;

	elseif _newMode = ShpDisplayMode_Defn then
		self.btnDefinition.value := true;
		self.switchWorkingMode(WorkMode_None);
		self.displayModeDefn();

	elseif _newMode = ShpDisplayMode_EDI then
		self.btnActual.value := false;
		self.btnDefinition.value := false;
		self.btnProposed.value := false;
		self.btnColorCodeDish.value := false;
		self.btnColorCodeLoad.value := false;
		
		self.doEnableEDI();
		self.doMnuEDIEnable(true);
		self.enableDisableWorkModes(false, false);
		self.mnuWorkEDI.visible := true;
		self.switchWorkingMode(WorkMode_None);
		self.displayModeActual(false);
		self.btnMakeActual.enabled		:= true;
		self.btnAutoDischCC.enabled		:= false;
		self.btnImportTasks.enabled		:= false;
		self.btnCustomsEDI.enabled		:= false;
		self.doResetWorkingButtons(true,true,true);

	elseif _newMode = ShpDisplayMode_Proposed then
		self.btnProposed.value := true;
		self.hideShowPens(false, false);
		self.hideShowViewModes(true);
		self.cmbCargoType.visible	:=	false;
		self.cmbCommodity.visible	:=	false;
		self.cmbPortDis.visible		:=	false;
		self.txtWeight.visible		:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
		self.chkIgnoreWeightV.visible :=	false;	// cnwdad1 30/07/2010 - PAR #24045.
		self.btnSaveBase.visible		:= false;
		self.btnDelete.visible			:= false;	
		self.btnEdit.visible			:= false;	
		self.btnMakeActual.enabled		:= false;
		self.btnAutoDischCC.enabled		:= false;
		self.btnImportTasks.enabled		:= false;
		self.btnCustomsEDI.enabled		:= false;

		self.switchWorkingMode(WorkMode_None);
		self.enableDisableWorkModes(false, false);
		self.enableDisableImexBtns(true, true);
		self.mnuWorkCCMain.visible := false;
		self.mnuWorkViewMain.visible := true;
		self.mnuWorkDisplayMain.visible := true;
		
		self.frmStatusLine.displayMode := DISPLAY_MODE_PLAN;
		self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_PLAN_ONLY);
		self.frmStatusLine.myFrameDisplayMode.enabled := true; 
		self.frmStatusLine.myFrameMoveMode.enabled := true;
		self.doResetWorkingButtons(true,true,true);
		self.myBayDrawingController.setViewMode(VIEW_DISPORT); 		// TFS 49824
		self.btnViewDischPort.value := true;						// TFS 49824

	elseif _newMode = ShpDisplayMode_VoyGlobActual then
		//this is displaying the actual plan from another terminals voyage (same vessel)
		self.btnActual.value := false;
		self.btnDefinition.value := false;
		self.btnProposed.value := false;
		self.btnColorCodeDish.value := false;
		self.btnColorCodeLoad.value := false;
		
		self.doEnableEDI();
		self.enableDisableWorkModes(false, false);
		self.mnuGlobalActual.enabled := true;
		self.switchWorkingMode(WorkMode_None);
		
		self.displayModeActual(false);
		self.btnMakeActual.enabled		:= true;
		self.btnAutoDischCC.enabled		:= false;
		self.btnImportTasks.enabled		:= false;
		self.btnCustomsEDI.enabled		:= false;

		self.doResetWorkingButtons(true,true,true);
		
	elseif _newMode = ShpDisplayMode_VoyGlobProposed then
		//this is displaying the proposed plan from another terminals voyage (same vessel)
		self.btnActual.value := false;
		self.btnDefinition.value := false;
		self.btnProposed.value := false;
		self.btnColorCodeDish.value := false;
		self.btnColorCodeLoad.value := false;
		
		self.doEnableEDI();
		self.enableDisableWorkModes(false, false);
		self.mnuGlobalActual.enabled := true;
		self.switchWorkingMode(WorkMode_None);
		
		self.displayModeActual(false);
		self.btnMakeActual.enabled		:= true;
		self.btnAutoDischCC.enabled		:= false;
		self.btnImportTasks.enabled		:= false;
		self.btnCustomsEDI.enabled		:= false;

		self.doResetWorkingButtons(true,true,true);
	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; _newMode.String &amp; ')');
		return;
	endif;
	
	self.frmToolbar.hideExtraSeperators();
	self.frmToolbar.positionToolbarControls();
	
	self.setModes();
	
	if _doDraw then
		self.voyageDrawGridAreasForMode();
	endif;
	self.setWorkingModeBubble();
end;</source>
        <Parameter name="_newMode" type="Integer"/>
        <Parameter name="_doDraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="switchWorkingMode" id="4836ca0b-c35e-4df5-924d-437ecc192533">
        <updating/>
        <source>switchWorkingMode(_newMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	oldMode	: Integer;
	needRedraw	: Boolean;
	
begin

	oldMode := self.workingMode;
	
	if oldMode = _newMode then
		return;
	endif;

	if self.hasChanged then
		// user has made some changes to need to warn
		if self.workingMode = self.WorkMode_CustomSeq then
			if (not self.giveCustSeqNeedSaveWarning(null, null, 0, 0, 0, 0)) then
				self.btnSequenceMode.value := true;
				return;
			endif;
		endif;
	endif;

	self.hasChanged := false;
	self.workingMode := _newMode;
	self.setModes();
	
	if oldMode = self.WorkMode_CustomSeq then
		self.showHideSequenceToolbar(false);
	endif;
	
	if _newMode = self.WorkMode_CustomSeq then
		self.doMnuEDIEnable(false);
		self.workModeSequence();
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a
		endif;
		//self.showHideCC(false);

	elseif _newMode = self.WorkMode_Job then
		self.doMnuEDIEnable(false);
		if oldMode = self.WorkMode_CustomSeq or
		   oldMode = self.WorkMode_Plan then
			needRedraw := true;
		endif;
		self.workModeJob(needRedraw);
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a	
		endif;
		//self.showHideCC(false);
	
	elseif _newMode = self.WorkMode_Plan then
		self.workModePlanning();
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a
		endif;
		//self.showHideCC(false);

	elseif _newMode = self.WorkMode_None then
		if oldMode = self.WorkMode_CustomSeq or
		   oldMode = self.WorkMode_Plan then
			needRedraw := true;
		endif;
		self.workModeNone(needRedraw);
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,true);//cnwas3 par26840a
			//24 Jan 2012	NDL	Par 28896
			if self.myCCPaletteLoad &lt;&gt; null then
				self.myCCPaletteLoad.visible := true;
			endif;
		endif;
		//self.showHideCC(true);

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; _newMode.String &amp; ')');
		return;
	endif;

	self.setCaptionForModes(self.displayMode);

	self.workingModeHistory := self.workingMode;
	self.frmToolbar.hideExtraSeperators();
	self.frmToolbar.positionToolbarControls();
	self.frmToolbar2.positionToolbarControls();


end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="98291015-d692-4342-a1ec-7963737b15e5">
