    <JadeMethod name="translateForm" id="e2448aa8-f9a5-4903-971a-1034bf114d2f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 May 2023 08:09:06.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025074, locale);
	btnAdd.translateCaption(Xlat_0025075, locale);
	btnAddAll.translateCaption(Xlat_0025076, locale);
	btnClose.translateCaption(Xlat_0025077, locale);
	btnPlan.translateCaption(Xlat_0025078, locale);
	btnRemove.translateCaption(Xlat_0025079, locale);
	btnRemoveAll.translateCaption(Xlat_0025080, locale);
	lblDoNotMoveWaons.translateCaption(Xlat_0025081, locale);
	lblMoveMode.translateCaption(Xlat_0025082, locale);
	lblMoveTheseWagons.translateCaption(Xlat_0025083, locale);
	lblOutward.translateCaption(Xlat_0025975, locale);
	lblRailArea.translateCaption(Xlat_0025084, locale);
	lblRailLine.translateCaption(Xlat_0025085, locale);
	lblRakePosition.translateCaption(Xlat_0025169, locale);
	shtMove.translateCaption(Xlat_0025086, locale);
	shtWagon.translateCaption(Xlat_0025087, locale);
end;</source>
    </JadeMethod>
</GUIClass>
