										);
										
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have found all 9 Rebar items, for Rule 4.");
	
	//stage the fifth rebar - should now get rule 3.
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", childCargoType1.id );
	self.doStwStageCargo( ti, br.allReservePackingChildren.first, ic1.allLocationsControllers.first );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
