    <JadeMethod name="mACheckGetPropertyValue" id="cd697f34-26ba-40d0-9cfb-0f16dd12e7d1">
        <source>mACheckGetPropertyValue();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2022		navma1	Initial creation

*/

vars
	prof     : JadeProfiler;
	folder   : String;
	ediTi      : CM_EDITrackedItem;
	term     : CM_Terminal;
	ediData	 : CM_EDIData;
	str      : String;
	count    : Integer;
	tmpValue : Any;
begin
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 20;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - getDisplayStringForAttribute - " &amp; app.actualTimeServer.getNumeralString() &amp; ".log";
		prof.clearMethodCache();
		prof.start;
	
	foreach term in CM_Terminal.instances discreteLock do 
		foreach ediData in term.myEdiConfig.ediDatas do
			foreach ediTi in ediData.allEDITrackedItems do
				str := ediTi.getDisplayStringForAttribute(ETRow_CountryOfOriginCode, true);
				//str := ediTi.countryOfOriginCode;
				/*
				tmpValue := ediTi.getPropertyValue(ETRow_CountryOfOriginCode);
				if tmpValue.isKindOf(String) then
					str := tmpValue.String;
				endif;
				*/
				count := count +1 ;
				
				if count &gt;=20000 then
					break;
				endif;
			endforeach;
		endforeach;
	endforeach;

epilog
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="mAEventsTerminalCheck" id="28ce6da6-a7e2-40a6-9f37-e44441dc93c1">
        <source>mAEventsTerminalCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2022		navma1	Initial creation

*/
vars
	appScm		     : Schema;
	const 		     : Constant;
	type			 : String;
	constantCategory : ConstantCategory;
	taskId			 : Integer;
begin
	
	appScm := currentSchema; 
	
	if appScm.name &lt;&gt; PortSchemaName then
		appScm := rootSchema.getSchema(PortSchemaName);
	endif;
	
	if appScm = null then
		return;
	endif;
	
	constantCategory := appScm.getConstantCategory('EventsTerminal');
	
	if constantCategory = null then
		return;
	endif;
	
	foreach const in constantCategory.getConstants do
	
		write const.getName &amp; Comma &amp; const.getSource().Integer.String;
	endforeach;

	
epilog

end;</source>
    </JadeMethod>
