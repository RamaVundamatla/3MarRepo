    <JadeMethod name="createQuantityRangeMap" id="5dda532d-b412-44b2-a2a9-0c80000d4e0b">
        <updating/>
        <source>createQuantityRangeMap(_quantityRange : String; _quantityMapObj : CM_QuantityMap; _quantityRangeMapObj : CM_QuantityRangeMap output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	rangeCount	: Integer;
	qtyFrom		: Real;
	qtyTo		: Real;
	proxyQuantityRangeMap	: CM_QuantityRangeMap;
	quantityRangeMapObj		: CM_QuantityRangeMap;
begin
	self.getQuantityRangeDetails(_quantityRange, isDefault, qtyFrom, qtyTo);
	if self.isCargo then
		self.getMappingHeaders();
	endif;

	foreach quantityRangeMapObj in _quantityMapObj.allQuantityRanges do
		rangeCount := rangeCount + 1;
		if isDefault and
		   quantityRangeMapObj.isDefaultRange then
			found := true;
			break;
		endif;
		if quantityRangeMapObj.rangeStart = qtyFrom and
		   quantityRangeMapObj.rangeEnd   = qtyTo   then
			found := true;
			break;
		endif;
	endforeach;

	// if the parent quantity map has been created in this load, as default, and this input is for a non-default range, over-write the
	//  default values with the input values, otherwise the create validation will reject this input as clashing with the automatically-created default
	if not found and
	   rangeCount = 1 and
	   quantityRangeMapObj.isDefaultRange and
 	   app.allReportObjectSet.includes(quantityRangeMapObj) then
		proxyQuantityRangeMap := app.createUpdateProxy(quantityRangeMapObj).CM_QuantityRangeMap;
		proxyQuantityRangeMap.setProxy(_quantityMapObj, qtyFrom.Integer, qtyTo.Integer,0);
		app.myTrxUA.trxUpdateInvoiceTMQtyRange(proxyQuantityRangeMap, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Updating quantity range map (' &amp; _quantityRange &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		self.updateCount := self.updateCount + 1;
		found := true;
	endif;
	if not found then
		quantityRangeMapObj := null;
		create proxyQuantityRangeMap transient;
		proxyQuantityRangeMap.setProxy(_quantityMapObj, qtyFrom.Integer, qtyTo.Integer,0);
		app.myTrxCA.trxCreateInvoiceTMQtyRange(proxyQuantityRangeMap, quantityRangeMapObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Adding quantity range map (' &amp; _quantityRange &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		self.createCount := self.createCount + 1;
	endif;

	_quantityRangeMapObj := quantityRangeMapObj;
	return true;
epilog
	delete proxyQuantityRangeMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_quantityRange" type="String"/>
        <Parameter name="_quantityMapObj" type="CM_QuantityMap"/>
        <Parameter name="_quantityRangeMapObj" type="CM_QuantityRangeMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createResourceMap" id="488722e9-79a7-479a-9b06-bc46f9fd720b">
        <updating/>
        <source>createResourceMap(_resourceName : String; _voyageMapObj : CM_TranMapVoyage; _resourceBrokerObj : CM_ResourceServiceBroker output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	isMove		: Boolean;
	className	: String;
	resourceObj : HMS_Resource;
	serviceBrokerObj : CM_ServiceBroker;
	resourceBrokerObj	 : CM_ResourceServiceBroker;
	proxyResourceBroker	: CM_ResourceServiceBroker;
begin
	self.getResourceDetails(_resourceName, isDefault, resourceObj);

	if isDefault then
		foreach resourceBrokerObj in _voyageMapObj.allResourceSBs do
			if resourceBrokerObj.myResource = null then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			resourceBrokerObj := null;
		endif;
	else
		resourceBrokerObj := _voyageMapObj.allResourceSBs[resourceObj.code];
	endif;
	_resourceBrokerObj := resourceBrokerObj;

	if resourceBrokerObj = null then
		create proxyResourceBroker transient;
		
		proxyResourceBroker.setProxyRSB(resourceObj, _voyageMapObj);
		
		app.myTrxCA.trxCreateInvoiceTMTransaction(proxyResourceBroker, serviceBrokerObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating resource map (' &amp; _resourceName &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		_resourceBrokerObj := serviceBrokerObj.CM_ResourceServiceBroker;
		createCount := createCount + 1;
	endif;
	
	return true;
epilog
	delete proxyResourceBroker;
end;
</source>
        <access>protected</access>
        <Parameter name="_resourceName" type="String"/>
        <Parameter name="_voyageMapObj" type="CM_TranMapVoyage"/>
        <Parameter name="_resourceBrokerObj" type="CM_ResourceServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createResourceMapForEventOrWO" id="adc4796a-30bd-45d9-af8b-7f246856bc55">
        <updating/>
        <source>createResourceMapForEventOrWO(_resourceType : String; _object : CM_ServiceBroker; _resourceServiceBroker : CM_ToDoResourceServiceBroker output) : Boolean updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
24/05/2023	navkc1	CR 57927 Task 57923: Jade - Transaction Map Export Import

*/

vars
	moveFrom				: String;
	moveTo					: String;
	resourceTypeObj 		: CM_ResourceType;
	proxyResourceMap		: CM_ToDoResourceServiceBroker;
	resourceMapObj			: CM_ServiceBroker;
begin

	self.getMoveDetails(_resourceType, false, moveFrom, moveTo, resourceTypeObj);
	
	resourceMapObj := _object.allToDoResourceServiceBrokers.getAtKey(resourceTypeObj);
	
	if resourceMapObj = null then
		
		create proxyResourceMap transient;
		proxyResourceMap.setResourceTypeAndBroker(resourceTypeObj, _object.CM_ServiceBroker);
		app.myTrxCA.trxCreateInvoiceTMTransaction(proxyResourceMap, resourceMapObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating resource map (' &amp; _resourceType &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	endif;
	
	_resourceServiceBroker := resourceMapObj.CM_ToDoResourceServiceBroker;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_resourceType" type="String"/>
        <Parameter name="_object" type="CM_ServiceBroker"/>
        <Parameter name="_resourceServiceBroker" type="CM_ToDoResourceServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSSBrokerMap" id="33556c78-494b-439a-bf7f-7eef3d8eb68e">
        <updating/>
        <source>createSSBrokerMap(_tranMap : CM_TranMapSSSummary; _outputFormat : CM_OutputFormat_SS; _yaCriteria : IntegerArray; _debtorType : CM_DebtorType; _tranMapObj : CM_SnapShotServiceBroker output) : Boolean updating, protected;

// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	ls : Boolean;
	pxySB, realSB 	: CM_ServiceBroker;
	defaultQtyType	: CM_XTABField;

begin

	realSB := _tranMap.allSnapShotServiceBrokers[_outputFormat];

	if realSB = null then
		create pxySB as CM_SnapShotServiceBroker transient;
	else
		app.cmsBeginLoad(ls);
		pxySB := app.createUpdateProxy(realSB).CM_SnapShotServiceBroker;
		app.cmsEndLoad(ls);
	endif;
	
	pxySB.CM_SnapShotServiceBroker.setProxySSB(_yaCriteria, _debtorType, defaultQtyType, _outputFormat, _tranMap);

	if realSB = null then
		app.myTrxCA.trxCreateInvoiceTMTransaction(pxySB, realSB, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating snap shot broker (' &amp; _outputFormat.description &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	else
		app.myTrxUA.trxUpdateInvoiceSSBroker(pxySB.CM_SnapShotServiceBroker, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Updating snap shot broker (' &amp; _outputFormat.description &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
	endif;

	_tranMapObj := realSB.CM_SnapShotServiceBroker;
	return true;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxySB;
end;
</source>
        <access>protected</access>
        <Parameter name="_tranMap" type="CM_TranMapSSSummary"/>
        <Parameter name="_outputFormat" type="CM_OutputFormat_SS"/>
        <Parameter name="_yaCriteria" type="IntegerArray"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_tranMapObj" type="CM_SnapShotServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSnapshotMap" id="0c924a98-37ec-4ee0-bce4-f7ac0854795e">
        <updating/>
        <source>createSnapshotMap(_bankObj : CM_Bank; _mapName : String; _snapshotMap : CM_TranMapSSSummary output) : Boolean updating, protected;

vars
	snapshotMap,
	proxyMap	: CM_TranMapSSSummary;

begin
	// Snapshot Summary map
	snapshotMap := _bankObj.allSnapShotTranMaps[_mapName];
	if snapshotMap = null then
		create proxyMap transient;
		proxyMap.setProxy(_bankObj, _mapName, _mapName);
		// this will create a chain of default children 
		app.myTrxCA.trxCreateInvoiceTranMapSS(proxyMap, snapshotMap, passport);
 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating snapshot map (' &amp; _mapName &amp; '), row ' &amp; rowCount.String);
 			return false;
 		endif;
		if app.isJMTUnitTest then	//24 Jul 2019	NDL	Snapshot testing
			app.writeLog( method.qualifiedName &amp; " created " &amp; snapshotMap.String, LogINFO);
		endif;
		createCount := createCount + 1;
	endif;
	
	_snapshotMap := snapshotMap;
	return true;
epilog
	delete proxyMap;
end;</source>
        <access>protected</access>
        <Parameter name="_bankObj" type="CM_Bank"/>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_snapshotMap" type="CM_TranMapSSSummary" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSubQuantityMap" id="63dfe0d8-83ea-4bb9-99ac-11fcbd25d945">
        <updating/>
        <source>createSubQuantityMap(_quantitySubType ,_quantitySubRange: String; _quantityRangeMapObj : CM_QuantityRangeMap ;_quantityMapObj : CM_QuantityMap output) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2017	TFS #2901:ADP - Variable storage charges based on weight and time


*/

vars
	isDefault	: Boolean;
	calculationTypeObj	: CM_CalculationType;
	mappingType	: Integer;
	chargeZero	: Boolean;
	proxyQuantityMap	: CM_QuantityMap;
	parentObject	: CM_FinancialObject;
	quantityRangeMapObj :CM_QuantityRangeMap;
	qm : CM_QuantityMap;
begin
	self.getQuantityTypeDetails(_quantitySubType, isDefault, calculationTypeObj, mappingType, chargeZero);
	if _quantityRangeMapObj.myChildQuantityMap = null then
		if calculationTypeObj &lt;&gt; _quantityRangeMapObj.myQuantityMap.myCalculationType or
		   mappingType &lt;&gt; _quantityRangeMapObj.myQuantityMap.mappingType or
		   chargeZero &lt;&gt; _quantityRangeMapObj.myQuantityMap.chargeZero then
			create proxyQuantityMap transient;
			proxyQuantityMap.setProxy(_quantityRangeMapObj, chargeZero, mappingType, calculationTypeObj, null);
			app.myTrxCA.trxCreateInvoiceTMQtySub(proxyQuantityMap,_quantityMapObj,app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				self.setAllErrors('Updating Sub quantity map (' &amp; _quantitySubType &amp; '), row ' &amp; rowCount.String);
				return false;
			endif;
			self.updateCount := self.updateCount + 1;
			
		endif;
	endif;
	if _quantityMapObj = null then
	 qm :=_quantityRangeMapObj.myChildQuantityMap;
	else
		qm :=_quantityMapObj;
	endif;
	
	if not self.createQuantityRangeMap(_quantitySubRange, 	qm, quantityRangeMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity range map', _quantitySubRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; _quantitySubRange &amp; ')');
			return false;
	endif;

	self.updateQuantityRangeMapMethods(quantityRangeMapObj);

	return true;
epilog
	delete proxyQuantityMap;
end;</source>
        <access>protected</access>
        <Parameter name="_quantitySubType" type="String"/>
        <Parameter name="_quantitySubRange" type="String"/>
        <Parameter name="_quantityRangeMapObj" type="CM_QuantityRangeMap"/>
        <Parameter name="_quantityMapObj" type="CM_QuantityMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTransactionMap" id="e32575c0-a82e-4ef4-945c-808aaa62227d">
        <updating/>
        <source>createTransactionMap(_transaction : String; _commodityMapObj : CM_CommodityMap; _move : Boolean output; _tranMapObj	: CM_TransServiceBroker output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	isMove		: Boolean;
	className	: String;
	tranTypeObj : CM_TransactionType;
	proxyTranMap	: CM_TransServiceBroker;
	tranMapObj	: CM_ServiceBroker;
begin
	self.getTransactionDetails(_transaction, isDefault, isMove, tranTypeObj);

	// (Move) entries are processed by the following csv field
	if isMove then
		_move := true;
		return true;
	endif;
	
	foreach tranMapObj in _commodityMapObj.allTransServiceBrokersByType do
		if tranMapObj.CM_TransServiceBroker.myTransactionType = tranTypeObj then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		tranMapObj := null;
	endif;

	if tranMapObj = null then
		create proxyTranMap transient;
		if tranTypeObj &lt;&gt; null then
			className := tranTypeObj.classNameToCreate;
		endif;
		proxyTranMap.setProxyTSB(className, _commodityMapObj, tranTypeObj);
		app.myTrxCA.trxCreateInvoiceTMTransaction(proxyTranMap, tranMapObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating transaction map (' &amp; _transaction &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	endif;
	
	_tranMapObj := tranMapObj.CM_TransServiceBroker;
	return true;
epilog
	delete proxyTranMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_transaction" type="String"/>
        <Parameter name="_commodityMapObj" type="CM_CommodityMap"/>
        <Parameter name="_move" type="Boolean" usage="output"/>
        <Parameter name="_tranMapObj" type="CM_TransServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createVoyageMap" id="1f7b310e-4d3b-448e-a33a-0e23d77932e3">
        <updating/>
        <source>createVoyageMap(_bankObj : CM_Bank; _mapName : String; _voyageMap : CM_TranMapVoyage output) : Boolean updating, protected;

vars
	voyageMap,
	proxyMap	: CM_TranMapVoyage;

begin
	voyageMap := _bankObj.allJMHTMs[_mapName];

	if voyageMap = null then
		create proxyMap transient;
		proxyMap.setProxy(_bankObj, _mapName, _mapName);
		// this will create a chain of default children 
		app.myTrxCA.trxCreateInvoiceTranMapVoyage(proxyMap, voyageMap, self.passport);
 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating voyage map (' &amp; _mapName &amp; '), row ' &amp; rowCount.String);
 			return false;
 		endif;
		createCount := createCount + 1;
	endif;
	
	_voyageMap := voyageMap;
	return true;
epilog
	delete proxyMap;
end;</source>
        <access>protected</access>
        <Parameter name="_bankObj" type="CM_Bank"/>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_voyageMap" type="CM_TranMapVoyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWorkOrderMap" id="6225b926-c499-4981-a84c-28d13d74df7e">
        <updating/>
        <source>createWorkOrderMap(_bankObj : CM_Bank; _mapName : String; _workorderMap : CM_TranMapWorkOrder output) : Boolean updating, protected;
/*
Purpose:	TFS 39518		
Date				Who			Reason
JULY 2018		CNWAB1		Initial creation
*/

vars
	workorderMap,
	proxyMap	: CM_TranMapWorkOrder;

begin
	// Work Order Map
	workorderMap := _bankObj.allWorkOrderTranMaps[_mapName];
	if workorderMap = null then
		create proxyMap transient;
		proxyMap.setProxy(_bankObj, _mapName, _mapName);
		// this will create a chain of default children 
		app.myTrxCA.trxCreateInvoiceTranMapWO(proxyMap, workorderMap, self.passport);
 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating work order map (' &amp; _mapName &amp; '), row ' &amp; rowCount.String);
 			return false;
 		endif;
		createCount := createCount + 1;
	endif;
	
	_workorderMap := workorderMap;
	return true;
epilog
	delete proxyMap;
end;</source>
        <access>protected</access>
        <Parameter name="_bankObj" type="CM_Bank"/>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_workorderMap" type="CM_TranMapWorkOrder" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWorkOrderTypeMap" id="ee752a91-abc2-4466-bd2d-c068a2a7a1fa">
        <updating/>
        <source>createWorkOrderTypeMap(_workorderName : String; _workorderMapObj : CM_TranMapWorkOrder; _workorderBrokerObj : CM_WorkOrderServiceBroker output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	isMove		: Boolean;
	className	: String;
	workorderTypeObj : CM_TransactionType;
	serviceBrokerObj : CM_ServiceBroker;
	workorderBrokerObj	 : CM_WorkOrderServiceBroker;
	proxyWorkOrderBroker	: CM_WorkOrderServiceBroker;
begin
	self.getWODetails(_workorderName, isDefault, workorderTypeObj);

	if isDefault then
		foreach workorderBrokerObj in _workorderMapObj.allWorkOrderSBs do
			if workorderBrokerObj.workOrderType = 0 then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			workorderBrokerObj := null;
		endif;
	else
		workorderBrokerObj := _workorderMapObj.allWorkOrderSBs[workorderTypeObj.trxType];
	endif;
	_workorderBrokerObj := workorderBrokerObj;

	if workorderBrokerObj = null then
		create proxyWorkOrderBroker transient;
		
		proxyWorkOrderBroker.setProxyRSB(workorderTypeObj.trxType, _workorderMapObj);
		
		app.myTrxCA.trxCreateInvoiceTMTransaction(proxyWorkOrderBroker, serviceBrokerObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating workorder type map (' &amp; _workorderName &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		_workorderBrokerObj := serviceBrokerObj.CM_WorkOrderServiceBroker;
		createCount := createCount + 1;
	endif;
	
	return true;
epilog
	delete proxyWorkOrderBroker;
end;
</source>
        <access>protected</access>
        <Parameter name="_workorderName" type="String"/>
        <Parameter name="_workorderMapObj" type="CM_TranMapWorkOrder"/>
        <Parameter name="_workorderBrokerObj" type="CM_WorkOrderServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
