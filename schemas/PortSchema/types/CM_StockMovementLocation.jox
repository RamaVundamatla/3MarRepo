<Class name="CM_StockMovementLocation" id="3a1cee35-df9f-4831-b9b3-7ed6625f12c2">
    <superclass name="CM_StockMovement"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkmove"/>
    <ExplicitInverseRef name="allTITransactions" id="e3cc3625-e00c-4e39-ada7-218a31ae57b1">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_TITransactionSet"/>
        <access>readonly</access>
        <Inverse name="CM_Edit::myStockMovementIn"/>
        <Inverse name="CM_Edit::myStockMovementOut"/>
        <Inverse name="CM_Erase::myStockMovementOut"/>
        <Inverse name="CM_LogVoyageTransaction::myStockMovement"/>
        <Inverse name="CM_Move::myStockMovementIn"/>
        <Inverse name="CM_Move::myStockMovementOut"/>
        <Inverse name="CM_Receive::myStockMovementIn"/>
        <Inverse name="CM_Receive::myStockMovementOut"/>
        <Inverse name="CM_Release::myStockMovementIn"/>
        <Inverse name="CM_Release::myStockMovementOut"/>
        <Inverse name="CM_Split::myStockMovementOut"/>
        <Inverse name="CM_Merge::myStockMovementIn"/>
    </ExplicitInverseRef>
    <CompAttribute name="allUpdates" id="e6697bd1-a164-487f-ab5e-f016783b6b72">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="addFixup" id="14acd88f-7d60-4a71-bfea-481a4c901a3b">
        <updating/>
        <source>addFixup(_quantity: Integer; _weight: Decimal; _volume: Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// 14 Jan 2016	NDL	Par 37369
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	ts		: TimeStamp;		
begin

	ts := app.serverTimestampAtTrxStart;
	
	tmpStr := '&lt;fixup&gt;' &amp; '::' &amp;
			  _quantity.String &amp; '::' &amp;
			  _volume.String &amp; '::' &amp;
			  _weight.asStringWeightJMT() &amp; '::' &amp;
			  ts.Date.formatAsYYYYMMDD() &amp; '::' &amp;
			  ts.Time.formatAsHHMMSS()[1:62];
			  
	self.allUpdates.add(tmpStr);
	
	inheritMethod(_quantity, _weight, _volume);

end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="2cbb9713-1b69-40b9-b18d-7497cb886f1f">
        <updating/>
        <source>addTrackedItem(_ti : CM_TrackedItem; _quantity: Integer; _weight : Decimal; _volume : Decimal;
			   _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  The ti to add and a flag to indicate if the move is in or out
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// 14 Jan 2016	NDL	Par 37369
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	ts		: TimeStamp;		
begin

	// PAR 19968 - for fixups
	//if _txn = null then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'Null CM_TITransaction. Contact Developer.');	
	//	return;
	//endif;
	
	ts := app.serverTimestampAtTrxStart;
	
	tmpStr := _ti.id &amp; '::' &amp;
			  _quantity.String &amp; '::' &amp;
			  _volume.String &amp; '::' &amp;
			  _weight.asStringWeightJMT() &amp; '::' &amp;
			  ts.date.formatAsYYYYMMDD() &amp; '::' &amp;
			  ts.Time.formatAsHHMMSS()[1:62];

	self.allUpdates.add(tmpStr);
	
	if _txn &lt;&gt; null then
		_txn.addToStockMovement(self);
	endif;
	
	inheritMethod(_ti, _quantity, _weight, _volume, null);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem_DocketCorrect" id="f424bb3c-a7b4-4768-924d-9a38ea790fc9">
        <updating/>
        <source>addTrackedItem_DocketCorrect( _ti : CM_TrackedItem; _ts : TimeStamp; _quantity: Integer; _weight : Decimal; _volume : Decimal;
			   _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2008 by cnwvu1
// 14 Jan 2016	NDL	Par 37369
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;

begin

	if _txn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CM_TITransaction. Contact Developer.');	
		return;
	endif;
	
	tmpStr := _ti.id &amp; '::' &amp;
			  _quantity.String &amp; '::' &amp;
			  _volume.String &amp; '::' &amp;
			  _weight.asStringWeightJMT() &amp; '::' &amp;
			  _ts.date.formatAsYYYYMMDD() &amp; '::' &amp;
			  _ts.Time.formatAsHHMMSS()[1:62];

	self.allUpdates.add(tmpStr);
	
	_txn.addToStockMovement(self);
	
	inheritMethod(_ti, _ts, _quantity, _weight, _volume, null);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="0ee93aac-d618-41d6-bbd4-80ee8813f3be">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

// Created by cnwdvb1 on 26 July 2006

vars

	tiTransaction : CM_TITransaction;

begin

	foreach tiTransaction in self.allTITransactions do
		tiTransaction.eraseForStockMovement(self, _eraseLevel);
	endforeach;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="7609f9df-9863-4d90-a705-e39c8a991298">
        <source>getTIs(_col: Collection input);
/* ---------------------------------------------------------------------------
Created:     26 June 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tiTxn	: CM_TITransaction;
begin
	foreach tiTxn in self.allTITransactions where
			tiTxn.myTrackedItem &lt;&gt; null do
		if (not _col.includes(tiTxn.myTrackedItem)) then
			_col.add(tiTxn.myTrackedItem);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTrackedItem_DocketCorrec" id="7fa981d2-ac05-45c5-82bc-518f6fc9c7d6">
        <updating/>
        <source>removeTrackedItem_DocketCorrec(	_ti : CM_TrackedItem; _ts : TimeStamp; _quantity: Integer; _weight : Decimal; _volume : Decimal;
								_txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2008 by cnwvu1
// 14 Jan 2016	NDL	Par 37369
// ---------------------------------------------------------------------------
vars
	tmpStr,
	strUpd	: String;

begin

	if _txn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CM_TITransaction. Contact Developer.');	
		return;
	endif;
	
	// REMOVE self.allUpdates( tmpStr )
	tmpStr := _ti.id &amp; '::' &amp;
			  (-_quantity).String &amp; '::' &amp;
			  (-_volume).String &amp; '::' &amp;
			  (-_weight).String &amp; '::' &amp;
			  _ts.date.formatAsYYYYMMDD()[1:62];
			  
	foreach strUpd in self.allUpdates do
		if strUpd[1:tmpStr.length] = tmpStr then
			self.allUpdates.remove(strUpd);
			break;
		endif;
	endforeach;
	
	//remove trnMove from allTITtransactions
	_txn.removeFromStockMovement(self);
	
	inheritMethod(_ti, _ts, _quantity, _weight, _volume, null);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
