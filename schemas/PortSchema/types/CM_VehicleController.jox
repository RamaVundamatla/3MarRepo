    <JadeMethod name="getWLEForTI" id="d215d8b0-73eb-47fc-b03e-e548b3cc031b">
        <source>getWLEForTI(_ti: CM_TrackedItem): CM_WorkListEntry;
/*
Purpose:			

Date		Who		Reason
10 February 2022	navab1	TFS 51855
*/

vars

	vvr : CM_VehicleVisitRecord;
	job : CM_Job;
	wle : CM_WorkListEntry;
begin
	if self.vehicle &lt;&gt; null then
		vvr :=  self.vehicle.visitRecords.last();
		
		if vvr &lt;&gt; null then
			job := vvr.getMyJob();
			
			if job &lt;&gt; null then
				foreach wle in job.workListEntries discreteLock do
					if wle.myTrackedItem = _ti then
						return wle;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	return inheritMethod(_ti);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="hasReceiveRoadCancelledTrans" id="e1d7b81e-866e-42cc-81e9-06402fb7cd74">
        <source>hasReceiveRoadCancelledTrans(_trackedItem : CM_TrackedItem) : Boolean;
/*

Purpose:  Returns true if there is a transaction 'Receive Road Cancelled' type attached to Tracked Item

Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Oct 2019	jlgdi1	46578	Initial creation
*/

vars
	tiTransaction : CM_TITransaction;
	
begin
	tiTransaction := _trackedItem.getTransactionOfType(TRANS_TYPE_RCVROADCANCELLED);
	if tiTransaction = null then
		return false;
	else
		return true;
	endif;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
