<Class name="CM_RemoteBOLMaintHdr" id="ab1f153a-abc2-477c-80be-0f06993cfe47">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>For CCMS 1121 BOL updates</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getMessageResponseType" id="e422d16b-c28c-4e06-965c-3cdc007febe4">
        <source>getMessageResponseType(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars

begin
	return CM_RemoteDataManager.BOLMAINTRSP;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="e70c60ee-3418-4e65-a108-cdbc3e04b194">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars

	response		: String;
	err				: Integer;
	errTxt,
	tmpTxt			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;
	
begin
	response	:=	inheritMethod(_parseAgent);
	
	if response = null then
		if _parseAgent.createBOLMaintDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, false, app.myPassport);
			
			if app.myPassport.trxCompletedOK() then
				tmpTxt	:=	self.runFromXMLWorker();
				
				if tmpTxt = null then
					return self.doBuildMessage(self.xmlResponse(err, errTxt));	
				else
					return self.doBuildMessage(self.xmlResponse(Err_XML, tmpTxt));
				endif;
			endif;
		endif;
		
		response	:=	app.getErrorString1(Err_XML, 'Docket Entry');
		
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
epilog

end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runFromXMLWorker" id="e35e3d9b-708c-43fa-b6ed-690add0e63bf">
        <source>runFromXMLWorker() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars
	entryDtl	: CM_RemoteDataDtl;
	str			: String;
begin

	app.myPassport.setIsBackgroundWarningsIgnored(true);
	foreach entryDtl in self.allRemoteDataDtl where not entryDtl.isProcessed do
		str := str &amp; entryDtl.CM_RemoteBOLMaintDtl.doMaintainBOL();
		process.sleep(2000);
	endforeach;
	return str;

epilog
	app.myPassport.setIsBackgroundWarningsIgnored(false);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="4d66fb57-0f85-42d0-bde2-48abed0e4d50">
        <source>runProcess(_errorSet: CM_ErrorSet input; _isBackGround: Boolean): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars

begin
	return inheritMethod(_errorSet, _isBackGround);

epilog

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
