    <JadeMethod name="hasTIs" id="e70c7971-79ab-4261-a0e6-b26e099449d7">
        <source>hasTIs(_mode : Integer) : Boolean;
/*
Purpose:		PAR 31671	
Date				Who			Reason
JUNE 2013		CNWAB1		Initial creation
*/

vars

begin
	


	if self.myLanePositionController &lt;&gt; null then
		if _mode = REAL_MODE then
			if not self.myLanePositionController.allTrackedItems.isEmpty() then
				return true;
			endif;
		// PAR 28919
		elseif _mode = PLANNING_MODE then
			return self.myLanePositionController.hasTIsOfMode(PLANNING_MODE);
		elseif _mode = QUEUE_MODE then
			return self.myLanePositionController.hasTIsOfMode(QUEUE_MODE);
		endif;
	endif;
	
	
	return false;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUnactionedWLE" id="be60af23-db2c-4f6e-b7df-d2ef62ad5277">
        <source>hasUnactionedWLE(_isLoad: Boolean): Boolean;
/*
Purpose:			
Date				Who			Reason
AUGUST 2012		CNWAB1		Initial creation
*/


vars

begin
	if _isLoad then
		if self.myLanePositionController.myRORORequestLoad &lt;&gt; null then
			if not self.myLanePositionController.myRORORequestLoad.isComplete then
				return true;
			endif;
		endif;
	else
		if self.myLanePositionController.myRORORequestDischarge &lt;&gt; null then
			if not self.myLanePositionController.myRORORequestDischarge.isComplete then
				return true;
			endif;
		endif;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAllReqsInJob" id="66cb3b2e-f175-4293-bf77-0db4ee218ab8">
        <source>isAllReqsInJob(_isLoad : Boolean): Boolean;
/* PAR 28787
Purpose:		IF there is a request, is it in a job.	
Date		Who		Reason
02 December 2011	cnwab1	Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
begin
	
	if self.myLanePositionController &lt;&gt; null then
		if _isLoad then
			if self.myLanePositionController.myRORORequestLoad &lt;&gt; null then
				if self.myLanePositionController.myRORORequestLoad.myJob = null 
				and not self.myLanePositionController.myRORORequestLoad.allAllocations.isEmpty()  then // PAR 29807
					return false;
				endif;
			else
				return false;
			endif;
		else
			if self.myLanePositionController.myRORORequestDischarge &lt;&gt; null then
				if self.myLanePositionController.myRORORequestDischarge.myJob = null 
				and not self.myLanePositionController.myRORORequestDischarge.allAllocations.isEmpty() then // PAR 29807
					return false;
				endif;
			else
				return false;
			endif;
		endif;
		
	endif;


	return true;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
