    <JadeMethod name="closeLstAndDisplayTxtHazards" id="737f2341-e93e-4210-aca0-2a1d6650cee1">
        <source>closeLstAndDisplayTxtHazards();
//-----------------------------------------
//
// Created : by cnwaer1 25 August 2008
//-----------------------------------------
vars
	obj		: Object;
	str		: String;
begin
/*
		NOTE for the tabbing to work !@#*&amp;% correctly  I had to make sure that the tab order for all the hazard controls was in the following order
			lstHazards
			frmHazards
			txtHazards
	
	*/
	
	self.frmHazards.visible := false;	
	str :=self.lstHazards.getSelectedString();

	if str.length &gt; 37 then
		self.txtHazards.text := str[1:36] &amp; '...';
	else
		self.txtHazards.text := str;
	endif;

	self.txtHazards.visible := true;

end;</source>
    </JadeMethod>
