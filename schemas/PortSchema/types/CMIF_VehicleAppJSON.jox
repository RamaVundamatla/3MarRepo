    <JadeMethod name="delete" id="269372cf-810d-4405-bade-f9e3cf879672">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	jlier1	Initial creation 57064
 
*/

vars

begin
	if allTransients &lt;&gt; null then
		allTransients.purge;
	endif;
epilog

end;</source>
