    <JadeMethod name="setForUpdate" id="09a95d58-74a3-4b3c-801c-3bc823de01f4">
        <updating/>
        <source>setForUpdate(_backup:CM_Backup) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars
	admin: JadeDatabaseAdmin;
begin
//	self.binaryBackupPath := _backup.binaryBackupPath;
//	self.binaryRemoteBackupPath := _backup.binaryRemoteBackupPath;
	self.dbBackupPath := _backup.dbBackupPath;
	self.dbRemoteBackupPath := _backup.dbRemoteBackupPath;
	self.dbCompress := _backup.dbCompress;
//	self.dbOverwrite := _backup.dbOverwrite;
//	self.dbVerify := _backup.dbVerify;
	self.debug := _backup.debug;
	self.journalCompress := _backup.journalCompress;
	self.journalLocalBackupPath := _backup.journalLocalBackupPath;
	self.journalNumber := _backup.journalNumber;
	if self.journalNumber = 0 then
		create admin transient;
		self.journalNumber := admin.getCurrentJournalNumber;
		delete admin;
	endif;
	self.journalRemoteBackupPath := _backup.journalRemoteBackupPath;
	self.journalVerify := _backup.journalVerify;
	self.purgeDBJournals := _backup.purgeDBJournals;
	self.purgeLocalJournal := _backup.purgeLocalJournal;
	self.purgeJournalDays := _backup.purgeJournalDays;
	self.purgeRemoteJournals := _backup.purgeRemoteJournals;
	self.purgeSDSJournals := _backup.purgeSDSJournals;	// CCMS1150 cnwrs1 04 July 2011
	self.sdsSecondaryBackup := _backup.sdsSecondaryBackup;	//cnwrs1 21 Jan 2010 ccms1150
	self.databaseWorkers := _backup.databaseWorkers;	//cnwrs1 21 Jan 2010 ccms1150
	self.setMyRoot;
end;</source>
        <Parameter name="_backup" type="CM_Backup"/>
    </JadeMethod>
