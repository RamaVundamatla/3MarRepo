    <JadeMethod name="queryButtonsGetWidth" id="fea0e836-8950-41ec-85f4-7cf62daaa994">
        <source>queryButtonsGetWidth( _nQueries : Integer; _captionsArray : StringArray; _frmWidth, _gapCol :Integer ) : Integer protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwvu1
// --------------------------------------------------------------------------------

vars
	maxW	: Integer;
	str		: String;
	
begin

	if _nQueries = 0 then
		return 0;
	endif;
	
	if _nQueries &gt; 24 then	// nQueries &gt; 24 - 3 columns in the screen
		return ( _frmWidth - _gapCol * 3 ) div 3;	// When there are upto 36 queries, button width is the "third" of the frame
	
	else	// nQueries &lt;= 12 - one column in the center of the screen
	
		maxW := 0;
		foreach str in _captionsArray do
			lblControlFont.caption := str;
			maxW := maxW.max( lblControlFont.width.Integer );
		endforeach;
		maxW := maxW + 20;	// adding extra pixels for better design
		if _nQueries &lt;= 12 then	// nQueries &lt;= 12 - one column in the center of the screen
			return maxW.min( _frmWidth - 2 * _gapCol );
		else	// 12 &lt; nQueries &lt;= 24 - two columns in the center of the screen
			return maxW.min( (_frmWidth - 3 * _gapCol) div 2 );
		endif;
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_nQueries" type="Integer"/>
        <Parameter name="_captionsArray" type="StringArray"/>
        <Parameter name="_frmWidth" type="Integer"/>
        <Parameter name="_gapCol" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="queryDefinitionShow" id="8b31f4c7-b112-47e2-aa8f-fe3bd5564109">
        <source>queryDefinitionShow( _dtoQueryDef : DTO_QueryDefinitionRT ) protected;

vars
	dtoCriteriaHolder		: DTO_QueryCriteriaLineHolderRT;
	dtoCriteriaLine			: DTO_SelectorCriteriaLineRT;
	dtoCriteriaLineBoolean	: DTO_CriteriaLineBoolean;
	dtoCriteriaLineStr		: DTO_CriteriaLineString;
	dtoCriteriaLineStrFromTo: DTO_CriteriaLineStringFromTo;
	rtCriteriaLineBool		: RT_CriteriaLineBoolean;
	rtCriteriaLineStr		: RT_CriteriaLineString;
	rtCriteriaLineStrFromTo	: RT_CriteriaLineStringFromTo;
	rtCriteriaLineSplit		: RT_CriteriaLineSplittingSheets;
	nCriteria, i			: Integer;
	iRow, tabInd			: Integer;
	height					: Real;
	
begin
	
	// delete old criteria lines
	if not self.aAllQueryCriteriaLines.isEmpty then
		nCriteria := self.aAllQueryCriteriaLines.size;
		foreach i in 1 to nCriteria reversed do
			self.aAllQueryCriteriaLines[i].deleteClone();
		endforeach;
	endif;
	
	self.queryResultTableReInitialize();
	
	nCriteria := _dtoQueryDef.allQueryCriteriaLineHolders.size;
	i		:= 0;
	iRow	:= 0;
	tabInd:= self.txtSearchValueA1.tabIndex + 800;
	height	:= self.txtSearchValueA1.height + 4;
	foreach dtoCriteriaHolder in _dtoQueryDef.allQueryCriteriaLineHolders do
		
		foreach dtoCriteriaLine in dtoCriteriaHolder.allCriteriaLines do
		
			iRow := iRow + 1;
		
			if dtoCriteriaLine.isKindOf( DTO_CriteriaLineBoolean ) then
				dtoCriteriaLineBoolean := dtoCriteriaLine.DTO_CriteriaLineBoolean;
				create rtCriteriaLineBool transient;
				rtCriteriaLineBool.setForCreate(self,
												dtoCriteriaLineBoolean.propClassName, dtoCriteriaLineBoolean.propName, dtoCriteriaLineBoolean.queryOperatorOid,
												dtoCriteriaLineBoolean.labelCriteria, 
												null/*searchValueA*/, null/*searchValueB*/,
												dtoCriteriaLineBoolean.searchValueBoolean,
												height * (iRow-1),
												tabInd);
				tabInd := tabInd + 2;
				
			elseif dtoCriteriaLine.isKindOf( DTO_CriteriaLineStringFromTo ) then
				dtoCriteriaLineStrFromTo := dtoCriteriaLine.DTO_CriteriaLineStringFromTo;
				create rtCriteriaLineStrFromTo transient;
				rtCriteriaLineStrFromTo.setForCreate(self,
												dtoCriteriaLineStrFromTo.propClassName, dtoCriteriaLineStrFromTo.propName, dtoCriteriaLineStrFromTo.queryOperatorOid,
												dtoCriteriaLineStrFromTo.labelCriteria, 
												dtoCriteriaLineStrFromTo.searchValueA, dtoCriteriaLineStrFromTo.searchValueB,
												null/*searchValueBoolean*/,
												height * (iRow-1),
												tabInd);
				tabInd := tabInd + 2;
												
			elseif dtoCriteriaLine.isKindOf( DTO_CriteriaLineString ) then
				dtoCriteriaLineStr := dtoCriteriaLine.DTO_CriteriaLineString;
				create rtCriteriaLineStr transient;
				rtCriteriaLineStr.setForCreate(self,
												dtoCriteriaLineStr.propClassName, dtoCriteriaLineStr.propName, dtoCriteriaLineStr.queryOperatorOid,
												dtoCriteriaLineStr.labelCriteria, 
												dtoCriteriaLineStr.searchValueA, null/*searchValueB*/,
												null/*searchValueBoolean*/,
												height * (iRow-1),
												tabInd);
				tabInd := tabInd + 1;
				
			endif;

		endforeach;
	
		i := i + 1;
		if i &lt; nCriteria then
			// creating split between query sheets - the row "--OR--"
			iRow := iRow + 1;
			create rtCriteriaLineSplit transient;
			rtCriteriaLineSplit.setForCreate( self,
										null, null, null,
										rtCriteriaLineSplit.CaptionSplittingQuerySheets, 
										null, null,
										false,
										height * (iRow-1),
										tabInd);
	endif;
	endforeach;

	// giving place for criteria line son the form
	self.tblResults.top			:= self.txtSearchValueA1.top + height * iRow + 6;
	self.tblResults.height		:= frmReportDtl.height - self.tblResults.top - 2;
	self.lblQueryName.caption	:= _dtoQueryDef.name;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_dtoQueryDef" type="MobileServerRTThin::DTO_QueryDefinitionRT"/>
    </JadeMethod>
    <JadeMethod name="queryDeleteButtonsMenu" id="a414b851-8c5f-4fea-a7c9-ebccda7bb0e7">
        <source>queryDeleteButtonsMenu()  protected;
// --------------------------------------------
// Created:		05 May 2008 by cnwvu1
// --------------------------------------------

vars
	nQueries, i	: Integer;
