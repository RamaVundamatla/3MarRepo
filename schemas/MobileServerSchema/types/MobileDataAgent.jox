    <JadeMethod name="changeAllLocationsTo" id="4b8fa443-bba7-48ae-b599-2d4279a7cfa7">
        <source>changeAllLocationsTo(loc : CM_LocationsController);
/*
	Created on 23 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif : CMIF_Object;
	cmifItem : CMIF_TIGenCargo;
begin
	foreach cmif in allCMIFs do
		cmifItem := cmif.CMIF_TIGenCargo;
		cmifItem.setMyNewLocation(loc);
	endforeach;
end;</source>
        <Parameter name="loc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="changePassword" id="19725e32-b1a7-4d59-9409-a9588aba888f">
        <updating/>
        <source>changePassword(_userCode: String; _oldPass: String; _newPass: String; _newPass2: String; _stateInfo: DTO_StateInfo input): Boolean updating;
/*
	Created on 03 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	passport	: CM_Passport;
	user		: CM_User;
	userEdition	: Integer;
	
begin
	passport := app.myPassport;
		
	app.myTrxRT.trxChangePassword(_userCode, _oldPass, _newPass, _newPass2, user, userEdition, passport);
	if not passport.trxCompletedOK then
		return false;
	endif;
	
	self.setMediatorState(self.LoggedOn_Reset);
	return true;
end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_oldPass" type="String"/>
        <Parameter name="_newPass" type="String"/>
        <Parameter name="_newPass2" type="String"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeSelectedLocationsTo" id="ec7cc0df-2661-477e-a6d6-d8f0a1fc7f10">
        <source>changeSelectedLocationsTo(_selectedItem:ObjectArray; loc : CM_LocationsController);
/*
	Created on 20 May 2009
	
	by cnwdz2
	
	Purpose: ccms1801
*/

vars
	cmif : Object;
	cmifItem : CMIF_TIGenCargo;
begin
	foreach cmif in _selectedItem do
		if cmif.isKindOf(CMIF_TIGenCargo) then
			cmifItem := cmif.CMIF_TIGenCargo;
			cmifItem.setMyNewLocation(loc);
		endif;
	endforeach;
end;</source>
        <Parameter name="_selectedItem" type="ObjectArray"/>
        <Parameter name="loc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="checkIfTIAlreadyExists" id="199be726-9c05-46a6-8d28-399bcc6df8b8">
        <source>checkIfTIAlreadyExists(_id : String):Boolean;
/*
	Created on 18 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	existingTI : CM_TrackedItem;
begin
	existingTI := myTerminal.lookupTrackedItem(_id, TI_CargoType_Null, TI_STATE_NORMAL, null, false);
	if existingTI &lt;&gt; null and existingTI.id = _id then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="closeLocation" id="8b58f188-0b04-4c12-b7f5-6d33d05c7d15">
        <source>closeLocation(location : CM_LocationsController input) : Boolean ;
//03 July 2008	cnwdw1	
// Close the location - will stop it being used in yard allocations
vars
	allAllocationsObj	: CM_YardAllocationSet;
begin
	create allAllocationsObj transient;
	
	app.myTrxUA.trxSetControllerStatusWithYA(LC_Status_Closed, location, location.edition, allAllocationsObj, app.myPassport);
	return app.myPassport.trxCompletedOK();

epilog
	delete allAllocationsObj;
end;
</source>
        <Parameter name="location" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="2e1674c9-e36e-4efc-a088-b01893e1390f">
        <updating/>
        <source>create() updating;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
