<PrimType name="String">
    <JadeMethod name="asAbbrevHost" id="f40e5532-3c43-4438-8165-afe21a2e3fc5">
        <source>asAbbrevHost():String;

begin
	if self[1:7] = 'cnwchcs' then
		return self[7:end];
	else
		return self;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asBuildVersion" id="796961c1-8665-434b-95ea-2fae31ad9043">
        <source>asBuildVersion():String;

vars
	i,j:Integer;
	id,base,buildId,t:String;
begin
	base := DailyBuildParentFolder &amp; "DailyResults\";
	if self[1:base.length] &lt;&gt; base then
		return "9900";  // ensure the test runs so it returns "invalid build" error
	endif;
	i := base.length+1;
	buildId := self.scanUntil("\", i); i:=i+1;  // eg jade7106.003
	return buildId[5:4];  // eg 7106
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asFastbuildId" id="83e85cb9-55ae-4cdf-b2b3-58be734730ab">
        <source>asFastbuildId():String;

vars
	i,j:Integer;
	id,base,buildId,t:String;
begin
	base:=DailyBuildParentFolder &amp; "DailyResults\";
	if self[1:base.length] &lt;&gt; base then
		return null;
	endif;
	i:=base.length+1;

	id:=self.scanUntil("\", i);		i:=i+1;	// product
	j:=i;
	buildId:=self.scanUntil("\", j);	j:=j+1;	// build id
	if buildId.contains("-") then				// no build id
		t:=self[i:end];
	else
		id:=id&amp;buildId;
		t:=self[j:end];
	endif;
	
	if t.toLower.contains("unicode") then
		id:=id&amp;"U";
	elseif t.toLower.contains("ansi") then
		id:=id&amp;"A";
	elseif t.toLower.contains("joob") then
		id:=id&amp;"J";
	endif;
	
	if t.toLower.contains("debug") then
		id:=id&amp;"D";
	elseif t.toLower.contains("release") then
		id:=id&amp;"R";
	endif;
	
	if t.toLower.contains("win64") then
		id:=id&amp;"64";
	elseif t.toLower.contains("win32") then
		id:=id&amp;"32";
	endif;
	
	return id;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asFileName" id="a0ade084-379c-4dcd-8567-eb9997cc2b7f">
        <source>asFileName():String;

vars
	s:String;
	pos:Integer;
begin
	s := self;
	s.replaceChar("/", "\");
	pos := s.reversePos("\");
	return s[pos+1:end];
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asFolderName" id="e1dec14f-1ded-4b07-aaa9-4f980b67addf">
