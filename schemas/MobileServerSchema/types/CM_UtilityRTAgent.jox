    <JadeMethod name="utlUpdateMediatorTimeStamp" id="8f3cef83-fc79-4288-982a-c3ae018fa54f">
        <source>utlUpdateMediatorTimeStamp(_mediator : CM_RadioTelemetryMediator input;
						   _passport : CM_Passport input);

/*

Purpose:			Update the lastUpdateTs of the passed in mediator to the current server
					time

Parameters:			Mediator

Return Value:		None


Date		Who		Reason
30 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	_mediator.setLastUpdateTs(app.actualTimeServer);
	

epilog

end;</source>
