    <JadeMethod name="trailerType" id="1f62a4f5-c923-47b6-9b9d-4882eea5aa65">
        <methodInvocation>mapping</methodInvocation>
        <source>trailerType(_set : Boolean; _value : String io) mapping;
/*
Date		Who		Reason
06 Dec 2012	cnwcs5	Initial creation - par 30852
*/
vars
	type	:CM_TILCType;
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// new trailer type is null
		self.trailerType = _value then	// not changing trailer type
		return;
	endif;
	
	if _value &lt;&gt; null then
		type := app.myRoot.allTILCTypes [null, _value];
		
		if type &lt;&gt; null then
			type.updateForNonInversedReference;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validate" id="d61be0c2-8dda-45db-a87f-4033f6462865">
        <updating/>
        <source>validate(_passport : CM_Passport input; _terminal : CM_Terminal) updating, protected;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
/****Changes

Date		Name	TFS#			Description
============================================================================	
04/03/2010	cnwcs5	par 22762 		Add validation of cargo type (temporary till this area gets fixed up)
11/03/2010	cnwcs5	par 22762 		Replace literals with tranlated text
06 Dec 2011	cnwkpd1	PAR #28803 		EDI Train Consist errors
									Add validation of ISO Type and ISO Group - if these are not null, then they must be valid
12/09/2014	cnwdap1	PAR #33944 		Add validation for exceeding maximum weight (same as validation for prenotes)
04/07/2018  jlgrh7  TFS #39128 		ADP - FW: DL for Rotation 1801002901 in production
23/07/2018	jlgrh7  TFS #39437 		POL - Re: Ticket 39226: [Fwd: ##RE-8122## : Bookings in terminal SGI not loading]
09/01/2019	jlgka1	42811			Use operator display fahrenheit to display 
									temperature warning message.
24/08/2022  namva1	Bug 54643 		SAL - 1090 exceptions while validating booking items
============================================================================*/

vars
	product				: CM_Product;
	tmpCommodity 		: CM_Commodity;
	invalid				: Boolean;
	temp				: String;
	tmpISOType			: CM_ISOType;
	tmpISOGroup			: CM_ISOTypeGroup;
	requiresTempCheck 	: Boolean;
	validateWeight		: Boolean;							// PAR #33944
	maxWeight			: Integer;							// PAR #33944
	measureType			: CM_MeasurementType;				// PAR #33944
	weightStr			: String;							// PAR #33944
	operator			: CM_Operator; // jlgka1 TFS 42811
	displayFahrenheit	: Boolean;	   // jlgka1 TFS 42811	
begin 
	self.raiseExceptionIfNotTransient(method);

	// par 22762 - start
	if self.cargoType = null then	
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'No cargo type ');	
	endif;
	
	if self.myCargoType = null then	
		app.raiseUnexpectedProgramError(self.class.name, method.name, self.cargoType. String &amp; ' is not a valid cargo type ');	
	endif;	
	
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - start
	if self.matchMode &lt;&gt; CM_BookingRefItem.BASIC_MATCH and self.matchMode &lt;&gt; CM_BookingRefItem.STRICT_MATCH then	
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'A valid match mode needs to be selected to save ');	
	endif;
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - end
	
	if self.myCargoType.isSubCargoTypeRequired then 
		product := self.myProduct;
		
		if product = null then
			app.raiseCMException(Unspecified_product,app.getErrorString(Unspecified_product),null);
		
		else  //24.08.2022 navma1 #54643
			on Exception do app.handleDeletedObject(exception, product, invalid);
			temp := product.code;	// force exception if invalid
			
			if invalid then
				app.raiseUnexpectedProgramError(self.class.name, method.name, 'Invalid sub cargo type ');	
			endif;
			
			on Exception do null;
		endif;
	endif;
	// par 22762 - end
	if self.isBulkMulti then
		
	else
		if self.quantity = 0 then
			app.raiseCMWarning2(WARN_NO_QUANTITY,self.myBookingReference.bookingReference, self.myCargoType.description, ETRow_Quantity, null, self);
		endif;
	endif;
	
	//+cnwml2 PAR21754
	if self.productWeight &lt;&gt; null then
		if self.productQuantity &lt;&gt; null then
			if self.weight &lt; (self.quantity * self.productQuantity * self.productWeight) then
				app.raiseCMWarning(TOTAL_WEIGHT_TOO_LOW, ETRow_Weight, null, self);
			elseif self.weight &lt; (self.quantity * self.productWeight) then
				app.raiseCMWarning(TOTAL_WEIGHT_TOO_LOW, ETRow_Weight, null, self);
			endif;
		elseif self.weight &lt; (self.quantity * self.productWeight) then
			app.raiseCMWarning(TOTAL_WEIGHT_TOO_LOW, ETRow_Weight, null, self);
		endif;
	endif;

	// PAR #28803 - Rework code to allow for additional checked to be added
	//+cnwml2 PAR26228
	if self.commodity &lt;&gt; null 
	and self.myCargoType &lt;&gt; null and self.myCargoType.isCommodityRequired then		//cnwmc5 - 18 Feb 2016 - PAR 37522
		// If a commodity has been entered then it must exist in the system (eg in EDI can just enter any old value).
		tmpCommodity := app.myRoot.allCommodities[ self.commodity.toUpper() ];	//+TFS39128 commodity table's codes are all upper case
		if tmpCommodity = null then
			app.raiseCMWarning1(ERR_INVALID_COMMODITY, self.commodity, app.getString(Commodity), self, self);	//par26681 cnwrs1 29 Decd 2010
		else
			// found one but must also be available to be used.
			if tmpCommodity.isNotAvailableForEntry then
				// The users (in particular CentrePort) want an error not a warning as warning often get missed.
				app.raiseCMWarning1(Commodity_available_entry, self.commodity, app.getString(Commodity), self, self);	//par26681 cnwrs1 29 Decd 2010
			endif;
			
			// Need to make sure the commodity contains the relevant cargo type.
			if tmpCommodity.allCargoTypes[ self.cargoType ] = null then
				app.raiseCMWarning2(CargoType_NotValid4_Commodity, self.cargoTypeDescr, self.commodity, ETRow_CargoTypeDescr, self, self);	//par26681 cnwrs1 29 Decd 2010
			endif;
		endif;
	endif;

	// PAR #28803 - Additional validation for ISO Type and ISO Group
	if self.isoType &lt;&gt; null then
		tmpISOType := app.myRoot.allISOTypes[self.isoType];
		if tmpISOType = null then
			app.raiseCMException2(InvalidSettings, app.getErrorString(ISO_Type), self.isoType, null, self);
		endif;
	endif;
	
	//26 Jun 2013	NDL	Par 30434
	if self.myBookingReference.myTerminal &lt;&gt; null and self.myBookingReference.myTerminal.getConfig( ReeferBookingReqsTemp ).Boolean then
		if ( tmpCommodity &lt;&gt; null and tmpCommodity.hasTemp ) or ( tmpISOType &lt;&gt; null and tmpISOType.isReefer ) then
		//Has at least one thing indication temp check may be required
			requiresTempCheck := true; // default value
			if ( tmpISOType &lt;&gt; null and tmpISOType.isReefer ) then
				//its a reefer 
				if ( tmpCommodity &lt;&gt; null and not tmpCommodity.hasTemp ) then
					// but the commodity inside does not need a temp.
					requiresTempCheck := false;
				endif;
			endif;
			
			if requiresTempCheck then
				if self.getTemperature = NULL_TEMPERATURE then
					app.raiseCMException(Reefer_type_bookin_requir_temp, null, self);
				else
					if  tmpCommodity &lt;&gt; null and tmpCommodity.hasTemp then						
						// jlgka1 TFS 42811 --&gt;
						operator := self.myBookingReference.myOperator;
						if operator &lt;&gt; null then
							displayFahrenheit := operator.displayTempFahrenheit;
						endif;
						// jlgka1 TFS 42811 &lt;--
						
						tmpCommodity.validateTemperature(	self.getTemperature,	//_temperature : Real;
															displayFahrenheit,	//_displayFahreiheit : Boolean;  //jlgka1 TFS 42811
															null,	//_packTempDetails : CM_PackTempReading;
															null,	//_allowableTimeOffPower : Decimal;
															self.getDisplayString,	//_idString	: String;
															true,	//_giveErrorTemp : Boolean;
															true,	//_ignoreIfNullTemp : Boolean;
															true,	//_validateHasTemp : Boolean;
															false,	//_validatePackTemp : Boolean;
															false,	//_giveErrorpackTemp : Boolean;
															null	//_ti : CM_TrackedItem
															);
					endif;
					
				endif;
			endif;
			
		endif;
	endif;

	if self.isoTypeGroup &lt;&gt; null then
		tmpISOGroup := app.myRoot.allISOTypeGroups[self.isoTypeGroup];
		if tmpISOGroup = null then
			app.raiseCMException2(InvalidSettings, app.getErrorString(ISO_Group), self.isoTypeGroup, null, self);
		endif;
	endif;
	
	if self.weight &lt;&gt; NULL_WEIGHT then																										// PAR #33944
		validateWeight := true;																												// PAR #33944
		maxWeight := _terminal.getConfig(MaxLiftWeight).Integer;																			// +TFS39437
		if self.quantity &gt; 1 then																											// PAR #33944
			if (self.weight / self.quantity ) &lt; maxWeight then																				// PAR #33944
				validateWeight := false;																									// PAR #33944
			endif;																															// PAR #33944
		endif;																																// PAR #33944
																																			// PAR #33944
		//maxWeight := _terminal.getConfig(MaxLiftWeight).Integer;																			// PAR #33944
		if maxWeight &lt;&gt; NULL_WEIGHT and self.weight &gt; maxWeight and validateWeight then														// PAR #33944
																																			// PAR #33944
			measureType := app.getDefaultMeasurementForType(Type_Weight);																	// PAR #33944
			if measureType = null or measureType.isSameAsDatabaseValue then																	// PAR #33944
				weightStr := null;																											// PAR #33944
			else																															// PAR #33944
				weightStr := measureType.getWeightConvertedStrForError( maxWeight.Decimal );												// PAR #33944
			endif;																															// PAR #33944
			if _terminal.getConfig(MaxLiftWeightWarnOnly).Boolean then																		// PAR #33944
				app.raiseCMWarning3(VB_MAX_LIFT_WEIGHT, self.cargoTypeDescr, maxWeight.String, weightStr, ETRow_TotalWeight, null, null);	// PAR #33944
			else																															// PAR #33944
				app.raiseCMException3(VB_MAX_LIFT_WEIGHT, self.cargoTypeDescr, maxWeight.String, weightStr, ETRow_TotalWeight, null);		// PAR #33944
			endif;																															// PAR #33944
		endif;																																// PAR #33944
	endif;																																	// PAR #33944
	
	//cnwmc5 - 7 November 2014 - CCMS 2429
	if tmpISOType &lt;&gt; null and tmpISOGroup &lt;&gt; null then
		if not tmpISOGroup.allISOTypes.includes(tmpISOType) then
			app.raiseCMException3(ERR_INVALID_ISOTYPE, tmpISOType.code, app.getErrorString(ISO_Group), tmpISOGroup.code, null, self);
		endif;
	endif;
	
	//epr 15/4/13 CCMS 2280
	self.validateTIHazards(_terminal);
	
	if self.myBookingRefItemActions &lt;&gt; null then
		self.myBookingRefItemActions.validateForUpdate();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6a4ac197-d699-4545-a661-27fb9098d708">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input; _terminal : CM_Terminal) updating;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
