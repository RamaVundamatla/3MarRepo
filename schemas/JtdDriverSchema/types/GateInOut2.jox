    <JadeMethod name="gio13_handHeldGateLaneOut" id="927b7ae6-8918-424c-a4e4-d8479c3223f3">
        <updating/>
        <source>gio13_handHeldGateLaneOut() updating;

//16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
begin
	if myRFIDTag = null or myRFIDTag.myRoadJob = null or myRFIDTag.myRoadJob.myVehicle = null then
		app.logMessage(method.qualifiedName&amp;' error, null reference in '&amp;myRFIDTag.String);
	else
		app.myPassport.setWarningsIgnored(true);
		app.logMessage(method.qualifiedName&amp;' truck '&amp;myRFIDTag.myRoadJob.myVehicle.code&amp;' leaving the yard');
		exclusiveLock(app.myPassport.myTerminal.allVehicleVisits);  // jhp mod
		//app.myTrxDA.trxRoadExit(myRFIDTag.myRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
		app.myTrxDA.trxRoadExit(myRFIDTag.myRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
		assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	endif;

	doEndOfLoop;
end;
</source>
    </JadeMethod>
