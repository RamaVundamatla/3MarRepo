    <JadeMethod name="getBookingSummaryData" id="f6054304-e13d-4ad5-9097-9730b822318b">
        <source>getBookingSummaryData( 	_date : Date;
						_inclUnBooked : Boolean;
						_inclUnUsed : Boolean;
						_inclUsed : Boolean;
						_carrier : CM_Carrier;
						_driver : CM_DriverDetails;
						_vehicle : CM_Vehicle;
						_short : Boolean;
						_strArray : StringArray input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

	iter : Iterator;
	localStartTS,
	startTS : TimeStamp;
	startObject : CM_VehicleBookingTimeSlot;
	slot : CM_VehicleBookingTimeSlot;
	
	totalSlots : Integer;
	statusInt : Integer;
	
	availableNotBooked : Integer;
	noLongerAvail : Integer;
	bookedNotYetDue : Integer;
	bookedOverdue : Integer;
	bookedCurrent : Integer;
	bookedArrivedEarly : Integer;
	bookedArrivedLate : Integer;
	bookedArrivedOntime : Integer;
	
	spaces : String;

begin

	if _short then
		_strArray.add( _date.asStringJMT );
	endif;
	spaces := "    ";
	
	localStartTS.setDate(_date);						// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localStartTS.setTime(TimeStartOfDay);				// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	startTS := self.localToSystemTime(localStartTS);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	iter := self.allBookingsByTS.createIterator;
	startObject := self.allBookingsByTS.getAtKeyGeq(startTS,null);
	
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next( slot ) do
			if slot.bookingTSstart.systemToLocalTimeUsingObject(self).Date &lt;&gt; _date then
				break;
			endif;
			totalSlots := totalSlots + 1;
			statusInt := slot.getStatusInteger();
			
			if statusInt = CM_VehicleBookingTimeSlot.AvailableNotBookedInt then
				if _inclUnBooked then
					availableNotBooked := availableNotBooked + 1;
				endif;
				continue;
			elseif statusInt = CM_VehicleBookingTimeSlot.NoLongerAvailInt then
				if _inclUnBooked then
					noLongerAvail := noLongerAvail + 1;
				endif;
				continue;
			endif;
			
			if _carrier &lt;&gt; null then
				if slot.myCarrier &lt;&gt; _carrier then
					continue;
				endif;
			endif;
			
			if _driver &lt;&gt; null then
				if slot.myDriver &lt;&gt; _driver then
					continue;
				endif;
			endif;
			if _vehicle &lt;&gt; null then
				if slot.myVehicle &lt;&gt; _vehicle then
					continue;
				endif;
			endif;
			
			if statusInt = CM_VehicleBookingTimeSlot.BookedNotYetDueInt then
				if _inclUnUsed then
					bookedNotYetDue := bookedNotYetDue + 1;
				endif;
				continue;
			elseif statusInt = CM_VehicleBookingTimeSlot.BookedOverdueInt then
				if _inclUnUsed then
					bookedOverdue := bookedOverdue + 1;
				endif;
				continue;
			elseif statusInt = CM_VehicleBookingTimeSlot.BookedCurrentInt then
				if _inclUnUsed then
					bookedCurrent := bookedCurrent + 1;
				endif;
				continue;
			elseif statusInt = CM_VehicleBookingTimeSlot.BookedArrivedEarlyInt then
				if _inclUsed then
					bookedArrivedEarly := bookedArrivedEarly + 1;
				endif;
				continue;
			elseif statusInt = CM_VehicleBookingTimeSlot.BookedArrivedLateInt then
				if _inclUsed then
					bookedArrivedLate := bookedArrivedLate + 1;
				endif;
				continue;
			elseif statusInt = CM_VehicleBookingTimeSlot.BookedArrivedOntimeInt then
				if _inclUsed then
					bookedArrivedOntime := bookedArrivedOntime + 1;
				endif;
				continue;
			endif;
			
		endwhile;
	endif;
	
	_strArray.add( app.getErrorString(Total_slots_generated) &amp; " " &amp; totalSlots.String );
	if availableNotBooked &gt; 0 then
		_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.AvailableNotBooked &amp; " " &amp; availableNotBooked.String );
	endif;
	if noLongerAvail &gt; 0 then
		_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.NoLongerAvail &amp; " " &amp; noLongerAvail.String );
	endif;
	
	if bookedNotYetDue &gt; 0
	or bookedOverdue &gt; 0 
	or bookedCurrent &gt; 0 
	or bookedArrivedEarly &gt; 0 
	or bookedArrivedLate &gt; 0 
	or bookedArrivedOntime &gt; 0 then
		if _carrier &lt;&gt; null then
			_strArray.add( _carrier.getDisplayDetails(false) );
		else
			_strArray.add( app.getErrorString(AllCarriers) );
		endif;
		if bookedNotYetDue &gt; 0 then
			_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.BookedNotYetDue &amp; " " &amp; bookedNotYetDue.String );
		endif;
		if bookedOverdue &gt; 0 then
			_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.BookedOverdue &amp; " " &amp; bookedOverdue.String );
		endif;
		if bookedCurrent &gt; 0 then
			_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.BookedCurrent &amp; " " &amp; bookedCurrent.String );
		endif;
		if bookedArrivedEarly &gt; 0 then
			_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.BookedArrivedEarly &amp; " " &amp; bookedArrivedEarly.String );
		endif;
		if bookedArrivedLate &gt; 0 then
			_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.BookedArrivedLate &amp; " " &amp; bookedArrivedLate.String );
		endif;
		if bookedArrivedOntime &gt; 0 then
			_strArray.add( spaces &amp; CM_VehicleBookingTimeSlot.BookedArrivedOntime &amp; " " &amp; bookedArrivedOntime.String );
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_inclUnBooked" type="Boolean"/>
        <Parameter name="_inclUnUsed" type="Boolean"/>
        <Parameter name="_inclUsed" type="Boolean"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_short" type="Boolean"/>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFutureTimesForCarrier" id="69949c5e-ac3b-43a5-862f-9eaff5383834">
        <source>getFutureTimesForCarrier(	_carrier 		 : CM_Carrier;
							_driver          : CM_DriverDetails;
							_vehicle 		 : CM_Vehicle;
							_type 			 : CM_VehicleBookingTimeSlotType;	//28 Oct 2014	NDL	Par 35008
							_includeUnBooked : Boolean;
							_includeBooked   : Boolean;
							_startDate 		 : TimeStamp; //27.9.2021 NAVMJ1 #51070
							_endDate 		 : TimeStamp; //27.9.2021 NAVMJ1 #51070
							_maxStartSet 	 : Integer;
							_localColl 		 : CM_VehicleBookingByTs input
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31506
26 Jun 2020 cnwma1	ChangeRequest 49570: Web Portal - VBS - Add / Search / Edit Vehicle Bookings UI changes
27 Sept 2021 navmj1 Bug 51070: PRP - Vehicle Booking Date / Time Bug
*/

vars

begin
	//28 Oct 2014	NDL	Par 35008
	self.getTimeslotsForCarrier(	true,				//_futureOnly	   : Boolean;
									_carrier,			//_carrier 		   : CM_Carrier;
									_driver,			//_driver 		   : CM_DriverDetails;
									_vehicle,			//_vehicle 		   : CM_Vehicle;
									_type,				//_type 		   : CM_VehicleBookingTimeSlotType;	//28 Oct 2014	NDL	Par 35008
									_includeUnBooked,	//_includeUnBooked : Boolean;
									_includeBooked,     //_includeBooked   : Boolean;
									_startDate,			//_startDate 	   : TimeStamp; //27.9.2021 NAVMJ1 #51070
									_endDate,			//_endDate 		   : TimeStamp; //27.9.2021 NAVMJ1 #51070
									_maxStartSet,		//_maxStartSet 	   : Integer;
									_localColl			//_localColl 	   : CM_VehicleBookingByTs input
									);
							
	return;
epilog

end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_type" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_includeUnBooked" type="Boolean"/>
        <Parameter name="_includeBooked" type="Boolean"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_maxStartSet" type="Integer"/>
        <Parameter name="_localColl" type="CM_VehicleBookingByTs" usage="input"/>
