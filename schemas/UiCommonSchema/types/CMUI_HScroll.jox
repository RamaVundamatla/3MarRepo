<GUIClass name="CMUI_HScroll" id="e53c822e-98c1-4be4-b2f7-44678c35f998">
    <superclass name="HScroll"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="distanceFromBottom" id="15bc7d96-df90-42ea-ad5c-20d946c70879">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="distanceFromRight" id="8e3fba31-64a9-4395-acda-6e0619972d2f">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="lockBottom" id="6309d7a9-ab42-4439-b563-63a15c70f1d3">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="lockRight" id="2995b661-ce61-4e8c-ab55-4c04fb3e60cb">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="stretchWidth" id="16873263-9474-4be0-ba42-7bd822574aad">
