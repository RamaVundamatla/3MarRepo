    <JadeMethod name="valCargoFieldUpdate" id="f8da31e6-bcd1-4690-bb7a-c4e618ee012d">
        <source>valCargoFieldUpdate(_ediDataCargoFieldUpdate : CM_EDIDataCargoFieldUpdate; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		14 December 2009 by cnwdad1:2
//
// Purpose:		Validate the cargo items that will be updated.
//
// Parameters:	_allCargoTIsObj - An array of Tracked Item objects to update.
//				_passportObj - The user's passport.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cargoTIObj		: CM_EDICargoFieldUpdateTI;
	terminalObj		: CM_Terminal;
	ediTI			: CM_EDITrackedItem;
	
begin
	self.raiseExceptionIfNull(_ediDataCargoFieldUpdate, "CM_EDIDataCargoFieldUpdate");

	terminalObj	:=	_ediDataCargoFieldUpdate.getMyTerminal();
	
	if terminalObj = null then
		app.raiseCMException1(ERR_TerminalNotSet, app.getString(EDI_Data), null, null);
	endif;

	foreach ediTI in _ediDataCargoFieldUpdate.allEDITrackedItems do
	
		cargoTIObj := ediTI.CM_EDICargoFieldUpdateTI;
		
		cargoTIObj.verifySelf();
		
		/*
		// There should only be a Cargo key (type and ID), or BOL key (Voyage code and BOL #),
		// not both.
		
		if (cargoTIObj.cargoType &lt;&gt; null or cargoTIObj.id &lt;&gt; null)
		and (cargoTIObj.voyageCode &lt;&gt; null or cargoTIObj.bolNumber &lt;&gt; null)
		then
			app.raiseCMException(Cargo_Field_Upd_TooManyKeys, null, null);
		endif;
		
		// Check that at least one of the key pairs have been provided.
		
		if cargoTIObj.cargoType = null and cargoTIObj.id = null
		and cargoTIObj.voyageCode = null and cargoTIObj.bolNumber = null
		then
			app.raiseCMException(Cargo_Field_Upd_NoKeys, null, null);
		endif;
		
		if cargoTIObj.cargoType = null and cargoTIObj.id = null then
			// If the Cargo keys are not provided, then we should have BOL keys.
			if cargoTIObj.voyageCode = null or cargoTIObj.bolNumber = null then
				app.raiseCMException1(Cargo_Field_Upd_KeyMissing, app.getString(Voyage_Code_And_BOL_Number), null, null);
			endif;
		elseif cargoTIObj.voyageCode = null and cargoTIObj.bolNumber = null then
		// If the BOL keys are not provided, then we should have Cargo keys.
			if cargoTIObj.cargoType = null or cargoTIObj.id = null then
				app.raiseCMException1(Cargo_Field_Upd_KeyMissing, app.getString(Cargo_Type_And_Id), null, null);
			endif;
		endif;
		
		// Check the field details.
		
		if cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_AvailabilityGrade
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_BOL
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_BookingRef
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_BulkRelease
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_Consignee
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_Consignor
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_CustomBroker
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_CustomsReference
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_DeliveryRelease
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_DestinationPort
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_DischargePort
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_FreightForwarder
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_IntendedReleaseMode
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_Remarks
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_ShipperSeal
		and cargoTIObj.fieldName &lt;&gt; CM_EDICargoFieldUpdateTI.F_Voyage
		then
			app.raiseCMException1(Invalid_Field_Name, cargoTIObj.fieldName, null, null);
		endif;
		
		if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_BulkRelease then
			if cargoTIObj.fieldValue = null then
				app.raiseCMException(BR_Field_Value_Null, null, null);
			else
				bulkRelObj	:=	terminalObj.getBulkReleaseFromCode(cargoTIObj.fieldValue);
				
				if bulkRelObj = null then
					app.raiseCMException1(Bulk_Release_Not_Found, cargoTIObj.fieldValue, null, null);
				endif;
			endif;
		endif;
		
		// Now check that the keys are valid.
		*/
		

	endforeach;
end;</source>
        <Parameter name="_ediDataCargoFieldUpdate" type="CM_EDIDataCargoFieldUpdate"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCargoForCranePickup" id="bc193e54-4423-4672-b1b4-758a887e86f7">
        <source>valCargoForCranePickup(	_ti 			 : CM_TrackedItem;
						_queue 			 : CM_RadioTelemetryQueue;
						_job 			 : CM_VoyageJob io;
						_state 			 : Integer io;
						_queuedLoc 		 : CM_LocationsController io;
						_useValidateNWNP : Boolean);
/* Changes

Date		Name	TFS#		Description
============================================================================
10 May 2017	cnwer1	TFS 995		Initial creation 
25 Nov 2019	jlgka1	TFS 47636	POL - Re: [Fwd: ##RE-13503## : Twin Lift discharge in web based vehicle app not working 
								1090 error after fixing original error raised.
14 Jan 2020	jlgka1	TFS 48284 	PRP PRP - Vehicle App unable to discharge cargo from vessel. (Re-use NWNP depends on code path)
============================================================================*/
vars

	currentLocation 	: CM_LocationsController;
	itsAvailable 		: Boolean;
	queueTask,
	task 				: CM_RTQueueTask;
	alert     			: CM_SystemAlert; 
	futureMovePlanned	: CM_FutureMovePlanned;
	nwnp				: Boolean;				
	errorOccur			: Boolean;				// jlgka1 TFS 48284
begin
	// Make sure TI is a DISCHARGE TI, this means that its either ON the ship, OR
	// Sitting in a locations controller that is part of a CTA. (it can be moved here
	// by the code below, when offered to a machine (who rejects it, and leaves the TI
	// there).
	currentLocation := _ti.getPrimaryLocation(REAL_MODE);
	itsAvailable := currentLocation.canBeDischarged;
	if currentLocation.isKindOf(CM_MachineController) then
		//check to see if this ti has been left dangling from a machine in error 1724 rs 20/2/2002
		//ie if a machine has it and the queuetask is unactioned then its available
		queueTask := _ti.getQueueTask;
		if queueTask &lt;&gt; null then
			if queueTask.machine = null and queueTask.status = TASK_UNACTIONED then
				itsAvailable := true;
			endif;
		endif;
	endif;
	
	if not itsAvailable then
		create alert;
		alert.details := app.getErrorString1(ERR_NOT_DISCHARGE, _ti.id.trimRight);
		alert.setSeverity(SEVERE_INFO);
		alert.add;
		
		app.raiseCMException1(ERR_NOT_DISCHARGE, _ti.id.trimRight, null, null);
		return;
	endif;
	
	// Ascertain the job(s) we are working on
	_job := _ti.getFirstAvailableDischargeJob();
	//jlgka1 TFS 47636, 48284 --&gt;
	if _useValidateNWNP then
		nwnp:=currentLocation.canBeDischargedNWNP();
		if (_job = null or not _job.isDischarge) and not nwnp then // PAR 34534
			errorOccur := true;
		endif;
	else		
		if (_job = null or not _job.isDischarge) then
			errorOccur := true;
		endif;
	endif;
	
	if errorOccur then
		create alert;
		alert.details := app.getErrorString1(ERR_NOT_DISCHARGE, _ti.id.trimRight);
		alert.setSeverity(SEVERE_INFO);
		alert.add;

		app.raiseCMException1(ERR_NOT_DISCHARGE, _ti.id.trimRight, null, null);
		return;
	endif;
	//jlgka1 TFS 47636, 48284 &lt;--
	
	task := _ti.locateTaskInQueue(_queue);
	//epr par 25735 14/9/10 remove task &lt;&gt; null validaton

	// Still no task found // If the ti is queued somewhere, then it cannot be 
	if task = null and  _ti.isQueued then //epr par 35597 30/1/15
		
		create alert;
		alert.details := app.getErrorString2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC &amp; " for " &amp; _ti.id.trimBlanks, _queue.id.trimRight);
		alert.setSeverity(SEVERE_INFO);
		alert.add;
				
		app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC &amp; " for " &amp; _ti.id.trimBlanks, _queue.id.trimRight, null, null);
		return;
	endif;
	
	
	
	
	_state:=null;
	
	_queuedLoc:=_ti.getPrimaryLocation(QUEUE_MODE);
	if _queuedLoc &lt;&gt; null then
		_state:=QUEUE_MODE;
		return;

	endif;
	
	
	//5/8/2009 epr par 20360
	// 17/8/09 epr par 20485 - removed the rehandle if discharge and planned to ship then only ignore 
	//can't use planned to ship have get Future move of type TI_FutureMoveDLRDischarge first then get the normal
	
	futureMovePlanned := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge).CM_FutureMovePlanned;
	if futureMovePlanned = null then
		futureMovePlanned := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned).CM_FutureMovePlanned;
	endif;
	if futureMovePlanned &lt;&gt; null then
		_queuedLoc:= futureMovePlanned.getPrimaryLocation();
		if _queuedLoc &lt;&gt; null then
			_state:=PLANNING_MODE;
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_state" type="Integer" usage="io"/>
        <Parameter name="_queuedLoc" type="CM_LocationsController" usage="io"/>
        <Parameter name="_useValidateNWNP" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valCargoForecast" id="ad777d82-7f3a-46cc-91c0-576eb7e93ea9">
        <source>valCargoForecast(_realCargoForecast, _pxyCargoForecast: CM_CargoForecast);
/*

Purpose:			Validates our Proxy gateScan Record for updating

Parameters:			_realGateScanRecord	CM_CargoForecast	The real cargo forecast to check that it is not null
					_pxyGateScanRecord	CM_CargoForecast	The proxy cargo forecast to validate

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	self.raiseExceptionIfNull(_pxyCargoForecast, 'Cargo Forecast Proxy');
	self.raiseExceptionIfNull(_realCargoForecast, "Cargo Forecast Record");
	_pxyCargoForecast.raiseExceptionIfNotProxy(method);
	_pxyCargoForecast.validateForUpdate();

end;</source>
        <Parameter name="_realCargoForecast" type="CM_CargoForecast"/>
        <Parameter name="_pxyCargoForecast" type="CM_CargoForecast"/>
    </JadeMethod>
    <JadeMethod name="valCargoGroupAssignment" id="1f831341-3021-431a-a39b-6543fb0cc6ec">
        <source>valCargoGroupAssignment( _real, _pxy : CM_CargoGroupAssignment; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

begin

	self.raiseExceptionIfNull(_pxy, 'Cargo Group Assignment Proxy');
	self.raiseExceptionIfNull(_real, "Cargo Group Assignment Existing");
	_pxy.raiseExceptionIfNotProxy(method);

	_pxy.validateUpdate( _passport );


epilog

end;</source>
        <Parameter name="_real" type="CM_CargoGroupAssignment"/>
        <Parameter name="_pxy" type="CM_CargoGroupAssignment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCargoGroupComplete" id="f4bd588a-91b0-45b3-b448-87311aa8705e">
        <source>valCargoGroupComplete(_cg : CM_CargoGroup; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/08/2015	cnwndl1	Initial creation	Par 36608
20/02/2018	jlgdap1	TFS 37096 Suppress maximum weight warning when a cargo group that's part of a preassigned notified group is completed
*/

vars

begin

	if _cg = null then
		app.raiseCMException(Cargo_group_found,null,null);
		return;
	endif;
	
	_cg.validateForComplete();					// TFS 37096

epilog

end;</source>
        <Parameter name="_cg" type="CM_CargoGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCargoSeals" id="ee459420-296a-46e7-8b6a-4191bc1ecd52">
        <source>valCargoSeals(	_pxyTI : CM_TrackedItem;
				_checkSealsForDischarge : Boolean;
				_passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwer1	Initial creation PAR 21806 CCMS 1900

*/

vars
	pxyContainer,
	realContainer : CM_TrackedItem;	// changed to be Tracked item 28 Sep 2010	NDL	Par 25608
begin
		
	if not _checkSealsForDischarge then
		//epr par 22102 6/1/10
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
		if _pxyTI.getSealNum &lt;&gt; app.getErrorString(Seal_Present) and 
			_pxyTI.getSealNum &lt;&gt;  app.getErrorString(Seal_Missing) then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Seals),null,null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Seals),null,null); // cnwdb2	PAR 35364
		endif;
		return;
	endif;
		
		
	/*28 Sep 2010	NDL Par 25608
	if not _pxyTI.isKindOf(CM_Container) then
		app.raiseCMException1(SetSealDtlsForNonSealedTI, _pxyTI.cargoTypeDescr, null, null);
		return;
	endif;
	*/
	
	pxyContainer:=_pxyTI;	//.CM_Container;
	realContainer:=pxyContainer.pxyGetRealObject();
	//only validate against existing cargo - should always been know ablout because this is discharge cargo raise unexpected program eror
	if realContainer = null then
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR, self.class.name,method.name ,null, null);
		return;
	endif;
	
	//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
	if realContainer.getSealNumCustoms &lt;&gt; null
	and realContainer.getSealNumCustoms &lt;&gt; pxyContainer.getSealNumCustoms then
		app.raiseCMException1(Err_HandHeldSeal_No_Match,"custom's",null,null);
	endif;
	
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
	if realContainer.getSealNum &lt;&gt; null
	and realContainer.getSealNum &lt;&gt; pxyContainer.getSealNum then
		app.raiseCMException1(Err_HandHeldSeal_No_Match,"operator's",null,null);
	endif;
	
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
	if realContainer.getSealNumShipper &lt;&gt; null
	and realContainer.getSealNumShipper &lt;&gt; pxyContainer.getSealNumShipper then
		app.raiseCMException1(Err_HandHeldSeal_No_Match,"shipper's",null,null);
	endif;
epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_checkSealsForDischarge" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCargoStatus" id="e26cd058-0669-4ed2-bd38-88d14a0526e3">
        <source>valCargoStatus(_realCargoStatus, _pxyCargoStatus : CM_CargoStatus);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(_pxyCargoStatus, ' Cargo Status Proxy');
	self.raiseExceptionIfNull(_realCargoStatus, ' Cargo Status Existing');
	_pxyCargoStatus.raiseExceptionIfNotProxy(method);
	
	//only able to edit abbreviation, description and colour
	_pxyCargoStatus.validateForUpdate;

end;</source>
        <Parameter name="_realCargoStatus" type="CM_CargoStatus"/>
        <Parameter name="_pxyCargoStatus" type="CM_CargoStatus"/>
    </JadeMethod>
    <JadeMethod name="valCargoType" id="b5175b93-0d72-4273-95d8-d33fb8cd3136">
        <source>valCargoType(pExistingCargoType, pProxyCargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(pProxyCargoType, 'Cargo Type Proxy');
	self.raiseExceptionIfNull(pExistingCargoType, "Cargo Type Existing");
	pProxyCargoType.raiseExceptionIfNotProxy(method);

	if pExistingCargoType.id = pProxyCargoType.id then
		pProxyCargoType.validateForUpdate();
	else
		pProxyCargoType.validateForCreate;
	endif;

epilog
	
end;</source>
        <Parameter name="pExistingCargoType" type="CM_CargoType"/>
        <Parameter name="pProxyCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="valCarrier" id="ec65dcd1-6291-4597-b872-9ad5c452e815">
        <source>valCarrier(pExistingCarrier,pProxyCarrier:CM_Carrier);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(pProxyCarrier, 'Carrier Proxy');
	self.raiseExceptionIfNull(pExistingCarrier, "Carrier Existing");
	pProxyCarrier.raiseExceptionIfNotProxy(method);
	if pExistingCarrier.code = pProxyCarrier.code then
		pProxyCarrier.validateForUpdate;
	else
		pProxyCarrier.validateForCreate;
	endif;

epilog
	
end;</source>
        <Parameter name="pExistingCarrier" type="CM_Carrier"/>
        <Parameter name="pProxyCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="valCarrierRelease" id="2fe809ff-fade-46ad-8a0d-28b4b2504059">
        <updating/>
        <source>valCarrierRelease(_releaseAgentType : Integer; pIntFaceCarrierRelease : CMIF_CarrierRelease input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	proxyTI,
	realTI	: CM_TrackedItem;
	control	: CMIF_TIUpdateController;
	needCheck	: Boolean;
	tmpFailedDAC	: CM_DataAccessController;
	
begin
	if pIntFaceCarrierRelease.myProxyTrackedItem = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tracked Item', 'trackedItem', null);
		app.raiseCMException(Input_required_field_trakedItm, 'trackedItem', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	proxyTI := pIntFaceCarrierRelease.myProxyTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	realTI := proxyTI.pxyGetRealObject();

	if _releaseAgentType = ReleaseAgent_Carrier then
		if (realTI.releaseCarrier = null and
		   proxyTI.releaseCarrier &lt;&gt; null) or
		   (realTI.releaseCarrier &lt;&gt; null and
		   proxyTI.releaseCarrier &lt;&gt; null and
		   realTI.releaseCarrier &lt;&gt; proxyTI.releaseCarrier) then
			// freight forwarder code has been changed or updated so
			// need to have entered check code
			needCheck := true;
		endif;
	elseif _releaseAgentType = ReleaseAgent_FreightForwarder then
		if (realTI.freightForwarderCode = null and
		   proxyTI.freightForwarderCode &lt;&gt; null) or
		   (realTI.freightForwarderCode &lt;&gt; null and
		   proxyTI.freightForwarderCode &lt;&gt; null and
		   realTI.freightForwarderCode &lt;&gt; proxyTI.freightForwarderCode) 
		   then
			// freight forwarder code has been changed or updated
			if realTI.myOperator = null then
				app.raiseCMException1(TI_No_Operator, realTI.id, null, null);
				return;
			endif;
			if not realTI.myOperator.getCargoReleaseImpFFUpdAllowed	then // adm 230708 CCMS 1738 
				app.raiseCMException2(No_FreightForwarder_Permission, realTI.myOperator.description,realTI.id, null, null);
				return;
			else
				// need to have entered check code
				needCheck := true;
			endif;		
		elseif realTI.freightForwarderCode = null and proxyTI.freightForwarderCode = null then
			// need to prevent user from updating other fields.
			app.raiseCMException1(Freig_forwa_been_assig_cargo_i, realTI.id,null, null);
			return;
		elseif realTI.myFreightForwarder &lt;&gt; null and (not realTI.myFreightForwarder.canUserAccessSelf(null, tmpFailedDAC, _passport)) then
			// to prevent user updating if already been allocated to other ff. AER - RS1 29/07/08
			app.raiseCMException1(Have_permi_updat_cargo_item_as,realTI.id, null, null);
			return;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Undhandled release agent (' &amp; _releaseAgentType.String &amp; ')');
		return;
	endif;

	// PAR 18536 - add in checks for Operator Release PIN
	if needCheck then
		// need to determine if check customs number or Operator Release PIN
		if ( _releaseAgentType = ReleaseAgent_FreightForwarder or _releaseAgentType = ReleaseAgent_Carrier  ) //cnwrd1 par 25594 ccms 2032 8.12.2010
		 and realTI.myOperator.getRequiresImpOperatorPIN() then
			// we check the operator PIN
			if pIntFaceCarrierRelease.operatorImportReleasePIN = null or 
			   realTI.getOperatorImportReleasePIN = null or
			   pIntFaceCarrierRelease.operatorImportReleasePIN &lt;&gt; realTI.getOperatorImportReleasePIN
			then
				app.raiseCMException2(ERR_INVALID_VALUE,'Operator Import Release PIN', realTI.id, "Operator Import Release PIN", null);
				return;
			endif;
			
		else
			// we check the customs number
			if (pIntFaceCarrierRelease.customsEntryCheckNo = null or (pIntFaceCarrierRelease.customsEntryCheckNo &lt;&gt; proxyTI.customsEntryNumber.trimBlanks
			and not proxyTI.allCustomsEntryNumbers.includes(pIntFaceCarrierRelease.customsEntryCheckNo)))
			or (pIntFaceCarrierRelease.customsEntryCheckNo &lt;&gt; null	// PAR-15992 - always give error if invalid customs number entered
			and not proxyTI.allCustomsEntryNumbers.includes(pIntFaceCarrierRelease.customsEntryCheckNo)) 
			then
				// carrier has entered an invalid customs number
				app.raiseCMException3(InvalidCustomsNoEntered, pIntFaceCarrierRelease.customsEntryCheckNo,
									  proxyTI.cargoTypeDescr, proxyTI.id, 'customsEntryCheckNo', null);
			endif;
			///
		endif;
	endif;
	
	
	/*
	if needCheck
	and (pIntFaceCarrierRelease.customsEntryCheckNo = null or (pIntFaceCarrierRelease.customsEntryCheckNo &lt;&gt; proxyTI.customsEntryNumber.trimBlanks
	and not proxyTI.allCustomsEntryNumbers.includes(pIntFaceCarrierRelease.customsEntryCheckNo)))
	
	or (pIntFaceCarrierRelease.customsEntryCheckNo &lt;&gt; null	// PAR-15992 - always give error if invalid customs number entered
	and not proxyTI.allCustomsEntryNumbers.includes(pIntFaceCarrierRelease.customsEntryCheckNo)) 
	then
	   
		// CCMS-JMT 1648 / PAR 16225
		if (app.myRoot.client = Client_DCTGdansk and
		   realTI.isKindOf(CM_Container) and 
		   realTI.CM_Container.isEmpty and
		   (pIntFaceCarrierRelease.customsEntryCheckNo = null or
		   pIntFaceCarrierRelease.customsEntryCheckNo = realTI.customsEntryNumber.trimBlanks)) then

		   	if realTI.freightForwarderCode &lt;&gt; null then
				// Do nothing as customs number not required for empty containers provided
				// FF has already been assigned.
			else
				app.raiseCMException1(Full_Replacement_Message, 'A Freight Forwarder has not been assigned to cargo item ' &amp; realTI.id &amp; ' so you are not able to update it.', null, null);
			endif;
		else
			// carrier has entered an invalid customs number
			app.raiseCMException3(InvalidCustomsNoEntered, pIntFaceCarrierRelease.customsEntryCheckNo,
								  proxyTI.cargoTypeDescr, proxyTI.id, 'customsEntryCheckNo', null);
		endif;
	endif;
	*/
	
	
	// Does not need to be ready for release for agent to
	// claim for release
	//control := app.createTIUpdateControl(TI_UPDMODE_RELEASE, null, null);
	//proxyTI.validateTrackedItem(control, _passport);
		
epilog
	if control &lt;&gt; null then
		delete control;
	endif;
	
end;</source>
        <Parameter name="_releaseAgentType" type="Integer"/>
        <Parameter name="pIntFaceCarrierRelease" type="CMIF_CarrierRelease" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCashCollectionForTI" id="7663b0a8-afdf-4f43-ac54-ed6b3283201d">
        <source>valCashCollectionForTI(	_ti 			: CM_TrackedItem input; 
						_isReceival 	: Boolean;
						_proformaLines  : CM_InvoiceLineBySeqNumDict input;
						_inTranState 	: Boolean;
						_allErrorMsgs 	: StringArray512 input) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10/08/2012	cnwer1	Initial creation CCMS MES 1035
30/04/2014	cnwjre1	33885 revised to just check the tracked item charges against payments and to not use any pre-payments
9/09/2015	cnwjre1	36361 remove 'protected' so can call directly
18/02/2019  cnwma1	Bug 43451: AAT - Error When Gating Out
27/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
02/05/2024  navma1	Bug 63718: QTS - Error 88618 while gate out
*/

vars
	terminal 					: CM_Terminal;
	bank 						: CM_Bank;
	agent 						: CM_CashInvoiceProformaAgent;
	effectiveDate 			    : Date;
	manual					    : Boolean;
	cashPayment 				: CM_CashPayment;
	debtor 						: CM_Debtor;
	estimatedCharges, 
	paymentAmount,
	cashInvoicedCharges,
	amountOwing,
	cashRequiredToClearCharges : Decimal[23,6];// [23,4]; //Decimal[12,4]; //18.02.2019 cnwma1 Bug #43451 // TFS 47529
    message 				   : String;
	otherPaid,
	lineOwing,
	otherOwing					: Decimal[23,6]; //25/02/2025	navkc1 JIRA Story MTN-33928
	invLine						: CM_InvoiceLine; //25/02/2025	navkc1 JIRA Story MTN-33928
	found						: Boolean; //25/02/2025	navkc1 JIRA Story MTN-33928
	proformaDetail				: CM_ProformaDetails; //25/02/2025	navkc1 JIRA Story MTN-33928
begin
	//no prenote can't do anything return
	if _ti = null then
		return;
	endif;
	
	// TFS 41291
	if _ti.isConfiguredForCash() then
		_ti.validateIsPopulatedForCash(_allErrorMsgs);
	endif;
	_ti.validateHasRDTLinesForCash(_allErrorMsgs);// TFS 41291
	
	terminal:=_ti.myTerminal;
	//receival calculate proforma balance 
	manual:=false;

	bank := _ti.companyOid;
	if bank = null then
		bank := terminal.getDefaultCompanyBank();
	endif;
	
	effectiveDate:=app.actualTimeServer.date;
	create agent transient;
	 // TFS 7357cashPayment:=_ti.allCashPayments.first;
	
	foreach cashPayment in _ti.allCashPayments do // TFS 7357
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue; // TFS 7357
		endif; // TFS 7357
		break;
	endforeach;
	
	if cashPayment &lt;&gt; null then
		//get the effective payment need to figure this out just using the first one here
		manual:=cashPayment.manual;	
		//this is incorrect will be able to figure out the debtor from the invoice lines
	endif;
	agent.init( bank, _ti, effectiveDate, _isReceival );

	//agent.createProformaInvLines( _proformaLines, _inTranState, true ); //14/04/2025	navkc1 JIRA Bug MTN-34628
	agent.createProformaInvLines( _proformaLines, _inTranState, false ); //14/04/2025	navkc1 JIRA Bug MTN-34628 - everywhere else is false. 
	
	agent.getCurrentInvLines(); //25/02/2025	navkc1 JIRA Story MTN-33928
	
	debtor := agent.myDebtor;
	
	//no cash debtor 
	if debtor = null then
		return;
	endif;
	
	//if not for a cash only debtor can continue;
	if not debtor.isCashOnlyDebtor(terminal) then
		return;
	endif;
		
	//find the debtor from the proforma lines - include the taxAmount 
	// taxAmount includes tax for real invoice charges

	estimatedCharges := agent.estimatedCashCharges; // TFS 8264 
	
	// TFS 8264 - only add in the tax on the actual invoice lines if we are running in GHANA tax mode (self.myTerminal.getConfig(CashAllCashTax).String &lt;&gt; null)
	if terminal.getConfig(CashAllCashTax).String &lt;&gt; null  // TFS 8264 
	and not terminal.getConfig(InvoiceMultiTaxRates).Boolean then // TFS 8264 
		estimatedCharges := estimatedCharges + agent.taxAmount; // TFS 8264 
	endif;

	paymentAmount 		:= _ti.getCashPaymentsTotal();				// don't care who paid
	cashInvoicedCharges :=_ti.getCashInvoicedCharges();
	amountOwing 		:= estimatedCharges + cashInvoicedCharges;	// cash payment amount must be &gt;= proforma amount
	
	// only pre-pay for duty docs
	cashRequiredToClearCharges := amountOwing - paymentAmount;
	
	//if cashRequiredToClearCharges &gt; 0 then						//02.05.2024 navma1 #63718		
	if cashRequiredToClearCharges &gt;.01 then							//02.05.2024 navma1 #63718	
		 // ### JIRA 34988 29MAY2025 NAVAB1
		_allErrorMsgs.add(app.getErrorString5(Cash_cargo_not_paid,_ti.id,debtor.name,amountOwing.String,paymentAmount.String, cashRequiredToClearCharges.String));
	elseif terminal.getConfig(CashRoadExitChkServices).Boolean then //25/02/2025	navkc1 JIRA Story MTN-33928
		
		otherOwing := 0;
		foreach invLine in _proformaLines do
			found := false;
			
			lineOwing := invLine.lineTotal; // ### JIRA 34719 23APR2025 NAVKC1
			
			foreach cashPayment in _ti.allCashPayments do
				// ### JIRA 34719 23APR2025 NAVAB1
				if cashPayment.isNotPaidByAPI() then
					// ### JIRA 34719 23APR2025 NAVKC1
					if cashPayment.voided then
						lineOwing += cashPayment.cashValue;
					endif;
					continue;
				endif;
				
				proformaDetail := cashPayment.getMyProformaDetails();
				
				if proformaDetail &lt;&gt; null and proformaDetail.myInvoiceLineType = invLine.invoiceLineDesc then
					if cashPayment.cashValue &gt;= invLine.lineTotal then
						found := true;
						otherPaid := otherPaid + cashPayment.cashValue;
						break;
					endif;
				endif;
			endforeach;
			if not found then
				//otherOwing := otherOwing + invLine.lineTotal;
				otherOwing += lineOwing; // ### JIRA 34719 23APR2025 NAVKC1
			endif;
		endforeach;
		
		foreach invLine in agent.allCurrentInvLines where invLine.debtor.isCashOnlyDebtor(terminal) do : outloop
			
			lineOwing := invLine.lineTotal; // ### JIRA 34719 23APR2025 NAVKC1
			
			if not invLine.allCashPayments.isEmpty() then
				found := true;
				
				// ### JIRA 34719 23APR2025 NAVAB1
				foreach cashPayment in invLine.allCashPayments do
					if cashPayment.isNotPaidByAPI() then
						found := false;
						
						continue; //30/04/2025	navkc1 JIRA Bug MTN-34734
						
						/* //30/04/2025	navkc1 JIRA Bug MTN-34734
						// ### JIRA 34719 23APR2025 NAVKC1
						if cashPayment.voided then
							lineOwing += cashPayment.cashValue;
						endif;
						
						break;
						*/
					else
						lineOwing -= cashPayment.cashValue; //30/04/2025	navkc1 JIRA Bug MTN-34734
					endif;
				endforeach;
				
				if found then
					continue;
				endif;
			endif;
			
			if invLine.myTransactionTI &lt;&gt; null then
				foreach cashPayment in agent.allCashPayments do
					// ### JIRA 34719 23APR2025 NAVAB1
					if cashPayment.isNotPaidByAPI() then
						continue;
					endif;
					
					proformaDetail := cashPayment.getMyProformaDetails();
					
					if proformaDetail &lt;&gt; null then
						if 	proformaDetail.transactionType = invLine.myTransactionTI.type and
							proformaDetail.myInvoiceLineType = invLine.invoiceLineDesc then
								continue outloop;
						endif;
					endif;
				endforeach;
			endif;
			
			//otherOwing += invLine.lineTotal;
			otherOwing += lineOwing; // ### JIRA 34719 23APR2025 NAVKC1
			
		endforeach;
		
		 // ### JIRA 35008 04JUN2025 NAVAB1
		if otherOwing = 0 then
			foreach cashPayment in _ti.allCashPayments discreteLock do
				if cashPayment.isNotPaidByAPI() 
				and cashPayment.myInvoiceLine = null 
				and not cashPayment.isCancelled()  then  // ### JIRA 35178 23JUN2025 NAVAB1
					otherOwing += cashPayment.cashValue;
				endif;
			endforeach;
		
		endif;
		
		if otherOwing &gt; 0 then	
			// ### JIRA 34988 29MAY2025 NAVAB1
			amountOwing := paymentAmount + otherOwing;
			_allErrorMsgs.add(app.getErrorString5(Cash_cargo_not_paid,_ti.id,debtor.name,amountOwing.String,paymentAmount.String, otherOwing.String));
		endif;
	endif;
	
epilog
	//07 July 2014	NDL	- error 4 while testing Par 34421
	if _proformaLines &lt;&gt; null and not _proformaLines.isEmpty then
		// these have been copied to a local dict and will be delete dby the caller, so clear from the agent so they are not made invalid objs.
		agent.allProformaInvLines.clear(); 
	endif;
	delete agent;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isReceival" type="Boolean"/>
        <Parameter name="_proformaLines" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <Parameter name="_inTranState" type="Boolean"/>
        <Parameter name="_allErrorMsgs" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCashCollectionForVVR" id="3d0a41dc-c3ed-4604-b3db-9b63aff0b4bc">
        <updating/>
        <source>valCashCollectionForVVR( 	_vvr : CM_VehicleVisitRecord input;
							_forReceival : Boolean;
							_forRelease	: Boolean;
							_allProformaLines : ObjectSet input;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2012	cnwer1	Initial creation CCMS MES 1280

*/

vars
//	ti		 : CM_TrackedItem;
//	gteEntity 	: CMGTE_Entity;
	terminal : CM_Terminal;
	status		: Integer;
//	allErrorMsgs : StringArray512;
//	isError : Boolean;
//	error : String;
//	exObj	: CM_Exception;
//	theCargoType	: CM_CargoType;
//	proformaLines : CM_InvoiceLineBySeqNumDict;
//	processedTis : CM_TISet;	//11 Jan 2013	NDL	Par 30921
	tiSet : CM_TISet;	//11 Jan 2013	NDL	Par 30921
begin
	// Always initialize the activity first
	_passport.initialiseTransaction();
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	// epr par  30583 if method returns because cash not enabled or no vvr have to return TRX_Committed so can continue with next trx
	status:=TRXStatus_Committed;
	if _vvr = null or _vvr.allGateEntities.isEmpty  then
		return;
	endif;
	
	terminal:=_vvr.myTerminal;
	
	if not terminal.isCashOnlyEnabled then
		return;
	endif;
	
	/* // ### JIRA 33806 15JAN2025 NAVAB1
	// TFS 41026 this is not needed for PEL1
	if not terminal.isUsingDefaultProcessJMT() then
		return;
	endif;
	*/
	
	self.doProformaValidation(_vvr, _forReceival, _forRelease, _allProformaLines, false, _passport ); // 08 Dec 2016	NDL	TFS 2867
	
/*	create proformaLines transient;
	//receivals have to use the GTE entities because the VVR allReceivedTrackedItems collection is not populated at the time of validation
	
	// unfortunately for releases while the VVR has GTE_Release objects the myTI reference may not be populated if the receival was by type and the TI 
	// was assigned while in the yard
	if _forReceival then
		foreach gteEntity in _vvr.allGateEntities discreteLock do			
			if not gteEntity.isKindOf(CMGTE_Receival) then
				continue;
			endif;		
			ti:=gteEntity.getTI;
			
			// no prenote 
			if ti = null then
				//first recheck if there is a prenote
				theCargoType := app.myRoot.allCargoTypesById[gteEntity.CMGTE_Receival.cargoType];
				if theCargoType = null then
				//	allErrorMsgs.add(app.getErrorString1(REQUIRED_FIELD, 'cargo type'));
					allErrorMsgs.add(app.getErrorString(Input_required_field_cargoType)); // cnwdb2	PAR 35364
					break;
				endif;
				//check again if there is a prenote
				ti := terminal.lookupTrackedItem(gteEntity.id, theCargoType.id, TI_STATE_NOTIFIED, null, false);
				if ti = null then
					ti:=terminal.createTI(theCargoType,true);
					//create ti transient;
					ti.setPxyFromCMGTE_Receival(gteEntity.CMGTE_Receival, _passport);
				endif;
			endif;
			
			self.valCashCollectionForTI(ti,true,proformaLines,allErrorMsgs);	
			if _allProformaLines &lt;&gt; null then
				proformaLines.copy(_allProformaLines);
				proformaLines.clear;		
			endif;
			proformaLines.purge;
			if ti.isTransient then
				delete ti;
			endif;
		endforeach;
	endif;
	
	if _forRelease then
		create processedTis transient;
		if _vvr.allReleasedTrackedItems.isEmpty then
			foreach gteEntity in _vvr.allGateEntities discreteLock do
			
				if not gteEntity.isKindOf(CMGTE_Release) then
					continue;
				endif;
				ti := gteEntity.CMGTE_Release.myTrackedItem;
				if ti = null and gteEntity.CMGTE_Release.id &lt;&gt; null and gteEntity.CMGTE_Release.cargoType &lt;&gt; null then
					ti := gteEntity.CMGTE_Release.findCargo(gteEntity.CMGTE_Release.id, gteEntity.CMGTE_Release.cargoType);
				endif;
				if ti = null then
					continue;
				endif;
				processedTis.add(ti);	//11 Jan 2013	NDL	Par 30921
				self.valCashCollectionForTI(ti,false,proformaLines,allErrorMsgs);
				//don't care about these for release;
				proformaLines.purge;
			
			endforeach;
		else
			foreach ti in _vvr.allReleasedTrackedItems discreteLock do
				processedTis.add(ti);	//11 Jan 2013	NDL	Par 30921
				self.valCashCollectionForTI(ti,false,proformaLines,allErrorMsgs);
				//don't care about these for release;
				proformaLines.purge;
			
			endforeach;
		endif;
		
		//11 Jan 2013	NDL	Par 30921 - catch cargo added on the fly via hand held without a release obj...
		create tiSet transient;
		_vvr.getAllLoadedCargo( tiSet );
		
		foreach ti in tiSet do
			if not processedTis.includes(ti) then
				// it was loaded to the truck during this visit
				if not _vvr.vehicle.locationsController.allTrackedItems.includes(ti) then
					continue;
				endif;
				// and is still on the truck.
				self.valCashCollectionForTI(ti,false,proformaLines,allErrorMsgs);
				//don't care about these for release;
				proformaLines.purge;
			endif;
		endforeach;
		
	endif;
	
	
	isError:=terminal.getConfig(CashProcUnderpayIsError).Boolean;
	
	//
	
	foreach error in allErrorMsgs do
		create exObj transient;
		exObj.set(Cash_cargo_not_paid, error, not isError, null, null, null);
		raise exObj;
	endforeach;
	
	*/
	self.checkValidationWithPassport(_passport);
	if _passport.warningsAcknowledged or not _passport.hasErrorsOrWarnings then
		status := TRXStatus_Committed;
	else
		status := TRXStatus_WarningsToBeAck;
	endif;
	
epilog
	_passport.finaliseTransaction(status);
//	if proformaLines &lt;&gt; null then
//		proformaLines.purge;
//	endif;
//	delete proformaLines;
//	delete processedTis;
//	delete tiSet;

//	delete allErrorMsgs;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_forReceival" type="Boolean"/>
        <Parameter name="_forRelease" type="Boolean"/>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCashReceiptAPIUpdateStatus" id="91693548-9737-4eee-b8f9-51084e2c19d4">
        <source>valCashReceiptAPIUpdateStatus(_pxyCashReceipt : CM_CashReceipt; _realCashReceipt : CM_CashReceipt; _newStatus : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	nextValidStatus : String;
begin

	// ### JIRA 34937 23MAY2025 NAVAB1
	if _realCashReceipt.paymentStatus = CM_CashReceipt.PAID then
		app.raiseCMException1(Cash_recei_fully_paid_cash_col, _realCashReceipt.sequenceNum.String, null, null);
		return;
	endif;

	// Next Status is invalid
	//if not _realCashReceipt.isNextProformaStatusValid(_newStatus, nextValidStatus) then
	if not _realCashReceipt.isNextProformaStatusValid(_newStatus, nextValidStatus, false) then //06/06/2025	navkc1 JIRA MTN 34779
		app.raiseCMException2(Cash_recei_statu_next_valid_st, app.paymentStatusCashEnumToString(_realCashReceipt.paymentStatus), nextValidStatus, null, null);
	endif;
	
	// Validation for differnt status
	if _newStatus = CM_CashReceipt.API_RECEIPT_HOLD then
		// Only the same user can update the status;
		if _realCashReceipt.externalUserCode &lt;&gt; _pxyCashReceipt.externalUserCode then
			app.raiseCMException3(Exter_user_canno_updat_recei_e, _pxyCashReceipt.externalUserCode, _realCashReceipt.sequenceNum.String, _realCashReceipt.externalUserCode, null, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_realCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="valCashReceiptJMTUpdateStatus" id="a0c1ec1f-dc3a-4c45-9d49-8c3c7495389e">
        <source>valCashReceiptJMTUpdateStatus(_pxyCashReceipt : CM_CashReceipt; _realCashReceipt : CM_CashReceipt; _newStatus : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars
	nextValidStatus : String;
begin

	// Next Status is invalid
	if not _realCashReceipt.isNextProformaStatusValid(_newStatus, nextValidStatus, true) then
		app.raiseCMException2(Cash_recei_statu_next_valid_st, app.paymentStatusCashEnumToString(_realCashReceipt.paymentStatus), nextValidStatus, null, null);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_realCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
