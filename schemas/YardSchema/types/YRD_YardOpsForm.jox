    <JadeMethod name="setToDoTaskComplete" id="b7422cdf-426f-4923-bded-6b72ab6065c3">
        <updating/>
        <source>setToDoTaskComplete() updating;
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		Complete selected To Do Tasks
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
// 05 Jul 2024  navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
// -----------------------------------------------------------------------------

vars

	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	tiTask : CM_ToDoTask;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	ti : CM_TrackedItem;
	taskDescCode : Integer;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	tiTrans : CM_TITransaction; //24/05/2023  navmv20 CR 57925 Task 57921
	
	resourceUsageResult : Boolean; //24/05/2023  navmv20 CR 57925 Task 57921
	wodTrans : CM_WOTransaction;   //24/05/2023  navmv20 CR 57925 Task 57921
begin
	if self.myCurrentWLE = null or not self.myCurrentWLE.isKindOf(CM_WOToDoWLE) then
		app.msgBox(app.getErrorString(Select_work_entry_complete),app.getErrorString(Make_selection), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
	tiTask := self.getToDoTask(self.myCurrentWLE.CM_WOToDoWLE);
	taskDescCode := tiTask.toDoTaskDescCode;

	
	//24/05/2023  navmv20 CR 57925 Task 57921 - START
	if self.myCurrentWLE.isForToDoWOTransaction() then
		if not tiTask.toDoTaskDesc.allResourceTypes.isEmpty then // ### TFS BUG 58402 13JUN2023 NAVAB1
			create resourceUsageProxys transient;	// will be populated with template versions of the resources to apply..
			resourceUsageResult := self.myAssistant.showResourceTypeUsageForTxn(null, null, tiTask.toDoTaskDesc, null, resourceUsageProxys, true, null);	//05.07.2024  navbs1  CR 64901 Task 64903
			if resourceUsageResult = false then
				// failed to create the form or was cancelled.
				app.msgBox(app.getErrorString(Resource_Usage_Form_Not_shown),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
				return;
			endif;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateWODTIToDoNoTIComplete(self.myCurrentWLE.CM_WOToDoWLE,tiTask.CM_TiToDoTask,resourceUsageProxys,app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
			theResult := app.showErrorWarningDialog(self.mnuComplete.caption, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;

			break;
		endwhile;
		//refresh table
		self.displayExtraInfoForObj(self.myCurrentWLE);
			
		return;
	endif;
	//24/05/2023  navmv20 CR 57925 Task 57921 - END
	
	ti := self.myCurrentWLE.myTrackedItem;

	create wleArray transient;
	self.getWLEsInTableSelectedOfClass(CM_WOToDoWLE, wleArray);
	
	create realTiSet transient;
	foreach wle in wleArray where self.canCompleteToDoWLE(wle.CM_WOToDoWLE) do
		if wle.myTrackedItem &lt;&gt; null then //57921
			if not realTiSet.includes(wle.myTrackedItem) then
				realTiSet.add(wle.myTrackedItem);
			endif;
		endif;	//24/05/2023  navmv20 CR 57925 Task 57921
		
	endforeach;

	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( taskDescCode, pxyTiSet, ti, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(tiTask.toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.mnuComplete.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.displayExtraInfoForObj(self.myCurrentWLE);
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	delete wleArray;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1446a76e-810f-4f01-85f7-be44dacb0c22">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwrd1	Initial creation
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	str : String;
	filterControl : CMUI_ToolbarFrameTableFilter;
begin
	//05/06/2024	navkc1 CR 63736 Task 63770
	filterControl := self.frmTableFilter;
	filterControl.visible := true;
	
	inheritMethod();

	self.initTblJobs();

	self.positionQueryFrame();
	self.initQueryFrame();
	self.loadTaskTypes();
	self.lstJobs.visible := false;
	self.splOperations.setLeftToRightRatioAndResize(0);
	//self.fldInfo.tabsHeight := 1;	
	self.fldInfo.tabsHeight := -1;	

	self.initMnuPriority();
	self.mnuColourLegend.visible := true;
	self.mnuHideTreeView.visible := false;
	//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.mskDateFrom.setDate(self.systemToLocalTime( app.actualTimeServer().TimeStamp).date );
	
	self.doBuildShiftSearchCombo();
	//app.getErrorString(Arrive_Yard) &amp;' ' &amp;
	
	//self.setCaption( self.caption);

	self.getXMLSettingsForSetup();
	
	//self.frmModeStatusBar.hideMoveModeFrame(false);
	

	//self.cmbOrganisation.listCollection(app.myRoot.allOrganisations, true, 0);
	//self.cmbOperator.listCollection(app.myRoot.allOperators, true, 0);

	self.beginClassNotification(CM_Job, false, Any_System_Event, Response_Continuous, null);	
	
	//self.beginClassNotification(CM_Request, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_WorkListEntry, false, Any_System_Event, Response_Continuous, null);
	
	self.beginClassNotification(CM_YardWLE, false, Object_Delete_Event, Response_Continuous, null);
	
	
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);	
	self.beginClassNotification(CM_YardWLE, false, self.myTerminal.getTerminalEvent(EVENT_WLE_COMPLETE), Response_Continuous, null);	
	
	self.beginClassNotification(CM_WOPackWLE, false, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOPackWLE, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOPackWLE, false, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);	
	
	self.beginClassNotification(CM_WOUnpackWLE, false, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOUnpackWLE, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOUnpackWLE, false, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);	
	
	self.beginClassNotification(CM_WOToDoWLE, false, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOToDoWLE, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOToDoWLE, false, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(CM_WOToDoWLE, false, self.myTerminal.getTerminalEvent(EVENT_WLE_COMPLETE), Response_Continuous, null);
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblWorkEntries.userInputEnabled := false;
		self.btnNewTV.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnDeleteTV.enabled:= false;
		self.btnShowSchedule.enabled:= false;
		self.btnShowWorkMgr.enabled:= false;
		self.btnShowWorkOrder.enabled:= false;
	endif;
	
	filterControl.setupControl(self.tblWorkEntries, null);	//05/06/2024	navkc1 CR 63736 Task 63770
	filterControl.setCallbackMethod(YRD_YardOpsForm::doFilterTable.name); //05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showJobWLE" id="c2e875c0-e797-476b-8b5e-2091e54eaa4b">
        <source>showJobWLE( _job : CM_Job );
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	menuAction : CMUI_MenuAction;
	tpForm : YRD_YardOpsForm;

begin
	menuAction := app.myController.createMenuAction(PmAdmYardOpsView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;

	tpForm := menuAction.goToObject(null, null, false, null).YRD_YardOpsForm;	
	if tpForm = null then
		return;
	endif;
	
	tpForm.setMyCurrentListObjects(_job);

	tpForm.show;	

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="showPack" id="98ecf9a5-30fd-478f-99b1-5291c26b1329">
