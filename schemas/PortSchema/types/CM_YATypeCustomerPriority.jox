    <JadeMethod name="getObjects" id="46d453d0-b3f4-4c8a-9584-2161387f21a0">
        <source>getObjects(objects: ObjectLongNameDict input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 November 2023
TFS#		: 61133
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	customerPriority : CM_CustomerPriority;
begin
	foreach customerPriority in app.myRoot.allCustomerPriorities do
		objects[customerPriority.getYAIdentifier] := customerPriority;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
