*/

vars
	incoMapping: CM_InvoiceINCOMapping;
begin
	incoMapping := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceINCOMapping;
	if incoMapping = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
