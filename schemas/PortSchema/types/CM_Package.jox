    <JadeMethod name="myUser" id="6e12154c-53fd-4502-88ea-9ec0a17c73aa">
        <methodInvocation>mapping</methodInvocation>
        <source>myUser(set: Boolean; _value: CM_User io) mapping;

// Created by cnwdvb1 on 30 June 2006

vars

begin

	// If the user has been deleted then all reports will have
	// been removed by inverses. We simply need to guard against
	// an invalid obj reference. This reference isn't called very often.
	if not set then
		if not global.isValidObject(_value) then
			_value := null;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_User" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="01cd32d7-4b59-404e-897c-6114cbf25996">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created by cnwdvb1 on 26 June 2006
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	package : SelfType;
	completedOK		: Boolean;
	
begin

	package := inheritMethod();
	
	self.allReportTemplates.copy(package.allReportTemplates);
	package.myEmailTemplate := self.myEmailTemplate.pxyCreateUpdateProxy();
	package.myUser := self.myUser;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return package;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete package;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b11c6b11-0f6c-47fd-9988-26091e03fdda">
        <updating/>
        <source>setForCreate(_proxyPackage : CM_Package) updating;

// Created by cnwdvb1 on 26 June 2006

vars

begin

	create self.myEmailTemplate persistent;
	
	self.type			:= _proxyPackage.type;

	self.setForUpdate(_proxyPackage);
	
	self.myRoot		:= app.myRoot;

end;</source>
        <Parameter name="_proxyPackage" type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="1a159281-9d84-4488-9336-4364ffbf5989">
        <updating/>
        <source>setForProxy(	_code, _description : String;
				_emailTemplate 		: CM_EmailTemplate;
				_allReports			: ObjectArray input;
				_user				: CM_User;
				_type				: Integer;
				_sendToDebtorEmail : Boolean;
				_attachExtAttOfInv : Boolean;
				_prefixEmailSubWithInvNo : Boolean) updating;

// Created by cnwdvb1 on 26 June 2006

vars

begin

	self.type				:= _type;
	self.code 				:= _code;
	self.description		:= _description;
	self.myEmailTemplate	:= _emailTemplate;
	self.myUser				:= _user;
	
	if self.isKindOf(CM_PackageInvoice) then
		self.CM_PackageInvoice.sendToDebtorEmail			:= _sendToDebtorEmail;					//navra1 - CR 61910/Task 62303 - 15th Feb 2024
		self.CM_PackageInvoice.attachExtAttOfInv 			:= _attachExtAttOfInv;					//navra1 - CR 61910/Task 62303 - 15th Feb 2024
		self.CM_PackageInvoice.prefixEmailSubWithInvNumber	:= _prefixEmailSubWithInvNo;			//navra1 - CR 61910/Task 62303 - 15th Feb 2024
	endif;
	
	self.allReportTemplates.clear();
	_allReports.copy(self.allReportTemplates);
	
	

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_allReports" type="ObjectArray" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_sendToDebtorEmail" type="Boolean"/>
        <Parameter name="_attachExtAttOfInv" type="Boolean"/>
        <Parameter name="_prefixEmailSubWithInvNo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5fbc3cc0-bf1f-4943-9072-91b12688a057">
        <updating/>
        <source>setForUpdate(_proxyPackage : CM_Package) updating;

// Created by cnwdvb1 on 26 June 2006

vars

begin

	self.allReportTemplates.clear();
	
	_proxyPackage.allReportTemplates.copy(self.allReportTemplates);
	self.myEmailTemplate.setForUpdate(_proxyPackage.myEmailTemplate);
	self.myUser			:= _proxyPackage.myUser;
	self.code			:= _proxyPackage.code;
	self.description	:= _proxyPackage.description;

end;</source>
        <Parameter name="_proxyPackage" type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="validate" id="eb722384-e228-4709-80e8-064f93faaeb3">
        <source>validate(_realPackage : CM_Package);

// Created by cnwdvb1 on 27 June 2006
// 08/12/2014   cnwdb2	PAR #35364

vars

	package : CM_Package;

begin

	if  self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364


	endif;
	
	if  self.type = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Type', null, null);
		app.raiseCMException(Input_required_field_type, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myEmailTemplate = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Email Template', null, null);
	endif;
	
	
	if self.isKindOf(CM_PackageInvoice) then											//navra1 - CR 61910/Task 62303 - 15th Feb 2024
		self.myEmailTemplate.validateForInvoicePackage(self.CM_PackageInvoice);			//navra1 - CR 61910/Task 62303 - 15th Feb 2024
	else																				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
		self.myEmailTemplate.validate();
	endif;																				//navra1 - CR 61910/Task 62303 - 15th Feb 2024
	
	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User', null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364
	endif;
	
	package := app.myRoot.allPackages[self.type, self.code];
	
	if package &lt;&gt; null and package &lt;&gt; _realPackage then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'Package ' &amp; self.code, null, null, null, null);
		app.raiseCMException1(Already_exists_package,self.code, null, null); //cnwdb2	PAR 35364

	endif;

end;</source>
        <Parameter name="_realPackage" type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="52350120-4c3c-40aa-bdd6-6a377e1c8188">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			Validate that the CM_Package is okay to be deleted

Parameters:			

Return Value:		

Date			Who		Reason
27 June 2006	cnwdvb1	Initial Creation
29 March 2012	cnwcs5	par 29012 - should not be able to delete a package if there is a task defined for it
28 January 2019	jlgzm1	TFS42936 Invoice packages can be deleted with an existing task

*/
vars
	coll	:Collection;
begin
	if not self.isKindOf(CM_PackageInvoice) then
		coll := self.allTasks;
		
		if not coll.isEmpty then
			app.raiseCMException1 (ERR_CANNOTDELETEPACKAGE, coll.size.String, null, null);
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
