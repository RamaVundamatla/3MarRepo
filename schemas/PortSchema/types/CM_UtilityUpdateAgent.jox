    <JadeMethod name="utlUpdateBOLHeader" id="ffde2f78-a525-4894-9725-c6ea3e3d16e0">
        <updating/>
        <source>utlUpdateBOLHeader(_intFaceBOL : CMIF_BOLOut input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 18 Jul 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	pxyBOLOut,
	realBOLOut			: CM_BOLOut;
	expectedEdition		: Integer;
	ao					: CM_AuditObject;
	updCntrl	: CMIF_TIUpdateController;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	_intFaceBOL.validateForUpdate(_passport);
	
	realBOLOut := _intFaceBOL.myPersistentBOL.CM_BOLOut;
	pxyBOLOut := _intFaceBOL.myProxyBOL.CM_BOLOut;
	pxyBOLOut.setFromCMIF_BOLOut(_intFaceBOL);
	
	app.myValUA.valBOL(pxyBOLOut, true, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if realBOLOut = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BOL.number.String, null, null);
		return;
	endif;
	
	exclusiveLock(realBOLOut);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBOLOut, true);
	endif;
	
	realBOLOut.setFromCMIF_BOLOut(_intFaceBOL);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBOLOut, false);
	endif;
	
end;</source>
        <Parameter name="_intFaceBOL" type="CMIF_BOLOut" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBOLIn" id="8071c4f1-6d86-4f13-a833-96f504999336">
        <updating/>
        <source>utlUpdateBOLIn(_proxyBOL : CM_BOLIn input; _passport : CM_Passport input) updating;
//
// cnwrs1 CCMS MES 1008 1036 20 Jan 2010
//
vars
	terminal : CM_Terminal;
	realBOL : CM_BOLIn;
	expectedEdition : Integer;
	tmpEvent : Integer;
	realDocketError : CM_DocketError;
	docketError	: CM_DocketError;
	ext	: CM_BOLExtLogIn;
	allNewBOLDtlProxies : CM_ObjectArrayActual;
begin
	app.setContinueCMExceptions(false);

	_proxyBOL.raiseExceptionIfNotProxy(method);
	
	//validate and update the proxy docket first as attachments are set from the docket
	app.myValUA.valBOL(_proxyBOL, false, _passport);

	endLoad;	// free up any validation locks
	
	create allNewBOLDtlProxies transient;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_proxyBOL.pxyGetRealObjectAndEdition(realBOL, expectedEdition);
	app.setContinueCMExceptions(true);
	
	if not  _proxyBOL.allDocketErrors.isEmpty() then 
		docketError := _proxyBOL.allDocketErrors.first();
		realDocketError := docketError.pxyGetRealObject();
	endif;
	if realBOL = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BOL.number.String, null, null);
		return;
	endif;

	terminal := _passport.myTerminal;
	exclusiveLock(realBOL);

	if _passport.noErrors and realBOL.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Docket', null, null);
		return;
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realBOL, true);		
	endif;

	if _passport.noErrors then
		realBOL.setForUpdate(_proxyBOL, app.myPassport);		
	endif;
	
	if realDocketError = null and not _proxyBOL.allDocketErrors.isEmpty() then
		create realDocketError persistent;
		
		realDocketError.setForUpdate(_proxyBOL.allDocketErrors.first());
		realDocketError.setMyDocketErrorType(_proxyBOL.allDocketErrors.first().myDocketErrorType);
		realBOL.allDocketErrors.purge();
		
		if realDocketError.myDocketErrorType &lt;&gt; null then
			realDocketError.setMyBol(realBOL);
		endif;		
		
	elseif not _proxyBOL.allDocketErrors.isEmpty() and realDocketError.myDocketErrorType &lt;&gt; null then
		realDocketError.setMyBol(realBOL);
		
	elseif realBOL.allDocketErrors &lt;&gt; null then
		realBOL.allDocketErrors.purge();
		
	endif;
	
	if realBOL.bolType = BOLType_Log and realBOL.isInward then
		if realBOL.CM_BOLIn.isMatched then
			ext := realBOL.myExtension.CM_BOLExtLogIn;
			if (not ext.isMatchedAndMoved) then
				// docket was matched but not moved into the yard, move them to new location
				app.writeLog(method.name &amp; '  moving BOL to planned location', LogINFO);
				ext.completeRoadInProcessForBOL(_passport);
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		realBOL.setForUpdateBOLDtl(_proxyBOL, allNewBOLDtlProxies, null);
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realDocketError, false);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realBOL, false);		
		tmpEvent := realBOL.myTerminal.getTerminalEvent(BOLRecon_Update_Event);
		terminal.causeEvent(tmpEvent, false, realBOL);
		tmpEvent := realBOL.myTerminal.getTerminalEvent(Event_BOLUpdate);
		terminal.causeEvent(tmpEvent, false, realBOL);
		
	
		realBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE); // ### TFS 53105 30MAY2022 NAVAB1
		
	endif;
epilog
	if allNewBOLDtlProxies &lt;&gt; null then //par 23484 cnwrs1 31 mar 2010
		allNewBOLDtlProxies.purge; //par23228 cnwrs1 17 Mar 2010
	endif;
	delete allNewBOLDtlProxies; //par23228 cnwrs1 17 Mar 2010
end;
</source>
        <Parameter name="_proxyBOL" type="CM_BOLIn" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBOLInCusCar" id="cc10a148-4202-4853-af60-22cd5cddf7f8">
        <updating/>
        <source>utlUpdateBOLInCusCar(_realCar : CM_Car input; _passport : CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 September 2006 By cnwth2

Purpose:	CCMS# 1032 for centreport - automatically create BOL for car to enable
			matching when loading CusRes file

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	expectedEdition			: Integer;
	receivalBOL				: CM_BOLIn;
	
begin

	self.initialiseActivity();
	
	if _realCar = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Car.name, null, null);
		return;
	endif;
	
	//assumes the car has already been validated
	app.setContinueCMExceptions(false);
	if _realCar.billOfLading = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Bill of Lading (CusCar required)', ETRow_BillOfLading, null);
		app.raiseCMException(Input_required_field_billOfLad, ETRow_BillOfLading, null); // cnwdb2	PAR 35364
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	receivalBOL := _realCar.myReceivalBOL;
	if receivalBOL &lt;&gt; null then
		if receivalBOL.number = _realCar.billOfLading then
			//nothing to do - it's already on the correct BOL
			return;
		else
			_realCar.setMyReceivalBOL(null);
		endif;
	endif;
	
	//find an existing bill of lading to add the car to - if none then create
	receivalBOL := _realCar.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, _realCar.billOfLading, null);
	if receivalBOL = null or receivalBOL.number = _realCar.billOfLading then
		receivalBOL := _passport.myTerminal.allBOLsReceivedByTypeNumberDT.getAtKeyGeq(BOLType_GeneralBillOfLading, _realCar.billOfLading, null).CM_BOLIn;
		if receivalBOL &lt;&gt; null and receivalBOL.number &lt;&gt; _realCar.billOfLading then
			receivalBOL := null;
		endif;
	endif;
	
	if receivalBOL = null then
		//create a new one with entered number and associate it with the selected voyage
		create receivalBOL persistent;
	endif;
	receivalBOL.setCusCarDetails(_realCar.billOfLading,
									_realCar.myVoyage,
									app.myRoot.allOperators[_realCar.operatorCode]);
									
	_realCar.attachToBOL(receivalBOL);
	
epilog
	
end;


</source>
        <Parameter name="_realCar" type="CM_Car" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBOLOutHeader" id="43676069-10a7-4a3c-b481-73a6922b98e6">
        <updating/>
        <source>utlUpdateBOLOutHeader(_pxyBOLOutHdr : CM_BOLOutHeader; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars
	realBOLOutHdr	: CM_BOLOutHeader;
	expectedEdition	: Integer;
	terminal		: CM_Terminal;
	
begin

	self.initialiseActivity();
	_pxyBOLOutHdr.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	_pxyBOLOutHdr.pxyGetRealObjectAndEdition(realBOLOutHdr, expectedEdition);
	
	if realBOLOutHdr = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BOLOutHeader.name, null, null);
		return;
	endif;

	app.myValUA.valBOLOutHdr(realBOLOutHdr, _pxyBOLOutHdr);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realBOLOutHdr);

	if _passport.noErrors and realBOLOutHdr.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'BOL Out Header', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBOLOutHdr, true);
	endif;
	
	if _passport.noErrors then
		realBOLOutHdr.setForUpdate(_pxyBOLOutHdr);
	endif;
	terminal := _passport.myTerminal;
	if _passport.noErrors then
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, realBOLOutHdr);	
		self.myUpdateAuditAgent.audUpdateGeneric(realBOLOutHdr, false);
	endif;

end;</source>
        <Parameter name="_pxyBOLOutHdr" type="CM_BOLOutHeader"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBOLStatus" id="e185bc52-7e75-473d-a436-ff13e17a65a3">
        <updating/>
        <source>utlUpdateBOLStatus(_bolArchiveController : CMIF_BOLArchiveController; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOut			: CM_BOLOut;
	statusToAssign	: Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	
	if _bolArchiveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Archive controller passed in was null');
		return;
	endif;
	
	statusToAssign := _bolArchiveController.archiveStatus;
	
	if statusToAssign = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '"Status to assign" on the archive controller passed in was null');
		return;
	endif;
	
	foreach bolOut in _bolArchiveController.allBOLOuts do
		bolOut.setStatus(statusToAssign);
	endforeach;

end;</source>
        <Parameter name="_bolArchiveController" type="CMIF_BOLArchiveController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
