    <JadeMethod name="doBtnUpdateClickNew" id="73cf64ff-7378-47d7-9723-9a660c1caefd">
        <source>doBtnUpdateClickNew();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 January 2023	navkc1	Initial creation TFS CR 55305 Task 55537 UI - Invoice List UI changes
29 May 2023  	navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023		navkc1	Bug 58995: EUP - Inv Maint Credit Notes
11 Sep 2023 	navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
21 Oct 2024		navlw1	Bug Jira MTN-33151: QTS - 1090 issue with the form being null when we do not have the correct permissions
*/

vars
	//form 	: INV_CreditNoteMaint; //29/05/2023 navmv20 Bug 58090
	//form    : CM_BaseForm; 		   //29/05/2023 navmv20 Bug 58090
	form	: INV_InvoiceUpdate; //20/07/2023	navkc1	Bug 58995
	invoice : CM_Invoice;
begin
	invoice := self.myCurrentInvoice;
	
	if invoice = null then
		return;
	endif;
	
	//create form transient; //29/05/2023 navmv20 Bug 58090
	
	//form.myParentForm := self; //29/05/2023 navmv20 Bug 58090
	
//20/07/2023	navkc1	Bug 58995	
//	if invoice.isCreditNote() then
//		create form as INV_CreditNoteMaint transient; //29/05/2023 navmv20 Bug 58090
//		form.INV_CreditNoteMaint.myCreditNote := invoice; //29/05/2023 navmv20 Bug 58090
//		form.INV_CreditNoteMaint.mode := INV_CreditNoteMaint.Mode_UpdateCreditNote;
//		form.INV_CreditNoteMaint.setMyBank(self.myCurrentBank); //29/05/2023 navmv20 Bug 58090
//	else
		//29/05/2023 navmv20 Bug 58090 - START
		//form.myFirstInvoiceFromParent := invoice;
		//form.mode := INV_CreditNoteMaint.Mode_UpdateInvoice;
		
		//20/07/2023	navkc1	Bug 58995
		form := app.loadForm(INV_InvoiceUpdate, INV_Assistant, false, false, false, self.myTerminal, null).INV_InvoiceUpdate;
		// Start navlw1 #MTN-33151
		if form = null then
			return;
		endif;
		// End navlw1 #MTN-33151
		
		//create form as INV_InvoiceUpdate transient;
		form.includeArchivedVoyages := self.btnIncludeArchive.value;	//11.9.2023 navhl20 #59376
		form.INV_InvoiceUpdate.setMyCurrentBank(self.myCurrentBank);
		form.INV_InvoiceUpdate.setCurrentInvoice(invoice);
		
		//29/05/2023 navmv20 Bug 58090 - END
//	endif;
	
	//29/05/2023 navmv20 Bug 58090 - START
	//form.setMyBank(self.myCurrentBank);
	form.setMyTerminal(self.myTerminal);
	form.myParentForm := self;
	//29/05/2023 navmv20 Bug 58090 - END
	
	form.showModal();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBOLBuild" id="1d08157c-a54b-4812-a572-afab4c30f39b">
        <source>doCmbBOLBuild(_voyage : CM_Voyage) protected;

/*

Purpose:			33528 BOL search via combo box
					33880 
Parameters:			

Return Value:		


Date		Who		Reason
21 February 2014	cnwjre1	Initial creation

*/

vars
	voyageBolNumbers	: StringArray;
	bolNumber			: String;
begin
	self.cmbBOL.clear();
	if _voyage &lt;&gt; null then
		create voyageBolNumbers transient;
		_voyage.getImportBOLNumbers(voyageBolNumbers);
		foreach bolNumber in voyageBolNumbers do
			self.cmbBOL.addItem(bolNumber);
		endforeach;
	endif;
epilog
	delete voyageBolNumbers;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="b7640a2e-b503-483c-8af2-b7db253049b7">
        <source>doCmbBankBuild(_combo : CMUI_ComboBox input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aTerm : CM_Terminal;
	company:  CM_Bank;
	failedDAC  :CM_DataAccessController;
begin
	_combo.clear;
	_combo.sorted := false;

	if self.mode = INV_ListInvoices.Mode_MultiTerminal then
		// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
		_combo.addItem(app.getErrorString(AllBusinessUnits));
		foreach aTerm in app.myRoot.allTerminals discreteLock do
			if not aTerm.canUserAccessSelf(app.myPassport.myUser,failedDAC, app.myPassport) then
				continue;
			endif;
			
			foreach company in aTerm.companies do
				if company.isBusinessUnit then
					_combo.addItem(company.code &amp; " (" &amp; aTerm.code &amp; ")");
					_combo.itemObject[_combo.newIndex] := company;
				endif;
			endforeach;
		endforeach;
		_combo.listIndex := 1;
	else
		_combo.addItem(app.getErrorString(AllBusinessUnits));// PAR 16382
		foreach company in self.myTerminal.companies do
			if company.isBusinessUnit then
				_combo.addItem(company.code);
				_combo.itemObject[_combo.newIndex] := company;
			endif;
		endforeach;
		if self.myCurrentBank &lt;&gt; null then
			_combo.listObject := self.myCurrentBank;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbCargoIdBuild" id="0d60a73b-b324-493c-8375-fbd9e9956e9b">
        <updating/>
        <source>doCmbCargoIdBuild() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2012	cnwer1	Initial creation SFW 1295
06 May 2024 navnk30 Defect 63947: MTN - (14051) Invalid table row error and 1090 exception on the Invoice List Form when searching for the invoices

*/

vars
	cargoTypeID : Integer;
	site : Integer;
	voyage : CM_Voyage;
	coll : Collection;
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	site:= self.filterCargoSite;
	self.filterCargoType:=self.cmbCargoType_.listObject.CM_CargoType;
	if self.filterCargoType &lt;&gt; null then			//06.05.2024 navnk30 #63947
		cargoTypeID :=self.filterCargoType.id;
	endif;
	voyage:=filterCargoVoyage; 
	cmbCargoID_.clear;
	if site = TI_SITE_ONSITE then
		if voyage &lt;&gt; null then
			coll :=voyage.allOnsiteTIsByCargoTypeId;
		else
			coll:=self.myTerminal.allOnsiteTIsByCargoTypeId;
		endif;
		iter:= coll.createIterator;
		coll.CM_TIByCargoTypeIdDict.startKeyGeq(cargoTypeID,null, iter);
	elseif  site = TI_SITE_OFFSITE then
		if voyage &lt;&gt; null then
			coll :=voyage.allOffsiteTIsByCargoTypeId;
		else
			coll:=self.myTerminal.allOffsiteTIsByCargoTypeId;
		endif;
		iter:= coll.createIterator;
		coll.CM_TIByCargoTypeIdRelseDict.startKeyGeq(cargoTypeID,null, null,iter);
	elseif site = TI_SITE_ONSHIP then
		if voyage &lt;&gt; null then
			coll :=voyage.allOnshipTIsByCargoTypeId;
		else
			return;
		endif;
		iter:= coll.createIterator;
		coll.CM_TIByCargoTypeIdDict.startKeyGeq(cargoTypeID,null, iter);
	elseif site = TI_SITE_TBA then
		if voyage &lt;&gt; null then
			coll :=voyage.allTbaTIsByCargoTypeId;
		else
			coll:=self.myTerminal.allTbaTIsByCargoTypeId;
		endif;
		iter:= coll.createIterator;
		coll.CM_TIByCargoTypeIdDict.startKeyGeq(cargoTypeID,null, iter);
	endif;
	
	while (iter.next(ti)) do
		if (cargoTypeID &lt;&gt; ti.cargoType) then
			break;
		endif;
		cmbCargoID_.addItemObject(ti.id, ti);
	endwhile;
	
	self.setEnableObjects();
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbCargoSiteBuild" id="0461b6b8-467e-4824-a022-22c325db9ec3">
        <source>doCmbCargoSiteBuild();
/* ---------------------------------------------------------------------------
Created:	10 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.cmbCargoSite_.sorted := false;
	self.cmbCargoSite_.addItem(app.getErrorString(INV_On_Site));
