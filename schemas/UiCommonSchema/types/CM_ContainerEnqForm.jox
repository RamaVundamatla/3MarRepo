    <JadeMethod name="btnTranship_click" id="394e831a-f308-4e53-a48c-5c77142505f2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTranship_click(btn: Button input) updating;

vars
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	obj : Object;
begin
	create tiArray transient;

	if 	self.useTblData	= false then 
		ti := self.myCurrentObject.CM_TrackedItem;
		tiArray.add(ti);	
	else
		self.tblData.allSelectedObjects.copy(tiArray);
		
	endif;
	
	self.myAssistant.showTranshipDetailForm(tiArray);
	
epilog
	delete tiArray;

end;</source>
