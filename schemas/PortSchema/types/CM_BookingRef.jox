    <JadeMethod name="setProxyBasic" id="c329e211-0775-4059-b212-b9960deb869a">
        <updating/>
        <source>setProxyBasic(	_bookingNum : String;
				_terminal : CM_Terminal;
				_voyage : CM_Voyage;
			   _operatorCode : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlger1	Initial creation 38518

*/

vars

begin
	self.bookingReference:=_bookingNum;
	self.myTerminal:= _terminal;
	self.myVoyage:=_voyage;
	self.myOperator:=app.myRoot.allOperators[_operatorCode];
	self.status:=BOOKING_REF_ACTIVE;
epilog

end;</source>
        <Parameter name="_bookingNum" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operatorCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromInterface" id="34870ada-a924-415a-b0ec-089a45ae5698">
        <updating/>
        <source>setProxyFromInterface(	pBookingRef : String;
						pStatus : Integer;
						pConsignorRef, pDestinationPort, pDischargePort : String;
						pTranshipToPort : CM_Port;
						pDischargePorts 	: StringArray;
						pConsignor 		: CM_ConsigneeConsignor; 
						pConsignee 		: CM_ConsigneeConsignor; 
						pOperator 			: CM_Operator; 
						pVoyage 			: CM_Voyage; 
						pBookingRemarks 	: String;
						pTerminal 			: CM_Terminal;
						pIsMultiItem 		: Boolean;
						pIsStockBookingRef : Boolean;//aer 29/05/08 CCMS 1618
						_itemInterface 		: CMIF_BookingRefItem;
						pShippingRef  		: String; // AER 30/06/2008
						_carrierReference	:String;		// par 27460 cnwcs5
						pDirectDelivery : Boolean
						) updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// ---------------------------------------------------------------------------
vars
	tmpHazards	: CM_HazardByCodeDict;
	
begin
	self.raiseExceptionIfNotTransient(method);
	//self.bookingReference	:= pBookingRef;
	//self.bookingReference	:= pBookingRef.trimBlanks;	//22 Oct 2013	NDL	Par 32553
	self.setBookingReference( pBookingRef.trimBlanks );	//06 Dec 2017	NDL	TFS 8013
	
	if _itemInterface &lt;&gt; null then
//		self.bolType			:= _itemInterface.bolType; // adm 160310 Par 22937 remove bolType
		self.cargoType			:= _itemInterface.cargoType;
		self.clean				:= _itemInterface.clean;
		self.commodity 			:= _itemInterface.commodity;
		self.cubicMetres		:= _itemInterface.cubicMetres;
		self.description 		:= _itemInterface.description;
		self.density			:= _itemInterface.density.Integer;		// MES1008
		self.setHumidity( _itemInterface.getHumidity );
		self.inspected			:= _itemInterface.inspected;
		self.isoType			:= _itemInterface.isoType;
		self.remarks			:= _itemInterface.remarks;
		self.temperature		:= _itemInterface.temperature;
		self.ventilation		:= _itemInterface.ventilation;
		self.weight				:= _itemInterface.weight;
		self.height				:= _itemInterface.height;
		self.length				:= _itemInterface.length;
		self.width				:= _itemInterface.width;
		self.heightString		:= _itemInterface.heightString;
		self.lengthString		:= _itemInterface.lengthString;
		self.widthString		:= _itemInterface.widthString;
		self.typeString			:= _itemInterface.typeString;
		self.volume				:= _itemInterface.volume;
		self.productQuantity	:= _itemInterface.productQuantity;
		self.quantity			:= _itemInterface.quantity;
		self.myProduct			:= _itemInterface.myProduct;
		self.myEDIBookingRefTI  := _itemInterface.myEDIBookingRefTI;
		self.rawEDIData 		:= _itemInterface.rawEDIData;
		create tmpHazards transient;
		_itemInterface.allTIHazards.copy(tmpHazards);
		self.setPxyHazards(tmpHazards);		//CCMS 1203
	endif;
	
	self.consignorReference	:= pConsignorRef;
	self.destinationPort	:= pDestinationPort;
	self.setDirectDelivery( pDirectDelivery );	//29 Jan 2013	NDL	Par 31102
	self.dischargePort		:= pDischargePort;
	//self.myTranshipToPort	:= pTranshipToPort;
	self.setTranshipToPort( pTranshipToPort, false );	//07 Sep 2012	NDL	Par 29684
	
	self.allDischargePorts.clear;
	pDischargePorts.copy(self.allDischargePorts);

	self.myConsignor		:= pConsignor;
	self.myConsignee		:= pConsignee;
	// self.myOperator is done below in references
	
	self.myVoyage			:= pVoyage;
	self.bookingRefRemarks	:= pBookingRemarks;
	self.isMultiItemBookingRef := pIsMultiItem; //aer 29/05/08 CCMS 1618
	self.isStockBookingRef  := pIsStockBookingRef; 
	self.shippingReference  := pShippingRef; //AER 30/06/2008 par 17421
	self.operatorReferenceNumber	:= _carrierReference;	// par 27460 cnwcs5
	// set the references with inverses that will add to the appropriate collections
	self.myOperator			:= pOperator;
	self.myTerminal			:= pTerminal;
	
	self.setStatus(pStatus);
epilog
	delete tmpHazards;
end;</source>
        <Parameter name="pBookingRef" type="String"/>
        <Parameter name="pStatus" type="Integer"/>
        <Parameter name="pConsignorRef" type="String"/>
        <Parameter name="pDestinationPort" type="String"/>
        <Parameter name="pDischargePort" type="String"/>
        <Parameter name="pTranshipToPort" type="CM_Port"/>
        <Parameter name="pDischargePorts" type="StringArray"/>
        <Parameter name="pConsignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="pConsignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="pOperator" type="CM_Operator"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pBookingRemarks" type="String"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pIsMultiItem" type="Boolean"/>
        <Parameter name="pIsStockBookingRef" type="Boolean"/>
        <Parameter name="_itemInterface" type="CMIF_BookingRefItem"/>
        <Parameter name="pShippingRef" type="String"/>
        <Parameter name="_carrierReference" type="String"/>
        <Parameter name="pDirectDelivery" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPxyHazards" id="798954a8-6665-4fb6-98db-9bdbcc1ed593">
        <updating/>
        <source>setPxyHazards(_hazards : CM_HazardByCodeDict) updating;
//----------------------------------------------------------------
//	Created:	05 April 2004	by Jason Chapman  (cnwjc2)
//	Updated:	27 May 2009		cnwjo3	need to call this method from form
// Changed On	By			Reason
// ----------	-------		------------------------------------------
// 27/05/2009	cnwjo3		need to call this method from form
// 11/06/2015	cnwdap1		PAR #36421 Change in signature for CM_TIHazard::setProxy
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
//----------------------------------------------------------------
vars
	obj		: Object;
	tiHaz	: CM_TIHazard;
	newHaz	: CM_TIHazard;
begin
	self.allTIHazards.purge;	//just clear NO

	if _hazards.isEmpty then
		return;
	endif;
	
	foreach obj in _hazards do
		if CM_TIHazard.hasInstance(obj) then
			tiHaz := obj.CM_TIHazard;
			create newHaz transient;
			//is transient need to use setProxy
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity);					// PAR #36421
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity, tiHaz.packingGroup);	// TFS 2842
			newHaz.setProxy(	tiHaz.code, 							// TFS 2842
								tiHaz.description, 						// TFS 2842
								tiHaz.allUNDGCodes.asCSV(false),		// TFS 2842
								null,									// TFS 2842
								tiHaz.limitedQuantity, 					// TFS 2842
								tiHaz.packingGroup,						// TFS 2842
								tiHaz.flashpointTemperature,			// TFS 2842
								tiHaz.isMarinePollutant,				// TFS 2842
								tiHaz.acidsBases	);					// TFS 2842
			self.allTIHazards.add(newHaz);
		endif;
	endforeach;

end;</source>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setPxySpecialStow" id="5ebf3bbf-228d-4a85-9f0a-ea6b9315612f">
        <updating/>
        <source>setPxySpecialStow(_specialStow : CM_SpecialStow) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwjo3
