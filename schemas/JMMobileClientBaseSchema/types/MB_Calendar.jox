    <JadeMethod name="buildSelf" id="5976c877-51e4-403c-80bc-39a6a35e31d7">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	datToday: Date;

begin
	self.createButton(self.myPrevMonthButton, 0, "&lt;");
	self.myPrevMonthButton.tabIndex	:=	tabIndex + 1;
	self.createLabel(self.myMonthLabel, self.myPrevMonthButton.width, clientWidth * MonthLabelWidthRatio, datToday.monthName);
	self.createButton(self.myNextMonthButton, self.myMonthLabel.left + self.myMonthLabel.width, "&gt;");
	self.myNextMonthButton.tabIndex	:=	tabIndex + 2;
	self.createButton(self.myPrevYearButton, self.myNextMonthButton.left + self.myNextMonthButton.width, "&lt;");
	self.myPrevYearButton.tabIndex	:=	tabIndex + 3;
	self.createButton(self.myNextYearButton, clientWidth - self.myPrevYearButton.width, "&gt;");
	self.myNextYearButton.tabIndex	:=	tabIndex + 4;
	
	self.createLabel(	self.myYearLabel,
						self.myPrevYearButton.left + self.myPrevYearButton.width,
						self.myNextYearButton.left - self.myPrevYearButton.left - self.myPrevYearButton.width,
						datToday.year.String);
	
	self.createTable(self.myMonthTable, self.myPrevMonthButton.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="click" id="f3e0d10b-8b42-40ff-9bc4-89b3d3958a00">
