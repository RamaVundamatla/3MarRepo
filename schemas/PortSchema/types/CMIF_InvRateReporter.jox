    <JadeMethod name="getEffectiveTimestampLocalTZ" id="04e35b51-ae59-4a2a-9991-82ff4482a1d4">
        <source>getEffectiveTimestampLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.effectiveTimestamp);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getExpiryTimestampForReport" id="b76e3154-db37-4d3c-b20e-cae35fed2cf2">
        <source>getExpiryTimestampForReport() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 25 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	if not self.expiryTimestamp.isValid() then
		return '';
	else
		return self.expiryTimestamp.asStringJMT();
	endif;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExpiryTimestampLocalTZ" id="7ee8b1bf-3fca-4a83-bd54-509f5caa577f">
