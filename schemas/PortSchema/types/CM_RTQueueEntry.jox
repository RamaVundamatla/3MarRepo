    <JadeMethod name="getTaskOfType" id="1d9a830e-604c-499e-af4c-e14488efd4f3">
        <source>getTaskOfType(taskType : Integer; _status : Integer) : CM_RTQueueTask;
//Returns the 1st available task of the type requested.
//See global variables for allowable types.
vars
	aTask	: CM_RTQueueTask;
begin

	foreach aTask in self.allTasks do
		if aTask.taskType = taskType then
			//-------------------
			//If its unactioned (or in a pending state), return it.
			//Ignore all others.
			//-------------------
			if _status &lt;&gt; 0 then
				if _status = aTask.status then
					if process.isInTransactionState then
						exclusiveLock(aTask);
					endif;
					return aTask;
				endif;
			else
				if aTask.status = TASK_UNACTIONED or 
					 aTask.status = TASK_PENDING then
					if process.isInTransactionState then 
						exclusiveLock(aTask);
					endif;
					return aTask;
				endif;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="taskType" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
