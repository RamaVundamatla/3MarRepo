	lblCreatedBy.translateCaption(Xlat_0024960, locale);
	lblDataAction.translateCaption(Xlat_0026877, locale);
	lblDateFrom.translateCaption(Xlat_0026878, locale);
	lblDateTo.translateCaption(Xlat_0026879, locale);
	lblEWSName.translateCaption(Xlat_0026880, locale);
	lblInterfaceName.translateCaption(Xlat_0024421, locale);
