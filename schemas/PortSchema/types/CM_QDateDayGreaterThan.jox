    <JadeMethod name="doMatch" id="1734d95e-0d7b-4fd0-8602-7a64ced95c4b">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if not _value.Date.isValid then //par #17512. Ready for 7.7.1
		return false;
	endif;
		
	return  searchValue.Integer&lt; (app.actualTimeServer.date - _value.Date);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="c6efba28-52f5-43b4-a71c-6345d148ccb4">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin
	
	_searchValueA			:= self.searchValue.asStringJMT();
	_searchValueB			:= null;
	_searchValueBoolean		:= null;
	_isStringProperty		:= true;
	_isStringBetweenProperty:= false;
	_isBooleanProperty		:= false;
	
end;
</source>
