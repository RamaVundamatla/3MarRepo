    <ImplicitInverseRef name="btnClose" id="c09fe95c-6635-4d71-bc6e-049294f9fb02">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblSummary" id="2f535a83-327f-49e7-b293-47280b2db46c">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnClose_click" id="4ba47246-68e1-44e0-bfde-157c8724636a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="6370afac-9226-4dbf-bdfe-0cfc88aa2adb">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 116 then // F5
		self.loadTheLot;
		keyCode := 0;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="f1afc81d-2abf-4553-a502-5af5c59a2e36">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.loadTheLot;
	self.resizeTheLot;
	self.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTheLot" id="8a0a90f6-cadf-4cb8-a9c6-03e1fef94197">
        <updating/>
        <source>loadTheLot() updating, protected;

vars
	profileName, prevProfileName, s : String;
	d : ProcessDescProfileProcessDict;
	pd : ProcessDescriptor;
	iter : Iterator;
	n, t : Integer;
	tbl : Table;
	p : Process;
	
begin
	tbl := self.tblSummary;
	
	tbl.rows := tbl.fixedRows;
	tbl.accessCell(1, 1).text := "Profile" &amp; Tab &amp; "Processes";
	tbl.accessColumn(2).alignment := Table.Alignment_Center;

	d := app.mySession.allProcessDescsByProfileProc;
	iter := d.createIterator;

	profileName := null;
	prevProfileName := null;
	n := 0;
	t := 0;
		
	while iter.next(pd) do
		d.getIteratorKeys(profileName, p, iter);
		
		if prevProfileName &lt;&gt; null and profileName &lt;&gt; prevProfileName then
			tbl.addItem(prevProfileName &amp; Tab &amp; n.String);
			n := 0;
			t := t + 1;
		endif;
		
		n := n + 1;
		prevProfileName := profileName;
	endwhile;
	
	if n &gt; 0 then
		tbl.addItem(prevProfileName &amp; Tab &amp; n.String);
		t := t + 1;
	endif;
	
	if d.size = 1 then
		s := "1 Process, ";
	else
		s := d.size.String &amp; " Processes, ";
	endif;
	
	if t = 1 then
		s := s &amp; "1 Profile";
	else
		s := s &amp; t.String &amp; " Profiles";
	endif;

	self.caption := "Profile Summary: " &amp; s;	
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="3775a7c0-9f9a-4192-bbb0-c707805c1a46">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	self.resizeTheLot;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTheLot" id="53e8aae6-f941-4608-9627-afce79728197">
        <source>resizeTheLot() protected;

begin
	self.btnClose.top := self.clientHeight - self.btnClose.height - 4;
	self.btnClose.left := self.clientWidth - self.btnClose.width - 4;
	
	self.tblSummary.move(4, 4, self.clientWidth - 8, self.btnClose.top - 8);
	
	self.tblSummary.columnWidth[1] := (self.tblSummary.clientWidth * 0.8).Integer;
	self.tblSummary.columnWidth[2] := self.tblSummary.clientWidth - self.tblSummary.columnWidth[1];
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
