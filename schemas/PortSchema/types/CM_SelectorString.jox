<Class name="CM_SelectorString" id="c3367214-a687-4ac8-9f58-e140f65f49e6">
    <superclass name="CM_SelectorObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="value" id="d970a993-bd60-4240-bc46-24bed3194a40">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getMethodText" id="03236bba-2c0a-4a0c-9934-efb51a53e616">
        <source>getMethodText(): String;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	str := 'if self.' &amp; self.attrName &amp; ' ' &amp; self.operator &amp; ' "' &amp; self.value &amp; '" then' &amp; CrLf &amp;
		   Tab &amp; 'return true;' &amp; CrLf &amp;
		   'endif;';

	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="ebb0b834-5f27-4c9b-b165-d0932608b3be">
        <updating/>
        <source>set(pName, pValue, pOperator : String) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.attrName	:= pName;
	self.value		:= pValue;
	self.operator	:= pOperator;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <Parameter name="pOperator" type="String"/>
    </JadeMethod>
</Class>
