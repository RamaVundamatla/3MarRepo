<Class name="CM_VesselTankVessel" id="5e5bf211-fe31-4da2-8a6d-3a2b80d67ebc">
    <superclass name="CM_VesselTank"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myVesselStructuralElement" id="816808d6-bc71-4de0-bec9-76e36e1e48a6">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VesselStructuralElements"/>
        <access>readonly</access>
        <Inverse name="CM_VesselStructuralElements::allTanks"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVesselStructure" id="d2099263-2f3b-47a5-8482-c49eb421c0b1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VesselStructure"/>
        <access>readonly</access>
        <Inverse name="CM_VesselStructure::allTanks"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelf" id="ae7bc46f-a2d2-445b-8636-8b392cf00c86">
        <updating/>
        <source>cloneMySelf(_newVessel : CM_VesselStructuralElements) : CM_VesselTankVessel updating;
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	newMe : SelfType;
begin
	newMe := self.cloneSelf(false);
	//newMe.myVesselStructure := _newVessel;
	newMe.myVesselStructuralElement := _newVessel;
	newMe.myVesselTankType := self.myVesselTankType;
		
	return newMe;

end;</source>
        <Parameter name="_newVessel" type="CM_VesselStructuralElements"/>
        <ReturnType type="CM_VesselTankVessel"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelfForVoyage" id="bf8c4f14-e759-499a-8d8c-a08a99273ef9">
        <source>cloneMySelfForVoyage(_newStructure : CM_VoyageStructuralElements;
					_transient : Boolean): CM_VesselTankVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	newTank : CM_VesselTankVoyage;
begin
	newTank:= self.cloneSelfAs(CM_VesselTankVoyage,_transient).CM_VesselTankVoyage;
	
	newTank.setMyVoyageStructure(_newStructure);
	
	return newTank;

epilog

end;</source>
        <Parameter name="_newStructure" type="CM_VoyageStructuralElements"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_VesselTankVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="50629c2d-d042-4579-8efb-52bfa7f4d82f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	self.myVesselStructuralElement.causeEvent(EVENT_TANK_DELETE,false,self);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditParent" id="4a119731-3189-466e-8471-653933f48184">
        <source>getAuditParent(): CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myVesselStructuralElement = null then
		return null;
	endif;
	
	return self.myVesselStructuralElement.myVessel;

epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getStructure" id="5e6111ce-5db6-4c15-ad1e-3f2b0aa5c99f">
        <source>getStructure(): CM_VesselStructuralElements;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVesselStructuralElement;

epilog

end;</source>
        <ReturnType type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4e312367-efab-4438-9758-6192c13d5b2e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxySelf : SelfType;
	completedOK		: Boolean;
begin
	pxySelf:= inheritMethod();
	
	pxySelf.myVesselStructuralElement:=self.myVesselStructuralElement;
	
	completedOK := true;			
	return pxySelf;

epilog
	if not completedOK then			
		delete pxySelf;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a9de3579-370e-493d-8be5-fd0f93fb70df">
        <updating/>
        <source>setForCreate(_proxyVesselTank: CM_VesselTankVessel) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _proxyVesselTank.myVesselStructuralElement.isTransient then
		self.myVesselStructuralElement:=_proxyVesselTank.myVesselStructuralElement.pxyGetRealObject();
	else
		self.myVesselStructuralElement:=_proxyVesselTank.myVesselStructuralElement;
	endif;

	inheritMethod(_proxyVesselTank);

epilog

end;</source>
        <Parameter name="_proxyVesselTank" type="CM_VesselTankVessel"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2684ae17-c2d0-47d6-89ef-a10874bb827b">
        <updating/>
        <source>setForUpdate(_proxyVesselTank: CM_VesselTank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031
22 June 2011	cnwer1  added auditing
*/

vars

	vessel : CM_Vessel;
	beforeAuditText,
	afterAuditText	: String;
begin
	if  self.myVesselStructuralElement &lt;&gt; null then
		beforeAuditText:=self.myVesselStructuralElement.getAuditText;
	endif;
	inheritMethod(_proxyVesselTank);
	
	if self.myVesselStructuralElement &lt;&gt; null then
	
		vessel:= self.myVesselStructuralElement.myVessel;
		afterAuditText:=self.myVesselStructuralElement.getAuditText;
		app.myAA.auditUpdateTrx(vessel,beforeAuditText, afterAuditText);
	
		if _proxyVesselTank.pxyGetRealObject =null then
			self.myVesselStructuralElement.causeEvent(EVENT_TANK_CREATE,false,self);
		else
			self.myVesselStructuralElement.causeEvent(EVENT_TANK_UPDATE,false,self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyVesselTank" type="CM_VesselTank"/>
    </JadeMethod>
    <JadeMethod name="setMyVesselStructElements" id="d72ea058-5009-4010-a68e-2d7a76c45531">
        <updating/>
        <source>setMyVesselStructElements( _vesStructElement : CM_VesselStructuralElements) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2013	cnwrd1	Initial creation

*/

vars

begin
	if not _vesStructElement.isKindOf(CM_VesselStructuralElements) then //cnwrd1 par 31874
	// ONLY STORE SECTIONS ON THE CELLULAR STRUCTURE NOT THE RORO STRUCTURE
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,null,null);
		return;
	endif;
	
	self.myVesselStructuralElement :=_vesStructElement;
epilog

end;</source>
        <Parameter name="_vesStructElement" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="setMyVesselStructure" id="9ce5122c-d613-462a-82f4-6c70b50ce0e8">
        <updating/>
        <source>setMyVesselStructure(_vesselStructure : CM_VesselStructuralElements) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if not _vesselStructure.isKindOf(CM_VesselStructuralElements) then //cnwrd1 par 31874
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,null,null);
		return;
	endif;

	self.myVesselStructuralElement:=_vesselStructure;
epilog

end;</source>
        <Parameter name="_vesselStructure" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="bcc74810-87ef-4000-9b66-b6070a05ba35">
        <source>validateCreate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myVesselStructuralElement = null then
//	 	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Structure), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Structure), null, null); // cnwdb2	PAR 35364
		return;
	endif;

	 if self.myVesselStructuralElement.allTanks[self.code] &lt;&gt; null then
		 app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	 endif;

	
	inheritMethod(_passport);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
