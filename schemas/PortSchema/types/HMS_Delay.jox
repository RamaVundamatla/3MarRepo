    <JadeMethod name="getDisplayString" id="b315b929-654b-4514-ba82-f8c261cc8778">
        <source>getDisplayString(): String;
//--------------------------------------------------
// Created:	26 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	//PAR3818
	return self.description &amp; ' ('&amp; self.code &amp; ')';
	//return self.code &amp; ' ' &amp; self.description;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTypeString" id="8bd2130b-5024-4243-ae5e-2354da5934f8">
