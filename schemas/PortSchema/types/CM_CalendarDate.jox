    <JadeMethod name="setForUpdate" id="d5cf68e6-ec38-4de9-b417-6eea3dd058a9">
        <updating/>
        <source>setForUpdate(_pxyCalendarDate : CM_CalendarDate) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.date 					:= _pxyCalendarDate.date;
	self.description 			:= _pxyCalendarDate.description.trimBlanks;
	self.endTime 				:= _pxyCalendarDate.endTime;
	self.startTime 				:= _pxyCalendarDate.startTime;
	self.dataSource				:= _pxyCalendarDate.dataSource;
	
	self.myCalendarYear := _pxyCalendarDate.myCalendarYear;
	
end;</source>
