    <JadeMethod name="savePreNote" id="3c2e9e02-9903-42aa-9ee6-5870c27e7740">
        <updating/>
        <source>savePreNote(_label : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpAttach			: CMIF_InOutAttachment;
	errObj				: CM_Error;
	result				: Integer;
	intFaceArray		: CMIF_TIObjectArray;
	origCargoType		: Integer;
	origTransMode		: Integer;
	newTI				: CM_TrackedItem;
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	carrier				: CM_Carrier;
	defaultEmailType	: Integer;
	consignee			: CM_ConsigneeConsignor;
begin
	if self.mode = Mode_Update then
		if self.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'ProxyObject is null for update');
			return false;
		endif;		
		origCargoType := self.myCurrentObject.CM_TrackedItem.cargoType;
		origTransMode := self.myCurrentObject.CM_TrackedItem.receiptTransportMode;
	endif;
		
	//take focus off the ISOType row - too much stuff going on there
	self.tblMain.row := self.tblMain.getRowByName(ETRow_IdTextBox);

	create intFaceArray transient;
	self.setPreNote();

	if self.myProxyObject &lt;&gt; null then
		self.myIntFacePreNote.CMIF_PreNote.setMyOriginalProxyTI(self.myProxyObject.CM_TrackedItem);
	endif;

	if self.myEmailDefaults = null
	and self.mode = Mode_Add
	and self.myIntFacePreNote.CMIF_PreNote.transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR then //par15417 cnwrs1 nov 2007
//	and self.viewTransportMode = ViewRoad then
		//create a clone of the terminal default to add to the IntFacePreNote
		//there may already be one if the terminal defaults have been changed by the user in this mode 
		if self.myIntFacePreNote.hasCSIStop then
//			termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_PrenoteCustomsInspect);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			defaultEmailType	:= PINEmail_PrenoteCustomsInspect;
		else
//			termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_Prenote);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			defaultEmailType	:= PINEmail_Prenote;
		endif;
		termEmailDefaults	:= self.myTerminal.getEmailDefaultsSettings( defaultEmailType );
		self.myEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
		carrier := self.cmbCarrierPN.myObject.CM_Carrier;
		consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor; //+ cnwmd1 Par 24232
		//if carrier &lt;&gt; null then //- cnwmd1 Par 24232
			//self.myEmailDefaults.setAddresses(self.myTerminal, carrier, null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			//self.myEmailDefaults.setAddresses( self.myTerminal, carrier, null, defaultEmailType ); //- cnwmd1, Par 24232
		self.myEmailDefaults.setAddresses( self.myTerminal, carrier, consignee, defaultEmailType ); //+ cnwmd1 Par 24232
		//endif;
	endif;

	if self.myEmailDefaults &lt;&gt; null then
// - cannot see the point of this.
//		if self.myIntFacePreNote.hasCSIStop then
//			termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_Prenote);	// cnwrl1 30/07/2009 PAR 20349 - what it was
//			termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( PINEmail_Prenote );
//		endif;
		self.myIntFacePreNote.setEmailDefaultObject(self.myEmailDefaults);
	endif;
	
	intFaceArray.add(self.myIntFacePreNote);

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreatePreNotes(intFaceArray, false, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdatePreNotes(intFaceArray, false, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
			return false;
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			errObj := app.myPassport.getFirstErrorWarning();			
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;

	endwhile;

	// The update was successful

	newTI := self.myIntFacePreNote.myPersistentTrackedItem;

	if self.mode = Mode_Add then
		// set self.myCurrentObject so this is selected in table
		self.myCurrentObject := newTI;
		if newTI &lt;&gt; null then
			self.allAddedPreNotes.add(newTI);
			if not self.myTerminal.getConfig(NoPINs).Boolean then
				if self.myIntFacePreNote.CMIF_PreNote.transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR 
					and self.myIntFacePreNote.pinNo &lt;&gt; null	//It can be null, when no PIN generation for hazardous or over dimension cargo. ccms 1676 Feb 2009.
				then
					app.msgBox(_label &amp; ' added with PIN (' &amp; self.myIntFacePreNote.pinNo &amp; ')', _label &amp; ' Added', MsgBox_OK_Only + MsgBox_Information_Icon);
				//cnwmc5 - 24 Feb 2014 - PAR 35743
				//else
				//	app.msgBox(_label &amp; ' added successfully', _label &amp; ' Added', MsgBox_OK_Only + MsgBox_Information_Icon	);
				endif;				
			endif;
		endif;
		
	else
		// self.mode = Mode_Update
		if newTI &lt;&gt; null then
		   	if newTI.cargoType &lt;&gt; origCargoType then
		   		self.myCurrentObject := newTI;
		   		
		   		// switch the mode as the old obj has been deleted and
		   		// a new one created
		   		self.mode := Mode_Add;
		   	endif;
		endif;
	endif;

	return true;

epilog
	if self.myIntFacePreNote.hasAttachments then
		// remove reference to attachment to prevent them from being deleted
		foreach tmpAttach in self.allAttachments do
			tmpAttach.setMasterItem(null);
			//proxy parent and children are deleted along with self.myIntFacePreNote;
			tmpAttach.setMyProxyTrackedItem(null);
		endforeach;
	else
		self.allAttachments.purge;
	endif;
	delete self.myIntFacePreNote;
	
	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
end;</source>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
