    </JadeMethod>
    <JadeMethod name="isShowingFilterResults" id="2a5e3bd6-7995-4929-95de-09de45d71874">
        <source>isShowingFilterResults() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2011	cnwer1	Initial creation

*/

vars

begin
	return self.myMachQEntryTableSynchAgent.showingFilteredResults;
epilog

end;</source>
        <ReturnType type="Boolean"/>
