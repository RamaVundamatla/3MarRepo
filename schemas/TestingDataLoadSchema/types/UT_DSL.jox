    <JadeMethod name="deleteMachine" id="f0a4c048-2524-45a8-8b77-f1f7ffb19593">
        <source>deleteMachine(_name: String);
//07 January 2009	cnwdw1	
//
vars
	machine: CM_Machine;
	rtDevice: CM_RadioTelemetryDevice;
	terminal: CM_Terminal;
	ti: CM_TrackedItem;
	tiSet: CM_TISet;
	queueTask			: CM_RTQueueTask;
	queueTaskArray		: CM_RTQueueTaskArray;
begin
	terminal := self.getTerminal();
	machine := self.getMachine(_name);
	if machine &lt;&gt; null then
		if machine.myRTDevice &lt;&gt; null then
			if machine.loggedOn then
				self.machineLogOff(machine);
			endif;
			rtDevice := machine.myRTDevice;
			app.myPassport.setMyTerminal(rtDevice.getMyTerminal);
			app.myTrxDA.trxDeleteRTDevice(rtDevice, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
		if machine.loggedOn then
			beginTransaction;
			machine.setLoggedOn(false);
			commitTransaction;
		endif;
		app.myPassport.setMyTerminal(machine.myTerminal);
		if machine.currentQueueTask &lt;&gt; null then
			self.machineZapTask(machine);
		endif;
		
		// 04/03/2014 cnwmh5 - Zap anything in allCurrentQueueTasks
		create queueTaskArray transient;
		machine.allCurrentQueueTasks.copy(queueTaskArray);
		beginTransaction;
		foreach queueTask in queueTaskArray do
			delete queueTask;
		endforeach;
		commitTransaction;
		
		// 04/03/2014 cnwmh5 - Zap anything in allCurrentWorkingQueueTasks
		queueTaskArray.clear();
		machine.allCurrentWorkingQueueTasks.copy(queueTaskArray);
		beginTransaction;
		foreach queueTask in queueTaskArray do
			delete queueTask;
		endforeach;
		commitTransaction;
		
		create tiSet transient;
		machine.myMachineController.allTrackedItems.copy(tiSet);
		foreach ti in tiSet do
			self.deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		if machine.isKindOf(CM_Crane) then							// 21/11/2011 cnwmh5
			self.removeCraneFromAllVoyages(machine.CM_Crane, terminal);
		endif;
		
		if machine.myRTVehicleConfig &lt;&gt; null then
			app.myTrxDA.trxDeleteRTVehicleConfig(machine.myRTVehicleConfig, app.myPassport);
		endif;
		
		app.myTrxDA.trxDeleteMachine(machine, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
epilog
	delete queueTaskArray;
	delete tiSet;
	app.myPassport.setMyTerminal(terminal);
end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteMachineRule" id="9943e1ab-facd-476d-a1cb-fa63c7622a56">
        <source>deleteMachineRule(_fromTA, _toTA: Any);
//16 September 2010	cnwdw1	
//
vars
	multiRule: CM_RTQueueMultiRule;
	obj: CM_Object;
begin
	//multiRule := getTerminal.getRTQueueMultiRule(_fromTA.getLocationsController, _toTA.getLocationsController);
	
	if _fromTA.isKindOf(CM_TerminalAreaType) or _toTA.isKindOf(CM_TerminalAreaType) then					// 18/09/2012 cnwmh5
		if _fromTA &lt;&gt; null and _toTA &lt;&gt; null then
			multiRule := self.getTerminal().allRTQueueMultiRuleTATypes[_fromTA.CM_TerminalAreaType, _toTA.CM_TerminalAreaType];
		endif;
	else
		multiRule := getTerminal.getRTQueueMultiRule(_fromTA.CM_TerminalArea.getLocationsController, _toTA.CM_TerminalArea.getLocationsController);
	endif;
	
	if multiRule &lt;&gt; null then
		obj := multiRule;
		app.myTrxDA.trxDeleteCMObject(obj, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
end;</source>
        <Parameter name="_fromTA" type="Any"/>
        <Parameter name="_toTA" type="Any"/>
    </JadeMethod>
