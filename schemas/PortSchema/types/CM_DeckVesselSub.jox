    <JadeMethod name="typeName" id="1940a0d7-40f0-4ee2-9a63-cd6b02e842a8">
        <source>typeName(): String;
/*
Date		    Who			Reason
16 May 2011	cnwas3	  Initial creation: CCMS 1031, par 27498
*/

vars

begin
	return app.getErrorString(Sub) &amp; " - " &amp; inheritMethod();

epilog

