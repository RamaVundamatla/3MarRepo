	self.assertEqualMsg(location, locations.first, "1. Did not autoplan haz lmtd to haz or lmtd ya");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazOrLimited, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertTrueMsg(location = null, "2. Location not null - planned non haz to haz or lmtd ya");
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazOrLimited, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHaz);
	self.assertEqualMsg(location, locations.first, "3. Did not autoplan haz to haz or lmtd ya");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazOrLimited, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHazLmtd);
	self.assertTrueMsg(location = null, "4. Location not null - planned haz lmtd to non haz or lmtd ya");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazOrLimited, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "5. Did not autoplan non haz to non haz or lmtd ya");
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazOrLimited, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHaz);
	self.assertTrueMsg(location = null, "6. Location not null - planned haz to non haz or lmtd ya");

epilog
	delete locations;
end;
