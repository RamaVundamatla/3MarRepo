    <JadeMethod name="getExtraInfoLogVoyOps" id="fd0248df-8d49-4e4f-8d5e-96b70d690442">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
09/07/2019	jlgka1 	45365	JMT - Log Voyage Operations - Suppliers Tab - Lot Plan Version issue.
							Instead of using TimeStamp as a casting method use asTimeStampJMT.
============================================================================*/
begin
	_array.add("Agent" &amp; Tab &amp; self.agentCode);
	_array.add("Lot Plan Version" &amp; Tab &amp; self.systemToLocalTime(self.lotPlanVersion.asTimeStampJMT).asStringJMT());	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support // jlgka1 TFS 45365
	_array.add("Global Voyage" &amp; Tab &amp; self.myVoyageGlobal.code);		
	self.myVoyage.getExtraInfoLogVoyOps(_array, _terminalForTerminology);
	_array.add("Stevedore Code 1" &amp; Tab &amp; self.stevedoreCode1);
	_array.add("Stevedore Code 2" &amp; Tab &amp; self.stevedoreCode2);			
				
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="eeaf382b-4004-4e6e-a651-823676408eb5">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	if self.myVoyage.code &lt;&gt; null and self.myVoyage.myTerminal &lt;&gt; null then
		return self.myOperator.code &amp; ' ' &amp; self.myVoyage.code &amp; ' ' &amp; self.myVoyage.myTerminal.code;
	elseif self.myVoyage.code &lt;&gt; null then
		return self.myOperator.code &amp; ' ' &amp; self.myVoyage.code;
	else
		return self.myOperator.code;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="e9beb74d-21c6-4fae-9e11-08307a7882b1">
        <source>getYAIdentifier(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2008	consw1	Initial creation

*/

vars

begin
	return self.getYADisplay().toUpper();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="operatorCode" id="43fb53b1-fa67-44cf-aa99-72957b7fc1e5">
        <methodInvocation>mapping</methodInvocation>
        <source>operatorCode(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.myOperator.code;
	endif;
		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="989be033-c54c-4167-a288-fe00d6e6d7ec">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyVoyageOperator : CM_VoyageOperator;
	completedOK		: Boolean;
begin
	pxyVoyageOperator := inheritMethod();
	
	pxyVoyageOperator.myOperator := self.myOperator;
	pxyVoyageOperator.myVoyage := self.myVoyage;
	pxyVoyageOperator.myVoyageGlobal := self.myVoyageGlobal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyVoyageOperator;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyVoyageOperator;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e486e6f5-3a1c-4990-a041-9add9e1fe3bd">
        <updating/>
        <source>setForCreate(_pxyVoyageOperator : CM_VoyageOperator) updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setForUpdate(_pxyVoyageOperator);
end;</source>
        <Parameter name="_pxyVoyageOperator" type="CM_VoyageOperator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="12d2354b-aec7-4aab-a89b-7ab190f91465">
        <updating/>
        <source>setForUpdate(_pxyVoyageOperator : CM_VoyageOperator) updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.agentCode 		:= _pxyVoyageOperator.agentCode;
	self.lotPlanVersion := _pxyVoyageOperator.lotPlanVersion;
	self.myOperator		:= _pxyVoyageOperator.myOperator;
	self.myVoyage		:= _pxyVoyageOperator.myVoyage;
	self.myVoyageGlobal	:= _pxyVoyageOperator.myVoyageGlobal;
	self.stevedoreCode1	:= _pxyVoyageOperator.stevedoreCode1;
	self.stevedoreCode2	:= _pxyVoyageOperator.stevedoreCode2;
end;</source>
        <Parameter name="_pxyVoyageOperator" type="CM_VoyageOperator"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cad6f764-a39b-4767-88f8-07ca9f2ea4ff">
        <updating/>
        <source>setProxy(_agentCode, _lotPlanVersion, _stevedoreCode1, _stevedoreCode2 : String;
			_operator : CM_Operator; _voyage : CM_Voyage; _voyageGlobal : CM_VoyageGlobal) updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.agentCode 		:= _agentCode;
	self.lotPlanVersion := _lotPlanVersion;
	self.myOperator		:= _operator;
	self.myVoyage		:= _voyage;
	self.myVoyageGlobal	:= _voyageGlobal;
	self.stevedoreCode1	:= _stevedoreCode1;
	self.stevedoreCode2	:= _stevedoreCode2;
end;</source>
        <Parameter name="_agentCode" type="String"/>
        <Parameter name="_lotPlanVersion" type="String"/>
        <Parameter name="_stevedoreCode1" type="String"/>
        <Parameter name="_stevedoreCode2" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="24cbf16c-6e84-4488-aa7c-b10904b1cde4">
        <source>validateForCreate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//27/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpVoyage	: CM_Voyage;
	
begin
	tmpVoyage := self.myVoyage;
	
	if tmpVoyage = null then
		// raise error for terminal as this is the field on screen that is
		// used to get the voyage
//		app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_Terminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null); // cnwdb2	PAR 35364
	elseif tmpVoyage.allVoyageIOperators[self.myOperator] &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, "Voyage", tmpVoyage.myTerminal.name &amp; " / " &amp; self.myOperator.code, ETRow_Place, null); //27/06/2022 NAVDS20 TFS 53760
		// Voyage %1 / %2 already exists for %3 : Voyage_alreadyexists
		app.raiseCMException2(Voyage_alreadyexists, self.myOperator.code, tmpVoyage.myTerminal.name , ETRow_Place, null);  //27/06/2022 NAVDS20 TFS 53760
		return;		
	endif;

	self.validateForUpdate(_passport);
	self.validateGVOperator();			// 10/10/2008 cnwar2 #18171 - copied from validateForUpdate
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="07a4fca5-b0f0-47e9-a3ab-366e664579ad">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myVoyage.checkHasOrdersForOperator(self.myOperator) then
		app.raiseCMWarning1(OperatorHasStockOrders, 'Supplier ' &amp; self.myOperator.code, null, null, self.myVoyage);	
	endif;
	if self.myVoyage.checkOrdersForOperatorLoaded(self.myOperator) then
		app.raiseCMException2(StockOrderLoadedToShip, 'Supplier ' &amp; self.myOperator.code, 'the ship', null, null);	
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9d47029b-5d8b-4853-9048-d2c71d085399">
        <source>validateForUpdate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr		: String;
	tmpVoyage 	: CM_Voyage;
begin
	if self.agentCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Agent', null, null);	
		app.raiseCMException(Input_required_field_agent, null, null);	 // cnwdb2	PAR 35364
	endif;
	
	if self.lotPlanVersion = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Lot No.', null, null);	
		app.raiseCMException(Input_required_field_lotNo, null, null);	 // cnwdb2	PAR 35364
	endif;
	
	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, null, null);	
		app.raiseCMException1(Input_required_field_Required, tmpStr, null, null);	 // cnwdb2	PAR 35364
	endif;
	
	if self.myVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);	
		app.raiseCMException(Input_required_field_voyage, null, null);	 // cnwdb2	PAR 35364
	endif;	
	
	if self.myVoyageGlobal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Global Voyage', null, null);	
		app.raiseCMException(Input_required_field_globVoyag, null, null);	 // cnwdb2	PAR 35364
	endif;
	
	if self.stevedoreCode1 = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Stevedore 1', null, null);	
		app.raiseCMException(Input_required_field_steve1, null, null);	 // cnwdb2	PAR 35364
	endif;
	
	if _passport.noErrors then
		// may need some changes here - add arrival date into key
		tmpVoyage := self.myVoyageGlobal.allVoyages.getAtKey(self.myVoyage.arrivedDT, self.myVoyage.myTerminal);
		
		if tmpVoyage &lt;&gt; null and tmpVoyage.myOperator = self.myOperator then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.myVoyage.myTerminal.code, null, null);		
		endif;
	endif;	
	
	//self.validateGVOperator();	// 10/10/2008 cnwar2 #18171 - this should only be done when validating for create
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateGVOperator" id="fe049dc8-f163-4286-bb0c-d7d104634310">
        <source>validateGVOperator() protected;
// --------------------------------------------------------------------------------
// Created:		15 August 2008 by cnwdad1
//
// Purpose:		This method will ensure that the receiver cannot be instantiated with
//				keys that already exist in CM_VoyageGlobal::allVoyOpsByOpTerm or
//				CM_VoyageGlobal::allVoyageOpsByTermOp.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
// --------------------------------------------------------------------------------
vars
	voyageOpObj		: CM_VoyageOperator;
	terminalCode	: String;
	operatorCode	: String;
	
begin
	if self.myVoyageGlobal = null then
		return;
	endif;
	
	if self.myVoyage &lt;&gt; null and self.myVoyage.myTerminal &lt;&gt; null then
		terminalCode	:=	self.myVoyage.myTerminal.code;
	endif;
	
	operatorCode	:=	self.myOperator.code;
	
	voyageOpObj	:=	self.myVoyageGlobal.allVoyOpsByOpTerm[operatorCode, terminalCode];
	
	if voyageOpObj &lt;&gt; null and voyageOpObj &lt;&gt; self then
		//app.raiseCMException2(DuplicateItem, "Operator/Terminal", "Voyage", null, null);	//14.06.2022 navds20 53760
		// Operator/Terminal already exists for Voyage : Operato_already_exists_voyage
		app.raiseCMException(Operato_already_exists_voyage, null, null);	//14.06.2022 navds20 53760
		return;
	endif;
	
	voyageOpObj	:=	self.myVoyageGlobal.allVoyageOpsByTermOp[terminalCode, operatorCode];
	
	if voyageOpObj &lt;&gt; null and voyageOpObj &lt;&gt; self then
		//app.raiseCMException2(DuplicateItem, "Terminal/Operator", "Voyage", null, null);	//14.06.2022 navds20 53760
		//Operator/Terminal already exists for Voyage : Operato_already_exists_voyage
		app.raiseCMException(Operato_already_exists_voyage, null, null); //14.06.2022 navds20 53760
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
