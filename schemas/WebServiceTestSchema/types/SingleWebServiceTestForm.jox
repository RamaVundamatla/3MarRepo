    <JadeMethod name="createEmptyInputMessage" id="e7754b3d-65a7-41dc-a6b5-f1afdeb359dc">
        <updating/>
        <source>createEmptyInputMessage(allPropertyNames,
						allPropertyValues : StringArray input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	meth			: JadeMethod;
	parameter		: Parameter;
	proxyParam		: ImportedWebServiceProxy;
	createdSubObjs	: ObjectSet;
	
begin
	txtInput.text := null;
	write cmbOperation.listIndex;
	meth := cmbOperation.listObject.JadeMethod;
	if meth = null then
		return;
	endif;
	
	self.doClearOutput;
	parameter := meth._getParameters.first;			// There will only be one
	create proxyParam as parameter.type.Class;
	create createdSubObjs transient;

	
	
	proxyParam.populateSubObjects(	allPropertyNames,
									allPropertyValues,
									createdSubObjs );
	
	txtInput.text := proxyParam.returnAsXMLString;
	
	self.zLoadPresetMessageDetails();
	
epilog
	delete proxyParam;
	if createdSubObjs &lt;&gt; null then
		createdSubObjs.purge;
		delete createdSubObjs;
	endif;
	
end;</source>
        <Parameter name="allPropertyNames" type="StringArray" usage="input"/>
        <Parameter name="allPropertyValues" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doClearOutput" id="acaf015b-589c-4329-9947-d25ec3a23c17">
        <updating/>
        <source>doClearOutput() updating, protected;

/*
Date				Who		Reason
06 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	
begin
	self.txtOutput.text	:= null;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGenScriptCode" id="1c22310e-d0b2-4cc6-8b88-80da217fef98">
        <source>doGenScriptCode() protected;

/*

Purpose:			Generate JadeScript code to populate the driver scripts from the 
					current selections


Return Value:		None


Date		Who		Reason
21 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	script,
	line,
	serviceName,
	operationName,
	xmlMessage		: String;
	len,
	pos				: Integer;
	
begin
	if not validateSelection(serviceName, operationName, xmlMessage) then
		return;
	endif;

	txtOutput.text := null;
	script := null;
	script := script &amp; Tab &amp; Tab &amp; "// " &amp; operationName &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "create payload;" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.myXMLSessionScript	:= session;" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.serviceName			:= " &amp; serviceName &amp; ".name;" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.operationName		:= " &amp; serviceName &amp; "::" &amp; operationName &amp; ".name;" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.message				:= ''";
	
	len := xmlMessage.length;
	pos := 1;
	while pos &lt;= len do
		line := xmlMessage.scanUntil(Cr, pos);
		script := script &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; "&amp; '" &amp; line.trimBlanks &amp; "'";
		if pos = 0 then
			break;
		endif;
		pos := pos + 2;
	endwhile;
	
	script := script &amp; ";";
	
	txtOutput.text := script;
	
	app.copyStringToClipboard(script);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadFileToClipboard" id="89267135-b846-4441-98f7-637fdbe8b2c5">
        <source>doLoadFileToClipboard() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	file			: File;
	cmdFile			: CMDFileOpen;
	bin				: Binary;
	str				: String;
	
begin
	create cmdFile transient;
	if cmdFile.open = 0 then
		create file transient;
		file.kind := File.Kind_Binary;
		file.fileName := cmdFile.fileName;
		
		if file.isAvailable() then
			file.open();
			bin := file.readBinary(file.fileLength);
			str := bin.base64Encode;
			
			app.copyStringToClipboard(str);
		endif;
	endif;
	
		
epilog
	delete file;
	delete cmdFile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendWebServiceMessage" id="25092588-c392-41fc-a71c-2b0451f3b7dc">
        <updating/>
        <source>doSendWebServiceMessage() protected, updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	message			: XMLMessagePayload;
	serviceName,
	operationName,
	xmlMessage		: String;
	
begin
	if not validateSelection(serviceName, operationName, xmlMessage) then
		return;
	endif;
	
	self.setCurrentSessionId(self.txtSessionId.text.trimBlanks);
	
	create message transient;
	message.serviceName := serviceName;
	message.operationName := operationName;
	message.message := xmlMessage;
	
	sendWebServiceMessage(message);
	
	
epilog
	delete message;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
