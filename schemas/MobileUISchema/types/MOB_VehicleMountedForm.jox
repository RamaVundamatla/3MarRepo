    <JadeMethod name="btnNextTask_click" id="15ed1097-fd43-414e-9264-0f7a506147ce">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNextTask_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
begin
	row:=self.tblTasks.row;
	if row + 1 &gt; self.tblTasks.rows then
		return;
	endif;
	
	self.tblTasks.row:=row+1;
	self.tblTasks.click(self.tblTasks);
	
	self.doShowGFXForSelectedTask();
epilog

end;</source>
