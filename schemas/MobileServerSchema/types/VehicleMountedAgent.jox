    <JadeMethod name="doGetNextTask" id="1bb488e9-ad2e-40a4-966d-86b08da4ea61">
        <source>doGetNextTask(_errorMsgs: DTO_HandHeldGateErrorDict input; _showErrors : Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 November 2006	cnwer1	Initial creation - PAR#xxxx
04 Decemeber 2009   conkc1  PAR 20388 18807 - moved code to new method doGetNextTask
							Put retry code in here
20 April 2010	cnwer1	Initial creation - moved from VehicleMountedIMVAgent 

*/

constants
	
vars



begin
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do
		doGetNextTaskBody(_errorMsgs, _showErrors);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	return null;
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <Parameter name="_showErrors" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doGetNextTaskBody" id="08df998d-2fad-4a67-a375-ba36efa21418">
        <source>doGetNextTaskBody(_errorMsgs: DTO_HandHeldGateErrorDict input;
					_showErrors : Boolean): String protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
14 November 2006	cnwer1	Initial creation - PAR#xxxx
04 Decemeber 2009   conkc1  Was doGetNextTask, but move here to allow for deadlock replay code
20 April 2010		cnwer1	Initial creation - moved from VehicleMountedIMVAgent
*/
constants
	Event_Factor = 1000;
vars
	result	: Boolean;
	task    : CM_RTQueueTask;
	infoStr : String;
	info	: DTO_VehicleMountedInfo;
begin

	while true do
		self.initialiseForNewRequest(_errorMsgs);

		//epr TFS 995 16/5/17 
		app.myTrxUA.trxMachineGetNext(self.myMachine,app.myPassport);
		
		//epr 6/11/12 par 30678 - now using only 1 get next task trx method
		//app.myTrxRT.trxRequestTask(self.myMediator,null,app.myPassport);
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
	
		if app.myPassport.trxCompletedOK then
			task:=self.myMachine.currentQueueTask;
			//changed the queue because task assigned is in new queue
			if	self.resetNotesForQueue(task.queue) then
				create info transient;
				info.event := Event_New_Queue_Entry + Event_Factor;
				info.eventMessage := infoStr[1:30];
				self.causeEvent(self.Event_Server_Note, true, info);
			endif;
		
			break;
		endif;
		
		if _showErrors then
			result:= self.createErrorsFromPassport(_errorMsgs);
		else
			result:=not app.myPassport.trxCompletedOK;
		endif;
			
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <Parameter name="_showErrors" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doMoveCurrentOverstow" id="e49a6d33-e3ce-4b23-b802-99851755f7a6">
        <updating/>
        <source>doMoveCurrentOverstow(_locId : String;  _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx
23 june 2008		concms1	par 17123 - extra parameter for forced move
15 Jan 2013	NDL	Par 30920 - code moved to doMoveCurrentOverstowBody, and dead lock handler added.

*/

vars

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		self.doMoveCurrentOverstowBody(_locId, _errorMsgs );
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;
	</source>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveCurrentOverstowBody" id="6c25ee30-b44d-454d-b64d-c68c6de9a732">
        <updating/>
        <source>doMoveCurrentOverstowBody(_locId : String;  _errorMsgs : DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation	Par 30920

*/

vars
	ti 		 : CM_TrackedItem;
	isPickup,
	result		: Boolean;
	toLocation : CM_LocationsController;
	error : CM_Error;
begin
	
	
	ti:=self.overstowTI;

	if ti = null then
		self.addError(Err_TrackedItemsNotFound,app.getErrorString1(Err_TrackedItemsNotFound, " for overstowed containers."),_errorMsgs);
		return;
	endif;
	
	
	isPickup:=false; //= TASK_MOVE;
	toLocation:=self.findLocationFromString(_locId);
	if toLocation = null then
		self.addError(ERR_INVALID_LOCN,app.getErrorString1(ERR_INVALID_LOCN,_locId),_errorMsgs);
		return;
	endif;
	
	//can not move the overstowed container to an IMV vehicle
	if toLocation.isKindOf(CM_MachineController) then
		self.addError(ERR_OVERSTOW_MOVE_TO_IMV,app.getErrorString(ERR_OVERSTOW_MOVE_TO_IMV),_errorMsgs);
		return;
	endif;
	
		
	while true do
		self.initialiseForNewRequest(_errorMsgs);
		
		//epr TFS 995 16/5/17  refactored
		app.myTrxUA.trxMachineMoveOverstow(self.getMoveMachine(),ti,toLocation,app.myPassport);
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	
	self.overstowTI:=null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveCurrentTask" id="3b9586a5-808e-4917-a11a-d1aa3cce1952">
        <updating/>
        <source>doMoveCurrentTask(_locId : String;  _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date				Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx
23 june 2008 		concms1	par 17123 - extra parameter

*/
vars
	returnString : String;
	result     : Boolean;
begin
	
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		self.doMoveCurrentTaskBody(_locId, _errorMsgs);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
	
	endwhile;	
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveCurrentTaskBody" id="a37f79a1-c1d3-49f7-a263-602d910f0dec">
        <updating/>
        <source>doMoveCurrentTaskBody(_locId : String;  _errorMsgs : DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:			


Return Value:		


Date				Who		Reason
15 Sep 2006	cnwer1	Initial creation - PAR#xxxx
23 jun 2008 		concms1	par 17123 - extra parameter
04 Dec 2009	conkc1	PAR 20338 18807 - code moved from doMoveCurrentTask
31 Jan 2011 cnwer1	1090 reported from JBL group
*/
vars
	ti 		 : CM_TrackedItem;
	completeTask,
	result		: Boolean;
	toLocation	: CM_LocationsController;
	wle : CM_WorkListEntry;
	imvMachine 	: CM_Machine;
	tiId		: String;
begin

	
	ti:=self.getCurrentTaskTI();
	
	if ti = null then
		if self.getCurrentTask &lt;&gt; null then
			tiId:= self.getCurrentTask.tiId;
		endif;
		//epr 31/1/2011 1090 reported from JBL testing 
		self.addError(Err_TrackedItemsNotFound,app.getErrorString1(Err_TrackedItemsNotFound, " for task " &amp; tiId),_errorMsgs);
		return;
	endif;

	toLocation:=self.findLocationFromString(_locId);
	if toLocation = null then
		self.addError(ERR_INVALID_LOCN,app.getErrorString1(ERR_INVALID_LOCN,_locId),_errorMsgs);
		return;
	endif;

	self.getMoveLocationAndIMV(toLocation,imvMachine);
	
	completeTask:=not self.isTaskLoad();
	wle:= self.getCurrentTaskWLE;
	
	while true do
		self.initialiseForNewRequest(_errorMsgs);
		//if we pass in a task then it will complete that task and its related tasks if it is complete //epr 21/09/09 par 17182 change so not forced move
		app.myTrxRT.trxRTGMoveTI(self.getMoveMachine(),ti,wle,toLocation, false,self.doForcedMove,self.getCurrentTask(),completeTask,imvMachine,self.myRelatedTask, null,app.myPassport); // par 17123 - extra parameter
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	
	if not global.isValidObject(self.myRelatedTask) then
		self.myRelatedTask:=null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPickupTask" id="614eea84-fb92-4579-b459-aec8aa72f044">
        <source>doPickupTask(_quantity: Integer;
				_weight : Decimal;
				_errorMsgs: DTO_HandHeldGateErrorDict input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation

*/

vars
	returnString : String;
	result     : Boolean;
begin
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do
	
		self.doPickupTaskBody(_quantity,_weight,  _errorMsgs); 
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
	endwhile;	
	
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

	

end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPickupTaskBody" id="b9b37d22-2e56-468d-99b0-906f33af42a3">
        <source>doPickupTaskBody(_quantity : Integer;
				_weight : Decimal;	
				_errorMsgs: DTO_HandHeldGateErrorDict input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	result : Boolean;	
begin

	while true do
		self.initialiseForNewRequest(_errorMsgs);
	
		//epr TFS 995 16/5/17
		app.myTrxUA.trxMachinePickupTask(self.myMachine, _quantity, _weight,app.myPassport);
	
		//app.myTrxRT.trxPickupWithTaskNoMediator(self.myMachine, _quantity, _weight,app.myPassport);

		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
			
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetdownTask" id="68908b79-c2f5-4c41-8bca-e53aaa3a07d1">
        <updating/>
        <source>doSetdownTask(	_rtTask: CM_RTQueueTask input;
				_twinTask: CM_RTQueueTask input;
				_setdownLoc: String; 
				_twinSetdownLoc: String;
				_overrideToInterchange : Boolean;
				_errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation

*/

vars
	returnString : String;
	result     : Boolean;
begin
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do
	
		self.doSetdownTaskBody(_rtTask,_twinTask, _setdownLoc, _twinSetdownLoc,_overrideToInterchange, _errorMsgs); 
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;	
	
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

end;</source>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setdownLoc" type="String"/>
        <Parameter name="_twinSetdownLoc" type="String"/>
        <Parameter name="_overrideToInterchange" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetdownTaskBody" id="f771a42c-ac15-4569-b15a-3b74f4577cac">
        <source>doSetdownTaskBody(_rtTask,_twinTask : CM_RTQueueTask input;
				  _setdownLoc,_twinSetdownLoc : String;
				  _overrideToInterchange : Boolean;
				 _errorMsgs: DTO_HandHeldGateErrorDict input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2010	cnwer1	Initial creation
11 May 2010 cnwer1 	_overrideToInterchange if true is setting down in interchange area will then in trx need
					to delete left over rt queue entries and recreate rtQ entries from source this ic area and target
					as the ultimate target location
22 Jun 2022 jlika1	53830	PNL - Vehicle App - Swap Button Broken when Tandem Lifting to two trucks					
*/

vars
	result : Boolean;
begin

	
	while true do
		self.initialiseForNewRequest(_errorMsgs);
		
		//epr TFS 995 16/5/17 
		app.myTrxUA.trxMachineSetdownTask(self.myMachine, _rtTask, _twinTask, _setdownLoc, _twinSetdownLoc, _overrideToInterchange, false,null,null, app.myPassport);
		
		//app.myTrxRT.trxSetdownTaskTwin(self.myMachine,_rtTask,_twinTask,_setdownLoc,_twinSetdownLoc,_overrideToInterchange,app.myPassport);
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setdownLoc" type="String"/>
        <Parameter name="_twinSetdownLoc" type="String"/>
        <Parameter name="_overrideToInterchange" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
