    <JadeMethod name="displayRow" id="cd626dfc-802d-416f-9e09-619b6f44e795">
        <controlMethod name="ComboBox::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayRow(combobox: ComboBox input; obj: Object; lstIndex: Integer; bcontinue: Boolean io): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if self.excludeRow(combobox, obj, lstIndex) then
		return null;
	else
		return self.displayEntry(combobox, obj, lstIndex);
	endif;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="lstIndex" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dropDown" id="b2ea2d84-76b5-4fb5-9c87-e461e54a215d">
        <updating/>
        <source>dropDown(combobox: ComboBox input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.useManualDropDown then
		if (not self.canDropDown) then
			return false;
		endif;
		self.canDropDown := false;
	endif;
	
	//Par 9435 now done on the gotFocus event, which was ok for CM_EntryTable
	//Par 10948 if object deleted then got focus not called before key down
	if (not self.amInitialised) then
		self.zInit();
	endif;
	
	return true;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
