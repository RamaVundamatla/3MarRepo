    <JadeMethod name="doDisplayYardAllocationForEdit" id="7e172e05-36be-43e2-8906-c2106202bd5a">
        <updating/>
        <source>doDisplayYardAllocationForEdit(_ydc : YRD_ContainerDrawingController;_showYAF : Boolean output) : CM_YardAllocation updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	olVIEWFrame, olEDITFrame	: YRD_ContainerOverDrawingFrame;
	ydc							: YRD_ContainerDrawingController;
	obj							: Object;
	showYAF 					: Boolean;
	yalloc 						: CM_YardAllocation;

begin

	ydc := _ydc;
	
	olVIEWFrame := ydc.getOverlayFrame(false); // get viewing frame
	yalloc := olVIEWFrame.myCurrentYardAllocation;
	
	if olVIEWFrame.visible then
		showYAF := true;
		olVIEWFrame.removeYardAllocation(yalloc);
		olVIEWFrame.drawAllYAFrames();
	endif;
	
	olEDITFrame := ydc.getOverlayFrame(true); // get edit  drawing frame, this will be on top
	olEDITFrame.visible := showYAF;
	if olEDITFrame.visible then
		olVIEWFrame.copyYardAllocation(olEDITFrame.myCurrentYardAllocation,olEDITFrame.allObjects);
		olEDITFrame.init();
		olEDITFrame.getCurrentAllocPoints();
		olEDITFrame.drawAllFrames();
	endif;

	_showYAF := showYAF;
	return yalloc;
end;</source>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController"/>
        <Parameter name="_showYAF" type="Boolean" usage="output"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
