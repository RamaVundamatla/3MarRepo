<Class name="CnEcHtmlSelectTag" id="82b2dd63-a815-437d-8491-28f188b900f5">
    <superclass name="CnEcHtmlFormElement"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

