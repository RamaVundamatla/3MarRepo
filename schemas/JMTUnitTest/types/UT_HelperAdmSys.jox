    <JadeMethod name="xCreateStop" id="640c83e1-6eff-48f3-896a-f3178a186498">
        <source>xCreateStop(_id : Integer; _code, _heading, _shortHeading : String; _requiresInfo : Boolean; _requriesInfoType : Integer; _isNotAvailableForEntry, _allowClearanceExpiryDate : Boolean) : CM_StopsTable;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2023	navpw1	Initial creation TFS: 58834

*/

vars
	pxyStopsTable,
	realStopsTable						: CM_StopsTable;
	pxyStopsTableTemplate				: CM_StopTableTemplate;
	
	isChildIgnore, isChildOnly,
	isCoastalOnly, isCoastalIgnore,
	isTranshipOnly, isTranshipIgnore,
	isMT, isFull						: Boolean;
	checkAreasArr, setAreasArr,
	processAreasArr						: IntegerArray;
	voyageHoldsArr						: CM_ObjectArray;
	
begin
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(_requiresInfo, _code, _heading, _shortHeading, _requriesInfoType, _id, null, _isNotAvailableForEntry, _allowClearanceExpiryDate, app.myRoot, null, app.myPassport.myUser.code,
	null	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTable );
	
	if self.opts.includesKey(UT_OPTS_IsChildOnly) then
		isChildOnly := self.opts.bool(UT_OPTS_IsChildOnly);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsChildIgnore) then
		isChildIgnore := self.opts.bool(UT_OPTS_IsChildIgnore);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsCoastalOnly) then
		isCoastalOnly := self.opts.bool(UT_OPTS_IsCoastalOnly);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsCoastalIgnore) then
		isCoastalIgnore := self.opts.bool(UT_OPTS_IsCoastalIgnore);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsTranshipOnly) then
		isTranshipOnly := self.opts.bool(UT_OPTS_IsTranshipOnly);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsTranshipIgnore) then
		isTranshipIgnore := self.opts.bool(UT_OPTS_IsTranshipIgnore);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsMT) then
		isMT := self.opts.bool(UT_OPTS_IsMT);
	endif;
	
	if self.opts.includesKey(UT_OPTS_IsFull) then
		isFull := self.opts.bool(UT_OPTS_IsFull);
	endif;
	
	if self.opts.includesKey(UT_OPTS_CheckAreas) then
		checkAreasArr := self.opts.obj(UT_OPTS_CheckAreas).IntegerArray;
	endif;
	
	if self.opts.includesKey(UT_OPTS_SetAreas) then
		setAreasArr := self.opts.obj(UT_OPTS_SetAreas).IntegerArray;
	endif;
	
	if self.opts.includesKey(UT_OPTS_ProcessAreas) then
		processAreasArr := self.opts.obj(UT_OPTS_ProcessAreas).IntegerArray;
	endif;
	
	if self.opts.includesKey(UT_OPTS_HoldVoyages) then
		voyageHoldsArr := self.opts.obj(UT_OPTS_HoldVoyages).CM_ObjectArray;
	endif;
	
	pxyStopsTableTemplate.setProxy(	checkAreasArr,
									setAreasArr,
									processAreasArr,
									voyageHoldsArr,
									isChildOnly,
									isChildIgnore,
									isCoastalOnly,
									isCoastalIgnore,
									isTranshipOnly,
									isTranshipIgnore,
									isMT,
									isFull);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTable, "realStopsTable");
	return realStopsTable;
	
epilog
	delete pxyStopsTable;
	
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_shortHeading" type="String"/>
        <Parameter name="_requiresInfo" type="Boolean"/>
        <Parameter name="_requriesInfoType" type="Integer"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_allowClearanceExpiryDate" type="Boolean"/>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="xCreateStopsTable" id="731330ce-e80d-41ff-8581-456653df87cb">
        <source>xCreateStopsTable(_stopId : Integer; _stopCode, _stopHeading, _stopShortHeading : String; _checkAreas, _setAreas, _processAreas : IntegerArray) : CM_StopsTable;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	pxyStopsTable,
	stopsTable		: CM_StopsTable;
	pxyStopsTableTemplate : CM_StopTableTemplate;
	
	checkAreas,
	setAreas,
	processAreas: IntegerArray;
	
begin
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(false, _stopCode, _stopHeading, _stopShortHeading, null, _stopId, null, false, false, app.myRoot, null, app.myPassport.myUser.code,
	null	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys( app.myPassport.myTerminal, pxyStopsTable );
	
	create checkAreas transient;
	create setAreas transient;
	create processAreas transient;
	
	_checkAreas.copyNoDups(checkAreas);
	_setAreas.copyNoDups(setAreas);
	_processAreas.copyNoDups(processAreas);
	
	pxyStopsTableTemplate.setProxy(	checkAreas,
									setAreas,
									processAreas,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, stopsTable, app.myPassport);
	self.assertNotNullMsg(stopsTable, "stopsTable");
	return stopsTable;
	
epilog
	delete pxyStopsTable;
	delete checkAreas;
	delete setAreas;
	delete processAreas;
	
end;</source>
        <Parameter name="_stopId" type="Integer"/>
        <Parameter name="_stopCode" type="String"/>
        <Parameter name="_stopHeading" type="String"/>
        <Parameter name="_stopShortHeading" type="String"/>
        <Parameter name="_checkAreas" type="IntegerArray"/>
        <Parameter name="_setAreas" type="IntegerArray"/>
        <Parameter name="_processAreas" type="IntegerArray"/>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="xCreateTaskCriteria" id="de3b5e6d-926b-493d-931e-f09efbb38a2f">
        <source>xCreateTaskCriteria(_pxyTaskCriteria : CM_TaskCriteria input) : CM_TaskCriteria;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	objMatchCriteria : CM_ObjectMatchCriteria;
	
begin
