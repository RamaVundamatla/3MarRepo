    <JadeMethod name="getAuditTextForProperty" id="79d0ac51-e05c-46e6-80b2-5224176fcc6e">
        <source>getAuditTextForProperty(_property: Property): String;
//
// 15 May 2017	cnwrs1	TFS 3698 add CM_Product and CM_FTPEntity auditing
//
vars
	propName : String;
begin
	propName := _property.name;
	if propName = CM_FTPEntity::password.name then
		return self.formatAuditText(propName, "******");			
	else
		return inheritMethod(_property);
	endif;
end;
</source>
