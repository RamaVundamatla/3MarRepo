<Class name="WS_RestReleaseDetailObject" id="49933dbe-0b3d-4e77-8213-cd1e9dc5807b">
    <superclass name="WS_CargoObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <Constant name="Release_Ship" id="5287959b-7c53-421e-9ebe-3c19b0100cfa">
        <source>"Ship"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Release_Train" id="5f51a945-038b-4521-b83e-f2d736f4f54d">
        <source>"Train"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Release_Truck" id="c5f9e999-0248-4b0c-9bf2-979adc6e45bd">
        <source>"Truck"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Release_Wagon" id="d50db75c-4817-4d77-a85a-e9d27fc36c43">
        <source>"Wagon"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="carrierId" id="76858baa-d8b1-4b09-ac5f-6260f4d3dc62">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="ee2e85db-2d5d-4873-a3ad-ae9a897206e0">
        <embedded/>
        <type name="TimeStampOffset"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="6d7b0e46-bce2-4b88-ac16-30ba47c28f37">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="10bdb28c-c091-499a-827b-192efdf72c93">
        <length>6</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="validateRequest" id="b0762bc0-359e-49a3-95ee-fd985f7c9193">
        <source>validateRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		navmd1	Initial creation TFS 64176 Add some basic validation to Receival Details

*/

vars

begin
	app.writeLog(method.qualifiedName, LogTRACE);
	
	if self.id = null then
		// Its a bit dumb, but going from Nowhere to somewhere is a thing we allow
		//app.raiseCMException1(0 /* no id */, self.id, null, null);
		//return false;
	endif;
	
	if	(self.id &lt;&gt; null and self.type = null) or
		(self.type &lt;&gt; null and not self.type.isOneOf(Release_Ship, Release_Truck, Release_Train, Release_Wagon)) then
		app.raiseCMException1(Release_Detail_Type_Invalid, self.type, null, null);
		return false;
	endif;
	
	// Validate Max lengths
	if self.type = WS_RestReleaseDetailObject.Release_Ship and self.id.length &gt;= CM_Voyage::code.length then
		app.raiseCMException2(Field_Value_Too_Long, "releaseDetails/id", (CM_Voyage::code.length-1).String, null, null);
		return false;
	elseif self.type = WS_RestReleaseDetailObject.Release_Truck and self.id.length &gt;= CM_Vehicle::regNumber.length then
		app.raiseCMException2(Field_Value_Too_Long, "releaseDetails/id", (CM_Vehicle::regNumber.length-1).String, null, null);
		return false;
	elseif self.type = WS_RestReleaseDetailObject.Release_Train and self.id.length &gt;= CM_Train::code.length then
		app.raiseCMException2(Field_Value_Too_Long, "releaseDetails/id", (CM_Train::code.length-1).String, null, null);
		return false;
	elseif self.type = WS_RestReleaseDetailObject.Release_Wagon and self.id.length &gt;= CM_Wagon::id.length then
		app.raiseCMException2(Field_Value_Too_Long, "releaseDetails/id", (CM_Wagon::id.length-1).String, null, null);
		return false;
	endif;
	
	return true;
			
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
