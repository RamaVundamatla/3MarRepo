    <JadeMethod name="setForm" id="506a65de-524b-4610-932f-04fc8a053fdd">
        <updating/>
        <source>setForm(pTheForm:Form) updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myForm &lt;&gt; pTheForm then
		self.myForm	:=	pTheForm;
	endif;
end;</source>
        <Parameter name="pTheForm" type="Form"/>
    </JadeMethod>
