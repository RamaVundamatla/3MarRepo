    <JadeMethod name="getValue" id="20aa8c66-2bc0-4c5a-8394-fa76a37eb018">
        <source>getValue(_str : String; _tag : String output) : String protected;

constants

	Equals = "=";
vars
	
	pos			: Integer;
	attribute,
	value		: String;

begin

	pos := 1;
	_str.scanUntil(Equals, pos);
	attribute	:= _str[1:pos-1];
	value 		:= _str[pos + 1: end];
	
	_tag := attribute;
	return value;
end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_tag" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
