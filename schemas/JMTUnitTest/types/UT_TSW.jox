      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 4 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 4 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 4 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 4 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 4 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been cleared
		tempStr	:= 'Test 4 - Stop ' &amp; STOP_ID_LAND_HOLD.display &amp; Space &amp; realStopsTableLandHold.heading.display &amp; ' does not exists for cargo ' &amp; ti1.id;
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_LAND_HOLD), true, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	/*
	**	Test 4 End - Test Statement Code is 1C. Should add the TSW LAND HOLD stop with stopId as 883
	*/
	
	/*
	**	Test 5 Start - Test Role Code that is GC with no AdditionalInformation that contains a StatementCode. Should not add the TSW LAND HOLD stop with stopId as 883
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST9, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST10, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	// add an import stop
	//foreach ti1 in tiSet do
	//	self.addStopById(ti1, STOP_ID_LAND_HOLD);
	//endforeach;
	
	//foreach ti1 in tiSet do
	//	// check - cargo should have the TT stop
	//	tempStr	:= 'Test 4 - Stop ' &amp; STOP_ID_LAND_HOLD.display &amp; Space &amp; realStopsTableLandHold.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
	//	self.assertEqualMsg(ti1.isStopSet(STOP_ID_LAND_HOLD), true, tempStr);
	//	
	//endforeach;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 10, "Test 4 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;51363182A&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20230214160658&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;569&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="dcc9d96c-0834-49c6-a241-dc3c0610e85d-lodgement" filename="PDF7-13739579-2023-02-14-1602296006.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;MB MB987654331 - MOVEMENT APPROVED. All movements approved under a DTR for uncleared goods must be moved by way of an enclosed, secure, leak-proof conveyance, being either within an enclosed vehicle, or within an enclosed air container.&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;13739579&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20230214160658&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;NSN_FCL_SEA&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;OfficerSubmissionClientCode&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;ArrivalDateTime formatCode="102"&gt;20221116&lt;/ArrivalDateTime&gt;
          &lt;FirstArrivalLocationID&gt;NZNSN&lt;/FirstArrivalLocationID&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Consignment&gt;
          &lt;GoodsStatusCode StatusType="CLEARANCE"&gt;IDR&lt;/GoodsStatusCode&gt;
          &lt;GoodsStatusCode StatusType="MOVEMENT"&gt;DTA&lt;/GoodsStatusCode&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;	  
		  &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementDescription&gt;MPI APPROVAL TO MOVE TO ATF&lt;/StatementDescription&gt;
            &lt;StatementTypeCode&gt;MCS&lt;/StatementTypeCode&gt;
            &lt;Pointer&gt;
              &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;DocumentSectionCode&gt;28A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;DocumentSectionCode&gt;31B&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AdditionalInformation&gt;
            &lt;StatementDescription&gt;seq:1,takenTo:TSW GROOT LOCATION, 15 Brigade Road, Manukau,for:MPI APPROVAL TO MOVE TO ATF,by:ACCREDITED PERSON,instructions:.Container(s) to be checked by Nominated Accredited Person,issuedDate:Tuesday, 14 February 2023 4:18:52 PM,issuedBy:MPI SYSTEMS,transportEquipment:BMOU8708209&lt;/StatementDescription&gt;
            &lt;StatementTypeCode&gt;ICN&lt;/StatementTypeCode&gt;
          &lt;/AdditionalInformation&gt;
          &lt;AssociatedTransportDocument&gt;
            &lt;ID&gt;MB987654331&lt;/ID&gt;
            &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
          &lt;/AssociatedTransportDocument&gt;
          &lt;Consignee&gt;
            &lt;Name&gt;NZ Chemicals&lt;/Name&gt;
          &lt;/Consignee&gt;
          &lt;ConsignmentItem&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;GoodsMeasure&gt;
              &lt;GrossMassMeasure unitCode="KGM"&gt;1234&lt;/GrossMassMeasure&gt;
            &lt;/GoodsMeasure&gt;
            &lt;Packaging&gt;
              &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
              &lt;QuantityQuantity&gt;10&lt;/QuantityQuantity&gt;
              &lt;TypeCode&gt;DR&lt;/TypeCode&gt;
            &lt;/Packaging&gt;
          &lt;/ConsignmentItem&gt;
          &lt;Consignor&gt;
            &lt;Name&gt;CN Chemicals&lt;/Name&gt;
          &lt;/Consignor&gt;
          &lt;GoodsLocation&gt;
            &lt;Name&gt;PORTNZNSN&lt;/Name&gt;
          &lt;/GoodsLocation&gt;
          &lt;TransitDestination&gt;
            &lt;Name&gt;PORTNZWLG&lt;/Name&gt;
          &lt;/TransitDestination&gt;
          &lt;TransportContractDocument&gt;
            &lt;ID&gt;' &amp; BOL1 &amp; '&lt;/ID&gt;
            &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
          &lt;/TransportContractDocument&gt;
          &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST9 &amp; '&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
		  &lt;TransportEquipment&gt;
            &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
            &lt;FullnessCode&gt;5&lt;/FullnessCode&gt;
            &lt;ID&gt;' &amp; CONTAINERTEST10 &amp; '&lt;/ID&gt;
          &lt;/TransportEquipment&gt;
          &lt;UnloadingLocation&gt;
            &lt;ID&gt;NZNSN&lt;/ID&gt;
          &lt;/UnloadingLocation&gt;
        &lt;/Consignment&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;MPIBIO&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20230214160658&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;B07&lt;/NameCode&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 5 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = BOL1 then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 5 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 5 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 5 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 5 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been cleared
		tempStr	:= 'Test 5 - Stop ' &amp; STOP_ID_LAND_HOLD.display &amp; Space &amp; realStopsTableLandHold.heading.display &amp; ' exists for cargo "' &amp; ti1.id &amp;'". It should not';
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_LAND_HOLD), false, tempStr);
		
	endforeach;
	
	/*
	**	Test 5 End - Test Role Code that is GC with no AdditionalInformation that contains a StatementCode. Should not add the TSW LAND HOLD stop with stopId as 883
	*/
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	//Delete TSW LAND HOLD
	stopsTableLandHold := self.getRoot.getStopTableForId(STOP_ID_LAND_HOLD);
	if stopsTableLandHold &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_LAND_HOLD);
		self.assertIsDeletedMsg(stopsTableLandHold, "stopsTableLandHold");
	endif;
	
	//Delete Customs Action 1O
	realCustomsAction1O := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_1O];
	if realCustomsAction1O &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_1O, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction1O, "realCustomsAction1O");
	endif;
	
	realCustomsAction1O := null;
	
	//Delete Customs Action 1C
	realCustomsAction1C := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_1C];
	if realCustomsAction1C &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_1C, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction1C, "realCustomsAction1C");
	endif;
	
	realCustomsAction1C := null;
	
	completedOk := true;
	
epilog
	delete systemUTHelper;
	delete pxyStopsTableLandHold;
	delete pxyCustomsAction1C;
	delete pxyCustomsAction1O;
	delete setAreasArr;
	delete checkAreasArr;
	delete processAreasArr;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRMPIClearances" id="f6f2e04b-a86d-46f0-8375-e62a5dc72325">
        <source>tTSWDTRMPIClearances();
/*

Purpose:			Tests changes in 60682 for MPI Clearances to make sure that a stop can be added and then cleared for a remove action in case a remove comes before an add stop message
					MPI Clearances: B04, B06, B07, B08

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2023	navpw1	Initial creation TFS: 60682 (60752)

*/

constants
	TSW_NAME_CODE_B04					: String	= 'B04';
	TSW_NAME_CODE_B06					: String	= 'B06';
	TSW_NAME_CODE_B07					: String	= 'B07';
	TSW_NAME_CODE_B08					: String	= 'B08';
	TSW_MPIBIO							: String	= 'MPIBIO';
	BLOCKSTACK							: String	= 'B60682';
	TSW_VESSEL_CODE						: String	= 'UTTSW60682';
	TSW_VOYAGE_CODE						: String	= 'UT_TSW_60682';
	OPERATOR							: String	= 'UTOP';
	USER_DEF_NAME						: String	= 'TSW';
	
	TSW_CONTAINER_1						: String	= "60682-1";
	TSW_CONTAINER_2						: String	= "60682-2";
	TSW_CONTAINER_3						: String	= "60682-3";
	TSW_CONTAINER_4						: String	= "60682-4";
	TSW_BOL								: String	= "BOL120N28100-1";
	
	TSW_STOP_CODE_BACC					: String	= "TSWBC";
	TSW_STOP_ID_BACC					: Integer	= 879;
	TSW_STOP_HEADING_BACC				: String	= "TSW BACC Underbond";
	TSW_CUSTOMS_ACTION_NAME_BACC_B04	: String	= "TSW BACC Underbond " &amp; TSW_NAME_CODE_B04;
	TSW_CUSTOMS_ACTION_KEYWORD_BACC_B04	: String	= TSW_NAME_CODE_B04;
	TSW_CUSTOMS_ACTION_NAME_BACC_B06	: String	= "TSW BACC Underbond " &amp; TSW_NAME_CODE_B06;
	TSW_CUSTOMS_ACTION_KEYWORD_BACC_B06	: String	= TSW_NAME_CODE_B06;
	TSW_CUSTOMS_ACTION_NAME_BACC_B07	: String	= "TSW BACC Underbond " &amp; TSW_NAME_CODE_B07;
	TSW_CUSTOMS_ACTION_KEYWORD_BACC_B07	: String	= TSW_NAME_CODE_B07;
	TSW_CUSTOMS_ACTION_NAME_BACC_B08	: String	= "TSW BACC Underbond " &amp; TSW_NAME_CODE_B08;
	TSW_CUSTOMS_ACTION_KEYWORD_BACC_B08	: String	= TSW_NAME_CODE_B08;
	
vars
	blockStack							: CM_BlockStack;
	pxyStopsTableBACCU,
	realStopsTableBACCU,
	stopsTableBACCU						: CM_StopsTable;
	vessel								: CM_Vessel;
	voyage								: CM_Voyage;
	operator							: CM_Operator;
	ti									: CM_TrackedItem;
	ediText, tempStr					: String;
	ediFile								: CM_EDIFile;
	ediTI								: CM_EDITrackedItem;
	ediStop								: CM_EDICustomStopTI;
	found1								: Boolean;
	realCustomsActionBACCU,
	pxyCustomsActionBACCUB04,
	realCustomsActionBACCUB04,
	pxyCustomsActionBACCUB06,
	realCustomsActionBACCUB06,
	pxyCustomsActionBACCUB07,
	realCustomsActionBACCUB07,
	pxyCustomsActionBACCUB08,
	realCustomsActionBACCUB08			: CM_EDIAction;
	
	pxyStopsTableTemplateBACCU			: CM_StopTableTemplate;
	pxyStopCriteria						: CM_StopCriteria;
	cargoTypeSet,
	imexStatusSet						: CM_ObjectSet;
	checkAreasArr,
	setAreasArr,
	processAreasArr						: IntegerArray;
	noImportStops,
	completedOk							: Boolean;
	
	tiTransaction						: CM_TITransaction;
	stopCleared, stopAdded				: Boolean;
	
begin
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(TSW_VOYAGE_CODE);
	self.deleteVessel(TSW_VESSEL_CODE);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(TSW_VESSEL_CODE, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(TSW_VOYAGE_CODE, TSW_VESSEL_CODE, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW BACC Underbond STOP
	stopsTableBACCU := self.getRoot.getStopTableForId(TSW_STOP_ID_BACC);
	if stopsTableBACCU &lt;&gt; null then
		self.deleteStopsTable(TSW_STOP_ID_BACC);
		self.assertIsDeletedMsg(stopsTableBACCU, "stopsTableBACCU");
	endif;
	
	//Create TSW BACC Underbond STOP
	create pxyStopsTableBACCU transient;
	pxyStopsTableBACCU.setProxy(false, TSW_STOP_CODE_BACC, TSW_STOP_HEADING_BACC, TSW_STOP_CODE_BACC, null, TSW_STOP_ID_BACC, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateBACCU transient;
	pxyStopsTableTemplateBACCU.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTableBACCU);
	
	create checkAreasArr transient;
	create setAreasArr transient;
	create processAreasArr transient;
	checkAreasArr.add(StopPreventReleaseRequest);
	checkAreasArr.add(StopPreventSubTerminalEdit);
	checkAreasArr.add(StopPreventGateOut);
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventExport);
	
	pxyStopsTableTemplateBACCU.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;				
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));	
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF"));
	
	create imexStatusSet transient;
	imexStatusSet.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTableBACCU);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableBACCU, realStopsTableBACCU, app.myPassport);
	self.assertNotNullMsg(realStopsTableBACCU, "realStopsTableCIDOU");
	
	//Delete Customs Action BACCU B04
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B04];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B04, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Delete Customs Action BACCU B06
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B06];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B06, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Delete Customs Action BACCU B07
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B07];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B07, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Delete Customs Action BACCU B08
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B08];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B08, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Create Customs Action BACCU B04
	create pxyCustomsActionBACCUB04 transient;
	pxyCustomsActionBACCUB04.setProxy(TSW_CUSTOMS_ACTION_NAME_BACC_B04, TSW_CUSTOMS_ACTION_KEYWORD_BACC_B04, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableBACCU, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionBACCUB04, realCustomsActionBACCUB04, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionBACCUB04, "realCustomsActionBACCUB04");
	
	app.writeLog("Created Customs Action: " &amp; TSW_CUSTOMS_ACTION_NAME_BACC_B04, LogINFO);
	
	//Create Customs Action BACCU B06
	create pxyCustomsActionBACCUB06 transient;
	pxyCustomsActionBACCUB06.setProxy(TSW_CUSTOMS_ACTION_NAME_BACC_B06, TSW_CUSTOMS_ACTION_KEYWORD_BACC_B06, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableBACCU, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionBACCUB06, realCustomsActionBACCUB06, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionBACCUB06, "realCustomsActionBACCUB06");
	
	app.writeLog("Created Customs Action: " &amp; TSW_CUSTOMS_ACTION_NAME_BACC_B06, LogINFO);
	
	//Create Customs Action BACCU B07
	create pxyCustomsActionBACCUB07 transient;
	pxyCustomsActionBACCUB07.setProxy(TSW_CUSTOMS_ACTION_NAME_BACC_B07, TSW_CUSTOMS_ACTION_KEYWORD_BACC_B07, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableBACCU, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionBACCUB07, realCustomsActionBACCUB07, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionBACCUB07, "realCustomsActionBACCUB07");
	
	app.writeLog("Created Customs Action: " &amp; TSW_CUSTOMS_ACTION_NAME_BACC_B07, LogINFO);
	
	//Create Customs Action BACCU B08
	create pxyCustomsActionBACCUB08 transient;
	pxyCustomsActionBACCUB08.setProxy(TSW_CUSTOMS_ACTION_NAME_BACC_B08, TSW_CUSTOMS_ACTION_KEYWORD_BACC_B08, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableBACCU, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionBACCUB08, realCustomsActionBACCUB08, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionBACCUB08, "realCustomsActionBACCUB08");
	
	app.writeLog("Created Customs Action: " &amp; TSW_CUSTOMS_ACTION_NAME_BACC_B08, LogINFO);
	
	/*
	**	Test 1 Start - Test Name Code 'B04'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalWeight, 2000.Decimal);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	ti := self.addContainerOnShip(TSW_CONTAINER_1, operator, "22G1", "GENL", null, voyage, null, TSW_VOYAGE_CODE);
	
	//Move container on site
	self.move(ti, blockStack);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 1, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_1, CM_EDIAction.RoleCode_GC, TSW_NAME_CODE_B04, TSW_BOL, TSW_MPIBIO, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo transactions for an add stop and remove stop transaction
	
	foreach tiTransaction in ti.allTransactions do
		if tiTransaction.isKindOf(CM_StopCleared) and tiTransaction.CM_StopCleared.stopID = TSW_STOP_ID_BACC then
			stopCleared := true;
		elseif tiTransaction.isKindOf(CM_StopAdd) and tiTransaction.CM_StopAdd.stopID = TSW_STOP_ID_BACC then
			stopAdded := true;
		elseif stopCleared and stopAdded then
			break;
		endif;
	endforeach;
	
	self.assertTrueMsg(stopCleared, "Test 1 - Could not find stop cleared transaction on ti ('" &amp; TSW_CONTAINER_1 &amp; "').");
	self.assertTrueMsg(stopAdded, "Test 1 - Could not find stop add transaction on ti ('" &amp; TSW_CONTAINER_1 &amp; "').");
	
	/*
	** Cleanup
	*/
	stopCleared := false;
	stopAdded := false;
	
	app.writeLog("Test 1: PASSED | Details: Test - Name Code 'B04'. Should add and then clear the TSW BACC Underbond stop with stopId as 879", LogINFO);
	
	/*
	**	Test 1 End - Test Name Code 'B04'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	**	Test 2 Start - Test Name Code 'B06'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalWeight, 2000.Decimal);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	ti := self.addContainerOnShip(TSW_CONTAINER_2, operator, "22G1", "GENL", null, voyage, null, TSW_VOYAGE_CODE);
	
	//Move container on site
	self.move(ti, blockStack);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 2, "Test 2 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_2, CM_EDIAction.RoleCode_GC, TSW_NAME_CODE_B06, TSW_BOL, TSW_MPIBIO, true);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 2 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 2 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 2 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 2 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 2 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo transactions for an add stop and remove stop transaction
	
	foreach tiTransaction in ti.allTransactions do
		if tiTransaction.isKindOf(CM_StopCleared) and tiTransaction.CM_StopCleared.stopID = TSW_STOP_ID_BACC then
			stopCleared := true;
		elseif tiTransaction.isKindOf(CM_StopAdd) and tiTransaction.CM_StopAdd.stopID = TSW_STOP_ID_BACC then
			stopAdded := true;
		elseif stopCleared and stopAdded then
			break;
		endif;
	endforeach;
	
	self.assertTrueMsg(stopCleared, "Test 2 - Could not find stop cleared transaction on ti ('" &amp; TSW_CONTAINER_2 &amp; "').");
	self.assertTrueMsg(stopAdded, "Test 2 - Could not find stop add transaction on ti ('" &amp; TSW_CONTAINER_2 &amp; "').");
	
	/*
	** Cleanup
	*/
	stopCleared := false;
	stopAdded := false;
	
	app.writeLog("Test 2: PASSED | Details: Test - Name Code 'B06'. Should add and then clear the TSW BACC Underbond stop with stopId as 879", LogINFO);
	
	/*
	**	Test 2 End - Test Name Code 'B06'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	**	Test 3 Start - Test Name Code 'B07'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalWeight, 2000.Decimal);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	ti := self.addContainerOnShip(TSW_CONTAINER_3, operator, "22G1", "GENL", null, voyage, null, TSW_VOYAGE_CODE);
	
	//Move container on site
	self.move(ti, blockStack);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 3, "Test 3 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWDTRFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_3, CM_EDIAction.RoleCode_GC, TSW_NAME_CODE_B07, TSW_BOL);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 3 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 3 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 3 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 3 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 3 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo transactions for an add stop and remove stop transaction
	
	foreach tiTransaction in ti.allTransactions do
		if tiTransaction.isKindOf(CM_StopCleared) and tiTransaction.CM_StopCleared.stopID = TSW_STOP_ID_BACC then
			stopCleared := true;
		elseif tiTransaction.isKindOf(CM_StopAdd) and tiTransaction.CM_StopAdd.stopID = TSW_STOP_ID_BACC then
			stopAdded := true;
		elseif stopCleared and stopAdded then
			break;
		endif;
	endforeach;
	
	self.assertTrueMsg(stopCleared, "Test 3 - Could not find stop cleared transaction on ti ('" &amp; TSW_CONTAINER_3 &amp; "').");
	self.assertTrueMsg(stopAdded, "Test 3 - Could not find stop add transaction on ti ('" &amp; TSW_CONTAINER_3 &amp; "').");
	
	/*
	** Cleanup
	*/
	stopCleared := false;
	stopAdded := false;
	
	app.writeLog("Test 3: PASSED | Details: Test - Name Code 'B07'. Should add and then clear the TSW BACC Underbond stop with stopId as 879", LogINFO);
	
	/*
	**	Test 3 End - Test Name Code 'B07'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	**	Test 4 Start - Test Name Code 'B08'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalWeight, 2000.Decimal);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	ti := self.addContainerOnShip(TSW_CONTAINER_4, operator, "22G1", "GENL", null, voyage, null, TSW_VOYAGE_CODE);
	
	//Move container on site
	self.move(ti, blockStack);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 4, "Test 4 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWDTRFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_4, CM_EDIAction.RoleCode_GC, TSW_NAME_CODE_B08, TSW_BOL);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 4 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 4 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 4 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 4 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 4 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo transactions for an add stop and remove stop transaction
	
	foreach tiTransaction in ti.allTransactions do
		if tiTransaction.isKindOf(CM_StopCleared) and tiTransaction.CM_StopCleared.stopID = TSW_STOP_ID_BACC then
			stopCleared := true;
		elseif tiTransaction.isKindOf(CM_StopAdd) and tiTransaction.CM_StopAdd.stopID = TSW_STOP_ID_BACC then
			stopAdded := true;
		elseif stopCleared and stopAdded then
			break;
		endif;
	endforeach;
	
	self.assertTrueMsg(stopCleared, "Test 4 - Could not find stop cleared transaction on ti ('" &amp; TSW_CONTAINER_4 &amp; "').");
	self.assertTrueMsg(stopAdded, "Test 4 - Could not find stop add transaction on ti ('" &amp; TSW_CONTAINER_4 &amp; "').");
	
	/*
	** Cleanup
	*/
	stopCleared := false;
	stopAdded := false;
	
	app.writeLog("Test 4: PASSED | Details: Test - Name Code 'B08'. Should add and then clear the TSW BACC Underbond stop with stopId as 879", LogINFO);
	
	/*
	**	Test 4 End - Test Name Code 'B08'. Should add and then clear the TSW BACC Underbond stop with stopId as 879
	*/
	
	/*
	** Global Cleanup
	*/
	
	//Delete TSW BACC Underbond STOP
	stopsTableBACCU := self.getRoot.getStopTableForId(TSW_STOP_ID_BACC);
	if stopsTableBACCU &lt;&gt; null then
		self.deleteStopsTable(TSW_STOP_ID_BACC);
		self.assertIsDeletedMsg(stopsTableBACCU, "stopsTableBACCU");
	endif;
	
	//Delete Customs Action BACCU B04
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B04];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B04, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Delete Customs Action BACCU B06
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B06];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B06, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Delete Customs Action BACCU B07
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B07];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B07, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	//Delete Customs Action BACCU B08
	realCustomsActionBACCU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_BACC_B08];
	if realCustomsActionBACCU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_BACC_B08, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionBACCU);
	endif;
	
	realCustomsActionBACCU := null;
	
	completedOk := true;
	
epilog
	if not completedOk and realStopsTableBACCU &lt;&gt; null then
		abortTransaction;
		beginTransaction;
		realStopsTableBACCU.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		commitTransaction;
	endif;
	delete pxyStopsTableBACCU;
	delete pxyCustomsActionBACCUB04;
	delete pxyCustomsActionBACCUB06;
	delete pxyCustomsActionBACCUB07;
	delete pxyCustomsActionBACCUB08;
	delete checkAreasArr;
	delete setAreasArr;
	delete processAreasArr;
	delete cargoTypeSet;
	delete imexStatusSet;

end;</source>
