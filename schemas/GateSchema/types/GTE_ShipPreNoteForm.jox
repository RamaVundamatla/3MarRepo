    <JadeMethod name="setControlsForAddEdit" id="50ff7eee-0966-4bbb-b065-7829d93d17c2">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	sptThumbEdit.visible := true;
	inheritMethod();
	btnNextTV.enabled := true;
	btnSaveBase.enabled := true;
	btnNextTV.enabled := true;
	btnCancelBase.enabled := true;
	sptThumbEdit.setLeftToRightRatio(25);
	//Transport Mode select is not required on the Create New Cargo form but does on the Prenotes in Gate.
//	tblMain.hideRowByName(ETRow_ReceiptTransportMode, false);
//	tblMain.hideRowByName(ETRow_StatusString, false);
	if self.myPreloadVoyage &lt;&gt; null then
		if self.cmbVoyage.findObject(self.myPreloadVoyage) &gt; 0 then
			self.cmbVoyage.listObject := self.myPreloadVoyage;
			self.cmbVoyage.click(self.cmbVoyage);
		endif;
	endif;
end;</source>
