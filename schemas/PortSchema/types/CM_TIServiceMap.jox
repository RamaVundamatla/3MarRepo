    <JadeMethod name="copyFrom" id="1fda78f6-417f-47bd-9abd-6281bdf01715">
        <updating/>
        <source>copyFrom(_map : CM_TIServiceMap; _cargoType : CM_CargoType; _parent : CM_TranMap) updating;
// 32311 set up self from the parameter plus the new cargo type, copy all of the parameter map children under self.
vars
	pgm			: CM_ProductGroupMap;
	newChild	: CM_ProductGroupMap;
begin
	self.myCargoType := _cargoType;
	self.className := _cargoType.classNameToCreate;
	if _parent = null then
		self.transactionMap := _map.transactionMap;
	else
		self.transactionMap := _parent;
	endif;
	// just copy the default product group and product maps, as the others will be cargo-type specific and not apply to the target
	foreach pgm in _map.allProductGroupMaps do
		if pgm.myProductGroup = null then
			create newChild as pgm.class persistent;
			newChild.copyFrom(pgm, pgm.myProductGroup, self);
			break;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_TIServiceMap"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_parent" type="CM_TranMap"/>
    </JadeMethod>
