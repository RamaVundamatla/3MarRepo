    <JadeMethod name="getProductForMeasurementTypes" id="b3978780-f0db-4d0c-bbdd-82104dbd55ce">
        <source>getProductForMeasurementTypes() : CM_Product;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2013	cnwndl1	Initial creation	Par 32055

*/

vars

	currentObject : CM_Object;
	ti : CM_TrackedItem;
	product : CM_Product;

begin
	// re-implemnted where required
	
	currentObject := self.getMyCurrentObject;
	
	if CM_TrackedItem.hasInstance(currentObject) then
		ti := currentObject.CM_TrackedItem;
		if ti.myProduct &lt;&gt; null then
			product := ti.myProduct;
		elseif ti.myCargoType.mySystemProductType &lt;&gt; null then
			product := ti.myCargoType.mySystemProductType;
		endif;
	endif;
	
	return product;

epilog

end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getRateEntryDecimalPlaces" id="4ac8d9ad-881e-4709-99ad-bfb129be3c69">
        <source>getRateEntryDecimalPlaces() : Integer;
/*

Purpose:			Replace the old $CM_RateEntry number format with the terminal config value instead


Date				Who		Reason
19 February 2018	jlgmd1	Initial creation TFS 36954 SNO - Error in SCT2 Rate Table

*/

vars
	dpl : Integer;
begin
	if self.myTerminal &lt;&gt; null then
		dpl := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;
	else
		dpl := $CM_RateEntry.decimalPlaces;	// 2 in WMAST
	endif;
	
	return dpl;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
