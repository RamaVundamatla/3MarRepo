    <JadeMethod name="isAllReqsInJob" id="20fe5767-f6f7-4ad2-b43a-4dd0828a8d32">
        <source>isAllReqsInJob(_isLoad : Boolean): Boolean;
/* PAR 28787
Purpose:		IF there is a request, is it in a job.	
Date		Who		Reason
02 December 2011	cnwab1	Initial creation
*/

vars
	has20, has40 : Boolean;
	slotDefn : CM_ROROSlotDefn;
	slotLC, aftSlot : CM_ROROSlotController;
	theReq : CM_RORORequest;
		has : Boolean;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
	
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
	
		if slotLC &lt;&gt; null then
			// PAR 28939
			if _isLoad then
				theReq := slotLC.myRORORequestLoad;
			else
				theReq := slotLC.myRORORequestDischarge;
			endif;
			
			if theReq &lt;&gt; null then
				if theReq.allAllocations.isEmpty() then // PAR 29807 load CC OOTL, all the slots have a req, but they are not attached to an allocation
					continue;
				endif;
				if theReq.myJob = null then
					return false;
				endif;
				has := true;// PAR 29807 
				
				// PAR 30253 if theReq.getAttrIs40() then
				if theReq.getAttrIsNOT20() then // PAR 30253
					has40 := true;
				else
					has20 := true;
				endif;
			endif;
		endif;
	endforeach;	

	
	// if mixed 20s and 40s we need to check for any 20s in the aft, as this is used by teh top down view that draws a 40 foot rectangle if the stack has any 40s.
	if has40 and has20 then
		foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		
			if slotLC &lt;&gt; null then
				// PAR 28939
				if _isLoad then
					theReq := slotLC.myRORORequestLoad;
				else
					theReq := slotLC.myRORORequestDischarge;
				endif;
				
				if theReq &lt;&gt; null then
					//  PAR 30253 if not theReq.getAttrIs40() then
					if theReq.getAttrIs20() then
						aftSlot := slotLC.getAftLC();
						if aftSlot &lt;&gt; null then
							// PAR 28939
							if _isLoad then
								theReq := aftSlot.myRORORequestLoad;
							else
								theReq := aftSlot.myRORORequestDischarge;
							endif;
							
							if theReq &lt;&gt; null then
								if theReq.myJob = null then
									return false;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endforeach;	
	
	endif;

	return has;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLocnContainer" id="a9b51fc8-823f-46ca-af70-ba0ac4eccdf4">
