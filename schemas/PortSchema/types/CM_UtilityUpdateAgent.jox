	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyLoadingContractor" type="CM_HandlingContractor1"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLocActRemarksOnly" id="981b1d5c-cf9c-4aa7-a5ea-3b9252ace01a">
        <updating/>
        <source>utlUpdateLocActRemarksOnly(	_pxyLA : CMEVT_LocationActivity; 
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2021	navndl1	Initial creation	TFS 51864

*/

vars
	realObject : CMEVT_LocationActivity;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyLA, 'Location Activity Object');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valLocationActivity( _pxyLA );

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyLA, 'Location Activity Object', _passport).CMEVT_LocationActivity;

	if _passport.noErrors then
		// This is only required if the class is being audited
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		realObject.setRemarks( _pxyLA.remarks );
	endif;

	if _passport.noErrors then
		// This is only required if the class is being audited
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_pxyLA" type="CMEVT_LocationActivity"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLocale" id="83e28320-bcbe-4c9a-989e-c8efdfa298b0">
        <source>utlUpdateLocale( _pxyLocale : CM_Locale; _isUserDefined : Boolean; _passport : CM_Passport input);
/* ---------------------------------------------------------------------------
Created:	05 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realLocale	: CM_Locale;

begin

	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull( _pxyLocale, 'Test Object');
	
	app.setContinueCMExceptions(true);
	app.myValUA.valLocale( _pxyLocale, _isUserDefined );
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realLocale := self.getRealObjectAndEditionCheck( _pxyLocale, app.getErrorString(Info_Locale), _passport).CM_Locale;
	
	realLocale.setForUpdate(_pxyLocale);


end;</source>
