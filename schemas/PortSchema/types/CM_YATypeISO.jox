    <JadeMethod name="isCMIFDataMatch" id="5be2aab1-9462-424a-9e1b-12f779011a3e">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars


begin

	
	return _cmifAutoPlan.isISO_Match(_yaData);

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="a8611e26-60f9-4144-9617-6f060ce12d60">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_ISOType.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="d98cfa5a-0d39-42f9-bd05-7fa883eee2f1">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars
	iso		: CM_ISOType;
	ti : CM_TrackedItem;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		ti := _tiTrx.myTrackedItem;// iso type not kept on the generic transaction
	else
		ti := _ti;
	endif;
	
	if ti.isKindOf(CM_Container) then
		iso := app.myRoot.allISOTypes[ti.CM_Container.isoType];
	endif;
	
	// specific value - 31221 handle wild cards as well
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(iso) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocationCT" id="dc7c298a-bd98-4e1c-9503-378e921d817d">
        <source>isVoyageAllocationCT(): Boolean;
// --------------------------------------------------------------------------------
// Created:		3 December 2009 by cnwjo3
//
// Purpose:		Is the current class (CM_YACriteriaType) used for Voyage Allocations?
//				CCMS 1028
//
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
