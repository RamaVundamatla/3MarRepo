    <JadeMethod name="setForCreate" id="877ff34e-eb67-4984-b036-476769b2cba2">
        <updating/>
        <source>setForCreate(pProxyShift : CM_ShiftEntity) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	17/5/01			AA		Changed status to always be export
// ---------------------------------------------------------------------------

vars

begin
	self.code 			:= pProxyShift.code;
	self.description 	:= pProxyShift.description;

end;
</source>
