    <JadeMethod name="isCertified" id="2b3d44ef-36cc-4648-90c4-eb274681007e">
        <source>isCertified() : Boolean;
/* ---------------------------------------------------------------------------
Created:	06 November 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	receivalBOL	: CM_BOLIn;
	extLogIn	: CM_BOLExtLogIn;

begin

	receivalBOL := self.myReceivalBOL;
	if receivalBOL = null then
		return false;
	endif;
	
	extLogIn := receivalBOL.myExtension.CM_BOLExtLogIn;
	if extLogIn = null then
		return false;
	endif;

	return extLogIn.isCertified();


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCompatibleWithRestriction" id="70bebc3b-952a-4cd3-a660-cdb94374a361">
        <source>isCompatibleWithRestriction(restrict: CM_LocationRestriction; obj: CMIF_AutoMovePlan input) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			18 October 2001 by cnwdwq1
Purpose:			NOTE: This receives a SUB-CLASS of CM_LocationRestriction, the SUPERCLASS
					implimentation takes the CM_LocationRestriction class. If you pass the wrong type
					to here, it WILL die at run-time. DQ 07/02/2002
Parameters:		None
Returns:		Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
13/12/2013		cnwjre1			27334 change warnings to errors, to match the UI processing
---------------------------------------------------------------------------
*/
vars
	loadStateSet: Boolean;
	tmpProduct	: CM_ProductLog;
	tmpRestrict : CM_LocationRestrictLog;
begin
	if restrict.isKindOf(CM_LocationRestrictLog) then
		tmpRestrict := restrict.CM_LocationRestrictLog;
	else
		return false;
	endif;
	
	if tmpRestrict = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, "Restriction Reference", null, null);
		return false;
	endif;
	
	app.cmsBeginLoad(loadStateSet);
	sharedLock(tmpRestrict);
	
	tmpProduct := self.myProduct.CM_ProductLog;
	
	if (not tmpRestrict.allLogSpecies.isEmpty) then
		if (not tmpRestrict.allLogSpecies.includes(tmpProduct.myLogSpecies)) then
			//obj.addLogEntry("Log (" &amp; self.id &amp; ") Log Species Restriction failed, skipping", IsWarning); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString1(Species_restric_failed_skippin, self.id), IsError, Species_restric_failed_skippin);
			return false;
		endif;
	endif;

	if (not tmpRestrict.allLogGrades.isEmpty) then
		if (not tmpRestrict.allLogGrades.includes(tmpProduct.myLogGrade)) then
			//obj.addLogEntry("Log (" &amp; self.id &amp; ") Log Grade Restriction failed, skipping", IsWarning); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString1(Grade_restric_failed_skippin, self.id), IsError, Grade_restric_failed_skippin);
			return false;
		endif;
	endif;

	if (not tmpRestrict.allLogTypes.isEmpty) then
		if (not tmpRestrict.allLogTypes.includes(tmpProduct.myLogType)) then
			//obj.addLogEntry("Log (" &amp; self.id &amp; ") Log Type Restriction failed, skipping", IsWarning); //+ cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString1(Type_restric_failed_skippin, self.id), IsError, Type_restric_failed_skippin);
			return false;
		endif;
	endif;

	if (not tmpRestrict.allLogTreatments.isEmpty) then
		if (not tmpRestrict.allLogTreatments.includes(tmpProduct.myLogTreatment)) then
			//obj.addLogEntry("Log (" &amp; self.id &amp; ") Log Treatment Restriction failed, skipping", IsWarning); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString1(Treatme_restric_failed_skippin, self.id), IsError, Treatme_restric_failed_skippin);
			return false;
		endif;
	endif;

	if (not tmpRestrict.allLogLengths.isEmpty) then
		if (not tmpRestrict.allLogLengths.includes(tmpProduct.myLogLength)) then
			//obj.addLogEntry("Log (" &amp; self.id &amp; ") Log Length Restriction failed, skipping", IsWarning); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString1(Length_restric_failed_skippin, self.id), IsError, Length_restric_failed_skippin);
			return false;
		endif;
	endif;

	return inheritMethod(tmpRestrict, obj);

epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
        <Parameter name="restrict" type="CM_LocationRestriction"/>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFSC" id="ad11c1bb-67dc-4396-962d-6c6835076497">
        <methodInvocation>mapping</methodInvocation>
        <source>isFSC(set: Boolean; _value: Boolean io) mapping;
/* ---------------------------------------------------------------------------
Created:	06 November 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	receivalBOL	: CM_BOLIn;
	extLogIn	: CM_BOLExtLogIn;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	receivalBOL := self.myReceivalBOL;
	if receivalBOL = null then
		_value := false;
		return;		// from 28082 testing Sep 2011
	endif;
	
	extLogIn := receivalBOL.myExtension.CM_BOLExtLogIn;
	if extLogIn = null then
		_value := false;
		return;		// from 28082 testing Sep 2011
	endif;

	_value := extLogIn.isFSC;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
