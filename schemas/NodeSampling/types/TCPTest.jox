    <JadeMethod name="getNumberOfProcessors" id="9f1ac41b-ab77-48f6-857d-7ea1f4888cf7">
        <source>getNumberOfProcessors() : Integer;

constants
	PROCESSOR_INTEL_386     : Integer = 386;
	PROCESSOR_INTEL_486     : Integer = 486;
    PROCESSOR_INTEL_PENTIUM : Integer = 586;
    PROCESSOR_MIPS_R4000    : Integer = 4000;
    PROCESSOR_ALPHA_21064   : Integer = 21064;
vars
	sysInfoStructure            : Binary;
	dwOemID                     : Integer;
	dwPageSize                  : Integer;
	lpMinimumApplicationAddress : Integer;
	lpMaximumApplicationAddress : Integer;
	dwActiveProcessorMask       : Integer;
	dwNumberOrfProcessors       : Integer;
	dwProcessorType             : Integer;
begin
	sysInfoStructure [ 32 : 1 ] := 0.Binary;
    call getSysInfo(sysInfoStructure);
    dwOemID                     := sysInfoStructure[ 1 : 4].Integer;
	dwPageSize                  := sysInfoStructure[ 5 : 4].Integer;
	lpMinimumApplicationAddress := sysInfoStructure[ 9 : 4].Integer;
	lpMaximumApplicationAddress := sysInfoStructure[ 13 : 4].Integer;
	dwActiveProcessorMask       := sysInfoStructure[ 17 : 4].Integer;
	dwNumberOrfProcessors       := sysInfoStructure[ 21 : 4].Integer;
	dwProcessorType             := sysInfoStructure[ 25 : 4].Integer;

	return dwNumberOrfProcessors;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfProcessorsOnAppSer" id="6e17f4df-d7b5-4928-9f8f-2b31ee67394a">
        <source>getNumberOfProcessorsOnAppSer(): Integer;

constants
	PROCESSOR_INTEL_386     : Integer = 386;
	PROCESSOR_INTEL_486     : Integer = 486;
    PROCESSOR_INTEL_PENTIUM : Integer = 586;
    PROCESSOR_MIPS_R4000    : Integer = 4000;
    PROCESSOR_ALPHA_21064   : Integer = 21064;
vars

	dwOemID                     : Integer;
	dwPageSize                  : Integer;
	lpMinimumApplicationAddress : Integer;
	lpMaximumApplicationAddress : Integer;
	dwActiveProcessorMask       : Integer;
	dwNumberOrfProcessors       : Integer;
	dwProcessorType             : Integer;
	sysInfoStructure            : Binary;

begin
	sysInfoStructure [ 32 : 1 ] := 0.Binary;
    call getSysInfoOnApplicationServer(sysInfoStructure);
    dwOemID                     := sysInfoStructure[ 1 : 4].Integer;
	dwPageSize                  := sysInfoStructure[ 5 : 4].Integer;
	lpMinimumApplicationAddress := sysInfoStructure[ 9 : 4].Integer;
	lpMaximumApplicationAddress := sysInfoStructure[ 13 : 4].Integer;
	dwActiveProcessorMask       := sysInfoStructure[ 17 : 4].Integer;
	dwNumberOrfProcessors       := sysInfoStructure[ 21 : 4].Integer;
	dwProcessorType             := sysInfoStructure[ 25 : 4].Integer;

	return dwNumberOrfProcessors;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
