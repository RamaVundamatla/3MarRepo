    <JadeMethod name="convertUnitsOfMeasure" id="86055e7d-04d2-4361-92b8-66f59f6ca5d0">
        <source>convertUnitsOfMeasure(_input : String) : String protected;

// cnwdvb1 22 October 2002 

vars

begin

	if _input = Choice_All then
		return BOL_UOM_PIECE_COUNT;
	elseif _input = Choice_Vol then
		return BOL_UOM_VOLUME;
	elseif _input = Choice_Weight then
		return BOL_UOM_WEIGHT;
	elseif _input = BOL_UOM_PIECE_COUNT then
		return Choice_All;
	elseif _input = BOL_UOM_VOLUME then
		return Choice_Vol;
	elseif _input = BOL_UOM_WEIGHT then
		return Choice_Weight;
	else
		return null;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_input" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
