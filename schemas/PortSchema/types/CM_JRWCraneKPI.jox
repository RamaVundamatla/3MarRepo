    <JadeMethod name="noOutputReturned" id="94b25b02-f969-4c82-a400-adf1aee11b34">
        <source>noOutputReturned(): Boolean;
// Dec 2010 CCMS 1134
vars

begin
	return self.allVoyageKPICraneShifts.isEmpty();

