    </JadeMethod>
    <JadeMethod name="eraseForVoyage" id="68790551-80b0-4cbc-8875-09b51cd874fb">
        <updating/>
        <source>eraseForVoyage(eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myVoyage := null;

	inheritMethod(eraseLevel);

end;</source>
        <Parameter name="eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyStockMovement" id="81f2f7a4-2230-49a0-a127-f036ff0b29e2">
        <source>getMyStockMovement(): CM_StockMovement;
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return self.myStockMovement;

end;</source>
        <ReturnType type="CM_StockMovement"/>
    </JadeMethod>
    <JadeMethod name="hasStockMovements" id="eb99116a-7bc3-4049-966f-d0a640ce4804">
        <source>hasStockMovements(): Boolean;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myStockMovement &lt;&gt; null then
	   	return true;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
