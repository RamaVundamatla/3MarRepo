    <JadeMethod name="writeToFileTest" id="fe8f7692-0326-4326-b968-be1fbe9bab31">
        <source>writeToFileTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwdb2	Initial creation

*/

constants
    FileNameWrite          : String = 'C:\Users\cnwdb2\Documents\excelTest.csv';
vars
    fileWrite    : File;
    recordCount  : Integer;
    str  : String;
	stringArray : StringArray  ; 
	
	/// create an index variable which adds one to each thing in a string?
	index  : Integer ; 
	

begin

	create stringArray transient  ; 
	stringArray.add("Line One") ;  
	stringArray.add("Line two")  ; 
	stringArray.add("Line three") ;  
	

    create fileWrite;
    fileWrite.mode     := File.Mode_Output;
    fileWrite.fileName := FileNameWrite;
    fileWrite.open;
    recordCount  := 1;
	foreach str in stringArray do	
        fileWrite.writeLine(str);
        recordCount := recordCount + 1;
	endforeach ; 
    fileWrite.close;
epilog
    delete fileWrite;
	delete stringArray  ; 
end;</source>
    </JadeMethod>
    <JadeMethod name="zGetHugeStringArray" id="8c494593-cc40-4532-a17e-0111adb9552c">
        <source>zGetHugeStringArray()  : HugeStringArray;
/*

Purpose: This returns the good and bad value of the agreed naming conventions for each table as written in the method uGetGoodVsBadTableNames

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2014	cnwdb2	Initial creation

*/

vars
	b , str  : String ; 
	firstLineBreak : HugeStringArray ; 
	seperatedLines : StringArray ;
	schema : Schema ; 
	class : Class ; 
	obj : Object;
	meth : Method ; 
begin 
	
	/*This is how you call a method that does not belong to the class.
	schema := rootSchema.getSchema('SysOpsSchema') ; 
	class := schema.getClass('SOP_TableMaintItem') ; 
	
	create obj as class transient ; 
	write obj.sendMsg('aaaaaaadb2Test') ; */
	//start of relevant code
	
	create firstLineBreak transient ; 
	create seperatedLines transient ; 
	b := uGetGoodVsBadTableNames() ; 
	
	b.getTokensForDelimiterHuge(Cr,firstLineBreak) ; // read the HUGE line and put it into the delimiter firstlinebreak

	
	return firstLineBreak ; 
	
	
	//Just to this point
	/*foreach str in firstLineBreak do
				 
		seperatedLines.clear() ;
		str.getTokensForDelimiter(",",seperatedLines) ; 
	
		if seperatedLines.size &lt;= 1 then
			continue ; 
		endif; 
		
		write seperatedLines[1] &amp; " &lt;&lt;&gt;&gt; " &amp; seperatedLines[2]  ;
	endforeach  ;  
	*/
	
	epilog 
		delete obj;
		delete seperatedLines  ; 
end ; 
</source>
        <ReturnType type="HugeStringArray"/>
    </JadeMethod>
</Class>
