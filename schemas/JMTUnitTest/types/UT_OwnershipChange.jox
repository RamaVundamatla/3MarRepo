<Class name="UT_OwnershipChange" id="e3411a3e-c3cd-4efd-9ae0-12ad03fe2192">
    <superclass name="UT_Invoicing"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="addOperatorToVoyage" id="c427e1c8-e977-4c63-9622-92e40da943ab">
        <source>addOperatorToVoyage(_voyage : CM_Voyage; _operator : CM_Operator);
/*
Purpose:	

Date		Who		Reason
22 January 2025	navab1	JIRA 33540
*/

vars
	voy : CM_Voyage;
begin
	voy := _voyage;
	if not voy.allOperators.includes(_operator) then			
		beginTransaction;
		voy.allOperators.add(_operator);
		commitTransaction;
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="addReleaseByTypeRequests" id="c01f897f-58a5-453d-9f7b-b9b8543bf761">
        <source>addReleaseByTypeRequests(_releaseNumber: String; _releaseType: Integer; _cargoType: Integer): CM_BulkRelease;
/*

Date		Name	TFS#			Description
============================================================================
	
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation		
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight														
============================================================================*/
vars
	release				: CM_BulkRelease;
	pxyReleaseRequest	: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	pxyReserveSelection2: CM_ReserveSelection;
	pxyDeliveryRequest 	: CM_DeliveryRequest;
	isoType				: CM_ISOType;
	isoGroup			: CM_ISOTypeGroup; 
	isoGroup2			: CM_ISOTypeGroup;
	fullRelease			: Boolean;
	canBeHiLoCube 		: Boolean;
	ta					: CM_TerminalArea;
	number				: Integer;
	voyage				: CM_Voyage;
	voyageCode			: String;
	operator 			: CM_Operator;
	grade 				: CM_MTGrade;
	availGrades 		: IntegerArray;
	carrierId 			: String;
	consignor			: String;
	consignee			: String;
	matchYACriteria 	: CM_ReleaseByTypeCriteria;
	delRequest 			: CM_DeliveryRequest;
	reserveSel 			: CM_ReserveSelection;
	allTermAreaDict		: CM_TAByIdDict;
	doDelete 			: Boolean;
	weightSelection 	: Decimal[14,4];
	weightRequested 	: Decimal[14,4];	
	tempWeightSelection : Decimal[14,4];
	measurementType 	: CM_MeasurementType;
	unit 				: String;
	customerRef			: String;
	lineNum				: Integer;
	isoTypeStr			: String;
	cargoGroup          : CM_CargoGroup; 
	volumeSelection     : Decimal[14,4];
	realOwnershipChange : CM_OwnershipChange;
	contextStr : String;
begin
	if self.opts.includesKey("Number") then
		number := self.opts.int("Number");
	elseif self.opts.includesKey(UT_OPTS_Number) then
		number := self.opts.int(UT_OPTS_Number);
	endif;
	
	if number = 0 then
		number := 1;
	endif;
	
	// NAVAB1 FIXUP UTs 08OCT2024
	if self.opts.includesKey("Context") then
		contextStr := self.opts.str("Context");
	endif;
	
	operator := self.opts.obj("Operator").CM_Operator; 
	if operator = null then
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;	
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_releaseNumber,
								_releaseType,
								true,
								BR_ACTIVE,
								null,
								null,
								//self.getProfileStr(UT_Profile.P_CARRIER),
								carrierId,
								null,
								consignee,
								null,
								consignor,
								null,
								null,//consign voyage
								app.actualTimeServer(),	
								null, //today,
								null,
								null,
								null,
								null, //door dir
								null,
								self.opts.obj("Booking").CM_BookingRef,
								self.getTerminal().getDefaultPort,//load port
								self.opts.obj("Destination").CM_Port,//_destinationPort
								self.opts.obj("DischargePort").CM_Port,
								null,//freightForwarder
								null,
								self.getTerminal(),
								operator,
								null,
								voyage,//voyage
								null,//bank
// 								false,
								fullRelease,
								null,null,null,
								self.getTerminal().getDefaultSubTerminalForRel(_releaseType),
								null,
								self.opts.obj("Train").CM_Train, 	//_assignedTrain : CM_Train
								false,
								null,
								false,	
								canBeHiLoCube, false,
								false,
								null, 	
								null,
								null,
								contextStr // NAVAB1 FIXUP UTs 08OCT2024
								);
	if self.opts.includesKey("weightRequested") then					
		weightRequested := self.opts.dec("weightRequested");
	endif;
	if self.opts.includesKey("WeightSelection") then						
		weightSelection := self.opts.dec("WeightSelection");
	endif;
	
	if self.opts.includesKey("MeasurementType")then							
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weightSelection := app.convertMeasurementForStorage(measurementType.shortName, weightSelection);
		weightRequested := app.convertMeasurementForStorage(measurementType.shortName, weightRequested);
	endif;
	
	if self.opts.includesKey("CargoGroup") then
		cargoGroup := self.opts.obj("CargoGroup").CM_CargoGroup;
	endif;
	
	create pxyReserveSelection transient;
	pxyReserveSelection.setMyHeader(pxyReleaseRequest);
	pxyReserveSelection.setPxyDefaults();

	pxyReserveSelection.setProxy(0, 
								app.myRoot.allCargoTypesById[_cargoType],
								self.opts.obj("BookingItem").CM_BookingRefItem,
								isoType,
								isoGroup,
								self.opts.obj("Product").CM_Product,
								null,
								null,
								number,
								availGrades, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,
								self.opts.str("Colour"),
								null,
								null,
								null,
								null,
								null,
								null,
								volumeSelection,
								//null,
								weightSelection,					
								null,
								self.opts.str("Mark"),
								null,
								null,
								allTermAreaDict,
								self.opts.obj("BOL").CM_BOLIn,
								self.opts.bool("BestPick"),
								null,
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,
								null,null, 
								cargoGroup, 
								false,			// 6/12/2023 navcs2 ChangeRequest 57537
								false, //19/02/2023	navkc1 CR 60078 Task 62450
								null, //24/04/2025	navrv30	MTN 34319
								null);
   
								
	if matchYACriteria &lt;&gt; null then
		matchYACriteria.setProxyBaseData(pxyReserveSelection);
	endif;
	
	if self.opts.includesKey("weightRequested") then
		pxyReserveSelection.setWeightRequested(weightRequested);
	endif;
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, release,null, app.myPassport);
			
	return release;
epilog
	delete pxyReleaseRequest;
	delete availGrades;
	delete allTermAreaDict;
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="chkOwnershipChangeAndDetls" id="3070f481-5731-430a-9e79-dda42f6f0cd2">
        <source>chkOwnershipChangeAndDetls(_trackAs, _trackBy : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
16 September 2023 navrv30 MTN 35967: MTN | Failing Unit Test - tOwnershipChangeAndDtls
*/

vars
	allTransientDetails,
	detailsSet : ObjectArray;
	pxyOwnershipChange,
	realOwnershipChange : CM_OwnershipChange;
	cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail;
	relRequest, releaseRequest1 : CM_BulkRelease;
	detail, pxyDetail : CM_OwnershipChangeDetail;
	myOperatorOrig : CM_Operator;
	debtor : CM_Debtor;
	cargoGroup : CM_CargoGroup;
	
begin
	create allTransientDetails transient;
	//initial setup
	self.deleteDebtor("debtor");
	debtor := self.addDebtor("debtor", PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor,"Debtor Create Failed");
	self.deleteOperator("Orig");
	myOperatorOrig := self.addOperator("Orig", "Ownership Change OperatorOrig", false, 0, 0, debtor, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOrig,"Operator Create Failed");
	
	self.opts.addAssoc("Operator",myOperatorOrig);
	
	pxyOwnershipChange := self.createOwnershipChangePxy("ABC1");
	detailsSet := self.createDetailsProxies(false,_trackAs,_trackBy);
	create cmifOwnershipChangeDtl transient;
	detailsSet.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	cargoGroup := detailsSet.first.CM_OwnershipChangeDetail.myTrackedItem.CM_CargoGroup;
	
	//27/05/2024	navkc1 Bug 64182
	foreach pxyDetail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		allTransientDetails.add(pxyDetail);
		pxyDetail.allSubDetails.copy(allTransientDetails);
	endforeach;
	
	if _trackAs = ProductType_Bulk then
		//self.opts.addAssoc("weightRequested",cargoGroup.totalWeight);
		self.opts.addAssoc("weightRequested",(cargoGroup.totalWeight/2));	//21/05/2024	navkc1 Bug 64182
	else
		//self.opts.addAssoc("Number",cargoGroup.totalQuantity);
		self.opts.addAssoc("Number",(cargoGroup.totalQuantity/2).Integer);  //21/05/2024	navkc1 Bug 64182
	endif;
	
	self.deleteReleaseRequest("abcd");
	self.opts.addAssoc("CargoGroup", cargoGroup);
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview); // NAVAB1 FIXUP UTs 08OCT2024
	relRequest := self.addReleaseByTypeRequests("abcd",1,cargoGroup.allAssignedTrackedItems.first.cargoType);
	
	self.assertTrueMsg(relRequest &lt;&gt; null,"Rel Rel NOT created"); // NAVAB1 FIXUP UTs 08OCT2024
	
	//The item has already been reserved on a release request, an error will be thrown
	/*self.expectedTrxErrors.add(Item_alrea_reser_canno_relea_f);
	releaseRequest1 := self.addReleaseByTypeRequests("abcd1",1,detailsSet.first.CM_OwnershipChangeDetail.myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first.CM_TrackedItem.cargoType);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Item_alrea_reser_canno_relea_f), " Should include error " &amp; Item_alrea_reser_canno_relea_f.String 
	&amp; " " &amp; app.getErrorString(Item_alrea_reser_canno_relea_f));*/
	
	//Trying to create ownership change detail when item is already present on a release request, warning is thrown
	self.expectedTrxErrors.add(Item_curre_relea_reque_canno_t);
	
	while true do
		app.myTrxCA.trxCreateOwnershipChangeAndDtl(pxyOwnershipChange,realOwnershipChange,cmifOwnershipChangeDtl,app.myPassport);
		self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Item_curre_relea_reque_canno_t), " Should include error " &amp; Item_curre_relea_reque_canno_t.String
		&amp;" " &amp;app.getErrorString(Item_curre_relea_reque_canno_t) );
		if not app.myPassport.trxCompletedOK and app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	//21/05/2024	navkc1 Bug 64182
	// Got error because items already in release request
	self.assertTrxError(Item_curre_relea_reque_canno_t);
	
	// Updat the ownership change details, qty weight vol to be half
	foreach detail in detailsSet as CM_OwnershipChangeDetail do
		detail.setPropertyValue("transferredQuantity", (detail.transferredQuantity/2).Integer);
		detail.setPropertyValue("transferredVolume", (detail.transferredVolume/2).asDecimal(23,4));
		detail.setPropertyValue("transferredWeight", (detail.transferredWeight/2).asDecimal(23,4));
	endforeach;
	
	// Create ownership change again, it shouldn't have any errors.
	while true do
		app.myTrxCA.trxCreateOwnershipChangeAndDtl(pxyOwnershipChange,realOwnershipChange,cmifOwnershipChangeDtl,app.myPassport);
		//self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Item_curre_relea_reque_canno_t), " Should include error " &amp; Item_curre_relea_reque_canno_t.String
		//&amp;" " &amp;app.getErrorString(Item_curre_relea_reque_canno_t) );
		if not app.myPassport.trxCompletedOK and app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	self.assertNoTrxErrorsOrWarnings();
	self.verifyOwnershipChange(pxyOwnershipChange,realOwnershipChange);
	self.verifyOwnershipChangeDtls(detailsSet,realOwnershipChange);
	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	detailsSet.clear();
	delete detailsSet;
	delete pxyOwnershipChange;
	foreach detail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		delete detail;
	endforeach;
	delete cmifOwnershipChangeDtl;
	
	/* //21/05/2024	navkc1 Bug 64182 - No longer needed to test update, because the coo is not created due to raising errors instead of warnings
	beginTransaction;
	pxyOwnershipChange := realOwnershipChange.pxyCreateUpdateProxy();
	foreach detail in realOwnershipChange.allDetails do
		pxyDetail := app.createUpdateProxy(detail).CM_OwnershipChangeDetail;
		pxyDetail.setOwnershipChange(pxyOwnershipChange);
	endforeach;
	commitTransaction;
	
	//Trying to update ownership change detail when item is already present on a release request, error is thrown
	self.expectedTrxErrors.add(Item_curre_relea_reque_canno_t);
	app.myTrxUA.trxUpdateOwnershipChange(pxyOwnershipChange,app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Item_curre_relea_reque_canno_t), " Should include error " &amp; Item_curre_relea_reque_canno_t.String
	&amp; " " &amp; app.getErrorString(Item_curre_relea_reque_canno_t));
	*/
	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	
	//delete pxyDetail;
	delete pxyOwnershipChange;
	delete detailsSet;
	delete cmifOwnershipChangeDtl;
	
	if _trackAs = ProductType_Bulk then
		self.opts.addAssoc("weightRequested",cargoGroup.totalWeight);
	else
		self.opts.addAssoc("Number",cargoGroup.totalQuantity);
	endif;
	self.opts.addAssoc("CargoGroup", cargoGroup);
	
	self.opts.addAssoc("Operator",myOperatorOrig);
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview); // NAVAB1 FIXUP UTs 08OCT2024
	
	//trying to create a new release request when the item is already present on a release request and Ownership change, an error is thrown
	/*16 September 2023 navrv30 MTN 35967 - When doing the validation, the order is BOL then Cargo Group, Commodity, Voyage and then 
	Ownership change. PReviously all the errors from these methods are consolidated and returned and then all the errors are displayed same , code has been 
	changed to display one error at a time and hence this was failing as the ownership change error is recorded last*/
	self.expectedTrxErrors.add(Total_reque_value_not_more_tha);
	self.expectedTrxErrors.add(Weigh_reque_value_not_more_tha);
	releaseRequest1 := self.addReleaseByTypeRequests("abcd1",1,cargoGroup.allAssignedTrackedItems.first.cargoType);
	if _trackBy = CargoType_TrackByWeight then
		self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Weigh_reque_value_not_more_tha), " Should include error " &amp; Weigh_reque_value_not_more_tha.String
	&amp; " "&amp;app.getErrorString(Weigh_reque_value_not_more_tha));
	else 
		self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Total_reque_value_not_more_tha), " Should include error " &amp; Total_reque_value_not_more_tha.String
	&amp; " "&amp;app.getErrorString(Total_reque_value_not_more_tha));
	endif;
	
	pxyOwnershipChange := self.createOwnershipChangePxy("ABC2");
	detailsSet := self.createDetailsProxies(true,null,null);
	create cmifOwnershipChangeDtl transient;
	detailsSet.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	
	foreach pxyDetail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		allTransientDetails.add(pxyDetail);
		pxyDetail.allSubDetails.copy(allTransientDetails);
	endforeach;
	
	//trying to create a new ownership change when the item is already present on a release request and Ownership change, a warning is thrown
	self.expectedTrxErrors.add(Item_reser_plus_curr_ow_tran);
	while true do
		app.myTrxCA.trxCreateOwnershipChangeAndDtl(pxyOwnershipChange,realOwnershipChange,cmifOwnershipChangeDtl,app.myPassport);
		self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Item_reser_plus_curr_ow_tran), " Should include error " &amp;
		Item_reser_plus_curr_ow_tran.String &amp; " " &amp; app.getErrorString(Item_reser_plus_curr_ow_tran));
		if not app.myPassport.trxCompletedOK and app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	//21/05/2024	navkc1 Bug 64182 - It's now raising error instead of warning, coo shouldn't get created
	self.assertTrueMsg( (not app.isValidObject(realOwnershipChange) or realOwnershipChange = null), "Real Ownership should be null");
	//self.verifyOwnershipChange(pxyOwnershipChange,realOwnershipChange);
	//self.verifyOwnershipChangeDtls(detailsSet,realOwnershipChange);
	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	delete pxyOwnershipChange;
	delete detailsSet;
	foreach detail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		delete detail;
	endforeach;
	delete cmifOwnershipChangeDtl;
	
	/* //21/05/2024	navkc1 Bug 64182 - No longer needed to test update, because the coo is not created due to raising errors instead of warnings
	beginTransaction;
	pxyOwnershipChange := realOwnershipChange.pxyCreateUpdateProxy();
	foreach detail in realOwnershipChange.allDetails do
		pxyDetail := app.createUpdateProxy(detail).CM_OwnershipChangeDetail;
		pxyDetail.setOwnershipChange(pxyOwnershipChange);
	endforeach;
	commitTransaction;
	
	//trying to update  ownership change when the item is already present on a release request and Ownership change, an error is thrown
	self.expectedTrxErrors.add(Item_reser_plus_curr_ow_tran);
	app.myTrxUA.trxUpdateOwnershipChange(pxyOwnershipChange,app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Item_reser_plus_curr_ow_tran), " Should include error " &amp; Item_reser_plus_curr_ow_tran.String 
	&amp; " " &amp; app.getErrorString(Item_reser_plus_curr_ow_tran));
	*/
	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	
	//delete pxyDetail;
	delete pxyOwnershipChange;
	delete detailsSet;
	delete cmifOwnershipChangeDtl;
	
	self.deleteReleaseRequest("abcd");
	
	pxyOwnershipChange := self.createOwnershipChangePxy("ABC3");
	detailsSet := self.createDetailsProxies(true,null,null);
	create cmifOwnershipChangeDtl transient;
	detailsSet.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	
	foreach pxyDetail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		allTransientDetails.add(pxyDetail);
		pxyDetail.allSubDetails.copy(allTransientDetails);
	endforeach;
	
	//trying to create a new rownership change when the item is already present on a Ownership change, a warning is thrown
	self.expectedTrxErrors.add(Item_alrea_owner_chang_canno_t);
	while true do
		app.myTrxCA.trxCreateOwnershipChangeAndDtl(pxyOwnershipChange,realOwnershipChange,cmifOwnershipChangeDtl,app.myPassport);
		self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Item_alrea_owner_chang_canno_t), " Should include error " &amp;
		Item_alrea_owner_chang_canno_t.String &amp; " " &amp; app.getErrorString(Item_alrea_owner_chang_canno_t));
		if not app.myPassport.trxCompletedOK and app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	//21/05/2024	navkc1 Bug 64182
	self.assertTrueMsg( (not app.isValidObject(realOwnershipChange) or realOwnershipChange = null), "Real Ownership should be null");
	//self.verifyOwnershipChange(pxyOwnershipChange,realOwnershipChange);
	//self.verifyOwnershipChangeDtls(detailsSet,realOwnershipChange);
	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	delete pxyOwnershipChange;
	delete detailsSet;
	foreach detail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		delete detail;
	endforeach;
	delete cmifOwnershipChangeDtl;
	
	/* //21/05/2024	navkc1 Bug 64182 - No longer needed to test update, because the coo is not created due to raising errors instead of warnings
	beginTransaction;
	pxyOwnershipChange := realOwnershipChange.pxyCreateUpdateProxy();
	foreach detail in realOwnershipChange.allDetails do
		pxyDetail := app.createUpdateProxy(detail).CM_OwnershipChangeDetail;
		pxyDetail.setOwnershipChange(pxyOwnershipChange);
	endforeach;
	commitTransaction;
	
	//trying to update ownership change when the item is already present on a Ownership change, an error is thrown
	self.expectedTrxErrors.add(Item_alrea_owner_chang_canno_t);
	app.myTrxUA.trxUpdateOwnershipChange(pxyOwnershipChange,app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Item_alrea_owner_chang_canno_t), " Should include error " &amp; Item_alrea_owner_chang_canno_t.String
	&amp; " "&amp; app.getErrorString(Item_alrea_owner_chang_canno_t));
	*/
	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	
	//delete pxyDetail;
	delete pxyOwnershipChange;
	delete detailsSet;
	delete cmifOwnershipChangeDtl;
	
	//trying to create a new release request when the item is already present on a Ownership change, an error is thrown
	self.expectedTrxErrors.add(Item_curre_owner_chang_canno_r);
	if _trackAs = ProductType_Bulk then
		self.opts.addAssoc("weightRequested",cargoGroup.totalWeight);
	else
		self.opts.addAssoc("Number",cargoGroup.totalQuantity);
	endif;
	self.opts.addAssoc("CargoGroup", cargoGroup);
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview); // NAVAB1 FIXUP UTs 08OCT2024
	
	self.opts.addAssoc("Operator",myOperatorOrig);
	releaseRequest1 := self.addReleaseByTypeRequests("abcd1",1,cargoGroup.allAssignedTrackedItems.first.cargoType);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Item_curre_owner_chang_canno_r), " Should include error " &amp; Item_curre_owner_chang_canno_r.String
	&amp; " " &amp; app.getErrorString(Item_curre_owner_chang_canno_r));
	
	self.deleteReleaseRequest("abcd");
	self.deleteDebtor(debtor);
	self.deleteOperator(myOperatorOrig.code);
	
epilog
	allTransientDetails.purge();
	delete allTransientDetails;
	delete pxyOwnershipChange;
	delete detailsSet;
end;</source>
        <access>protected</access>
        <Parameter name="_trackAs" type="Integer"/>
        <Parameter name="_trackBy" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createContract" id="86a4d8e6-45fa-4420-be7d-8a7eecad5253">
        <updating/>
        <source>createContract(_debtor : CM_Debtor; _contractId : String; _active, primary : Boolean; _fromTS, _toTS : TimeStamp; _purgeContracts : Boolean) : CM_InvoiceContract updating;
/*
Purpose:			

Date		Who		Reason
15 August 2024	navra1	Initial creation for //navra1 - TFS 64874 - 14th Aug 2024
*/ 
 
vars
	pxyCon, realCon : CM_InvoiceContract;
	terminal : CM_Terminal;
	bank : CM_Bank;
	debtor : CM_Debtor;
begin
	debtor := _debtor;
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();

	if _purgeContracts then
		self.deleteAllContractsForDebtor(debtor);
	endif;
	
	create pxyCon transient;
	pxyCon.setProxy(_active,_contractId, _fromTS, _toTS, primary, bank, terminal, debtor, "Generated By Unit Test");
	
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realCon.contractId = _contractId, "Contract Id should be " &amp; _contractId &amp; ", it is &gt;&gt;&gt;" &amp; realCon.contractId &amp; "&lt;&lt;&lt;");
	assertTrueMsg(realCon.primary = primary, "Contract should NOT be PRIMARY");
	assertTrueMsg(realCon.active = _active, "Contract should NOT be ACTIVE");
	assertTrueMsg(realCon.myBusinessUnit &lt;&gt; null, "BANK is null");
	assertTrueMsg(realCon.myBusinessUnit = bank, "BANK is wrong");
	assertTrueMsg(realCon.myTerminal &lt;&gt; null, "TERMINAL is null");
	assertTrueMsg(realCon.myTerminal = terminal, "TERMINAL is wrong");
	assertTrueMsg(realCon.myDebtor &lt;&gt; null, "DEBTOR is null");
	assertTrueMsg(realCon.myDebtor = debtor, "DEBTOR is wrong");
	assertTrueMsg(realCon.description = "Generated By Unit Test", "Description is wrong");
	
	return realCon;
epilog
	delete pxyCon;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_purgeContracts" type="Boolean"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="createDetailsProxies" id="f4dfbcbc-4a16-4eed-90d1-4185defe4232">
        <source>createDetailsProxies(_existingCargoGroup : Boolean; _trackAs, _trackBy : Integer): ObjectArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

constants
	
vars
	pxySubDetails,
	pxyOwnershipDetail				: CM_OwnershipChangeDetail;
	transferedWeight, transferedVolume : Decimal[23,4];
	ti, pxyTI								: CM_TrackedItem;
	allTis                          : CM_TISet;
	cargoGroup                      : CM_CargoGroup;
	cargoType 						: CM_CargoType;
	bs								: CM_BlockStack;
	include  						: Boolean;
	transferedQuantity : Integer;
	allDetails : ObjectArray;
begin
	include := true;
	
	if not _existingCargoGroup then
		bs := self.addBlockStack("BSLOCC", 49, null);
		self.assertNotNull(bs);
		if _trackAs&lt;&gt; null then
			self.opts.addAssoc("TrackAs", _trackAs);
		endif;
		create allTis transient;
		
		cargoType := self.addCargoType("TYPE1",false);
		if _trackBy &lt;&gt; null then
		beginTransaction;
			cargoType.setPxyTrackBy(_trackBy);
			cargoType.setPropertyValue("allowDuplicates",true); // NAVAB1 FIXUP UTs 08OCT2024
		commitTransaction;
		endif;
		self.deleteCargo("UT_MATOCC", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC1", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC1", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC2", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC2", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC3", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC3", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC4", cargoType);
		ti := self.createTrackedItem("UT_MAOCC4", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargo("UT_MATOCC5", cargoType);	
		ti := self.createTrackedItem("UT_MAOCC5", cargoType.id, null, app.myRoot.allOperators["Orig"], false, bs.myLocationsController);
		allTis.add(ti);
		
		self.deleteCargoGroup("GRP1");
		cargoGroup := self.addCargoGroup("GRP1",allTis);
	else
		cargoGroup := self.getMyTerminal().getCargoGroupItem("GRP1");
	endif;
	
	self.assertNotNull(cargoGroup);
	transferedWeight		:= cargoGroup.totalWeight;
	transferedVolume		:= cargoGroup.totalVolume;
	transferedQuantity		:= cargoGroup.totalQuantity;
	
	
	create pxyOwnershipDetail transient;
	pxyOwnershipDetail.setProxy(transferedWeight,transferedVolume,transferedQuantity,include,null,null,cargoGroup);
	
	//27/05/2024	navkc1 Bug 64182
	foreach ti in cargoGroup.allAssignedTrackedItems do
		create pxySubDetails transient;
		transferedWeight		:= ti.totalWeight;
		transferedVolume		:= ti.totalVolume;
		transferedQuantity		:= ti.totalQuantity;
		
		pxySubDetails.setProxy(transferedWeight,transferedVolume,transferedQuantity,include,null,pxyOwnershipDetail,ti);
	endforeach;
	
	create allDetails transient;
	allDetails.add(pxyOwnershipDetail);
	return allDetails;
epilog
	delete allTis;
end;</source>
        <Parameter name="_existingCargoGroup" type="Boolean"/>
        <Parameter name="_trackAs" type="Integer"/>
        <Parameter name="_trackBy" type="Integer"/>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="createGCOnVoyage" id="607cae91-6929-488d-accb-af23272d6b6e">
        <source>createGCOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer; _volume : Decimal; _quantity : Integer) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
13FEB2023	NAVAB1	CR 56446 TASK 56447  
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.getProductFromCode("12POUNDER-12");
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage, _voyage.myOperator, _quantity, null).CM_Cargo;
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", _volume);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight);
	self.opts.addAssoc(UTTI_CustomsAgent, "UTCA1"); // ### TFS CR 58263 TASK 58264 07FEB2024 NAVAB1
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	return cargo;
epilog

end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createOwnerShip" id="bbccc20b-6b2e-45cd-a041-c4b0aa7854c7">
        <source>createOwnerShip(_realOwnership: CM_OwnershipChange output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2023 navtnr20	TFS CR 58507	Task 58211: Jade - Unit Test Ownership Change

*/
constants

	DEBTOR 		= "UT_DEBTOR_AB";
vars
	pxyOwnership				: CM_OwnershipChange;
	dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew: TimeStamp;
	remarks 					: String;
	myiNCOTerm					: CM_InvoiceINCOTerm;
	myOperatorNew,
	myOperatorOid,
	myOperatorOrig,
	myOperatorStorage			: CM_Operator;
	myFreightForward			: CM_ConsigneeConsignor;
	root						: CM_Root;
	terminal					: CM_Terminal;
	myOwnerShip					: CM_OwnershipChange;
	transferedWeight, transferedVolume : Decimal[23,4];
	debtor1			: CM_Debtor;
begin
	//Create OwnershipChange
 
	dateTimeCOO		:= app.actualTimeAppServer();
	storageExpriryOperatorNew := app.actualTimeAppServer();
	root := app.myRoot;
	terminal := self.getTerminal;
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	transferedWeight		:= 25.4578;
	transferedVolume		:= 78.8974;
	if self.opts.includesKey("DtRequired") then
		dateTimeApproved := self.opts.str("DtRequired").TimeStamp;
	endif;
	self.deleteInvINCOTerm("abcd");
	self.contractINCOCreate(myiNCOTerm, "abcd");
	self.deleteDebtor(DEBTOR);
	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	self.deleteOperator("ABCO");
	self.deleteOperator("Oid");
	self.deleteOperator("Orig");
	self.deleteOperator("OStorage");
	self.deleteConsigneeConsignor("UTFreightForward");
	myOperatorNew := self.addOperator("ABCO", "Ownership Change OperatorNew", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorNew,"Operator Create Failed");
	//myOperatorNew := root.allOperators[UTOperatorNew];
	myOperatorOid := self.addOperator("Oid", "Ownership Change Operatoroid", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOid,"Operator Create Failed");
	myOperatorOrig := self.addOperator("Orig", "Ownership Change OperatorOrig", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOrig,"Operator Create Failed");
	myFreightForward := self.addConsigneeConsignor("UTFr", "FreightForward", true, false, false);
	myOperatorStorage := self.addOperator("OSto", "Ownership Change OperatorStorage", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorStorage,"Operator Create Failed");
	foreach myOwnerShip in myOperatorNew.allOwnershipChangeNew do 
		if  myOwnerShip.refNumber = "ABCde" then
			deleteOwnershipChange(myOwnerShip);
		endif;
	endforeach;
	

    create pxyOwnership transient;
	pxyOwnership.setProxy('ABCde',app.getMyUserCode(),"Good",app.getMyUserCode(),dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew,11,12,13,150,transferedWeight,transferedVolume,remarks,
	myFreightForward,myiNCOTerm,myOperatorNew,myOperatorOid,myOperatorOrig,myOperatorStorage,null,terminal, null);	//navra1 - TFS 64874 - 14th Aug 2024
	
	self.createOwnershipChange(pxyOwnership,_realOwnership);
	self.assertEqual(_realOwnership.refNumber,"ABCde");
	self.assertEqual(_realOwnership.userCodeApproved,app.getMyUserCode());
	self.assertEqual(_realOwnership.condition,"Good");
	self.assertEqual(_realOwnership.userCode,app.getMyUserCode());
	self.assertEqual(_realOwnership.dateTimeCOO,dateTimeCOO);
	self.assertEqual(_realOwnership.dateTimeApproved,dateTimeApproved);
	self.assertEqual(_realOwnership.storageExpiryOperatorNew,storageExpriryOperatorNew);
	self.assertEqual(_realOwnership.freeDaysAdditional,11);
	self.assertEqual(_realOwnership.freeDaysOperatorNew,12);
	self.assertEqual(_realOwnership.freeDaysOperatorOld,13);
	self.assertEqual(_realOwnership.transferredQuantity,150);
	self.assertEqual(_realOwnership.transferredWeight,transferedWeight);
	self.assertEqual(_realOwnership.transferredVolume,transferedVolume);
	self.assertEqual(_realOwnership.remarks,remarks);
	self.assertEqual(_realOwnership.myFreightForwarder,myFreightForward);
	self.assertEqual(_realOwnership.myIncoterm,myiNCOTerm);
	self.assertEqual(_realOwnership.myOperatorNew,myOperatorNew);
	self.assertEqual(_realOwnership.myOperatorOld,myOperatorOid);
	self.assertEqual(_realOwnership.myOperatorOrig,myOperatorOrig);
	self.assertEqual(_realOwnership.myOperatorStorage,myOperatorStorage);
	self.assertEqual(_realOwnership.myOwnershipChangePrevious,null);
	self.assertEqual(_realOwnership.myTerminal,terminal);
	
	//delete pxyOwnership;
epilog
	delete pxyOwnership;
end;</source>
        <Parameter name="_realOwnership" type="CM_OwnershipChange" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createOwnership000d" id="6380efb7-7106-4976-af7c-f5435fa10fc4">
        <updating/>
        <source>createOwnership000d(_refNumber,_userCodeApproved,_condition, _userCode : String; _dateTimeCOO, _dateTimeApproved, _storageExpiryOperatorNew : TimeStamp; 
	_freeDaysAdditional, _freeDaysOperatorNew, _freeDaysOperatorOld, _transferredQuantity : Integer; _transferredWeight,_transferredVolume : Decimal; _remarks : String;
	_myFreightForward : CM_ConsigneeConsignor; _myIncoTerm : CM_InvoiceINCOTerm; _myOperatorNew, _myOperatoeOid,_myOperatorOrig,_myOperatorStorage : CM_Operator;
	_myOwnerShipChangePrevious: CM_OwnershipChange; _myTerminal : CM_Terminal ): CM_OwnershipChange updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023 navtnr20	TFS CR 58507	Task 58212: Jade - Test script to Create Test COO

*/

vars
	refNumber,
	userCodeApproved,
	condition, 
	userCode,
	remarks 					: String;
	dateTimeCOO, 
	dateTimeApproved,
	storageExpiryOperatorNew 	: TimeStamp;
	freeDaysAdditional, 
	freeDaysOperatorNew,
	freeDaysOperatorOld,
	transferredQuantity 		: Integer;
	transferredWeight,
	transferredVolume 			: Decimal[23,4];
	myFreightForward 			: CM_ConsigneeConsignor;
	myIncoTerm 					: CM_InvoiceINCOTerm;
	myOperatorNew, 
	myOperatoeOid,myOperatorOrig,
	myOperatorStorage 			: CM_Operator;
	myOwnerShipChangePrevious,
	_pxyOwnershipChange,
	_realOwnershipChange		: CM_OwnershipChange;
	myTerminal 					: CM_Terminal;
begin
	refNumber				:= _refNumber;
	condition				:= _condition;
	userCode				:= _userCode;
	dateTimeApproved 		:= _dateTimeApproved;
	userCodeApproved		:= _userCodeApproved;
	dateTimeCOO				:= _dateTimeCOO;
	storageExpiryOperatorNew:= _storageExpiryOperatorNew;
	freeDaysAdditional		:= _freeDaysAdditional;
	freeDaysOperatorNew		:= _freeDaysOperatorNew;
	freeDaysOperatorOld		:= _freeDaysOperatorOld;
	transferredQuantity		:= _transferredQuantity;
	transferredWeight		:= _transferredWeight;
	transferredVolume		:= _transferredVolume;
	remarks					:= _remarks;
	myFreightForward		:= _myFreightForward;
	myIncoTerm				:= _myIncoTerm;
	myOperatorNew			:= _myOperatorNew;
	myOperatoeOid			:= _myOperatoeOid;
	myOperatorOrig			:= _myOperatorOrig;
	myOperatorStorage		:= _myOperatorStorage;
	myOwnerShipChangePrevious	:= _myOwnerShipChangePrevious;
	myTerminal					:= _myTerminal;
	create _pxyOwnershipChange transient;
	_pxyOwnershipChange.setProxy(_refNumber,_userCodeApproved,_condition,_userCode,_dateTimeCOO,_dateTimeApproved,_storageExpiryOperatorNew,_freeDaysAdditional,_freeDaysOperatorNew,
	_freeDaysOperatorOld,_transferredQuantity,_transferredWeight,_transferredVolume,_remarks,_myFreightForward,_myIncoTerm,_myOperatorNew,_myOperatoeOid,_myOperatorOrig,_myOperatorStorage,
	null,_myTerminal, null);			//navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(_pxyOwnershipChange,_realOwnershipChange);
	return _realOwnershipChange;
epilog
	delete _pxyOwnershipChange;
end;</source>
