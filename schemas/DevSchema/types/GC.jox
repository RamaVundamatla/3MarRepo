    <JadeMethod name="testGC" id="e66af48f-1c5e-456e-bd62-c743680b1e7f">
        <source>testGC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2025	navnk30	Initial creation

*/

vars
	bgpReq	: BGP_DatabasePurgeRequest;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("NAVNK30");
	app.myPassport.setMyTerminal(self.getRamTerm2);
	bgpReq := "6081.75".asOid().BGP_DatabasePurgeRequest;
	
	beginTransaction;
		bgpReq.action();
		delete bgpReq;
epilog
	commitTransaction;
end;</source>
