        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITI_rowColumnChg(table: CM_DataTable input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	i : Integer;
begin
	self.doTblBoldSelected(table);
	
	// 21/01/2013 cnwar2 #31028
	if self.mode = Mode_Update then
		foreach i in 1 to table.rows do
			if i &lt;&gt; table.row then
				table.accessRow(i).selected := false;
			endif;
		endforeach;
	endif;
end;</source>
