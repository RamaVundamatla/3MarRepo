    <JadeMethod name="handleContentsStatus" id="b8bb7eef-7e1e-42ab-97bd-e180577db610">
        <source>handleContentsStatus(_status : Integer; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	theCode,
	abbrKey,
	codeKey		: String;
	statusKey,
	theColor,
	colorKey	: Integer;
	tmpStatus	: CM_ContentsStatus;
	theObject : Object;
begin

	iter := self.myIterContentsStatus;
	self.allContentsStatus.startKeyGeq(_status, null, 0, iter);
	self.allContentsStatus.getIteratorKeys(statusKey, abbrKey, colorKey, iter);
	
	theCode		:= null;
	theColor	:= NullColour;
	if statusKey = _status then
		// found the right one
		theCode		:= abbrKey;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		tmpStatus := self.myRoot.allContentsStatuses[_status];
		if tmpStatus &lt;&gt; null then
			self.allContentsStatus.addNoDuplicates(tmpStatus,false);
			self.beginNotification(tmpStatus, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= tmpStatus.abbreviation;
			theColor	:= tmpStatus.colour;
			theObject := tmpStatus;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
