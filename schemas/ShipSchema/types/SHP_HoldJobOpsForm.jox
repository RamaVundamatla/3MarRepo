    <JadeMethod name="populateJobDetailsLocation" id="babbaacb-e358-4c1c-88ff-ba8400554b66">
        <updating/>
        <source>populateJobDetailsLocation(_job : CM_VoyageHoldJob) updating;
/*
Purpose:			
Date		Who		Reason
14/02/2017	cnwab1	Initial creation
22/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
16/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
19/08/2019	jlgzm1	TFS 42872 Direct Release Between HOLD Voyages and Rail
30/10/2019	jlgzm1	TFS 47085 Direct Release Ship to Ship
10/11/2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
07/12/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
*/

vars
   wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	showShipAreas : Boolean;				// TFS 3489
	fmp : CM_FutureMove;					// TFS 3489
	location : CM_LocationsController;		// TFS 3489
	foundHeight : Integer;				// TFS 52360

begin

	// If is direct release, get final destination
	if self.myCurrentWLE &lt;&gt; null and self.myCurrentWLE.isDRLinkedByFM then	// TFS 47085
		lc := self.myCurrentWLE.getTargetLocation();	// TFS 42872
		if lc &lt;&gt; null then								// TFS 42872
			self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(lc);	// TFS 42872
			self.myLoadArea := lc;						// TFS 42872
			return;										// TFS 42872
		endif;
	endif;
	
	foreach wle in _job.workListEntries discreteLock do
		if wle.status = WLE_COMPLETED then					// TFS 3516
			continue;										// TFS 3516
		endif;												// TFS 3516
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null then
			if ti.isSOB then												// TFS 3489
				showShipAreas := true;										// TFS 3489
			endif;															// TFS 3489
			lc := ti.myPrimaryPlannedLocation;								// TFS 3489
			// load job for a DLR - need ship locations, and primary		// TFS 3489
			// planeed location comes from future move						// TFS 3489
			if ti.isRehandle and not _job.isDischarge then					// TFS 3489
				showShipAreas := true;										// TFS 3489
				foreach fmp in ti.allPlannedFutureMoves do					// TFS 3489
					foreach location in fmp.CM_FutureMovePlanned.allLocationsControllers do		// TFS 3489
						if location.isVoyageController then					// TFS 3489
							lc := location;									// TFS 3489
							break;											// TFS 3489
						endif;												// TFS 3489
					endforeach;												// TFS 3489
				endforeach;													// TFS 3489
			endif;															// TFS 3489
			// TFS 52360 load job for a direct delivery prenote - location comes from wle 
			//if self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean 			// TFS 52293
			if _job.isDirectDeliveryJob 											// TFS 52293
			and not _job.isDischarge then
				self.myTerminal.findLocationFromString(wle.locationTarget, true, lc, foundHeight);
			endif;
			// TFS 52360 end
			if lc &lt;&gt; null then
				break;
			endif;
		endif;
	endforeach;
	
	//if _job.isDischarge then												// TFS 3489
	if _job.isDischarge and not showShipAreas then							// TFS 3489
		if lc &lt;&gt; null then
			ta := lc.getMyTerminalArea();
			if ta &lt;&gt; null then
				self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(ta);
				self.doBuildSubAreaCombo();
				self.myDischargeArea := ta;
				if ta.type = TA_TYPE_FORK_LIFT_STACK then															// TFS 3516
					self.cmbSubArea.listIndex := self.cmbSubArea.findObject(lc.CM_StackController.myGridColumn);	// TFS 3516
				elseif ta.type = TA_TYPE_STRADDLE_STACK then														// TFS 3516
					self.cmbSubArea.listIndex:= self.cmbSubArea.findObject(lc.CM_StackController.myGridRow);		// TFS 3516
				else																								// TFS 3516
					self.cmbSubArea.listIndex := self.cmbSubArea.findObject(lc);
				endif;																								// TFS 3516
			endif;
			self.myDischargeSubArea := lc;
		endif;
	else
		if lc &lt;&gt; null then
			self.loadLocationsCombo(false);
			self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(lc);
			self.myLoadArea := lc;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="632b162a-9713-433d-962c-8760e4edb34f">
        <source>removeWLE(_wle : CM_WorkListEntry);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	idx : Integer;

begin
	if (not self.allDisplayedWLEs.includes(_wle)) then
		return;
	endif;
	
	if self.tblJobDetails.findObjectInRow(_wle, idx) then
		self.tblJobDetails.removeItem(idx);
	endif;
	self.allDisplayedWLEs.remove(_wle);
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setDischargeLoadArea" id="a34ef208-8e08-4cc1-8343-a0d9c8199255">
        <updating/>
        <source>setDischargeLoadArea(_job : CM_VoyageHoldJob) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operatinos Enhancements
// 14/08/2018	jlgdap1		TFS 40003 PEL1 Voyage to Road Moves
//
vars
	terminalArea : CM_TerminalArea;
	lc : CM_LocationsController;

begin
	if _job = null then
		return;
	endif;
	
	if _job.isDischarge then
		if self.cmbDischLoad.listObject.isKindOf(CM_TerminalArea) then					// TFS 40003
			terminalArea := self.cmbDischLoad.listObject.CM_TerminalArea;
			if terminalArea &lt;&gt; null then
				self.myDischargeArea := terminalArea;
			endif;
		elseif self.cmbDischLoad.listObject.isKindOf(CM_LocationsController) then		// TFS 40003
			lc := self.cmbDischLoad.listObject.CM_LocationsController;					// TFS 40003
			if lc &lt;&gt; null then															// TFS 40003
				self.myDischargeArea := null;											// TFS 40003
				self.myDischargeSubArea := lc;											// TFS 40003
			endif;																		// TFS 40003
		endif;																			// TFS 40003
	else
		lc := self.cmbDischLoad.listObject.CM_LocationsController;
		if lc &lt;&gt; null then
			self.myLoadArea := lc;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="setDischargeSubArea" id="692695e9-b968-474f-a0b5-24a1300ab5ad">
        <updating/>
        <source>setDischargeSubArea() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	obj : CM_Object;
	lc : CM_LocationsController;
	col : CM_GridColumn;
	row : CM_GridRow;
	rc : CM_RoRoController;

begin
	self.myDischargeSubArea := null;
	if self.cmbSubArea.listIndex &lt; 1 then
		return;
	endif;
	
	obj := self.cmbSubArea.listObject.CM_Object;
	if obj = null then
		return;
	endif;
	self.myDischargeSubArea := obj;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="8dc54a8d-cd0a-4811-ad7d-4ee5f9088c9c">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
// 3/11/2019	jlgns1		TFS 3827 XLAT_FormCaptions need to be sorted out
// 22/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail 
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	str 	: String;
	vessel 	: CM_Vessel;
	edLocal	: TimeStamp;
begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event));	// TFS 42872
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event));	// TFS 42872
	endif;
	
	self.myCurrentVoyage := _voyage;
			   
	str := self.baseCaption;	
	if self.myCurrentVoyage = null then
		self.tblJobDetails.rows := self.tblJobDetails.fixedRows;
	else

		str := str &amp; app.getFormCaptionsString(Xlat_0021759);
		str := str &amp; " " &amp; self.myCurrentVoyage.getId.trimBlanks;
	endif;

	self.setCaption(str);
	self.setNavigatorHeading(str);
	
	if self.myCurrentVoyage &lt;&gt; null then
		app.setMyCurrentVoyage(self.myCurrentVoyage);
	endif;
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);	// TFS 42872
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);	// TFS 42872
	
	self.loadCombos();
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setReadOnlyControls" id="27ea0189-213c-466e-a5a1-11f740d78337">
        <updating/>
        <source>setReadOnlyControls() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars

begin
	self.txtShiftStartDate.backColor := self.backColor;
	self.txtShiftStartTime.backColor := self.backColor;
	self.txtShiftEndDate.backColor := self.backColor;
	self.txtShiftEndTime.backColor := self.backColor;
//	self.txtJobRemarks.backColor := self.backColor;
//	self.txtShiftRemarks.backColor := self.backColor;
	
	if not app.myCurrentUserCan(self.myTerminal, PmVoyageHoldOpsDate) then
		self.txtEffectiveDate.enabled := false;
		self.txtEffectiveTime.enabled := false;
		self.txtEffectiveDate.backColor := self.backColor;
		self.txtEffectiveTime.backColor := self.backColor;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.cmbDischLoad.enabled := false;
		self.cmbSubArea.enabled := false;
		self.btnDischLoad.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="d15b7988-e35a-4762-8c0c-eae20a8270da">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/01/2017	cnwdap1		Initial creation TFS 3127 LNX Voyage Operations Enhancements
//
vars
	job : CM_VoyageHoldJob;
	wleArray : CM_WLEArray;

begin
	job := self.cmbJob.listObject.CM_VoyageHoldJob;
	if job &lt;&gt; null then
		create wleArray transient;
		job.getAllWLEs(wleArray);
		self.loadWLEDetailsToTable(wleArray);
	endif;
epilog
	delete wleArray;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0c816803-d78f-4b62-9bcf-2e9819a3db98">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars

begin
	// The user can access the summarise functionality only if they have at least view security role.
	self.allowSummaryDefn := app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	inheritMethod();

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	self.setupJobTable();
	self.setReadOnlyControls();
	
	self.minimumWidth := 920;
	self.minimumHeight := 410;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupJobTable" id="a5651eed-4bfe-4392-aa58-d9656f3d179c">
        <updating/>
        <source>setupJobTable() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX voyage Operations Enhancements
//
vars
	def : EntTableDef;

begin
	def := app.myController.getEntTableDef(ETDef_LlHeadings);
	self.tblJobDetails.setTblDataEntRowsFromDef(def);
	
	self.tblJobDetails.userInputEnabled := false;
	self.tblJobDetails.multiSelect := CM_DataTable.MultiSelect_None;
	self.tblJobDetails.selectMode := Table.SelectMode_CurrentRow;
	self.tblJobDetails.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(self.tblJobDetails);

epilog

end;</source>
