    <JadeMethod name="getLocationDisplay" id="5e31556f-8494-4737-afbe-acf2feb0b8aa">
        <source>getLocationDisplay(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	08 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.usage = BUILDING_USE then
		return LOC_Display_Building;
	elseif self.usage = LIGHT_TOWER_USE then
		return LOC_Display_LightTower;
	elseif self.availability &lt;&gt; PAD_AVAILABLE then
		return LOC_Display_Unavailable;
	elseif self.power then
		return LOC_Display_HasPower;
	elseif self.is45ft then
		return LOC_Display_45ft;
	elseif self.is20ft then // PAR 18682 CCMS SFW 1055
		return LOC_Display_20ft; // PAR 18682 CCMS SFW 1055
	elseif self.is40ft then // PAR 18682 CCMS SFW 1055
		return LOC_Display_40ft; // PAR 18682 CCMS SFW 1055
	elseif self.is30ft then
		return LOC_Display_30ft; // PAR 16415 CCMS 1029
	elseif self.is53ft then
		return LOC_Display_53ft; // PAR 16415 CCMS 1029
	elseif self.usage = REEFERGANTRY_USE then
		return LOC_Display_ReeferGantry;
	else
		return LOC_Display_RTG;
	endif;
	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLocationForVehicleMove" id="5e1837b0-f83f-455d-81be-19905e7c1a49">
        <source>getLocationForVehicleMove(_vehicle :CM_Vehicle): CM_YardController;
// ---------------------------------------------------------------------------
// Created:     14 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2010	cnwcs5		par 24292 - change of paremeters in superclass method 
// ---------------------------------------------------------------------------
vars
	lc :CM_GantryICAreaLaneController;
begin
	lc := self.getMyLaneController;
	
	if lc = null then
		return null;
	endif;

	return lc;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getMaxStackingHeight" id="851d1ce5-bb13-44cb-9448-0b652e094c9b">
        <source>getMaxStackingHeight() : Integer;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	maxHeight	: Integer;
	area		: CM_GridArea;
begin

	// DVB 5/04/04 Par 7462. Added resynch. Getting wrong max height.
	
	if self.availability = PAD_AVAILABLE then
		area := self.myTerminalArea.CM_GridArea;
		//self.resynchObject(area);
		maxHeight := area.heightOfStack;
	else 
		// DVB changed to stop it returning negatives.
		maxHeight := (self.availability  - 3).max(0); // PAR 7861
	endif;
	return maxHeight;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMoveTaskRTGLane" id="65b6d6e4-04fc-4b2a-8748-7e7ca2779cc1">
        <source>getMoveTaskRTGLane() : CM_LocationsController;

// Created by cnwdvb1 on 15 August 2006
// Method that returns the work required to move a TI.
vars

		
begin
	if self.myGridColumn.CM_RTGColumn.myBottomGantryICColumn &lt;&gt; null then
		//will always only be one row
		return self.myGridColumn.CM_RTGColumn.myBottomGantryICColumn.allControllersByRow[1];
	elseif self.myGridColumn.CM_RTGColumn.myTopGantryICColumn  &lt;&gt; null then
		//will always only be one row
		return self.myGridColumn.CM_RTGColumn.myTopGantryICColumn.allControllersByRow[1];
	endif;
		
	return null;
	
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getMyLaneController" id="0aa2cf3a-bf21-4471-8380-e003280e859f">
        <source>getMyLaneController() : CM_GantryICAreaLaneController;
/*
----------   ----------  --------------------------------------------------
Created:	15 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	//defaults to top row
	if self.myGridColumn.CM_RTGColumn.myTopGantryICColumn &lt;&gt; null then
		//will always only be one row
		return self.myGridColumn.CM_RTGColumn.myTopGantryICColumn.allControllersByRow[1].CM_GantryICAreaLaneController;
	elseif self.myGridColumn.CM_RTGColumn.myBottomGantryICColumn  &lt;&gt; null then
		//will always only be one row
		return self.myGridColumn.CM_RTGColumn.myBottomGantryICColumn.allControllersByRow[1].CM_GantryICAreaLaneController;
	endif;
	
	return null;

end;


</source>
        <ReturnType type="CM_GantryICAreaLaneController"/>
    </JadeMethod>
