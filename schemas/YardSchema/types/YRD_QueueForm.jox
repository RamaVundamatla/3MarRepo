        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspectTask_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwer1	Initial creation

*/

vars

begin	
	if self.myCurrentTask &lt;&gt; null then
		self.myCurrentTask.inspect;
	elseif self.myCurrentEntry &lt;&gt; null then
		self.myCurrentEntry.inspect;
	endif;
epilog

end;</source>
