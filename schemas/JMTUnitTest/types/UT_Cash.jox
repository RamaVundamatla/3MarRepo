    <JadeMethod name="createCashCargoOnSite" id="535564fb-6cb0-4691-9e1d-839a9880ee59">
        <updating/>
        <source>createCashCargoOnSite(_voyage : CM_Voyage; _daysBack : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	BlockStack = "BS2";
vars
	now			: Date;
	baseDate	: Date;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	strs : StringArray;
	containers	: ObjectArray;
	obj	: Object;
	aPort : CM_Port;
begin
	voy := _voyage;

	aPort := app.myRoot.allPorts["NZAKL"];

	create strs transient;
	create containers transient;
	
	bs:= self.getTerminalArea(BlockStack).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	deleteTerminalArea(BlockStack);
	bs:= addBlockStack(BlockStack, 100, null);

	// ### 20 GENERALS
	self.deleteContainer("GENU2077441");
	cargo := self.addContainerAtLocnDisch("GENU2077441", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU2077442");
	cargo := self.addContainerAtLocnDisch("GENU2077442", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU2077443");
	cargo := self.addContainerAtLocnDisch("GENU2077443", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU2077444");
	cargo := self.addContainerAtLocnDisch("GENU2077444", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU2077445");
	cargo := self.addContainerAtLocnDisch("GENU2077445", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU2077446");
	cargo := self.addContainerAtLocnDisch("GENU2077446", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);

	// ### 40 GENERALS
	self.deleteContainer("GENU4077441");
	cargo := self.addContainerAtLocnDisch("GENU4077441", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU4077442");
	cargo := self.addContainerAtLocnDisch("GENU4077442", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU4077443");
	cargo := self.addContainerAtLocnDisch("GENU4077443", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU4077444");
	cargo := self.addContainerAtLocnDisch("GENU4077444", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU4077445");
	cargo := self.addContainerAtLocnDisch("GENU4077445", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("GENU4077446");
	cargo := self.addContainerAtLocnDisch("GENU4077446", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);

	// ### 20 REEFERS
	self.deleteContainer("REEF2077441");
	cargo := self.addContainerAtLocnDisch("REEF2077441", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF2077442");
	cargo := self.addContainerAtLocnDisch("REEF2077442", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF2077443");
	cargo := self.addContainerAtLocnDisch("REEF2077443", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF2077444");
	cargo := self.addContainerAtLocnDisch("REEF2077444", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF2077445");
	cargo := self.addContainerAtLocnDisch("REEF2077445", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF2077446");
	cargo := self.addContainerAtLocnDisch("REEF2077446", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF2077447");
	cargo := self.addContainerAtLocnDisch("REEF2077447", "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);

	// ### 40 REEFERS
	self.deleteContainer("REEF4077441");
	cargo := self.addContainerAtLocnDisch("REEF4077441", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF4077442");
	cargo := self.addContainerAtLocnDisch("REEF4077442", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF4077443");
	cargo := self.addContainerAtLocnDisch("REEF4077443", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF4077444");
	cargo := self.addContainerAtLocnDisch("REEF4077444", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF4077445");
	cargo := self.addContainerAtLocnDisch("REEF4077445", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF4077446");
	cargo := self.addContainerAtLocnDisch("REEF4077446", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("REEF4077447");
	cargo := self.addContainerAtLocnDisch("REEF4077447", "4332", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);

	// ### 40 EMPTY
	self.deleteContainer("MTMU8099001");
	cargo := self.addContainerAtLocnDisch("MTMU8099001", "4200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("MTMU8099002");
	cargo := self.addContainerAtLocnDisch("MTMU8099002", "4200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("MTMU8099003");
	cargo := self.addContainerAtLocnDisch("MTMU8099003", "4200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("MTMU8099004");
	cargo := self.addContainerAtLocnDisch("MTMU8099004", "4200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("MTMU8099005");
	cargo := self.addContainerAtLocnDisch("MTMU8099005", "4200", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);

	// ### 40 GENL OD
	// NOTE: after over-height changes Dec 2011 these don't get planned but are kept here for simplicity ***
	self.deleteContainer("XDOU8099006");
	cargo := self.addContainerAtLocnDisch("XDOU8099006", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("XDOU8099002");
	cargo := self.addContainerAtLocnDisch("XDOU8099002", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("XDOU8099003");
	cargo := self.addContainerAtLocnDisch("XDOU8099003", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("XDOU8099004");
	cargo := self.addContainerAtLocnDisch("XDOU8099004", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);
	self.deleteContainer("XDOU8099005");
	cargo := self.addContainerAtLocnDisch("XDOU8099005", "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	containers.add(cargo);

	// set transaction dates back the given number of days
	if _daysBack &lt;&gt; 0 then
		baseDate := now - _daysBack;	// cargo create date
		foreach obj in containers do
			cargo := obj.CM_TrackedItem;
			self.setTransactionDate(cargo, baseDate);
		endforeach;
	endif;

epilog
	delete strs;
	delete containers;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_daysBack" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createCashReceipt" id="371faa24-d9ea-4a64-8df0-01a9c806a434">
        <source>createCashReceipt(_drTerm1 : CM_DebtorTerminal; _paymentMeth : CM_PaymentMethod; _cashToPay,_cashTotal	: Decimal; _allAgents : ObjectArray) : CM_CashReceipt;
/*
Purpose:	

Date		Who		Reason
30 June 2025	navab1	JIRA 35213
*/

vars
	
	cashReceipt1 : CM_CashReceipt;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
begin
	cashReceipt1 := self.createBOLCashReceipt(	_paymentMeth,	// _payMeth : CM_PaymentMethod;
					_cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					_cashToPay,
					_cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					_allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
					
					
	return cashReceipt1;
epilog

end;</source>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_paymentMeth" type="CM_PaymentMethod"/>
        <Parameter name="_cashToPay" type="Decimal"/>
        <Parameter name="_cashTotal" type="Decimal"/>
        <Parameter name="_allAgents" type="ObjectArray"/>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="createCashTestCargoOnShip" id="8fba0f54-b471-4fac-9d93-779f4f989381">
        <source>createCashTestCargoOnShip(_voyage : CM_Voyage) protected;
// create two onship cargo containers
vars
	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;
	idPrefix,
	reefPrefix	: String;
	aPort : CM_Port;
	oper	: CM_Operator;
	term	: CM_Terminal;

begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal();
	idPrefix := "GENU";
	reefPrefix := "REEF";

	create strs transient;
	// ### 20 GENERAL
	strs.clear;
	strs.add("010688");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2122334");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2122334", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	
	strs.clear;
	strs.add("010488");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2122335");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2122335", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );

epilog
	delete strs;
end;</source>
