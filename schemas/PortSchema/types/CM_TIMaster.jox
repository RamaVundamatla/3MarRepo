Date		Who		Reason
18 November 2009	cnwer1	Initial creation

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	//app.myTrxUA.trxUpdateTIMasterTILC(self, app.myPassport);
epilog

end;</source>
        <Parameter name="_cmifDamageController" type="CMIF_Object" usage="input"/>
