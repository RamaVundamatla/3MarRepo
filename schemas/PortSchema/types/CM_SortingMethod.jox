    <JadeMethod name="setForCreate" id="7bd31a22-d625-447f-8ab0-52573371a646">
        <updating/>
        <source>setForCreate(_pxySortingMethod : CM_SortingMethod) updating;
/*

Purpose:			Sets the fields on the class from the proxy object

Parameters:			_pxySortingMethod	CM_SortingMethod	The proxy sorting method to set fields from

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.setForUpdate(_pxySortingMethod);
	
end;</source>
        <Parameter name="_pxySortingMethod" type="CM_SortingMethod"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="09efeede-7946-473d-a227-e1948804a20b">
        <updating/>
        <source>setForUpdate(_pxySortingMethod : CM_SortingMethod) updating;
/*

Purpose:			Sets the fields on the class from the proxy object

Parameters:			_pxySortingMethod	CM_SortingMethod	The proxy sorting method to set fields from

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.code					:= _pxySortingMethod.code;
	self.description			:= _pxySortingMethod.description;
	self.isNotAvailableForEntry	:= _pxySortingMethod.isNotAvailableForEntry;
	self.myRoot					:= app.myRoot;
	
end;</source>
        <Parameter name="_pxySortingMethod" type="CM_SortingMethod"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4e45162b-7ef9-47af-aab9-40d11fefeb12">
        <updating/>
        <source>setProxy(_code, _description : String; _isAvailableForEntry : Boolean) updating;
/*

Purpose:			Sets the fields on the proxy object

Parameters:			_code					String	The code for the sorting method
					_description			String	The description for the sorting method
					_isAvailableForEntry	Boolean	Whether or not the sorting method an be used

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.code					:= _code;
	self.description			:= _description;
	self.isNotAvailableForEntry	:= _isAvailableForEntry;
	self.myRoot					:= app.myRoot;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f326a1e5-5924-49be-bed7-d8ad64dd3ee5">
        <source>validateForCreate();
/*

Purpose:			Validation to use when creating the object

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.validateMe();
	
	if app.myRoot.allSortingMethods[self.code] &lt;&gt; null then
		app.raiseCMException1(Sortin_method_alread_exists_co, self.code, null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ffe48d27-6ca5-42f5-b044-8d653f18f75a">
        <source>validateForDelete();
/*

Purpose:			Validation to use when deleting the object

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

vars
	terminal		: CM_Terminal;
	ti				: CM_TrackedItem;
	sortingMethod	: CM_SortingMethod;
	iter			: Iterator;
	
begin
	foreach terminal in app.myRoot.allTerminals do
		iter := terminal.allOnsiteTIsByIdCargoType.createIterator;
		while iter.next(ti) do
			sortingMethod := ti.mySortingMethod;
			if sortingMethod &lt;&gt; null and sortingMethod.code = self.code then
				app.raiseCMException2(Sorti_metho_assoc_track_items, self.code, terminal.code, null, null);
				break;
			endif;
			
		endwhile;
		delete iter;
	endforeach;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="362c651c-e85f-4f5c-9b99-6d58366830cf">
        <source>validateForUpdate();
/*

Purpose:			Validation to use when updating the object

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.validateMe();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="324869cd-7a0f-485d-a864-d251e37abe8c">
        <source>validateMe() protected;
/*

Purpose:			Generic validation code that applies to both create and update

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
09 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, null, null);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
