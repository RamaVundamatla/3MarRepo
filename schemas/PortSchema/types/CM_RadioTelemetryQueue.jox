    <JadeMethod name="addMachine" id="5115f1ff-935a-4a54-8072-f27e057744cd">
        <updating/>
        <source>addMachine(pMachine : CM_Machine input) updating;

vars

	terminal 		: CM_Terminal;
	doNotSendNote	: Boolean;
	currentTask		: CM_RTQueueTask;
begin

	exclusiveLock(self);
	exclusiveLock(pMachine);

	if self.isMachinePresent(pMachine) then
		return;
	endif;

	if pMachine.isKindOf(CM_Crane) and (not self.canAddCraneToQueue) then
		//Error, can only assign cranes to master and voyage queues!
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_QUEUE_CRANE, null, null);
		return;			
	endif;

	//---------------
	//Can machine be added to a Queue
	//---------------
	pMachine.checkCanJoinQueue;
	//---------------
	//Is machine in a Queue?
	//---------------
	terminal := pMachine.myTerminal;
	
	if pMachine.myPrimaryQueue &lt;&gt; null then
		//-----------
		//Currently in a queue, release
		//-----------
		// CCMS 1330
		if not pMachine.myPrimaryQueue.releaseMachine(pMachine) then
			// Must be working a current task. Actioning queued machine move.
			pMachine.setMyNextPrimaryQueue(self);
			currentTask := pMachine.currentQueueTask;
			// Can't be to careful. Checking whether machine is doing a Loadrite weigh.
			// We don't want to splat the weight on the screen.
			doNotSendNote := true;	
		else
			pMachine.addToQueue(self, true, 0);
		endif;
	else
		pMachine.addToQueue(self, true, 0);
	endif;
	
	if not doNotSendNote then
		pMachine.causeEvent(EVENT_MACHQUEUE_ALTERED, false, null);	
	endif;
	
	if terminal &lt;&gt; null then
		pMachine.causeEvent(terminal.getTerminalEvent(RTMachine_Update_Event), false, null);
	endif;

end;</source>
        <Parameter name="pMachine" type="CM_Machine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addQueueEntry" id="425ef2ad-552b-4aa4-86bd-fe76a6d26861">
        <updating/>
        <source>addQueueEntry(entry : CM_RTQueueEntry input) updating;
//Superclass method.
//Adds a queueEntry to the current queue object.
/*

Date		Who		Reason
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
29 Jul 2013	cnwkpd1	PAR #32107 - change to prevent upgrade deadlocks on allEntries

*/

vars
	alert 		: CM_SystemAlert;
	terminal	: CM_Terminal;
	ti 			: CM_TrackedItem;
	twinFlag	: Integer;
begin

	//Check our status, can we accept entries?
	if status &lt;&gt; QSTATUS_RUNNING then
		create alert transient;
		alert.details := app.getErrorString1(ERR_Q_DISABLED, id);
		alert.setSeverity(SEVERE_WARNING);
		//-----------
		//Tell alert to add itself to system
		//-----------
		alert.add;
	endif;

	// PAR #32107 - change check to the other end for performance and no shared lock
	if entry.myQueue = self then
//	if self.allEntries.includes(entry) then
		//-----------
		//Already there. Make sure the back ref is right
		//-----------
		return;
	endif;
	
	if entry.myQueue &lt;&gt; null and entry.myQueue &lt;&gt; self  then
	 	//----------------
	 	//Is in another queue, remove it from there...
	 	//----------------
	 	entry.myQueue.removeQueueEntry(entry);
	endif;
	  //-------------
	  //Update the references to new Queue
	  //-------------
	self.allEntries.add(entry);
	
	//epr par 23389 24/3/10
	ti := entry.getTrackedItem;
	
	if ti &lt;&gt; null then
		ti.addToQueue(self);
	endif;
	
	self.updateObjectEdition(self);	// par 30292
	
	terminal := self.getMyTerminal();
	
	if terminal &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self, terminal.getTerminalEvent(Event_New_Queue_Entry),entry);
		app.myEventManager.createSingleObjInfoNoteEvt(self , terminal.getTerminalEvent(Event_Update_Queue_Entry), entry );
		//epr par 33423 CCMS 2330 7/2/14
		if entry.status = ENTRY_UNACTIONED then
			app.myEventManager.createSingleObjInfoNoteEvt(self , terminal.getTerminalEvent(RTQueueEntry_Available_Event), entry );
		endif;
	endif;
 
end;</source>
        <Parameter name="entry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addSubQueue" id="469cea02-6c87-4f16-894d-84d491224233">
        <source>addSubQueue(pQueue : CM_RadioTelemetryQueue; pPos : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     08 October 2001 by cnwrs2
//
// Purpose:     Adds a queue to the allSubQueues dicts
//
// Parameters:  The queue to add
//				The positon in the allSubQueuesByOrder array (0 if not there)
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
/*	if (not self.allSubQueuesById.includes(pQueue)) then
		self.allSubQueuesById.add(pQueue);
	endif;*/
	
	if (not self.allSubQueuesByOrder.includes(pQueue)) then
		if pPos = 0 or pPos &gt; self.allSubQueuesByOrder.size then
			// Just add to the end
			self.allSubQueuesByOrder.add(pQueue);
		else
			self.allSubQueuesByOrder.insert(pPos, pQueue);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
