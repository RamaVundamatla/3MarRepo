    <JadeMethod name="getXSDDefinition" id="2b2d109a-8f4e-41c8-a415-b61c7150d1c8">
        <source>getXSDDefinition(_ediData : CM_EDIData) : String;
/*

Purpose:			Generate an XSD for the passed in EDI data

Parameters:			

Return Value:		XSD string to be used in overall structure

Date		Who		Reason
01 Sep 2014	cnwrs1	Par 34702 - Add support for JMT XML
02 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
17 Mar 2015	cnwkpd1	PAR #34713 - Change to pull out child types as referenced types
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	ediAgent : CM_EDIControllerAgent;
	ediDataTransManifest : CM_EDIDataTransManifest;
	dataType : Integer;
	dataTypeString : String;
	ediDataTypes : IntegerArray;
	intArray : IntegerArray;
	xsdString,
	xsdSubString : String;
begin
	if process.isSarge then
		write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;_ediData.String;
	endif;
	create ediDataTypes transient;
	create ediAgent transient;
	create intArray transient;
	ediAgent.setTerminal(CM_Terminal.firstInstance);
	
	xsdString := null;
	
	// First generate any child complex type defintions
	if _ediData.isKindOf(CM_EDIDataTransManifest) then
		ediDataTransManifest := _ediData.CM_EDIDataTransManifest;
		ediDataTransManifest.createTransientChildrenClasses();
	endif;
	_ediData.getEDIChildDataTypes(ediDataTypes);
	if _ediData.isKindOf(CM_EDIDataCallOff) then
		ediDataTypes.remove(EDIDataType_ReqBookToDo);
	endif;
	ediDataTypes.copyNoDups(intArray);
	foreach dataType in intArray do //where dataType &lt;&gt; _ediData.getEDIDataType() do
		if _ediData.isKindOf(CM_EDIDataCallOff) and
		   dataType = EDIDataType_CallOff then
			continue;
		endif;
		if _ediData.isKindOf(CM_EDIDataCallOff) and
		   dataType = EDIDataType_ReqBookToDo then
			continue;
		endif;
		if _ediData.isKindOf(CM_EDIDataTransManifest) and
		   dataType = EDIDataType_TransportManifest then
			continue;
		endif;
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' dataType='&amp;dataType.String;
		endif;
		xsdString := xsdString &amp; self.getXSDTypeDefinition(ediAgent, dataType, _ediData);
	endforeach;
	
	ediDataTypes.clear();	
	
	// Generate group list name for any sub items
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; _ediData.getJMTInternalName() &amp; '"&gt;';
	xsdString := xsdString &amp; '&lt;xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;xs:sequence&gt;';

	if _ediData.includeAsHeaderInXML then
		xsdString := xsdString &amp; self.getXSDSubHeaderDefinition(ediAgent, _ediData);
	else
		_ediData.getEDIDataTypeChildren(EDIDataType_JMTInternal, ediDataTypes);
		foreach dataType in ediDataTypes do
			xsdString := xsdString &amp; self.getXSDSubDefinition(ediAgent, dataType, _ediData);
		endforeach;
	endif;
	
	xsdString := xsdString &amp; '&lt;/xs:sequence&gt;';
	xsdString := xsdString &amp; '&lt;/xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;/xs:element&gt;';

	return xsdString;
	
epilog
	if _ediData.isKindOf(CM_EDIDataTransManifest) then
		ediDataTransManifest := _ediData.CM_EDIDataTransManifest;
		ediDataTransManifest.deleteTransientChildrenClasses();
	endif;
	delete ediDataTypes;
	delete intArray;
	delete ediAgent;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXSDSubDefinition" id="2a3fdc70-e9ca-4e54-965c-f1db6aaab6ae">
        <source>getXSDSubDefinition(_ediAgent : CM_EDIControllerAgent; 
					_dataType : Integer; 
					_ediData : CM_EDIData) : String protected;
/*

Purpose:			Generate an XSD for the passed in EDI data

Parameters:			

Return Value:		XSD string to be used in overall structure

Date		Who		Reason
01 Sep 2014	cnwrs1	Par 34702 - Add support for JMT XML
02 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
17 Mar 2015	cnwkpd1	PAR #34713 - Change child types to referenced types

*/

vars
	xsdString,
	tiTypeString : String;
	
begin
	tiTypeString := _ediAgent.getEDIDisplayStrForType(_dataType).asXMLTagName();
	if process.isSarge then
		write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' tiTypeString=All'&amp;tiTypeString.String;
	endif;
	xsdString := null;
	
	// Generate group list name for any sub items
	xsdString := xsdString &amp; '&lt;xs:element name="All' &amp; tiTypeString &amp; '"&gt;';
	xsdString := xsdString &amp; '&lt;xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;xs:sequence&gt;';
	
	// Create reference to child type
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; tiTypeString &amp; '" type="' &amp; tiTypeString &amp; '" maxOccurs="unbounded"/&gt;';
	xsdString := xsdString &amp; '&lt;/xs:sequence&gt;';
	xsdString := xsdString &amp; '&lt;/xs:complexType&gt;';
	
	xsdString := xsdString &amp; '&lt;/xs:element&gt;';
	
	return xsdString;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXSDSubHeaderDefinition" id="b8471734-4524-4809-a299-3545f370c121">
        <source>getXSDSubHeaderDefinition(_ediAgent : CM_EDIControllerAgent; 
					_ediData : CM_EDIData) : String protected;
/*

Purpose:			Generate an XSD for the passed in EDI data

Parameters:			

Return Value:		XSD string to be used in overall structure

Date		Who		Reason
10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
17 Jun 2016	cnwkpd1	Add in property documentation if text is present
25 Jan 2017	cnwkpd1	Make all the attributes optional (minOccurs="0")
*/

vars
	itemFieldClass	: Class;
	dataClass : Class;
//	tiClass : Class;
	dataType : Integer;
	ediDataTypes : IntegerArray;
	tempDataTypes : IntegerArray;
	propertyCollObj	: PropertyColl;
	prop : Property;
	dataClassName,
//	tiClassName : String;
	xsdString : String;
//	strLength : Integer;
	propertyDoc : String;
	
begin
	if process.isSarge then
		write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' _ediData='&amp;_ediData.String;
	endif;
	create ediDataTypes transient;
	create tempDataTypes transient;
	itemFieldClass := CM_EDIItemFieldXML;
	dataClass := _ediData.class;
	dataClassName := dataClass.name[7:end];
	
	xsdString := null;
	// Generate group list name for any sub items
	xsdString := '&lt;xs:element name="All' &amp; dataClassName &amp; '" minOccurs="0"&gt;';
	xsdString := xsdString &amp; '&lt;xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;xs:sequence&gt;';
	
	// create header
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; dataClassName &amp; '" minOccurs="1" maxOccurs="1"&gt;';
	xsdString := xsdString &amp; '&lt;xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;xs:sequence&gt;';
	
	propertyCollObj := dataClass.allPropertiesUpTo(CM_Object);
	foreach prop in propertyCollObj do
		if prop.isSystemObject or 
		   not prop.isKindOf(Attribute) or	  
		   prop.virtual or 
		   not _ediData.canUserSet(prop.name) then
			continue;
		endif;
		xsdString := xsdString &amp; '&lt;xs:element name="' &amp; prop.name &amp; '" type="xs:' &amp; prop.type.getTypeNameForXSD() &amp; '"';
		xsdString := xsdString &amp; ' minOccurs="0"';
		
		propertyDoc := prop.text.trimBlanks();
		if propertyDoc = null then
			xsdString := xsdString &amp; '/&gt;';
		else
			xsdString := xsdString &amp; '&gt;&lt;xs:annotation&gt;&lt;xs:documentation&gt;' &amp; propertyDoc &amp; 
				'&lt;/xs:documentation&gt;&lt;/xs:annotation&gt;&lt;/xs:element&gt;';
		endif;
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' Property name='&amp;prop.name;
		endif;
	endforeach;

	dataType := EDIDataType_JMTInternal;
	if _ediData.isKindOf(CM_EDIDataCallOff) then
	   dataType := EDIDataType_CallOff;
	endif;
	if _ediData.isKindOf(CM_EDIDataTransManifest) then
	   dataType := EDIDataType_TransportManifest;
	endif;
	_ediData.getEDIDataTypeChildren(dataType, ediDataTypes);
	if _ediData.isKindOf(CM_EDIDataTransManifest) then		//30 Jan 2024	jlirs1	TFS 62182
		ediDataTypes.copy(tempDataTypes);
		ediDataTypes.clear();
		foreach dataType in tempDataTypes do
			if dataType = EDIDataType_CargoOnShip then
				ediDataTypes.add(EDIDataType_CargoOnShip);
			endif;
			if dataType = EDIDataType_GateDocument or
			   dataType = EDIDataType_ShipManifest or
			   dataType = EDIDataType_TrainConsist then
				if dataType = EDIDataType_TrainConsist then
					dataType := EDIDataType_Train;
				endif;
				_ediData.getEDIDataTypeChildren(dataType, ediDataTypes);
			endif;
		endforeach;
	endif;
	dataType := null;
	if _ediData.isKindOf(CM_EDIDataTransManifest) then		//05 Feb 2024	jlirs1	TFS 62182
		ediDataTypes.add(EDIDataType_CargoOnSite);
	endif;
//	tiClass := _ediData.getEDITIType(ediDataTypes.first);	//.myTerminal.myEdiConfig.getEDIDataClassForType(dataType);
//	strLength := tiClass.name.length-10;
//	tiClassName := tiClass.name[7:strLength];
	tempDataTypes.clear;		//05 Feb 2024	jlirs1	TFS 62182
	foreach dataType in ediDataTypes do
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' ediDataTypes dataType='&amp;dataType.String;
		endif;
		if tempDataTypes.includes(dataType) then 		//05 Feb 2024	jlirs1	TFS 62182
			continue;
		endif;
		tempDataTypes.add(dataType);
		xsdString := xsdString &amp; self.getXSDSubDefinition(_ediAgent, dataType, _ediData);
	endforeach;

	// Close off sub item list
	xsdString := xsdString &amp; '&lt;/xs:sequence&gt;';
	xsdString := xsdString &amp; '&lt;/xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;/xs:element&gt;';
	
	// Close off header
	xsdString := xsdString &amp; '&lt;/xs:sequence&gt;';
	xsdString := xsdString &amp; '&lt;/xs:complexType&gt;';
	xsdString := xsdString &amp; '&lt;/xs:element&gt;';

	return xsdString;
	
epilog
	delete ediDataTypes;
	delete tempDataTypes;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXSDTypeDefinition" id="4341fe04-ae72-4f41-a9d5-89f6233950c2">
        <source>getXSDTypeDefinition(_ediAgent : CM_EDIControllerAgent; 
					_dataType : Integer; 
					_ediData : CM_EDIData) : String protected;
/*

Purpose:			Generate an XSD complex type definition for the passed in EDI data

Parameters:			

Return Value:		XSD string that defines the type

Date		Who		Reason
17 Mar 2015	cnwkpd1	PAR #34713 - .NET EDI transform integration
25 Jan 2017	cnwkpd1	Make all the attributes optional (minOccurs="0")
20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	itemFieldClass	: Class;
	tiClass	: Class;
	tiTypeString : String;
	dataType : Integer;
	ediDataTypes : IntegerArray;
	masterEDITI	: CM_EDITrackedItem;
	allFieldsOfType : CM_FieldByTypeSysNameDict;
	fileField : CM_Field;
	xmlField : CM_EDIItemFieldXML;
	prop : Property;
	xsdString,
	xsdSubString : String;
	childTiTypeString : String;
	nullString : String;
	
begin
	if process.isSarge then
		write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' _dataType='&amp;_dataType.String&amp;' '&amp;_ediAgent.getEDIDisplayStrForType(_dataType).asXMLTagName();
	endif;
	create ediDataTypes transient;
	create allFieldsOfType transient;
	itemFieldClass := CM_EDIItemFieldXML;
	tiClass := _ediData.getEDITIType(_dataType);
	if tiClass = null or		//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	   tiClass.abstract then	//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		tiClass := _ediData.getClassForObject(_ediData);
		_ediData.getItemFields(allFieldsOfType, itemFieldClass);
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' tiClass='&amp;tiClass.name;
		endif;
	else
		create masterEDITI as tiClass transient;
		masterEDITI.getItemFields(allFieldsOfType, itemFieldClass);
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' tiClass='&amp;tiClass.name&amp;' masterEDITI='&amp;masterEDITI.String;
		endif;
	endif;
	tiTypeString := _ediAgent.getEDIDisplayStrForType(_dataType).asXMLTagName();
	
	xsdString := null;
	
	// Create type header
	xsdString := xsdString &amp; '&lt;xs:complexType name="' &amp; tiTypeString &amp; '"&gt;';
	xsdString := xsdString &amp; '&lt;xs:sequence&gt;';
	
	foreach fileField in allFieldsOfType do
		xmlField := fileField.CM_EDIItemFieldXML;
		prop := tiClass.getPropertyInHTree(xmlField.systemName);
		if prop &lt;&gt; null then
			xsdString := xsdString &amp; '&lt;xs:element name="' &amp; xmlField.systemName &amp; '" type="xs:' &amp; prop.type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
		endif;
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' fileField='&amp;xmlField.systemName;
		endif;
	endforeach;
	
	if masterEDITI &lt;&gt; null then								//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		masterEDITI.zGetAllExtraDataXSD( xsdString, nullString );	//09 Jun 2017	NDL	TFS 4331
	endif;
	
	// Generate all child types as references to previously defined types
	_ediData.getEDIDataTypeChildren(_dataType, ediDataTypes);
	foreach dataType in ediDataTypes do
		if _ediData.isKindOf(CM_EDIDataCallOff) and
		   dataType = EDIDataType_ReqBookToDo then
			continue;
		endif;
		if process.isSarge then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' dataType='&amp;dataType.String&amp;' '&amp;_ediAgent.getEDIDisplayStrForType(dataType).asXMLTagName();
		endif;
		childTiTypeString := _ediAgent.getEDIDisplayStrForType(dataType).asXMLTagName();
		
		// Generate group list name for any sub items
		xsdString := xsdString &amp; '&lt;xs:element name="All' &amp; childTiTypeString &amp; '"&gt;';
		xsdString := xsdString &amp; '&lt;xs:complexType&gt;';
		xsdString := xsdString &amp; '&lt;xs:sequence&gt;';
	
		// Create reference to child type
		xsdString := xsdString &amp; '&lt;xs:element name="' &amp; childTiTypeString &amp; '" type="' &amp; childTiTypeString &amp; '" maxOccurs="unbounded"/&gt;';
		xsdString := xsdString &amp; '&lt;/xs:sequence&gt;';	
		xsdString := xsdString &amp; '&lt;/xs:complexType&gt;';
		xsdString := xsdString &amp; '&lt;/xs:element&gt;';
	endforeach;
	
	// Close off type header
	xsdString := xsdString &amp; '&lt;/xs:sequence&gt;';
	xsdString := xsdString &amp; '&lt;/xs:complexType&gt;';

	return xsdString;
	
epilog
	delete masterEDITI;
	delete ediDataTypes;
	delete allFieldsOfType;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="e57abc65-427c-4c8d-b29a-5536153c3c28">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			Standard process file for EDI type

Parameters:			

Return Value:		None

Date		Who		Reason
27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
01 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
10 Nov 2014	cmwrs1	Par 34702 - Allow for implied header
20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
10 jun 2016	cnwrs1	TFS 2150 - Add support for operator xlation and operator xlation code
29/09/2016   cnwma1  TFS #2772:PAR38274 SPL/PAR38273 CPL - Internal XML Translations not applying
18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
25 Jun 2019	NDL		TFS 44895 - use the XML Data strucrure we set up to find what file type we have.
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/
vars
	allFieldsOfType 	: CM_FieldByTypeSysNameDict;	
	numMsgs				: Integer;
	message				: String;
	ediData				: CM_EDIData;
	xmlDoc 				: CM_XMLDocument;
	xmlElement 			: JadeXMLElement;
	theXMLStr 			: String;
	ediAgent 			: CM_EDIControllerAgent;
	ediDataType 		: Integer;
	dataTypeString 		: String;
	xlationOperator 	: CM_Operator;
	assist 				: CMIF_EDIUserDefinedAssist;
	operatorXlationCode : String;
	foundMatch 			: Boolean;
	usingExistingDoc 	: Boolean;
	agent 				: CM_Agent;
	root				: CM_Root;
	ediFileEDIData : CM_EDIData;
begin
	
	ediData := _ediFile.ediData;
	ediFileEDIData := ediData;
	
	agent := app.myPassport.getMyBGPAgent();
	if agent &lt;&gt; null and agent.isKindOf(CM_EDIControllerAgent) and agent.CM_EDIControllerAgent.myXMLDocument &lt;&gt; null then 
		ediAgent :=  agent.CM_EDIControllerAgent;
	endif;
	
	if ediAgent &lt;&gt; null then
		// use the XML data we set up when we established the file type
		xmlDoc := ediAgent.myXMLDocument.CM_XMLDocument;
		usingExistingDoc := true;
	else
		create xmlDoc transient;
		create ediAgent transient;
	endif;
	
	create assist transient;
	
	if not usingExistingDoc then
		message := self.rawDataToString(_ediFile);
		theXMLStr := message.extractXML();
		if theXMLStr &lt;&gt; null then
			xmlDoc.parseString(theXMLStr);
		else
			return;
		endif;
	
	endif;

	numMsgs	:= 0;

	xmlElement := xmlDoc.getElementByTagName(ETRow_OperatorCode);        //cnwma1 TFS #2772 30/09/2016
	if xmlElement &lt;&gt; null then
		operatorXlationCode := xmlElement.textData;
	endif;
	root                := app.myRoot;																					//21.11.2022 navma1 #55424	
	operatorXlationCode := root.getXlationSystemOperatorCode(xlationOperator, operatorXlationCode, foundMatch)[1:4];	//21.11.2022 navma1 #55424
	xlationOperator 	:= root.allOperators[operatorXlationCode];														//21.11.2022 navma1 #55424
	
	if xlationOperator &lt;&gt; null then
		ediData.setXlationOperator(xlationOperator);
	endif;

	if xmlDoc.rootElement &lt;&gt; null then
		// JMTInternal XML?
		if xmlDoc.rootElement.tagName.startsWith(EDIFileVersion_JMTInternal) then
			dataTypeString := EDIFileVersion_JMTInternal;
		endif;
		if xmlDoc.rootElement.tagName.startsWith(EDIFileVersion_SystemXML) then
			dataTypeString := EDIFileVersion_SystemXML;
		endif;
	endif;
	
	dataTypeString := dataTypeString &amp; ediData.class.name[11:end];
	ediDataType    := EDIDataType_JMTInternal;
	xmlElement 	   := xmlDoc.getElementByTagName(dataTypeString);
	
	if xmlElement &lt;&gt; null then
		if ediData.includeAsHeaderInXML then
			self.processSubHeaderStructure(ediData, _ediFile, ediAgent, ediDataType, xmlElement, xlationOperator);
			if ediData.isKindOf(CM_EDIDataTransManifest) or 
			   ediData.isKindOf(CM_EDIDataCallOff) then
				ediData := ediFileEDIData.getMyActiveEDIData();
				if ediData.ediDataType = 0 then
					ediDataType := ediData.getEDIDataType();
					ediData.setForCreateNoProxy(_ediFile.ediConfig, ediDataType, _ediFile.myEDIFileType.type, _ediFile, app.myPassport.userCode);		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
				endif;
			endif;
		endif;
		self.processSubFileStructure(ediData, _ediFile, ediAgent, ediDataType, xmlElement, xlationOperator, assist);
		ediFileEDIData.processAttributeDependencies(assist, null, false, xlationOperator);
	endif;
	
epilog
	
	if not usingExistingDoc then
		delete xmlDoc;
	else
		ediAgent.setMyXMLDocument(null);
	endif;
	if allFieldsOfType &lt;&gt; null then
		allFieldsOfType.purge;
	endif;
	delete allFieldsOfType;
	if not usingExistingDoc then
		delete ediAgent;
	endif;
	delete assist;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processSubFileStructure" id="4e15dc72-5850-4b0f-b39c-ac1c24975385">
        <updating/>
        <source>processSubFileStructure(_ediData : CM_EDIData input; 
						_ediFile: CM_EDIFile input; 
						_ediAgent : CM_EDIControllerAgent; 
						_ediDataType : Integer; 
						_xmlElement : JadeXMLElement io;
						_xlationOperator : CM_Operator;
						_assist : CMIF_EDIUserDefinedAssist io) protected, updating;
/*

Purpose:			Process the passed in XML element and extract the relevant information from it

Parameters:			

Return Value:		None

Date		Who		Reason
26 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML without header record
02 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 20 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	allFieldsOfType : CM_FieldByTypeSysNameDict;
	tiTypeString : String;
	parentTITypeString : String;
	xmlElement1 : JadeXMLElement;
	xmlElement2 : JadeXMLElement;
	allElement : JadeXMLElement;
	elements1 : JadeXMLElementArray;
	elements2 : JadeXMLElementArray;
	tiClass	: Class;
	masterEDITI	: CM_EDITrackedItem;
	itemFieldClass	: Class;
	fileField : CM_Field;
	xmlField : CM_EDIItemFieldXML;
	fieldValue	: Any;
	str : String;
	childrenDataTypes : IntegerArray;
	dataType : Integer;
begin
	if _xmlElement = null then
		return;
	endif;
	create childrenDataTypes transient;
	create elements1 transient;
	create elements2 transient;
	create allFieldsOfType transient;
	
	parentTITypeString := _ediAgent.getEDIDisplayStrForType(_ediDataType).asXMLTagName();
	_ediData.getEDIDataTypeChildren(_ediDataType, childrenDataTypes);
//if _xmlElement.parentElement &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' _xmlElement.tagName='&amp;_xmlElement.tagName&amp;' parentTITypeString='&amp;parentTITypeString&amp;' parent='&amp;_xmlElement.parentElement.tagName;
//else
//write class.name&amp;'::'&amp;method.name&amp;' _xmlElement.tagName='&amp;_xmlElement.tagName&amp;' parentTITypeString='&amp;parentTITypeString;
//endif;
	
	foreach dataType in childrenDataTypes do
//		_assist.allChildrenEDITIs.clear;
		tiTypeString := _ediAgent.getEDIDisplayStrForType(dataType).asXMLTagName();
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;"All"&amp;tiTypeString;
		allElement := _xmlElement.getElementByTagName("All"&amp;tiTypeString);
		if allElement = null then
			continue;
		endif;
//if xmlElement1 &lt;&gt; null and
//   xmlElement1.parentElement &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' tiTypeString='&amp;tiTypeString&amp;' parent='&amp;xmlElement1.parentElement.tagName;
//else
//write class.name&amp;'::'&amp;method.name&amp;' tiTypeString='&amp;tiTypeString;
//endif;
		allElement.getAllElementsByTagName(tiTypeString, elements1);

		allFieldsOfType.purge;
		itemFieldClass := CM_EDIItemFieldXML;
		tiClass := app.myPassport.myTerminal.myEdiConfig.getEDITIClassFromEDIDataType(dataType);		//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//		tiClass := _ediData.getEDITIType(dataType);
		foreach xmlElement1 in elements1 do
			if xmlElement1.childNodes.size = 0 then
				continue;
			endif;
//			if xmlElement1.parentElement.tagName &lt;&gt; _xmlElement.tagName then
//				continue;
//			endif;

//			self.processSubFileStructure(_ediData, _ediFile, _ediAgent, dataType, xmlElement1, _xlationOperator, _assist);
//write class.name&amp;'::'&amp;method.name&amp;' tagName='&amp;xmlElement1.tagName;

			if tiClass = null or
			   tiClass.abstract then		//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
				_ediData.getItemFields(allFieldsOfType, itemFieldClass);
			else
				create masterEDITI as tiClass persistent;
				masterEDITI.setForCreateNew(_ediData);
				masterEDITI.getItemFields(allFieldsOfType, itemFieldClass);
				
				masterEDITI.zGetExtraItemFields(allFieldsOfType, itemFieldClass);	//09 Jun 2017	NDL	TFS 4331
			endif;
			
			foreach fileField in allFieldsOfType do
				xmlField := fileField.CM_EDIItemFieldXML;
//write class.name&amp;'::'&amp;method.name&amp;' xmlField.systemName='&amp;xmlField.systemName;
				//find the element associated with this field
				xmlElement2 := xmlElement1.getElementByTagName(xmlField.systemName);

				if xmlElement2 = null or (xmlElement2.tagName &lt;&gt; xmlField.systemName) then
					continue;
				endif;
		
				fieldValue := xmlElement2.text();
				str := fileField.systemName;
//if xmlField.systemName = 'bol' or
//   xmlField.systemName = 'id' then
//if xmlElement2.parentElement.parentElement &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' systemName='&amp;xmlField.systemName&amp;' fieldValue='&amp;fieldValue.String&amp;' tag='&amp;xmlElement2.tagName&amp;' parent='&amp;xmlElement2.parentElement.tagName&amp;' grandParent='&amp;xmlElement2.parentElement.parentElement.tagName;
//else
//write class.name&amp;'::'&amp;method.name&amp;' systemName='&amp;xmlField.systemName&amp;' fieldValue='&amp;fieldValue.String&amp;' tag='&amp;xmlElement2.tagName&amp;' parent='&amp;xmlElement2.parentElement.tagName;
//endif;
//endif;
				
				if xmlField.className = _ediFile.class.name then
					_ediFile.setEDIFileProperty(xmlField.systemName, fieldValue);	
				elseif masterEDITI &lt;&gt; null then			//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
					if xmlField.className = masterEDITI.class.name then
						masterEDITI.setPropertyFromField(xmlField.systemName, fieldValue, _ediFile, _xlationOperator);
					endif;
				else
					if xmlField.className = _ediData.class.name then
						_ediData.setEDIFileProperty(xmlField.systemName, fieldValue);	
					endif;
				endif;
			endforeach;
			if masterEDITI &lt;&gt; null then
				_assist.allChildrenEDITIs.add(masterEDITI);
				masterEDITI.processAttributeDependencies(_assist, null, false, _xlationOperator); 
			endif;
			self.processSubFileStructure(_ediData, _ediFile, _ediAgent, dataType, xmlElement1, _xlationOperator, _assist);
			if masterEDITI &lt;&gt; null then
				masterEDITI.processAttributeDependencies(_assist, null, true, _xlationOperator); 
			endif;
			allFieldsOfType.purge;
		endforeach;
	endforeach;
epilog
	if allFieldsOfType &lt;&gt; null then
		allFieldsOfType.purge;
	endif;
	delete allFieldsOfType;
	delete childrenDataTypes;
	delete elements1;
	delete elements2;
end;
</source>
        <access>protected</access>
