        <source>doCargoAdd() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwmd1	Initial creation

*/

vars

begin
	self.mode := self.Mode_Add;
	
	self.myCurrentTI := null; //Only clear for add only, therefore not in clearControls()
		
	self.clearControls();
	self.setDefaults();
	self.doCargoDisplay();
