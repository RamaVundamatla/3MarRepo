    <JadeMethod name="scrChildTemp_change" id="1f214f74-859a-48c2-93be-b2679002f401">
        <controlMethod name="ScrollBar::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>scrChildTemp_change(scroll: ScrollBar input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2016	cnwndl1	Initial creation

*/

vars

	index : Integer;
	int : Integer;
	buttonCount : Integer;
	cloneFrame : MOB_Frame;

begin

	if not self.allSelectedConts.isEmpty then
		if self.chkByCont.value then
			foreach int in 1 to self.allSelectedConts.size do
				if self.scrChildTemp.getControl(int) = scroll then
					cloneFrame := self.frmChildTemp.getControl(int).MOB_Frame;
					index := int;
					break;
				endif;
			endforeach;
		else
			cloneFrame := self.frmChildTemp.getControl(1).MOB_Frame;
			index := 1;
		endif;
	endif;
	
	if index &gt; 0 and self.childButtonCountArray.size &gt;= index then
		buttonCount := self.childButtonCountArray[ index ];
	endif;
	
	if cloneFrame &lt;&gt; null then
		self.setMenuScrollStart( scroll, self.btnChildTemp, cloneFrame, buttonCount );
	endif;

epilog

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
