    <JadeMethod name="getWOResourceInUseFor" id="71b33f22-76b2-4482-90f4-6a49fbccc10e">
        <source>getWOResourceInUseFor(_transWOBroker : CM_WorkOrderServiceBroker; _resources : CM_ResourceTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars

begin
	if _resources = null then
		return;
	endif;
	
	_resources.clear();
	
	_transWOBroker.getWOResourceInUse(_resources);
epilog

end;</source>
        <Parameter name="_transWOBroker" type="CM_WorkOrderServiceBroker"/>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasWOResource" id="dab7b06a-a8b1-4711-8809-e119a10c0978">
        <source>hasWOResource() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	toDoTask 	: CM_ToDoTaskDesc;
	root		: CM_Root;
	transType	: CM_TransactionType;
begin
	transType := self.getMyWorkOderType();
	
	if transType &lt;&gt; null then
		foreach toDoTask in transType.allToDoTaskDesc discreteLock do
			if not toDoTask.allResourceTypes.isEmpty() then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="ee3f349c-01ea-471c-877e-f62bf80b0447">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/
vars
	tmcDebtor 			: CMIF_TMCDebtorGroup;
	aDM 				: CM_DebtorMap;
	tmcResourceHeader 	: CMIF_TMCTaskResourceTypeHeader; // 15/05/2023	navkc1	CR 57927 Task 54268
	tmcBroker 			: CMIF_TMCTaskResourceTypeGroup; // 15/05/2023	navkc1	CR 57927 Task 54268
	serviceBroker		: CM_ToDoResourceServiceBroker; // 15/05/2023	navkc1	CR 57927 Task 54268
begin
	self.myTMCController := self.myGroup.myTMCController;	
	self.hidePictures := self.myTMCController.hidePictures;

	create tmcDebtor as CMIF_TMCDebtorGroupDefault;
	tmcDebtor.myDebtor := null;
	tmcDebtor.myDebtorMap := null;
	tmcDebtor.myServiceBroker := self.myWOBroker;
	tmcDebtor.itemName := tmcDebtor.getItemName();
	tmcDebtor.extractName := tmcDebtor.getItemCode();		
	tmcDebtor.myGroup := self;
	tmcDebtor.initialise(_groupCount);
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.myWOBroker &lt;&gt; null then
		if self.myWOBroker.allToDoResourceServiceBrokers.isNotEmpty() then
			create tmcResourceHeader;
			tmcResourceHeader.myTransServiceBroker := self.myWOBroker;
			tmcResourceHeader.itemName := "Resource Mappings"; 
			tmcResourceHeader.extractName := tmcResourceHeader.itemName;
			tmcResourceHeader.myTMCController := self.myTMCController;
			tmcResourceHeader.myGroup := self;
			_groupCount := _groupCount + 1;
		endif;
		// 15/05/2023	navkc1	CR 57927 Task 54268
		foreach serviceBroker in self.myWOBroker.allToDoResourceServiceBrokers discreteLock do
			create tmcBroker;
			tmcBroker.myTransResourceServiceBroker := serviceBroker;
			tmcBroker.itemName := serviceBroker.getResourceName();
			tmcBroker.extractName := serviceBroker.getResourceCode();
			tmcBroker.myGroup := tmcResourceHeader;
			tmcBroker.initialise(_groupCount);
		endforeach;
	endif;
	
	foreach aDM in self.myWOBroker.allDebtorMapsByDebtor do
		create tmcDebtor;
		tmcDebtor.myDebtor := aDM.myDebtorNode;
		tmcDebtor.myDebtorMap := aDM;
		tmcDebtor.itemName := tmcDebtor.getItemName();
		tmcDebtor.extractName := tmcDebtor.getItemCode();		
		tmcDebtor.myGroup := self;
		tmcDebtor.initialise(_groupCount);
	endforeach;
	_groupCount := _groupCount + 1; 
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="acc66375-f843-49fc-8534-b1dd5d944e09">
        <source>setControllerCurrent() ;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/
vars

begin
	inheritMethod();
	
	myTMCController.myCurrentMapTMWO := self.myWOBroker.myTransMap;
	myTMCController.myCurrentMapServiceBroker := self.myWOBroker;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="8248dd21-059d-47a7-9f48-65a196f5aa3e">
        <source>setEnableObjects(form: INV_TransactionMap io);
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars

begin
	inheritMethod(form);

	form.menuTMWOnew.visible := true;  // MAIN WO NEW MENU
	form.menuSItemNew.visible := false;  // MAIN CARGO NEW MENU	
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Debtor;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_TransType;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_WorkOrder;

	form.menuTMWOnew.enabled := true;
	form.menuTMWOdebtor.visible := true;
	form.menuSItemDelete.enabled := true;
	
	form.btnDelete.enabled := true;
	form.btnNew.enabled := true;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	form.menuTMWOTransType.visible := true;
	form.menuTMWOResourceType.visible := true;
	
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="f1bacc57-30d7-4271-aea3-df9c531089c3">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars

begin
	inheritMethod(form);
	
	form.myCurrentMapTMWorkOrder := self.myWOBroker.myTransMap;
	form.myCurrentMapServiceBroker := self.myWOBroker;
	
	form.myTMCWO := self; // 15/05/2023	navkc1	CR 57927 Task 54268
	
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
