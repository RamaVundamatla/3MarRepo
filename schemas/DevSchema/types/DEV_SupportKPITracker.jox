    <JadeMethod name="calculateStats" id="8f1816a9-6c20-4ad4-9f69-be2e0e20aaa3">
        <source>calculateStats();

/*
Date			Who		Reason
21 July 2016	cnwar2	Initial creation

*/
vars
	startTS, endTS  : TimeStamp;
	date			: Date;
	time			: Time;
	contact			: DEV_SupportContact;
	count, kpi1_1,
	kpi1_2, kpi2_1,
	kpi2_2, kpi3_1,
	kpi3_2, kpi3_3	: Integer;
	kpiFailedBy		: Real;
	
begin
	date := self.txtStatsStart.text.Date;
	if not date.isValid then
		return;
	endif;
	time.setTime(0,0,0,0);
	startTS.setDate(date);
	startTS.setTime(time);
	
	date := self.txtStatsEnd.text.Date;
	if not date.isValid then
		return;
	endif;
	time.setTime(23,59,59,999);
	endTS.setDate(date);
	endTS.setTime(time);
	
	count 	:= 0;	// number of contacts opened within timeframe
	kpi1_1	:= 0;	// number of contacts that passed the 1st initial response KPI (within 4 hours)
	kpi1_2	:= 0;	// number of contacts that passed the 2nd initial response KPI (within 8 hours)
	kpi2_1	:= 0;	// number of contacts that passed the 1st plan of action KPI (within 48 hours)
	kpi2_2	:= 0;	// number of contacts that passed the 2nd plan of action KPI (within 72 hours)
	kpi3_1	:= 0;	// number of contacts that passed the 1st resolution KPI (within 30 days)
	kpi3_2	:= 0;	// number of contacts that passed the 2nd resolution KPI (within 45 days)
	kpi3_3	:= 0;	// number of contacts that passed the 3rd resolution KPI (within 65 days)
	
	foreach contact in self.myRoot.allContacts do
		if contact.openedTS &lt; startTS then
			continue;
		endif;
		if contact.openedTS &gt; endTS then
			break;
		endif;
		if contact.getCurrentState() &lt;&gt; 'Closed' then
			continue;
		endif;
		if cmbOwnerStats.text &lt;&gt; "*ALL*" and cmbOwnerStats.text &lt;&gt; contact.owner then
			continue;
		endif;
		
		count := count + 1;
		
		kpiFailedBy := contact.kpi1FailedBy.Real;
		if kpiFailedBy = 0 then
			kpi1_1 := kpi1_1 + 1;
			kpi1_2 := kpi1_2 + 1;
		elseif kpiFailedBy &gt; -4 then
			kpi1_2 := kpi1_2 + 1;
		endif;
		
		kpiFailedBy := contact.kpi2FailedBy.Real;
		if kpiFailedBy = 0 then
			kpi2_1 := kpi2_1 + 1;
			kpi2_2 := kpi2_2 + 1;
		elseif kpiFailedBy &gt; -24 then
			kpi2_2 := kpi2_2 + 1;
		endif;
			
		kpiFailedBy := contact.kpi3FailedBy.Real;
		if kpiFailedBy = 0 then
			kpi3_1 := kpi3_1 + 1;
			kpi3_2 := kpi3_2 + 1;
			kpi3_3 := kpi3_3 + 1;
		elseif kpiFailedBy &gt; -15 then
			kpi3_2 := kpi3_2 + 1;
			kpi3_3 := kpi3_3 + 1;
		elseif kpiFailedBy &gt; -35 then
			kpi3_3 := kpi3_3 + 1;
		endif;
		
	endforeach;
	
	kpi1_1 := ((kpi1_1/count)*100).rounded();
	kpi1_2 := ((kpi1_2/count)*100).rounded();
	kpi2_1 := ((kpi2_1/count)*100).rounded();
	kpi2_2 := ((kpi2_2/count)*100).rounded();
	kpi3_1 := ((kpi3_1/count)*100).rounded();
	kpi3_2 := ((kpi3_2/count)*100).rounded();
	kpi3_3 := ((kpi3_3/count)*100).rounded();
	
	lblKPI1_1.caption := kpi1_1.String &amp; "%";
	lblKPI1_2.caption := kpi1_2.String &amp; "%";
	lblKPI2_1.caption := kpi2_1.String &amp; "%";
	lblKPI2_2.caption := kpi2_2.String &amp; "%";
	lblKPI3_1.caption := kpi3_1.String &amp; "%";
	lblKPI3_2.caption := kpi3_2.String &amp; "%";
	lblKPI3_3.caption := kpi3_3.String &amp; "%";
	
	if kpi1_1 &lt; 80 then
		lblKPI1_1.foreColor := Red;
	else
		lblKPI1_1.foreColor := Green;
	endif;
	
	if kpi1_2 &lt;&gt; 100 then
		lblKPI1_2.foreColor := Red;
	else
		lblKPI1_2.foreColor := Green;
	endif;
	
	if kpi2_1 &lt; 80 then
		lblKPI2_1.foreColor := Red;
	else
		lblKPI2_1.foreColor := Green;
	endif;
	
	if kpi2_2 &lt;&gt; 100 then
		lblKPI2_2.foreColor := Red;
	else
		lblKPI2_2.foreColor := Green;
	endif;
	
	if kpi3_1 &lt; 70 then
		lblKPI3_1.foreColor := Red;
	else
		lblKPI3_1.foreColor := Green;
	endif;
	
	if kpi3_2 &lt; 90 then
		lblKPI3_2.foreColor := Red;
	else
		lblKPI3_2.foreColor := Green;
	endif;
	
	if kpi3_3 &lt;&gt; 100 then
		lblKPI3_3.foreColor := Red;
	else
		lblKPI3_3.foreColor := Green;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbCustomerRpt_click" id="613ff059-b4ce-4bb4-a533-1c671236a724">
