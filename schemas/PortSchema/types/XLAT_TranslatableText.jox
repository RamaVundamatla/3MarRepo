    <JadeMethod name="vLocaleList" id="7e0f3560-2477-4130-b871-01698c9ebe03">
        <methodInvocation>mapping</methodInvocation>
        <source>vLocaleList(set: Boolean; _value: String io) mapping;

// [VIRTUAL] quick list of recorded locales

vars
	translation	: XLAT_Translation;
	locale 		: CM_Locale;
begin
	if set then
		// read only
	else
		foreach translation in allTextByLocale do
			_value := _value &amp; CrLf &amp; Tab &amp; translation.myLocale.vLocaleIdAndDescription;
		endforeach;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
