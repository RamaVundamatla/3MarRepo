    <JadeMethod name="populateCmbBOL" id="37658e8e-1107-4191-9fe5-4431c80527bc">
        <source>populateCmbBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	gte : CMGTE_Entity;
	bolStr : String;
	bolSet : CM_BOLSet;
	bol : CM_BOL;
	bolDtl : CM_BOLDtl;
	voyCode : String;
	voyage : CM_Voyage;

begin

	self.cmbBOL.clear();
	create bolSet transient;
	
	if self.optOps.value then
		if self.optLoad.value then
			//setup the BOLs combo from the VVR.
			foreach gte in self.myVehicleVisitRecord.allGateEntities where gte.isCMGTE_Release do
				if gte.CMGTE_Release.myTrackedItem &lt;&gt; null then
					//This is a release by id that just happens to have a BOL. Skip it here it will be caught later.
					continue;
				endif;
				bolDtl := gte.CMGTE_Release.myBOLDtl;
				if bolDtl &lt;&gt; null and bolDtl.myBOL &lt;&gt; null then
					bolSet.addNoDuplicates( bolDtl.myBOL, false );
				else
					bolStr := gte.CMGTE_Release.billOfLading;
					voyCode := gte.CMGTE_Release.voyageCode;
					if bolStr &lt;&gt; null then
						self.myTerminal.allBOLsReceivedByTypeNumberDT.getAllBolsMatching( bolSet, BOLType_GeneralBillOfLading, bolStr, voyCode );
					endif;
				endif;
			endforeach;
			
			foreach bol in bolSet do
				voyage := bol.getMyVoyage;
				if voyage &lt;&gt; null then
					bolStr := voyage.code &amp; " " &amp; bol.number;
				else
					bolStr := bol.number;
				endif;
				self.cmbBOL.itemObject[ self.cmbBOL.addItem( bolStr ) ] := bol;
			endforeach;
			
			if self.cmbBOL.listCount &gt;= 1 then
				self.cmbBOL.listIndex := 1;
				self.clickCmbBOL();
			endif;
			
			self.cmbBOL.enabled := ( self.cmbBOL.listCount &gt;= 1 );
			
		endif;
		
	endif;
	
	self.populateCmbRelease();

epilog

	delete bolSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbLocations" id="0eb1cdbc-3ee8-4f43-970f-bd5808fb6a55">
        <source>populateCmbLocations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189
08 Sep 2022		jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars

	index : Integer;
	prevTa : CM_TerminalArea;
	ta : CM_TerminalArea;
	prevLocation : CM_LocationsController;
	intArray : IntegerArray;
	chassis : CM_TILC;
	lc : CM_LocationsController;

begin

	prevTa := self.cmbLocation.listObject.CM_TerminalArea;
	prevLocation := self.cmbSubLocation.listObject.CM_LocationsController;

	self.cmbLocation.clear();
	self.cmbSubLocation.clear();
	
	if self.optDischarge.value then
	
		self.cmbLocation.enabled := true;
		self.cmbSubLocation.enabled := true;
	
		create intArray transient;
		intArray.add(TA_TYPE_DEPOT_LCL);
		intArray.add(TA_TYPE_BLOCK_STACK);
		intArray.add(TA_TYPE_SUBBLOCK_STACK);	
		intArray.add(TA_TYPE_WASH_AREA);			
		intArray.add(TA_TYPE_PTI);				
		intArray.add(TA_TYPE_REPAIR);				
		intArray.add(TA_TYPE_IRREGULAR_BLOCK_AREA);		
		intArray.add(TA_TYPE_FORK_LIFT_STACK); 
		intArray.add(TA_TYPE_STRADDLE_STACK); 
		intArray.add(TA_TYPE_RTG); 
		intArray.add(TA_TYPE_RMG);
		intArray.add(TA_TYPE_RORO_LANE_AREA);  
		intArray.add(TA_TYPE_BULK);	
		intArray.add(TA_TYPE_RELTRANS);	
		intArray.add(TA_TYPE_GEN_CARGO_ALLOC_ROW);
		intArray.add(TA_TYPE_MAFI);
		
		foreach ta in self.myTerminal.allTerminalAreas do
			if not intArray.includes( ta.type ) then
				continue;
			endif;
			index := self.cmbLocation.addItem( ta.id );
			self.cmbLocation.itemObject[index] := ta;
		endforeach;
		if prevTa &lt;&gt; null then
			self.cmbLocation.listIndex := self.cmbLocation.findObject( prevTa );
			self.populateCmbSubLocs( prevTa );
			if prevLocation &lt;&gt; null then
				self.cmbSubLocation.listIndex := self.cmbSubLocation.findObject( prevLocation );
			endif;
		endif;
		
	else
		self.cmbLocation.enabled := false;
		self.cmbSubLocation.enabled := false;
		
		if self.myVehicleVisitRecord &lt;&gt; null then
			if self.myVehicleVisitRecord.myOutCMGTE_Chassis &lt;&gt; null and self.myVehicleVisitRecord.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem &lt;&gt; null then
				chassis := self.myVehicleVisitRecord.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.CM_TILC;
				self.cmbLocation.listIndex := self.cmbLocation.addItem( chassis.id );
				lc := chassis.allLCs.first;
				self.cmbSubLocation.listIndex := self.cmbSubLocation.addItem( lc.getFullId );
				self.cmbSubLocation.itemObject[1] := lc;
			elseif self.myVehicleVisitRecord.vehicle &lt;&gt; null then
				lc := self.myVehicleVisitRecord.vehicle.locationsController;
				self.cmbLocation.listIndex := self.cmbLocation.addItem( lc.getFullId );		
				self.cmbSubLocation.listIndex := self.cmbSubLocation.addItem( lc.getFullId );
				self.cmbSubLocation.itemObject[1] := lc;
			endif;
		endif;
		
	endif;

epilog

	delete intArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbRelease" id="939278e5-5484-4722-8c43-0ce76ac61c8f">
        <source>populateCmbRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2020	jlgndl1	Initial creation

*/

vars

	bol : CM_BOL;
	bolDtl : CM_BOLDtl;
	gte : CMGTE_Entity;
	reqMaxQty : Integer;
	reqMaxWt : Decimal[14,4];
	selectedGte : CMGTE_Entity;

begin

	bol := self.cmbBOL.listObject.CM_BOL;
	selectedGte := self.cmbRelease.listObject.CMGTE_Entity;
	
	self.cmbRelease.clear();
	
	if bol = null then
		return;
	endif;
	
	foreach bolDtl in bol.allBOLDtls discreteLock do
		foreach gte in bolDtl.allCMGTEEntities discreteLock do
			if gte.myVehicleVisitRecord &lt;&gt; self.myVehicleVisitRecord then
				continue;
			endif;
			if not gte.isCMGTE_Release then
				continue;
			endif;
			
			//29 Oct 2020	NDL	TFS 49189
			reqMaxQty := gte.CMGTE_Release.getAspaMaxQty();
			reqMaxWt := gte.CMGTE_Release.getAspaMaxWeight();
			if reqMaxQty &lt;= 0 and reqMaxWt &lt;= 0 then
				continue;
			endif;
		
			self.cmbRelease.itemObject[ self.cmbRelease.addItem( gte.getTableDisplayString ) ] := gte;
		endforeach;
	endforeach;
	
	if self.cmbRelease.listCount = 1 then
		self.cmbRelease.listIndex := 1;
	elseif selectedGte &lt;&gt; null then		//05 Nov 2020	NDL	TFSD 50305
		self.cmbRelease.listIndex := self.cmbRelease.findObject( selectedGte );
	endif;

epilog

	self.cmbRelease.enabled := ( self.cmbRelease.listCount &gt;= 1 );

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbSubLocs" id="c42afc6a-836b-4190-801a-6bcd0045e187">
        <source>populateCmbSubLocs( _ta : CM_TerminalArea );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	obj : Object;
	lc : CM_LocationsController;
	lcArray : ObjectArray;
	index : Integer;

begin

	if _ta = null then
		return;
	endif;

	create lcArray transient;
	_ta.getAllLocationsControllers( lcArray );
	
	foreach obj in lcArray do
		lc := obj.CM_LocationsController;
		if lc.isRack then
			continue;
		endif;
		index := self.cmbSubLocation.addItem( lc.getFullId );
		self.cmbSubLocation.itemObject[ index ] := lc;
	endforeach;
	
	if lcArray.size = 1 then
		self.cmbSubLocation.listIndex := 1;
	endif;
	
epilog

	delete lcArray;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="populateTblCargo" id="a74d442a-e432-49d2-b047-9b8564e43a1e">
        <source>populateTblCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	bol : CM_BOL;
	cargo : CM_TrackedItem;
	columnIndex : Integer;
	rowIndex : Integer;
	gte : CMGTE_Entity;
	hasBeenGatedOut : Boolean;
	onTruckTrailerLC : CM_LocationsController;
	getRelease : CMGTE_Release;
	trailer : CM_TILC;	//17 Nov 2020	NDL	TFS 50344

begin

	self.tblCargo.rows := self.tblCargo.fixedRows;
	self.btnMove.enabled := false;  // default value until someone clicks an item to move
	self.tblCargo.enabled := not self.optGateOut.value;
	hasBeenGatedOut := self.myVehicleVisitRecord.getGateOutVVRDetail &lt;&gt; null;
	
	if self.myVehicleVisitRecord.myOutCMGTE_Chassis &lt;&gt; null and self.myVehicleVisitRecord.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem &lt;&gt; null then
		onTruckTrailerLC := self.myVehicleVisitRecord.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.CM_TILC.allLCs.first;
		trailer := self.myVehicleVisitRecord.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.CM_TILC;	//
	elseif self.myVehicleVisitRecord.vehicle &lt;&gt; null then
		onTruckTrailerLC := self.myVehicleVisitRecord.vehicle.locationsController;
	endif;
	

	if self.optGateOut.value and self.optOps.value then //Selected to Gaet Out the truck, show everything that is on it now.
	
		self.btnMove.enabled := not hasBeenGatedOut; // i.e. not already gated out
		//treat it as view of whats on the truck
		foreach cargo in self.myVehicleVisitRecord.allReleasedTrackedItems do
			if cargo.hasBeenMerged then
				continue;
			endif;
			if cargo.myPrimaryActualLocation &lt;&gt; onTruckTrailerLC then
				continue;
			endif;
			if cargo.isOffSite then
				continue;
			endif;
			if cargo.isOnSite and cargo.canMergeBreakBulk and self.myVehicleVisitRecord.getMoveTotalForTIID( cargo.id ).Decimal = 0 then
				//Taken off, merged, split and put back on.  We add its spawned replacement ti futher down.
				continue;
			endif;
			rowIndex := self.addCargoToTable( cargo, false );
		endforeach;
		foreach cargo in self.myVehicleVisitRecord.allReceivedTrackedItems do	
			if cargo.myPrimaryActualLocation = onTruckTrailerLC then
				rowIndex := self.addCargoToTable( cargo, true );
			endif;
		endforeach;
		// waiting to be unloaded
		foreach gte in self.myVehicleVisitRecord.allGateEntities do
			if gte.isCMGTE_Receival then
				cargo := gte.CMGTE_Receival.getTI;
				if cargo &lt;&gt; null then
					//Only include what is still on the truck/trailer.
					if cargo.myPrimaryActualLocation = onTruckTrailerLC then
						rowIndex := self.addCargoToTable( cargo, not cargo.isROB );
					endif;
				endif;
			endif;
		endforeach;
		// i.e. unloaded, merged, split and put back again
		foreach cargo in onTruckTrailerLC.allTrackedItems do
			if not cargo.isROB then
				if cargo.canMergeBreakBulk and self.myVehicleVisitRecord.getMoveTotalForTIID( cargo.id ).Decimal = 0 then
					rowIndex := self.addCargoToTable( cargo, true );
				endif;
			endif;
		endforeach;
		
		//17 Nov 2020	NDL	TFS 50344
		if trailer &lt;&gt; null then
			rowIndex := self.addCargoToTable( trailer, false );
		endif;
		
	elseif self.optOps.value and self.optLoad.value then	// Operations Load Mode, show what can be loaded
		
		bol := self.cmbBOL.listObject.CM_BOL;
		getRelease := self.cmbRelease.listObject.CMGTE_Release;	//29 Oct 2020	NDL	TFS 49189
			
		if bol &lt;&gt; null and getRelease &lt;&gt; null then
			foreach cargo in bol.allTrackedItems do
				//Only include what is NOT on the truck and not off-site and not on-site
				if cargo.myPrimaryActualLocation = onTruckTrailerLC then
					continue;
				endif;
				if cargo.isOffSite then
					continue;
				endif;
				if cargo.isOnShip then
					continue;
				endif;
				if cargo.hasBeenMerged then
					continue;
				endif;
				//29 Oct 2020	NDL	TFS 49189
				if getRelease &lt;&gt; null then
					if getRelease.myCargoType &lt;&gt; null and getRelease.myCargoType &lt;&gt; cargo.myCargoType then
						continue;
					endif;
					if getRelease.myProduct &lt;&gt; null and getRelease.myProduct &lt;&gt; cargo.myProduct then
						continue;
					endif;
					if getRelease.operatorCode &lt;&gt; null and getRelease.operatorCode &lt;&gt; cargo.operatorCode then
						continue;
					endif;
					if getRelease.colour &lt;&gt; null and getRelease.colour &lt;&gt; cargo.getColour then
						continue;
					endif;
					if getRelease.commodity &lt;&gt; null and getRelease.commodity &lt;&gt; cargo.commodity then
						continue;
					endif;
					if getRelease.markNumber &lt;&gt; null and getRelease.markNumber &lt;&gt; cargo.markNumber then
						continue;
					endif;
				endif;
				rowIndex := self.addCargoToTable( cargo, false );
			endforeach;
		endif;
		// to handle direct cargo releases that are not BOL releated release by type.
		foreach gte in self.myVehicleVisitRecord.allGateEntities where gte.isCMGTE_Release do
			cargo := gte.CMGTE_Release.myTrackedItem;
			if cargo = null then
				continue;
			endif;
			if cargo.isROB then
				continue;
			endif;
			if cargo.myPrimaryActualLocation = onTruckTrailerLC then
				continue;
			endif;
			if cargo.isOffSite then
				continue;
			endif;
			if cargo.isOnShip then
				continue;
			endif;
			rowIndex := self.addCargoToTable( cargo, false );
		endforeach;
			
	elseif self.optOps.value and self.optDischarge.value then 	// Operations Load Mode, show what is waiting to be unloaded
		
		foreach gte in self.myVehicleVisitRecord.allGateEntities do
			if gte.isCMGTE_Receival then
				cargo := gte.CMGTE_Receival.getTI;
				if cargo &lt;&gt; null and not cargo.isROB then
					//Only include what is still on the truck.
					if cargo.myPrimaryActualLocation = onTruckTrailerLC
					or ( cargo.isOnSite and cargo.canMergeBreakBulk and self.myVehicleVisitRecord.getMoveTotalForTIID( cargo.id ).Decimal = 0 )// i.e. unloaded and put back again
					then
						rowIndex := self.addCargoToTable( cargo, false );
					endif;
				endif;
			endif;
		endforeach;
		// i.e. unloaded, merged, split and put back again
		foreach cargo in onTruckTrailerLC.allTrackedItems do
			if not cargo.isROB then
				if cargo.isOnSite and cargo.canMergeBreakBulk and self.myVehicleVisitRecord.getMoveTotalForTIID( cargo.id ).Decimal = 0 then
					rowIndex := self.addCargoToTable( cargo, false );
				endif;
			endif;
		endforeach;
		
		
	elseif self.optView.value and self.optLoad.value then  //View Mode, show what is loaded on the truck and will be / has been released
	
		if hasBeenGatedOut then
			foreach cargo in self.myVehicleVisitRecord.allReleasedTrackedItems do
				if cargo.hasBeenMerged then
					continue;
				endif;
				if self.myVehicleVisitRecord.allReceivedTrackedItems.includes( cargo ) then
					//was on the truck when it arrived and when it left.
					continue;
				endif;
				rowIndex := self.addCargoToTable( cargo, false );
			endforeach;
		else
			foreach cargo in self.myVehicleVisitRecord.allReleasedTrackedItems do
				if cargo.hasBeenMerged then
					continue;
				endif;
				if cargo.isOnSite and cargo.canMergeBreakBulk and self.myVehicleVisitRecord.getMoveTotalForTIID( cargo.id ).Decimal = 0 then
					//was discharged, now back on, not really loaded.
					continue;
				endif;
				rowIndex := self.addCargoToTable( cargo, false );
			endforeach;
		endif;
			
	elseif self.optView.value and self.optDischarge.value then	//View Mode, show what was received
	
		foreach cargo in self.myVehicleVisitRecord.allReceivedTrackedItems do
			if hasBeenGatedOut then
				if self.myVehicleVisitRecord.allReleasedTrackedItems.includes( cargo ) then
					//was on the truck when it arrived and when it left.
					continue;
				endif;
			endif;
			
			if cargo.isOnSite and cargo.canMergeBreakBulk and self.myVehicleVisitRecord.getMoveTotalForTIID( cargo.id ).Decimal = 0 then
				//was discharged, now reloaded in some way.
				continue;
			endif;
			
			rowIndex := self.addCargoToTable( cargo, cargo.myPrimaryActualLocation = onTruckTrailerLC );
		//	if cargo.isOnSite and cargo.canMergeBreakBulk then
			if cargo.myCargoType.allowDuplicates then
				// use the vvr to show how much we actually received
				columnIndex := self.tblCargo.getColumnByRowName(ETRow_Amount);
				if columnIndex &gt; 0 then
					self.tblCargo.accessCell( rowIndex, columnIndex ).text := self.myVehicleVisitRecord.getMoveTotalForTIIDDisplay( cargo );
				endif;
			endif;
		endforeach;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetDTtoLatestOnVVR" id="72a53552-4e9f-4efe-bafb-8f4f9cc800a1">
        <updating/>
        <source>resetDTtoLatestOnVVR( _warn : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	dt : TimeStamp;
	lastVVRD : CM_VehicleVisitRecordDetail;
	vvrTimeRounded : Time;
	vvrTS : TimeStamp;
	screenTime : Time;
	screenTS : TimeStamp;
	msg : String;

begin

	//Date and time is truncated to hrs and mins because it is captured from the screen, but the VVRD will automatically increment in milliseconds so we get the order correct
	// check to make sure manually entered times don't end up accidently pre-dating other records, cos it looks crap. I.e. Gate out occuring before gate-in.
	// So teh user gets the choise to over-ride.

	dt := self.myTerminal.systemToLocalTime( self.myVehicleVisitRecord.timeIn );
	lastVVRD := self.myVehicleVisitRecord.allVehicleVisitRecordDetails.last();
	if lastVVRD &lt;&gt; null and lastVVRD.timeStart &gt; dt then
		dt := lastVVRD.timeStart;
	endif;
	
	vvrTimeRounded.setTime( dt.Time.hour, dt.Time.minute, 0, 000 );
	if dt.Time.second &gt; 0 then
		vvrTimeRounded := vvrTimeRounded.addMinutes(1);
	endif;
	
	screenTS.setDate(self.txtDate.getDate());
	screenTS.setTime(self.txtTime.getTime());
	
	if not screenTS.date.isValid then
		self.txtDate.setDate( dt.Date );
		self.txtTime.setTime( vvrTimeRounded );
		return;
	elseif screenTS &gt;= dt then
		//All good any new VVRD will be the latest chronologically
		return;
	endif;
	
	vvrTS.setDate(dt.Date);
	vvrTS.setTime(vvrTimeRounded);

	if screenTS &gt;= vvrTS then
		//All good any new VVRD will be the latest chronologically
		return;
	endif;
	
	if _warn then
		msg := "The selected Date and Time " &amp; screenTS.asStringJMT &amp; " is earlier than the last record on the Vehicle Visit " &amp; vvrTS.asStringJMT &amp; ".";
		msg := msg &amp; CrLf &amp; "Would you like the Date/Time set forward?";
		if app.msgBox( msg, app.getErrorString(Advance_time), MsgBox_Yes_No ) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	self.txtDate.setDate( dt.Date );
	self.txtTime.setTime( vvrTimeRounded );

epilog

end;</source>
        <Parameter name="_warn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="ce96a626-c6ff-424f-af6c-8ce31a9665e1">
