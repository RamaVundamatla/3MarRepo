    <JadeMethod name="clearChassisInFields" id="b14cc937-589a-47ca-ac52-4fac2764506a">
        <source>clearChassisInFields() protected;
/*
Date		Who		Reason
04 September 2009	cnwjk3	Initial creation

*/

vars

	defTrailerOperator : CM_Operator;

begin
	self.cmbTrlrTypeIn.listObject := null;
	self.cmbOperatorIn.setObject(null);
	if self.myTerminal.roadProcessIsASPA then	//28 Oct 2020	NDL	TFS 50113
		defTrailerOperator := self.myTerminal.getConfig(DefRecTrailOper).CM_Operator;	
		if defTrailerOperator &lt;&gt; null then
			self.cmbOperatorIn.setObject( defTrailerOperator );
		endif;
	endif;
	//self.txtTareChassIN.text := null;																		// PAR #32536
	self.txtTareChassIN.setValues("" &amp; Space &amp; app.getDefaultMeasurementForType(Type_Weight).shortName);	// PAR #32536
	
	//17 Jan 2019	NDL	TFS 42951
	if self.chkLockReceive.value then
		self.setTrailerReceiveDefs( self.xmlForReceiveTrailer, false );
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearForm" id="07b4ad07-aaee-4f9f-84a7-067d2df3b4c4">
        <updating/>
        <source>clearForm() updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09/02/2011		cnwdap1			PAR #26929 Stop incorrect "you have changed something" messages
// 26/09/2013		cnwdap1			PAR #32536 Tare Weight In field is now a measurement table
// 10/12/2015       cnwma1			PAR #37193 Appointment Number Not Displayed on Receive Cargo Screen
// 30/10/2019		jlgdap1			TFS 46854 SNO Driver Identity Checking for Cargo Release
// 11/01/2022		navdap1			TFS 52268 AAT 1-Stop VBS Integration
// 13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 12/07/2022		navmd1			TFS 52777 Tidy up/review code
// 24/05/2023		navpw1			TFS: 54049 (55840) - Added code to clear all vehicle bookings collection
// 14 Feb 2024 		navhl20 		ChangeRequest 62084:[62377] EUP | Retrospective Operations - [54177.010] - Road Entry
// 14/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// ---------------------------------------------------------------------------

vars
	gate : CM_Gate;
	defTrailerStatus : Integer;
	defTrailerOperator : CM_Operator;
begin
	self.clearingForm := true;
	
	self.clearSavedWarnings();			// cnwjk3 PAR 23206 18/03/2010
	self.enableFieldsAfterClear();
	

	//self.tblItems.rows := self.tblItems.fixedRows;
	self.tblItems.clear;
	
	self.chassisOwnerID := "";
	self.txtDriverCode.text := null;
	self.txtDriverName.text := null;
	self.txtState.text := null;
	
	self.enableFields(true);
	
	self.cmbCarrier.listIndex := -1;
	self.cmbSubCarrier.listIndex := -1;   //13/05/2022 navhl20 TFS 53430
	self.cmbGateLanes.clear();
	self.cmbDriver.clear;
	self.cmbDriverCode.clear();
	self.cmbDriverCode.visible := false;
	
	// cnwjk3 PAR 23184  15/03/2010 
	// When the form is cleared, set the gate combo to the gate recorded in user prefs.
	// If that fails, then set it to the default configured gate
	self.setDefaultGate();
	
	if self.cmbGateLanes.listCount() &gt; 0 then	// cnwjk3 15/10/09 PAR 21338
		self.cmbGateLanes.enabled := true;
	else
		self.cmbGateLanes.enabled := false;	
	endif;

	self.cmbInterchange.listIndex := -1;		// cnwjk3 ccms 1071 18/02/10 
	
	if not self.myTerminal.getConfig(HideRGateDriverCodeName).Boolean and not self.cmbDriver.visible then
		self.txtDriverCode.visible := true;
	endif;
	
	if not self.printerIsUserSelected then	//03 Sep 2012	NDL	Par 30286 - If the user has set the printer, leave it be...
		self.cmbPrinter.listIndex := -1;
	endif;

	self.txtVisitNumber.text := null;
	self.txtRegno.text := null;
	self.cmbRegNo.listIndex := -1;
	self.myRealVVR := null;
	self.btnRecordWeight.enabled := false;		// 21/6/17 MAP TFS4273
	
	if self.myVehicleBookingTimeslot &lt;&gt; null then       // 10/12/2015 cnwma1 PAR #37193
		self.myVehicleBookingTimeslot := null;
	endif;
	self.detailsChangedVehicle := false; // PAR 18553	// PAR #26929
	self.enableActionButtons(true);
	//self.txtDriverCode.setFocus();		// PAR #35805
	self.txtRegno.setFocus();				// PAR #35805
	
	//29 Nov 2012	NDL	Par 30745
	//self.chkReceiptReq.value := false;
	self.chkReceiptReq.value := self.myTerminal.getConfig(GateReceiptCopies).Integer &gt; 0;
	
	//self.txtPIN.text := null;
	self.setTxtPinToNullOrVbsId();
	
	// Receive Trailer
	self.txtChassisIDIn.text := null;
	//self.txtTareChassIN.text := null;																		// PAR #32536
	self.txtTareChassIN.setValues("" &amp; Space &amp; app.getDefaultMeasurementForType(Type_Weight).shortName);	// PAR #32536
	self.cmbTrlrTypeIn.listIndex := -1;
	self.cmbOperatorIn.listIndex := -1;
	
	//26 May 2017	NDL	TFS 4452
	defTrailerStatus := self.myTerminal.getConfig(DefRecTrailIMEX).Integer;
	if defTrailerStatus = 0 then
		defTrailerStatus := TI_IMEX_STATUS_STORAGE;
	endif;
	if self.myTerminal.roadProcessIsASPA then	//09 Oct 2020	NDL	TFS 49189
		self.cmbTrailIMEX.setIndexFromObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD]);
		defTrailerOperator := self.myTerminal.getConfig(DefRecTrailOper).CM_Operator;	//28 Oct 2020	NDL	TFS 50113
		if defTrailerOperator &lt;&gt; null then
			self.cmbOperatorIn.setObject( defTrailerOperator );
		endif;
	else
		self.cmbTrailIMEX.setIndexFromObject(app.myRoot.allImexStatuses[defTrailerStatus]);
	endif;
	// Release Trailer
	self.txtChassisIDOut.text := null;
	self.txtChassisIDOut.userObject:=null;
	self.lblCassOutLoc.caption := "";
	self.cmbTrlTypeOut.listIndex := -1;
	self.cmbOperatorOut.listIndex := -1;
	self.doChangeChassisReleaseBy(self.optChassisRelID.value);
	self.txtAVGrade.text:=null;
	self.lstAVGrade.clearSelected;
	//cnwas3
	self.clearLayout();
	
	//29 Nov 2012	NDL	Par 30745
	//self.chkAutoComplete.value := false;
	//if self.grpAutoComplete.visible then
	if self.grpAutoComplete.visible and not self.myTerminal.roadProcessIsASPA then	//09 Oct 2020	NDL	TFS 49189
		self.chkAutoComplete.value := self.myTerminal.getConfig(GateInAutoComplete).Boolean;
	else
		self.chkAutoComplete.value := false;
	endif;
	
	self.doEnableDateTimeAutoComplete(false);

	self.btnPrint.visible := false;
	
	//20 Sep 2011	NDL	Par 24455
	self.tblTransfers.rows := self.tblTransfers.fixedRows;
	self.btnTfrAction.enabled := false;
	self.populateTblTransfers();
	self.tblBulkRelease.rows := self.tblBulkRelease.fixedRows;
	self.btnRelAction.enabled := false;
	self.txtBulkRelease.text := null;
	
	self.myAssistant.comboBoxRFIDTag( self.cmbRFID, self.myTerminal, null );	//23 Apr 2012	NDL	Par 29417
	
	//17 Jan 2019	NDL	TFS 42951
	if self.chkLockReceive.value then
		self.setTrailerReceiveDefs( self.xmlForReceiveTrailer, false );
	endif;
	self.setReceiveReleaseTotals();	//10 Jan 2019	NDL	TFS 40479
	
	self.driverIDScanned := false;		// TFS 46854
	
	self.all1StopVBSDetails.purge;			// TFS 52268
	
	self.hasChanged := false;
	self.resetFirstChange();
	self.allVehicleBookingTimeslots.clear();	// ### TFS 54049 (55840) 24May2023 NAVPW1
	
	self.chkOpsRetrospective.value := false;					//14.02.2023 navhl20 #62084:[62377]
	self.chkOpsRetrospective_click(self.chkOpsRetrospective); 	//14.02.2023 navhl20 #62084:[62377]
epilog
	self.clearingForm := false;
end;</source>
    </JadeMethod>
