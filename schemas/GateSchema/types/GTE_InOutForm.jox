        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSrcLocn_lostFocus(combobox: GTE_ComboBox input) updating;
//--------------------------------------------------------------
//Created: 12 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sheet	: GTE_Sheet;
	assistant	: GTE_Assistant;
	entryTable	: CM_EntryTable;
	subCmb, subSubCmb	: GTE_ComboBox;
begin
	sheet := combobox.mySheet;
	self.setCellTextFromControl(sheet, combobox, combobox.text);
	if self.origValueStr &lt;&gt; combobox.text then	
		assistant := self.myAssistant.GTE_Assistant;
		entryTable := sheet.myTblExtra;
		subCmb	:= sheet.getControlByName(Cntrl_cmbSrcSubLocn).GTE_ComboBox;
		subSubCmb	:= sheet.getControlByName(Cntrl_cmbSrcSubSubLocn).GTE_ComboBox;	
		assistant.setSourceSubLocns(entryTable, subCmb, subSubCmb, combobox.listObject.CM_SourceLocation);
		// need to set FSC value according sourceLocation, sourceSubLocation and sourceSubSubLocation. CCMS 1105, PAR 21535 Nov 2009
		assistant.setCertified(entryTable, combobox.listObject.CM_SourceLocation, subCmb.listObject.CM_SourceSubLocation, subSubCmb.listObject.CM_SourceSubSubLocation);
	endif;
end;</source>
        <Parameter name="combobox" type="GTE_ComboBox" usage="input"/>
    </JadeMethod>
