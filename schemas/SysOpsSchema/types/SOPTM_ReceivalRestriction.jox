    <JadeMethod name="isObjectRelevant" id="9e30f82e-129c-4456-8e11-cc6c6575285d">
        <source>isObjectRelevant(_obj: Object): Boolean;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation

*/
vars

begin
	if inheritMethod(_obj) then
		if _obj.CM_ReceivalCutoffTermDef.myTerminal = self.myForm.myTerminal then
			return true;
		endif;	
	endif;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="2b8cf4bd-60de-4b42-a66b-d73f989511b1">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
28/02/2012	cnwcs5	par 29158 - EDI Booking Cutoff
*/
vars
	form	 	: SOP_TableMaintForm;
	table		: CM_EntryTable;
	maxSortKey	: Integer;
	recCutoff	: CM_ReceivalCutoffTermDef;

begin
	form 					:= self.myForm;
	table					:= form.tblInput1;
	table.userInputEnabled 	:= true;
				
	if form.mode = form.Mode_Add then
		table.clearValues;
		table.enableRowByName(ETRow_Code);
		table.setFocus;
		table.moveFirst();
		table.gotFocus(table);	// sets case etc.
		form.fldInput.initSheetBackColors();
		
		self.allCriteria.purge();
		self.allEDIDataTypes.clear();	// par 29158 - Feb 2012
		
		form.myAssistant.comboBoxCriteriaType(table, ETRow_CriteriaType, CM_ReceivalCutoffTermDef.CriteriaType_CARGO_Desc);	// 20 Apr 2012	NDL	Par 29452		
	//	table.setValueByName(ETRow_CriteriaType, CM_ReceivalCutoffTermDef.CriteriaType_CARGO_Desc);	// par 29158 - Feb 2012
		
		form.myAssistant.comboBoxDefaultRelativeTo(table, ETRow_DefaultRelativeTo, 
													DefaultRelativeTo_Arrival_Str, 
													CM_ReceivalCutoffTermDef.CriteriaType_CARGO);	// par 29158
													
		table.setValueByName(ETRow_IsAvailableForEntry, true);
		
		foreach recCutoff in form.myTerminal.allReceivalCutoffDefs do
			maxSortKey := maxSortKey.max(recCutoff.sortKey);
		endforeach;
		
		table.setValueByName(ETRow_SortKey, maxSortKey + 1);
		
		table.showRowByName(ETRow_DefaultEarliestReceival, false);	// 12/10/2012 cnwar2 #30508
		table.showRowByName(ETRow_DefaultEarliestReceivePN, false);	//20/03/2025	navkc1 JIRA Story MTN-34231
		table.adjustHeight(800);
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(form.myProxyObject.CM_ReceivalCutoffTermDef);
		// cannot update code
		table.disableRowByName(ETRow_Code);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="73b74906-ff5f-430a-a9cf-d9d6b31fd65a">
        <updating/>
        <source>setCtrlsForView() updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
29/02/2012	cnwcs5	par 29158 - EDI Booking Cutoff
*/
vars
	form 	: SOP_TableMaintForm;
