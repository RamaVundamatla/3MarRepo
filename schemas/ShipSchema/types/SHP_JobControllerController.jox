    <JadeMethod name="frmScrollingMain_dragDrop" id="ea901112-f5c6-429d-9e55-3bf07982d2b2">
        <updating/>
        <source>frmScrollingMain_dragDrop(_x: Real; _y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : Object;
	x1,y1,x2,y2,
	x,y: Real;
	z, numJobsFound : Integer;
	selectedCraneJob,
	craneJob: SHP_CraneJobDrawingController;
	voyageJob,
	selJob,toObject : CM_VoyageJob;
	theSelectedObjects : CM_VoyageJobArray;
	hasErrors : Boolean;
	changeJobSheet : Boolean;
	toCrane : CM_Crane;
	theCompletionTime : TimeStamp;
	before,
	back : Boolean;
	halfway : Real;
begin
	app.mousePointer:=Window.MousePointer_HourGlass;
	if not self.doCheckCanEdit() then
		self.doClearAllSelected(true);
		return;
	endif;
	theCompletionTime:=self.voyageEndTime;
	x:=_x;
	y:=_y;	
	voyageJob:=self.getBubbleJob(x,y,false, numJobsFound);
	foreach craneJob in self.allJobDrawControllers do
		if craneJob.allJobObjects.includes(voyageJob) then
			craneJob.getXYZsForJob(voyageJob,x1,y1,x2,y2,z);
			break;
		endif;
	endforeach; 
 
	halfway:=(x1 + x2)/2;
	before:= x &lt; halfway;
	
	
	self.allWarnings.clear;
	hasErrors:=false;
	
	
	if voyageJob  &lt;&gt; null and self.mySelectedJobDrawConroller.allJobObjects.size &lt;&gt; null then //self.allSelectedJobs.size  = 1 then
		create theSelectedObjects transient;
		 self.mySelectedJobDrawConroller.allJobsInOrderAdded.copy(theSelectedObjects);
		 changeJobSheet:= craneJob.crane &lt;&gt;  self.mySelectedJobDrawConroller.crane; 
		foreach obj in  theSelectedObjects do
			selJob:=obj.CM_VoyageJob;
			 if not changeJobSheet then
				if not self.doMoveJobInJobSheetNew(selJob,voyageJob,before) then
					hasErrors:=true;
					break;
				endif;
			else
				if not self.doChangeJobsCraneAtXYNew(selJob,theSelectedObjects,craneJob.crane,x,y) then
					hasErrors:=true;
				endif;	
			endif;	
		endforeach;

			
		
		self.checkCraneClearance(craneJob.crane);
		
		self.mySelectedJobDrawConroller.allJobObjects.clear;
		currentBubbleJob:=null;
		if theCompletionTime &lt;&gt; self.voyageEndTime then
			//need to change the time scale
			self.doChangeTimeScale();
		else
			self.drawAllJobs(true);
		endif;
		
		if not hasErrors and self.allWarnings.size &lt;&gt; null then
			self.doDisplayWarnings();
		endif;
	else
		self.doClearAllSelected(true);	
	endif;

epilog
	if theSelectedObjects &lt;&gt; null then
		delete theSelectedObjects;
	endif;
	app.mousePointer:=Window.MousePointer_Default;
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frmScrollingMain_mouseDown" id="f46530ad-db62-4231-9a23-fefa0b03c034">
        <updating/>
        <source>frmScrollingMain_mouseDown(button: Integer; shift: Integer; x: Real; y: Real) : Integer updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	x1,y1, x2,y2	: Real;
	z : Integer;
	voyageJob : CM_VoyageJob;
	craneJob,
	realJobController: SHP_CraneJobDrawingController;
	multiSelect : Boolean;
	zOrder, numJobsFound : Integer;
begin
	
	
	if button = 2 then
		return 0;
	endif;
	multiSelect:=shift = 1 or  shift = 2;
		
	self.frmJobBubble.visible:=false;
	
	voyageJob:=self.getBubbleJob(x,y,false,numJobsFound);
	self.myOnlyVoyageJob := voyageJob;
	
	foreach craneJob in self.allJobDrawControllers do
		if craneJob.allJobObjects.includes(voyageJob) then
			craneJob.getXYZsForJob(voyageJob,x1,y1,x2,y2,z);
			break;
		endif;
	endforeach; 
//	process.debug;
	if voyageJob &lt;&gt; null then
		if not multiSelect then
			self.doClearAllSelected(true);
		endif;
		//can only select if 
		//selectedCraneJob:=self.allSelectedJobDrawControllers[craneJob.crane];
		if self.mySelectedJobDrawConroller = null then
			create self.mySelectedJobDrawConroller transient;
			self.mySelectedJobDrawConroller.setDetails(craneJob.crane,null,self.frmScrollingMain);
			self.mySelectedJobDrawConroller.dontCleanUpTransients:=true;
		else
			if  multiSelect and self.mySelectedJobDrawConroller.crane &lt;&gt; craneJob.crane then
				return 0;
			endif;
			self.mySelectedJobDrawConroller.setCrane(	craneJob.crane);
		endif;
		
		self.mySelectedJobDrawConroller.addJobAt(voyageJob,x1,y1,x2,y2,1);
		zOrder:=0;
		while zOrder &lt;= 1 do
			self.mySelectedJobDrawConroller.drawAllJobs(true,self.getCurrentTimeX,zOrder);
			zOrder:=zOrder + 1;
		endwhile;
		realJobController:=self.allJobDrawControllers[self.mySelectedJobDrawConroller.crane];
		realJobController.drawAllDelays;
	else
		if shift &lt;&gt; 1 and shift &lt;&gt; 2 then
			self.doClearAllSelected(true);
		endif;
	endif;
	return numJobsFound;
epilog


end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="frmScrollingMain_mouseMove" id="f67d095d-3f8f-4440-8bad-c58411f6518e">
        <updating/>
        <source>frmScrollingMain_mouseMove(button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	x1,y1, x2,y2	: Real;
	z, numJobsFound : Integer;
	obj : Object;
	voyageJob : CM_VoyageJob;
	craneJob : SHP_CraneJobDrawingController;
	delay : CM_Delay;
begin
	if button &lt;&gt; 0 and button &lt;&gt; 1 then
		return;
	endif;

	voyageJob:=self.getBubbleJob(x,y,false,numJobsFound);
	
	if button = 0 then
		self.displayJobBubble(voyageJob,x, y);
	elseif button = 1 then
		if self.mySelectedJobDrawConroller &lt;&gt; null and voyageJob = null then
			self.myForm.dragMode := Frame.DragMode_Drag; //1;
			self.myForm.dragCursor := self.myForm.picYAGroupCur.picture; // PAR 16629
		endif;
	endif;

end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frmScrollingMain_mouseUp" id="45c72c45-e908-4c01-866c-1900e901d9ee">
        <updating/>
        <source>frmScrollingMain_mouseUp(button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	x1,y1, x2,y2	: Real;
	z : Integer;
	voyageJob : CM_VoyageJob;
	crane : CM_Crane;
	craneJob,
	realJobController: SHP_CraneJobDrawingController;
	zOrder, numJobsFound : Integer;
begin

	if button = 2 then
		self.myForm.dragMode:=0;
		return;
	endif;
	self.frmJobBubble.visible:=false;
	
	voyageJob:=self.getBubbleJob(x,y,false, numJobsFound);
	
	foreach craneJob in self.allJobDrawControllers do
		if craneJob.allJobObjects.includes(voyageJob) then
			craneJob.getXYZsForJob(voyageJob,x1,y1,x2,y2,z);
			break;
		endif;
	endforeach; 
	
	//obj:=self.allJobObjects.findObjectInDict(x,y,x1,y1,x2,y2);
	if voyageJob = null then
		return;
	endif;

	//voyageJob:=obj.CM_VoyageJob;
	crane:=voyageJob.getJobCrane;
	
	if shift.bitAnd(1) &lt;&gt; 0 or shift.bitAnd(2) &lt;&gt; 0 then
		
	else
		if self.mySelectedJobDrawConroller = null then
			
			return;
		endif;
		zOrder:=0;
		while zOrder &lt;= 1 do
			self.mySelectedJobDrawConroller.drawAllJobs(false,self.getCurrentTimeX,zOrder);
			zOrder:=zOrder + 1;
		endwhile;
		realJobController:=self.allJobDrawControllers[self.mySelectedJobDrawConroller.crane];
		realJobController.drawAllDelays;
		self.mySelectedJobDrawConroller.removeJobAt(voyageJob,x1,y1,x2,y2,1);		
		//endif;
	endif;
end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllCraneJobs" id="a9daa523-479a-4cfc-b05e-492fa8081db0">
        <updating/>
        <source>getAllCraneJobs(_voyageJobSheet : CM_VoyageJobSheet;
				_allJobsStartEndTime : ObjectArray input;
				_currentEnd : TimeStamp io) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	job  : CM_Job;
	voyageJob :CM_VoyageJob;
	jobStart,
	jobEnd,
	theVoyageEnd: TimeStamp;
	crane : CM_Crane;
	cmif_ObjectDateRange : CMIF_MyObjectDateRange;
	pJobStart, pJobEnd,
	jobSheetStartTS: TimeStamp;
	estJobTime : Integer;
begin
	theVoyageEnd:=self.getEndTime;
	
	jobSheetStartTS:=_voyageJobSheet.getWorkStarted;
	
	if self.myVoyage.arrivedDT &lt;&gt; null  then
		if self.myVoyage.arrivedDT &gt; jobSheetStartTS  or (theVoyageEnd &lt;&gt; null and jobSheetStartTS &gt; theVoyageEnd) then
			_currentEnd:=self.myVoyage.arrivedDT;
		else
			_currentEnd:=jobSheetStartTS ;
		endif;
	else
		_currentEnd:=jobSheetStartTS ;
	endif;
	
	if voyageStartTime = null or _currentEnd &lt; voyageStartTime then
		self.setVoyageStartTime(_currentEnd);
	endif;

	_currentEnd:=self.getJobSheetStartTimeWithDelays(_voyageJobSheet,_currentEnd);
	foreach job in _voyageJobSheet.allJobsByOrder discreteLock do
		if not job.isKindOf(CM_VoyageJob) then
			continue;
		endif;
		voyageJob:=job.CM_VoyageJob;
		crane:=voyageJob.getJobCrane;
		pJobStart:=null;
		pJobEnd:=null;
		voyageJob.getStartEndFromWLEs(pJobStart,pJobEnd);
		if	voyageJob.actualStartTs &lt;&gt; null   then
			jobStart := voyageJob.actualStartTs;
		else
			if pJobStart &lt;&gt; null then
				jobStart := pJobStart;
			else
				jobStart:=_currentEnd;
			endif;
		endif;
		if voyageJob.workListEntries.size = 0 and voyageJob.actualEndTs &lt;&gt; null then
			jobEnd:=voyageJob.actualEndTs;
			jobEnd:=voyageJob.getEndTsWithDelays(jobStart,jobEnd,crane,self.myVoyageStats.allVoyageDelays);
		else
			if voyageJob.status = JOB_COMPLETE then
				if voyageJob.actualEndTs &lt;&gt; null then
					jobEnd:=voyageJob.actualEndTs;
				elseif  pJobEnd &lt;&gt; null then
					jobEnd:=pJobEnd;
					jobEnd:=voyageJob.getEndTsWithDelays(jobStart,jobEnd,crane,self.myVoyageStats.allVoyageDelays);
				endif;
				
			else
		
				estJobTime:=voyageJob.getEstJobTimeUsingCraneRates(crane);
				
				if estJobTime &lt;&gt; null and jobStart &lt; self.getCurrentTime then
					if voyageJob.actualStartTs = null then
						jobStart :=self.getCurrentTime;
					endif;
					jobEnd :=self.getCurrentTime.addMinutes(estJobTime);
					jobEnd:=voyageJob.getEndTsWithDelays(self.getCurrentTime,jobEnd,crane,self.myVoyageStats.allVoyageDelays);
				else
					jobEnd:=jobStart.addMinutes(estJobTime);
					jobEnd:=voyageJob.getEndTsWithDelays(jobStart,jobEnd,crane,self.myVoyageStats.allVoyageDelays);
				endif;				
			endif;
		endif;	
		
		create cmif_ObjectDateRange transient;
		cmif_ObjectDateRange.setDetails(voyageJob,jobStart,jobEnd);
		_allJobsStartEndTime.add(cmif_ObjectDateRange);
		_currentEnd:=jobEnd;
	endforeach;

epilog

end;</source>
        <Parameter name="_voyageJobSheet" type="CM_VoyageJobSheet"/>
        <Parameter name="_allJobsStartEndTime" type="ObjectArray" usage="input"/>
        <Parameter name="_currentEnd" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllDelays" id="d5b1cb2e-9654-4156-a9d9-49cf091f05df">
        <source>getAllDelays();
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneDelayIter :Iterator;
	voyageDelayIter : Iterator;
	delay : CM_Delay;
	delayStartX,
	delayEndX,
	delayY1,
	delayY2: Real;
	z 		: Integer;
	voyageJobSheet : CM_VoyageJobSheet;
	crane : CM_Crane;
	craneJobController : SHP_CraneJobDrawingController;
begin
	
	self.frmScrollingMain.drawStyle:=Window.DrawStyle_Solid;
	self.frmScrollingMain.drawFillStyle:=Window.DrawFillStyle_Transparent;

	if self.myVoyage.allDelays.size &gt; 0 then
	voyageDelayIter:=self.myVoyage.allDelays.createIterator;
//	self.myVoyage.allDelays.startKeyLeq(self.voyageStartTime,voyageDelayIter); //epr 19/4/07 par 13905
	while voyageDelayIter.next(delay) do
		if delay.startDT &gt; self.voyageEndTime then
			break;
		endif;
		delayStartX:=self.myTimeLineDrawController.getXForTime(delay.startDT);
		if delay.getEndDT = null or delay.getEndDT &lt; self.voyageStartTime then //epr 19/4/07 par 13905
			continue;
		endif;
		delayEndX:=self.myTimeLineDrawController.getXForTime(delay.getEndDT);
	
		foreach craneJobController in self.allJobDrawControllers do
			if delay.myMachine &lt;&gt; null and craneJobController.crane &lt;&gt; delay.myMachine then
				continue;
			endif;
		
			if craneJobController.getYRangeAtXRange(delayStartX,delayEndX,delayY1,delayY2) then	
				if craneJobController.allDelayObjects.getAtKey(delayStartX,delayY1,delayEndX,delayY2, z) = null then
					craneJobController.allDelayObjects.putAtKey(delayStartX,delayY1,delayEndX,delayY2,z, delay);
				endif;
			endif;
		endforeach;
	endwhile;	
	
	delete voyageDelayIter;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllJobDrawControllersNew" id="dcf16c95-c13e-4883-a81e-d4a8a1fcfe9f">
        <source>getAllJobDrawControllersNew(_voyageStats : CMIF_VoyageStats);
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
obj : Object;
	//cmif_ObjectDateRange : CMIF_MyObjectDateRange;
	x1,
	x2,
	y1,
	y2,z : Real;
	startFromTop : Boolean;
	voyageJob,
	realVoyageJob: CM_VoyageJob;
	bayOne , bayTwo : CM_Bay;
	forwardBayOverview,
	aftBayOverview : CMUI_BayOverviewObject;
	cmifJobStats : CMIF_JobStats;
	cmifJobSheetStats : CMIF_JobSheetStats;
	craneJobDrawCont : SHP_CraneJobDrawingController;
	crane: CM_Crane;
	deleteObjects : ObjectArray;
	jobSheetStatIter, jobStatIter : Iterator;
	invalidJob : Boolean;
begin
	/*
	Date	    Who		Reason
	4 Sep. 2008	cnwdz2	Par17866 - Use app.handleDeletedObject() to handle invalid object reference.
	*/
	on Exception do app.handleDeletedObject(exception, voyageJob, invalidJob);
				
	create deleteObjects transient;
	jobSheetStatIter := _voyageStats.allJobSheetStats.createIterator;
	while jobSheetStatIter.next(cmifJobSheetStats) do
		crane:=cmifJobSheetStats.myJobSheet.CM_VoyageJobSheet.getMyCrane;
		if crane = null then
			continue;
		endif;
		
		if mode = MODE_ACTUAL then
			jobStatIter:=cmifJobSheetStats.allJobStatsByActualEndTime.createIterator;
		else
			jobStatIter:=cmifJobSheetStats.allJobStatsByTargetEndTime.createIterator;
		endif;
		while jobStatIter.next(cmifJobStats) do
			invalidJob := false;
			voyageJob:=cmifJobStats.myJob.CM_VoyageJob;
			
			//crane:=voyageJob.getJobCrane;
			if self.mode = MODE_ACTUAL then
				x1:=self.myTimeLineDrawController.getXForTime(cmifJobStats.actualStartTime);
				x2:=self.myTimeLineDrawController.getXForTime(cmifJobStats.actualEndTime);
			else
				x1:=self.myTimeLineDrawController.getXForTime(cmifJobStats.targetStartTime);
				x2:=self.myTimeLineDrawController.getXForTime(cmifJobStats.targetEndTime);				
			endif;
			
			if x1 = x2 and cmifJobStats.myJob.status &lt;&gt; JOB_COMPLETE then		//this is for when we only have 1 container for a job,so the end/start times coincide. The user still wants to see something on the graphic tho
				x2 := x1 + 4;		//maybe a 4 pix wide bar will be enough
			endif;		//cnwas3 par 25976
			
			bayOne:=null;
			bayTwo:=null;
			forwardBayOverview:=null;
			aftBayOverview:=null;
			if voyageJob.isTransient then
				realVoyageJob:=app.myProxyManager.getRealObject(voyageJob).CM_VoyageJob;
			else
				realVoyageJob:=voyageJob;
			endif;
			
			// 4 sep 2008 cnwdz2 par17866
			if invalidJob then 
				continue;
			endif;
			
			realVoyageJob.getBays(bayOne,bayTwo);
			if bayOne = null then
				continue;
			endif;
			forwardBayOverview:=self.myVoyageDrawController.allBayOverviewObjects[bayOne.id];
			if bayTwo &lt;&gt; null then
				aftBayOverview:=self.myVoyageDrawController.allBayOverviewObjects[bayTwo.id];
			endif;	
			
			startFromTop:=self.myVoyageDrawController.getStartFromTop;
			
			if  startFromTop then
				y1:= forwardBayOverview.y;
				if aftBayOverview &lt;&gt; null then
					y2:=aftBayOverview.y + self.myVoyageDrawController.bayLength;
				else
					y2:=y1 + self.myVoyageDrawController.bayLength;
				endif;
			else
				y2:= forwardBayOverview.y + self.myVoyageDrawController.bayLength;
				if aftBayOverview &lt;&gt; null then
					y1:=aftBayOverview.y; 
				else
					y1:=y2 - self.myVoyageDrawController.bayLength;
				endif;
			endif;
			
			craneJobDrawCont:=self.allJobDrawControllers[crane];
			if craneJobDrawCont = null then
				create craneJobDrawCont transient;
				craneJobDrawCont.setDetails(crane,cmifJobSheetStats,self.frmScrollingMain);
				self.allJobDrawControllers.add(craneJobDrawCont);
			else
				craneJobDrawCont.allDelayObjects.clear;
			endif;

			craneJobDrawCont.addJobAt(voyageJob,x1,y1,x2,y2-1,0);
		endwhile;
		delete jobStatIter;
	endwhile;
	self.getAllDelays;
epilog
	deleteObjects.purge;
	delete deleteObjects;
	delete  jobSheetStatIter;

end;</source>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats"/>
    </JadeMethod>
    <JadeMethod name="getAllJobs" id="a2f87bff-b618-4f66-96d4-e2153f07cb3c">
        <updating/>
        <source>getAllJobs(_allJobsStartEndTime : ObjectArray io) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	voyageJobSheet : CM_VoyageJobSheet;
	currentEnd,lastDelayEnd : TimeStamp;
	lastDelay : CM_Delay;
begin
	self.voyageEndTime:=null;
	self.voyageStartTime:=null;
	currentEnd:=self.getStartTime;
	self.allJobDrawControllers.purge;
	delete self.mySelectedJobDrawConroller;
	
	self.setCurrentTime(app.actualTimeServer);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach voyageJobSheet in self.myVoyage.allJobSheets discreteLock do
	
		self.getAllCraneJobs(voyageJobSheet,_allJobsStartEndTime,currentEnd);
		
		//set the voyage end on form so we have a timescale to draw
		if currentEnd &gt; self.voyageEndTime then
			self.setVoyageEndTime(currentEnd);
		endif;
		
	endforeach;
	
	if self.myVoyage.allDelays.size &gt; 0 then
		lastDelay:= self.myVoyage.allDelays.last;
		lastDelayEnd:=lastDelay.getEndDT;
		if lastDelayEnd &lt;&gt; null and lastDelayEnd &gt; self.voyageEndTime then
			self.setVoyageEndTime(lastDelayEnd);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_allJobsStartEndTime" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllJobsStartEndTime" id="35443bcb-741e-4585-9a76-f3f4dc4683df">
        <source>getAllJobsStartEndTime(_objArray : ObjectArray io);
/*

Purpose:	does the opposite to method getAllJobDrawControllers 
			- gets a collection of CMIF_MyObjectDateRange objs
			for the current allCraneControllers.allObjects


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	drawJobControllers : SHP_CraneJobDrawingController;
	obj : Object;
	iter : Iterator;
	x1,y1,x2,y2 : Real;
	z 			: Integer;
	startTime,
	endTime : TimeStamp;
	cmifObjectDateRange : CMIF_MyObjectDateRange;
begin

	if _objArray = null then
		return;
	endif;

	foreach drawJobControllers in self.allJobDrawControllers do 
		iter:=drawJobControllers.allJobObjects.createIterator;
		while iter.next(obj) do
			drawJobControllers.allJobObjects.getIteratorKeys(x1, y1, x2, y2, z, iter);
			startTime:= self.myTimeLineDrawController.getTimeForX(x1);
			endTime:=self.myTimeLineDrawController.getTimeForX(x2);
			create cmifObjectDateRange transient;
			cmifObjectDateRange.setDetails(obj,startTime,endTime);
			_objArray.add(cmifObjectDateRange);	
		endwhile;
		delete iter;
	endforeach;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
