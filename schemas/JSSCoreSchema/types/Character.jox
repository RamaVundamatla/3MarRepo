  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssHexToInt" id="8b070e90-1411-4e11-9088-260018eabd88">
        <source>jssHexToInt():Integer;

vars

begin
    if self &gt;= "0" and self &lt;= "9" then
		return self.Integer - 48;
	endif;

   if self = "A" or self = "a" then
		return 10;
	endif;

   if self = "B" or self = "b" then
		return 11;
	endif;

   if self = "C" or self = "c" then
		return 12;	endif;

   if self = "D" or self = "d" then
		return 13;
	endif;

   if self = "E" or self = "e" then
		return 14;
	endif;

   if self = "F" or self = "f" then
		return 15;
	endif;

	// Not a valid hex digit, so ...
	return -1;

end;</source>
        <text>___________________________________________________________________________

