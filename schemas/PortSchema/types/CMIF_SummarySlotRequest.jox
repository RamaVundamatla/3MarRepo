        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="dlr40Tra" id="4366a7f7-2cb6-4004-96d8-0945a16003f4">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="gen20Imp" id="1b7e6ab8-82c2-4fd1-84a3-69a4a5754b0a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="gen40Imp" id="3b1940de-e941-44b9-b9f2-fd2bdb2fcc9b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
