    <JadeMethod name="doCargoEnquiry" id="f2392392-65fc-4043-908c-c4da23287f62">
        <source>doCargoEnquiry(_all : Boolean);
/*

Date		    Who			Reason
13 October 2010	cnwas3	  Initial creation

*/

vars	
	tiSet 		: ObjectArray;
	masterTI 	: CM_TrackedItem;
begin
	
	create tiSet transient;
	if _all then
		self.getAllCellsTIs(tiSet);
	else
		self.getSelectedCellsTIs(tiSet);
	endif;
	
	tiSet.removeInvalidObjects();
	tiSet.removeDuplicateObjects();
	
	if tiSet.isEmpty() then		
		app.msgBox(app.getErrorString(Select_some_cargo_enquire), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;
	
	masterTI := tiSet.first().CM_TrackedItem;	
	self.myAssistant.showCargoEnquiryForTIs(masterTI,tiSet,self.myMasterMenuAction,false);
epilog
	
	delete tiSet;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeTableColours" id="b2dce94d-3136-4692-97da-25034ac650a9">
        <updating/>
        <source>doChangeTableColours() updating;
/*

Date		    Who			Reason
09 November 2010	cnwas3	  Initial creation

*/

vars

begin
	self.xmlColourCargoType 	:= self.clrCargoType.backColor;
	self.xmlColourTotals 		:= self.clrTotals.backColor;
	self.xmlColourRowColour 	:= self.clrRowColour.backColor;
	self.xmlColourAltRow 		:= self.clrAltRowColour.backColor;
	
	self.doRefresh();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doInspectObject" id="e90a42dc-5432-45d2-9a01-7691234a7d95">
        <source>doInspectObject();
/*

Date		    Who			Reason
16 December 2010	cnwas3	  Initial creation
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	date 		: TimeStamp;
	cargoType 	: CM_CargoType;
	rowHeader 	: String;
	index		: Integer;
	kpi			: CM_KPICargoEntity;
begin
	if self.tblCargoCounter.row &lt;= 1 or
		self.tblCargoCounter.column &lt;= 1 then 
		return;
	endif;
		
	rowHeader := self.rowHeaders[self.tblCargoCounter.row - 1];
	
	if rowHeader.cnContains(app.getErrorString(Total)) then
		return;
	endif;
	index := 1;
	
	rowHeader := rowHeader.cnEcGetNextWord(index);
	if rowHeader = null and self.cargoTypes[1].id = 1 then
		cargoType := self.cargoTypes[1];	
	else
		foreach cargoType in self.cargoTypes do
			if cargoType.abbreviation.compareEql(rowHeader,true,false,null) then
				break;
			endif;
		endforeach;	
	endif;
	
	date := self.localToSystemTime(self.referenceTimeStamp.asTimeStamp).addDays(self.tblCargoCounter.column - 2);// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	kpi := self.myTerminal.allKPICargo.getAtKey(date,cargoType);
	if kpi &lt;&gt; null then
		kpi.inspectModal();
	endif;	
epilog

end;</source>
    </JadeMethod>
