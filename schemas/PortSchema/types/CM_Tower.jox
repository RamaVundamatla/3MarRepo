end;</source>
    </JadeMethod>
    <JadeMethod name="disconnectPortHole" id="88b427f7-177f-4e0a-b09c-c39a86dc108f">
        <updating/>
        <source>disconnectPortHole(params : CMIF_ConnectParams; _passport : CM_Passport input) updating;
//NFS 3814 AA 21/9/01: Handles the disconnection of a TI from the tower.
//Not the same as C++ in that we only generate the txn for the tower
//in this method, not txns for both items.
vars
	txnParams : CMIF_ConnectParams;
	txn : CM_TITransaction;
begin
	if params.myTrackedItem = prevPortHole then
		prevPortHole := null;
		if nextPortHole = null then		//Nothing else connected to this tower
			self.temperature := NULL_TEMPERATURE;
		endif;	
	elseif params.myTrackedItem = nextPortHole then
		nextPortHole := null;
		if prevPortHole = null then
			self.temperature := NULL_TEMPERATURE;
		endif;	
	else
		app.raiseCMException1(ERR_NOT_CONNECTED, "Internal: Tower believes " &amp; params.myTrackedItem.id, null, null); 
	endif;

	//Create a secondary transaction for ourself
	txnParams := params;
	txnParams.type := TRANS_TYPE_DISCONNECT_TOWER;
	txnParams.myOtherTrackedItem := params.myTrackedItem;
	txnParams.myTrackedItem := self;
	txn := self.createTransaction(txnParams, _passport);	
	txn.CM_DisconnectTower.secondary := true;
	
end;</source>
        <Parameter name="params" type="CMIF_ConnectParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
