    <JadeMethod name="handleBtnOne" id="9422e3d9-f6b1-45ed-852c-74949c18d7f0">
        <updating/>
        <source>handleBtnOne() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	if self.btnOne.caption = app.getErrorString(Edit) then
		self.setForEdit();
	elseif self.btnOne.caption =  app.getErrorString(Save) then
		if somethingChanged then
			if self.doSave() then
				somethingChanged := false;
				self.displayGrades();
			endif;
		endif;
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
