        <type name="CM_Bytes"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="d583c367-3044-4915-8132-8aa8f7685a22">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	#cnwdz2	 par21808

*/

vars

begin
	if self.photoBytes = null then
		if self.isTransient() then
			create self.photoBytes transient;
		else
			create self.photoBytes persistent;
		endif;		
	endif;
	   
	if self.thumbnailBytes = null then
		if self.isTransient() then
			create self.thumbnailBytes transient;
		else
			create self.thumbnailBytes persistent;
		endif;		
	endif;
	
	self.type := CM_Attachment.Type_Photo;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createThumbnailContent" id="c6fc8b7b-9b2d-463f-803d-ae5d4d907e2a">
        <source>createThumbnailContent(_originalImage : Binary):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2025	navsp1	Initial creation MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client

*/
constants
    ThumbWidth  = 120;  //Default
vars
    originalImage,
    thumbnailImage  : Binary;
    imageHelper     : CMIF_ImageProcessingHelper;
    terminal        : CM_Terminal;
    thumbWidth      : Integer;
    error           : StringUtf8;
begin   
    
    terminal    := app.myPassport.myTerminal;    
    if terminal &lt;&gt; null then
        thumbWidth  := terminal.getConfig(DefaultThumbnailWidth).Integer;
    endif;
    
    if thumbWidth = null then
        thumbWidth  := ThumbWidth;
    endif;    
    
    create imageHelper transient;
    if _originalImage &lt;&gt; null then
        thumbnailImage := imageHelper.getImageDataByDimension(_originalImage, thumbWidth , error);
        
        if error &lt;&gt; null then
            app.writeLog(method.qualifiedName &amp; Tab &amp; error.String, LogERROR);
        endif;
        
    endif;
    return thumbnailImage;
epilog
    delete imageHelper;
end;</source>
        <Parameter name="_originalImage" type="Binary"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d9ce8b7b-7da6-4b6d-af61-fd153aff039a">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	#cnwdz2	 par21808
09 Oct 2025 navhl20 Defect MTN-36235: Audits are not capturing date, time, and user for changes to photo.
*/

vars

begin
	delete self.photoBytes;
	delete self.thumbnailBytes;
	
	if not self.isTransient 
	and self.myParent &lt;&gt; null then
		self.updateObjectEdition(self.myParent);  // ### TFS CR 58499 TASK 61458 04JAN2024 NAVAB1
	endif;
	
	self.resetAuditsDuringDelete();					//09.10.2025 navhl20 #36235
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="extractToFile" id="bac2477a-692d-49e7-97c2-140bfef3331e">
        <source>extractToFile(_fileName:String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	#cnwdz2	 par21808

*/

vars
	file : File;
begin
	create file transient;
	file.fileName := _fileName;
	file.allowReplace := true;

	if file.tryOpen() then
		self.photoBytes.extractUsingFile(file);
		//self.photoBytes.extractToFile(_fileName,true);
	else
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
	endif;
	file.close();
	
epilog
	delete file;
end;</source>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getPhotoContent" id="8254bbc1-076b-41e3-b9b5-6fd2f9e01ada">
        <source>getPhotoContent():Binary;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	#cnwdz2	 par21808

*/

vars
    binData, photoContent : Binary;
begin
    binData := self.photoBytes.getContent();
    if binData &lt;&gt; null then
        photoContent := binData.uncompressToBinaryJMT();
    endif;
    return photoContent;
	//return self.photoBytes.getContent();
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getThumbnailContent" id="1b782db4-85b7-4ab7-b5ac-15b8c9274c6c">
        <source>getThumbnailContent():Binary;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	#cnwdz2	 par21808

*/

vars

begin
	return self.thumbnailBytes.getContent();
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="474e7108-58c8-4f2b-9edc-21b1ff02cd14">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date				Who		Reason
26 November 2009	#cnwdz2	par21808
0/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	proxyObj		: SelfType;
	pBytes,
	tBytes : CM_Bytes;
	completedOK		: Boolean;
begin

	proxyObj	:=	inheritMethod();
	create pBytes transient;
	pBytes.setContent(self.photoBytes.getContent());
	create tBytes transient;
	tBytes.setContent(self.thumbnailBytes.getContent());
	proxyObj.photoBytes		:=	pBytes;
	proxyObj.thumbnailBytes    :=  tBytes;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFileName" id="034376be-7610-461a-b248-2aed0e4d9ca3">
        <updating/>
        <source>setFileName(_filename : String) updating;
/*
Purpose:			

Date		Who		Reason
03 January 2024	navab1	CR 58499 TASK 61458
*/

vars

begin
	self.filename := _filename;
epilog

end;</source>
        <Parameter name="_filename" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3f894025-4ed5-4b04-8955-c00f74b8ea2e">
        <updating/>
        <source>setForUpdate(_proxyObj: SelfType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	#cnwdz2	 par21808
18 November 2025	navsp1	 MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
    photoContent : Binary;                                                      //MTN-36650
begin
	inheritMethod(_proxyObj);
    
    photoContent    := _proxyObj.getPhotoContent();                             //MTN-36650
	self.setPhotoContent(photoContent);
	//self.setThumbnailContent(_proxyObj.getThumbnailContent());                //MTN-36650
    self.setThumbnailContent(_proxyObj.createThumbnailContent(photoContent));   //MTN-36650
	self.filename := _proxyObj.filename;// ### TFS CR 58499 TASK 61458 03JAN2024 NAVAB1
epilog

end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setInvalidReference" id="a86afc10-c01c-40e5-9845-9b398620ae5e">
        <updating/>
        <source>setInvalidReference(_pName: String; _fixit: Boolean) updating;
// cnwrs1 14 Mar 2014
vars

begin
	if not _pName = CM_Photo::photoBytes.name and
	   not _pName = CM_Photo::thumbnailBytes.name then
		inheritMethod(_pName, _fixit);
	endif;
end;
</source>
        <Parameter name="_pName" type="String"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
