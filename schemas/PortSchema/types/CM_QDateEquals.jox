    <JadeMethod name="setSearchValue" id="dd0f6670-c74c-4f2e-a58e-0e6550bc4069">
        <updating/>
        <source>setSearchValue(_date : Any) updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 22/11/2019	jlgdap1		TFS 47456 SNO Web Portal Report Issue 2 - strip date/time from web portal down to just date
vars

begin
	self.searchValue := null;
	if _date &lt;&gt; null and (_date.isKindOf(Date) or _date.isKindOf(String)) then      // par 18123 
		if _date.isKindOf(String) and _date.String.length = 16 then		// TFS 47456
			self.searchValue := _date.String[1:10].Date;				// TFS 47456
		else															// TFS 47456
			self.searchValue := _date.Date;
		endif;															// TFS 47456
		if not self.searchValue.isValid() then
			app.raiseCMException1( ERR_INVALID_TIMESTAMP, null, null, self );
		endif;
	endif;

end;</source>
        <Parameter name="_date" type="Any"/>
    </JadeMethod>
