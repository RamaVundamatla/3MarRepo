    <JadeMethod name="getWLEForExportReplan" id="2f430d43-cb03-40df-8068-8a113fea47c1">
        <source>getWLEForExportReplan() : CM_WorkListEntry;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theWLE, theVWLE : CM_WorkListEntry;
begin
	// this is the target REQUEST/WLE
	theWLE := self.allWorkListEntries.last; // leave as last as in this case there could be more than one
	if theWLE.myTrackedItem &lt;&gt; null then
		// add another WLE to the slot request, once  cargo is planned to the ship, 
		// they can see the weight of the cargo on the screen,
		// at this point they may drag and drop cargo around within the 
		// job, so we need a 2nd WLE or 3rd, 4th etc.
		create theVWLE as CM_VoyageWLE;
		theVWLE.updateRequest(self);
		theVWLE.setJob(self.myJob);
		return theVWLE;
		
	endif;

	return theWLE;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWLEForMultiMove" id="eaddca8b-6c5c-4057-9018-7418d3682053">
        <source>getWLEForMultiMove() : CM_VoyageWLE;
// ---------------------------------------------------------------------------
// Created:		JULY By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theWLE : CM_WorkListEntry;
	theVWLE : CM_VoyageWLE;
begin
	// look through all my wles for empty TI, if find one use it
	foreach	theWLE in self.allWorkListEntries do
		theVWLE := theWLE.CM_VoyageWLE;
		if theVWLE.myTrackedItem = null then
			return theVWLE;
		endif;
	endforeach;
	
	// else get new one
	create theVWLE as CM_VoyageWLE;
	theVWLE.updateRequest(self);
	theVWLE.setJob(self.myJob);
	return theVWLE;
		
end;</source>
        <ReturnType type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="getWLEWorkSequence" id="fac543f6-e823-49d4-ba74-56aeb2288169">
        <source>getWLEWorkSequence() : Integer;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	retVal : Integer;
	wle : CM_WorkListEntry;
begin

	retVal := -1;

	if self.allWorkListEntries = null then
		return retVal;
	endif;
	wle := self.allWorkListEntries.first;
	if wle = null then
		return retVal;
	endif;
	return wle.CM_VoyageWLE.seqNumWorkOrder;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeight" id="0e1da06b-deb7-40b4-888b-e7c455a4e02b">
        <source>getWeight() : Integer;
/*

Purpose:			Return the weight of items associated with this slot

Parameters:			

Return Value:		


Date		Who		Reason
???
15 Dec 2008	cnwkpd1	PAR #18664 - clean up transient leaks for performance

*/

vars
	array : CM_TIArray;
	trackedItem : CM_TrackedItem;
	weight : Integer;

begin
	if self.isBulkRelease() then
		weight := (self.getBulkReleaseReserveDetail().getAverageWeight() / 1000).Integer;
	else
		create array transient;
		self.mySlotController.getAllPlannedTrackedItems(array, true, false);
		foreach trackedItem in array do			// PAR #18664 removed discreteLock - not required for transient coll
			weight := weight + (trackedItem.totalWeight / 1000).Integer;
		endforeach;
	endif;
	
	return weight;
	
epilog
	delete array;			// PAR #18664
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeightRangeFromWeight" id="ad778efe-aad6-4f3b-a692-b1c3feae0c8d">
        <source>getWeightRangeFromWeight(_weight:Integer):CM_WeightRange;
// --------------------------------------------------------------------------------
// Created:		30 July 2010 by cnwdad1
//
// Purpose:		Returns a reference to a CM_WeightRange object, using the receiver's
//				rounded weight as the key.
//
// Parameters:	_weight - An alternative weight value to use (only used if not zero).
//
// Returns:		A reference to a CM_WeightRange object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/07/2010	cnwdad1		PAR #24045.  Original implementation.
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// --------------------------------------------------------------------------------
vars
	roundedWeight	: Integer;
	measure			: CM_MeasurementType;									// PAR #31155
	
begin
	measure := app.getDefaultMeasurementForType(Type_Weight);				// PAR #31155
	if _weight = 0 then
		roundedWeight	:=	self.weight.rounded();
		
		//return app.myRoot.allWeightRanges.getAtKeyGeq(roundedWeight);		// PAR #31155
		return measure.allWeightRanges.getAtKeyGeq(measure, roundedWeight);	// PAR #31155
	else
		//return app.myRoot.allWeightRanges.getAtKeyGeq(_weight);			// PAR #31155
		return measure.allWeightRanges.getAtKeyGeq(measure, _weight);		// PAR #31155
	endif;
end;</source>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_WeightRange"/>
    </JadeMethod>
    <JadeMethod name="getWeightRounded" id="20b14a32-d390-48ee-939f-520c4d83cb40">
        <source>getWeightRounded():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2021	navma1	Bug 51149: SNO - Planning containers with mismatching weight

*/


vars
	array 		: CM_TIArray;
	trackedItem : CM_TrackedItem;
	weight 		: Decimal[14,4];

begin
	if self.isBulkRelease() then
		weight := ((self.getBulkReleaseReserveDetail().getAverageWeight() / 1000));
	else
		create array transient;
		self.mySlotController.getAllPlannedTrackedItems(array, true, false);
		foreach trackedItem in array do			
			weight := weight + (trackedItem.totalWeight / 1000);
		endforeach;
	endif;
	
	return weight.rounded();
	
epilog
	delete array;		
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="has30FootBackendSlotRequest" id="aff27608-ed11-4fe9-8894-f0b0dad2ad5d">
        <source>has30FootBackendSlotRequest(_isLoad : Boolean) : CM_SlotRequest;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		A slot controller has a collection of slot requests. This includes the slot request for the back end.
//					With slot requests for 30 footers the slot controller for the back end can also have an additional 30 foot front end is a seperate slot request.
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	otherSR : CM_SlotRequest;
	requests : CM_SlotRequestArray;
begin

	if not self.getAttrIs30() then
		return null;
	endif;
	
	if _isLoad then
		requests := self.mySlotController.allSlotRequestsLoad;
	else
		requests := self.mySlotController.allSlotRequestsDischarge;
	endif;
	foreach otherSR in requests discreteLock do
		if otherSR = self then
			continue;
		endif;
		
		if otherSR.getAttrIs30() and otherSR.isBackend &lt;&gt; self.isBackend then
			return otherSR;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="hasAnEmptyAttributeSet" id="4cd8accd-9255-481b-8da9-8f84dd30b555">
        <source>hasAnEmptyAttributeSet(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2015	cnwndl1	Initial creation	Par 36032

*/

vars

	criteria : CM_YACriteria;
	intValue : Integer;
	commGroup : CM_CommodityGroup;
	comm : CM_Commodity;

begin

	if self.useVoyageAllocations  then 
		criteria := self.getAttrByType(YACriteriaType_IsEmpty); // PAR 35325 
		if criteria &lt;&gt; null then
			intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
			if intValue = CM_YADataBoolean.VALUE_FALSE or intValue = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;						
		endif;

		criteria := self.getAttrByType(YACriteriaType_CommodityGroup); // PAR 23263 
		if criteria &lt;&gt; null then
			commGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;
			if commGroup &lt;&gt; null then
				return true;
			endif;
		endif;
			
		criteria := self.getAttrByType(YACriteriaType_Commodity);
		if criteria &lt;&gt; null then
			comm := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;	
			if comm &lt;&gt; null then
				return true;
			endif;
		endif;
		
		return false;
		
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasBackEndRequest" id="56d86f52-c155-49d2-b751-d428d9981e46">
        <source>hasBackEndRequest() : Boolean;

/*

Purpose:		Returns whether there is a back end or not by checking if forward slot request. (30, 40, 45, and 53)

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwmh5	Initial creation #20661

*/

vars
	backEndReqeust : Boolean;
begin

	// if we have a forward slot request must currently be on the backend
//	if self.mySlotRequestForward &lt;&gt; null then
	if self.mySlotRequestForward &lt;&gt; null and not self.mySlotRequestForward.getAttrIsBackend then	//06 Nov 2020	NDL	TFS 49917
		backEndReqeust := true;
	endif;
	
	return backEndReqeust;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasCCInSameJobAboveBelow" id="63299b84-15c8-4435-9b5d-269bd46200f0">
        <source>hasCCInSameJobAboveBelow(_above : Boolean) : CM_SlotRequest;
// ---------------------------------------------------------------------------
// Created:		24 July 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	overSlotObj			: CM_SlotRequest;
	controllerObj		: CM_SlotController;
	controllerOverObj	: CM_SlotController;
	
begin

	controllerObj	:=	self.mySlotController;
	
	if controllerObj = null then
		return null;
	endif;
	
	if _above then
		controllerOverObj	:=	controllerObj.myOverheadSlot;
	else
		controllerOverObj	:=	controllerObj.myUnderfootSlot;
	endif;
	
	if controllerOverObj = null then
		return null;
	endif;
	
	if self.isLoad then
		overSlotObj	:=	controllerOverObj.mySlotRequestLoad;
	else
		overSlotObj	:=	controllerOverObj.mySlotRequestDischarge;
	endif;
	
	if overSlotObj = null then
		return null;
	endif;
	
	if overSlotObj.myJob = self.myJob then
		return overSlotObj;
	endif;
	
	return null;

	
end;</source>
        <Parameter name="_above" type="Boolean"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="hasCCTL20InSameJobAboveBelow" id="2e140c3a-bd29-463e-8551-2a281e2dfaf9">
        <source>hasCCTL20InSameJobAboveBelow(_above : Boolean) : CM_SlotRequest;
/*
Purpose:		Is all the colour coding above me SL? If any TL then return NULL	if no TLs at all pass back the last SL
Date		Who		Reason
21 December 2015	cnwab1	Initial creation
*/

vars
	slotDefn, iterDefn : CM_SlotDefn;
	cellDefn : CM_CellDefn;
	iter : Iterator;
	iterReq, found : CM_SlotRequest;
	iterSlot : CM_SlotController;
	starboard, isLoad : Boolean;
	voyage : CM_Voyage;
begin

	voyage := self.getMyVoyageObject();
	starboard := false;
	if voyage &lt;&gt; null then
		starboard := voyage.starboardBerthed;
	endif;

	isLoad := self.isLoad;
	slotDefn := self.mySlotDefinition;
	
	if slotDefn = null then
		return null;
	endif;
	
	cellDefn := slotDefn.myCellDefinition;
	
	if cellDefn = null then
		return null;
	endif;
	
	iter := cellDefn.allSlotDefinitions.createIterator();
	iter.startAtObject(slotDefn);
	
	if _above then
		while iter.next(iterDefn) do
		
			iterSlot := iterDefn.CM_SlotDefnVoyage.mySlotController;
			if iterSlot= null then
				continue;
			endif;
			
			if isLoad then
				iterReq := iterSlot.mySlotRequestLoad;
			else	
				iterReq := iterSlot.mySlotRequestDischarge;
			endif;
			
			
			if iterReq = null then
				continue;
			endif;
			
			// TL or 40 
			if (iterReq.isTwinLift(starboard) or iterReq.is40) and iterReq.myJob = self.myJob then
				return null;
			endif;
			
			found := iterReq;
		endwhile;
	else
		while iter.back(iterDefn) do
		
			iterSlot := iterDefn.CM_SlotDefnVoyage.mySlotController;
			if iterSlot= null then
				continue;
			endif;
			
			if isLoad then
				iterReq := iterSlot.mySlotRequestLoad;
			else	
				iterReq := iterSlot.mySlotRequestDischarge;
			endif;
			
			
			if iterReq = null then
				continue;
			endif;
			
			// TL or 40 
			if (iterReq.isTwinLift(starboard) or iterReq.is40) and iterReq.myJob = self.myJob then
				return null;
			endif;
			found := iterReq;
		
		endwhile;
	
	endif;
	
	return found;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_above" type="Boolean"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="hasCCTL40InSameJobAboveBelow" id="2b1c5391-5568-4938-9613-d99b52e1cb5c">
        <source>hasCCTL40InSameJobAboveBelow(_above : Boolean) : CM_SlotRequest;
/*
Purpose:			
Date		Who		Reason
21 December 2015	cnwab1	Initial creation
*/

vars
	slotDefn, iterDefn : CM_SlotDefn;
	cellDefn : CM_CellDefn;
	iter : Iterator;
	iterReq : CM_SlotRequest;
	iterSlot : CM_SlotController;
	starboard, isLoad : Boolean;
	voyage : CM_Voyage;
begin

	voyage := self.getMyVoyageObject();
	starboard := false;
	if voyage &lt;&gt; null then
		starboard := voyage.starboardBerthed;
	endif;

	isLoad := self.isLoad;
	slotDefn := self.mySlotDefinition;
	
	if slotDefn = null then
		return null;
	endif;
	
	cellDefn := slotDefn.myCellDefinition;
	
	if cellDefn = null then
		return null;
	endif;
	
	iter := cellDefn.allSlotDefinitions.createIterator();
	iter.startAtObject(slotDefn);
	
	if _above then
		while iter.next(iterDefn) do
		
			iterSlot := iterDefn.CM_SlotDefnVoyage.mySlotController;
			if iterSlot= null then
				continue;
			endif;
			
			if isLoad then
				iterReq := iterSlot.mySlotRequestLoad;
				if iterReq = self then	//17 Jun 2019	NDL	TFS 45192
					continue;
				endif;
			else	
				iterReq := iterSlot.mySlotRequestDischarge;
				if iterReq = self then	//17 Jun 2019	NDL	TFS 45192
					continue;
				endif;
			endif;
			
			
			if iterReq = null then
				continue;
			endif;
			
			if (iterReq.isTwinLift(starboard) or iterReq.is40) and iterReq.myJob = self.myJob then
				return iterReq;
			//17 Jun 2019 NDL TFS 45192
			elseif iterReq.is40 and iterReq.getAttrIsBackend and iterReq.mySlotRequestForward &lt;&gt; null and iterReq.mySlotRequestForward.myJob = self.myJob then
				return iterReq.mySlotRequestForward;
			endif;
			
		endwhile;
	else
		while iter.back(iterDefn) do
		
			iterSlot := iterDefn.CM_SlotDefnVoyage.mySlotController;
			if iterSlot= null then
				continue;
			endif;
			
			if isLoad then
				iterReq := iterSlot.mySlotRequestLoad;
				if iterReq = self then	//17 Jun 2019	NDL	TFS 45192
					continue;
				endif;
			else	
				iterReq := iterSlot.mySlotRequestDischarge;
				if iterReq = self then	//17 Jun 2019	NDL	TFS 45192
					continue;
				endif;
			endif;
			
			
			if iterReq = null then
				continue;
			endif;
			if (iterReq.isTwinLift(starboard) or iterReq.is40) and iterReq.myJob = self.myJob then
				return iterReq;
			//17 Jun 2019 NDL TFS 45192
			elseif iterReq.is40 and iterReq.getAttrIsBackend and iterReq.mySlotRequestForward &lt;&gt; null and iterReq.mySlotRequestForward.myJob = self.myJob then
				return iterReq.mySlotRequestForward;
			endif;
		
		endwhile;
	
	endif;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_above" type="Boolean"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="hasJobLoadToOps" id="4e6547d9-5dda-48ed-81ad-283812e7320e">
        <source>hasJobLoadToOps(_workPoint: IF_VoyageWorkPoint): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2012	cnwer1	Initial creation CCMS MES 1026

*/

vars

	job: CM_VoyageJob;
	request : CM_Request;
begin

	if self.mySlotRequestForward &lt;&gt; null then
		request:=self.mySlotRequestForward;
	else
		request:=self;
	endif;

	
	if 	(request.isSOB) and request.myRequestLinkedDischarge &lt;&gt; null  then
		request:=request.myRequestLinkedDischarge;		
	endif;
	
	job	:= request.myJob.CM_VoyageJob;
	
	
	if job = null then
		return false;
	endif;
	if not job.isLoadedToOperations then
		return false;
	endif;
	if job.getMyWorkPointObject.IF_VoyageWorkPoint &lt;&gt; _workPoint then
		return false;
	endif;
	

	return true;

epilog

end;</source>
        <Parameter name="_workPoint" type="IF_VoyageWorkPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
