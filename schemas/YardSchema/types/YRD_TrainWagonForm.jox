    <JadeMethod name="getLocationId" id="5b5fae0e-e7af-4542-9eed-7f85ae46b773">
        <source>getLocationId(_wagon : CM_Wagon) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwmd1	Initial creation

*/

vars
	id, idStr : String;
begin
	if _wagon.confirmed then
		id := _wagon.getLocationId();
		if id &lt;&gt; null then
			idStr := "(" &amp; id &amp; ")";
		endif;
	else
		idStr := "(" &amp; app.getErrorString(Unconfirmed) &amp; ")";
	endif;
epilog
	return idStr;
end;</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTblDataXML" id="7b60302f-74bb-4752-8b23-545ade372aac">
        <updating/>
        <source>getTblDataXML(_userWindow: CM_UserWindow) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars
	tagStr,tmpTypeStr	: String;
begin
	tagStr := self.tblCargo.XMLTag_Table &amp; self.tblCargo.name;

	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETView_WagonIn2);
	self.tableDefIn := tmpTypeStr.trimCharacters(CrLf);
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETView_WagonOut2);
	self.tableDefOut := tmpTypeStr.trimCharacters(CrLf);
end;</source>
        <access>protected</access>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
