	if pTheException.currentMethodDesc = null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred.";
	else
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp;
					pTheException.currentMethodDesc.method.name &amp; " at position " &amp;
					pTheException.currentMethodDesc.position.String;
