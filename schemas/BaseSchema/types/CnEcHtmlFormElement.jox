    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="myForm" id="3b0492ad-6de8-46e5-9eb4-8881e0097e66">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
