    </PrimAttribute>
    <JadeMethod name="setAtEnd" id="d723a8e1-188d-4d87-9988-0234e23c8815">
        <updating/>
        <source>setAtEnd(_endTimestamp : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:      16 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.endTimestamp := _endTimestamp;
end;</source>
        <Parameter name="_endTimestamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setAtStart" id="0de69c87-8b6e-4959-8959-58c055134b32">
        <updating/>
        <source>setAtStart(_process : Process; _method : Method; _terminal : CM_Terminal; 
		_startTimestamp : TimeStamp; _info, _nodeName, _appName : String) updating;
// ---------------------------------------------------------------------------
// Created:      16 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.myProcess := _process;
	self.myMethod := _method;
	self.myTerminal := _terminal;
	self.startTimestamp := _startTimestamp;
	self.endTimestamp := null;
	self.info := _info;
	self.nodeName := _nodeName;
	self.appName := _appName;
end;</source>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_startTimestamp" type="TimeStamp"/>
        <Parameter name="_info" type="String"/>
        <Parameter name="_nodeName" type="String"/>
        <Parameter name="_appName" type="String"/>
    </JadeMethod>
</Class>
