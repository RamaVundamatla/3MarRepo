    <JadeMethod name="doResize" id="e50af6a3-399f-47ef-9f4b-95650adcf1d6">
        <updating/>
        <source>doResize() updating;
/*
Purpose:			

Date		Who		Reason
20 September 2021	navab1	TFS 51853
*/

vars

begin
	inheritMethod();

	self.grpFaultDetails.top := self.frmToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.grpResponse.top := self.grpFaultDetails.top + self.grpFaultDetails.height + 5; // ### TFS 50421 17SEP2021 NAVAB1
	self.height := self.grpResponse.top + self.grpResponse.height + 40; // ### TFS 50421 17SEP2021 NAVAB1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="502950f4-734a-4c5c-a7dd-e1bcaa34106c">
        <updating/>
        <source>doSave() : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx
01/07/2009	cnwrl1	PAR 19938 - Handle deleted objects during updating.
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	faultType : CM_FaultType;
	faultStatus : CM_FaultStatus;
	reportedUser : CM_User;
	enterUser : CM_User;
	machine : CM_Machine;
	additionalDetails,
	resolutionDetails : String;
	reportedTS : TimeStamp;
	faultResponse : CM_FaultResponse;
	rtnValue  : Boolean;
	result : Integer;
	invalidObject	: Boolean;
	object			: Object;
	localReported: TimeStamp;
	
begin
	if self.myProxyFault = null then	
		create self.myProxyFault  transient;
	endif;
	if self.cmbFaultType.listIndex &gt; 0 then
		faultType:=self.cmbFaultType.itemObject[self.cmbFaultType.listIndex].CM_FaultType;
	endif;
	
	if self.cmbFaultStatus.listIndex &gt; 0 then
		faultStatus := self.cmbFaultStatus.itemObject[self.cmbFaultStatus.listIndex].CM_FaultStatus;
	endif;
	
	if self.cmbEnteredBy.listIndex &gt; 0 then
		enterUser:=self.cmbEnteredBy.itemObject[self.cmbEnteredBy.listIndex].CM_User;
	endif;
		
	if self.cmbReportedBy.listIndex &gt; 0 then
		reportedUser:=self.cmbReportedBy.itemObject[self.cmbReportedBy.listIndex].CM_User;
	endif;	
	
	if self.cmbMachine.listIndex &gt; 0 then
		machine := self.cmbMachine.itemObject[self.cmbMachine.listIndex].CM_Machine;
	endif;
	
	additionalDetails:= self.txtAdditional.text;
	resolutionDetails:=self.txtResolution.text;
	
	localReported.setDate(self.txtReportedDate.getDate);	// cnwmp6 TFS 488 - Multi timezone changes 13/4/16
	localReported.setTime(self.txtReportedTime.getTime);
	reportedTS := self.localToSystemTime(localReported);
	
	if self.myFault &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myFault, invalidObject );		// cnwrl1 02/07/2007 PAR 19938

		faultResponse:=self.myFault.myFaultResponse;
		// cnwrl1 02/07/2009 PAR 19938 - start of coding
		if invalidObject then
			app.msgBox(	app.getErrorString1( ObjectDeletedByOtherUser, app.getErrorString( Fault ) ),
						app.getString( Warning ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			return false;
		endif;
		// cnwrl1 02/07/2009 PAR 19938 - end of coding
	endif;
	
	self.myProxyFault.setProxy(reportedTS, reportedUser, enterUser, machine, faultType, faultStatus, additionalDetails, resolutionDetails, faultResponse);

	while true do
		if self.myFault = null then	
			app.myTrxCA.trxCreateFault(self.myProxyFault,self.myTerminal, self.myFault, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
			
		else
			app.myTrxUA.trxUpdateFault(self.myProxyFault, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
		endif;
			
		if (not rtnValue) then
			result := app.showErrorWarningDialog('Faults', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			//we had a cancelled update - refresh data
			if self.myFault &lt;&gt; null then
				
				self.myProxyFault := app.createUpdateProxy(self.myFault).CM_Fault;
			endif;
			return false;
		else
			self.clearErrorWarnings();
		endif;
		break;
	endwhile;
	
	return rtnValue;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="5b83f93f-12f8-4ede-9190-166728fae9dd">
        <updating/>
        <source>init(_terminal : CM_Terminal; _fault : CM_Fault) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.myTerminal:=_terminal;
	self.myFault:=_fault;
	if self.myFault &lt;&gt; null then
		self.myProxyFault := app.createUpdateProxy(self.myFault).CM_Fault;
	else
		if self.myProxyFault &lt;&gt; null then
			delete self.myProxyFault;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_fault" type="CM_Fault"/>
    </JadeMethod>
