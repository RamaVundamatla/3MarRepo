// Purpose:		This transaction will set the status of a Locations Controller to
//				either "Closed" or "Open", and will also delete the Yard Allocations
//				specified in the set parameter.
//
// Parameters:	_status - A status of either "Closed" or "Open".
//				_controllerObj - A reference to the Locations Controller to update.
//				_edition - The expected edition of the Locations Controller object.
//				_allAllocationObj - A of Yard Allocations to be deleted.
//				_passport - A reference to the current User's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	beginTransaction;
	
	app.myUtilityUA.utlSetControllerStatusWithYA(_status, _controllerObj, _edition, _allAllocationsObj, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
