    <JadeMethod name="valTLessonCreate" id="e8b1a697-2c42-4494-8931-99027e3fb85e">
        <updating/>
        <source>valTLessonCreate(	pName				: String; 	
					pFormName			: String; 
					pNextLessonName 	: String;
					pText 				: String;
					pCheckControlEnabled: Boolean;
					pCheckControlValue 	: Boolean;
					pCheckControlVisible: Boolean;
					pControlHasAValue 	: Boolean;
					pControlIsEnabled 	: Boolean;
					pControlIsVisible 	: Boolean;
					pControlName 		: String;
					pLogDirectory 		: String ):String updating;

// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Validation for creating a Lesson.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	lesson		: CnEcTLesson;
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	trimmedName	:=	pName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The Lesson Name cannot be null.");
	elseif trimmedName.length &gt; 40 then
		return self.agentSetError("Update Lesson: name too long '" &amp; trimmedName &amp; "'") ;
	endif;

	trimmedName	:=	pFormName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The Form Name cannot be null.");
	endif;

	lesson := app.myBaseRoot.allTLessons.getAtKey(pFormName,pName);
	if lesson &lt;&gt; null then
		return self.agentSetError("A Lesson already exists for form " &amp; pFormName &amp; " and lesson name " &amp; pName &amp; ".");
	endif;

	if pControlName.length = 0 then
		if pCheckControlVisible or pCheckControlEnabled or pCheckControlValue then
			return self.agentSetError("Update Lesson: form set checking is enabled, but no control is specified");
		endif;
	else
		if not ( pCheckControlVisible or pCheckControlEnabled or pCheckControlValue ) then
			return self.agentSetError("Update Lesson: no form set up checking is specified for " &amp; pControlName);
		endif;
	endif;

	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pNextLessonName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pCheckControlEnabled" type="Boolean"/>
        <Parameter name="pCheckControlValue" type="Boolean"/>
