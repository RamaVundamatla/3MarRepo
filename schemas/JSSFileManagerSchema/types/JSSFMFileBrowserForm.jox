    </JadeMethod>
    <JadeMethod name="doFetchDiskDrives" id="cc3b4d76-dc7f-4fa3-a365-999959d5eb62">
        <updating/>
        <source>doFetchDiskDrives(	pTheContainer:JSSFMFolder io;
					pIsDbServer:Boolean;
					pIsAppServer:Boolean;
					pIsUnix:Boolean;
					pAllDriveNames:StringArray):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad2
//
// Purpose:		Finds all of the available disk drives attached to the machine on
//				which the JADE node is running.  Note: Do not invoke this method
//				directly - there are two wrapper methods for client and server
//				execution which should be called instead.
//
// Parameters:	pTheContainer - The container object for the disk drive names.
//				pIsDbServer - A flag to indicate whether the node is the database
//					Server node.
//				pIsAppServer - A flag to indicate whether the node is the Application
//					Server node.
//				pIsUnix - True if the disk's OS platform is Unix.
//				pAllDriveNames - An array of restricted disk drive names.  If this
//					array is empty, then access will be allowed to all disk drives,
//					otherwise only the drive names in the array will be accessible.
//
// Returns:		True of if any disk drives were found, otherwise false.  Also
//				returns the pTheContainer IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/08/2002	cnwdad1		Added the pIsUnix parameter.  Unix has mounted drives
//							that can be mounted anywhere in a "directory" tree, but
//							it always starts with a single root path.
// --------------------------------------------------------------------------------
constants
	LOWER_DRIVE		: Character = "C";
	UPPER_DRIVE		: Character = "Z";
	
vars
	diskFolderObj	: FileFolder;
	driveCharacter	: Integer;
	driveLetter		: String;
	nodeType		: Integer;
	isRestricted	: Boolean;
	isNotEmpty		: Boolean;
	
begin
	if pIsDbServer then
		nodeType		:=	self.LISTBOX_NODE_DB_SERVER_FOLDER;
	elseif pIsAppServer then
		nodeType		:=	self.LISTBOX_NODE_APP_SERVER_FOLDER;
	else
		nodeType		:=	self.LISTBOX_NODE_LOCAL_FOLDER;
	endif;
	
	isRestricted	:=	(not pAllDriveNames.isEmpty());
	isNotEmpty		:=	false;
	
	if pIsUnix then
		pTheContainer.addFolder(JSS_SEPARATOR_UNIX, JSS_SEPARATOR_UNIX, nodeType, pIsUnix);
		isNotEmpty	:=	true;
	else
		create diskFolderObj transient;
		diskFolderObj.usePresentationFileSystem	:=	(not pIsAppServer);
		
		foreach driveCharacter in LOWER_DRIVE.Integer to UPPER_DRIVE.Integer do
			driveLetter		:=	driveCharacter.Character;
			
			if isRestricted and (not pAllDriveNames.includes(driveLetter)) then
				continue;
			endif;
			
			diskFolderObj.fileName	:=	driveLetter &amp; ":";
			
			if diskFolderObj.isAvailable() then
				pTheContainer.addFolder(diskFolderObj.name, (driveLetter &amp; ":"), nodeType, pIsUnix);
				
				if (not isNotEmpty) then
					isNotEmpty	:=	true;
				endif;
			endif;
		endforeach;
	endif;
	
	return isNotEmpty;
epilog
	delete diskFolderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pTheContainer" type="JSSFMFolder" usage="io"/>
        <Parameter name="pIsDbServer" type="Boolean"/>
        <Parameter name="pIsAppServer" type="Boolean"/>
        <Parameter name="pIsUnix" type="Boolean"/>
        <Parameter name="pAllDriveNames" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFetchDiskDrivesClient" id="274a80a8-a8ce-4a3b-8019-ba40782c0f73">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doFetchDiskDrivesClient(pTheContainer:JSSFMFolder io; pIsAppServer:Boolean):Boolean updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad2
//
// Purpose:		This method is a wrapper for the doFetchNodeDiskDrives method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DB_SERVER	: Boolean = false;
	
vars
	allDriveNames	: StringArray;
	isUnix			: Boolean;
	
begin
	create allDriveNames transient;
	
	if pIsAppServer then
		self.aAllDriveNamesAppServer.copy(allDriveNames);
		isUnix	:=	self.aIsUnixAppServer;
	else
		isUnix	:=	false;
	endif;
	
	return self.doFetchDiskDrives(	pTheContainer,
									IS_DB_SERVER,
									pIsAppServer,
									isUnix,
									allDriveNames);
epilog
	delete allDriveNames;
end;</source>
        <access>protected</access>
        <Parameter name="pTheContainer" type="JSSFMFolder" usage="io"/>
        <Parameter name="pIsAppServer" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFetchDiskDrivesServer" id="3a9ff636-b56d-4a63-b080-72899cec58e2">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doFetchDiskDrivesServer(pTheContainer:JSSFMFolder io):Boolean updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		This method is a wrapper for the doFetchNodeDiskDrives method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DB_SERVER	: Boolean = true;
	IS_APP_SERVER	: Boolean = false;
	
begin
	return self.doFetchDiskDrives(	pTheContainer,
									IS_DB_SERVER,
									IS_APP_SERVER,
									self.aIsUnixDbServer,
									self.aAllDriveNamesDbServer);
end;</source>
