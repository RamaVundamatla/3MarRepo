    <DbClassMap file="_usergui"/>
    <JadeMethod name="cnEcPopulate" id="8658d660-aedf-48be-94b4-dfda9fb234ef">
        <updating/>
        <source>cnEcPopulate() updating;
// --------------------------------------------------------------------------------
// Created:		17 April 2006 by cnwdad1
//
// Purpose:		Populates the receiver with the system info details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05 Apr 2016	cnwkpd1		Issue in JADE 7.1 (PAR #63664) means calls to some external functions
//							crash the JADE executable (or RAP in a server execution).
//							Removed calls to the offending methods as a temporary 
//							workaround
// --------------------------------------------------------------------------------
vars
	licenceName		: String;
	licenceKey		: String;
	licenceCount	: Integer;
	developCount	: Integer;
	freeMemory		: Integer;
	freeDisk		: Decimal[23];
	driveName		: String;
	totalMemory		: Integer;
	localeObj		: Locale;
	skinObj			: JadeSkin;
	displayValue	: String;
	appType			: Character;
	
begin
	appType		:=	app.applicationType;
	self.rows	:=	0;
	system.getLicenceInfo(licenceName, licenceKey, licenceCount, developCount);
	self.addItem("Process" &amp; Tab &amp; process.cnEcGetDisplay());
	self.addItem("App. Name" &amp; Tab &amp; app.name);
	self.addItem("App. Version" &amp; Tab &amp; app.appVersion);
	
	if appType = app.ApplicationType_GUI then
		displayValue	:=	"GUI";
	elseif appType = app.ApplicationType_GUI_No_Forms then
		displayValue	:=	"GUI - No forms";
	elseif appType = app.ApplicationType_Non_GUI then
		displayValue	:=	"Non-GUI";
	elseif appType = app.ApplicationType_Non_GUI_Web then
		displayValue	:=	"Non-GUI Web";
	elseif appType = app.ApplicationType_Web_Enabled then
		displayValue	:=	"Web-enabled";
	else
		displayValue	:=	"Unknown";
	endif;
	
	self.addItem("App. Type" &amp; Tab &amp; displayValue);
	
	skinObj	:=	app.getSkin();
	
	if skinObj = null then
		displayValue	:=	"N/A";
	else
		displayValue	:=	skinObj.name;
	endif;
	
	self.addItem("Skin" &amp; Tab &amp; displayValue);
	self.addItem("Licence Name" &amp; Tab &amp; licenceName);
	self.addItem("Licenced Users" &amp; Tab &amp; licenceCount.cnEcNumberFormat());
	self.addItem("Jade Version" &amp; Tab &amp; app.getSystemVersion());
	self.addItem("CardSchema Version" &amp; Tab &amp; CnCntrl.CardSchema_Version);
	self.addItem("BaseSchema Version" &amp; Tab &amp; CNEC_BASESCHEMA_VERSION);
	self.addItem("Jade Client Binaries" &amp; Tab &amp; app.getJadeInstallDir());
	self.addItem("App Server Binaries" &amp; Tab &amp; app.getJadeInstallDirAppServer());
	self.addItem("Jade Binaries" &amp; Tab &amp; global.cnGetServerInstallDir());
	self.addItem("Jade Database" &amp; Tab &amp; app.dbPath());
	self.addItem("Jade Client ini" &amp; Tab &amp; app.getIniFileName());
	self.addItem("Jade App Server ini" &amp; Tab &amp; app.getIniFileNameAppServer());
	self.addItem("Jade ini" &amp; Tab &amp; global.cnEcGetServerIniFileName());
	self.addItem("User name" &amp; Tab &amp; app.userName());
	self.addItem("Machine Name" &amp; Tab &amp; app.computerName());
	self.addItem("App. Server" &amp; Tab &amp; app.computerNameAppServer());
	self.addItem("Jade Server" &amp; Tab &amp; app.dbServerComputerName());
	
	localeObj	:=	app.defaultLocale();
	
	if localeObj = null then
		displayValue	:=	"N/A";
	else
		displayValue	:=	localeObj.name;
	endif;
	
	self.addItem("Default Locale" &amp; Tab &amp; displayValue);
	
	localeObj	:=	app.currentLocale;
	
	if localeObj = null then
		displayValue	:=	"N/A";
	else
		displayValue	:=	localeObj.name;
	endif;
	
	self.addItem("Current Locale" &amp; Tab &amp; displayValue);
	self.addItem("Is Multi-user GUI" &amp; Tab &amp; app.isMultiUser().cnEcGetYesNo());
	self.addItem("Is Portable GUI" &amp; Tab &amp; app.isPortableGui().cnEcGetYesNo());
	self.addItem("Is Production" &amp; Tab &amp; app.productionMode().cnEcGetYesNo());
	self.addItem("Is Unicode GUI" &amp; Tab &amp; app.isUnicode().cnEcGetYesNo());

	/*	KPD - removed to stop RAP crashes	
	
	node.cnEcGetMemory(totalMemory, freeMemory);
	system.cnEcGetDiskAndMemory(freeMemory, freeDisk, driveName);
	self.addItem("Client CPU Info" &amp; Tab &amp; system.cnEcGetCPUInfo() &amp; " MHz");
	self.addItem("Client Total Memory" &amp; Tab &amp; totalMemory.cnEcNumberFormat());
	self.addItem("Client Free Memory" &amp; Tab &amp; freeMemory.cnEcNumberFormat());
	self.addItem("Client Free Disk" &amp; Tab &amp; freeDisk.cnEcNumberFormat() &amp; " (" &amp; driveName.toUpper() &amp; ":)");
	
	node.cnEcGetServerMemory(totalMemory, freeMemory);
	system.cnEcGetDiskAndMemoryServer(freeMemory, freeDisk, driveName);
	self.addItem("Server CPU Info" &amp; Tab &amp; system.cnEcGetServerCPUInfo() &amp; " MHz");
	self.addItem("Server Total Memory" &amp; Tab &amp; totalMemory.cnEcNumberFormat());
	self.addItem("Server Free Memory" &amp; Tab &amp; freeMemory.cnEcNumberFormat());
	self.addItem("Server Free Disk" &amp; Tab &amp; freeDisk.cnEcNumberFormat() &amp; " (" &amp; driveName.toUpper() &amp; ":)");
	*/
	
	self.cnEcAlternateRowColors(White, Gray);
	self.userInputEnabled	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="6f34b626-21c7-458b-b950-49305b309292">
        <controlMethod name="CnEcTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		17 April 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.rows			:=	0;
	self.fixedRows		:=	0;
	self.fixedColumns	:=	1;
	self.fixed3D		:=	false;
	self.scrollBars		:=	Table.ScrollBars_Both;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
