    <JadeMethod name="getExtraInfoForEntDef" id="aa109aad-f4a0-499f-b040-75d86fc6df96">
        <source>getExtraInfoForEntDef(_dataContainer : CM_DataContainer input;_entDef : EntTableDef input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	entTableRow : EntTableRow;
	value  : String;
	heading : String;
	block : CM_DataContainerBlock;
begin

	foreach entTableRow in _entDef.allEntTableRows discreteLock where entTableRow.visible  do
		heading:=entTableRow.getHeading(null,null,app.myCurrentLocale);
		value:=self.getDisplayStringForAttribute(entTableRow.name,true);
		if value = null or value = "0" or
			value = "0.00" then
			continue;
		endif;
		block := _dataContainer.addNewBlock;
		block.addNewItem(heading, DC_Label, 1, self);
		block.addNewItem(value, DC_Data, 1, self);
	
	endforeach;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="input"/>
        <Parameter name="_entDef" type="EntTableDef" usage="input"/>
    </JadeMethod>
