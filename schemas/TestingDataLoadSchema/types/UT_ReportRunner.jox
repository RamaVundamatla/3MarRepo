<Class name="UT_ReportRunner" id="2bba195c-d56c-4172-b00c-b7aa6c74c212">
    <superclass name="CM_Transient"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Utility class to get the data for a given report.</text>
    <DbClassMap file="unitTest"/>
    <ImplicitInverseRef name="allQueryReportParams" id="97f05da5-63f7-4160-a3bb-ab5a28834636">
        <memberTypeInverse/>
        <type name="CM_QueryParamsByNameDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myQryReport" id="0289a65b-ceb4-4d86-b06f-11ebe5d5738e">
        <embedded/>
        <type name="CM_QryReport"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getData" id="b3aad7d7-7a24-4d90-aa08-59c14fe2cf20">
        <source>getData(_terminal : CM_Terminal; _opts : CM_AssociationDict);

vars
	
	filterObject	: CMQF_FilterReports;

begin
	if self.myQryReport &lt;&gt; null then
		filterObject := self.myQryReport.createFilter();
	endif;
	if filterObject &lt;&gt; null then
		filterObject.initialize();
		filterObject.allQueryReportParams.clear();

		self.allQueryReportParams.copy(filterObject.allQueryReportParams);
		if self.myQryReport.mySelectorQuery &lt;&gt; null then
			filterObject.selectorMode := self.myQryReport.mySelectorQuery.queryMode;
		else
			filterObject.setFromOpts(_terminal, _opts);
		endif;
		
		self.myQryReport.doFilter(filterObject, app.myPassport);
		
	endif;

end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
    </JadeMethod>
    <JadeMethod name="setReport" id="ee45f67f-929f-4f8b-865a-4c8992226eaf">
        <updating/>
        <source>setReport(_reportName : String) : Boolean updating;
// input parameter is report description
vars
	userTerminal	: CM_UserTerminal;
	menuEnt		: CM_MenuEntity;
	menuDtl		: CM_MenuUserDtl;
	qryReport	: CM_QryReport;
	result	: Boolean;
begin
	userTerminal := app.myPassport.myUser.allUserTerminals.first;
	foreach menuEnt in userTerminal.myReportMenuRoot.allMenuUserItemsWithAMenuItem do
		qryReport := null;
		
		if menuEnt.isKindOf(CM_MenuUserDtl) then
			menuDtl := menuEnt.CM_MenuUserDtl;
			if menuDtl.myMenuItem.isKindOf(CM_QryReport) then
				qryReport := menuDtl.myMenuItem.CM_QryReport;
				if qryReport.heading = _reportName then
					self.myQryReport := qryReport;
					result := true;
					break;
				endif;
			endif;
		endif;
	endforeach;
	return result;
end;</source>
        <Parameter name="_reportName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
