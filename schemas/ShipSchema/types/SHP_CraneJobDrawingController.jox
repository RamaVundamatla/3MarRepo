    <JadeMethod name="addJobAt" id="ad8647dd-9b9c-4b0e-8233-ca2ed4687d2d">
        <updating/>
        <source>addJobAt(_obj : Object;x1,y1,x2,y2 : Real;z : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.allJobObjects.getAtKey(x1,y1,x2,y2,z) = null then
		self.allJobObjects.putAtKey(x1,y1,x2,y2,z,_obj);
		self.setZforJobsAtXY(_obj,x1,y1,x2,y2);
		self.allJobsInOrderAdded.add(_obj);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="z" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addRemoveJobObjects" id="858a8a9c-f542-43b0-9e05-0e5821122ad8">
        <updating/>
        <source>addRemoveJobObjects(	_removeDict,
						_addDict,
						selectedDict : CMUI_ObjectByRealX1Y1X2Y2Dict   input
						 ) updating;
/*

Purpose:	synchronising self.allJobObjects with those objects that need to be removed (in _removeDict) and those that need to be added (in _addDict);
			
			also at this point if the a job has neved been moved they are real objects in the dict hence allowing users to edit them elsewhere
			- this method will also create proxy job objects &amp; change the crane if needed 
			- as a consequence of this users will no longer be able to edit the jobs that have been moved

Return Value:		


Date			Who		Reason
25 January 2007	cnwer1	Initial creation - PAR#xxxx
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/
vars
	iter : Iterator;
	obj : Object;
	x1, y1, x2, y2,
	rX1,rY1,rX2,rY2: Real;
	z,rZ : Integer;
	voyageJob,
	pxyJob: CM_VoyageJob;
	selectedObjects : ObjectSet;
begin
	create selectedObjects transient;
	iter:=_removeDict.createIterator;
	while iter.next(obj) do
		_removeDict.getIteratorKeys(x1, y1, x2, y2,z, iter);
		self.removeJobAt(obj,x1, y1, x2, y2,z );
	endwhile;
	delete iter;
	
	//put them back at new points these objects from self
	iter:=_addDict.createIterator;
	while iter.next(obj) do
		_addDict.getIteratorKeys(x1, y1, x2, y2,z, iter);
		voyageJob:=obj.CM_VoyageJob;
		if not voyageJob.isTransient then
			beginLoad;
				pxyJob:=voyageJob.pxyCreateUpdateProxy;
			endLoad;
		else
			pxyJob:=voyageJob;
		endif;
	
		pxyJob.setProxyVoyageJob(crane.id,
											pxyJob.jobNum,
											pxyJob.remarks,
											pxyJob.systemRemarks,
											pxyJob.isTwinLift,
											pxyJob.jobType,
											pxyJob.myUserJobType,
											pxyJob.estimatedTimeToCompleteMins,
											pxyJob.actualStartTs,
											pxyJob.actualEndTs,
											pxyJob.allowOutOfOrderLoading);//cnwrd1 par 30626 ccms 2209 23.10.12
		
		self.addJobAt(pxyJob,x1, y1, x2, y2,z);
		if selectedDict &lt;&gt; null then
			if selectedDict.findObjectInDictGetXY(obj,rX1,rY1,rX2,rY2,rZ) then
				selectedDict.removeKeyEntry(rX1,rY1,rX2,rY2,rZ,obj);
				if selectedDict.getAtKey(x1,y1,x2,y2,rZ) = null then
					selectedDict.putAtKey(x1,y1,x2,y2,rZ,pxyJob);
				endif;
			endif;
		endif;
	endwhile;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	hasChanged:=true;
	delete selectedObjects;
	delete iter;
end;</source>
        <Parameter name="_removeDict" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_addDict" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="selectedDict" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ca8ec265-882b-41a8-a7a9-01562811ad07">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	oa : ObjectArray;
	obj : Object;
begin

	if self.dontCleanUpTransients then
		return;
	endif;
	create oa transient;
	//self.allJobObjects.purge;
	foreach obj in self.allJobObjects do
	//epr 13931 3/5/07
		if not global.isValidObject(obj) then
			continue;
		endif;
		if obj.isTransient then
			//app.myProxyManager.deleteProxyLink(obj.CM_Object);
			oa.add(obj);
		endif;
	endforeach;
	
	oa.purge;
	self.allJobsInOrderAdded.clear;
epilog
	if oa &lt;&gt; null then
		delete oa;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawAllDelays" id="abe2c3a8-addc-464e-9f0b-a50aabfdec31">
        <source>drawAllDelays();
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter : Iterator;
	drawFillStyle : Integer;
	colour,z : Integer;
	obj : Object;
	x1, y1, x2, y2,
	delayY1,delayY2 : Real;
	delayString : String;
	delay : CM_Delay;
begin
	iter:=self.allDelayObjects.createIterator;
	drawFillStyle:=Window.DrawFillStyle_Cross;
	colour:=self.drawingFrame.backColor;
	self.drawingFrame.drawTextAlign:=Window.DrawTextAlign_Center;
	//self.drawingFrame.drawStyle:=Window.DrawStyle_Dash;//Transparent;
	while iter.next(obj) do
		self.allDelayObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
		self.getYRangeAtXRange(x1,x2,delayY1,delayY2);
		//self.drawJobRectangle(x1,delayY1,x2,delayY2,drawFillStyle,colour, false,false,false);
		self.drawingFrame.drawFillColor:=White;
		self.drawingFrame.drawFilledRectangle(x1,delayY1,x2,delayY2,Black);
		delay:=obj.CM_Delay;
		delayString:="Delay";
		if delay.myDelayType &lt;&gt; null then
			delayString :=delay.myDelayType.description;
		endif;
		self.drawingFrame.drawTextIn(delayString,x1,delayY1,x2,delayY2,Black);
	endwhile;
	
	

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawAllJobs" id="08eb96ef-75c3-4b2d-95d2-525509498d04">
        <source>drawAllJobs(	_selected : Boolean; 
				_currentTimeX : Real;
				_zOrder : Integer);
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter : Iterator;
	obj: Object;
	x1, y1, x2, y2,z: Real; 
	cranePastColour,
	craneMoveColour,
	craneColour,
	colour: Integer;
	oldFontName : String;
begin

	oldFontName:=self.getOriginalFontName;
	
	craneColour:=self.crane.colour;
	colour:=craneColour;
	cranePastColour:=self.getCranePastColour;
	craneMoveColour:=self.getCraneMovedColour;
	self.drawingFrame.drawTextAlign:=Window.DrawTextAlign_Left;
	iter:=self.allJobObjects.createIterator();
	while iter.next(obj) do
		
		self.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
		if z &lt;&gt; _zOrder then
			continue;
		endif;
		
		self.drawJob(_selected,_currentTimeX,obj,x1, y1, x2, y2,oldFontName,cranePastColour,craneMoveColour);
		
	endwhile;



epilog
	self.drawingFrame.drawFontName:=oldFontName;
	delete iter;
end;</source>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_currentTimeX" type="Real"/>
        <Parameter name="_zOrder" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawJob" id="6c47d7a6-cacc-4b53-b594-709db86387eb">
        <source>drawJob(_selected : Boolean; 
		_currentTimeX : Real;
		_obj : Object input;
		_x1, _y1, _x2, _y2 : Real input;
		_originalFont : String;
		_cranePastColour,
		_craneMoveColour : Integer);
/*

Purpose:			


Return Value:		


Date		Who		Reason
03 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
constants
	TwinChar  = "T";
	NewFontName = "Wingdings";
	DisInt =#[E9].Integer;
	LoadInt =#[EA].Integer;
	Rehandle =#[6C].Integer;
	OverHeight =#[F4].Integer;
vars
	typeHeight, typeWidth , jobWidth,xOffset: Real; 
	drawFillStyle ,
	craneColour,
	cranePastColour,
	craneMoveColour,
	colour: Integer;
	isDischarge,
	isLoad,
	isRehandle,
	isOverHeight,
	hasMoved,
	hasReefers: Boolean;
	cmifObj : CMIF_JobTITotals;
	voyageJob : CM_VoyageJob;
	num20s,
	num40s,yOffset : Integer;
	type : String;
	infoString1,
	infoString2: String;
	infoColour : Integer;
	userJobColour : Integer;
	jobStats : CMIF_JobStats;
	reeferDrawAttr	: CM_DrawingAttribute;
	reeferChar : Integer;
begin
	craneColour:=self.crane.colour;
	cranePastColour:=_cranePastColour;
	craneMoveColour:=_craneMoveColour;
	reeferDrawAttr := app.myRoot.allDrawingAttributes[PicTIConnected];
	
	if not _obj.isKindOf(CM_VoyageHatchLidJob) then
		isDischarge:= _obj.CM_VoyageJob.isDischarge;
		isLoad:=not isDischarge;
	
	endif;
	if cmifObj &lt;&gt; null then
		delete cmifObj;
	endif;
	create cmifObj transient;
	if _obj.isTransient then
		drawFillStyle :=Window.DrawFillStyle_Solid;//Window.DrawFillStyle_DownDiagonal;//DiagonalCross;
		hasMoved:=true;
		voyageJob:=app.myProxyManager.getRealObject(_obj.CM_Object).CM_VoyageJob;
	else
		drawFillStyle := Window.DrawFillStyle_Solid;
		voyageJob:=_obj.CM_VoyageJob;
	endif;
	
	//if its a hatch lid job and it has a colour specified then user that colour
	if voyageJob.isKindOf(CM_VoyageHatchLidJob) then
		if voyageJob.CM_VoyageHatchLidJob.myUserJobType &lt;&gt; null then			
			userJobColour:= voyageJob.CM_VoyageHatchLidJob.myUserJobType.colour;
			if userJobColour &lt;&gt; White then
				craneColour:=userJobColour;
				cranePastColour:=userJobColour;
				craneMoveColour:=userJobColour;
			endif;
		endif;
	
	endif;
	
	
	if self.myJobSheetStats &lt;&gt; null then
		jobStats:=self.myJobSheetStats.allJobStatsByJob.getAtKey(voyageJob);
	endif;
	
	hasReefers:=voyageJob.getNumReefersLoading &gt; 0;
	if jobStats &lt;&gt; null then
		num20s:=jobStats.num20s;
		num40s:=jobStats.num40s;
		isRehandle:=jobStats.isRehandle;
		isOverHeight:=jobStats.hasOverDimension;
	else
		voyageJob.getJobTITotals(cmifObj);
		num20s:=cmifObj.numTwentyFoot;
		num40s:=cmifObj.numFortyFoot;
		isRehandle:=voyageJob.isRehandle;
		isOverHeight:=voyageJob.hasOverDimensionRequests;
	endif;
	
	infoString1:=null;
	infoString2:=null;
	if num20s &lt;&gt; null then
		infoString1 :="2:" &amp; num20s.asStringJMT;
	endif;
	if num40s &lt;&gt; null then
		infoString2:="4:" &amp; num40s.asStringJMT;
	endif;

	if isDischarge then
		type:=DisInt.Character;
	elseif isLoad then
		type:=LoadInt.Character;
	else
		type := null;	
	endif;
	//write _y2 - _y1;
	if _x2 &lt;= _currentTimeX then
		colour :=cranePastColour;
		self.drawJobRectangle(_x1,_y1,_x2,_y2,drawFillStyle,cranePastColour, isDischarge,isLoad,_selected);
	elseif _x1 &lt; _currentTimeX and _x2 &gt; _currentTimeX then
		//have to break this up into two drawings 
		self.drawJobRectangle(_x1,_y1,_currentTimeX,_y2,drawFillStyle,cranePastColour, isDischarge,isLoad,_selected);
		self.drawJobRectangle(_currentTimeX,_y1,_x2,_y2,drawFillStyle,craneColour, false,false,_selected);	
		colour :=cranePastColour;
	else
		if hasMoved then
			colour:=craneMoveColour;
		else
			colour:=craneColour;
		endif;
		self.drawJobRectangle(_x1,_y1,_x2,_y2,drawFillStyle,colour, isDischarge,isLoad,_selected);
	endif;
	infoColour:=colour.getInverseColour;
	self.drawingFrame.drawTextAlign:=Window.DrawTextAlign_Left;
	self.drawingFrame.drawFontName:=NewFontName;
	typeHeight:=self.drawingFrame.drawTextHeight(type);
	typeWidth:=self.drawingFrame.drawTextWidth(type);
	jobWidth:=_y2-_y1;
	if type &lt;&gt; null then
		if typeWidth &lt; (_x2- _x1) then
			if isLoad then
				yOffset:=2;
			endif;
			self.drawingFrame.drawTextAt(type, _x1 + 2,_y1 + yOffset ,infoColour);//,x2,y2,infoColour);
			xOffset:=typeWidth + 2;
		endif;
		
		
		if isRehandle then
			if (xOffset + self.drawingFrame.drawTextWidth(Rehandle.Character)) &lt; (_x2 - _x1) then
				self.drawingFrame.drawTextAt(Rehandle.Character, _x1+xOffset,_y1,infoColour);
				xOffset:=xOffset + self.drawingFrame.drawTextWidth(Rehandle.Character);
			endif;
		endif;
		
		if isOverHeight then
			if (xOffset + self.drawingFrame.drawTextWidth(OverHeight.Character)) &lt; (_x2 - _x1) then
				self.drawingFrame.drawTextAt(OverHeight.Character, _x1+xOffset,_y1,infoColour);
				xOffset:=xOffset + self.drawingFrame.drawTextWidth(OverHeight.Character);
			endif;
		endif;
		
		self.drawingFrame.drawFontName:=_originalFont;
		yOffset :=0;
		if infoString1 &lt;&gt; null then
			if	(xOffset + self.drawingFrame.drawTextWidth(infoString1)) &lt; (_x2 - _x1) then
				self.drawingFrame.drawTextAt(infoString1,_x1+xOffset,_y1,infoColour);//,x2,y2,infoColour);
			endif;
		endif;
		
		
		yOffset:=12;
		if jobWidth  &gt; yOffset + 2 then
			if infoString2 &lt;&gt; null then		
				if	(typeWidth + 4  + self.drawingFrame.drawTextWidth(infoString2)) &lt; (_x2 -_x1) then
					self.drawingFrame.drawTextAt(infoString2, _x1+xOffset,_y1 + yOffset,infoColour);
				endif;
			
			endif;
			
			xOffset:=3;
			if voyageJob.isTwinLift then
				if self.drawingFrame.drawTextWidth(TwinChar) &lt; (_x2 - _x1) then
					self.drawingFrame.drawTextAt(TwinChar, _x1 +xOffset,_y1 + yOffset,infoColour);
					xOffset:=xOffset + self.drawingFrame.drawTextWidth(TwinChar);
				endif;
			endif;
			if reeferDrawAttr &lt;&gt; null then
				if isLoad and hasReefers then //and hasPlannedReeferContainers
					self.drawingFrame.drawFontName:=reeferDrawAttr.fontName;
					reeferChar:=reeferDrawAttr.fontCharacter;
					if self.drawingFrame.drawTextWidth(reeferChar.Character) &lt; (_x2 - _x1) then					
						self.drawingFrame.drawTextAt(reeferChar.Character, _x1 +xOffset,_y1 + yOffset,infoColour);
						xOffset:=xOffset + self.drawingFrame.drawTextWidth(reeferChar.Character);											
					endif;
					self.drawingFrame.drawFontName:=_originalFont;
				endif;
			endif;
		endif;
		
		
	endif;
	self.drawingFrame.drawFontName:=_originalFont;

epilog
	if cmifObj &lt;&gt; null then
		delete cmifObj;
	endif;
end;</source>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_currentTimeX" type="Real"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_x1" type="Real" usage="input"/>
        <Parameter name="_y1" type="Real" usage="input"/>
        <Parameter name="_x2" type="Real" usage="input"/>
        <Parameter name="_y2" type="Real" usage="input"/>
        <Parameter name="_originalFont" type="String"/>
        <Parameter name="_cranePastColour" type="Integer"/>
        <Parameter name="_craneMoveColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawJobRectangle" id="c008d56e-c30d-41c7-8e5a-b78945be5e5d">
        <source>drawJobRectangle(x1,y1,x2,y2 : Real;
				_drawFillStyle : Integer;
				_fillColour : Integer;
				_isDischarge : Boolean;
				_isLoad : Boolean;
				_selected : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	outerColourUpper, 
	outerColourLower,
	filledColour : Integer;
	newX2 : Real;
begin
	
	outerColourUpper := DarkGray;
	outerColourLower := White;
	filledColour:=_fillColour;

	
	if _selected then
		filledColour:=Grey;
	endif;
	self.drawingFrame.drawStyle:=Window.DrawStyle_Solid;
	self.drawingFrame.drawFillStyle:=_drawFillStyle;
	self.drawingFrame.drawFillColor:=filledColour;
	if (x1.truncated() = x2.truncated()) then //cnwas3 par 25976
		newX2 := x1 + 3;
	else
		newX2 := x2;
	endif;
	self.drawingFrame.drawFilledRectangle(x1,y1,newX2,y2,Black);

	if _selected then															//cnwas3 par 25976 substituted x2 with newX2
		self.drawingFrame.drawLine(x1, y1, newX2, y1, outerColourUpper);
		self.drawingFrame.drawLine(x1, y1, x1, y2 - 1, outerColourUpper);
		self.drawingFrame.drawLine(newX2 - 1, y1 + 1, newX2 - 1, y2, outerColourLower);
		self.drawingFrame.drawLine(x1, y2 - 1, newX2 - 1, y2 - 1, outerColourLower);
	endif;


epilog

end;</source>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="_drawFillStyle" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_isDischarge" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_selected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findAllJobsFromXtoJob" id="3faa9fd2-ae83-42f7-9f3a-b679b956e6ee">
        <source>findAllJobsFromXtoJob(	_newDict : CMUI_ObjectByRealX1Y1X2Y2Dict input;
						_x : Real;
						_endJob : CM_VoyageJob);
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	voyageJob : CM_VoyageJob;
	jobObj : Object;
	iter : Iterator;
	x1, y1, x2, y2 : Real;
	tarX1,tarY1,tarX2,tarY2 : Real;
	z : Integer;
begin
	iter:=self.allJobObjects.createIterator;
	self.allJobObjects.startKeyLeq( _x,null,_x,null,null,iter);
	while iter.next(jobObj) do
		if not jobObj.isKindOf(CM_VoyageJob) then
			continue;
		endif;
		voyageJob:=jobObj.CM_VoyageJob;
		if  voyageJob = _endJob then
			break;
		endif;
		self.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
		if _newDict.getAtKey(x1,y1,x2,y2,z) = null then
			_newDict.putAtKey(x1,y1,x2,y2,z,jobObj);
		endif;		
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_newDict" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_endJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="findDelayAtX" id="8e458d4e-afdf-4912-a252-2a2a954a04a0">
        <source>findDelayAtX(_x1 : Real ) : CM_Delay;
/*

Purpose:	// at any x point there should be only one object 
			return the object and its full co-ordinates


Return Value:		


Date		Who		Reason
09 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter : Iterator;
	obj : Object;
	x1, y1, x2, y2 : Real;
	z				: Integer;
begin

	iter:=self.allDelayObjects.createIterator;
	self.allDelayObjects.startKeyLeq(_x1,null,_x1,null,null,iter);
	while iter.next(obj) do
		self.allDelayObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
		if _x1 &gt; x2 then
			break;
		endif;
		if x1 &gt; _x1 then
			continue;
		endif;
		return obj.CM_Delay;
	endwhile;

	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_x1" type="Real"/>
        <ReturnType type="CM_Delay"/>
    </JadeMethod>
