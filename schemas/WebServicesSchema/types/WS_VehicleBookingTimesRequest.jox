27 Sept 2021 navmj1 Bug 51070: PRP - Vehicle Booking Date / Time Bug
*/

vars

	date : TimeStamp;

begin

	date := self.fromDate.asTimeStampFromWebInterface();	//27.9.2021 NAVMJ1 #51070
