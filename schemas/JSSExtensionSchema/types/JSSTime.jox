<Class name="JSSTime" id="3835276b-87bb-4bd6-857a-d09e71294935">
    <superclass name="JSSPrimitiveValue"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
