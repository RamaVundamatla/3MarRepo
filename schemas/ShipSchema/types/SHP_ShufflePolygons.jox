    <JadeMethod name="create" id="2ccbd2ce-b722-443b-bb91-331ba4661e28">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView  := PmShipDefinView;
	self.permissionMaint := PmShipDefinMaint;
	self.helpFileName := HelpFile_Voyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayStuff" id="52efa0a0-066a-4d02-92a2-32d09c14a073">
        <source>displayStuff(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aBay : CM_Bay;
	aLayoutGraphic : CM_ROROGraphic;
	theString : String;
begin
	
	if _theObject &lt;&gt; null then
		aLayoutGraphic := _theObject.CM_ROROGraphic;
		theString := aLayoutGraphic.label;
		return  theString;
	else
		return "Null Object";
	endif;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnCloseClick" id="92f7aaf5-4a23-4d87-a153-6251d088ec65">
        <updating/>
        <source>doBtnCloseClick() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	pxyTerminal : CM_Terminal;
	pxyGraphic : CM_ROROGraphic;
begin
	pxyGraphic := self.allGraphics.first.CM_ROROGraphic;
	if pxyGraphic = null then
		return;
	endif;

	pxyTerminal := pxyGraphic.myTerminal;
	if pxyTerminal = null then
		return;
	endif;
	// put the graphics back into the original order
	pxyTerminal.doOrderLayoutGraphics(self.allGraphics);
	self.unloadForm();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="b6b7de03-ecb9-48f4-99fd-092dc76e1174">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theGraphics : CM_GraphicArray;
begin
	create theGraphics transient;
	self.magPolygons.getItemsOnRightSide(theGraphics);
	
	//myProxyRORODefn.doOrderLayoutGraphicsSet(theGraphics);
	
	global.beep;
	self.unloadForm();
epilog
	delete theGraphics;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="422238f7-f924-4585-9453-b3ad31ea2092">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
begin
	self.width := 260;
	self.height := 225;

	self.btnSave.move(5,165, 70,25);
	self.btnClose.move(self.btnSave.left + self.btnSave.width + 5,self.btnSave.top, 70,25);

	self.lblPolygons.move(5,5,self.clientWidth - 10, 15 );
	self.magPolygons.move(0, self.lblPolygons.top + self.lblPolygons.height + 5,self.clientWidth - 10, 140);
	self.magPolygons.cnEcResizeContents();
	self.magPolygons.move(0, self.lblPolygons.top + self.lblPolygons.height + 5,self.clientWidth - 10, 140);


end;</source>
    </JadeMethod>
    <JadeMethod name="initGroupBox" id="a864ffb8-34ba-40e6-9c29-a5d8e47e7c94">
        <source>initGroupBox();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.magPolygons.caption := null;
	self.magPolygons.distanceFromBottom 	:= 5;
	self.magPolygons.distanceFromRight 		:= 5;
	self.magPolygons.lockBottom 				:= false;
	self.magPolygons.lockRight				:= false;
	self.magPolygons.stretchHeight 			:= true;
	self.magPolygons.stretchWidth 			:= true;
	self.magPolygons.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.magPolygons.borderStyle := Frame.BorderStyle_None;
	
	self.magPolygons.availableHeading := app.getErrorString(SHP_Graphics);	//cnwmc5 

	self.magPolygons.selectedHeading := app.getErrorString(SHP_Graphics);	//cnwmc5 

	self.magPolygons.displayAddRemoveBtns(false, false);	//cnwmc5
	self.magPolygons.displayOrderBtns(true, true);	//cnwmc5
	self.magPolygons.myBaseForm	:= self;
	self.magPolygons.mySelectedListBox.sorted := false;
	self.magPolygons.cnEcResizeContents();
	self.magPolygons.readOnly := false;
	self.magPolygons.myAvailableListBox.listObject := null;
	self.magPolygons.setAsAlignOnly();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCollections" id="2d9bc7c9-5ee5-4484-9735-04a604f3d8b9">
        <source>setCollections(_theRightPolygon: CM_GraphicArray) : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.magPolygons.setItemsOnRightSide(_theRightPolygon, true);
	_theRightPolygon.copy(self.allGraphics);
	return true;
epilog
end;</source>
        <Parameter name="_theRightPolygon" type="CM_GraphicArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="0718a6c3-aacd-4ae6-b1b9-f65ca48fa182">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_colorControl);
	self.lblPolygons.backColor := self.backColor;
	self.magPolygons.backColor := self.backColor;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a9a9dec5-4660-4084-84e7-487b916a5e40">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer := Window.MousePointer_Default;
	self.centreWindow();
	self.initGroupBox();
	
	inheritMethod();

	//self.doResize();
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="99a139cc-9f49-4990-b4af-73eab04ab5ec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
///	self.translateCaption(Xlat_0015663, locale);
///	btnClose.translateCaption(Xlat_0015664, locale);
///	btnSave.translateCaption(Xlat_0015665, locale);
///	lblPolygons.translateCaption(Xlat_0015666, locale);
///	magPolygons.translateCaption(Xlat_0015667, locale);
end;</source>
    </JadeMethod>
</GUIClass>
