    <JadeMethod name="setupForm" id="6842a108-ddba-4c01-972c-771d6e33fa2e">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// 06/12/2012	cnwcs5	par 30852 - use translatable form caption
vars

begin
	inheritMethod();

	self.frmPictureActual.autoRedraw 	:= true;
	self.frmToolbar.alignContainer		:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle 					:= self.ToolbarStyle_ShowNoHide;	
	self.showToolbar 					:= true;
	
	self.frmTableFilter.setupControl(self.tblData, null);
	
	self.initTblData();	
	
	self.setNavigatorHeading(self.caption);
	
	self.dkbDetails.visible := false;
	
	self.beginClassNotification(CM_TILCType, false, Any_System_Event, Response_Continuous, null);	//Par 17769
	
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;
	endif;
end;</source>
    </JadeMethod>
