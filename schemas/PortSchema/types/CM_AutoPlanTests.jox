    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>One of these objects is hung off each terminal area that can accept
Tracked Items. It determines the tests that the users want to
run when planning TO the Terminal Area</text>
    <DbClassMap file="planning"/>
