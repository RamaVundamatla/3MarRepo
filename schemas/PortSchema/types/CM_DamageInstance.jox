    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d376cf41-53cc-4a1d-9aea-8d995c0d93fe">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
24 June 2022  navhl20 	 TFS 53862 EUP - WMS - Damage Recording Extra Details
24 June 2022  navsj20 	 TFS 53862 EUP - WMS - Damage Recording Extra Details
07 Nov 2022	  navak20 	 Bug 55274: MTN - Damage Date/Time not showing current date/time as defaultr
16 Dec 2022   navlw1	 Bug 55876: MTN - Optional Damage Severity Validate Check Not Working Correctly
19 Dec 2022	  navlw1	 Bug 55885: MTN - Damage Date Is Mandatory and Should Be Optional
10 Mar 2023	  navlw1	 Bug 56958: MTN - Added a Permission check for optional fields
04 Apr 2023	  navlw1	 Bug 57383: SNO - Incorrect error 95674 when attempting to create a damage in basic mode
28/07/2023 	  navcs2	 Bug 59427: EUP | Advanced Damage and Repair
09/08/2023	  navcs2	 Bug 59629: EUP - Damage | 1090 if you change between damage parameters being optional in a terminal
31/10/2024	  navcs2	 MTN-33164 EUP | 53489 - Error 89407 when updating cargo with Quick Damage and Responsible Party
31 Jan 2025	  navnk30	 JIRA 33947 MTN | Getting Error when saving Road gate Form - Obbject has been Deleted in Current transaction
17 Jul 2025   navbk1     Bug 34529: MTN - Cannot add quick damage correctly when damage details are mandatory configs are set
----------   ----------  --------------------------------------------------
*/
constants
	DamageInstance : String = "damage instance";
vars
	terminal : CM_Terminal; //24 June 2022 navsj20 TFS 53862
	damageSeverityOptional, damageDetailsOptional,
	advanceDamPerm: Boolean;
	isQuickDamage	: Boolean;							// 31/10/2024	  navcs2	 MTN-33164
	realDamage	: CM_DamageInstance;					// 31/10/2024	  navcs2	 MTN-33164
begin
	realDamage := self.pxyGetRealObject;				// 31/10/2024	  navcs2	 MTN-33164
	
	if realDamage &lt;&gt; null and
		global.isValidObject(realDamage) and			//31.01.2025 navnk30 JIRA 33947
		realDamage.myDamagePlace = null					// 31/10/2024	  navcs2	 MTN-33164
		and realDamage.myDamagePlace = null				// 31/10/2024	  navcs2	 MTN-33164
		and self.myDamagePlace = null					// 31/10/2024	  navcs2	 MTN-33164
		and realDamage.myDamageDefinition = null		// 31/10/2024	  navcs2	 MTN-33164
		and self.myDamageDefinition = null				// 31/10/2024	  navcs2	 MTN-33164
		and realDamage.myDamageParty &lt;&gt; null			// 31/10/2024	  navcs2	 MTN-33164
		and self.myDamageParty &lt;&gt; null then				// 31/10/2024	  navcs2	 MTN-33164
		isQuickDamage := true;							// 31/10/2024	  navcs2	 MTN-33164
	endif;												// 31/10/2024	  navcs2	 MTN-33164
	if self.myDamageDefinition = null and				//17.07.25 navbk1 #34529
		self.myDamagePlace = null and					//17.07.25 navbk1 #34529
		self.myDamageSeverity = null then				//17.07.25 navbk1 #34529
		isQuickDamage := true;							//17.07.25 navbk1 #34529
	endif;												//17.07.25 navbk1 #34529
	if self.myTrackedItem &lt;&gt; null then
		terminal := self.myTrackedItem.myTerminal;
	elseif self.mySubject &lt;&gt; null then
		terminal := self.mySubject.getMyTerminal;
	endif;
	
	if terminal = null then
		app.raiseCMException(No_Terminal_specified,null, self); // cnwdb2	PAR 35364
		return;
	endif;
	
	// 28/07/2023 Bug 59427: EUP | Advanced Damage and Repair
	/*
	if self.repairedDateTime &lt;&gt; null and self.repairedDateTime &lt;= self.damageDateTime then
		app.raiseCMException(Repai_date_canno_befor_damage ,null, self); 
		return;
	endif;
	*/
	
	// tracked item validation
	if self.myTrackedItem = null and self.myTIMaster = null and self.mySubject = null then
		if self.myTrackedItem = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'null parent proxy tracked item');
		elseif self.myTIMaster = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'null parent proxy master tracked item');
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'null parent proxy wagon (Master)');
		endif;
		return;
	endif;
	
	damageSeverityOptional := terminal.getConfig(DamageSeverityOptional).Boolean; 	//24 June 2022 navsj20 TFS 53862
	damageDetailsOptional := terminal.getConfig(DamageDetailsOptional).Boolean;	//24 June 2022 navsj20 TFS 53862
	
	advanceDamPerm := app.myCurrentUserCan(terminal, PmAdmDamageCodeAdvancedMaint); // 10 Mar 2023 navlw1 tfs 56958
	
	if (not damageSeverityOptional) and (not damageDetailsOptional) and (not isQuickDamage) then // 16 Dec 2022 navlw1 tfs navlw1    //17.07.25 navbk1 #34529
		if self.myDamageSeverity = null then  
			app.raiseCMException1(Err_DamageSeverity, app.getDamageDescrForPosition(self.myDamagePosition), null, null);
		endif;
	endif;																		
	
	// damage size checks
	if self.damageSize &lt;&gt; null and (self.damageSize &lt; 0 or self.damageSize &gt; 99999999) then								
		app.raiseCMException1(Invalid_damage_size, self.damageSize.String, null, null);		
	endif;   
	
	// 19 Dec 2022 navlw1 tfs 55885 
	// damage date checks
	if self.damageDateTime &lt;&gt; null then
		if self.damageDateTime &gt; app.actualTimeServer then // navlw1 04/04/2023 tfs 57383
			app.raiseCMException(Damage_date_time_future, 'damageDateTime', null);
		elseif self.damageDateTime &lt; app.actualTimeServer.subtractYears(10) then
			app.raiseCMWarning(Damage_date_time_past, 'damageDateTime', null, null);
		endif;
	endif;

	if not damageDetailsOptional and (not isQuickDamage) then																//17.07.25 navbk1 #34529			 												
		// 10 Mar 2023 navlw1 tfs 56958
		if advanceDamPerm then
			if self.myDamageReason = null and terminal &lt;&gt; null and not terminal.allDamageReasons.isEmpty then
				app.raiseCMException1(Damage_reason_not_been_entered, DamageInstance, null, null);// ### TFS BUG 59111		// 09/08/2023 navcs2 Bug 59629
			endif;
			if self.myDamageParty = null and terminal &lt;&gt; null and terminal.allDamageParties.size &gt; 0 then   
				app.raiseCMException1(Damag_respo_party_not_been_ent, DamageInstance, null, null);// ### TFS BUG 59111 		// 09/08/2023 navcs2 Bug 59629
			endif;
			if self.myDamagePlace = null and terminal &lt;&gt; null and not terminal.allDamagePlaces.isEmpty then
			app.raiseCMException1(Damage_location_not_entered, DamageInstance, null, null);// ### TFS BUG 59111 		// 09/08/2023 navcs2 Bug 59629
			endif;
		endif;
		/*// ### TFS BUG 59111 these are not optional
		if self.myDamageDefinition = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(DamageType), 'myDamageDefinition', self);
		endif;
		
		if self.myDamagePosition = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(DamagePosition), 'myDamagePosition', self);
		endif;
		*/
	endif;
	
	
	//jlier1 TFS 58968 12/9/23 
	if advanceDamPerm and damageDetailsOptional and damageSeverityOptional and app.isWebApp then
		if  realDamage = null then																								// 31/10/2024	  navcs2	 MTN-33164
			return;
		else
			if realDamage &lt;&gt; null and (realDamage.myDamageDefinition = null or  realDamage.myDamagePosition = null) then		// 31/10/2024	  navcs2	 MTN-33164
				return;
			endif;
		
		endif;
	endif;
	
	if not isQuickDamage then																									// 31/10/2024	  navcs2	 MTN-33164
		// ### TFS BUG 59111 - mandatory
		if self.myDamageDefinition = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(DamageType), 'myDamageDefinition', self);
		endif;
		
		if self.myDamagePosition = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(DamagePosition), 'myDamagePosition', self);
		endif;
	endif;																														// 31/10/2024	  navcs2	 MTN-33164
end;


</source>
    </JadeMethod>
</Class>
