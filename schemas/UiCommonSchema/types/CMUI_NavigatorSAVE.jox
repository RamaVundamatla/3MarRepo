    <JadeMethod name="translateForm" id="ccd91cfa-1610-475f-8b93-5eab3549b551">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007832, locale);
	mnuDockTopLeft2.translateCaption(Xlat_0007833, locale);
	mnuOrganiseMenu.translateCaption(Xlat_0007834, locale);
	mnuOrganize.translateCaption(Xlat_0007835, locale);
	mnuOrganizeTerminals.translateCaption(Xlat_0007836, locale);
	mnuResetAllUserMenus.translateCaption(Xlat_0007837, locale);
	mnuResetFromSystem.translateCaption(Xlat_0007838, locale);
	mnuResetToDefault.translateCaption(Xlat_0007839, locale);
	mnuSaveToAdmin.translateCaption(Xlat_0007840, locale);
	mnuSaveToSystem.translateCaption(Xlat_0007841, locale);
end;</source>
    </JadeMethod>
</GUIClass>
