    <JadeMethod name="tVoyageMisc" id="3e0815c0-0a51-4b26-972f-3c9da1b8e060">
        <source>tVoyageMisc();

/*

Purpose:		Voyage Miscellaneous
				
				trxUpdateROROVesselDecksOrd					Done
				
				trxUpdateRoROLaneFreedLength			
				trxCreateROROGCLoadCC					
				trxROROControllerUpdateRelease				?
				
				trxUpdateVoyageKPIMoveForTRAN				?
				trxSetMediateState							
				trxUpdateMeidateTimeStamp					
				trxUpdateRTResetMediator					
				trxPickupWithTask							
				trxUpdateLogonWithMachine					
				trxUpdateQueueEntryPosition					
				trxEnqTrackedItem							
				trxMoveTI									
				trxLogOnInterface							
				trxLogOffForInterface						
				trxCreateMachineInitiatedMove				
				trxCreateStowageConfirmation				
				trxMOveTrackedItemsAssignToJob				
							
				trxUpdateVoyageJobUnassignTI											
				trxHandleGenCargo							
				trxShiftJobinJobSheet						
				trxUpdateSlotRequestSeqNUm					
				trxChangeRTEntryMoveRule									
				trxUpdateMachineStatus						
				trxTransferVoyageJobsToCrane
				trxUPdateSlotDenfsAttribute					
				trxUpdateVoyageOpsCargoReceive				
				trxUpdateWLEStatus							
							
				trxUpdateSlotRequestDirection			
				trxUpdateQueueStatus						
				trxUPdateSlotDefn							
										
				trxProcessStopsEDIOnShip					
				trxRunImportTasksOnShip						
				trxUpdateVoyageJobUnplan						
				trxUpdateWLEsUnassignTI						
				trxUpdateQueueEntryStatus					
				
				trxUpdateTaskRemoveMachine				
				trxUpdateWLEConvertToRelease			
				trxUpdateRTTaskDirectoLocation			
				trxDeleteVoyageAllocation				
				trxUPdateSlotControllerSuffFM			
						
				trxUpdateRTDevice						
				trxUpdateSlotRequestLnkControl			
				trxUpdateMachineRejectedRTTsks			
				trxUpdateVoyageAllocNumbers				
							
				trxSwapMachineTandemTasks				
				trxUpdateWLEAutoplan					
				trxUpdateWLEsAutoplanTwin				
				
				trxDeleteVoyageJobs		
				trxDeleteCMObjects

Date			Who		Reason
17 February 2014	cnwmh5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants

	VesselNameId					: String = "Jolly Diamante OFFICIAL";
	NewVesselId						: String = "UTMHMISC";
	VoyageId						: String = "UTMHMISC";
	Voyage1Id						: String = "UTMHMISC1";
	Voyage2Id						: String = "UTMHMISC2";
	
vars

	vessel							: CM_Vessel;
	oldVessel						: CM_Vessel;
	operator						: CM_Operator;
	deck							: CM_Deck;
	voyage1							: CM_Voyage;
	voyage2							: CM_Voyage;
	
	allDecks						: CM_DeckVesselByOrdinalDIct;
	allDeckOrds						: IntegerArray;
	objArray						: CM_ObjectArrayActual;
	
	index							: Integer;
	warningsIgnored					: Boolean;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// delete the voyage
	self.deleteVoyage(VoyageId);
	self.deleteVoyage(Voyage1Id);
	self.deleteVoyage(Voyage2Id);
	
	// delete cloned vessel
	self.deleteVessel(NewVesselId);
	
	// clone vessel
	oldVessel := app.myRoot.getVesselByName(VesselNameId);
	self.assertNotNull(oldVessel);
	
	// clone the vessel
	vessel := self.cloneVessel(NewVesselId, oldVessel);
	self.assertNotNull(vessel);
	
	// copy decks
	create allDecks transient;
	vessel.myROROVesselStructure.allDecks.copy(allDecks);
	
	// get the ordinals for the decks
	create allDeckOrds transient;
	foreach deck in allDecks do
		allDeckOrds.add(deck.ordinal);
	endforeach;	
	
	app.myTrxUA.trxUpdateROROVesselDecksOrd(allDecks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach index in 1 to allDecks.size step 1 do
		self.assertNotEqual(allDecks[index].ordinal, allDeckOrds[index]);
	endforeach;
		
	// 18/06/2015 cnwmh5 - trxDeleteCMObjects
	create objArray transient;
	operator := app.myRoot.allOperators["UTOP"];
	voyage1 := self.addVoyageWithContainerStructur(Voyage1Id, NewVesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage1);
	objArray.add(voyage1);
	
	voyage2 := self.addVoyageWithContainerStructur(Voyage2Id, NewVesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage2);
	objArray.add(voyage2);
	
	warningsIgnored := app.myPassport.warningsIgnored;					// 11/09/2019 jlgmh5 - Ignore warnings
	app.myPassport.setWarningsIgnored(true);							// 11/09/2019 jlgmh5 - Ignore warnings
	app.myTrxDA.trxDeleteCMObjects(objArray, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myPassport.setWarningsIgnored(warningsIgnored);					// 11/09/2019 jlgmh5 - Ignore warnings
	
	voyage1 := self.getVoyage(Voyage1Id);
	self.assertNull(voyage1);
	
	voyage2 := self.getVoyage(Voyage2Id);
	self.assertNull(voyage2);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	app.myPassport.setWarningsIgnored(warningsIgnored);

	delete allDeckOrds;
	delete allDecks;
	delete objArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tYAOverstowRule" id="19795972-a306-42fa-bdb6-5d60fa66b341">
        <source>tYAOverstowRule();
/*

Purpose:			

Date		Who		Reason
11 November 2015	cnwmk3	Initial creation

*/
constants
   RCode                                : String = "UT_CODE";
   RDesc                                : String = "Created by UT";
vars
   pxyOverstowRule, yaOverstowRule      : CM_YAOverstowRule;
   attributeArray                       : IntegerArray;
   allImex                              : CM_IMEXStatusByCodeDict;
   pxyUpdateOverstowRule                : CM_YAOverstowRule;
begin
  
   create attributeArray transient;
   attributeArray.add(Carrier);
   attributeArray.add(IMEX);
   create allImex transient;
   allImex.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
   allImex.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE]);
   create pxyOverstowRule transient;
   pxyOverstowRule.setProxy(RCode, RDesc, 5, attributeArray, allImex, null, false, self.getTerminal());
   app.myTrxCA.trxCreateYAOverstowRule(pxyOverstowRule, yaOverstowRule, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
   beginLoad;
   pxyUpdateOverstowRule := yaOverstowRule.pxyCreateUpdateProxy();
   endLoad;
   pxyUpdateOverstowRule.setPropertyValue("myTerminal", yaOverstowRule.myTerminal);
   pxyUpdateOverstowRule.setPropertyValue("description", "Updated by UT");
   app.myTrxUA.trxUpdateYAOverstowRule(pxyUpdateOverstowRule, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
   yaOverstowRule := self.getTerminal().allYAOverstowRules[RCode];
   if yaOverstowRule &lt;&gt; null then
       app.myTrxDA.trxDeleteOverstowRule(yaOverstowRule, app.myPassport);
	   self.assertNoTrxErrorsOrWarnings();
   endif;
   
epilog
   delete attributeArray;
   delete allImex;
   delete pxyOverstowRule;
   delete pxyUpdateOverstowRule;
end;</source>
    </JadeMethod>
    <JadeMethod name="xAddCargoToWagons" id="5008c919-58fa-4189-9814-d0583709157e">
        <source>xAddCargoToWagons(_train : CM_Train);

/*

Purpose:		Add cargo to wagons

Date			Who		Reason
15/04/2014		cnwmh5	Initial creation

*/

vars

	moveController					: CMIF_MoveController;
	wagon							: CM_Wagon;
	bs								: CM_BlockStack;
	ti								: CM_TrackedItem;

	wagons 							: CM_WagonArray;
	tis 							: CM_TIArray;
	
	count							: Integer;
	
begin

	create wagons transient;
	count := 1;
	foreach wagon in _train.allWagonsByIdInward do
		if count mod 2 = 0 then
			wagons.add(wagon);
		endif;
		count := count + 1;
	endforeach;
	
	bs := self.addBlockStack("UTMHRAIL1", 50, null);
	self.assertNotNull(bs);
	
	self.opts.purge();
			self.opts.addAssoc("DischargePort", "NZAKL");
			self.opts.addAssoc("STATE",TI_STATE_NOTIFIED);	//27 Aug 2020	NDL	TFS 49950
	create tis transient;
	foreach count in 1 to 11 step 1 do
		if count = 6 then
			self.opts.purge();
			self.opts.addAssoc("DischargePort", "NZCHC");
			self.opts.addAssoc("STATE",TI_STATE_NOTIFIED);	//27 Aug 2020	NDL	TFS 49950
		endif;
	//	ti := self.addContainerAtLocation(bs.getNextQuickCargoID(TI_CargoType_Container), app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator, 
	//		"2213", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
			//27 Aug 2020	NDL	TFS 49950
		ti := self.addContainer(self.getNextQuickPrenoteID(TI_CargoType_Container), app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator, 
			"2213", "GENL", TI_IMEX_STATUS_IMPORT);
		self.assertNotNull(ti);
		self.updateTI(ti);
		self.deleteStops(ti);
		tis.add(ti);
	endforeach;
	self.assertEqual(tis.size, 11);
	
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;
	moveController.setMyTrackedItem(tis.first);
	moveController.setMyToPrimaryLocation(wagons.first.allLocationsControllersArray.first);
	
	app.myTrxUA.trxMoveTrackedItemsNewRailJob(wagons, tis, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings(); 

epilog

	delete moveController;
	delete wagons;
	delete tis;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xAutoPlanMoveTIs" id="c936dc8d-fbac-4b77-b049-be56960a9063">
        <source>xAutoPlanMoveTIs(_voyage : CM_Voyage io);

/*

Purpose:		Auto plan tis and move

Date			Who		Reason
13/03/014		cnwmh5	Initial creation

*/

vars

	ti							: CM_TrackedItem;
	voyageJob					: CM_VoyageJob;
	voyageJob1					: CM_VoyageJob;
	voyageJob2					: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	crane						: CM_Crane;
	voyageJobSheet 				: CM_VoyageJobSheet;
	voyageWLE 					: CM_VoyageWLE;
	obj							: Object;
	pxyCraneMoveRate			: CM_CraneMoveRates;
	moveController				: CMIF_MoveController;

	slotsToFill					: StringArray;
	slots						: CM_SlotControllerArray;
	tmpJobArray					: CM_VoyageJobArray;
	tmpJobWithWarnings			: CM_VoyageJobArray;
	requests 					: CM_RequestSet;
	wleSet						: CM_WLESet;
	wleSetQueue					: CM_WLESet;
	wleSetOut					: CM_WLESet;
	voyageJobSheets 			: CM_VoyageJobSheetArray;
	oa 							: ObjectArray;
	theTIs						: CM_TIArray;
	theLCs						: CM_LCArray;
	
	loadState					: Boolean;
	tmpStr						: String;
	tmpStr2						: String;
	
begin


	self.expectedTrxErrors.add(WarningPileHeightExceed2);

	create slotsToFill transient;
	create slots transient;
	create wleSet transient;
	create wleSetOut transient;
	create tmpJobArray transient;
	create tmpJobWithWarnings transient;
	create requests transient;
	create wleSetQueue transient;
			
	// create some cargo on the LOLO voyage to run import tasks against
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZAKA");
	self.opts.addAssoc("AvailabilityGrade", 12);
	self.addVoyageCargoLOLO(_voyage, "170602", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 2, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEs(_voyage, voyageJob, wleSet, NO_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZCHC");
	self.opts.addAssoc("AvailabilityGrade", 12);
	self.addVoyageCargoLOLO(_voyage, "170402", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 3, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEs(_voyage, voyageJob, wleSet, NO_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "AUSYD");
	self.opts.addAssoc("AvailabilityGrade", 12);
	self.addVoyageCargoLOLO(_voyage, "170202", 14, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 4, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob1 := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob1);
	self.xGetWLEs(_voyage, voyageJob1, wleSet, NO_MODE);
	tmpJobArray.add(voyageJob1);
	
	self.opts.purge();
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 5, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEs(_voyage, voyageJob, wleSet, NO_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.opts.addAssoc("AvailabilityGrade", 12);
	self.addVoyageCargoLOLO(_voyage, "170302", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 6, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	
	// change CRN2's seed value
	crane := self.getCrane("CRMH");
	self.assertNotNull(crane);
	app.myTrxUA.trxUpdateCraneSeedJobNumber(crane, 444, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//create pxyCraneMoveRate transient;
	app.cmsBeginLoad(loadState);
	pxyCraneMoveRate := crane.myMoveRate.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	pxyCraneMoveRate.setProxy(22, 33, 44, 55, 66);
	app.myTrxUA.trxUpdateCraneMoveRates(pxyCraneMoveRate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(crane.myMoveRate);
	self.assertEqual(crane.myMoveRate.ratePerHourSLOD, 22);
	self.assertEqual(crane.myMoveRate.ratePerHourSLUD, 33);
	self.assertEqual(crane.myMoveRate.ratePerHourTLOD, 44);
	self.assertEqual(crane.myMoveRate.ratePerHourTLUD, 55);
	self.assertEqual(crane.myMoveRate.ratePerHourOD, 66);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.opts.addAssoc("AvailabilityGrade", 1);
	self.addVoyageCargoLOLO(_voyage, "170502", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 7, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob2 := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob2);
	self.xGetWLEs(_voyage, voyageJob2, wleSetQueue, NO_MODE);
	
	self.opts.purge();
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 1, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEs(_voyage, voyageJob, wleSet, NO_MODE);
	
	self.opts.purge();
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 8, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	
	
	app.myTrxUA.trxProcessStopsEDIOnShip(_voyage, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(_voyage.remarks.cnContains("added to EDI Customs processing"), true);
	
	foreach ti in _voyage.allOnshipTIsByIdCargoType discreteLock do	
		self.deleteStops(ti);
		self.assertEqualMsg(ti.getAllStops().size, 0, ti.id &amp; ' has stops');
	endforeach;
	
	self.loadAllJobsToOps(_voyage, true);
	
	
	app.myTrxUA.trxAutoPlanMultipleTis(wleSet, wleSetOut, PLANNING_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	voyageJobSheet := _voyage.allJobSheetsInOrder.last;
	wleSet.clear();
	self.xGetWLEs(_voyage, voyageJob1, wleSet, NO_MODE);
	foreach obj in wleSet do
		requests.addNoDuplicates(obj.CM_VoyageWLE.myRequest, false);
	endforeach;
	app.myTrxUA.trxTransferVoyageJobsToCrane(false, tmpJobArray, tmpJobWithWarnings, voyageJobSheet, PLANNING_MODE, requests,null,
		"333", true, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyageJob1.getJobCrane().id, "CRMH");
	
	
	
	voyageJobSheet := _voyage.allJobSheets[crane.id];
	create voyageJobSheets transient;
	voyageJobSheets.add(voyageJobSheet);
	create oa transient;
	tmpStr := null;
	foreach obj in voyageJobSheet.allJobsByOrder reversed do
		tmpStr := obj.CM_VoyageJob.id &amp; tmpStr;
		oa.add(obj);
	endforeach;
	app.myTrxUA.trxUpdateVoyageJobSheetJobs(_voyage, oa, voyageJobSheets, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	tmpStr2 := null;
	foreach obj in voyageJobSheet.allJobsByJobNum do
		tmpStr2 := tmpStr2 &amp; obj.CM_VoyageJob.id;
	endforeach;
	self.assertEqual(tmpStr2, tmpStr);

	// get all the wle's that haven't been planned / queued and queue them
	wleSet.clear();
	foreach obj in _voyage.allVoyageJobs do
		voyageJob := obj.CM_VoyageJob;
		self.xGetWLEs(_voyage, voyageJob, wleSet, NO_MODE);
	endforeach;
	app.myTrxUA.trxAutoPlanMultipleTis(wleSet, wleSetOut, QUEUE_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// move all the ti's off ship
	self.moveAllCargoOnVoyage(_voyage, REAL_MODE);
	
epilog

	app.cmsEndLoad(loadState);

	self.expectedTrxErrors.clear();

	delete slotsToFill;
	delete slots;
	delete wleSetOut;
	delete wleSet;
	delete wleSetQueue;
	delete voyageJobSheets;
	delete oa;
	delete theTIs;
	delete tmpJobArray;
	delete tmpJobWithWarnings;
	delete requests;
	delete pxyCraneMoveRate;
	delete theLCs;
	delete moveController;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xAutoPlanTIs" id="c09453eb-3208-4af2-81c4-a283ab16c09e">
        <source>xAutoPlanTIs(_voyage : CM_Voyage io);

/*

Purpose:		Auto plan tis

Date			Who		Reason
13/03/014		cnwmh5	Initial creation

*/

vars

	ti							: CM_TrackedItem;
	voyageJob					: CM_VoyageJob;
	voyageJob1					: CM_VoyageJob;
	voyageJob2					: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	crane						: CM_Crane;
	voyageJobSheet 				: CM_VoyageJobSheet;
	voyageWLE 					: CM_VoyageWLE;
	obj							: Object;
	pxyCraneMoveRate			: CM_CraneMoveRates;

	slotsToFill					: StringArray;
	slots						: CM_SlotControllerArray;
	tmpJobArray					: CM_VoyageJobArray;
	tmpJobWithWarnings			: CM_VoyageJobArray;
	requests 					: CM_RequestSet;
	wleSet						: CM_WLESet;
	wleSetQueue					: CM_WLESet;
	wleSetOut					: CM_WLESet;
	voyageJobSheets 			: CM_VoyageJobSheetArray;
	oa 							: ObjectArray;
	
	loadState					: Boolean;
	tmpStr						: String;
	tmpStr2						: String;
	
begin

	
	self.expectedTrxErrors.add(WarningPileHeightExceed2);

	create slotsToFill transient;
	create slots transient;
	create wleSet transient;
	create wleSetOut transient;
	create tmpJobArray transient;
	create tmpJobWithWarnings transient;
	create requests transient;
	create wleSetQueue transient;
		
	// create some cargo on the LOLO voyage to run import tasks against
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZAKA");
	self.addVoyageCargoLOLO(_voyage, "170602", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 2, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEsToAutoPlan(_voyage, voyageJob, wleSet);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZCHC");
	self.addVoyageCargoLOLO(_voyage, "170402", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 3, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEsToAutoPlan(_voyage, voyageJob, wleSet);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "AUSYD");
	self.addVoyageCargoLOLO(_voyage, "170202", 14, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 4, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob1 := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob1);
	self.xGetWLEsToAutoPlan(_voyage, voyageJob1, wleSet);
	tmpJobArray.add(voyageJob1);
	
	self.opts.purge();
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 5, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEsToAutoPlan(_voyage, voyageJob, wleSet);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.addVoyageCargoLOLO(_voyage, "170302", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 6, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	
	// change CRN2's seed value
	crane := self.getCrane("CRMH");
	self.assertNotNull(crane);
	app.myTrxUA.trxUpdateCraneSeedJobNumber(crane, 444, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//create pxyCraneMoveRate transient;
	app.cmsBeginLoad(loadState);
	pxyCraneMoveRate := crane.myMoveRate.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	pxyCraneMoveRate.setProxy(22, 33, 44, 55, 66);
	app.myTrxUA.trxUpdateCraneMoveRates(pxyCraneMoveRate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(crane.myMoveRate);
	self.assertEqual(crane.myMoveRate.ratePerHourSLOD, 22);
	self.assertEqual(crane.myMoveRate.ratePerHourSLUD, 33);
	self.assertEqual(crane.myMoveRate.ratePerHourTLOD, 44);
	self.assertEqual(crane.myMoveRate.ratePerHourTLUD, 55);
	self.assertEqual(crane.myMoveRate.ratePerHourOD, 66);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.addVoyageCargoLOLO(_voyage, "170502", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 7, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob2 := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob2);
	self.xGetWLEsToAutoPlan(_voyage, voyageJob2, wleSetQueue);
	
	self.opts.purge();
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 1, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.xGetWLEsToAutoPlan(_voyage, voyageJob, wleSet);
	
	self.opts.purge();
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "17", DeckUnderDeck, 8, 1, 7, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, true);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	
	
	app.myTrxUA.trxProcessStopsEDIOnShip(_voyage, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(_voyage.remarks.cnContains("added to EDI Customs processing"), true);
	
	foreach ti in _voyage.allOnshipTIsByIdCargoType discreteLock do	
		self.deleteStops(ti);
		self.assertEqualMsg(ti.getAllStops().size, 0, ti.id &amp; ' has stops');
	endforeach;
	
	self.loadAllJobsToOps(_voyage, true);
	
	
	app.myTrxUA.trxAutoPlanMultipleTis(wleSet, wleSetOut, PLANNING_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	voyageJobSheet := _voyage.allJobSheetsInOrder.last;
	wleSet.clear();
	self.xGetWLEsToAutoPlan(_voyage, voyageJob1, wleSet);
	foreach obj in wleSet do
		requests.addNoDuplicates(obj.CM_VoyageWLE.myRequest, false);
	endforeach;
	app.myTrxUA.trxTransferVoyageJobsToCrane(false, tmpJobArray, tmpJobWithWarnings, voyageJobSheet, PLANNING_MODE, requests,null,
		"333", true, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyageJob1.getJobCrane().id, "CRMH");
	
	
	
	voyageJobSheet := _voyage.allJobSheets[crane.id];
	create voyageJobSheets transient;
	voyageJobSheets.add(voyageJobSheet);
	create oa transient;
	tmpStr := null;
	foreach obj in voyageJobSheet.allJobsByOrder reversed do
		tmpStr := obj.CM_VoyageJob.id &amp; tmpStr;
		oa.add(obj);
	endforeach;
	app.myTrxUA.trxUpdateVoyageJobSheetJobs(_voyage, oa, voyageJobSheets, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	tmpStr2 := null;
	foreach obj in voyageJobSheet.allJobsByJobNum do
		tmpStr2 := tmpStr2 &amp; obj.CM_VoyageJob.id;
	endforeach;
	self.assertEqual(tmpStr2, tmpStr);
	
	return;
	
	app.myTrxUA.trxAutoPlanMultipleTis(wleSetQueue, wleSetOut, PLANNING_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	foreach obj in wleSetQueue do
		app.myTrxUA.trxUpdateSlotControllerUnplan(PLANNING_MODE, obj.CM_VoyageWLE.myRequest.CM_SlotRequest.mySlotController, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
epilog

	app.cmsEndLoad(loadState);

	self.expectedTrxErrors.clear();

	delete slotsToFill;
	delete slots;
	
	delete wleSetOut;
	delete wleSet;
	delete wleSetQueue;
	
	delete voyageJobSheets;
	delete oa;
	
	delete tmpJobArray;
	delete tmpJobWithWarnings;
	
	delete requests;
	delete pxyCraneMoveRate;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xConsigneeNorImportFile" id="bbede212-5202-49c7-b6de-9e809da66263">
        <source>xConsigneeNorImportFile(_consignCode, _debtorCode : String) : File;

/*

Purpose:		Consignee / Consignor Import file

Date			Who		Reason
03/07/2015		cnwmh5	Initial creation

*/

vars

	file					: File;


begin


	create file transient;
	file.usePresentationFileSystem := true;
	//file.kind := File.Kind_ANSI;// 2/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := app.getTempDir() &amp; "ConsigneeNor_Import.csv";
	if file.isAvailable then
		file.purge();
	endif;
	
	file.writeLine("Code,Description,Colour,Consign Group,Derogation Number,Email Address,SEP,OOW Remarks,Not Available For Entry,Is Consignee,Is Consignor,Is Freight Forwarder,Debtor");
	file.writeLine(_consignCode &amp; ",Michael's UT Consignee/nor - DON’T USE,16000808,,,,0,0,0,1,1,0," &amp; _debtorCode);
	file.close();
	
	return file;

epilog

end;</source>
        <Parameter name="_consignCode" type="String"/>
        <Parameter name="_debtorCode" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="xDebtorNodeImportFile" id="f09639de-024c-4b6b-9285-edf05401ed74">
