    <JadeMethod name="setMyTrackedItem" id="847f5c53-f126-4d9a-b23b-41564aa6434a">
        <updating/>
        <source>setMyTrackedItem(_ti: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
31 Jul 2024 navhl20	Defect 65460: Some columns are missing on the Pack Unpack operation mode and the Quantity is not displaying the correct value
*/

vars

begin
	inheritMethod(_ti);
	
	self.quantity 	:= self.getTotalQuant();
	self.weight 	:= self.getTotalWt();		//31.07.2024 navhl20 #65460
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
