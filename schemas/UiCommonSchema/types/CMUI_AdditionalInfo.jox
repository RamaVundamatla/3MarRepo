    <JadeMethod name="tblMain_rowColumnChg" id="8b08ac38-d38f-4941-bef5-213ecbd0b221">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_rowColumnChg(table: Table input) updating;
//--------------------------------------------------------------
//Created: 05 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if table.row = 1 then
	   	if table.accessCell(table.row, 2).text = '1' then
   			table.accessCell(2, 2).text := '0';
   		endif;
	elseif table.row = 2 then
	   	if table.accessCell(table.row, 2).text = '1' then
   			table.accessCell(1, 2).text := '0';
   		endif;   		
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="db0d401e-2ee4-49b4-ab65-fc00ef7f5678">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007246, locale);
	btnCancel.translateCaption(Xlat_0000035, locale);
	btnSave.translateCaption(Xlat_0000036, locale);
	clrOne.translateCaption(Xlat_0000037, locale);
	clrOneDark.translateCaption(Xlat_0000038, locale);
	lblOne.translateCaption(Xlat_0000039, locale);
	lblTwo.translateCaption(Xlat_0000040, locale);
end;</source>
    </JadeMethod>
</GUIClass>
