    <JadeMethod name="initFilterTable" id="aa43e47f-59f6-4f8d-9758-4a3d0b7cf313">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	cargoTypeObj	: CM_CargoType;
	terminalObj		: CM_Terminal;
	
begin
	theTable	:=	self.tblSearch;
	entTableDef	:=	app.myController.getEntTableDef(ETDef_ProductGroupSearch);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(25);
		self.sptDataFilter.setLeftToRightRatio(20);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
	endif;

	cargoTypeObj	:=	self.cmbFiltCargoType.listObject.CM_CargoType;
	
	if cargoTypeObj &lt;&gt; null then
		theTable.setValueByName(ETRow_CargoTypeFilter, cargoTypeObj.description);
	endif;
	
	terminalObj	:=	self.cmbFilteTerminal.listObject.CM_Terminal;
	
	if terminalObj &lt;&gt; null then
		theTable.setValueByName(ETRow_Terminal, terminalObj.code);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="20f89fe5-e690-4d3e-8875-89dbfeca1473">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= true;
	self.allowTblDataSearch := true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled 	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();	
	
	self.fldEntDetail.visible := false;
	self.fldEntDetail.useSheetBackColors := true;
	self.fldEntDetail.setDefaultSheetBackColors();
	self.fldEntDetail.initSheetBackColors();
	
//	self.myAssistant.comboBoxTerminal(self.cmbFilteTerminal,null);
	self.loadCombos();
//	self.myAssistant.comboBoxCargoBolType(self.cmbFiltCargoType,-1, true, false,true,false);

	if self.cmbFiltCargoType.listCount() &gt; 0 then
		self.cmbFiltCargoType.listIndex	:=	1;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMSG" id="d5542eb1-bbaa-484e-a6e8-5b3cf893b225">
        <source>initMSG() protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theGroupBox : CMUI_MultiSelectGroupBox;
	
begin
	theGroupBox := self.msgProducts;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayProduct";
	theGroupBox.availableHeading := app.getErrorString(AvailableCargoSubtypes);
	theGroupBox.selectedHeading := app.getErrorString(SelectedCargoSubtypes);
	
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="33916d48-866a-48a2-b597-465a999416c9">
        <source>initTblEntDetail() protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
//	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin
	theTable	:=	self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent	:=	true;
	theTable.optimiseRowHeight	:=	true;
	entTableDef := app.myController.getEntTableDef(ETDef_ProductGroupMaint);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="d70379be-ec4d-4722-bf48-96abddd8857b">
        <source>initTblThumb() protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
