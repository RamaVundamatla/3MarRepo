		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomLeft, self.mnuHideFrameSub, mnuIdx);
	if self.allowFrameBottomLeft and self.dkbBottomLeft.visible then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomRight, self.mnuHideFrameSub, mnuIdx);
	if self.allowFrameBottomRight and self.dkbBottomRight.visible then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopRight, self.mnuHideFrameSub, mnuIdx);
	if self.allowFrameTopRight and self.dkbTopRight.visible then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	/*
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcLeftMain, self.mnuHideFrameSub, mnuIdx);
	if self.dkcLeftMain.visible then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
