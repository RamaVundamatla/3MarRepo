    <JadeMethod name="addError" id="cf80ce87-9a45-4050-95f0-835be4d9f032">
        <source>addError(_errorNum : Integer; _errorDescr : String; _errorMsgs : DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	error		: DTO_HandHeldGateError;
begin
	create error transient;
	if _errorMsgs.includesKey(_errorNum) then
		return;
	endif;
	
	error.errorNo := _errorNum;
	error.errorDescr := _errorDescr;
	_errorMsgs.add(error);

end;


</source>
        <access>protected</access>
        <Parameter name="_errorNum" type="Integer"/>
        <Parameter name="_errorDescr" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bindMediator" id="36c2a13e-0c41-44c3-8d31-cb1840307f44">
        <updating/>
        <source>bindMediator() : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 Oct 2006	cnwer1	Initial creation - PAR#xxxx
14 Oct 2010 cnwer1	PAR  26011
*/
vars

	mediator	: CM_RadioTelemetryMediator;
	deviceID	: Integer;
	rtnValue	: Boolean;

begin
	
	//need to handle the errors and add to passport par 26011 14/10/10
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	app.setContinueCMExceptions(true);
	
	rtnValue:=true;

	if self.myTerminal = null then
		app.raiseCMException1(UnableToBindMediator, 'Invalid Terminal', null, null);
		return false;
	endif;
	
	
	if self.myRTDevice = null then
		// Problem.
		app.raiseCMException1(UnableToBindMediator, 'Invalid Device', null, null);
		return false;
	endif;

	if self.myMediator &lt;&gt; null then
		if self.myMediator.device &lt;&gt; self.myRTDevice or self.myMediator.myActiveTerminal &lt;&gt; self.myTerminal then
			app.raiseCMException1(UnableToBindMediator, 'Invalid pre existing mediator set up', null, null);
			// Raise exception;
			return false;
		endif;
		
		mediator := self.myMediator;
		return true;
	endif;

	//epr par 26011
	if not self.checkDeviceID then
		return false;
	endif;
	// Is there a mediator left in an invalid state.
	
	deviceID:=self.myRTDevice.id.Integer;
	
	
	// TFS #43007 - Remove Teklogix	jlgmd1 22/01/19
	//epr par  33346 22/1/13
	/*if self.myRTDevice.mySession &lt;&gt; null then
		app.raiseCMException1(UnableToBindMediator, 'Device is part of a Teklogix RT Interface session ' &amp;  self.myRTDevice.mySession.interface.id &amp; " " &amp; self.myRTDevice.mySession.id, null, null);
		return false;
	endif;
	*/
	
	
	mediator := self.myTerminal.allActiveMediators[deviceID].CM_RadioTelemetryMediator;

	beginTransaction;	
	if mediator = null then
		create self.myMediator persistent;
	
	else
		/**********************************************************/
		// Need to write code here to see what state mediator is in.
		// Check it against the passed in parameters.
		self.myMediator := mediator;
		rtnValue := true;
	endif;
	
	self.myMediator.setAttributesForRadioTelemetry(self.myRTDevice, deviceID,self.user);
	self.myMediator.setActiveTerminal(self.myTerminal);
	self.myMediator.setTwinTasks(true);
	self.myMediator.setCanBeAllocatedMixedTasks(true); //cnwrd1 32293
	

	commitTransaction;
	
	if self.myMediator.machine = null then
		app.raiseCMException1(UnableToBindMediator, 'Machine is null', null, null);
		return false;
	endif;

	return rtnValue;


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
