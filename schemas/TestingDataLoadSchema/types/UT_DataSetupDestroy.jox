    <JadeMethod name="processDelayTypes" id="da23096f-68b4-4c09-bc46-073ae3a0b7de">
        <source>processDelayTypes(_delayTypeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the carrier details

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	isRoad					: Boolean;
	isRail					: Boolean;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'pinEmailAddresses	: CM_EmailEntityByTypeNameDict;';

	epilogStr := CrLf &amp; Tab &amp; 'delete pinEmailAddresses;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create pinEmailAddresses transient;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _delayTypeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Creating Delay Type " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Delay Type " &amp; xmlElement.tagName &amp; ".  Please wait...";

		optsElement := xmlElement.getElementByTagName('opts');
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(optsElement, codeStr);
		endif;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addDelayType(' &amp; description &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_delayTypeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDeleteStops" id="0bb8eeee-ebc4-4632-b7a5-04023478d663">
        <source>processDeleteStops(_stopsXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Either delete all stops or specified stops for a cargo item

Date			Who		Reason
15/11/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlAttribute			: JadeXMLAttribute;
		
	obj						: Object;
	
	isoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
		
begin

	varsStr := varsStr &amp; 'ti					: CM_TrackedItem;' &amp; CrLf &amp; CrLf;

	foreach obj in _stopsXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Deleting Stop(s).  Please wait...", LogINFO);
		write "Deleting Stop(s).  Please wait...";
		
		optsElement := xmlElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		xmlAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; xmlAttribute.value &amp; '");' &amp; CrLf;
		
		// get any stops that need ot be deleted
		xmlElement2 := xmlElement.getElementByTagName("stopsToDelete");
		
		if xmlElement2 = null then
			// want to delete all the stops on the tracked item
			codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem("' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp;
				Tab &amp; 'if ti &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; '    self.deleteStops(ti);' &amp; CrLf &amp;
				Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
		else
			// only delete the specified stops
		endif;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete isoTypesArray;
end;
</source>
        <Parameter name="_stopsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDeleteTrains" id="16e31008-e01a-4987-88cf-eaf1f7866ee4">
        <source>processDeleteTrains(_trainElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Will delete a train and all it's wagon, cargo, etc.....

Date			Who		Reason
17/03/2018		jlgmh5	Initial creation

*/

vars

	element				: JadeXMLElement;
	elementItem				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	bookingItemElement		: JadeXMLElement;
	element2				: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	isContainer				: Boolean;
	
begin
	
	varsStr := varsStr &amp; CrLf &amp;	Tab &amp; 'train				: CM_Train;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf&amp; CrLf;
		
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
	
	foreach obj in _trainElement.childNodes do
		element := obj.JadeXMLElement;
				
		optsElement := element.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		attribute := element.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp; 
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; attribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq("' &amp; element.tagName &amp; '",null);' &amp; CrLf &amp;
			Tab &amp; 'if train = null then' &amp; CrLf &amp;
			Tab &amp; '	train := app.myPassport.myTerminal.allTrainsDeparted.getAtKeyGeq("' &amp; element.tagName &amp; '", null);' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf &amp;
			Tab &amp; 'if train &lt;&gt; null then' &amp; CrLf &amp;
			Tab &amp; '	self.deleteTrainAndAssociatedObjs(train);' &amp; CrLf &amp;
			Tab &amp; '	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_trainElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDischLoadJobToOps" id="19c43414-c688-4ec2-af3f-f003c07a4b43">
        <updating/>
        <source>processDischLoadJobToOps(_dlJobToOpsXMLElement : JadeXMLElement; _methodStr : String io) updating;

/*

Purpose:		Create required color coding and job

Date			Who		Reason
04/12/2017		jlgmh5	Initial creation

criterial (CM_YACriteriaType)
=============================
Availability Grade							= 1
Cargo Type									= 2
Release Carrier								= 3
Clean										= 4
Commodity									= 5
Commodity Group								= 6
Communicating/Non-Communicating Reefer		= 7
Consignee									= 8
Consignor									= 9
Discharge Port								= 10
Hazardous									= 11
Heavy Duty									= 12
IMEX Status									= 13
ISO Type									= 14
ISO Group									= 15
Is Coastal									= 16
Is Forty									= 17
Is Over Dimensional							= 18
Operator (Item)								= 19
Receive Transport Mode						= 20
Release Transport Mode						= 21
Requires Power								= 22
Rehandles									= 23
Source Terminal Area						= 24
Source Terminal Area Type					= 25
Stops										= 26
To Do Tasks									= 27
Voyage Trade								= 28
Voyage										= 29
Voyage Berth								= 30
Operator (Voyage)							= 31
Voyage Planning Code						= 32
Is Water Cooled								= 33
Weight										= 34
Is TransShip								= 35
Is Hazardous								= 36
Load Port									= 37
Is Forty Five								= 38
Destination Port							= 39
Release Request								= 40
Freight Forwarder							= 41
Is Controlled Atmosphere					= 42
Is Fifty Three								= 43	
Is Thirty									= 44
Booking										= 45
Cargo Subtype								= 46
Trailer Type								= 47
Is Twenty									= 48
Container Length (cm)						= 49
Is Hazardous Limited Quantity				= 50
Is Hazardous Or Limited Quantity			= 51
Curtains In									= 52
Sub-Terminal								= 53
Train										= 54
Intended Release Mode						= 55
Is Available								= 56
Id											= 57
BOL											= 58
Tranship to Port							= 59
Special Stow								= 61
Weight Flexi								= 62
Cargo Length								= 63
Cargo Width									= 64
Cargo Height								= 65
Special Lift								= 66
Voyage Inbound								= 67
Voyage Outbound								= 68
Is Hazardous Not Limited					= 69
Tranship Discharge Port						= 70
Contents Status								= 71
Destination Terminal						= 72
Is Damaged									= 73
Is Empty									= 74
Is Reefer									= 75
Colour										= 76
Mark										= 77
Vehicle Make								= 78
Vehicle Model								= 79
Vehicle Type								= 80
Year of Manufacture							= 81
New Vehicle									= 82
Number of Doors								= 83	
Self Propelled								= 84
Transaction Type							= 85
Required Temperature						= 86
Cargo Group Id								= 87
Dwell Days Range							= 88
Is Externally Monitored						= 89
Freight Tons								= 90
Is Weight Certified							= 91
Service Order								= 92
Empty Pool Party							= 93
Inbound Ship Operator						= 94
Outbound Ship Operator						= 95
Transit Status								= 96
Is Direct Delivery							= 97

*/

vars

	discLoadXMLElement		: JadeXMLElement;
	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlElement3				: JadeXMLElement;
	xmlElement4				: JadeXMLElement;
	xmlAttribute			: JadeXMLAttribute;
	voyageTypeAttribute		: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	
	obj						: Object;
	voyage					: CM_Voyage;
	yaCriteriaType			: CM_YACriteriaType;
	
	locationsArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	isLoadJob				: Boolean;
	location				: String;
	bayId					: String;

begin

	varsStr := CrLf &amp; Tab &amp; 'realAlloc					: CM_VoyageAllocation;' &amp; CrLf &amp; 
		Tab &amp; 'slot							: CM_SlotController;' &amp; CrLf &amp;
		Tab &amp; 'voyageJob					: CM_VoyageJob;' &amp; CrLf &amp;
		Tab &amp; 'voyage						: CM_Voyage;' &amp; CrLf &amp; 
		Tab &amp; 'ti							: CM_TrackedItem;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'roroLCs						: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'altRoroLCs					: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'slots						: CM_SlotControllerArray;' &amp; CrLf &amp;
		Tab &amp; 'altSlots						: CM_SlotControllerArray;' &amp; CrLf &amp; 
		Tab &amp; 'tiArray						: CM_TIArray;' &amp; CrLf &amp; 
		Tab &amp; 'voyageJobArray				: CM_VoyageJobArray;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; 'create roroLCs transient;' &amp; CrLf &amp;
		Tab &amp; 'create altRoroLCs transient;' &amp; CrLf &amp;
		Tab &amp; 'create slots transient;' &amp; CrLf &amp;
		Tab &amp; 'create altSlots transient; ' &amp; CrLf &amp;
		Tab &amp; 'create tiArray transient;' &amp; CrLf &amp; 
		Tab &amp; 'create voyageJobArray transient;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'delete roroLCs;' &amp; CrLf &amp;
		Tab &amp; 'delete altRoroLCs;' &amp; CrLf &amp;
		Tab &amp; 'delete slots;' &amp; CrLf &amp;
		Tab &amp; 'delete altSlots;' &amp; CrLf &amp;
		Tab &amp; 'delete tiArray;' &amp; CrLf &amp; 
		Tab &amp; 'delete voyageJobArray;' &amp; CrLf;
		
	create locationsArray transient;

	foreach obj in _dlJobToOpsXMLElement.childNodes do
		discLoadXMLElement := obj.JadeXMLElement;
		
		// set any opts
		optsElement := discLoadXMLElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		// get the terminal
		xmlAttribute := discLoadXMLElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; xmlAttribute.value &amp; '");' &amp; CrLf;
		
		// check whether load or discharge
		isLoadJob := discLoadXMLElement.tagName.toUpper() = "Load".toUpper();
		
		write 'isLoadJob: ' &amp; isLoadJob.String;
		
		foreach obj in discLoadXMLElement.childNodes do
			xmlElement := obj.JadeXMLElement;
			write xmlElement.tagName;
			
			if xmlElement.tagName = "colorCodeCriteriasLocs" then
				foreach obj in xmlElement.childNodes do
					xmlElement2 := obj.JadeXMLElement;
					write Tab &amp; xmlElement2.tagName;
					foreach obj in xmlElement2.childNodes do	
						xmlElement3 := obj.JadeXMLElement;
						write Tab &amp; Tab &amp; xmlElement3.tagName;
						if xmlElement3.tagName = "criterias" then
							foreach obj in xmlElement3.childNodes do
								xmlElement4 := obj.JadeXMLElement;
								write Tab &amp; Tab &amp; Tab &amp; xmlElement4.tagName;
								xmlAttribute := xmlElement4.getAttributeByName("Type");
								yaCriteriaType := app.myRoot.allYACriteriaTypes[xmlAttribute.value.Integer];
								codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; yaCriteriaType.description &amp; '", ' &amp; self.returnElementText(xmlElement4).String &amp; ');' &amp; CrLf;		
							endforeach;
							codeStr := codeStr &amp; Tab &amp; 'realAlloc := self.addVoyageAllocation(voyage);' &amp; CrLf &amp; CrLf &amp;
								Tab &amp; 'roroLCs.clear();' &amp; CrLf &amp;
								Tab &amp; 'altRoroLCs.clear();' &amp; CrLf &amp;
								Tab &amp; 'slots.clear();' &amp; CrLf &amp;
								Tab &amp; 'altSlots.clear();' &amp; CrLf &amp; CrLf;
						elseif xmlElement3.tagName = "locations" then
							locationsArray.clear();
							xmlElement4 := xmlElement.getElementByTagName("locationsToColorCode");
							location := self.returnElementText(xmlElement3).String;
							location.getTokensForDelimiter(";", locationsArray);
							foreach location in locationsArray do
								// get the locations
								bayId := location[1:2];
								codeStr := codeStr &amp; Tab &amp; 'slot := self.getJobLOLOControllerByID(voyage.code, "' &amp; bayId &amp; '", "' &amp; location &amp; '");' &amp; CrLf &amp;
									Tab &amp; 'slots.add(slot);' &amp; CrLf;
							endforeach;
							codeStr := codeStr &amp; Tab &amp; 'self.addLCsToLOLOAllocation(' &amp; isLoadJob.String &amp; '.Boolean, realAlloc, slots, altSlots);' &amp; CrLf;
						endif;
					endforeach;
				endforeach;
			elseif xmlElement.tagName = "jobs" then
				///self.processJobs(xmlElement, codeStr);
				
			elseif xmlElement.tagName = "voyage" then
				voyageTypeAttribute := xmlElement.getAttributeByName("Type");
				codeStr := codeStr &amp; Tab &amp; 'voyage := self.getVoyage(' &amp; self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
				voyage := self.getVoyage(self.returnElementText(xmlElement).String);
			endif;
		
		endforeach;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

		delete locationsArray;
		
end;
</source>
        <Parameter name="_dlJobToOpsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDischargeJobToOps" id="57e6955f-1b96-45ea-aaa0-42b37e9686a2">
        <updating/>
        <source>processDischargeJobToOps(_dischargeXMLElement : JadeXMLElement; _methodStr : String io) updating;

/*

Purpose:		Create discharge color coding, jobs, and send to ops

Date			Who		Reason
05/12/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlElement3				: JadeXMLElement;
	voyageTypeAttribute		: JadeXMLAttribute;
	xmlAttribute			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	jobDischOpsElement	:	 JadeXMLElement;
		
	obj						: Object;
	
	locationsArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	location				: String;
	bayId					: String;
	craneId					: String;
	alreadyDischargeCC		: Boolean;
		
begin

	varsStr := "voyage						: CM_Voyage;" &amp; CrLf &amp; 
		Tab &amp; 'slot							: CM_SlotController;' &amp; CrLf &amp;
		Tab &amp; 'wle							: CM_WorkListEntry;' &amp; CrLf &amp;
		Tab &amp; 'voyageJob					: CM_VoyageJob;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'roroLCs						: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'altRoroLCs					: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'slots						: CM_SlotControllerArray;' &amp; CrLf &amp;
		Tab &amp; 'altSlots						: CM_SlotControllerArray;' &amp; CrLf &amp; 
		Tab &amp; 'tiArray						: CM_TIArray;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'voyageJobArray				: CM_VoyageJobArray;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; 'create roroLCs transient;' &amp; CrLf &amp;
		Tab &amp; 'create altRoroLCs transient;' &amp; CrLf &amp;
		Tab &amp; 'create slots transient;' &amp; CrLf &amp;
		Tab &amp; 'create altSlots transient; ' &amp; CrLf &amp;
		Tab &amp; 'create tiArray transient;' &amp; CrLf &amp; 
		Tab &amp; 'create voyageJobArray transient;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'delete roroLCs;' &amp; CrLf &amp;
		Tab &amp; 'delete altRoroLCs;' &amp; CrLf &amp;
		Tab &amp; 'delete slots;' &amp; CrLf &amp;
		Tab &amp; 'delete altSlots;' &amp; CrLf &amp;
		Tab &amp; 'delete tiArray;' &amp; CrLf &amp; 
		Tab &amp; 'delete voyageJobArray;' &amp; CrLf;	
		
	create locationsArray transient;

	foreach obj in _dischargeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;

		// set any opts
		optsElement := xmlElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		// get the terminal
		xmlAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; xmlAttribute.value &amp; '");' &amp; CrLf;
		
		// get the voyage
		xmlElement2 := xmlElement.getElementByTagName("voyage");
		voyageTypeAttribute := xmlElement2.getAttributeByName("Type");
		codeStr := codeStr &amp; Tab &amp; 'voyage := self.getVoyage(' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;
				
		if not alreadyDischargeCC and voyageTypeAttribute.value.toUpper() = "LOLO".toUpper() then
			codeStr := codeStr &amp; Tab &amp; "self.voyageDischargeColourCode(voyage);" &amp; CrLf &amp; CrLf;
			alreadyDischargeCC := true;
		endif;
		
		// create the discharge jobs
		jobDischOpsElement := xmlElement.getElementByTagName("jobs");
		foreach obj in jobDischOpsElement.childNodes do
			xmlElement2 := obj.JadeXMLElement;
			
			craneId := self.returnElementText(xmlElement2.getElementByTagName("crane")).String;
			
			// get the locations to add to the job
			if voyageTypeAttribute.value.toUpper() = "LOLO".toUpper() then

				// get the slots to color code
				locationsArray.clear();
				xmlElement3 :=  xmlElement2.getElementByTagName("locations");
				location := self.returnElementText(xmlElement3).String;
				location.getTokensForDelimiter(";", locationsArray);
				foreach location in locationsArray do
					// get the locations
					bayId := location[1:2];
					codeStr := codeStr &amp; Tab &amp; 'slot := self.getJobLOLOControllerByID(voyage.code, "' &amp; bayId &amp; '", "' &amp; location &amp; '");' &amp; CrLf &amp;
						Tab &amp; 'slots.add(slot);' &amp; CrLf;
				endforeach;
				codeStr := codeStr &amp; Tab &amp; 'voyageJob := self.addVoyageJob(voyage, ' &amp; craneId &amp; ', slots, true);' &amp; CrLf &amp; 
					Tab &amp; 'voyageJobArray.add(voyageJob);' &amp; CrLf &amp; CrLf;
			endif;
			
			xmlElement3 := xmlElement2.getElementByTagName("loadToJobOps");
			if xmlElement3 &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("JobsToSendToOps", voyageJobArray);' &amp; CrLf &amp;
					Tab &amp; 'self.loadAllJobsToOps(voyage, true);' &amp; CrLf &amp; CrLf;
			endif;
			
			xmlElement3 :=  xmlElement2.getElementByTagName("queueToInJobOps");
			if xmlElement3 &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'foreach voyageJob in voyageJobArray do' &amp; CrLf &amp;
					Tab &amp; '	foreach wle in voyageJob.workListEntries do' &amp; CrLf &amp;
					Tab &amp; '		self.queueWLE(wle);' &amp; CrLf &amp;
					Tab &amp; '	endforeach;' &amp; CrLf &amp;
					Tab &amp; 'endforeach;' &amp; CrLf &amp; CrLf;
			endif;
				
		endforeach;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

	delete locationsArray;

end;
</source>
        <Parameter name="_dischargeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processEDIFiles" id="7541c917-eed1-4f66-84b9-2f19de746386">
        <source>processEDIFiles(_methodStr : String io);

/*

Purpose:		Process EDI Files

Date			Who		Reason
19/10/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	obj						: Object;
	fileFolder				: FileFolder;
	fileNode				: FileNode;
	
	xmlDocumentParser		: JadeXMLDocumentParser;
	xmlDocument				: JadeXMLDocument;
	rootElement 			: JadeXMLElement;
	
	opsToPerformArray		: StringArray;
	opsToPerformStatusArray	: StringArray;
	tempStrArray			: StringArray;
	tokens					: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	tempStr					: String;
	tempStr2				: String;
	userDefName				: String;
	pos						: Integer; 
	opsToPerform			: String;
	opsToPerformStatus		: String;
	indexOf					: Integer;
	tiIds					: String;
	tiId					: String;
	
begin
	
	on FileException do app.fileExceptionHandler(exception);
	
	varsStr := varsStr &amp; Tab &amp; 'ti					: CM_TrackedItem;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'ediFileObj 				: CM_EDIFile;' &amp; CrLf &amp; 
		Tab &amp; 'passportObj 				: CM_Passport;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'opsToPerformArray		: StringArray;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'ediText					: String;' &amp; CrLf &amp; 
		Tab &amp; 'tempStr					: String; ' &amp; CrLf &amp;
		Tab &amp; 'tiId						: String;' &amp; CrLf &amp;
		Tab &amp; 'errorMsg 				: String;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; 'self.opts.purge();' &amp; CrLf;
	
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
	
	create tokens transient;
	create opsToPerformArray transient;
	create opsToPerformStatusArray transient;
	
	create fileFolder transient;
	fileFolder.fileName := DataLoadedCopyFromEDIFiles &amp; "\";
	//"D:\TestingDataLoad\DataToBeLoaded\EDIFiles\";
	fileFolder.usePresentationFileSystem := true;
	fileFolder.mask := "*.xml";
	
	foreach fileNode in fileFolder.files do
	
		//parse xml into doc
		delete xmlDocumentParser;
		create xmlDocumentParser transient;
		delete xmlDocument;
		create xmlDocument transient;
		xmlDocumentParser.parseDocumentFile(xmlDocument, fileNode.fileName);
		rootElement := xmlDocument.rootElement;
		rootElement := rootElement.childNodes.first.JadeXMLElement;
		
		userDefName := fileNode.fileName;
		pos := 1;
		pos := userDefName.reversePos("\");
		userDefName := userDefName[pos+1:end];
		pos := 1;
		pos := userDefName.reversePos(".");
		userDefName := userDefName[1:pos - 1];
		userDefName := userDefName[1:end];
		
		create tempStrArray transient;
		
		// setup delete for all tracked items
		foreach obj in rootElement.childNodes do
			xmlElement := obj.JadeXMLElement;
			
			if xmlElement.tagName = 'operationsToPerform' then
				opsToPerform := self.returnElementText(xmlElement).String;
				opsToPerform := opsToPerform.replaceString('"', '');
				//create opsToPerformArray transient;
				opsToPerformArray.clear();
				opsToPerform.getTokensForDelimiter(";", opsToPerformArray);
				continue;
			elseif xmlElement.tagName = 'operationsToPerformStatuses' then
				opsToPerformStatus := self.returnElementText(xmlElement).String;
				opsToPerformStatus := opsToPerformStatus.replaceString('"', '');
				//create opsToPerformStatusArray transient;
				opsToPerformStatusArray.clear();
				opsToPerformStatus.getTokensForDelimiter(";", opsToPerformStatusArray);
				continue;
			endif;
			
			codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
			terminalAttribute := xmlElement.getAttributeByName("Terminal");
			codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
				Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
				
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
			
			// delete the tis
			tiIds := self.returnElementText(xmlElement.getElementByTagName('id')).String;
			if tiIds = null or tiIds = 'true' then
				tiIds := self.returnElementText(xmlElement.getElementByTagName('ids')).String;
				if tiIds = 'true' then
					tiIds := null;
				endif;
			endif;
			
			tokens.clear();
			tiIds.getTokensForDelimiter(CrLf, tokens);
			foreach tiId in tokens do
				codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem(' &amp; tiId &amp; ');' &amp; CrLf &amp;
					Tab &amp; 'self.deleteTrackedItem(ti, false);' &amp; CrLf &amp; CrLf;
			endforeach;
			
			
			
				//Tab &amp; 'tiId := self.getTrackedItem(' &amp; self.returnElementText(xmlElement.getElementByTagName('id')).String &amp; ');' &amp; CrLf &amp;
				//Tab &amp; 'ti := self.getTrackedItem(' &amp; self.returnElementText(xmlElement.getElementByTagName('id')).String &amp; ');' &amp; CrLf &amp;
			//	Tab &amp; 'self.deleteTrackedItem(ti, false);' &amp; CrLf &amp; CrLf;
			
		endforeach;
		
		// load the file to edi operations
		codeStr := codeStr &amp; Tab &amp; 'passportObj	:=	app.myPassport;' &amp; CrLf &amp;
			Tab &amp; "ediText := '" &amp; xmlDocument.writeToString() &amp; "';" &amp; CrLf &amp;
			//Tab &amp; 'delete ediFileObj;' &amp; CrLf &amp;
			Tab &amp; 'ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, "' &amp; userDefName &amp; '", "' &amp; userDefName &amp; '1'  &amp; method.name &amp; '");' &amp; CrLf;
		
		// need to verify the details just loaded
		indexOf := opsToPerformArray.indexOf("Verify");
		if indexOf &gt; 0 then
		
			// work out what statuses are to be checked for
			tempStrArray.clear();
			tempStr2 := null;
			tempStr := null;
			opsToPerformStatusArray[indexOf].getTokensForDelimiter("/", tempStrArray);
			foreach tempStr2 in tempStrArray do
				tempStr := tempStr &amp; ", CM_EDIFile." &amp; tempStr2.trimBlanks();
			endforeach;
			
			codeStr := codeStr &amp; Tab &amp; 'self.ediVerify(ediFileObj);' &amp; CrLf &amp;
				Tab &amp; 'errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();' &amp; CrLf &amp;
				Tab &amp; 'self.assertIsOneOf(	ediFileObj.fileStatus, errorMsg' &amp; tempStr &amp; ');' &amp; CrLf &amp; CrLf;
			
		endif;
		
		// need to Load to DB the details just loaded
		indexOf := opsToPerformArray.indexOf("Load To DB");
		if indexOf &gt; 0 then
		
			// work out what statuses are to be checked for
			tempStrArray.clear();
			tempStr2 := null;
			opsToPerformStatusArray[indexOf].getTokensForDelimiter("/", tempStrArray);
			foreach tempStr2 in tempStrArray do
				tempStr := tempStr &amp; ", CM_EDIFile." &amp; tempStr2.trimBlanks();
			endforeach;
			
			codeStr := codeStr &amp; Tab &amp; 'self.ediDBLoad(ediFileObj);' &amp; CrLf &amp;
				Tab &amp; 'errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();' &amp; CrLf &amp;
				Tab &amp; 'self.assertIsOneOf(ediFileObj.fileStatus, errorMsg' &amp; tempStr &amp; ');' &amp; CrLf &amp; CrLf;
			
		endif;
		
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
	//write 'varsStr: ' &amp; varsStr;
	//write 'codeStr: ' &amp; codeStr;
	//write 'epilogStr: ' &amp; epilogStr;
	
epilog

	delete xmlDocumentParser;
	delete xmlDocument;

	delete opsToPerformArray;
	delete opsToPerformStatusArray;
	delete tempStrArray;
	delete tokens;
	
	
end;
</source>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processEDIFilesAutomation" id="0bb805f7-60b2-496c-ab48-6b85715c3a3c">
        <source>processEDIFilesAutomation(_ediFileXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Process EDI Files

Date			Who		Reason
19/10/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	obj						: Object;
	fileFolder				: FileFolder;
	fileNode				: FileNode;
	
	xmlDocumentParser		: JadeXMLDocumentParser;
	xmlDocument				: JadeXMLDocument;
	rootElement 			: JadeXMLElement;
	
	opsToPerformArray		: StringArray512;
	opsToPerformStatusArray	: StringArray512;
	tempStrArray			: StringArray512;
	tokens					: StringArray512;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	tempStr					: String;
	tempStr2				: String;
	userDefName				: String;
	pos						: Integer; 
	opsToPerform			: String;
	opsToPerformStatus		: String;
	indexOf					: Integer;
	tiIds					: String;
	tiId					: String;
	posEDI					: Integer;
	deleteTrackedItems		: Boolean;
	xmlDocAsString			: String;
	
begin
	
	on FileException do app.fileExceptionHandler(exception);
	
	varsStr := varsStr &amp; Tab &amp; 'ti					: CM_TrackedItem;' &amp; CrLf &amp; 
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'ediFileObj 				: CM_EDIFile;' &amp; CrLf &amp; 
		Tab &amp; 'passportObj 				: CM_Passport;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'opsToPerformArray		: StringArray;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'ediText					: String;' &amp; CrLf &amp; 
		Tab &amp; 'tempStr					: String; ' &amp; CrLf &amp;
		Tab &amp; 'tiId						: String;' &amp; CrLf &amp;
		Tab &amp; 'errorMsg 				: String;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; 'self.opts.purge();' &amp; CrLf;
	
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
	
	create tokens transient;
	create opsToPerformArray transient;
	create opsToPerformStatusArray transient;
	
	 
	
	
	///create fileFolder transient;
	///fileFolder.fileName := DataLoadedCopyFromEDIFiles &amp; "\";
	//"D:\TestingDataLoad\DataToBeLoaded\EDIFiles\";
	///fileFolder.usePresentationFileSystem := true;
	///fileFolder.mask := "*.xml";
	
	///foreach fileNode in fileFolder.files do
	
		// Need to get the fileName and  reset methodStr
		posEDI := 1;
		posEDI := _methodStr.pos("&lt;EDI&gt;", posEDI);
		if posEDI = 0 then
			return;
		endif;
		userDefName := _methodStr[1:posEDI - 1];
		
		pos := 1;
		pos := _methodStr.pos("&gt;", pos);
		if pos = 0 then
			return;
		endif;
		_methodStr := _methodStr[pos + 1:end];
	
		//parse xml into doc
		delete xmlDocumentParser;
		create xmlDocumentParser transient;
		delete xmlDocument;
		create xmlDocument transient;
		//xmlDocumentParser.parseDocumentFile(xmlDocument, fileNode.fileName);
		xmlDocumentParser.parseDocumentFile(xmlDocument, userDefName);
		rootElement := xmlDocument.rootElement;
		rootElement := rootElement.childNodes.first.JadeXMLElement;
		///rootElement := _ediFileXMLElement.childNodes.first.JadeXMLElement;
		
		deleteTrackedItems := false;
		xmlDocAsString := xmlDocument.writeToString;
		if xmlDocAsString.cnContains("CargoOn") and xmlDocAsString.cnContains("&lt;messageMode&gt;D&lt;/messageMode&gt;") then
			deleteTrackedItems := true;
		endif;
		
		
		//userDefName := fileNode.fileName;
		pos := 1;
		pos := userDefName.reversePos("\");
		userDefName := userDefName[pos+1:end];
		pos := 1;
		pos := userDefName.reversePos(".");
		userDefName := userDefName[1:pos - 1];
		userDefName := userDefName[1:end];
		
		create tempStrArray transient;
		
		// setup delete for all tracked items
		foreach obj in rootElement.childNodes do
			xmlElement := obj.JadeXMLElement;
			
			if xmlElement.tagName = 'operationsToPerform' then
				opsToPerform := self.returnElementText(xmlElement).String;
				opsToPerform := opsToPerform.replaceString('"', '');
				//create opsToPerformArray transient;
				opsToPerformArray.clear();
				opsToPerform.getTokensForDelimiter(";", opsToPerformArray);
				continue;
			elseif xmlElement.tagName = 'operationsToPerformStatuses' then
				opsToPerformStatus := self.returnElementText(xmlElement).String;
				opsToPerformStatus := opsToPerformStatus.replaceString('"', '');
				//create opsToPerformStatusArray transient;
				opsToPerformStatusArray.clear();
				opsToPerformStatus.getTokensForDelimiter(";", opsToPerformStatusArray);
				continue;
			endif;
			
			codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
			terminalAttribute := xmlElement.getAttributeByName("Terminal");
			codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
				Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
				
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
			
			// delete the tis
			if deleteTrackedItems then
				tiIds := self.returnElementText(xmlElement.getElementByTagName('id')).String;
				if tiIds = null or tiIds = 'true' then
					tiIds := self.returnElementText(xmlElement.getElementByTagName('ids')).String;
					if tiIds = 'true' then
						tiIds := null;
					endif;
				endif;
				
				tokens.clear();
				tiIds.getTokensForDelimiter(CrLf, tokens);
				foreach tiId in tokens do
					codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem(' &amp; tiId &amp; ');' &amp; CrLf &amp;
						Tab &amp; 'self.deleteTrackedItem(ti, false);' &amp; CrLf &amp; CrLf;
				endforeach;
			
			endif;
			
				//Tab &amp; 'tiId := self.getTrackedItem(' &amp; self.returnElementText(xmlElement.getElementByTagName('id')).String &amp; ');' &amp; CrLf &amp;
				//Tab &amp; 'ti := self.getTrackedItem(' &amp; self.returnElementText(xmlElement.getElementByTagName('id')).String &amp; ');' &amp; CrLf &amp;
			//	Tab &amp; 'self.deleteTrackedItem(ti, false);' &amp; CrLf &amp; CrLf;
			
		endforeach;
		
		// load the file to edi operations
		codeStr := codeStr &amp; Tab &amp; 'passportObj	:=	app.myPassport;' &amp; CrLf &amp;
			Tab &amp; "ediText := '" &amp; xmlDocument.writeToString() &amp; "';" &amp; CrLf &amp;
			//Tab &amp; 'delete ediFileObj;' &amp; CrLf &amp;
			Tab &amp; 'ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, "' &amp; userDefName &amp; '", "' &amp; userDefName &amp; '1'  &amp; method.name &amp; '");' &amp; CrLf;
		
		// need to verify the details just loaded
		indexOf := opsToPerformArray.indexOf("Verify");
		if indexOf &gt; 0 then
		
			// work out what statuses are to be checked for
			tempStrArray.clear();
			tempStr2 := null;
			tempStr := null;
			opsToPerformStatusArray[indexOf].getTokensForDelimiter("/", tempStrArray);
			foreach tempStr2 in tempStrArray do
				tempStr := tempStr &amp; ", CM_EDIFile." &amp; tempStr2.trimBlanks();
			endforeach;
			
			codeStr := codeStr &amp; Tab &amp; 'self.ediVerify(ediFileObj);' &amp; CrLf &amp;
				Tab &amp; 'errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();' &amp; CrLf &amp;
				Tab &amp; 'self.assertIsOneOf(	ediFileObj.fileStatus, errorMsg' &amp; tempStr &amp; ');' &amp; CrLf &amp; CrLf;
			
		endif;
		
		// need to Load to DB the details just loaded
		indexOf := opsToPerformArray.indexOf("Load To DB");
		if indexOf &gt; 0 then
		
			// work out what statuses are to be checked for
			tempStrArray.clear();
			tempStr2 := null;
			opsToPerformStatusArray[indexOf].getTokensForDelimiter("/", tempStrArray);
			foreach tempStr2 in tempStrArray do
				tempStr := tempStr &amp; ", CM_EDIFile." &amp; tempStr2.trimBlanks();
			endforeach;
			
			codeStr := codeStr &amp; Tab &amp; 'self.ediDBLoad(ediFileObj);' &amp; CrLf &amp;
				Tab &amp; 'errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();' &amp; CrLf &amp;
				Tab &amp; 'self.assertIsOneOf(ediFileObj.fileStatus, errorMsg' &amp; tempStr &amp; ');' &amp; CrLf &amp; CrLf;
			
		endif;
		
	///endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
	//write 'varsStr: ' &amp; varsStr;
	//write 'codeStr: ' &amp; codeStr;
	//write 'epilogStr: ' &amp; epilogStr;
	
epilog

	delete xmlDocumentParser;
	delete xmlDocument;

	delete opsToPerformArray;
	delete opsToPerformStatusArray;
	delete tempStrArray;
	delete tokens;
	
	
end;
</source>
        <Parameter name="_ediFileXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processEmailAddresses" id="1563020c-f101-4cc9-a39c-ca7a698b1c47">
        <source>processEmailAddresses(_emailAddressXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the email address

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	address					: String;	
	name					: String;
	
begin

	codeStr := codeStr &amp; CrLf;

	foreach obj in _emailAddressXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		name := self.returnElementText(xmlElement.getElementByTagName('name')).String;
		address := self.returnElementText(xmlElement.getElementByTagName('address')).String;
		codeStr := codeStr &amp; Tab &amp; 'self.addEmailAddress(' &amp; name &amp; ', ' &amp; address &amp; ');' &amp; CrLf; 
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_emailAddressXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGateInCargo" id="cac996f4-f80d-493b-bed6-a7d4c0df04d9">
        <source>processGateInCargo(_gateInXMLElement : JadeXMLElement; _methodStr : String io);

//	07/11/2017	jlgmh5		Initial creation

vars


	xmlElement				: JadeXMLElement;
	regoElement				: JadeXMLElement;
	cargoElement			: JadeXMLElement;
	terminalAttrib			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	vehicleElement			: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	cargoType				: String;
	driverName				: String;
	state					: String;
	gate					: String;	
	isoType					: String;
	operator				: String;
	commodity				: String;
	quantity				: String;
	rego					: String;
	carrier					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'gateEntity			: CMGTE_Entity;' &amp; CrLf &amp;
		Tab &amp; 'pxyVvr				: CM_VehicleVisitRecord;' &amp; CrLf &amp;
		Tab &amp; 'vvr					: CM_VehicleVisitRecord;' &amp; CrLf &amp; 
		Tab &amp; 'ti 					: CM_TrackedItem;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'expectErrors 		: Boolean;' &amp; CrLf &amp; CrLf;
		
	////codeStr := codeStr &amp; Tab &amp; "expectErrors := true;" &amp; CrLf &amp; CrLf;
		
	epilogStr := Tab &amp; 'delete pxyVvr;' &amp; CrLf;
		
	foreach obj in _gateInXMLElement.childNodes do
		vehicleElement := obj.JadeXMLElement;
		app.writeLog("Gating In for  " &amp; vehicleElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Gating In for " &amp; vehicleElement.tagName &amp; ".  Please wait...";
		
		terminalAttrib := vehicleElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;		// required for addVehicleVisitRecord
					
		// get the registraion details
		regoElement := vehicleElement.getElementByTagName("Registration");
		driverName := self.returnElementText(regoElement.getElementByTagName("driverName")).String;
		state := self.returnElementText(regoElement.getElementByTagName("state")).String;
		gate := self.returnElementText(regoElement.getElementByTagName("gate")).String;
		rego := self.returnElementText(regoElement.getElementByTagName("rego")).String;
		carrier := self.returnElementText(regoElement.getElementByTagName("carrier")).String;
		
		if carrier &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Carrier", ' &amp; carrier &amp; ');' &amp; CrLf &amp; CrLf;
		endif;
		
		// delete the vehicle
		codeStr := codeStr &amp; Tab &amp; 'self.deleteVehicle("' &amp; rego &amp; '");' &amp; CrLf &amp; CrLf;
		
		// Create the Vehicle Visit Record
		codeStr := codeStr &amp; Tab &amp; 'vvr := self.addVehicleVisitRecord("' &amp; rego &amp; '", ' &amp; state &amp; ', ' &amp;
			driverName &amp; ', ' &amp; gate &amp; ');' &amp; CrLf &amp;
			Tab &amp; 'self.assertNoTrxErrorsOrWarnings();' &amp; CrLf &amp;
			Tab &amp; 'if vvr = null then' &amp; CrLf &amp;
			Tab &amp; '	return;' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
		
		// get cargo details
		cargoElement := vehicleElement.getElementByTagName("Cargo");
		foreach obj in cargoElement.childNodes do
			xmlElement := obj.JadeXMLElement;
			
			// sort out opts
			optsElement := xmlElement.getElementByTagName('opts');
			if optsElement &lt;&gt; null then
				self.setupOptsAssoc(optsElement, codeStr);
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			else
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			endif;
					
			// delete the tracked item
			codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem("' &amp;  xmlElement.tagName &amp; '");' &amp; CrLf &amp;
				Tab &amp; 'self.deleteTrackedItem(ti, false);' &amp; CrLf &amp; CrLf;
					
			cargoType := self.returnElementText(xmlElement.getElementByTagName("cargoType")).String;
			commodity := self.returnElementText(xmlElement.getElementByTagName("commodity")).String;
			isoType := self.returnElementText(xmlElement.getElementByTagName("isoType")).String;
			operator := self.returnElementText(xmlElement.getElementByTagName("operator")).String;
			quantity := self.returnElementText(xmlElement.getElementByTagName("quantity")).String;
			
			if quantity.Integer = 0 then
				quantity := 1.String;
			endif;
			
			codeStr := codeStr &amp; Tab &amp; 'gateEntity := self.createGateEntity(vvr, ' &amp; cargoType &amp; ', "' &amp; xmlElement.tagName &amp; '", "' &amp;
				isoType &amp; '", ' &amp; operator &amp; ', ' &amp; commodity &amp; ', ' &amp; quantity &amp; ');' &amp; CrLf &amp; CrLf;
		
		endforeach;
	
		// Complete the Gate In - Road job is created
		codeStr := codeStr &amp; Tab &amp; 'pxyVvr := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;' &amp; CrLf &amp;
			Tab &amp; 'self.ignoreTrxWarnings(true);' &amp; CrLf &amp;
			Tab &amp; 'app.myTrxCA.trxCreateInOutFlexiJob(pxyVvr, vvr, null, app.myPassport);' &amp; CrLf &amp;
			Tab &amp; 'self.assertNoTrxErrors();' &amp; CrLf &amp;
			Tab &amp; 'self.checkTIsForTxnOfType(vvr.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);' &amp; CrLf &amp; CrLf;
			
		// work the vehicle to the yard
		xmlElement := vehicleElement.getElementByTagName("workVehicle");
		if xmlElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.' &amp; xmlElement.tagName &amp; '(vvr);' &amp; CrLf &amp;
				Tab &amp; 'assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);' &amp; CrLf &amp; CrLf;
		endif;
		
		// road exit the vehicle
		xmlElement := vehicleElement.getElementByTagName("roadExit");
		if xmlElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.' &amp; xmlElement.tagName &amp; '(vvr);' &amp; CrLf &amp;
				Tab &amp; 'assertIsDeleted(vvr.myRoadJob);' &amp; CrLf &amp; CrLf;
		endif;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);

epilog

end;
</source>
        <Parameter name="_gateInXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGateInContainers" id="151131fb-f9ea-4c16-89cc-3c735e6dd871">
        <source>processGateInContainers(_gateInXMLElement : JadeXMLElement; _methodStr : String io);

//	29/01/2018	jlgmh5		Initial creation

vars


	xmlElement				: JadeXMLElement;
	regoElement				: JadeXMLElement;
	cargoElement			: JadeXMLElement;
	terminalAttrib			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	cargoType				: String;
	driverName				: String;
	state					: String;
	gate					: String;	
	isoType					: String;
	operator				: String;
	commodity				: String;
	quantity				: String;
	rego					: String;
	carrier					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'vvr					: CM_VehicleVisitRecord;' &amp;
		Tab &amp; 'terminal 				: CM_Terminal;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
		
	foreach obj in _gateInXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Gating In for  " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Gating In for " &amp; xmlElement.tagName &amp; ".  Please wait...";
	
		// get terminal
		terminalAttrib := xmlElement.getAttributeByName("Terminal");
		
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttrib.value &amp; '"]);' &amp; CrLf &amp; CrLf;
					
		// get the registraion details
		regoElement := xmlElement.getElementByTagName("Registration");
		driverName := self.returnElementText(regoElement.getElementByTagName("driverName")).String;
		state := self.returnElementText(regoElement.getElementByTagName("state")).String;
		gate := self.returnElementText(regoElement.getElementByTagName("gate")).String;
		rego := self.returnElementText(regoElement.getElementByTagName("rego")).String;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.deleteVehicle("' &amp; rego &amp; '");' &amp; CrLf &amp; CrLf;
		
		// get cargo details
		cargoElement := xmlElement.getElementByTagName("Cargo");
		foreach obj in cargoElement.childNodes do
			xmlElement2 := obj.JadeXMLElement;
			
			// sort out opts
			optsElement := xmlElement2.getElementByTagName('opts');
			if optsElement &lt;&gt; null then
				self.setupOptsAssoc(optsElement, codeStr);
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			else
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			endif;
			
			operator := self.returnElementText(xmlElement2.getElementByTagName("operator")).String;
			isoType := self.returnElementText(xmlElement2.getElementByTagName("isoType")).String;
			commodity := self.returnElementText(xmlElement2.getElementByTagName("commodity")).String;
			
			// delete the vehicle
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.deleteVehicle("' &amp; rego &amp; '");' &amp; CrLf &amp; CrLf &amp;
				Tab &amp;'vvr := self.gateInContainer("' &amp; rego &amp; '", "' &amp; xmlElement2.tagName &amp; '", "' &amp; isoType &amp; 
					'", ' &amp; operator &amp; ', ' &amp; commodity &amp; ', ' &amp; gate &amp; ');' &amp; CrLf &amp; CrLf; 
			
		endforeach;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);

epilog

end;
</source>
        <Parameter name="_gateInXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGateInGC" id="a000e3aa-0d72-4425-be54-b23a7d45179f">
        <source>processGateInGC(_gateInXMLElement : JadeXMLElement; _methodStr : String io);

//	29/01/2018	jlgmh5		Initial creation

vars


	xmlElement				: JadeXMLElement;
	regoElement				: JadeXMLElement;
	cargoElement			: JadeXMLElement;
	terminalAttrib			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	cargoType				: String;
	driverName				: String;
	state					: String;
	gate					: String;	
	isoType					: String;
	operator				: String;
	commodity				: String;
	quantity				: String;
	rego					: String;
	carrier					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'vvr					: CM_VehicleVisitRecord;' &amp;
		Tab &amp; 'terminal 				: CM_Terminal;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
		
	foreach obj in _gateInXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Gating In for  " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Gating In for " &amp; xmlElement.tagName &amp; ".  Please wait...";
	
		// get terminal
		terminalAttrib := xmlElement.getAttributeByName("Terminal");
		
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttrib.value &amp; '"]);' &amp; CrLf &amp; CrLf;
					
		// get the registraion details
		regoElement := xmlElement.getElementByTagName("Registration");
		driverName := self.returnElementText(regoElement.getElementByTagName("driverName")).String;
		state := self.returnElementText(regoElement.getElementByTagName("state")).String;
		gate := self.returnElementText(regoElement.getElementByTagName("gate")).String;
		rego := self.returnElementText(regoElement.getElementByTagName("rego")).String;
		
		// get cargo details
		cargoElement := xmlElement.getElementByTagName("Cargo");
		foreach obj in cargoElement.childNodes do
			xmlElement2 := obj.JadeXMLElement;
			
			// sort out opts
			optsElement := xmlElement2.getElementByTagName('opts');
			if optsElement &lt;&gt; null then
				self.setupOptsAssoc(optsElement, codeStr);
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			else
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			endif;
			
			
			// delete the vehicle
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.deleteVehicle("' &amp; rego &amp; '");' &amp; CrLf &amp; CrLf &amp;
				Tab &amp;'vvr := self.gateInGCByType("' &amp; rego &amp; '", ' &amp; state &amp; ', ' &amp; driverName &amp; ', ' &amp; gate &amp; ');' &amp; CrLf &amp; CrLf; 
			
		endforeach;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);

epilog

end;
</source>
        <Parameter name="_gateInXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGateInGC2" id="b3265ba4-0683-437e-809f-14202668531b">
        <source>processGateInGC2(_gateInXMLElement : JadeXMLElement; _methodStr : String io);

//	29/01/2018	jlgmh5		Initial creation

vars


	xmlElement				: JadeXMLElement;
	regoElement				: JadeXMLElement;
	cargoElement			: JadeXMLElement;
	terminalAttrib			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	cargoType				: String;
	driverName				: String;
	state					: String;
	gate					: String;	
	isoType					: String;
	operator				: String;
	commodity				: String;
	quantity				: String;
	rego					: String;
	carrier					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'vvr					: CM_VehicleVisitRecord;' &amp;
		Tab &amp; 'terminal 				: CM_Terminal;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
		
	foreach obj in _gateInXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Gating In for  " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Gating In for " &amp; xmlElement.tagName &amp; ".  Please wait...";
	
		// get terminal
		terminalAttrib := xmlElement.getAttributeByName("Terminal");
		
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttrib.value &amp; '"]);' &amp; CrLf &amp; CrLf;
					
		// get the registraion details
		regoElement := xmlElement.getElementByTagName("Registration");
		driverName := self.returnElementText(regoElement.getElementByTagName("driverName")).String;
		state := self.returnElementText(regoElement.getElementByTagName("state")).String;
		gate := self.returnElementText(regoElement.getElementByTagName("gate")).String;
		rego := self.returnElementText(regoElement.getElementByTagName("rego")).String;
		
		// get cargo details
		cargoElement := xmlElement.getElementByTagName("Cargo");
		foreach obj in cargoElement.childNodes do
			xmlElement2 := obj.JadeXMLElement;
			
			// sort out opts
			optsElement := xmlElement2.getElementByTagName('opts');
			if optsElement &lt;&gt; null then
				self.setupOptsAssoc(optsElement, codeStr);
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			else
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			endif;
			
			
			// delete the vehicle
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.deleteVehicle("' &amp; rego &amp; '");' &amp; CrLf &amp; CrLf &amp;
				Tab &amp;'vvr := self.gateInGC2("' &amp; rego &amp; '", ' &amp; state &amp; ', ' &amp; driverName &amp; ', ' &amp; gate &amp; ');' &amp; CrLf &amp; CrLf; 
			
		endforeach;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);

epilog

end;
</source>
        <Parameter name="_gateInXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGateOutGC2" id="bd3cb306-4ba8-4e50-bb78-f3e6ad528f93">
        <source>processGateOutGC2(_gateOutXMLElement : JadeXMLElement; _methodStr : String io);

//	29/01/2018	jlgmh5		Initial creation

vars


	xmlElement				: JadeXMLElement;
	regoElement				: JadeXMLElement;
	cargoElement			: JadeXMLElement;
	terminalAttrib			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	idElement				: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	driverName				: String;
	state					: String;
	gate					: String;	
	rego					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'vvr					: CM_VehicleVisitRecord;' &amp; CrLf &amp;
		Tab &amp; 'cargo					: CM_TrackedItem;' &amp; CrLf &amp;
		Tab &amp; 'terminal 				: CM_Terminal;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
		
	foreach obj in _gateOutXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		// get terminal
		terminalAttrib := xmlElement.getAttributeByName("Terminal");
		
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttrib.value &amp; '"]);' &amp; CrLf &amp; CrLf;
					
		// get the registraion details
		regoElement := xmlElement.getElementByTagName("Registration");
		driverName := self.returnElementText(regoElement.getElementByTagName("driverName")).String;
		state := self.returnElementText(regoElement.getElementByTagName("state")).String;
		gate := self.returnElementText(regoElement.getElementByTagName("gate")).String;
		rego := self.returnElementText(regoElement.getElementByTagName("rego")).String;
		
		// get cargo details
		cargoElement := xmlElement.getElementByTagName("Cargo");
		foreach obj in cargoElement.childNodes do
			xmlElement2 := obj.JadeXMLElement;
			
			// sort out opts
			optsElement := xmlElement2.getElementByTagName('opts');
			if optsElement &lt;&gt; null then
				self.setupOptsAssoc(optsElement, codeStr);
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			else
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttrib.value &amp; '");' &amp; CrLf &amp; CrLf;
			endif;
			
			// get cargoID element
			idElement := xmlElement2.getElementByTagName('cargoID');
			if idElement &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'cargo := self.getTrackedItem(' &amp; 
					self.returnElementText(idElement).String &amp; ');' &amp; CrLf;
			endif;
					
			// delete the vehicle
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.deleteVehicle("' &amp; rego &amp; '");' &amp; CrLf &amp; CrLf &amp;
				Tab &amp;'vvr := self.gateOutGC2("' &amp; rego &amp; '", ' &amp; state &amp; ', ' &amp; driverName &amp; ', cargo, ' &amp; gate &amp; ', null);' &amp; CrLf &amp; CrLf; 
			
		endforeach;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);

epilog

end;
</source>
        <Parameter name="_gateOutXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGates" id="5bce8e4c-d055-4d06-ad0c-61857a8ba468">
        <source>processGates(_gateXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	gateElement				: JadeXMLElement;
	gateAreaElement			: JadeXMLElement;
	icaElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	ica						: String;
	name					: String;
	gateName				: String;
	comment					: String;
	areaType				: Integer;
	inGate					: Boolean;
	outGate					: Boolean;
	lanes					: Integer;
	isEntry					: Boolean;
	isExit					: Boolean;
	promptRFID				: Boolean;
	activeLanes				: String;
	
begin
	
	varsStr := 'terminal			: CM_Terminal;' &amp; CrLf &amp; 
		Tab &amp; 'yicArea				: CM_YardInterchangeArea;' &amp; CrLf &amp; 
		Tab &amp; 'gateAreasArray		: StringArray;' &amp; CrLf;
		
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;
	
	foreach obj in _gateXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		//gateName.cnReplaceString('_', ' ');
		
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		
		codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
				Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'opts.purge();' &amp; CrLf &amp; 
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; 
			Tab &amp; 'terminal := self.getTerminal();' &amp; CrLf;
				
		icaElement := xmlElement.getElementByTagName('InterchangeArea');
		if icaElement = null then
			ica := _gateXMLElement.tagName &amp; "ICA";
		else
			ica := icaElement.text;
		endif;

		codeStr := codeStr &amp; Tab &amp; 'yicArea := terminal.allTerminalAreasByTypeId[32,"' &amp; ica &amp; '"].CM_YardInterchangeArea;' &amp; CrLf &amp; 
			Tab &amp; 'if yicArea = null then' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'yicArea := self.addYardInterchangeArea("' &amp; ica &amp; '", null, 0, 0);' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf &amp;
			Tab &amp; 'create gateAreasArray transient;' &amp; CrLf;
		
		gateAreaElement := xmlElement.getElementByTagName('GateArea');
		foreach obj in gateAreaElement.childNodes do
			gateElement := obj.JadeXMLElement;
			name := gateElement.tagName;
			comment	:= self.returnElementText(gateElement.getElementByTagName("comment")).String;
			if comment = '""' then
				comment := null;
			endif;

			areaType := self.returnElementText(gateElement.getElementByTagName("areaType")).Integer;
			inGate := self.returnElementText(gateElement.getElementByTagName("in")).Boolean;
			outGate := self.returnElementText(gateElement.getElementByTagName("out")).Boolean;		
			lanes := self.returnElementText(gateElement.getElementByTagName("lanes")).Integer;
			activeLanes := self.returnElementText(gateElement.getElementByTagName("activeLanes")).String;
			activeLanes := activeLanes.replaceString('"', "");
						
			codeStr := codeStr &amp; Tab &amp; 'gateAreasArray.add("' &amp; name &amp; ';' &amp; comment &amp; ';' &amp; areaType.String &amp; ';' &amp; 
				inGate.String &amp; ';' &amp; outGate.String &amp; ';' &amp; lanes.String &amp; ';' &amp; activeLanes &amp; '");' &amp; CrLf;
			
		endforeach;
		
		isEntry := self.returnElementText(xmlElement.getElementByTagName("isEntry")).Boolean;
		isExit := self.returnElementText(xmlElement.getElementByTagName("isExit")).Boolean;
		promptRFID := self.returnElementText(xmlElement.getElementByTagName("promptRFID")).Boolean;
		gateName := self.returnElementText(xmlElement.getElementByTagName("id")).String;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addGate(' &amp; gateName &amp; ', false, ' &amp; isEntry.String &amp; ', ' &amp; isExit.String &amp; 
			', ' &amp; promptRFID.String &amp; ', yicArea, gateAreasArray);' &amp; CrLf;
		
	endforeach;
	
	epilogStr := 'delete gateAreasArray;';
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_gateXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourBerths" id="0e112dd0-06f9-42f4-baee-f74075c90ee1">
        <source>processHarbourBerths(_berthXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour berth

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	berthElement				: JadeXMLElement;
	optElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	harbour					: String;
	wharf					: String;
	code					: String;
	noMarineServices		: Boolean;
	
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf &amp; 
		Tab &amp; 'wharf					: HMS_Wharf;' &amp; CrLf;
		
	foreach obj in _berthXMLElement.childNodes do
		berthElement := obj.JadeXMLElement;
		
		code := self.returnElementText(berthElement.getElementByTagName('code')).String;
		code.cnReplaceString('"', '');
		description := self.returnElementText(berthElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		harbour := self.returnElementText(berthElement.getElementByTagName('harbour')).String;
		wharf := self.returnElementText(berthElement.getElementByTagName('wharf')).String;
		wharf.cnReplaceString('"', '');
		noMarineServices := self.returnElementText(berthElement.getElementByTagName('noMarineServices')).Boolean;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours[' &amp; harbour &amp; '];' &amp; CrLf &amp; 
			Tab &amp; 'wharf := harbour.allWharves["' &amp; wharf &amp; '"].HMS_Wharf;' &amp; CrLf;
		optsElement := berthElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		codeStr := codeStr &amp; Tab &amp; 'self.addBerth("' &amp; code &amp; '", "' &amp; description &amp; '", harbour, ' &amp; 
			self.returnElementText(berthElement.getElementByTagName('startPosition')).String &amp; ', ' &amp; 
			self.returnElementText(berthElement.getElementByTagName('length')).String &amp; ', ' &amp; 
			self.returnElementText(berthElement.getElementByTagName('minDepth')).String &amp; ', ' &amp;
			noMarineServices.String &amp; ', wharf);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_berthXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourDetails" id="691650a7-0f4f-44ad-b4c0-a6042597dadb">
        <source>processHarbourDetails(_harbourXMLElement : JadeXMLElement);

/*

Purpose:		Create the Harbour Details	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement		: JadeXMLElement;
	obj				: Object;
	
	methodStr		: String;
	
begin

	foreach obj in _harbourXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		methodStr := self.MethodString;
		
		if xmlElement.tagName = "Harbours" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Harbours");
			self.processHarbours(xmlElement, methodStr);
		elseif xmlElement.tagName = "TidalClass" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "TidalClass");
			self.processHarbourTidalClasses(xmlElement, methodStr);
		elseif xmlElement.tagName = "TidalModelDefinitions" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "TidalModelDef");
			self.processHarbourTidalModelDefns(xmlElement, methodStr);
		elseif xmlElement.tagName = "TidalHILO" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "TidalHILO");
			//self.processHarbourTidalHILOs(xmlElement, methodStr);
		elseif xmlElement.tagName = "ResourceTypes" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ResourceTypes");
			self.processHarbourResourceType(xmlElement, methodStr);
		elseif xmlElement.tagName = "CheckPoints" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "CheckPoints");
			self.processHarbourRestrictions(xmlElement, methodStr);
		elseif xmlElement.tagName = "Wharfs" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Wharfs");
			self.processHarbourWharfs(xmlElement, methodStr);
		elseif xmlElement.tagName = "Berths" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Berths");
			self.processHarbourBerths(xmlElement, methodStr);
		elseif xmlElement.tagName = "RouteTemplates" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "RouteTemplates");
			self.processHarbourRouteTemplates(xmlElement, methodStr);
		elseif xmlElement.tagName = "WayPoints" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "WayPoints");
			self.processHarbourWayPoints(xmlElement, methodStr);
		elseif xmlElement.tagName = "PathSegments" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "PathSegments");
			self.processHarbourPathSegments(xmlElement, methodStr);
		elseif xmlElement.tagName = "MovementPaths" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "MovementPaths");
			self.processHarbourMovementPaths(xmlElement, methodStr);
		elseif xmlElement.tagName = "Resources" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Resources");
			self.processHarbourResources(xmlElement, methodStr);
		elseif xmlElement.tagName = "UpdateHarbour" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "UpdateHarbour");
			self.processHarbourUpdate(xmlElement, methodStr);
		elseif xmlElement.tagName = "UpdateBerths" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "UpdateBerths");
			self.processHarbourUpdateBerth(xmlElement, methodStr);
		endif;

		if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
				methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
			continue;
		endif;
		
		write methodStr &amp; CrLf &amp; CrLf;
		
		// execute the transient method
		self.executeMethod(methodStr);
		
	endforeach;


end;
</source>
        <Parameter name="_harbourXMLElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processHarbourMovementPaths" id="6f577f35-3a7b-498f-83a0-e9eb7dc4fb67">
        <source>processHarbourMovementPaths(_movementPathXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour movement paths
Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	pathSegments			: JadeXMLElement;
	pathSegment				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	name					: String;
		
begin
	
	varsStr := 'pathSegmentArray		: StringArray;' &amp; CrLf;
	
	codeStr := codeStr &amp; Tab &amp; 'create pathSegmentArray transient;' &amp; CrLf;
	
	epilogStr := Tab &amp; 'delete pathSegmentArray;' &amp; CrLf;
		
	foreach obj in _movementPathXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		pathSegments := xmlElement.getElementByTagName('pathSegments');
		if pathSegments &lt;&gt; null then
			foreach obj in pathSegments.childNodes do
				pathSegment := obj.JadeXMLElement;
				name := self.returnElementText(pathSegment).String;
				codeStr := codeStr &amp; Tab &amp; 'pathSegmentArray.add(' &amp; name &amp; ');' &amp; CrLf;
			endforeach;
		endif;
			
		codeStr := codeStr &amp; Tab &amp; 'self.addHarbourMovementPath("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; ', pathSegmentArray);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_movementPathXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourPathSegments" id="78e36cda-72a0-4621-84bc-967b962b243f">
        <source>processHarbourPathSegments(_pathSegmentXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour path segments

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	harbour					: String;
	berth					: String;
	name					: String;
		
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf;
		
	foreach obj in _pathSegmentXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		name := xmlElement.tagName;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		harbour := self.returnElementText(xmlElement.getElementByTagName('harbour')).String;
		
		if harbour &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours[' &amp; harbour &amp; '];' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addHarbourPathSegment("' &amp; name &amp; '", ' &amp; description &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('fromRegion')).String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('toRegion')).String &amp;  ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('steamingAToB')).String &amp;', harbour);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_pathSegmentXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourResourceType" id="94d1d927-aa49-4201-a8e2-4d71045142c9">
        <source>processHarbourResourceType(_resourceTypeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour resource type

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	quantityIsRequired		: Boolean;
	units					: String;
	decPlaces				: Integer;
	requiresActionDT		: Boolean;
	requiresFromToDT		: Boolean;
	notAvailable			: Boolean;
	marineService			: Boolean;
	iconVisibleOnView		: Boolean;
	code					: String;
	
begin
	
	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _resourceTypeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		code.cnReplaceString('"', '');
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		quantityIsRequired := self.returnElementText(xmlElement.getElementByTagName('quantityIsRequired')).Boolean;
		units := self.returnElementText(xmlElement.getElementByTagName('units')).String;
		units.cnReplaceString('"', '');
		decPlaces := self.returnElementText(xmlElement.getElementByTagName('decPlaces')).Integer;
		requiresActionDT := self.returnElementText(xmlElement.getElementByTagName('requiresActionDT')).Boolean;
		requiresFromToDT := self.returnElementText(xmlElement.getElementByTagName('requiresFromToDT')).Boolean;
		notAvailable := self.returnElementText(xmlElement.getElementByTagName('notAvailable')).Boolean;
		marineService := self.returnElementText(xmlElement.getElementByTagName('marineService')).Boolean;
		iconVisibleOnView := self.returnElementText(xmlElement.getElementByTagName('iconVisibleOnView')).Boolean;
		codeStr := codeStr &amp; Tab &amp; 'self.addHMSResourceType("' &amp; code &amp; '", ' &amp; description &amp; 
			', "' &amp;units.String &amp; '", ' &amp; decPlaces.String &amp; ', ' &amp; quantityIsRequired.String &amp; ', ' &amp; 
			requiresActionDT.String &amp; ', ' &amp; requiresFromToDT.String &amp; ', ' &amp; notAvailable.String &amp; ', ' &amp; 
			marineService.String &amp; ', ' &amp; iconVisibleOnView.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_resourceTypeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourResources" id="6058e7a5-f718-4d06-9d13-8b7952c78fc8">
        <source>processHarbourResources(_resourceXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour resource

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	harbour					: String;
	resourceType			: String;
	wharf					: String;
	code					: String;
	startPosAlongWharf		: Integer;
	endPosAlongWharf		: Integer;
		
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf &amp; 
		Tab &amp; 'wharf					: HMS_Wharf;' &amp; CrLf &amp; 
		Tab &amp; 'resourceType 		: HMS_ResourceType;' &amp; CrLf;
		
	foreach obj in _resourceXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		code.cnReplaceString('"', '');
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		harbour := self.returnElementText(xmlElement.getElementByTagName('harbour')).String;
		harbour.cnReplaceString('"', '');
		wharf := self.returnElementText(xmlElement.getElementByTagName('wharf')).String;
		wharf.cnReplaceString('"', '');
		resourceType := self.returnElementText(xmlElement.getElementByTagName('resourceType')).String;
		resourceType.cnReplaceString('"', '');
		startPosAlongWharf := self.returnElementText(xmlElement.getElementByTagName('startPosAlongWharf')).Integer;
		endPosAlongWharf := self.returnElementText(xmlElement.getElementByTagName('endPosAlongWharf')).Integer;
		
		if harbour &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours["' &amp; harbour &amp; '"];' &amp; CrLf;
		endif;
		
		if wharf &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'wharf := harbour.allWharves["' &amp; wharf &amp; '"];' &amp; CrLf;
		endif;
				
		codeStr := codeStr &amp; Tab &amp; 'resourceType := app.myRoot.allResourceTypes["' &amp; resourceType &amp; '"];' &amp; CrLf &amp; 
			Tab &amp; 'self.addHarbourResource("' &amp; code &amp; '", ' &amp; description &amp; ', harbour, resourceType, wharf, ' &amp; 
			 startPosAlongWharf.String &amp; ', ' &amp; endPosAlongWharf.String &amp;  ', false);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_resourceXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourRestrictions" id="901c31a3-0d2d-4ba8-bc4e-7ceb2faa3348">
        <source>processHarbourRestrictions(_restrictionsXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour restriction / check points

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	harbour					: String;
	tidalModel				: String;
	code					: String;
	relativeToWhichTide		: String;
	relativeToWhichTide2	: String;
	
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf &amp;
		Tab &amp; 'tidalModel				: HMS_TidalModelDefinition;' &amp; CrLf;
		
	foreach obj in _restrictionsXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		code.cnReplaceString('"', '');
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		if description = null then
			description := code;
		endif;		
		harbour := self.returnElementText(xmlElement.getElementByTagName('harbour')).String;	
		tidalModel := self.returnElementText(xmlElement.getElementByTagName('tidalModel')).String;
		relativeToWhichTide := self.returnElementText(xmlElement.getElementByTagName('relativeToWhichTide')).String;
		if relativeToWhichTide = null then
			relativeToWhichTide := "null";
		endif;
		relativeToWhichTide2 := self.returnElementText(xmlElement.getElementByTagName('relativeToWhichTide2')).String;
		if relativeToWhichTide2 = null then
			relativeToWhichTide2 := "null";
		endif;
		
		codeStr := codeStr &amp; CrLf &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours[' &amp; harbour &amp; '];' &amp; CrLf &amp; 
			Tab &amp; 'tidalModel := app.myRoot.allHMSTidalModelDefinitions[' &amp; tidalModel &amp; '];' &amp; CrLf;
		
		optsElement := xmlElement.getElementByTagName("opts");
		if optsElement &lt;&gt; null then
			foreach obj in optsElement.childNodes do 
				optElement := obj.JadeXMLElement;
				codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
				if optElement.tagName = "OverrideCheckPointType" then
					codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; optElement.tagName &amp; 
						'", ' &amp; self.returnElementText(optElement).Integer.String &amp; ');' &amp; CrLf;
				else
					codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; optElement.tagName &amp; '", "' &amp;
						optElement.childNodes.first.JadeXMLCDATA.data &amp; '");' &amp; CrLf;
				endif;		
			endforeach;
		endif;
				
		codeStr := codeStr &amp; Tab &amp; 'self.addCheckPoint("' &amp; code &amp; '", "' &amp; description &amp; '", ' &amp; 
			relativeToWhichTide &amp; ', ' &amp; relativeToWhichTide2 &amp; ', harbour, tidalModel, ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('checkPointType')).Integer.String &amp; ', ' &amp;  
			self.returnElementText(xmlElement.getElementByTagName('relativeTimeFrom')).Integer.String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('relativeTimeTo')).Integer.String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('relativeTimeFrom2')).Integer.String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('relativeTimeTo2')).Integer.String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('tideRangeAmount')).Integer.String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('tideRangeAmount2')).Integer.String &amp; ', ' &amp;
			self.returnElementText(xmlElement.getElementByTagName('tideState')).Integer.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_restrictionsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourRouteTemplates" id="f88058dc-01d6-40d0-8a03-10433139b07b">
        <source>processHarbourRouteTemplates(_routeTemplateXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the harbour route template

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	regionsElement			: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code					: String;
	
begin
			
	varsStr := Tab &amp; 'allHarbourRegions 		: HMS_HarbourRegionArray;' &amp; CrLf;
	
	codeStr := Tab &amp; 'create allHarbourRegions transient;' &amp; CrLf;
	
	epilogStr := Tab &amp; 'delete allHarbourRegions;' &amp; CrLf;
	
	foreach obj in _routeTemplateXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'allHarbourRegions.clear();' &amp; CrLf;
		regionsElement := xmlElement.getElementByTagName("regions");
		if regionsElement &lt;&gt; null then
			foreach obj in regionsElement.childNodes do
				codeStr := codeStr &amp; Tab &amp; 'allHarbourRegions.add(app.myRoot.allHMSHarbourRegions["' &amp; 
					obj.JadeXMLElement.tagName &amp; '"]);' &amp; CrLf;
			endforeach;
		
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addHarbourRouteTemplate(' &amp; code &amp; ', ' &amp; description &amp; 
			', allHarbourRegions);' &amp; CrLf;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_routeTemplateXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourTidalClasses" id="6158f7a2-4b92-4cd6-ab7e-b1595f75fdd8">
        <source>processHarbourTidalClasses(_tidalClassXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Tidal Class Details	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	arrMaxFlood				: Decimal[6,3];
	arrMaxEbb				: Decimal[6,3];
	depMaxFlood				: Decimal[6,3];
	depMaxEbb				: Decimal[6,3];
	
begin
	
	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _tidalClassXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		arrMaxFlood := self.returnElementText(xmlElement.getElementByTagName('arrMaxFlood')).Decimal;
		arrMaxEbb	:= self.returnElementText(xmlElement.getElementByTagName('arrMaxEbb')).Decimal;
		depMaxFlood	:= self.returnElementText(xmlElement.getElementByTagName('depMaxFlood')).Decimal;
		depMaxEbb := self.returnElementText(xmlElement.getElementByTagName('depMaxEbb')).Decimal;
		codeStr := codeStr &amp; Tab &amp; 'self.addTidalClass("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; 
			', ' &amp; arrMaxFlood.String &amp; ', ' &amp; arrMaxEbb.String &amp; ', ' &amp; depMaxFlood.String &amp; 
			', ' &amp; depMaxEbb.String &amp; ');' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_tidalClassXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourTidalHILOs" id="293a0db8-7843-45d5-aa9b-5a26d44e1f22">
        <source>processHarbourTidalHILOs(_tidalHILOXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Tidal HI / Lo details
Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	detailsElement			: JadeXMLElement;
	dataElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	ts						: TimeStamp;
	height					: Decimal[6,2];
	tideType				: Integer;
	tidalModelDef			: String;
	
begin
			
	detailsElement := _tidalHILOXMLElement.getElementByTagName("Details");
	if detailsElement = null then
		return;
	endif;
	
	varsStr := 'tmd						: HMS_TidalModelDefinition;' &amp; CrLf &amp;
		Tab &amp; 'hiLoTidalData			: HMS_HiLoTidalData;' &amp; CrLf &amp; 
		Tab &amp; 'ts						: TimeStamp;' &amp; CrLf;
		
	codeStr := codeStr &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
	
	foreach obj in detailsElement.childNodes do
		dataElement := obj.JadeXMLElement;
		height := self.returnElementText(dataElement.getElementByTagName('height')).Decimal;
		tideType := self.returnElementText(dataElement.getElementByTagName('tideType')).Integer;
		tidalModelDef := self.returnElementText(dataElement.getElementByTagName('myTidalModelDefinition')).String;
		if tidalModelDef &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'tmd := app.myRoot.allHMSTidalModelDefinitions[' &amp; tidalModelDef &amp; '];' &amp; CrLf;
		endif;
		ts	:= self.returnElementText(dataElement.getElementByTagName('ts')).TimeStamp;
		codeStr := codeStr &amp; Tab &amp; 'ts := "' &amp; self.returnElementText(dataElement.getElementByTagName('ts')).String &amp; '".TimeStamp;' &amp; CrLf &amp;
			Tab &amp; 'if tmd.allHMSTidalData[ts] = null then' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'create hiLoTidalData persistent;' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'hiLoTidalData.setPropertyValue("height", ' &amp; height.String &amp; ');' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'hiLoTidalData.setPropertyValue("tideType", ' &amp; tideType.String &amp; ');' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'hiLoTidalData.setPropertyValue("myTidalModelDefinition", tmd);' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'hiLoTidalData.setPropertyValue("ts", ts);' &amp; CrLf &amp; 
			Tab &amp; 'endif;' &amp; CrLf;
	endforeach;
	
	codeStr := codeStr &amp; Tab &amp; 'commitTransaction;' &amp; CrLf;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_tidalHILOXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourTidalModelDefns" id="6a16f144-9ca1-4bc6-8409-0d46c64cb75e">
        <source>processHarbourTidalModelDefns(_tidalClassXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Tidal Class Details	

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	dataType				: String;
	dataSource				: String;
	declaredDepth			: Real;
	underKeelClearance		: Real;
	highestValue			: Real;
	lowestValue				: Real;
	tideFileName			: String;
	code					: String;
	
begin
	
	codeStr := codeStr &amp; CrLf;
			
	foreach obj in _tidalClassXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code  := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		dataType := self.returnElementText(xmlElement.getElementByTagName('dataType')).String;
		dataType.cnReplaceString('"', '');
		dataSource	:= self.returnElementText(xmlElement.getElementByTagName('dataSource')).String;
		declaredDepth	:= self.returnElementText(xmlElement.getElementByTagName('declaredDepth')).Real;
		underKeelClearance := self.returnElementText(xmlElement.getElementByTagName('underKeelClearance')).Real;
		highestValue	:= self.returnElementText(xmlElement.getElementByTagName('highestValue')).Real;
		lowestValue	:= self.returnElementText(xmlElement.getElementByTagName('lowestValue')).Real;
		tideFileName := self.returnElementText(xmlElement.getElementByTagName('tideFileName')).String;
		codeStr := codeStr &amp; Tab &amp; 'self.addTidalModel(' &amp; code &amp; ', ' &amp; description &amp; 
			', ' &amp; dataSource.String &amp; ', ' &amp; tideFileName.String &amp; ', ' &amp; dataType.String &amp; ', ' &amp; 
			highestValue.String &amp; ', ' &amp; lowestValue.String &amp; ',  ' &amp; declaredDepth.String &amp; ', ' &amp; 
			underKeelClearance.String &amp; ');' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_tidalClassXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourUpdate" id="25382a3e-88ad-467d-8fc1-62f3269087c5">
        <source>processHarbourUpdate(_resourceXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Now have harbour stuff created update any outstanding details that need updating

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalsElement		: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	harbour					: String;
	arrival					: String;
	departure				: String;
		
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf &amp; 
		Tab &amp; 'berth 					: HMS_Berth;' &amp; CrLf;
		
	foreach obj in _resourceXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		arrival := self.returnElementText(xmlElement.getElementByTagName('defaultArrvBerth')).String;
		arrival.cnReplaceString('"', '');
		departure := self.returnElementText(xmlElement.getElementByTagName('defaultDepartBerth')).String;
		departure.cnReplaceString('"', '');
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours["' &amp; xmlElement.tagName &amp; '"];' &amp; CrLf &amp; 
			Tab &amp; 'if harbour &lt;&gt; null then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'berth := harbour.allBerths["' &amp; arrival &amp; '"];' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'harbour.setPropertyValue("defaultArrvBerth", berth);' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'berth := harbour.allBerths["' &amp; departure &amp; '"];' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'harbour.setPropertyValue("defaultDepartBerth", berth);' &amp; CrLf; 
			
		terminalsElement := xmlElement.getElementByTagName("terminals");
		if terminalsElement &lt;&gt; null then
			foreach obj in terminalsElement.childNodes do
				codeStr := codeStr &amp; Tab &amp; Tab &amp; 'if harbour.allTerminalsByCode["' &amp; obj.JadeXMLElement.tagName &amp; '"] = null then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; Tab &amp; 'harbour.allTerminalsByCode.add(app.myRoot.allTerminals["' &amp; 
					obj.JadeXMLElement.tagName &amp; '"]);' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'endif;' &amp; CrLf;
			endforeach;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'commitTransaction;' &amp; CrLf &amp; Tab &amp; 'endif;' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_resourceXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourUpdateBerth" id="8e3318ff-a1de-4110-9b62-c3da7c86452b">
        <source>processHarbourUpdateBerth(_updateXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Now have harbour stuff created update any outstanding details that need updating

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	harbour					: String;
	arrival					: String;
	departure				: String;
		
begin
	
	varsStr := 'berth				: HMS_Berth;' &amp; CrLf &amp;
		Tab &amp; 'harbourRegion		: HMS_HarbourRegion;' &amp; CrLf;
		
	foreach obj in _updateXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		codeStr := codeStr &amp; Tab &amp; 'foreach berth in HMS_Berth.instances do' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'if berth.code = "' &amp; xmlElement.tagName &amp; '" then' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; Tab &amp; 'break;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'endif;' &amp; CrLf &amp;
			Tab &amp; 'endforeach;' &amp; CrLf &amp; 
			Tab &amp; 'if berth &lt;&gt; null then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'harbourRegion := app.myRoot.allHMSHarbourRegions["' &amp; xmlElement.text &amp; '"];' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'if harbourRegion &lt;&gt; null then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; Tab &amp; '	berth.setPropertyValue("myHarbourRegion", harbourRegion);' &amp; CrLf &amp;
			Tab &amp; Tab &amp; Tab &amp; '	commitTransaction;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'endif;' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_updateXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourWayPoints" id="299db382-86f9-48ae-af8d-6c9fca62ba97">
        <source>processHarbourWayPoints(_waypointXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour waypoints

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	harbour					: String;
	berth					: String;
	code					: String;
		
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf &amp;
		Tab &amp; 'berth				: HMS_Berth;' &amp; CrLf;
		
	foreach obj in _waypointXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		berth := self.returnElementText(xmlElement.getElementByTagName('berth')).String;
		harbour := self.returnElementText(xmlElement.getElementByTagName('harbour')).String;
		
		if harbour &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours[' &amp; harbour &amp; '];' &amp; CrLf;
		endif;
		
		if berth &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'foreach berth in harbour.allBerths do' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'if berth.code = ' &amp; berth &amp; ' then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; Tab &amp; 'break;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'endif;' &amp; CrLf &amp;
				Tab &amp; 'endforeach;' &amp; CrLf;
		endif;
			
		optsElement := xmlElement.getElementByTagName("opts");
		self.setupOptsAssoc(optsElement, codeStr);
		
		codeStr := codeStr &amp; Tab &amp; 'self.addWaypoint(' &amp; code &amp; ', ' &amp; description &amp; ', harbour, berth);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_waypointXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbourWharfs" id="dbf2870f-bd2e-44d3-aa8f-3d1400d07c8c">
        <source>processHarbourWharfs(_wharfXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Harbour Wharf

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	harbourElement			: JadeXMLElement;
	wharfElement			: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	length					: Integer;
	width					: Integer;
	code					: String;
	
begin
	
	varsStr := 'harbour					: HMS_Harbour;' &amp; CrLf;
		
	foreach obj in _wharfXMLElement.childNodes do
		harbourElement := obj.JadeXMLElement;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'harbour := app.myRoot.allHarbours["' &amp; harbourElement.tagName &amp; '"].HMS_Harbour;' &amp; CrLf;
		
		foreach obj in harbourElement.childNodes do
			wharfElement := obj.JadeXMLElement;
			code := self.returnElementText(wharfElement.getElementByTagName('code')).String;
			code.cnReplaceString('"', '');
			description := self.returnElementText(wharfElement.getElementByTagName('description')).String;
			length := self.returnElementText(wharfElement.getElementByTagName('length')).Integer;
			width := self.returnElementText(wharfElement.getElementByTagName('width')).Integer;
			optsElement := wharfElement.getElementByTagName("opts");
			self.setupOptsAssoc(optsElement, codeStr);
			
			codeStr := codeStr &amp; Tab &amp; 'self.addWharf("' &amp; code &amp; '", ' &amp; description &amp; ', harbour, ' &amp; length.String &amp; ',  ' &amp; 
				width.String &amp; ');' &amp; CrLf;
		endforeach;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_wharfXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHarbours" id="bf3424fb-fcbc-4475-84f6-f638f025f3c3">
        <source>processHarbours(_harbourXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Admin Details	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	terminalsElement		: JadeXMLElement;
	terminalElement			: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
		
begin
	
	varsStr := 'terminalArray					: ObjectArray;' &amp; CrLf;
	
	codeStr := codeStr &amp; Tab &amp; 'create terminalArray transient;' &amp; CrLf;
	
	epilogStr := Tab &amp; 'delete terminalArray;' &amp; CrLf;
	
	foreach obj in _harbourXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("IgnoreWarnings",' &amp; self.returnElementText(xmlElement.getElementByTagName('IgnoreWarnings')).String &amp; ');' &amp; CrLf &amp; 
			Tab &amp; 'terminalArray.clear();' &amp; CrLf;
		terminalsElement := xmlElement.getElementByTagName("Terminals");
		foreach obj in terminalsElement.childNodes do
			terminalElement := obj.JadeXMLElement;
			codeStr := codeStr &amp; Tab &amp; 'terminalArray.add(app.myRoot.allTerminals["' &amp; terminalElement.tagName &amp; '"]);' &amp; CrLf;
		endforeach;
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminals", terminalArray);' &amp; CrLf;
		codeStr := codeStr &amp; Tab &amp; 'self.addHarbour("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; ');' &amp; CrLf;
	endforeach;
			
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_harbourXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processHazardClasses" id="031c47f2-05f1-4946-8850-4e21680faeab">
        <source>processHazardClasses(_hazClassXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Hazard Classes 

Date			Who		Reason
26/01/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	drawingAttributeElement	: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'hazClass				: CM_HazardClass;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _hazClassXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating Hazard Class " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Hazard Class " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		
		// drawing attributes so pass as opts
		drawingAttributeElement := xmlElement.getElementByTagName('DrawingAttributes');
		if drawingAttributeElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; drawingAttributeElement.tagName &amp; '", true);' &amp; CrLf;
			xmlElement2 := drawingAttributeElement.getElementByTagName("fontCharacter");
			if xmlElement2 &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; xmlElement2.tagName &amp; '", ' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;
			endif;
			xmlElement2 := drawingAttributeElement.getElementByTagName("font");
			if xmlElement2 &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; xmlElement2.tagName &amp; '", ' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;
			endif;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'hazClass := self.addHazardClass(' &amp; self.returnElementText(xmlElement.getElementByTagName('code')).String &amp; '.String, ' &amp;
			self.returnElementText(xmlElement.getElementByTagName('description')).String &amp; ', ' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('altCode')).String &amp; ', false);' &amp; CrLf;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_hazClassXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processISOGroups" id="bfd21672-534f-4998-b2e8-4600852f57bb">
        <source>processISOGroups(_isoGroupXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the iso groups

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	isoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	code					: String;
	isoTypes				: String;
		
begin

	varsStr := 'isoTypes 			: CM_ISOTypeByCodeDict;' &amp; CrLf &amp;
		Tab &amp; 'substituteISOGroups				: CM_ISOTypeGroupByCodeDict;' &amp; CrLf;
	
	codeStr := codeStr &amp; 'create isoTypes transient;' &amp; CrLf &amp;
		Tab &amp; 'create substituteISOGroups transient;' &amp; CrLf;
	
	epilogStr := 'delete isoTypes;' &amp; CrLf &amp;
		Tab &amp; 'delete substituteISOGroups;' &amp; CrLf;

	create isoTypesArray transient;
	
	foreach obj in _isoGroupXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating ISO Group " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating ISO Group " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'isoTypes.clear();' &amp; CrLf;
		
		isoTypesArray.clear();
		isoTypes := self.returnElementText(xmlElement.getElementByTagName('isoTypes')).String;
		isoTypes.cnReplaceString('"', '');
		isoTypesArray.clear();
		isoTypes.getTokensForDelimiter(';', isoTypesArray);
		foreach isoTypes in isoTypesArray do
			codeStr := codeStr &amp; Tab &amp; 'isoTypes.add(app.myRoot.allISOTypes["' &amp; isoTypes.trimBlanks() &amp; '"]);' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addISOGroup("' &amp; code &amp; '", "' &amp; description &amp; '", isoTypes, substituteISOGroups);' &amp; CrLf; 
		codeStr.cnReplaceString('""', '"');
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete isoTypesArray;
end;
</source>
        <Parameter name="_isoGroupXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processISOTypes" id="a9180307-d8ce-46f5-9aec-caa8770b8c88">
        <source>processISOTypes(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the iso types

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code					: String;
	isReefer				: Boolean;
	is20ft					: Boolean;
	is8ft6					: Boolean;
	canBeTwinLifted			: Boolean;
	isGeneral				: Boolean;
	tareWeight				: Integer;
	is8ft					: Boolean;
	isCrib					: Boolean;
	is30ft					: Boolean;
	is9ft6					: Boolean;
	is40ft					: Boolean;
	is45ft					: Boolean;
	is53ft					: Boolean;
	isIntegral				: Boolean;
	isPowered				: Boolean;
	isOpenTop				: Boolean;
	cargoType				: String;
	isFlat					: Boolean;
	isTank					: Boolean;
	isFrame					: Boolean;
	isPortHole				: Boolean;
	isFan					: Boolean;
	is4ft					: Boolean;
	is4ft3					: Boolean;
	
begin

	varsStr := 'cargoType			: CM_CargoType;' &amp; CrLf;
	
	codeStr := CrLf;
	
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating ISO Type " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating ISO Type " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		cargoType := self.returnElementText(xmlElement.getElementByTagName('cargoType')).String;
		isReefer := self.returnElementText(xmlElement.getElementByTagName('isReefer')).Boolean;
		is20ft := self.returnElementText(xmlElement.getElementByTagName('is20ft')).Boolean;
		is8ft6 := self.returnElementText(xmlElement.getElementByTagName('is8ft6')).Boolean;
		canBeTwinLifted	:= self.returnElementText(xmlElement.getElementByTagName('canBeTwinLifted')).Boolean;
		isGeneral := self.returnElementText(xmlElement.getElementByTagName('isGeneral')).Boolean;
		tareWeight := self.returnElementText(xmlElement.getElementByTagName('tareWeight')).Integer;
		is8ft := self.returnElementText(xmlElement.getElementByTagName('is8ft')).Boolean;
		isCrib := self.returnElementText(xmlElement.getElementByTagName('isCrib')).Boolean;
		is30ft := self.returnElementText(xmlElement.getElementByTagName('is30ft')).Boolean;
		is9ft6 := self.returnElementText(xmlElement.getElementByTagName('is9ft6')).Boolean;
		is40ft := self.returnElementText(xmlElement.getElementByTagName('is40ft')).Boolean;
		is45ft := self.returnElementText(xmlElement.getElementByTagName('is45ft')).Boolean;
		is53ft := self.returnElementText(xmlElement.getElementByTagName('is53ft')).Boolean;
		isIntegral := self.returnElementText(xmlElement.getElementByTagName('isIntegral')).Boolean;
		isPowered := self.returnElementText(xmlElement.getElementByTagName('isPowered')).Boolean;
		isOpenTop := self.returnElementText(xmlElement.getElementByTagName('isOpenTop')).Boolean;
		isFlat := self.returnElementText(xmlElement.getElementByTagName('isFlat')).Boolean;
		isTank := self.returnElementText(xmlElement.getElementByTagName('isTank')).Boolean;
		isFrame := self.returnElementText(xmlElement.getElementByTagName('isFrame')).Boolean;
		isPortHole := self.returnElementText(xmlElement.getElementByTagName('isPortHole')).Boolean;
		isFan := self.returnElementText(xmlElement.getElementByTagName('isFan')).Boolean;
		is4ft := self.returnElementText(xmlElement.getElementByTagName('is4ft')).Boolean;
		is4ft3 := self.returnElementText(xmlElement.getElementByTagName('is4ft3')).Boolean;

		if cargoType = null then
			cargoType := 1.String;
		endif;
		codeStr := codeStr &amp; Tab &amp; 'cargoType := app.myRoot.allCargoTypesById[' &amp; cargoType &amp; '];' &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addISOType("' &amp; code &amp; '", "' &amp; description &amp; '", cargoType,  ' &amp; isGeneral.String &amp; ',' &amp; isFlat.String &amp; ', ' &amp; 
			isCrib.String &amp; ', ' &amp; isTank.String &amp; ',' &amp; isFrame.String &amp; ', ' &amp; isOpenTop.String &amp; ', ' &amp; isReefer.String &amp; ', ' &amp; isPortHole.String &amp; ', ' &amp; 
			isIntegral.String &amp; ', ' &amp; isFan.String &amp; ', ' &amp; isPowered.String &amp; ', ' &amp; is20ft.String &amp; ', ' &amp; is30ft.String &amp; ', ' &amp; is40ft.String &amp; ', ' &amp; 
			is45ft.String &amp; ', ' &amp; is53ft.String &amp; ', ' &amp; is8ft.String &amp; ', ' &amp; is8ft6.String &amp; ', ' &amp; is9ft6.String &amp; '
			, ' &amp; is4ft.String &amp; ', ' &amp; is4ft3.String &amp; ', ' &amp; canBeTwinLifted.String &amp; ', ' &amp; tareWeight.String &amp; ');' &amp; CrLf;
		codeStr.cnReplaceString('""', '"');
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processLoadColorCodeJobToOps" id="15bdbc5f-3fc2-45df-a0a9-19fa344541d8">
        <updating/>
        <source>processLoadColorCodeJobToOps(_colorCodeXMLElement : JadeXMLElement; _methodStr : String io) updating;

/*

