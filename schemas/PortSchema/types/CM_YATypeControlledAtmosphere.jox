<Class name="CM_YATypeControlledAtmosphere" id="6e175e92-917d-4528-8457-c099ee86874f">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="403f64fd-d9e9-4ad4-848f-c58e9d2425e5">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

vars

begin
	if _ti.isKindOf(CM_Container) then
		if _ti.CM_Container.isControlledAtmosphere then
			_process := true;
		endif;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="18bc18f7-b067-4f4d-aef0-a99279ad2b3c">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars

begin
	if _ti.isControlledAtmosphere then
		_criteriaValue := CM_YADataBoolean.VALUE_TRUE;
	else
		_criteriaValue := CM_YADataBoolean.VALUE_FALSE;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="d5985f85-c549-4f2a-a03d-1a49d694e530">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		18 September 2007 by cnwvu1
// --------------------------------------------------------------------------------
begin
	return "Is Controlled Atmosphere";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isBooleanType" id="b6043a70-b57a-45e4-bee4-f4ae2c9d66e1">
        <source>isBooleanType(): Boolean;
// --------------------------------------------------------------------------------
// Created:		18 September 2007 by cnwvu1
