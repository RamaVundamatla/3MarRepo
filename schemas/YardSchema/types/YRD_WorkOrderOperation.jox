    <JadeMethod name="tblJobSheet_dblClick" id="7db2ff1d-ac2c-4f84-ae13-d4e97ff8e662">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobSheet_dblClick(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
02 Jun 2023	navhl20	ChangeRequest 57760: EUP - Delivery Dispatch – Un Allocated VAS
*/

vars
	form		: YRD_WorkPointJobSheetMaint;
	obj			: Object;
	pxyJobSheet : CM_WorkPointJobSheet;
begin
	if table.row = 1 then
		self.doSortByColumn(table);
		return;
	endif;
	
	obj := self.tblJobSheet.allSelectedObjects.first;
	if obj = null then
		return;
	endif;
	
	if form = null then
		form := app.loadForm(YRD_WorkPointJobSheetMaint,CMUI_Assistant,false,false,true,self.myTerminal,null).YRD_WorkPointJobSheetMaint;
	endif;
	
	if form = null then
		return;
	endif;
	
	pxyJobSheet := app.myProxyManager.getProxyObject(pxyJobSheet).CM_WorkPointJobSheet;
	
	if pxyJobSheet = null then
		pxyJobSheet := app.createUpdateProxy(obj.CM_WorkPointJobSheet).CM_WorkPointJobSheet;
	endif;
	
	form.setWorkPointJobSheet(obj.CM_WorkPointJobSheet);
	form.setPxyWorkPointJobSheet(pxyJobSheet);
	form.myParentForm := self;
	form.showModal();
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblJobSheet_dragDrop" id="4b82d4fd-ade0-4b85-991b-763a677c7205">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobSheet_dragDrop(table: CM_DataTable input; win: Window input; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
15 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
16 Apr 2024 navhl20 ChangeRequest 63636: EUP | 53729 - Delivery Dispatch Screen - initial feedback
07 Jun 2024 navhl20 Bug 64538: EUP - Allocating job to job sheet throwing an error 1090.
31 Mar 2025	navhl20 CR MTN-34425: MTN - MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	jobSheet,
	oldJobSheet	: CM_WorkPointJobSheet;
	theRow		: Integer;
	job			: CM_Job;
	tblJobSheet,
	tblJobUn	: CM_DataTable;
	voyJob		: CM_VoyageWorkPointJob;
	allVoyJobs	: CM_JobArray;
begin
	if self.myDraggedTable = table then
		return;
	endif;
	
	tblJobSheet := self.tblJobSheet;
	tblJobSheet.clearAllSelected();
	theRow := tblJobSheet.getRowFromY(y);
	
	if theRow &gt; tblJobSheet.fixedRows then
		jobSheet := tblJobSheet.accessRow(theRow).itemObject.CM_WorkPointJobSheet;
		tblJobSheet.selectRow(theRow,false);
	endif;
	
	tblJobUn := self.tblJobsUnallocated;
	job := tblJobUn.allSelectedObjects.first.CM_Job;								//15.12.2023 navhl20 #61092[61621]
	if job = null or jobSheet = null then											//07.06.2024 navhl20 #64538
		return;
	endif;
	
	self.validateRBTAllocated(job);													//31.03.2025 navhl20 #34425
	
	self.doMnuAllocateJob(jobSheet);
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblJobSheet_dragOver" id="2912a37a-ef59-4f20-92bb-830e86a5adbc">
        <controlMethod name="Table::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobSheet_dragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
16 Apr 2024 navhl20 ChangeRequest 63636: EUP | 53729 - Delivery Dispatch Screen - initial feedback
*/

vars
	columnIndex : Integer;
	rowIndex 	: Integer;
	headerText 	: String;
	backColour 	: Integer;
	obj			: CM_Object;
begin
	if table.rows = 0 then
		return;
	endif;
	
	if self.myDraggedTable = table then			//16.04.2024 navhl20 #63636
		return;
	endif;
	
	if y &gt; table.accessRow(1).height then
		//we are not in the header row
		
		//find our row
		table.getCellFromPosition( x, y, rowIndex, columnIndex );
		
		if columnIndex &lt; 1 or columnIndex &gt; table.columns then
			return;
		endif;
		
		//select the hovered row
		table.CM_DataTable.deselectAll();
		table.CM_DataTable.selectRow( rowIndex, false );
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
