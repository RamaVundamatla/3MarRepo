    </JadeMethod>
    <JadeMethod name="locationId40" id="2847afd6-a0f9-4e7d-88f1-19dfaaa1c22e">
        <methodInvocation>mapping</methodInvocation>
        <source>locationId40(set: Boolean; _value: String io) mapping;
//Returns the full location of where this container actually is, if its a 40' location, returns
//"C 2303-041", ie c23031 and c23041 strung together, else returns null
vars
	myLoc : CM_StackController;
	sc : CM_StackController;
	aStr : String;
	lc : CM_LocationsController;
	array : CM_LCArray;
begin
	_value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	sharedLock(self);
	lc := self.getPrimaryLocation(REAL_MODE);
	if lc = null then
		return;
	endif;
	if not lc.isKindOf(CM_StackController) then
		return;
	endif;
	//if not self.is40 then
	if not self.requiresMoreThan1TwentyLC() then  // PAR 16415 CCMS 1029
		return;
	endif;
	array := self.getLocationsArray(REAL_MODE, 1);
	if array = null then
		return;
	endif;
	if array.size &lt; 2 then
		return;	//This should NEVER happen.
	endif;	
	if not array[2].isKindOf(CM_StackController) then
		return;
	endif;
	//Get the secondary location
	sc := array[2].CM_StackController;
	myLoc := lc.CM_StackController;
	//------------------
	//Return the terminal Area id &amp; a space
	//------------------
	aStr := myLoc.myTerminalArea.id.trimRight &amp; " ";	
	//------------------
	//Add row label
	//------------------
	aStr := aStr &amp; myLoc.getRowLabel;
	//------------------
	//Add column label
	//------------------
	aStr := aStr &amp; myLoc.getColumnLabel(true);
	//------------------
	//Add column label of NEXT position
	//------------------
	aStr := aStr &amp; "-" &amp; sc.getColumnLabel(true);
	//------------------
	//Append the height
	//------------------
	aStr := aStr &amp; myLoc.allTrackedItems.indexOf(self).String;
	_value := aStr;
epilog
	unlock(self);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="matchesLength" id="bd62d518-f612-451c-94d6-134986939ef7">
        <source>matchesLength(_contLength : Integer) : Boolean;
/*

Date		    Who			Reason
17 February 2011	cnwas3	 par 25163

*/

vars
	actualLength : Integer;
begin
	
	actualLength := self.getActualLength().Integer;
	
	if actualLength = _contLength then
		return true;
	endif;
	
	if  _contLength = 40   then			//include the 30',45' and 53' in the 40' category
	   
	   if  actualLength = 30 and self.myTerminal.getConfig(Is30IncludedForReports).Integer = 0 then
		   return true;
	   elseif actualLength = 45 and self.myTerminal.getConfig(Is45IncludedForReports).Integer = 0 then
		   return true;
	   elseif actualLength = 53 and self.myTerminal.getConfig(Is53IncludedForReports).Integer = 0 then
		   return true;
	   endif;
	endif;	
	
	if _contLength = NULL_INTEGER then		//this is for the case in which 30',45' and 53's are to be included in an "Other" column, for printing/displaying purposes
		if  actualLength = 30 and self.myTerminal.getConfig(Is30IncludedForReports).Integer = ISOTypeOtherIncludedAsOther then
		   return true;
	   elseif actualLength = 45 and self.myTerminal.getConfig(Is45IncludedForReports).Integer = ISOTypeOtherIncludedAsOther then
		   return true;
	   elseif actualLength = 53 and self.myTerminal.getConfig(Is53IncludedForReports).Integer = ISOTypeOtherIncludedAsOther then
		   return true;
	   endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_contLength" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="needToMergeMove" id="6d155d57-6713-4c91-983a-6970fb9a7868">
        <source>needToMergeMove(otherTI: CM_Container): Boolean;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//If the containers are different then we want to move them from the actual to the shifted bayplans.
//If they are break-bulk or timber move 'em (may have multiple stowage locations)
//Also if they have children move 'em
vars
	str		: String;
	haz		: CM_Hazard;
begin

	if self.cargoType = TI_CargoType_BreakBulk or self.cargoType = TI_CargoType_Timber then
		return true;
	endif;
	if self.cargoType &lt;&gt; otherTI.cargoType then
		return true;
	endif;

	if self.id &lt;&gt; otherTI.id then
		return true;
	endif;


	if self.carrier &lt;&gt; otherTI.carrier then
		return true;
	endif;
			  

	if self.commodity &lt;&gt; otherTI.commodity then
		return true;
	endif;  	
	
	if self.consignee &lt;&gt; otherTI.consignee then
		return true;
	endif;
	
	if self.consignor &lt;&gt; otherTI.consignor then
		return true;
	endif;

	if self.damaged &lt;&gt; otherTI.damaged then
		return true;
	endif;

	if self.description &lt;&gt; otherTI.description then
		return true;
	endif;

	if self.destinationPort &lt;&gt; otherTI.destinationPort then
		return true;
	endif;

	if self.dischargePort &lt;&gt; otherTI.dischargePort then
		return true;
	endif;
	
	if self.loadPort &lt;&gt; otherTI.loadPort then
		return true;
	endif;
	
	if self.myOperator &lt;&gt; otherTI.myOperator then
		return  true;
	endif;

  	if self.quantity &lt;&gt; otherTI.quantity then
  		return true;
  	endif;

	//if self.weight &lt;&gt; otherTI.weight then					//-cnwml2 MSL CCMS 1017
	if self.totalWeight &lt;&gt; otherTI.totalWeight then			//+cnwml2 MSL CCMS 1017
		return true;
	endif;
	
	if self.height &lt;&gt; otherTI.height then
		return true;
	endif;
	
	if self.length &lt;&gt; otherTI.length then
		return true;
	endif;
	
	if self.width &lt;&gt; otherTI.width then
		return true;
	endif;
	
	if self.allChildren.isEmpty = false then
		return true;
	endif;

	if otherTI.allChildren.isEmpty = false then
		return true;
	endif;

	//----------------
	//check each hazard!
	//----------------
	if self.allTIHazards &lt;&gt; null and otherTI.allTIHazards  = null then
		return true;
	endif;
	if self.allTIHazards = null and otherTI.allTIHazards  &lt;&gt; null then
		return true;
	endif;
	if self.allTIHazards.size &lt;&gt;  otherTI.allTIHazards.size then
		return true;
	endif;
	foreach haz in self.allTIHazards do
		if not otherTI.allTIHazards.includesKey(haz.code) then
			return true;
		endif;
	endforeach;
	//----------------
	//Check DischargePorts
	//----------------
  	if self.allDischargePorts &lt;&gt; null and otherTI.allDischargePorts = null then
		return true;
	endif;
  	if self.allDischargePorts = null and otherTI.allDischargePorts &lt;&gt; null then
		return true;
	endif;
  	if self.allDischargePorts.size &lt;&gt; otherTI.allDischargePorts.size then
		return true;
	endif;
	foreach str in self.allDischargePorts do
		if not otherTI.allDischargePorts.includes(str) then
			return true;
		endif;
	endforeach;

	if self.couId &lt;&gt; otherTI.couId then
		return true;
	endif;
	if self.isoType &lt;&gt; otherTI.isoType then
		return true;
	endif;
//	if self.preSlung &lt;&gt; otherTI.preSlung then
//		return true;
//	endif;
 	if self.getTemperature &lt;&gt; otherTI.getTemperature then
 		return true;
 	endif;

	return false;

end;</source>
        <Parameter name="otherTI" type="CM_Container"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noChargeForTemperature" id="24363dfd-f8b5-4438-afed-3ee6819d188a">
        <source>noChargeForTemperature(_guiNoCharge: Boolean; _readingTime: TimeStamp): Boolean;
//----------------------------------------------------------------
//	Created:	11 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Reefer properties and methods moved up from CM_Container level
vars
	firstOnly	: Boolean;
	tempReading	: CM_TempReading;
	tempDate	: Date;
	
begin
	return inheritMethod(_guiNoCharge, _readingTime);
	
	/*firstOnly := self.myTerminal.getConfig(ChargeFirstTemperatureOnly).Boolean;
	
	if not firstOnly then
		//charge based on the gui value (_guiNoCharge is ignored if firstOnly)
		return _guiNoCharge;
	endif;
	
	//------------------------------------------
	// Only charge for the first on this date
	//------------------------------------------
	
	tempDate := _readingTime.date;
	
	//if a temperature reading for this date is found then no charge
	foreach tempReading in self.allTempReadings reversed do
		//all bases covered here
		if tempReading.dateTime.date &lt; tempDate then		//temp is younger than this one - charge!
			return false;
		elseif tempReading.dateTime.date &gt; tempDate then	//older ones exist
			continue;
		elseif tempReading.dateTime.date = tempDate then	//one already exists - no charge
			return true;
		endif;
		
	endforeach;
	
	//we end up here if the adding temperature is prior to the first recorded (only older ones exists or there are non)
	return false;	*/
end;</source>
        <Parameter name="_guiNoCharge" type="Boolean"/>
        <Parameter name="_readingTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="overstowingDifferentDischPort" id="e04a6c8b-ac5f-4b68-960b-d4ff919646a6">
        <source>overstowingDifferentDischPort() : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	lc	 			: CM_LocationsController;
	
begin
	
	lc := self.myPrimaryActualLocation;
	
	if  lc = null then
		return false;
	endif;
	
	if lc &lt;&gt; null and lc.myTerminalArea &lt;&gt; null and lc.myTerminalArea.isTransferArea then
		return false;
	endif;

	return lc.overstowingDifferentDischPort(self);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
