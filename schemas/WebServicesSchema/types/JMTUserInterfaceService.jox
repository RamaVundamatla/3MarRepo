		if targetLoc &lt;&gt; null and rtqTask &lt;&gt; null then
			create cmifMultiItem transient;
			cmifMultiItem.setCmifDetails(rtqTask,targetLoc);
			allCmifItems.add(cmifMultiItem);
		endif;
