    <JadeMethod name="addTiTxnSubTerminalReceive" id="7f76d250-25e5-45cf-b370-f1b87bec1291">
        <source>addTiTxnSubTerminalReceive(_ti : CM_TrackedItem; _transportMode : Integer; _intArray: IntegerArray input);
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:    CCMS 1875 - determines if a Sub-Terminal receive ti txn is required and adds to
			list of transaction types to be created
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin

	if _ti = null or _ti.mySubTerminal = null then
		return;
	endif;
	
	if self.isSubTerminalsOn(_ti.myTerminal) then
		_intArray.add(self.getSubTerminalReceiveTxnType(_ti.mySubTerminal.type, _transportMode));
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transportMode" type="Integer"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
