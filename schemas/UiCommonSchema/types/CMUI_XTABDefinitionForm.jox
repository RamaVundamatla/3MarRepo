        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="831a19cb-b883-45cc-b7d9-5d72e0c3b94b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009250, locale);
	btnDeleteDefn.translateBubbleHelp(Xlat_0009251, locale);
	btnDeleteDefn.translateCaption(Xlat_0009252, locale);
	btnField.translateCaption(Xlat_0009253, locale);
	btnHideDetails.translateBubbleHelp(Xlat_0009254, locale);
	btnHideDetails.translateCaption(Xlat_0009255, locale);
	btnMapping.translateCaption(Xlat_0013548, locale);
	btnNewDefn.translateBubbleHelp(Xlat_0009256, locale);
	btnNewDefn.translateCaption(Xlat_0009257, locale);
	btnRunDefn.translateBubbleHelp(Xlat_0009258, locale);
	btnRunDefn.translateCaption(Xlat_0009259, locale);
	btnSaveAsCancel.translateBubbleHelp(Xlat_0009260, locale);
	btnSaveAsCancel.translateCaption(Xlat_0009261, locale);
	btnSaveAsDefn.translateBubbleHelp(Xlat_0009262, locale);
	btnSaveAsDefn.translateCaption(Xlat_0009263, locale);
	btnSaveAsName.translateBubbleHelp(Xlat_0009264, locale);
	btnSaveAsName.translateCaption(Xlat_0009265, locale);
	btnSaveDefn.translateBubbleHelp(Xlat_0009266, locale);
	btnSaveDefn.translateCaption(Xlat_0009267, locale);
	btnShowDetails.translateBubbleHelp(Xlat_0009268, locale);
	btnShowDetails.translateCaption(Xlat_0009269, locale);
	chkHideDetails.translateCaption(Xlat_0009270, locale);
	chkHideGrandTot.translateCaption(Xlat_0009271, locale);
	chkHideSubTotal.translateCaption(Xlat_0009272, locale);
