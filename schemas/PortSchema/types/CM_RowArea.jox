    <JadeMethod name="adjustWidth" id="98cf92d9-66d2-418a-b210-a34b59687138">
        <source>adjustWidth(_row : CM_RowAreaRow input; _width : Real; _previousDistance : Real);

vars

	lastRow, prev, next 		: CM_RowAreaRow;
	pos							: Integer;
	prevGapWidth, prevRowWidth	: Real;
	newWidth					: Real;

begin

	// Get postion of row.
	pos := self.allRows.indexOf(_row);
	// Make sure we can index correctly.
	if pos &lt;&gt; 0 and (pos - 1) &gt; 0 and (pos + 1) &lt;= self.allRows.size then		
		// Get preceding gap.
		prev := self.allRows.at(pos-1);
		// Get following gap.
		next := self.allRows.at(pos+1);
		// Do they exist.
		if prev &lt;&gt; null and next &lt;&gt; null then
			// Get change in row width.
			prevRowWidth := _row.width - _width;
			// Set new row width.
			_row.setAttributes(_width);
			// Adjust gaps if gap managed.
			if self.isGapManaged then
				// Get preceding gap width change.
				prevGapWidth := prev.width - _previousDistance;
				// Set new distance.
				prev.setAttributes(_previousDistance);
				// Add to changes together.
				newWidth := prevGapWidth + prevRowWidth; 
				// Adjust width of following gap.
				next.setAttributes((next.width + newWidth).max(0));
			endif;
			lastRow := self.allRows.last;
			if lastRow &lt;&gt; null then
				lastRow.setAttributes((self.lengthOfArea - rowAreaActualLength(false)).max(0));	
				return;
			endif;
		endif;
	endif;
	app.raiseCMException(GapNotFound, null, null);
end;</source>
        <Parameter name="_row" type="CM_RowAreaRow" usage="input"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_previousDistance" type="Real"/>
    </JadeMethod>
