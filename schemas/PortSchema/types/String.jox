//--------------------------------------------------------------
//Created: 09/10/2006 by cnwmo1
//--------------------------------------------------------------
//takes ddmmyyyy converts to dd/mm/yyyy
vars
	dateResult	: Date;
begin
	if self.length = 8 then
		dateResult.setDate(self[1:2].Integer, self[3:2].Integer, self[5:4].Integer);
