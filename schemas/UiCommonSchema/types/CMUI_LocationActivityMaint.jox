    <JadeMethod name="createCMIF" id="206af93b-da1d-40c8-92d8-7844811fa35c">
        <source>createCMIF(	_cmifDict : CMIF_TITxnControllerSet input;	
			_ti : CM_TrackedItem;
			_multiplier : Integer;
			_changedAmount : Decimal;
			_isVolume : Boolean;
			_isWeight : Boolean;
			_isQuantity : Boolean
			) : CMIF_BBDiscrepancyController protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906
29/03/2023	navkc1	CR# 56430 Task 56434 Jade - Onship Discrepancy
*/

vars

	cmif : CMIF_BBDiscrepancyController;

begin

	create cmif transient;
	//29/03/2023	navkc1	CR# 56430 TASK 56434
	if _ti.isOnShip() and _multiplier = -1 then
		cmif.type := TRANS_TYPE_DISCREPANCY_SHIP;
	else
		cmif.type := TRANS_TYPE_LocationDiscrep;
	endif;
	cmif.myTrackedItem := _ti;
	cmif.urNumber := "1";
	cmif.userId := app.myPassport.userCode;
	cmif.dateTime := self.myLocationActivity.dateTime;
	cmif.myLocationActivity := self.myLocationActivity;
	cmif.multiplier := _multiplier;
	cmif.reason := self.txtRemarks.text;
	
	if _isVolume then
		cmif.volumeChange := _changedAmount * _multiplier;
		cmif.newTotalVolume := _ti.totalVolume + cmif.volumeChange;
		if cmif.newTotalVolume &lt; 0 then
			delete cmif;
			app.raiseCMException( Remai_volum_will_less_than_zer, null, null );
			return null;
		endif;
	elseif _isWeight then
		cmif.weightChange := _changedAmount * _multiplier;
		cmif.newTotalWeight := _ti.totalWeight + cmif.weightChange;
		if cmif.newTotalWeight &lt; 0 then
			delete cmif;
			app.raiseCMException( Remai_weigh_will_less_than_zer, null, null );
			return null;
		endif;
	elseif _isQuantity then
		cmif.quantityChange := _changedAmount.Integer * _multiplier;
		cmif.newTotalQuantity := _ti.totalQuantity + cmif.quantityChange;
		if cmif.newTotalQuantity &lt; 0 then
			delete cmif;
			app.raiseCMException( Remai_quant_will_less_than_zer, null, null );
			return null;
		endif;
	endif;
				
	_cmifDict.add( cmif );
	
	return cmif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifDict" type="CMIF_TITxnControllerSet" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_multiplier" type="Integer"/>
        <Parameter name="_changedAmount" type="Decimal"/>
        <Parameter name="_isVolume" type="Boolean"/>
        <Parameter name="_isWeight" type="Boolean"/>
        <Parameter name="_isQuantity" type="Boolean"/>
        <ReturnType type="CMIF_BBDiscrepancyController"/>
    </JadeMethod>
    <JadeMethod name="createDiscrepCMIFs" id="33387feb-1d70-4d28-a77a-f1d1444413fa">
        <source>createDiscrepCMIFs(	_cmifDict : CMIF_TITxnControllerSet input;
					_sourceChanged : Boolean;
					_targetChanged : Boolean;
					_changedAmount : Decimal;
					_chgIsIncrease : Boolean;
					_isVolume : Boolean;
					_isWeight : Boolean;
					_isQuantity : Boolean
					) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	sourceTi : CM_TrackedItem;
	newSourceTi : CM_TrackedItem;
	targetTi : CM_TrackedItem;
	newTargetTi : CM_TrackedItem;

	cmif : CMIF_BBDiscrepancyController;
	multiplier : Integer;

begin

	//Find the object that we have to create the 'Location Activity Discrepancy' transactions against if the user selected one. 
	if self.cmbSourceItem.enabled then
		if self.cmbSourceItem.listIndex &gt; 0 then
			sourceTi := self.cmbSourceItem.itemObject[ self.cmbSourceItem.listIndex ].CM_TrackedItem;
		endif;
	endif;
	
	if self.cmbNewSourceItem.enabled then
		if self.cmbNewSourceItem.listIndex &gt; 0 then
			newSourceTi := self.cmbNewSourceItem.itemObject[ self.cmbNewSourceItem.listIndex ].CM_TrackedItem;
		endif;
	endif;
	
	if self.cmbTargetItem.enabled then
		if self.cmbTargetItem.listIndex &gt; 0 then
			targetTi := self.cmbTargetItem.itemObject[ self.cmbTargetItem.listIndex ].CM_TrackedItem;
		endif;
	endif;
	
	if self.cmbNewTargetItem.enabled then
		if self.cmbNewTargetItem.listIndex &gt; 0 then
			newTargetTi := self.cmbNewTargetItem.itemObject[ self.cmbNewTargetItem.listIndex ].CM_TrackedItem;
		endif;
	endif;
	
	if sourceTi = null 
	and newSourceTi = null
	and targetTi = null
	and newTargetTi = null
	then
		//nothing to do.
		return;
	endif;
	
//	NOTE: Rules effectively should be the same as "populateCmbItems"
	
	if self.myLocationActivity.isLocationDiscrepancyDecrease then
		if sourceTi &lt;&gt; null then
			if not _chgIsIncrease then
				//we are adding back to the source item, because the original Location discrepancy decreased it too much
				multiplier := 1;
			else
				//we are subtracting from the original source item again, because the original Location discrepancy was too little
				multiplier := -1;
			endif;
			cmif := createCMIF(	_cmifDict, sourceTi, multiplier, _changedAmount, _isVolume, _isWeight, _isQuantity );		
		endif;
		
	elseif self.myLocationActivity.isLocationDiscrepancyIncrease then
		if targetTi &lt;&gt; null then
			if _chgIsIncrease then
				//we are adding to the target item, because the original Location discrepancy increase wasn't enough
				multiplier := 1;
			else
				//we are subtracting from the original target item, because the original Location discrepancy was too big
				multiplier := -1;
			endif;
			cmif := createCMIF(	_cmifDict, targetTi, multiplier, _changedAmount, _isVolume, _isWeight, _isQuantity );
		endif;
		
	elseif self.myLocationActivity.isLocationMove then
	
		if sourceTi &lt;&gt; null then
			if ( _changedAmount &lt;&gt; 0 and not _chgIsIncrease ) or _sourceChanged then
				//we are adding back to this source item, because the original Location move amount was too much,
				//or we have selected a different source location. 
				multiplier := 1;
			elseif _chgIsIncrease then
				//we are subtracting more from source item, because the original Location move amount was not enough
				multiplier := -1;
			endif;
			cmif := createCMIF(	_cmifDict, sourceTi, multiplier, _changedAmount, _isVolume, _isWeight, _isQuantity );		
		endif;
		
		if newSourceTi &lt;&gt; null then
			if _sourceChanged then
				//we are subtracting more from the new source item, for the move amount
				multiplier := -1;
				cmif := createCMIF(	_cmifDict, newSourceTi, multiplier, _changedAmount, _isVolume, _isWeight, _isQuantity );
			endif;
		endif;
		
		if targetTi &lt;&gt; null then
			if _chgIsIncrease then
				//we are adding to the target item, because the move amount wasn't enough
				multiplier := 1;
			elseif _targetChanged or ( _changedAmount &lt;&gt; 0 and not _chgIsIncrease ) then
				//we are subtracting from the original target item, because the move amount was too much
				multiplier := -1;
			endif;
			cmif := createCMIF(	_cmifDict, targetTi, multiplier, _changedAmount, _isVolume, _isWeight, _isQuantity );
		endif;
		
		if newTargetTi &lt;&gt; null then
			if _targetChanged then
				//we are adding to the new target item, for the move amount
				multiplier := 1;
				cmif := createCMIF(	_cmifDict, newTargetTi, multiplier, _changedAmount, _isVolume, _isWeight, _isQuantity );
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifDict" type="CMIF_TITxnControllerSet" usage="input"/>
        <Parameter name="_sourceChanged" type="Boolean"/>
        <Parameter name="_targetChanged" type="Boolean"/>
        <Parameter name="_changedAmount" type="Decimal"/>
        <Parameter name="_chgIsIncrease" type="Boolean"/>
        <Parameter name="_isVolume" type="Boolean"/>
        <Parameter name="_isWeight" type="Boolean"/>
        <Parameter name="_isQuantity" type="Boolean"/>
    </JadeMethod>
