    <JadeMethod name="deleteYardAllocation" id="240578f2-93d8-41ca-9352-1aa42790a531">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>deleteYardAllocation() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2022	navak20	TFS ChangeRequest 54842: MTN - Yard Allocation Delete Option

*/

vars
	yaSet : CM_YardAllocationSet;
	msgStr : String;
	invalid : Boolean;
begin
	if self.myYardAllocation &lt;&gt; null then
		msgStr := app.getErrorString2(ConfirmDelete, self.myYardAllocation.code, app.getErrorString(Yard_allocation));
		if app.msgBox(msgStr, app.getErrorString(YAM_Msg_ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		
		on Exception do app.handleDeletedObject(exception, self.myYardAllocation, invalid);
		create yaSet transient;
		yaSet.add(self.myYardAllocation);
		
		if yaSet.size = 0 then
			return;
		endif;
		app.myTrxDA.trxDeleteYardAllocations(yaSet, app.myPassport);
		self.unloadForm;
	else
		app.msgBox(app.getErrorString(No_yard_allocation_selected), app.getErrorString(Select_yard_allocation), MsgBox_OK_Only);
	endif;
epilog
	delete yaSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCriteriaDesc" id="6aeec869-3790-42d9-8c25-666f3a2185c6">
        <source>displayCriteriaDesc();

/*

Purpose:		Refresh display for template criteria

Parameters:			

Return Value:		


Date			Who		Reason
20 August 2008	consw1	Initial creation

*/

vars
	criteria: CM_YACriteria;
	template : CM_YATemplate;
	text: String;
	cmifCriteria: CMIF_Object;
	
begin

	foreach cmifCriteria in self.allTemplateCriteria do
		criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		text := text &amp; criteria.getListDisplay &amp; " ";
	endforeach;
	
	self.lblCriteriaDesc.caption := null;

	if self.isTemplateModified then
		self.lblCriteriaDesc.caption := "(criteria modified) ";
	endif;

	template := cmbYATemplate.listObject.CM_YATemplate;

	if template &lt;&gt; null then
		self.lblCriteriaDesc.caption := self.lblCriteriaDesc.caption &amp; template.myYardAllocation.description;
	endif;
	
	self.txtYADescription.text := self.lblCriteriaDesc.caption;
	self.lblCriteriaDesc.caption := text.trimBlanks;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddLocation" id="2889c78c-11d4-448b-b7d0-b8fb9fdcb53d">
        <source>doAddLocation(location: String);
//05 August 2008	cnwdw1	
//
vars
	result: Boolean;
	topLeft, bottomRight: CM_LocationsController;
	r: Integer;
	locations: StringArray;
	range: String;
begin
	if location &lt;&gt; null and not self.tblLocation.findStringInColumn(location, 1, r) then
		// PAR 19308
		result := self.myTerminal.findYABlock(location, topLeft, bottomRight, null);
		
		if result then
			//cnwjo3 par 22883.
			if topLeft &lt;&gt; null and topLeft.myTerminalArea &lt;&gt; null then
				if not self.canAddToYA(topLeft.myTerminalArea) then
					app.msgBox(app.getErrorString(Yard_alloc_canno_added_this_ty), app.getErrorString(Error) ,MsgBox_OK_Only);
					return;
				endif;
			endif;
			
			create locations transient;
			foreach r in 1 to self.tblLocation.rows do
				range := self.tblLocation.accessCell(r, 1).text;
				if range &lt;&gt; null then
					locations.add(range);
				endif;
			endforeach;
			locations.add(location);
			if self.checkForRangeOverlap(locations) = false then
				self.tblLocation.rows := self.tblLocation.rows + 1;
				self.tblLocation.accessCell(self.tblLocation.rows, 1).text := location;
			else
				app.msgBox(app.getErrorString(YAM_Msg_OverlapingRanges), app.getErrorString(Error) ,MsgBox_OK_Only);
			endif;
		endif;
	endif;
epilog
	delete locations;
end;</source>
        <Parameter name="location" type="String"/>
    </JadeMethod>
