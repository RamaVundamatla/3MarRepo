    <JadeMethod name="getDisplayStringForAttribute" id="28ab3522-23b7-40d3-b996-8c6b9a8ddd0a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58258: Jade - Ownership Changed Transaction

*/

vars
	string		: String;
begin
	if _attrName = ETRow_Details then
		string := 	"Change of Ownership - " &amp; self.refNumber &amp; CrLf &amp;
					"Effective - " &amp; self.dateTimeCOO.asStringJMT() &amp; CrLf &amp;// ### TFS BUG 65978 04SEP2024 NAVAB1
					"Free Storage Expiry - " &amp; self.expiryOperatorNew.asStringJMT() &amp; CrLf &amp;// ### TFS BUG 65978 04SEP2024 NAVAB1
					"Old Operator - " &amp; self.operatorOldCode &amp; CrLf &amp;
					"New Operator - " &amp; self.operatorNewCode &amp; CrLf &amp;
					"Transferred Quantity - " &amp; self.transferredQuantity.asStringJMT() &amp; CrLf &amp; 
					"Transferred Weight - " &amp; app.getWeightForDefaultDisplay(self.transferredWeight) &amp; CrLf &amp; 
					"Transferred Volume - " &amp; app.getVolumeForDefaultDisplay(self.transferredVolume);
					
		return string;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="46a98c4c-6e0d-4842-a7eb-960ad8ea824d">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023 navmv20 CR 58213 Task 58214: Jade - New TI Transaction

*/

vars

begin
	return inheritMethod() &amp; self.refNumber &amp; " " &amp; self.dateTimeCOO.asStringJMT() &amp; " " &amp; self.operatorOldCode &amp; " -&gt; " &amp; self.operatorNewCode;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCOO" id="dbd0d7eb-b7d6-4e7a-9d35-00771e3b987d">
        <updating/>
        <source>setDetailsFromCOO(_cooDetails : CM_OwnershipChangeDetail; _cooHeader : CM_OwnershipChange; _newTI : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58258: Jade - Ownership Changed Transaction

*/

vars
	
begin
	
	if _cooDetails = null and _cooHeader = null then
		return;
	endif;
	
	self.condition := _cooHeader.condition;
	self.dateTimeCOO := _cooHeader.dateTimeCOO;
	self.expiryOperatorNew := _cooHeader.storageExpiryOperatorNew;
	//self.expiryOperatorOld := null;
	self.freeDaysOperatorNew := _cooHeader.freeDaysOperatorNew;
	self.freeDaysOperatorOld := _cooHeader.freeDaysOperatorOld;
	//self.freeDaysOperatorOriginal := null;
	if _cooHeader.myOperatorNew &lt;&gt; null then
		self.operatorNewCode := _cooHeader.myOperatorNew.code;
	endif;
	if _cooHeader.myOperatorOld &lt;&gt; null then
		self.operatorOldCode := _cooHeader.myOperatorOld.code;
	endif;
	if _cooHeader.myOperatorOrig &lt;&gt; null then
		self.operatorOriginalCode := _cooHeader.myOperatorOrig.code;
	endif;
	//self.previousId := null;
	self.refNumber := _cooHeader.refNumber;
	
	//08/12/2023	navkc1 ChangeRequest 58261 Task 58262
	if _cooHeader.myIncoterm &lt;&gt; null then
		self.incoTermCode := _cooHeader.myIncoterm.code;
	endif;
	
	//08/12/2023	navkc1 ChangeRequest 58261 Task 58262
	if _cooHeader.myOperatorStorage &lt;&gt; null then
		self.operatorStorageCode := _cooHeader.myOperatorStorage.code;
	endif;
	
	if _newTI &lt;&gt; null then
		self.transferredQuantity := _newTI.totalQuantity;
		self.transferredVolume := _newTI.totalVolume;
		self.transferredWeight := _newTI.totalWeight;
	elseif _cooDetails &lt;&gt; null then
		self.transferredQuantity := _cooDetails.transferredQuantity;
		self.transferredVolume := _cooDetails.transferredVolume;
		self.transferredWeight := _cooDetails.transferredWeight;
	else
		self.transferredQuantity := _cooHeader.transferredQuantity;
		self.transferredVolume := _cooHeader.transferredVolume;
		self.transferredWeight := _cooHeader.transferredWeight;
	endif;
epilog

end;</source>
        <Parameter name="_cooDetails" type="CM_OwnershipChangeDetail"/>
        <Parameter name="_cooHeader" type="CM_OwnershipChange"/>
        <Parameter name="_newTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="d5ec20f5-3291-467f-a1f7-b58f7636ebc8">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023 navmv20 CR 58213 Task 58214: Jade - New TI Transaction
*/

vars

begin
	_value := "Ownership Changed";

epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
