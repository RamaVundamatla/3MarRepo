    <JadeMethod name="generateSlots" id="7fa5943b-dfcc-46cd-b3f9-aece97a1372e">
        <source>generateSlots( _date : Date):Boolean;
/*

Purpose:			Generates new CM_VehicleBookingTimeSlot's

Parameters:			_date	Date	Start date time to use to generate the VBS slots
					_user	CM_User	The user who created the slots (We get this from the BGP Controller in case it has a specific user)

Return Value:		Boolean	Representing whether slots were created or not

Date		Who		Reason
10 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
29 May 2023	navpw1	TFS: 58169 - Fixed 1090 error caused by type being null, which it can be. Added a new var for type code and checked for null
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
09 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

vars
	index		: Integer;
	proxy		: CM_VehicleBookingTimeSlot;
	loadState	: Boolean;
	startTS,
	endTS		: TimeStamp;
	vbTerm		: CM_VehicleBookingTerminal;
	newVBooking	: CM_VehicleBookingTimeSlot;
	type		: CM_VehicleBookingTimeSlotType;
	typeCode	: String;
	
begin

	if self.numberOfSlots &lt; 1 then
		return true;
	endif;
	
	startTS.setDate( _date );
	startTS.setTime( self.startTime );
	endTS := startTS.cnEcAddMinutes( self.duration );
	
	if startTS &lt; app.actualTimeServer then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		return true; // don't fail, just don't create anything.
	endif;
	
	vbTerm := self.myVehicleBookingDayTemplate.myVehicleBookingTerminal;
	type   := self.myVBTimeslotType;
	if type &lt;&gt; null and type.notAvailableForEntry then
		type := null;
	endif;
	
	if type &lt;&gt; null then
		typeCode := type.code;
	endif;
	
	foreach index in 1 to self.numberOfSlots do
		delete proxy;
		create proxy transient;
		
		proxy.setProxy(	startTS,	//_scheduleTSstart : TimeStamp;
						endTS,	//_scheduleTSend : TimeStamp;
						vbTerm,	//_myVBTerminal : CM_VehicleBookingTerminal;
						null,	//_myCarrier : CM_Carrier;
						null,	//_mySubCarrier : CM_Carrier;
						null,	//_myDriver : CM_DriverDetails;
						null,	//_myVehicle : CM_Vehicle;
						self.remarks,	//_remarks : String;
						null,	//_includesDelivery : Boolean;
						null,	//_includesPickUp : Boolean;
						null,	//_bookedTiIds : StringArray;
						null,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
						type,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
						vbTerm.generateNextVBSTimeslotId(),	//_id : String;
						null,	//_allBookingRefs : CM_BookingRefSet;
						null,	//_allBulkReleases : CM_BulkReleaseSet
						null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
						null,	//_preGateInCheck : Boolean;
						null,	//_preGateOutChck : Boolean;
						null,	//_kioskCheck : Boolean;
						null,	//_externalReference : String
						null 	// 29 July 2024 navcs2	ChangeRequest 63928
						);
		
		proxy.setCreationMethod(CM_VehicleBookingTimeSlot.Creation_Method_BGP);					//14.07.2023 navma1 #59136
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.warningsAcknowledged	:= true;
		
		//app.myTrxCA.trxCreateVehicleBooking(proxy, newVBooking, app.myPassport);				// TFS 51248
		app.myTrxCA.trxCreateVehicleBooking(proxy, newVBooking, null, null, app.myPassport);	// TFS 51248
		
		if not app.myPassport.trxCompletedOK then
			return false;
		// ### TFS 54049 (56519) 08Mar2023 NAVPW1
		else
			app.writeLog("Created VBS Slot with ID: " &amp; proxy.id &amp; " For Type: " &amp; typeCode, LogINFO);
		// ### TFS 54049 (56519) 08Mar2023 NAVPW1
		endif;
		
	endforeach;
	
	return true;

epilog
	delete proxy;
end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForError" id="d9fc7e19-83a7-4eb6-9073-8b5ef156b0d4">
        <source>getDisplayForError():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	return app.getErrorString(Vehicle_schedul_time_templat) &amp; " " &amp; self.startTime.asStringJMT &amp; "-" &amp; self.endTime.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="40cd96f4-3bcc-4c7b-9401-e52ada23ffc4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation

*/

vars

begin

	//ETDef_TimeSlotTemplate

	if _attrName = ETRow_StartTime then
		return self.startTime.asStringJMT;
	
	elseif _attrName = ETRow_Duration then
		return self.duration.String;
	
	elseif _attrName = ETRow_EndTime then
		return self.endTime.asStringJMT;
	
	elseif _attrName = ETRow_NumberOfSlots then
		return self.numberOfSlots.String;
	
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	
	//09 Oct 2014	NDL	Par 35008
	elseif _attrName = ETRow_TsType then
		if self.myVBTimeslotType &lt;&gt; null then
			return self.myVBTimeslotType.code;
		endif;
		return null;
	
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5d2f7648-273a-4d2f-a8c1-f64bf9d6d96d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2014	cnwndl1	Initial creation

*/

vars

	pxy : CM_VehicleBookingTimeTemplate;

begin

	pxy := inheritMethod();
	
	pxy.myVBTimeslotType := self.myVBTimeslotType;
	
	return pxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
