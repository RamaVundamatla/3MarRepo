    <JadeMethod name="utlUpdateProduct" id="18d0a9e3-af68-4722-977d-16e0ae207f22">
        <source>utlUpdateProduct(_proxyProduct : CM_Product input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newCode,
	typeCode		: CM_ProductAttributeCode;
	operator		: CM_Operator;
	existingProduct,
	realProduct		: CM_Product;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();

	_proxyProduct.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyProduct.pxyGetRealObjectAndEdition(realProduct, expectedEdition);
	
	if realProduct = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Product.name, null, null);
		return;
	endif;

	app.myValUA.valProduct(realProduct, _proxyProduct);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realProduct);

	if _passport.noErrors and realProduct.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Product), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realProduct, true);
	endif;
	
	if _passport.noErrors then
		realProduct.setForUpdate(_proxyProduct);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realProduct, false);
	endif;

	if (not _passport.noErrors) then
		return;
	endif;
// Taken out as this is not consistent. ie if deleting or edidting a code does not delete same code in other products. 
// each product attribute of an individual product will have its own set of codes. these can be cloned from another product on creation. 
// this means each product of a type can have different codes for a product attribute. 
/*
	//copy any new type codes to all other products for this produt's operator
	//N.B may have to do this for other product attributes that have codes in the future (ie.myHeightString etc.)
	if realProduct.myType &lt;&gt; null then
		operator := realProduct.myOperator;
		foreach typeCode in realProduct.myType.allCodes do : codeLoop
			foreach existingProduct in operator.allProducts do : productLoop
				if existingProduct.myType = null then
					continue productLoop;
				endif;
				
				if existingProduct.myCargoType &lt;&gt; realProduct.myCargoType then 
					// added 19/09/2005 if not same cargo type then not interested in updating?
					continue;
				endif;
				
				if (not existingProduct.myType.allCodes.includesKey(typeCode.code)) then
					//create code and add it
					create newCode persistent;
					newCode.setCode(typeCode.code);
					newCode.setDescription(typeCode.description);
					newCode.setNotAvailableForEntry(typeCode.notAvailableForEntry);
					existingProduct.myType.allCodes.add(newCode);
				endif;
			endforeach;	
		endforeach;
	endif;
*/
	//navsp1 01Jun2022 TFS#53104
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			realProduct.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE, BGP_OpsViewWSRequest.OPS_TYPE_CARGOSUBTYPE, realProduct);
		endif;
	endif;
epilog
	
	
end;</source>
        <Parameter name="_proxyProduct" type="CM_Product" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateProductGroup" id="da7a2b78-916c-4f0e-b944-f148b0cba62d">
        <source>utlUpdateProductGroup(pProxyProductGroup:CM_ProductGroup; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realProductGroup:CM_ProductGroup;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	pProxyProductGroup.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyProductGroup.pxyGetRealObjectAndEdition(realProductGroup, expectedEdition);
	
	if realProductGroup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ProductGroup.name, null, null);
		return;
	endif;

	app.myValUA.valProductGroup(realProductGroup, pProxyProductGroup);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realProductGroup);

	if _passport.noErrors and realProductGroup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ProductGroup', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realProductGroup, true);
	endif;
	
	if _passport.noErrors then
		if realProductGroup.colour &lt;&gt; pProxyProductGroup.colour then
			codeChanged := true;
		endif;
		realProductGroup.setForUpdate(pProxyProductGroup);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realProductGroup.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realProductGroup.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realProductGroup.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realProductGroup, false);
	endif;

end;</source>
        <Parameter name="pProxyProductGroup" type="CM_ProductGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateProformaCritUnits" id="1dfb8402-ae22-4cdd-804e-6ab3897e4691">
