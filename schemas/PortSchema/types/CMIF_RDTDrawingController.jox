    <JadeMethod name="drawAreaSubsetLandscape" id="6449e965-ed6c-4ad5-849f-564cf3ab4c4b">
        <updating/>
        <source>drawAreaSubsetLandscape(_gapRows : IntegerArray; _gapCols : IntegerArray) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	y1 				: Real;
	flipCol,
	row, i 			: Integer;
	gridWidth,
	gridHeight		: Real;
	finishedRows	: Boolean;
	lc 				: CM_LocationsController;
	maxY			: Real;
begin		 
	if self.flipV then
		y1 := self.myDrawingFrame.clientHeight() + self.yDrawOffset - self.bottomOffset;	
	else
		y1 := self.yDrawOffset + self.topOffset;
	endif;
	//05/11/2010 cnwdz2 26196
	self.yDrawStart := y1;
	maxY := self.myDrawingFrame.clientHeight();
	if y1 &gt; maxY then
		self.yDrawStart := maxY;
	endif;
	if y1 &lt; 0 then
		self.yDrawStart := 0;
	endif;

	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	if self.flipV then
		row := self.bottomGridRowDraw;	
	else
		row := self.topGridRowDraw;
	endif;
	i:=0;
	while not finishedRows do	
		lc := null;
		//gridRow := self.myGridArea.allGridRows[row];	
		self.drawRowsLandscape(y1, gridWidth, gridHeight, row, _gapCols, lc);
		if _gapRows.includes(row) and lc &lt;&gt; null then
			// Move up/down
			if self.flipV then
				y1 := y1 - lc.getGapWidthPixels(gridHeight);
			else
				y1 := y1 + lc.getGapWidthPixels(gridHeight);
			endif;
		else
			// Move up/down
			if self.flipV then
				y1 := y1 - gridHeight;
			else
				y1 := y1 + gridHeight;
			endif;
		endif;
		
		row := row + 1;
		i:=i+1;
		if i &gt;= self.numGridRowsToDraw then
			break;
		endif;
			
	endwhile;
	//05/11/2010 cnwdz2 26196
	self.yDrawEnd := y1;	
	if y1 &gt; maxY then
		self.yDrawEnd := maxY;
	endif;
	if y1 &lt; 0 then
		self.yDrawEnd := 0;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gapRows" type="IntegerArray"/>
        <Parameter name="_gapCols" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="drawAreaSubsetPortrait" id="f12be4dc-a567-474a-9811-7f96f0965866">
        <updating/>
        <source>drawAreaSubsetPortrait(_gapRows : IntegerArray; _gapCols : IntegerArray) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	x1 				: Real;
	flipCol,
	col ,i			: Integer;
	gridWidth,
	gridHeight		: Real;
	gridRow 		: CM_GridRow;
	finishedCols	: Boolean;
	lc 				: CM_LocationsController;
	maxX 			: Real;
begin
	
	// Drawing  portrait, so rows == columns &amp; columns == rows
	
	if self.flipH then
		x1 := self.myDrawingFrame.clientWidth() + self.xDrawOffset - self.rightOffset;	
	else
		x1 := self.xDrawOffset + self.leftOffset;
	endif;
	//05/11/2010 cnwdz2 26196
	self.xDrawStart := x1;
	maxX := self.myDrawingFrame.clientWidth();
	if x1 &gt; maxX then
		self.xDrawStart := maxX;
	endif;
	if x1 &lt; 0 then
		self.xDrawStart := 0;
	endif;
	
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	if self.flipH then
		col := self.rightGridColDraw;	
	else
		col := self.leftGridColDraw;
	endif;
	
	while not finishedCols do	
		lc := null;
		self.drawRowsPortrait(x1, gridWidth, gridHeight, col, _gapRows, lc/*remember, this is row*/);
		if _gapCols.includes(col) and lc &lt;&gt; null then
			if self.flipH then
				x1 := x1 - lc.getGapWidthPixels(gridWidth);
			else
				x1 := x1 + lc.getGapWidthPixels(gridWidth);
			endif;
		else
			if self.flipH then
				x1 := x1 - gridWidth;
			else
				x1 := x1 + gridWidth;
			endif;
		endif;
		
		col := col + 1;
		i:=i+1;
		if i &gt;= self.numGridColsToDraw then
			break;
		endif;		
	endwhile;
	//05/11/2010 cnwdz2 26196
	self.xDrawEnd := x1;
	if x1 &gt; maxX then
		self.xDrawEnd := maxX;
	endif;
	if x1 &lt; 0 then
		self.xDrawEnd := 0;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gapRows" type="IntegerArray"/>
        <Parameter name="_gapCols" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="drawColumnRowHeaders" id="4427a3cf-5300-4714-8f5e-8447d9a8aff9">
        <updating/>
        <source>drawColumnRowHeaders(_gapRows : IntegerArray; _gapCols : IntegerArray) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Sep 2010	cnwdz2	Initial creation 25642
29 May 2012	cnwer1	PAR 29588 

*/

vars
	x1,y1 				: Real;
	col ,i			: Integer;
	row 			: Integer;
	gridWidth,
	gridHeight		: Real;
	finishedCols	: Boolean;
	lc 				: CM_LocationsController;
	lcDraw, otherLCDraw			: CMIF_RDTLocationDrawElement;
	rowIndex,
	colIndex		: Integer;
	isGapRow,
	isGapCol    : Boolean;
	vLabelFrame,
	hLabelFrame		: Frame;
	tmpTA			: CM_GridArea;
begin
	tmpTA:=self.myGridArea;
	if tmpTA = null then
		return;
	endif;

	if self.flipV then
		y1 := self.myDrawingFrame.clientHeight() + self.yDrawOffset - self.bottomOffset;
		rowIndex := self.bottomGridRowDraw;	
	else
		y1 := self.yDrawOffset + self.topOffset;
		rowIndex := self.topGridRowDraw;
	endif;
	if self.flipH then
		x1 := self.myDrawingFrame.clientWidth + self.xDrawOffset - self.rightOffset;
		colIndex := self.rightGridColDraw;
	else
		x1 := self.xDrawOffset + self.leftOffset;
		colIndex := self.leftGridColDraw;
	endif;	
	
	row:=rowIndex;
	col:=colIndex;	
	finishedCols := false;
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	//05/11/2010 cnwdz2 26196
	if self.myLeftVLabelsFrame &lt;&gt; null then
		vLabelFrame := self.myLeftVLabelsFrame;
	elseif self.myRightVLabelsFrame  &lt;&gt; null then
		vLabelFrame := self.myRightVLabelsFrame;
	endif;
	//19/04/2011 cnwdz2 par27313
	if self.drawMode = CMIF_RDTDrawElement.MODE_FACE and self.isDrawForkLiftStack(self.myTargetLocation) then
		vLabelFrame := null;
	endif;	
	i := 0;
	if vLabelFrame &lt;&gt; null then 
		while  i &lt;= self.numGridRowsToDraw  do	
			if (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END)  then	
				lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(row,self.leftGridColDraw  , self.gridRowToStackHeight(row, self.myGridArea)); //colself.leftGridColDraw
			else
				lcDraw := self.myDisplayBuilder.getLocationDraw(row , self.leftGridColDraw); 
			endif;
			lc := null;
			if lcDraw &lt;&gt; null then 			
				lc := lcDraw.getLocationController();
				isGapRow := false;
				if _gapRows.includes(row) then
					isGapRow := true;
				endif;				
				if vLabelFrame.width = self.vLabelsFrameWidth and lc.isKindOf(CM_GridController) then		
				
					if tmpTA.isKindOf(CM_ForkLiftStack) or tmpTA.isKindOf(CM_StraddleStack) then
						if not self.flipH and tmpTA.leftLabel &lt;&gt; null then	
							if self.myTopLeftLabelFrame  &lt;&gt; null then
								self.myTopLeftLabelFrame.width := self.myTopLeftLabelFrame.width + self.ACCESS_LABEL_WIDTH;			
							endif;
							vLabelFrame.width :=  vLabelFrame.width + self.ACCESS_LABEL_WIDTH;
							if self.myBottomLeftLabelFrame &lt;&gt; null then
								self.myBottomLeftLabelFrame.width := self.myBottomLeftLabelFrame.width + self.ACCESS_LABEL_WIDTH;								
							endif;
							if not self.isLandscape then
								self.yDrawOffset := self.yDrawOffset + self.ACCESS_LABEL_HEIGHT;
							endif;
						endif;						
					endif;
				endif;

				if self.myLeftVLabelsFrame &lt;&gt; null then
					self.drawHeader(self.myLeftVLabelsFrame,0, y1, vLabelFrame.width, gridHeight, lcDraw, isGapRow);	
				endif;
				if self.myRightVLabelsFrame &lt;&gt; null then
					otherLCDraw:=lcDraw;
					if (self.drawMode = CMIF_RDTDrawElement.MODE_END) then	
						otherLCDraw := self.myDisplayBuilder.getLocationDrawWithHeight(row,self.rightGridColDraw , self.gridRowToStackHeight(row, self.myGridArea));
					elseif (self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN and not self.isLandscape) then
						otherLCDraw := self.myDisplayBuilder.getLocationDraw(row,self.rightGridColDraw);
					endif;
					
					self.drawHeader(self.myRightVLabelsFrame,0, y1, self.myRightVLabelsFrame.width, gridHeight, otherLCDraw, isGapRow);	
				endif;
			
				if self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END then
					break;
				endif;
			endif;
			
			//08/10/2010 cnwdz2 par25671
			if lc &lt;&gt; null and _gapRows.includes(row) then
				// Move up/down
				if self.flipV then
					y1 := y1 - lc.getGapWidthPixels(gridHeight);			
				else
					y1 := y1 + lc.getGapWidthPixels(gridHeight);			
				endif;
			else
				// Move up/down
				if self.flipV then
					y1 := y1 - gridHeight;			
				else
					y1 := y1 + gridHeight;			
				endif;			
			endif;

			finishedCols := false;
			row := row + 1;
			i:=i+1;
		endwhile;
	endif;
	
	//05/11/2010 cnwdz2 26196
	if self.myTopHLabelsFrame &lt;&gt; null then
		hLabelFrame := self.myTopHLabelsFrame;
	elseif self.myBottomHLabelsFrame  &lt;&gt; null then
		hLabelFrame := self.myBottomHLabelsFrame;
	endif;
	i := 0;
	if hLabelFrame &lt;&gt; null then
		while i &lt;= self.numGridColsToDraw   do				
			if (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END) then	
				lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(rowIndex, col, self.gridRowToStackHeight(rowIndex, self.myGridArea));
			else
				lcDraw := self.myDisplayBuilder.getLocationDraw(self.topGridRowDraw , col);
			endif;
			lc := null;
			if lcDraw &lt;&gt; null then 
				lc := lcDraw.getLocationController();
				isGapCol := false;
				if _gapCols.includes(col) then
					isGapCol := true;
				endif;		
				//21/06/2011 cnwdz2 27732 start

				if self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
					lcDraw.setLookForkLiftStackFromBottom(self.lookForkLiftStackFromBottom);
				endif;
				if hLabelFrame.height = self.hLabelsFrameHeight and lc.isKindOf(CM_GridController) then
					if tmpTA.isKindOf(CM_ForkLiftStack) or tmpTA.isKindOf(CM_StraddleStack) then						
						if not self.flipV and tmpTA.topLabel &lt;&gt; null then
							if self.myTopLeftLabelFrame &lt;&gt; null then
								self.myTopLeftLabelFrame.height := self.myTopLeftLabelFrame.height + self.ACCESS_LABEL_HEIGHT;	
							endif;
							hLabelFrame.height :=  hLabelFrame.height + self.ACCESS_LABEL_HEIGHT;
							if self.myTopRightLabelFrame &lt;&gt; null then
								self.myTopRightLabelFrame.height := self.myTopRightLabelFrame.height + self.ACCESS_LABEL_HEIGHT;								
							endif;
							if not self.isLandscape then
								self.xDrawOffset := self.xDrawOffset + self.ACCESS_LABEL_WIDTH;
							endif;
						endif;
					endif;
				endif;
					
				if 	self.myTopHLabelsFrame &lt;&gt; null then
					self.drawHeader(self.myTopHLabelsFrame, x1, 0, gridWidth, hLabelFrame.height, lcDraw, isGapCol);
				endif;
				if self.myBottomHLabelsFrame &lt;&gt; null then
					otherLCDraw:=lcDraw;
					if (self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN and self.isLandscape) then	
						otherLCDraw := self.myDisplayBuilder.getLocationDraw(self.bottomGridRowDraw , col);
					endif;
					
					self.drawHeader(self.myBottomHLabelsFrame,x1, 0, gridWidth, self.myBottomHLabelsFrame.height, otherLCDraw, isGapCol);
				endif;					
			endif;
			
			//08/10/2010 cnwdz2 par25671
			if lc &lt;&gt; null and _gapCols.includes(col) then
				// Move across
				if self.flipH then
					x1 := x1 - lc.getGapWidthPixels(gridWidth);
				else
					x1 := x1 + lc.getGapWidthPixels(gridWidth);
				endif;
				lc := null;
			else
				// Move across
				if self.flipH then
					x1 := x1 - gridWidth;
				else
					x1 := x1 + gridWidth;
				endif;
			endif;		
			col := col + 1;
			i:=i+1;			
		endwhile;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gapRows" type="IntegerArray"/>
        <Parameter name="_gapCols" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="drawEverything" id="96b92731-98fc-405c-a15c-450a270205e4">
        <updating/>
        <source>drawEverything() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation
29 May 2012	cnwer1	PAR 29588 
*/

vars
	picture	: Picture;
	gapCols,
	gapRows : IntegerArray;
begin
	self.hideSelectedLocationHighlight();
	self.clearGraphics();
	self.myDrawingFrame.transparent := true;

	create gapRows transient;
	create gapCols transient;
	
	self.getGapRows(gapRows);
	self.getGapColumns(gapCols);

	self.drawColumnRowHeaders(gapRows,gapCols);//29/05/2012 cnwer1 29588
	if self.isLandscape then			
		self.drawAreaSubsetLandscape(gapRows,gapCols);
	else		
		self.drawAreaSubsetPortrait(gapRows,gapCols);
	endif;
	self.drawGrid();
	self.drawGuides();
	
	// To fix problems where frames go missing on mobile device
	if self.myViewportFrame.parent &lt;&gt; null then 
		self.myViewportFrame.parent.zOrder(0);
	endif;

epilog
	delete gapRows;
	delete gapCols;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawFancyTI" id="47c9cee8-b466-4369-aa8c-d5a8628269e9">
        <source>drawFancyTI(_x1, _y1, _x2, _y2 : Real; _ti : CM_TrackedItem; _frame : Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwjk3	Initial creation

// Just for demo purposes


*/

vars
	picture			: Picture;
	opCode			: String;
begin
	opCode := _ti.operatorCode;
	if opCode = "ABOC" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicGreenV();
	elseif opCode = "DOUG" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicRedV();
	elseif opCode = "HLL" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicLightBlueV();
	elseif opCode = "TAT" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicOrangeV();
	elseif opCode = "CMS" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicBlueV();
	elseif opCode = "CSA" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicYellowV();
	else
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicPurpleV();
	endif;
	_frame.drawPictureIn(picture.picture, _x1, _y1, _x2, _y2);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="drawGrid" id="3ac65784-6504-4802-8506-38641a38a92f">
        <source>drawGrid() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	hLineLen,
	vLineLen,
	gridWidth,
	gridHeight		: Real;
	numHLines,
	numVLines,
	count			: Integer;
begin
	if not self.showGrid then
		return;
	endif;
	
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	numHLines := self.numGridRowsToDraw;
	numVLines := self.numGridColsToDraw;

	hLineLen := self.myDrawingFrame.width;
	vLineLen := self.myDrawingFrame.height;

	
	// Adjust number of lines
	if self.flipV  then
		if self.bottomGridRow = 1 and self.vScrollOffset &gt; 0 then
			numHLines := numHLines -1;
		endif;
	else
		if self.bottomGridRow = self.maxGridRow and self.vScrollOffset &gt; 0 then
			numHLines := numHLines -1;
		endif;
	endif;	
	if self.flipH  then
		if self.rightGridCol = 1 and self.hScrollOffset &gt; 0 then
			numVLines := numVLines -1;
		endif;
	else
		if self.rightGridCol = self.maxGridCol and self.hScrollOffset &gt; 0 then
			numVLines := numVLines -1;
		endif;
	endif;	
	
	// Draw horizontal lines 
	foreach count in 0 to numHLines do
		if self.flipV then
			self.myTIFrame.drawLine(0, self.myDrawingFrame.height - (self.bottomOffset - self.vScrollOffset + gridHeight * count), hLineLen, self.myDrawingFrame.height - (self.bottomOffset - self.vScrollOffset + gridHeight * count), Red); 
		else
			self.myTIFrame.drawLine(0, self.topOffset + self.vScrollOffset + gridHeight * count, hLineLen, self.topOffset + self.vScrollOffset + gridHeight * count, Red); 			
		endif;
	endforeach;

	// Draw vertical lines 
	foreach count in 0 to numVLines  do
		if self.flipH then
			self.myTIFrame.drawLine(self.myDrawingFrame.width - (self.rightOffset - self.hScrollOffset + gridWidth * count), 0, self.myDrawingFrame.width - (self.rightOffset - self.hScrollOffset + gridWidth * count), vLineLen, Red); 
		else
			self.myTIFrame.drawLine(self.leftOffset + self.hScrollOffset + gridWidth * count, 0, self.leftOffset + self.hScrollOffset + gridWidth * count, vLineLen, Red); 
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawGuides" id="c460d56a-e983-492f-be06-9015a926a665">
        <source>drawGuides() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not self.showGuideLines then
		return;
	endif;
	
	self.myTIFrame.drawLine(self.myDrawingFrame.clientWidth/2, 0, self.myDrawingFrame.clientWidth/2, self.myDrawingFrame.clientHeight, Blue);
	self.myTIFrame.drawLine(0, self.myDrawingFrame.clientHeight/2, self.myDrawingFrame.clientWidth, self.myDrawingFrame.clientHeight/2, Blue);
	self.myTIFrame.drawLine(self.leftOffset, 0, self.leftOffset, self.myDrawingFrame.clientHeight, Black);
	self.myTIFrame.drawLine(self.myDrawingFrame.clientWidth - self.rightOffset, 0, self.myDrawingFrame.clientWidth - self.rightOffset, self.myDrawingFrame.clientHeight, Black);
	self.myTIFrame.drawLine(0, self.topOffset, self.myDrawingFrame.clientWidth, self.topOffset, Black);
	self.myTIFrame.drawLine(0, self.myDrawingFrame.clientHeight - self.bottomOffset, self.myDrawingFrame.clientWidth, self.myDrawingFrame.clientHeight - self.bottomOffset, Black);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawHeader" id="3791df0b-fac1-4315-aa26-101c4f292a01">
        <source>drawHeader(	_headerFrame : Frame;
			_x1, _y1, _headerWidth, _headerHeight : Real; 
			_lcDraw : CMIF_RDTLocationDrawElement;  
			_isGapRow : Boolean) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732
29 May 2012	cnwer1	PAR 29588 refactored 4 methods into 1
*/

vars
	headerX1, headerY1,
	headerX2, headerY2	: Real;
begin	
	if _lcDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			headerX1 := _x1 - _headerWidth;
			headerY1 := _y1 - _headerHeight;
			headerX2 := _x1;
			headerY2 := _y1;
		else
			headerX1 := _x1 - _headerWidth;
			headerY1 := _y1;
			headerX2 := _x1;
			headerY2 := _y1 + _headerHeight;
		endif;
	else
		if self.flipV then
			headerX1 := _x1;
			headerY1 := _y1 - _headerHeight;
			headerX2 := _x1 + _headerWidth;
			headerY2 := _y1;
		else
			headerX1 := _x1;
			headerY1 := _y1;
			headerX2 := _x1 + _headerWidth;
			headerY2 := _y1 + _headerHeight;
		endif;
	endif;
	
	if _headerFrame = self.myLeftVLabelsFrame then
		_lcDraw.drawGridLeftRowHeader(headerX1, headerY1, headerX2, headerY2, self.myLeftVLabelsFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode, _isGapRow);	
	elseif _headerFrame =  self.myRightVLabelsFrame then
		_lcDraw.drawGridRightRowHeader(headerX1, headerY1, headerX2, headerY2, self.myRightVLabelsFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode, _isGapRow);	
	elseif _headerFrame =  self.myTopHLabelsFrame then 
		_lcDraw.drawGridTopColumnHeader(headerX1, headerY1, headerX2, headerY2, self.myTopHLabelsFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode, _isGapRow);	
	elseif _headerFrame =  self.myBottomHLabelsFrame then 
		_lcDraw.drawGridBottomColumnHeader(headerX1, headerY1, headerX2, headerY2, self.myBottomHLabelsFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode, _isGapRow);	
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_headerFrame" type="Frame"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_headerWidth" type="Real"/>
        <Parameter name="_headerHeight" type="Real"/>
        <Parameter name="_lcDraw" type="CMIF_RDTLocationDrawElement"/>
        <Parameter name="_isGapRow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawLocation" id="8b793389-cc3a-4d27-b8e1-5bb3ae58990f">
        <source>drawLocation( _x1, _y1, _gridWidth, _gridHeight : Real; _lcDraw : CMIF_RDTLocationDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
	gx1, gy1,
	gx2, gy2	: Real;
begin	
	if _lcDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			gx1 := _x1 - _gridWidth;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1;
			gy2 := _y1;
		else
			gx1 := _x1 - _gridWidth;
			gy1 := _y1;
			gx2 := _x1;
			gy2 := _y1 + _gridHeight;
		endif;
	else
		if self.flipV then
			gx1 := _x1;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1 + _gridWidth;
			gy2 := _y1;
		else
			gx1 := _x1;
			gy1 := _y1;
			gx2 := _x1 + _gridWidth;
			gy2 := _y1 + _gridHeight;
		endif;
	endif;
	
	_lcDraw.draw(gx1, gy1, gx2, gy2, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
	_lcDraw.gridPointsToElementPoints(gx1, gy1, gx2, gy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
	self.storeLCScreenPos(gx1, gy1, gx2, gy2, _lcDraw.myLocationsController);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_lcDraw" type="CMIF_RDTLocationDrawElement"/>
    </JadeMethod>
    <JadeMethod name="drawRowsLandscape" id="2e28be21-d51f-4e9d-ace0-6fe3a25062cf">
        <updating/>
        <source>drawRowsLandscape(_y1 : Real; _gridWidth : Real; _gridHeight : Real; _row : Integer; _gapCols : IntegerArray; _lc : CM_LocationsController output) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	x1 				: Real;
	col 			: Integer;
	finishedCols 	: Boolean;
	lc 				: CM_LocationsController;
	tiDraw			: CMIF_RDTTIDrawElement;
	lcDraw			: CMIF_RDTLocationDrawElement;
	wagonDraw		: CMIF_RDTWagonPartDrawElement;
	trackDraw 		: CMIF_RDTTrackDrawElement;
	notEmpty 		: Boolean;
	theTI			: CM_TrackedItem;
	isGridArea 		: Boolean;
	key				: String;
	maxX 			: Real;
	willHighlightTargetLoc : Boolean;
	gridLoc : CMIF_RDTGridLocation;
	maxNumInStack : Integer;
begin
		isGridArea := self.isLocationInGriddedArea(self.myTargetLocation);
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		
		// Draw the Locations
		if self.flipH then
			x1 := self.myDrawingFrame.clientWidth + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;	
		//05/11/2010 cnwdz2 26196
		self.xDrawStart := x1;
		maxX := self.myDrawingFrame.clientWidth();
		if x1 &gt; maxX then
			self.xDrawStart := maxX;
		endif;
		if x1 &lt; 0 then
			self.xDrawStart := 0;
		endif;
	
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			if (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END)  and isGridArea then	
				//lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.maxGridRow - _row + 1);
				lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.gridRowToStackHeight(_row, self.myGridArea));
				//if lcDraw &lt;&gt; null then
				//	write "row,col :" &amp; _row.String &amp; "," &amp; col.String &amp; " lc:" &amp;  lcDraw.myLocationsController.CM_GridController.getFullId() &amp; " key: : " &amp; lcDraw.key;  
				//endif;
			else
				lcDraw := self.myDisplayBuilder.getLocationDraw(_row, col);
				
				//18 Dec 2014	NDL	Par 35346
				if lcDraw = null and self.myDisplayBuilder.isKindOf(CMIF_RDTRailDisplayBuilder) then
					lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, 1);
					if lcDraw = null then
						lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, 2);
					endif;
				endif;
		
			endif;
			
			if lcDraw &lt;&gt; null then 				
				lc := lcDraw.getLocationController();
				if lc &lt;&gt; null then
					_lc := lc;
				endif;
				if lc &lt;&gt; null and lc.isGap() then
					if _gapCols.includes(col) then
						// Move across
						if self.flipH then
							x1 := x1 - lc.getGapWidthPixels(_gridWidth);
						else
							x1 := x1 + lc.getGapWidthPixels(_gridWidth);
						endif;
					else
						// Move across
						if self.flipH then
							x1 := x1 - _gridWidth;
						else
							x1 := x1 + _gridWidth;
						endif;
					endif;
					
					col := col + 1;
					if self.flipH then
						finishedCols := col &gt; self.leftGridColDraw;
					else
						finishedCols := col &gt; self.rightGridColDraw;
					endif;						
					
					continue;
				endif;
			else
				lc := null;
			endif;
			
			// New wagon handling
			wagonDraw := self.myDisplayBuilder.getWagonPart(_row, col);

			if wagonDraw &lt;&gt; null then
				self.drawWagon(x1, _y1, _gridWidth, _gridHeight, wagonDraw); 
			endif;
			//
			
			// New train track handling
			trackDraw := self.myDisplayBuilder.getTrack(_row, col);
			if trackDraw &lt;&gt; null then
				self.drawTrack(x1, _y1, _gridWidth, _gridHeight, trackDraw); 		
			endif;			
			//			
			
			if lcDraw &lt;&gt; null then 
				self.drawLocation(x1, _y1, _gridWidth, _gridHeight, lcDraw); 				
			endif;
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;
		//05/11/2010 cnwdz2 26196
		self.xDrawEnd := x1;		
		if x1 &gt; maxX then
			self.xDrawEnd := maxX;
		endif;
		if x1 &lt; 0 then
			self.xDrawEnd := 0;
		endif;
		
		// Draw the TIs
		if self.flipH then
			x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;

		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			
			if (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END) and isGridArea then
				//lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.maxGridRow - _row + 1);
				lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.gridRowToStackHeight(_row, self.myGridArea));
			else
				lcDraw := self.myDisplayBuilder.getLocationDraw(_row, col);
				//18 Dec 2014	NDL	Par 35346
				if lcDraw = null and self.myDisplayBuilder.isKindOf(CMIF_RDTRailDisplayBuilder) then
					lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, 1);
					if lcDraw = null then
						lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, 2);
					endif;
				endif;
			endif;

			if lcDraw &lt;&gt; null then 
				lc := lcDraw.getLocationController();
				//07/10/2010 cnwdz2 par25671
				if lc &lt;&gt; null and lc.isGap() then
					if _gapCols.includes(col) then
						// Move across
						if self.flipH then
							x1 := x1 - lc.getGapWidthPixels(_gridWidth);
						else
							x1 := x1 + lc.getGapWidthPixels(_gridWidth);
						endif;
					else
						// Move across
						if self.flipH then
							x1 := x1 - _gridWidth;
						else
							x1 := x1 + _gridWidth;
						endif;
					endif;
					
					col := col + 1;
					if self.flipH then
						finishedCols := col &gt; self.leftGridColDraw;
					else
						finishedCols := col &gt; self.rightGridColDraw;
					endif;						
					continue;
				endif;
			else
				lc := null;
			endif;

			
			tiDraw := self.myDisplayBuilder.getTI(_row, col);			
			if tiDraw &lt;&gt; null then
				theTI := tiDraw.getTI();
				//02 March 2011	#cnwdz2	 ccms 2005 par25644
				tiDraw.setHighlightHeight(self.highlightHeight);
				// Draw it
				self.drawTI(x1, _y1, _gridWidth, _gridHeight, tiDraw);
			else
				theTI := null;
			endif;
						

			if lcDraw &lt;&gt; null then
				if self.flipH then
					lcx1 := x1 - _gridWidth;
					lcx2 := x1;
				else			
					lcx1 := x1;
					lcx2 := x1 + _gridWidth;
				endif;
				
				if self.flipV then
					lcy1 := _y1 - _gridHeight;
					lcy2 :=  _y1;
				else
					lcy1 := _y1;
					lcy2 :=  _y1 + _gridHeight;
				endif;
	
				
				lcDraw.gridPointsToElementPoints(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
		
				
				key := self.genHighlightedLCKey(lc, lcDraw.stackHeight);
				
				//write "draw key: '" &amp; key &amp; "'";
			
				//if self.allHighlightLCsByID.includesKey(lc.getFullId()) then
				if self.allHighlightLCsByID.includesKey(key) then
					self.highlightLocation(lcx1, lcy1, lcx2, lcy2);					
				endif;
	
				if lc = self.myTargetLocation then
					//21/04/2011 cnwdz2 par27313 start
					willHighlightTargetLoc := true;
					
					if lc.isBoxcarCont then	//26 Mar 2013	NDL	Par 31278
						gridLoc := self.myDisplayBuilder.getGridLocation(lc);
						if gridLoc = null or gridLoc.col &lt;&gt; col or gridLoc.row &lt;&gt; _row then
							willHighlightTargetLoc := false;
						endif;
					elseif lc.isWagon then	//19 Dec 2014	NDL	Par 35346
						maxNumInStack := lc.CM_WagonController.myWagon.myWagonClass.maxNumInStack;
					endif;
					
					if self.drawMode = CMIF_RDTDrawElement.MODE_FACE and self.isDrawForkLiftStack(self.myTargetLocation) then				
						//if  (theTI &lt;&gt; null and theTI.myPrimaryActualLocation &lt;&gt; lc) then					
						if theTI &lt;&gt; null then							
							if self.lookForkLiftStackFromBottom and theTI.myPrimaryActualLocation.CM_GridController.myGridRow.row &gt; 
										self.myTargetLocation.CM_GridController.myGridRow.row then
								willHighlightTargetLoc := false;
							elseif not self.lookForkLiftStackFromBottom and theTI.myPrimaryActualLocation.CM_GridController.myGridRow.row &lt; 
										self.myTargetLocation.CM_GridController.myGridRow.row then
								willHighlightTargetLoc := false;							
							endif;							
						endif;						
					endif;
					//21/04/2011 cnwdz2 par27313 end
					
					// Highlight the location
					if willHighlightTargetLoc then
						if (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END) and isGridArea then												
							// we only want to highlight the location at the height specified in the location string
							if self.gridRowToStackHeight(_row, self.myGridArea) = self.targetLocationHeight then
								self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2,self.myTargetTI);// theTI	);		//epr par 24901	8/7/10		
							endif;
						else
							if maxNumInStack &gt; 1 and lcDraw.stackHeight &gt; 0 then
								if lc.allTrackedItems.size &gt;= lcDraw.stackHeight and self.myTargetTI = lc.allTrackedItems[lcDraw.stackHeight] then
									self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2,self.myTargetTI);
								elseif not lc.allTrackedItems.includes(self.myTargetTI) and lc.allTrackedItems.size + 1 = lcDraw.stackHeight then
									self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2,self.myTargetTI);
								endif;
							else
								self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2,self.myTargetTI);// theTI); 		//epr par 24901	8/7/10	
							endif;
						endif;	
					endif;
				endif;
				
				//20/04/2011 cnwdz2 par27313 
				if not (self.drawMode = CMIF_RDTDrawElement.MODE_FACE and self.isDrawForkLiftStack(self.myTargetLocation) and lcDraw.isBackEnd) then	
					lcDraw.drawLocationId(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.flipV, self.flipH, tiDraw, self.myTIFrame,self.drawMode);
				endif;
															
			endif;
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_gapCols" type="IntegerArray"/>
        <Parameter name="_lc" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawRowsPortrait" id="60aab80a-743b-44a4-9672-6508574c277c">
        <updating/>
        <source>drawRowsPortrait(_x1 : Real; _gridWidth : Real; _gridHeight : Real; _col : Integer; _gapRows : IntegerArray; _lc : CM_LocationsController output) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	y1 				: Real;
	row 			: Integer;
	finishedRows 	: Boolean;
	lc 				: CM_LocationsController;
	lcDraw			: CMIF_RDTLocationDrawElement;
	tiDraw			: CMIF_RDTTIDrawElement;
	wagonDraw		: CMIF_RDTWagonPartDrawElement;
	trackDraw 		: CMIF_RDTTrackDrawElement;
	notEmpty 		: Boolean;
	theTI			: CM_TrackedItem;
	maxY			: Real;
begin		
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		// Draw the Locations		
		if self.flipV then
			y1 := self.myDrawingFrame.clientHeight + self.yDrawOffset - self.bottomOffset;	
		else
			y1 := self.yDrawOffset + self.topOffset;
		endif;
		//05/11/2010 cnwdz2 26196
		self.yDrawStart := y1;
		maxY := self.myDrawingFrame.clientHeight();
		if y1 &gt; maxY then
			self.yDrawStart := maxY;
		endif;
		if y1 &lt; 0 then
			self.yDrawStart := 0;
		endif;
		
		if self.flipV then
			row := self.bottomGridRowDraw;
		else
			row := self.topGridRowDraw;
		endif;
		
		finishedRows := false;	
		while not finishedRows do
			lcDraw := self.myDisplayBuilder.getLocationDraw(row, _col);
			if lcDraw &lt;&gt; null then 
				//08/10/2010 cnwdz2 par25671
				lc := lcDraw.getLocationController();
				if lc &lt;&gt; null then
					_lc := lc;
				endif;
				if lc &lt;&gt; null and lc.isGap() then	
					if _gapRows.includes(row) then
						// Move up/down
						if self.flipV then
							y1 := y1 - lc.getGapWidthPixels(_gridHeight);			
						else
							y1 := y1 + lc.getGapWidthPixels(_gridHeight);			
						endif;	
					else
						// Move up/down
						if self.flipV then
							y1 := y1 - _gridHeight;			
						else
							y1 := y1 + _gridHeight;			
						endif;
					endif;
					
					row := row + 1;
					if self.flipV then
						finishedRows := row &gt; self.topGridRowDraw;
					else
						finishedRows := row &gt; self.bottomGridRowDraw;
					endif;	
					continue;
				endif;
			else
				lc := null;
			endif;
						
			// New wagon handling
			wagonDraw := self.myDisplayBuilder.getWagonPart(row, _col);
			if wagonDraw &lt;&gt; null then
				self.drawWagon(_x1, y1, _gridWidth, _gridHeight, wagonDraw); 		
			endif;
			
			// New train track handling
			trackDraw := self.myDisplayBuilder.getTrack(row, _col);
			if trackDraw &lt;&gt; null then
				self.drawTrack(_x1, y1, _gridWidth, _gridHeight, trackDraw); 		
			endif;			
			//			
			
			if lcDraw &lt;&gt; null then 
				self.drawLocation(_x1, y1, _gridWidth, _gridHeight, lcDraw); 				
			endif;

			row := row + 1;
			if self.flipV then
				finishedRows := row &gt; self.topGridRowDraw;
			else
				finishedRows := row &gt; self.bottomGridRowDraw;
			endif;	
			
			// Move up/down
			if self.flipV then
				y1 := y1 - _gridHeight;			
			else
				y1 := y1 + _gridHeight;			
			endif;			
		endwhile;
		//05/11/2010 cnwdz2 26196
		self.yDrawEnd := y1;
		if y1 &gt; maxY then
			self.yDrawEnd := maxY;
		endif;
		if y1 &lt; 0 then
			self.yDrawEnd := 0;
		endif;
		
		// Draw the TIs
		if self.flipV then
			y1 := self.myDrawingFrame.height + self.yDrawOffset - self.bottomOffset;	
		else
			y1 := self.yDrawOffset + self.topOffset;
		endif;

		if self.flipV then
			row := self.bottomGridRowDraw;
		else
			row := self.topGridRowDraw;
		endif;

		finishedRows := false;	
		while not finishedRows do
			lcDraw := self.myDisplayBuilder.getLocationDraw(row, _col);
			if lcDraw &lt;&gt; null then 
				lc := lcDraw.getLocationController();
				//07/10/2010 cnwdz2 par25671
				if lc &lt;&gt; null and lc.isGap() then
					if _gapRows.includes(row) then
						// Move up/down
						if self.flipV then
							y1 := y1 - lc.getGapWidthPixels(_gridHeight);			
						else
							y1 := y1 + lc.getGapWidthPixels(_gridHeight);			
						endif;
					else
						// Move up/down
						if self.flipV then
							y1 := y1 - _gridHeight;			
						else
							y1 := y1 + _gridHeight;			
						endif;
					endif;
					row := row + 1;
					if self.flipV then
						finishedRows := row &gt; self.topGridRowDraw;
					else
						finishedRows := row &gt; self.bottomGridRowDraw;
					endif;						
					continue;
				endif;
			else
				lc := null;
			endif;

			tiDraw := self.myDisplayBuilder.getTI(row, _col);
			if tiDraw &lt;&gt; null then
				theTI := tiDraw.getTI();
				//02 March 2011	#cnwdz2	 ccms 2005 par25644			
				tiDraw.setHighlightHeight(self.highlightHeight);
				// Draw it
				self.drawTI(_x1, y1, _gridWidth, _gridHeight, tiDraw);
			else
				theTI := null;
			endif;					
			
			if lcDraw &lt;&gt; null then 
				if self.flipH then
					lcx1 := _x1 - _gridWidth;
					lcx2 := _x1;
				else
					lcx1 := _x1;
					lcx2 := _x1 + _gridWidth;
				endif;
	
				if self.flipV then
					lcy1 := y1 - _gridHeight;
					lcy2 :=  y1;
				else
					lcy1 := y1;
					lcy2 :=  y1 + _gridHeight;
				endif;
	
				lcDraw.gridPointsToElementPoints(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
				
				
				if self.allHighlightLCsByID.includesKey(lc.getFullId()) then
					self.highlightLocation(lcx1, lcy1, lcx2, lcy2);
				endif;
					
				if lc = self.myTargetLocation then
					// Highlight the location
					if lc.isBoxcarCont and lcDraw.isBoxcarPortrait then	//11 Apr 2014	NDL CCMS 1366
						if lcDraw.isBoxcarDoor then
							self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, self.myTargetTI);
						endif;
					else
						self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, self.myTargetTI);//theTI); 	//epr par 24901	8/7/10	
					endif;
				endif;
				
				lcDraw.drawLocationId(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.flipV, self.flipH, tiDraw, self.myTIFrame,self.drawMode);
			
			endif;
			
			
			row := row + 1;
			
			if self.flipV then
				finishedRows := row &gt; self.topGridRowDraw;
			else
				finishedRows := row &gt; self.bottomGridRowDraw;
			endif;	
			
			// Move up/down
			if self.flipV then
				y1 := y1 - _gridHeight;			
			else
				y1 := y1 + _gridHeight;			
			endif;
			
		endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_gapRows" type="IntegerArray"/>
        <Parameter name="_lc" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawTI" id="60c3d851-df7e-4fb8-9cea-5d23cc95b97f">
        <source>drawTI( _x1, _y1, _gridWidth, _gridHeight : Real; _tiDraw : CMIF_RDTTIDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
	gx1, gy1,
	gx2, gy2	: Real;
begin	
	if _tiDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			gx1 := _x1 - _gridWidth;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1;
			gy2 := _y1;
		else
			gx1 := _x1 - _gridWidth;
			gy1 := _y1;
			gx2 := _x1;
			gy2 :=  _y1 + _gridHeight;
		endif;
	else
		if self.flipV then
			gx1 := _x1;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1 + _gridWidth;
			gy2 :=  _y1;
		else
			gx1 := _x1;
			gy1 := _y1;
			gx2 := _x1 + _gridWidth;
			gy2 := _y1 + _gridHeight;
		endif;
	endif;

	_tiDraw.draw(gx1, gy1, gx2, gy2, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
	_tiDraw.gridPointsToElementPoints(gx1, gy1, gx2, gy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
	self.storeTIScreenPos(gx1, gy1, gx2, gy2, _tiDraw.myTI);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_tiDraw" type="CMIF_RDTTIDrawElement"/>
    </JadeMethod>
    <JadeMethod name="drawTrack" id="9b9a6827-3a6e-42b8-acbd-507cafbde8fa">
        <source>drawTrack( _x1, _y1, _gridWidth, _gridHeight : Real; _trackDraw : CMIF_RDTTrackDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _trackDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			_trackDraw.draw(_x1 - _gridWidth, _y1 - _gridHeight, _x1, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		else
			_trackDraw.draw(_x1 - _gridWidth, _y1, _x1, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	else
		if self.flipV then
			_trackDraw.draw(_x1, _y1 - _gridHeight, _x1 + _gridWidth, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);						
		else
			_trackDraw.draw(_x1, _y1, _x1 + _gridWidth, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_trackDraw" type="CMIF_RDTTrackDrawElement"/>
    </JadeMethod>
    <JadeMethod name="drawWagon" id="dbdb0466-8c31-4cdc-80ef-06ab348742be">
        <source>drawWagon( _x1, _y1, _gridWidth, _gridHeight : Real; _wagonDraw : CMIF_RDTWagonPartDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _wagonDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			_wagonDraw.draw(_x1 - _gridWidth, _y1 - _gridHeight, _x1, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		else
			_wagonDraw.draw(_x1 - _gridWidth, _y1, _x1, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	else
		if self.flipV then
			_wagonDraw.draw(_x1, _y1 - _gridHeight, _x1 + _gridWidth, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);						
		else
			_wagonDraw.draw(_x1, _y1, _x1 + _gridWidth, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_wagonDraw" type="CMIF_RDTWagonPartDrawElement"/>
    </JadeMethod>
    <JadeMethod name="flipFancyGFX" id="240d0562-e02a-4981-83ff-73bf85c11085">
        <updating/>
        <source>flipFancyGFX() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.isFancyGFX := not self.isFancyGFX;
	self.refresh();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="flipHorizontal" id="c92f0c7b-9820-4c7b-a242-9b7ddeab389e">
        <updating/>
        <source>flipHorizontal(_recenterLocation : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.myDisplayBuilder = null then
		return;
	endif;
	
	if self.myTargetLocation = null then
		return;
	endif;

	if  not self.myDisplayBuilder.canFlipH(self.drawMode) then
		return;
	endif;

	self.flipH := not self.flipH;
	
	if self.flipH then
		self.leftOffset := 0;
	else
		self.rightOffset := 0;
	endif;

	if _recenterLocation then
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.reDrawAreaFromLocation(self.myTargetLocation, self.drawMode);	
	else			
		// Code for flipping without re-centering on location
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.calcViewSizes();	
		self.reCalcColsForFlip();
		self.calcDrawRows();
		self.calcDrawCols();
		self.drawEverything();
	endif;

epilog

end;</source>
        <Parameter name="_recenterLocation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="flipLandscapePortrait" id="5b186919-d0e2-470d-b85e-9f022548820d">
        <updating/>
        <source>flipLandscapePortrait() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.myTargetLocation = null then
		return;
	endif;
	self.isLandscape := not self.isLandscape;
	self.resetScrollOffsets();
	self.resizeDrawingFrames();
	self.reDrawAreaFromLocation(self.myTargetLocation, self.drawMode);
epilog

end;</source>
    </JadeMethod>
