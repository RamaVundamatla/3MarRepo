    <JadeMethod name="getTransactionTSLocalTZ" id="8846c084-ae59-4ece-8917-d3260f7a2836">
        <source>getTransactionTSLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.transactionTS);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
