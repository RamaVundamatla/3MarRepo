    <JadeMethod name="applyColumnFilter" id="69fb04b0-587a-4e25-a8be-762897c6ab06">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2013	cnwjre1	Initial creation

*/

vars

	visibleCount : Integer;

begin

	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="btnAttachments_click" id="e58bdd29-1e9e-4a2c-8a1f-fabd9d816e90">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAttachments_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 November 2022	navvt20	Task 55527: Invoice List Attachments
12 Dec 2022			navvt20 TFS CR 55302 Defect 55795: MTN - Cannot attach files in state = posted
*/

vars
	obj : ObjectArray;
begin
	obj:= self.tblData.allSelectedObjects;
	// Start 12 Dec 2022 navvt20 Defect 55795
	if obj.first = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice),app.getErrorString(Warning),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// End 12 Dec 2022 navvt20 Defect 55795
	self.myAssistant.showFileAttachmentsForm( obj.first.CM_Object, self.myMasterMenuAction);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
