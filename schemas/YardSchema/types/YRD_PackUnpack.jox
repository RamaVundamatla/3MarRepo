    <JadeMethod name="doUnpackCompleteCancelClick" id="bdfa9f8d-04f5-464e-921d-18435abdb320">
        <source>doUnpackCompleteCancelClick();
//----------------------------------------------------------------
//	Created:	May 2007 cnwrs1
//----------------------------------------------------------------
vars

begin
