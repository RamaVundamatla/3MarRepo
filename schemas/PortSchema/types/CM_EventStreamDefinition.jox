    <JadeMethod name="getSelectedEventTypes" id="88a1ff10-369b-493e-bf34-95951385559a">
        <source>getSelectedEventTypes( _eventTypes : CM_EventTypeSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2020	jlgndl1	Initial creation	TFS 49590

*/

vars

	esEventType : CM_EventStreamEventType;

begin

	foreach esEventType in self.allEventStreamEventTypes do
		if esEventType.myObject &lt;&gt; null and esEventType.myObject.isKindOf( CM_EventType ) then
			_eventTypes.addNoDuplicates( esEventType.myObject.CM_EventType, false );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_eventTypes" type="CM_EventTypeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedHmsTypes" id="edfd3275-068b-4d2a-83a4-2bf2b8f6690c">
        <source>getSelectedHmsTypes( _transTypes : CM_TransactionTypeSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2020	jlgndl1	Initial creation	TFS 49747

*/

vars

	esEventType : CM_EventStreamEventType;

begin

	foreach esEventType in self.allEventStreamEventTypes do
		if esEventType.myObject &lt;&gt; null and esEventType.myObject.isKindOf( CM_TransactionType ) then
			if esEventType.myObject.CM_TransactionType.trxGroup = TRANS_TYPE_GROUP_HMS then
				_transTypes.addNoDuplicates( esEventType.myObject.CM_TransactionType, false );
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_transTypes" type="CM_TransactionTypeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTransTypes" id="57df1bbe-bd51-4a06-aeae-f09a228f44d2">
