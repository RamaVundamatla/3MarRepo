    <JadeMethod name="cloneMe" id="9ccfb28a-c27c-4f67-9147-fc6cc76f758e">
        <updating/>
        <source>cloneMe(_newTi : CM_TrackedItem ; _newQuantity : Integer) : CM_ReserveTI updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2013	cnwrd1	Initial creation
10 Oct 2025	navdap1	MTN-36227 Yara New Discoveries | Cater for multiple lines in an OrderCreate / OrderChange / OrderResponse
*/

vars
	newReserveTI : CM_ReserveTI;
	yaraData : String;				// MTN-36227
begin
	
	newReserveTI := self.cloneSelf(false);
	
	newReserveTI.allTrackedItems.clear;
	self.myReserveHeader.allReserveDetails.add(newReserveTI);
	newReserveTI.myBookingRefItem := self.myBookingRefItem;
	
	newReserveTI.totalRequested := _newQuantity;
	
	self.totalRequested := self.totalRequested - _newQuantity;
	
	// MTN-36227 Do we have Yara extra data
	yaraData := self.getYaraExtraData();
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Yara Data is " &amp; yaraData, LogDEBUG);
	if yaraData &lt;&gt; null then
		newReserveTI.setYaraExtraData(yaraData);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "newResrveTI yara Data is " &amp; newReserveTI.getYaraExtraData(), LogDEBUG);
	endif;
	
	return newReserveTI;
epilog

end;</source>
        <Parameter name="_newTi" type="CM_TrackedItem"/>
        <Parameter name="_newQuantity" type="Integer"/>
        <ReturnType type="CM_ReserveTI"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="65bd4ad7-7148-46f5-81a0-577fe3ffe687">
        <updating/>
        <source>cloneReferences(_clone: SelfType input; bTransient: Boolean) updating;

/*

Purpose:		Clone required details for Reserve TI

Date			Who		Reason
24/10/2012		cnwmh5	Initial creation

*/

vars

begin
	
	self.allTrackedItems.copy(_clone.allTrackedItems);

epilog

end;</source>
        <Parameter name="_clone" type="SelfType" usage="input"/>
        <Parameter name="bTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesTIMatchForRelease" id="86431c6d-ac04-439a-acc2-564a8ce167a6">
        <source>doesTIMatchForRelease(_ti : CM_TrackedItem; _isExact : Boolean output) : Boolean;
// ---------------------------------------------------------------------------
// Created:		26 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------
vars
begin
	// we only want to update reserveDetails that are associated with this TI
	//if (self.allTrackedItems.includes(_ti)) then
	if (self.includeTrackedItem(_ti, false)) then //23/06/2023	navkc1	CR 58406 Task 58408
		_isExact:=true;
		return true;
	endif;
	//07 Aug 2014	NDL	Par 34675 - Huh???
//	if (self.allTrackedItemsReleased.isEmpty) then
//		return true;//PAR 14971 - if reserve TI, should only ever have a single TI in either the assigned or released items collection.
//	endif;

	return false;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isExact" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGradesIntegers" id="b622de31-0ad0-4795-970e-44ddfacda87e">
        <source>getAvailabilityGradesIntegers(): String;
//
// 23 Mar 2017	cnwrs1	TFS3648
//
vars
	gradesCode : String;
	grade : Integer;
begin
	foreach grade in self.myReserveHeader.allAvailabilityGrades do
		if gradesCode = null then
			gradesCode := grade.String;
			break;
		endif;
	endforeach;
	return gradesCode;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
