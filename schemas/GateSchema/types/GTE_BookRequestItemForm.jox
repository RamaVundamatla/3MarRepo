    <JadeMethod name="initFromUserWindow" id="8b49b4e4-5915-4ab1-b74c-b9c07b8cace1">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navra1	Initial creation for //navra1 - CR 63764/Task 64227 - 22nd May 2024

*/

vars
	
begin
	inheritMethod(_userWindow);
	
	self.savedMatchMode := _userWindow.xmlInfo.cnEcGetTagValueOfName("savedMatchMode").Integer;
	
	self.warnedForUser := _userWindow.xmlInfo.cnEcGetTagValueOfName(app.userName() &amp; "_warned").Boolean;	
	
	if process.isRam() then
		write _userWindow.xmlInfo;
		write "The savedMode was " &amp; self.savedMatchMode.String;
		write "The warnedForUser was " &amp; self.warnedForUser.String;
	endif;
	
epilog

end;</source>
