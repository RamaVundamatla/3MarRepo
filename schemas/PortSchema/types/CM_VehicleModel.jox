    <JadeMethod name="cnEcGetDuplicate" id="2d92df43-9398-453d-bf1a-8facf5fe9b7b">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	model : String;
	vModel : CM_VehicleModel;

begin

	model := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "model" ).String; 
	
	if model &lt;&gt; null then
		vModel := app.myDutyDocRoot.allVehicleModels.getAtKey( model );
	endif;

epilog

	return vModel;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
