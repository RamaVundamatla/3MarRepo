<CollClass name="CM_TerminalAreaSet" id="2fe55206-da9b-4d24-b19e-27bc4a2840ce">
    <memberType name="CM_TerminalArea"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <JadeMethod name="getDisplay" id="3f978d59-3e28-489c-a21e-539c20b9ee43">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Purpose:		Returns a display string of the receiver's Terminal Area Ids.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	areaObj			: CM_TerminalArea;
	displayValue	: String;
	
begin
	foreach areaObj in self discreteLock do
		if displayValue = null then
			displayValue	:=	areaObj.id;
		else
			displayValue	:=	displayValue &amp; ", " &amp; areaObj.id;
		endif;
	endforeach;
	
	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
