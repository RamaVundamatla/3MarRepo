        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNonStagedAvail" id="d5924ff7-40d6-427f-91cd-fa381850a5da">
        <source>getNonStagedAvail(	_reserveSelection : CM_ReserveSelection; 
					_tiSet : CM_TISet input;
					_isByID : Boolean;
					_index, _limit : Integer;
					_count : Integer io	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2021	jlier1	Initial creation TFS 51879
05 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars

	cargoType : CM_CargoType;
	iter : Iterator;
	startTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	reason : String;
	opTerm : CM_OperatorTerminal;
	product : CM_Product;
	xtraReleaseCriteria : CM_ReleaseByTypeCriteria;
	criteria : CM_YACriteria;
	cargoId : String;
	cargoGroupId : String;
	cg : CM_CargoGroup;
	localDict : CM_TIByCargoTypeIdDict;
	skipAttributes : IntegerArray;	//11 Jan 2016	NDL	TFS 3189/2876
	tiArea : CM_TerminalArea;			// MTN-34024

begin

	if _reserveSelection = null then
		return;
	endif;
	
	if _tiSet = null then
		return;
	endif;

	opTerm := self.myOperatorTerminal;
	if opTerm = null then
		return;
	endif;

	cargoType := _reserveSelection.getCargoType;
	if cargoType = null then
		return;
	endif;
	
	product := _reserveSelection.myProduct;
	
	//OK see if we have any extra criteria that we can really use.
	xtraReleaseCriteria:= _reserveSelection.myReleaseCriteria;
	if xtraReleaseCriteria &lt;&gt; null then
		criteria := xtraReleaseCriteria.getCriteriaFor(YACriteriaType_ID);
		if criteria &lt;&gt; null then
			cargoId := criteria.getDisplayForYAMTableColumn;
		endif;
		criteria := xtraReleaseCriteria.getCriteriaFor(YACriteriaType_CargoGroup);
		if criteria &lt;&gt; null then
			cargoGroupId := criteria.getDisplayForYAMTableColumn;
		endif;
	endif;
	
	// Find / build the best collection of ti's to use and start an iterator
	if cargoGroupId &lt;&gt; null then
		cg := self.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq( cargoGroupId , null ).CM_CargoGroup;
		if cg &lt;&gt; null and cg.id = cargoGroupId then
			// we  have a cargo group to use, get a collection of the on-site cargo from it.
			create localDict transient;	
			iter := cg.allAssignedTrackedItems.createIterator;
			while iter.next(ti) do
				if not ti.isOnSite then
					continue;
				endif;
				if ti.isNotified or ti.myPrimaryActualLocation = null then
					continue;
				endif;
				localDict.add(ti);
			endwhile;
			delete iter;
			
			if not localDict.isEmpty then
				//there is some potential data, start an iterator
				iter := localDict.createIterator;
				startTi := localDict.getAtKeyGeq( cargoType.id, cargoId);
		
			endif;
			
		endif;
	
	else
		iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
		startTi := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, cargoId);
		
	endif;
		
	if startTi &lt;&gt; null and startTi.myCargoType = cargoType then
	
		//11 Jan 2016	NDL	TFS 3189/2876
		if self.isShipType then
			//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
			//because these are unconditionally reset when assigned to the ship release during staging
			create skipAttributes transient;
			skipAttributes.add( YACriteriaType_Voyage );
			skipAttributes.add( YACriteriaType_DischargePort );
			skipAttributes.add( YACriteriaType_ImexStatus );
		endif;
		
		// ok we have an iterator and a tracked item to start from
		iter.startAtObject( startTi );
		while iter.next(ti) do
			if ti.myCargoType &lt;&gt; cargoType then	// check the cargo type.
				break;
			endif;
			if cargoId &lt;&gt; null then // if we found a cargo id in teh xtra criteria on the reserve selection check it
				if cargoId &lt;&gt; ti.id then
					break;
				endif;
			endif;
			if product &lt;&gt; null then	// if we found a product on the reserve selection, check it
				if ti.myProduct &lt;&gt; product then
					continue;
				endif;
			endif;
			if not ti.testAgainstReserveSelection( _reserveSelection, reason, true, skipAttributes ) then
				continue;
			endif;
			if  not ti.allBulkReleasesAssigned.isEmpty then
				if ti.allBulkReleasesAssigned.size = 1 and ti.allBulkReleasesAssigned.first = self then
					//that's OK.
				else
					continue;
				endif;
			endif;
			if ti.isStagedFor( self ) then	//22 Mar 2016	NDL	
				continue;
			endif;
			
			tiArea := ti.myPrimaryActualLocation.myTerminalArea;	// MTN-34024
			if tiArea &lt;&gt; null and tiArea.isInterchangeArea then		// MTN-34024
				continue;											// MTN-34024
			endif;													// MTN-34024
			if ti.isAvailableToStageFor(  self ) then
				// MTN-34024 start first bit
				if _isByID then
					_count += 1;
					if _index &gt; 1 and _count &lt; _index then
						continue;
					endif;
				endif;
				// MTN-34024 end first bit
				_tiSet.addNoDuplicates( ti, false );
				// MTN-34024 start second bit
				if _isByID and _count &gt;= ((_index-1)+_limit) then
					break;
				endif;
				// MTN-34024 end second bit
			endif;
		endwhile;
	endif;
	

epilog

	delete localDict;
	delete iter;
	delete skipAttributes;

end;</source>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_isByID" type="Boolean"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_limit" type="Integer"/>
        <Parameter name="_count" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNumItemsBeingActioned" id="5c03707e-68b5-44bb-8763-c379f7ed47de">
        <source>getNumItemsBeingActioned() : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	req					: CM_Request;
	res					: CM_ReserveDetail;
	num, numReleased	: Integer;
	needEndLoad			: Boolean;

begin
	if not (process.isInTransactionState or process.isInLoadState) then
		needEndLoad := true;
		beginLoad;
	endif;

	foreach req in self.allRequestsBeingActioned do	
		//epr par 32330 29/8/13
		num := num + req.getQuantityOnRequest().Integer; //must be a specific TI release	
	endforeach;

	return num;
epilog
	if needEndLoad then
		endLoad;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumItemsBeingActionedEx" id="c6fcb190-9665-422b-9156-af22fadd584c">
        <source>getNumItemsBeingActionedEx(_excludingJob : CM_Job):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 February 2017	cnwma1	Initial creation

*/

vars
	req					: CM_Request;
	res					: CM_ReserveDetail;
	num, numReleased	: Integer;
	needEndLoad			: Boolean;

begin
	if not (process.isInTransactionState or process.isInLoadState) then
		needEndLoad := true;
		beginLoad;
	endif;

	foreach req in self.allRequestsBeingActioned do	
		//epr par 32330 29/8/13
		if _excludingJob &lt;&gt; null and
		   req.myJob = _excludingJob then
			continue;
		endif;
		num := num + req.getQuantityOnRequest().Integer; //must be a specific TI release	
	endforeach;

	return num;
epilog
	if needEndLoad then
		endLoad;
	endif;
end;</source>
        <Parameter name="_excludingJob" type="CM_Job"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumItemsBeingActionedIncom" id="504b0410-1140-4a43-b8fa-34915e8cc83b">
        <source>getNumItemsBeingActionedIncom(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwrd1	Initial creation
//cwnrd1 par 25900 22.11.2010
*/

vars
	req					: CM_Request;
	res					: CM_ReserveDetail;
	num, numReleased	: Integer;
	needEndLoad			: Boolean;

begin
	if not (process.isInTransactionState or process.isInLoadState) then
		needEndLoad := true;
		beginLoad;
	endif;

	foreach req in self.allRequestsBeingActioned do
		num := num + req.getCountIncompleteWLE();	
	endforeach;

	return num;
epilog
	if needEndLoad then
		endLoad;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
