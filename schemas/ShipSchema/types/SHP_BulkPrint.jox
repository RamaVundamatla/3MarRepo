    <JadeMethod name="translateForm" id="1869cd74-61f4-4155-87f5-7c40feeea575">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 17 February 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021155, locale);
	chkPrintAllHolds.translateCaption(Xlat_0021156, locale);
	chkPrintMacro.translateCaption(Xlat_0021157, locale);
	chkPrintPreview.translateCaption(Xlat_0021158, locale);
	grpReport.translateCaption(Xlat_0021159, locale);
	lblPrintHold.translateCaption(Xlat_0021160, locale);
end;</source>
    </JadeMethod>
