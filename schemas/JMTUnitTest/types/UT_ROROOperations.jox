    <JadeMethod name="planGCDCDischageItems" id="b11b0a40-e9fb-4890-9be3-0e42a9b6c889">
        <source>planGCDCDischageItems(_voyage : CM_Voyage);

/*

Purpose:		Discharge containers	

Date			Who		Reason
07/09/2012		cnwmh5	Initial creation

*/

vars

	bs					: CM_BlockStack;
	location			: CM_LocationsController;
	job					: CM_Job;
	req 				: CM_Request;
	wle 				: CM_WorkListEntry;
	
	itemsToDischarge	: StringArray;
	
begin

	create itemsToDischarge transient;
	itemsToDischarge.add("UTMDHYA0006");
	itemsToDischarge.add("UTMDHYA0008");
	itemsToDischarge.add("UTMDHYA0009");
	itemsToDischarge.add("UTMDHYA0010");
	itemsToDischarge.add("UTMDHYA0018");
	itemsToDischarge.add("UTMDHYA0019");
	itemsToDischarge.add("UTMDHYA0024");
	itemsToDischarge.add("UTMDHYA0025");

	bs := self.getTerminal().allTerminalAreas["UTMHBSE"].CM_BlockStack;
	self.assertNotNull(bs);
	location := bs.allLocationsControllers.first;
	
	foreach job in _voyage.allVoyageJobs do
		if not job.CM_VoyageJob.isDischarge then			// Discharge only
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.myTrackedItem &lt;&gt; null and itemsToDischarge.includes(wle.myTrackedItem.id) then
					self.movePlannedWLE(wle.myTrackedItem, location, wle);
				endif;
			endforeach;
		endforeach;
	endforeach;
		
epilog
	
	delete itemsToDischarge;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupCargoForGCDC" id="a7705b0d-4ea3-41a5-82de-aace6231cae3">
