    <JadeMethod name="orderCriteriaLines" id="ba0d500f-a895-41e0-a298-1d36718ab054">
        <source>orderCriteriaLines() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2022	jlier1	Initial creation

*/

vars
	object : Object;
	objectArray : ObjectArray;
	row: Integer;
	criteriaLine : CM_SelectorCriteriaLine; 
begin
	
	create objectArray transient;
	row:=1;
	while row &lt;= self.tblCriteria.rows do
		criteriaLine := self.tblCriteria.accessRow(row).itemObject.CM_SelectorCriteriaLine;
		if criteriaLine &lt;&gt; null then
			objectArray.add(criteriaLine);
			criteriaLine.setMyCriteriaLineHolder(null);
		endif;
		
		row:=row+1;
	endwhile;
	
	foreach object in objectArray discreteLock do
		object.CM_SelectorCriteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
	endforeach;
	
	
	
epilog
	delete objectArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCriteriaLabel" id="59ce5dab-935f-4b45-90fc-cf38b89a7d7e">
        <source>setCriteriaLabel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries

*/

vars
	count : Integer;
	max		: Integer;
	selectorLine : CM_SelectorCriteriaLine;
	labelCaption : String;
begin
	
	labelCaption := null;
	
	max := 3;
	
	foreach selectorLine in self.myCriteriaLineHolder.allCriteriaLines do
		if count &gt;= max then
			count += 1;
			continue;
		endif;
		
		if count &gt; 0 then
			labelCaption &amp;= ", " &amp; selectorLine.getDescriptionString(); 
		else
			labelCaption &amp;= selectorLine.getDescriptionString();
		endif;
		
		count += 1;
		
	endforeach;
	
	if count &gt; max then
		labelCaption &amp;= " (+" &amp; (count-max).asStringJMT &amp; ")";
	endif;
	
	//self.lblSelectorBy.caption := labelCaption;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEntRowsLabel" id="85dd8f70-1ba4-497f-8356-4859d48261e3">
        <source>setEntRowsLabel(_label : Label input; _entTableRows : EntTableRowArray input; _maxColumns : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	jlier1	Initial creation

*/


vars
	entTableRow  : EntTableRow;
	count : Integer;
	str		: String;
	bubble	: String;
begin
	 
	bubble := null;
	_label.caption:=null;
	foreach entTableRow in _entTableRows discreteLock do
		str := entTableRow.getHeading(null,self.myTerminal,app.myCurrentLocale) ;
		// build all entRow for button bubble help;
		if bubble &lt;&gt; null then
			bubble &amp;= CrLf &amp; str;
		else
			bubble := str;
		endif;
		
		if count &gt;= _maxColumns then
			count:=count+1;
			continue;
		endif;
		if count &gt; 0 then
			_label.caption:= _label.caption &amp; ", " &amp; str;
		else
			_label.caption:= _label.caption &amp; str;
		endif;
		count:=count + 1;
	endforeach;
	
	if count &gt; _maxColumns then
		_label.caption:=_label.caption &amp; " (+" &amp; (count-_maxColumns).asStringJMT &amp; ")";
	endif;
	
	// Set the toolbar button bubble help
	if _label.name = self.lblAdditional.name then
		if self.btnAddtionalCols.myToolbarButton &lt;&gt; null then
			self.btnAddtionalCols.myToolbarButton.bubbleHelp := "Additional Columns - " &amp; CrLf &amp; bubble;
		endif;
	elseif _label.name = self.lblGroupedBy.name then
		if self.btnGrouping.myToolbarButton &lt;&gt; null then
			self.btnGrouping.myToolbarButton.bubbleHelp := "Group By - " &amp; CrLf &amp; bubble;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="Label" usage="input"/>
        <Parameter name="_entTableRows" type="EntTableRowArray" usage="input"/>
        <Parameter name="_maxColumns" type="Integer"/>
    </JadeMethod>
