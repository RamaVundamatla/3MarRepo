    <JadeMethod name="addToolbarControls" id="033677ce-2f03-4062-be6c-1ffdce61d9ab">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	inheritMethod();
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	self.btnPrint.caption := app.getErrorString(Audit_report); // PAR 31662
	self.btnPrint.bubbleHelp := app.getErrorString(Audit_report); // PAR 31662
	
	frm.addButton(self.btnNewItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAudits, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);

	self.btnPrint.visible := app.myPassport.myUser.canDo(self.myTerminal,PmInvRateAuditReport);
	
	frm := self.frmRateToolbar;
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelRate, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
