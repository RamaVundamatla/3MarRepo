	self.cmb_Customer.addItem('Messina Line');
	//self.cmb_Customer.addItem('Milaha');								// TFS 38497 - Now Qatar Navigation Port Services
	self.cmb_Customer.addItem('NSW Ports');
	self.cmb_Customer.addItem('Pakistan International Bulk');			// TFS 38497
	self.cmb_Customer.addItem("Patriot Ports");							// TFS 38497 - Formally DPH
	self.cmb_Customer.addItem('Pelindo 1');								
