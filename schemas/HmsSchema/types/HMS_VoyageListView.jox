    <JadeMethod name="doDelete" id="ff15cb53-f6e2-4952-8b91-01291569cf37">
        <updating/>
        <source>doDelete() updating;

vars

	obj:					Object;
	workingVoyage:			CMIF_HMS_WorkingVoyage;
	voyageDeleteChange:  	CMIF_HMS_VoyageDelete;
	movementDeleteChange:	CMIF_HMS_MovementDelete;
	workingMovement:		CMIF_HMS_WorkingMovement;
	msgBoxType: 			Integer;
	msgString:				String;
	term:					CM_Terminal;
	c:						Character;
begin
	if not checkSecurity(PmHMSVoyageMaint,"HMS Voyage") then
		return;
	endif;	 
	// Check that user has "write" rights to update this form
	// -------------------------------------------------------------------------------------
	/*if not hasWriteRights(class.name) then
		app.msgBox($MSGBOX_SecurityWriteDenied &amp; "'" &amp; class.name &amp;"'.", 
										$MSGBOX_SecurityTitle, 
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only  );
		return;
	endif;*/
	// -------------------------------------------------------------------------------------
	c:="A".Character;
	term := self.myTerminal;
	if lbxVoyageTree.listIndex&gt;0 then
		obj:=lbxVoyageTree.itemObject[lbxVoyageTree.listIndex];
		if obj&lt;&gt;null then
    		// Confirm deletion
    		if obj.isKindOf(CMIF_HMS_WorkingVoyage) then
    			workingVoyage := obj.CMIF_HMS_WorkingVoyage;
				msgBoxType:=MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;
				if app.msgBox(app.getErrorString(MSGBOX_DeleteVoyage) &amp; "'" &amp; lbxVoyageTree.itemText[lbxVoyageTree.listIndex].String.trimBlanks &amp; "' ?", app.getErrorString(Confirm_Delete) , msgBoxType)=MsgBox_Return_Yes then
					
					// OK Clicked: Proceed with delete
					create voyageDeleteChange;
					voyageDeleteChange.appliesToVoyage:=workingVoyage;
					voyageDeleteChange.ofViewController:=myViewController;
					myViewController.changeApply(voyageDeleteChange,false, true);
				else
					// Delete was cancelled
				endif;
			elseif obj.isKindOf(CMIF_HMS_WorkingMovement) then
				workingMovement:=obj.CMIF_HMS_WorkingMovement;
				msgBoxType:=MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;
				if workingMovement.moveType=HMSMovementTypeArrival or workingMovement.moveType=HMSMovementTypeDeparture then
					// Tell user that they cannot delete a departure or arrival movement unless they delete the entire voyage
					msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
					app.msgBox(app.getErrorString(ArrDeptMoveNoDelete), app.getErrorString(MSGBOX_InvalidAction), msgBoxType);
				else
					msgString:=lbxVoyageTree.itemText[lbxVoyageTree.listIndex];
					msgString.replaceChar(Tab.Character," ".Character);
					if app.msgBox(app.getErrorString(MSGBOX_DeleteMovement) &amp; "'" &amp; msgString.trimBlanks &amp; "' ?", app.getErrorString(Confirm_Delete), msgBoxType)=MsgBox_Return_Yes then
						// OK Clicked: Proceed with delete
						create movementDeleteChange;
						movementDeleteChange.appliesToMovement:=obj.CMIF_HMS_WorkingMovement;
						movementDeleteChange.ofViewController:=myViewController;
						myViewController.changeApply(movementDeleteChange,false, true);
					else
						// Delete was cancelled
					endif;
				endif;		
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="21f3a7f0-5079-41bf-9919-7d7885757e7b">
        <updating/>
        <source>doEdit() updating;

vars
	object : Object;
	workingMove	: CMIF_HMS_WorkingMovement;
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin
	object := lbxVoyageTree.listObject;
	if object = null then
		return;
	endif;
	
	if CMIF_HMS_WorkingVoyage.hasInstance(object) then
		workingVoyage := object.CMIF_HMS_WorkingVoyage;
		self.showVoyageMaintenance(workingVoyage);
 	elseif CMIF_HMS_WorkingMovement.hasInstance(object) then
 		workingMove := object.CMIF_HMS_WorkingMovement;
		self.showWorkingMovementForm(workingMove);		
 	endif;
end;</source>
    </JadeMethod>
