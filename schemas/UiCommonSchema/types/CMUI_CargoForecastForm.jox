    <JadeMethod name="doOperator" id="2c5a9c9d-498a-4082-9045-79ee83630bf3">
        <source>doOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	operator	:	CM_Operator;
begin
	if myObject.isKindOf(CM_Voyage) then								// 08.06.2022 navsrk20 53142 starts
		foreach operator in self.myObject.CM_Voyage.allOperators do
			if operator &lt;&gt; null then
				cmbOperator.addItemObject(operator.description, operator);
			endif;
		endforeach;
	else
		foreach operator in app.myRoot.allOperators do
			if operator &lt;&gt; null then
				cmbOperator.addItemObject(operator.description, operator);
			endif;
		endforeach;
	endif;																// 08.06.2022 navsrk20 53142 ends
epilog

end;</source>
