    <JadeMethod name="resetInterfaceForMachine" id="a009e6ea-ce34-4549-b3d5-bff834f35bb4">
        <updating/>
        <source>resetInterfaceForMachine(_machine : CM_Machine; _upToTS : TimeStamp) updating;

/*

Purpose:			Reset Interface for machine.

Parameters:			_machine	: Machine to reset.
					_upToTS		: Time up to which incoming requests are to be reset (null = all).

Return Value:		None


Date		Who		Reason
01 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	message	: CM_ITSInterfaceMessage;

begin
	if self.allMachinesLoggedOn.includes(_machine) then
		self.allMachinesLoggedOn.remove(_machine);
	endif;
	
	foreach message in self.allResponsesWaitingAck where message.myMachine = _machine do
		message.reset();
	endforeach;

	foreach message in self.allResponsesToSend where message.myMachine = _machine do
		message.reset();
	endforeach;
	
	foreach message in self.allRequestsToAction where message.myMachine = _machine do
		if _upToTS = null or
		   message.createdTS &lt; _upToTS then
			message.reset();
		endif;
	endforeach;
	
	foreach message in _machine.allITSInterfaceResponsesActive do
		message.reset();
	endforeach;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_upToTS" type="TimeStamp"/>
    </JadeMethod>
