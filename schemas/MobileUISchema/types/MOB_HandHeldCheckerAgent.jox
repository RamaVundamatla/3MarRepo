    <JadeMethod name="msgBox" id="ff33932f-49f3-403e-9a41-38a4fd697f18">
        <source>msgBox(msg, title : String; flags: Integer; alertOption : Boolean ): Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars
	form : Form;
	hhForm : MOB_HandHeldForm;
	
	schema : Schema;
	class : Class;
	obj : Object;
begin

	if app.isJMTUnitTest then	//08 Jan 2016	NDL	Par 37288
		schema := rootSchema.getSchema("JMTUnitTest");
		class := schema.getClass("UT_UnitTest");
		create obj as class transient;
		obj.sendMsgWithParams("assertTrueMsg",false,"MobileUISchema::MobHandHeldCheckerAgent::msgBox error = " &amp; msg);
		delete obj;
	endif;

	form := app.activeForm();
	if form.isKindOf(MOB_HandHeldForm) then
		hhForm := form.MOB_HandHeldForm;
		return hhForm.sendMsgWithParams("msgBox", msg, title, flags, alertOption ).Integer;
	else
		return app.msgBox(msg, title, flags);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <Parameter name="alertOption" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupCargoCheckTableMergeCells" id="b546f322-007d-4607-b00f-5e7e7af6ca30">
        <updating/>
        <source>setupCargoCheckTableMergeCells(_table : CM_MobEntryTable input; _row : Integer) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2010	cnwdap1	Initial creation
*/
vars
	jadeCell : JadeTableCell;

begin
	jadeCell := _table.accessCell(_row, _table.ColumnValue);
	jadeCell.mergeCells := _table.MergeCells_Merge;
	jadeCell.alignment := Table.Alignment_Center_Middle;  //cnwjo3 par 23694
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_MobEntryTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupCargoCheckTableYesNoBtns" id="21b1c6dd-974e-4f9b-a96e-adba746087bd">
        <updating/>
        <source>setupCargoCheckTableYesNoBtns(	_table : CM_MobEntryTable input; 
								_row : Integer;
								_tickBtn, _crossBtn : MOB_Button	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2010	cnwdap1	Initial creation
*/
vars
	jadeCell : JadeTableCell;
begin
	jadeCell := _table.accessCell(_row, _table.ColumnValue);
	jadeCell.picture := _tickBtn.createPicture(false, false, 32);
	jadeCell.mergeCells := _table.MergeCells_NotAvailable;
	jadeCell.alignment := Table.Alignment_Center_Middle;  //cnwjo3 par 23694
	
	jadeCell := _table.accessCell(_row, _table.ColumnValueExtra);
	jadeCell.picture := _crossBtn.createPicture(false, false, 32);
	jadeCell.mergeCells := _table.MergeCells_NotAvailable;
	jadeCell.alignment := Table.Alignment_Center_Middle;  //cnwjo3 par 23694
epilog

end;</source>
        <Parameter name="_table" type="CM_MobEntryTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_tickBtn" type="MOB_Button"/>
        <Parameter name="_crossBtn" type="MOB_Button"/>
    </JadeMethod>
    <JadeMethod name="setupContextChecksTable" id="556d7af6-2c72-45f2-b5ff-badc8c2470df">
        <updating/>
        <source>setupContextChecksTable(	_table : CM_MobEntryTable input; 
						_context : Integer; 
						_form : MOB_HandHeldForm;
						_tickBtn, _crossBtn, _tickBtnDown, _crossBtnDown, _button : MOB_Button;
						_formToDisplay : Class output;
						_otherObject : CM_Object
						) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2010	cnwdap1	Initial creation
25/03/2010	cnwdap1	PAR #23369 Weight extra info, expand seals checking
*/
vars
	cargoCheck 		: CM_CargoCheck;
	item			: CM_CargoCheckItem;
	idx				: Integer;
	jadeCol			: JadeTableColumn;
	jadeCell		: JadeTableCell;
	str				: String;
	setting			: CM_TICargoChecks;
	cmifAutoPlan	: CMIF_YAAutoPlan;
	change			: Real;

begin

	// retrieve the cargo check object for the current context
	cargoCheck := app.myPassport.myTerminal.allCargoChecks[_context];
	if cargoCheck = null then
		return;
	endif;
	
	_table.selectMode := Table.SelectMode_None;
	_table.visible := true;
	_table.rows := _table.fixedRows;
	_table.stretch := 4;
	_table.move(	_form.resizedMargin,
					_form.resizedMargin + (_form.getSearcherHeight * 3),
					_form.clientWidth - (_form.resizedMargin * 2),
					_form.getSearcherHeight	);
	
	// Add extra column for Yes/No buttons
	_table.columns := _table.ColumnValueExtra;
	
	// do we have a tracked item?
	if self.myMobileGenericAgent.myNextTiToAction &lt;&gt; null then
		// create an auto plan for checking criteria
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(self.myMobileGenericAgent.myNextTiToAction);
	endif;
	
	// load table with current context Cargo Check Items
	foreach item in cargoCheck.allCargoCheckItems discreteLock do	//31 May 2012	NDL Par 29038
		// does this tracked item match the cargo check criteria?
		if cmifAutoPlan &lt;&gt; null and not item.doesTIMatchMe(cmifAutoPlan) then
			continue;
		endif;
	
	
		idx := _table.addItem(item.name);
		_table.accessRow(idx).itemObject := item;
		
		// set cell control according to item's required extra info
		// if item is required, add two buttons Yes/No
		if item.required then
		
			self.setupCargoCheckTableYesNoBtns(_table, idx, _tickBtn, _crossBtn);
			
		elseif item.requiredExtraInfo.isOneOf(EXTRA_INFO_WEIGHT, EXTRA_INFO_DIMENSION, EXTRA_INFO_DAMAGE, EXTRA_INFO_PHOTO, EXTRA_INFO_SPECIAL_LIFT) then	// PAR #23369
		
			// add a button
			_table.accessCell(idx, _table.ColumnValue).picture := _button.createPicture(false, false, 32);
			// merge the second and third columns
			self.setupCargoCheckTableMergeCells(_table, idx);
			
		elseif item.requiredExtraInfo = EXTRA_INFO_SEALS then
		
			// PAR #23369 if this is ship load/unload context, and we have to check seals, put a button in the seals row otherwise just a check box.
			// If this isn't ship load/unload context, make it a button
			//if app.myMobileAgent.myVoyage &lt;&gt; null and app.myMobileAgent.myVoyage.myTerminal.getConfig(ETRow_IsShipLanderSealCheck).Boolean then
			if cargoCheck.context.isOneOf(CARGO_CHECK_CONTEXT_SHIP_LOAD, CARGO_CHECK_CONTEXT_SHIP_DISC) then
				if app.myMobileAgent.myVoyage &lt;&gt; null and app.myMobileAgent.myVoyage.myTerminal.getConfig(ETRow_IsShipLanderSealCheck).Boolean then
					// add a button
					_table.accessCell(idx, _table.ColumnValue).picture := _button.createPicture(false, false, 32);
				else
					// add a checkbox
					_table.accessCell(idx, _table.ColumnValue).inputType := Table.InputType_CheckBox;
				endif;
			else
				// add a button
				_table.accessCell(idx, _table.ColumnValue).picture := _button.createPicture(false, false, 32);
			endif;
				
			// merge the second and third columns
			self.setupCargoCheckTableMergeCells(_table, idx);
				
		else
			// add a check box
			_table.accessCell(idx, _table.ColumnValue).inputType := Table.InputType_CheckBox;
			// merge the second and third columns
			self.setupCargoCheckTableMergeCells(_table, idx);
		endif;
		
		// do we have anything to display from a previous visit to this form?
		if _otherObject &lt;&gt; null then
			setting := self.myMobileGenericAgent.allNonCargoCheckItemSelections[_otherObject, item];
		else
			setting := self.myMobileGenericAgent.allCargoCheckItemSelections[self.myMobileGenericAgent.myNextTiToAction, item];
		endif;
		if setting &lt;&gt; null then
		//if idx &lt;= self.allCargoCheckItemSelections.size then
		//	str := self.allCargoCheckItemSelections[idx];
			str := setting.selection;
			if item.required then
				if str = "Y" then
					_table.column := _table.ColumnValue;
				elseif str = "N" then
					_table.column := _table.ColumnValueExtra;
				endif;
				_table.row := idx;
				_formToDisplay := self.doEquipmentCheckTableClick(_table, true, _tickBtn, _crossBtn, _tickBtnDown, _crossBtnDown, _otherObject);
				
			elseif _table.accessCell(idx, _table.ColumnValue).inputType = Table.InputType_CheckBox then
				if str = "Y" then
					_table.accessCell(idx, _table.ColumnValue).text := "1";
				endif;
			//cnwjo3 par 23693, highlight button
			elseif _table.accessCell(idx, _table.ColumnValue).inputType = Table.InputType_None then
				if str = "Y" then  //its only Y for buttons
					_table.accessCell(idx, _table.ColumnValue).selected := true;
				endif;
			endif;
		endif;
	endforeach;

	if _table.rows &gt; _table.fixedRows then

		//_table.height := _table.rows * _table.rowHeight[1] + _form.MARGIN;
		_table.height := _table.rows * _table.rowHeight[1] + _form.resizedMargin;
		
		// PAR #23422 If table is now too tall to fit above buttons, change height
	//	if (_table.top + _table.height) &gt; _form.btnOne.top + 20 then
		if (_table.top + _table.height) &gt; (_form.btnOne.top - 5) then	//11 Sep 2013	NDL	Par 32172
			//change := (_table.top + _table.height) - _form.btnOne.top;
			change := (_table.top + _table.height) - (_form.btnOne.top - 5 );	//11 Sep 2013	NDL	Par 32172
			_table.height := _table.height - change;
			// allow for scroll bar
			_table.width := _table.width;
		endif;
	endif;
	_table.resize();
	_table.tabKey := J_key_Tab;
epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_table" type="CM_MobEntryTable" usage="input"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_form" type="MOB_HandHeldForm"/>
        <Parameter name="_tickBtn" type="MOB_Button"/>
        <Parameter name="_crossBtn" type="MOB_Button"/>
        <Parameter name="_tickBtnDown" type="MOB_Button"/>
        <Parameter name="_crossBtnDown" type="MOB_Button"/>
        <Parameter name="_button" type="MOB_Button"/>
        <Parameter name="_formToDisplay" type="Class" usage="output"/>
        <Parameter name="_otherObject" type="CM_Object"/>
    </JadeMethod>
</Class>
