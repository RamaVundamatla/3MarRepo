    <JadeMethod name="setForUpdate" id="5d15598f-18e7-47e4-a579-0f60ad9071ce">
        <updating/>
        <source>setForUpdate( _pxyWoDDtl : CM_WodCargoRequest ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/05/2018	jlgndl1	Initial creation	TFS 38560
24/10/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object
*/

vars
	pxyFile,
	realFile : CM_FileData;
	
	//17 Aug 2018	NDL	TFS 40127
	realMarineDetail : CM_WodMarineServiceDetail;
	pxyMarineDetail : CM_WodMarineServiceDetail;
	pxyDetail : CM_WorkOrderDtl;
	wodMarineServiceDtl : CM_WodMarineServiceDetail;	
	purgeSet : CM_WodMarineServiceDetailSet;
	voyage : CM_Voyage;									// TFS 41305 
	realWorkOrder	    : CM_WorkOrder;
begin

	inheritMethod(_pxyWoDDtl);
	
	self.dischargePort := _pxyWoDDtl.dischargePort;
	self.loadPort := _pxyWoDDtl.loadPort; //20 Jul 2018	NDL	TFS 39837
	self.imexStatus := _pxyWoDDtl.imexStatus;
	self.numGangs := _pxyWoDDtl.numGangs;
	self.totalQuantity := _pxyWoDDtl.totalQuantity;
	self.totalVolume := _pxyWoDDtl.totalVolume;
	self.totalWeight := _pxyWoDDtl.totalWeight;
	self.transferType := _pxyWoDDtl.transferType;
	self.weightCargo := _pxyWoDDtl.weightCargo;
	self.weightTare := _pxyWoDDtl.weightTare;
	
	self.myCargoSubType := _pxyWoDDtl.myCargoSubType;
	self.myCargoType := _pxyWoDDtl.myCargoType;
	self.myCommodity := _pxyWoDDtl.myCommodity;
	self.myConsignee := _pxyWoDDtl.myConsignee;
	self.myConsignor := _pxyWoDDtl.myConsignor;
	self.myFreightForwarder := _pxyWoDDtl.myFreightForwarder;
	self.myLocationsController := _pxyWoDDtl.myLocationsController;
	self.myOperator := _pxyWoDDtl.myOperator;
	self.setMyWorkPoint( _pxyWoDDtl.getMyWorkPoint );
	self.bolNumber  := _pxyWoDDtl.bolNumber;
//	self.myBerth 	:= _pxyWoDDtl.myBerth;
	self.estimatedEndTS :=_pxyWoDDtl.estimatedEndTS;
	self.estimatedStartTS := _pxyWoDDtl.estimatedStartTS;
	self.permitType := _pxyWoDDtl.permitType; //27 Jun 2018	NDL	TFS 39246
	self.rkbmNumber :=_pxyWoDDtl.rkbmNumber;
	self.specialStow := _pxyWoDDtl.specialStow;	//07 Sep 2018	NDL	TFS 40699
		
	self.taskID := _pxyWoDDtl.taskID; // TFS 42221 19DEC18

	// TFS 41026
	if self.permitType = 0 then
		self.permitType  := INV_WO_PERMIT_MANUALETMAL;
	endif;
	
	self.allFiles.clear();
	//20 May 2019	NDL	TFS 44813
	if _pxyWoDDtl.myVoyageCargoRequest &lt;&gt; null and _pxyWoDDtl.myVoyageCargoRequest.myParent &lt;&gt; null then	//09Aug2022 navsp1 TFS#54361 								
		voyage := _pxyWoDDtl.myVoyageCargoRequest.getMyVoyageObject;	
		realWorkOrder	:= _pxyWoDDtl.myVoyageCargoRequest.myParent.pxyGetRealObject;  						//08Aug2022 navsp1 TFS#54361 
	elseif _pxyWoDDtl.myPermitRequest &lt;&gt; null and _pxyWoDDtl.myPermitRequest.myParent &lt;&gt; null then			//09Aug2022 navsp1 TFS#54361 						
		voyage := _pxyWoDDtl.myPermitRequest.getMyVoyageObject;	
		realWorkOrder := _pxyWoDDtl.myPermitRequest.myParent.pxyGetRealObject;		   						//08Aug2022 navsp1 TFS#54361 
	endif;
	foreach pxyFile in _pxyWoDDtl.allFiles do
		create realFile persistent;
		//realFile.setForCreateProxy(null,app.myPassport.userCode,pxyFile);																				
		realFile.setForCreateProxy(realWorkOrder,app.myPassport.userCode,pxyFile);	//20 May 2019	NDL	TFS 44813
																					//replace voyage with realWorkOrder. - 08Aug2022 navsp1 TFS#54361
		//self.allFiles.add(realFile); 												//08Aug2022 navsp1 TFS#54361
	endforeach;
	
	//17 Aug 2018	NDL	TFS 40127
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _pxyWoDDtl.allMarineServiceDetails.findWodMarineServiceDet( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
     
	foreach pxyMarineDetail in _pxyWoDDtl.allMarineServiceDetails discreteLock do
		 realMarineDetail:=pxyMarineDetail.pxyGetRealObject .CM_WodMarineServiceDetail;
		 pxyDetail:=pxyMarineDetail;
		 if realMarineDetail = null then
			 create realMarineDetail persistent;	
			
			 realMarineDetail.setForCreate(pxyDetail.CM_WodMarineServiceDetail, null);
			 self.allMarineServiceDetails.add(realMarineDetail);
		else
			realMarineDetail.setForUpdate(pxyMarineDetail);			
		endif;
	endforeach;

	/* find the voyage moved up 20 May 2019	NDL	TFS 44813
	// TFS 41305 Update operator onto voyage if the voyage doesn't know about it yet	// TFS 41305
	if _pxyWoDDtl.myVoyageCargoRequest &lt;&gt; null then										// TFS 41305
		voyage := _pxyWoDDtl.myVoyageCargoRequest.getMyVoyageObject;					// TFS 41305
	elseif _pxyWoDDtl.myPermitRequest &lt;&gt; null then										// TFS 41305
		voyage := _pxyWoDDtl.myPermitRequest.getMyVoyageObject;							// TFS 41305
	endif;																				// TFS 41305 */
	if self.myOperator &lt;&gt; null and voyage &lt;&gt; null then									// TFS 41305
		voyage.allOperators.addNoDuplicates(self.myOperator, false);					// TFS 41305
	endif;																				// TFS 41305

epilog

	delete purgeSet;	//31 May 2019	NDL	TFS 44773

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="setMarineDetsFromResourceUsed" id="311ad0a9-dcd8-4633-8ab9-7a2d97197390">
        <updating/>
        <source>setMarineDetsFromResourceUsed( _resourceUsedSet : HMS_ResourceUsedSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	resourceUsed : HMS_ResourceUsed;
	purgeSet : CM_WodMarineServiceDetailSet;

begin

	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _resourceUsedSet.findResourceUsedFor( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	if _resourceUsedSet= null or _resourceUsedSet.isEmpty then
		return;
	endif;
	
	foreach resourceUsed in _resourceUsedSet do
		wodMarineServiceDtl := self.allMarineServiceDetails.findWodMarineServiceDet( resourceUsed.myResource );
		if wodMarineServiceDtl = null then
			if self.isTransient then
				create wodMarineServiceDtl transient;
			else
				create wodMarineServiceDtl persistent;
			endif;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setProxyFromResourceUsed( resourceUsed );		
	endforeach;

epilog

	delete purgeSet;

end;</source>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkPoint" id="b3acf4d3-eb9d-4454-9da0-1e034737a8f9">
        <updating/>
        <source>setMyWorkPoint(	_wp : CM_WorkPoint ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2018	jlgndl1	Initial creation	TFS 42613

*/

vars

	invalid : Boolean;
	ed : Integer;

begin

	if _wp = null then
		self.myWorkpoint := null;
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _wp, invalid );
	ed := _wp.edition;
	if invalid then
		self.myWorkpoint := null;
		return;
	endif;
	
	self.myWorkpoint := _wp;

epilog

end;</source>
        <Parameter name="_wp" type="CM_WorkPoint"/>
    </JadeMethod>
