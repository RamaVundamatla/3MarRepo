    <JadeMethod name="setupDisplayAndMoveModes" id="80b3f23f-52bd-4841-8246-b4fee9d43a75">
        <updating/>
        <source>setupDisplayAndMoveModes() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars
	
begin

	self.stbGeneral.enabled := true;
	self.stbGeneral.setDisplayMode(DISPLAY_MODE_ACTUAL);
	self.stbGeneral.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_INSTANT);
	self.stbGeneral.myFrameDisplayMode.enabled := false;
	self.stbGeneral.myFrameDisplayMode.clearGraphics;
	self.stbGeneral.myFrameMoveMode.enabled := true;
	
	self.setTableDisplayMode( self.frmDispOnship, DISPLAY_MODE_ACTUAL );
	self.setTableDisplayMode( self.frmDispOnsite, DISPLAY_MODE_ACTUAL );
	self.setTableDisplayMode( self.frmDispOffsite, DISPLAY_MODE_ACTUAL );
	self.setTableDisplayMode( self.frmDispPreNote, DISPLAY_MODE_ACTUAL );
	
	self.showTableDisplayMode( self.frmDispOnship );
	self.showTableDisplayMode( self.frmDispOnsite );
	self.showTableDisplayMode( self.frmDispOffsite );
	self.showTableDisplayMode( self.frmDispPreNote );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fd26ee92-3c65-4630-8981-f7b5616069b2">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
// 02 March 2018	jlgrh7		TFS 36564 AAT - Missing Stevedore field from Column Organiser in Voyage Operations
//
vars

begin
	self.frmToolbar.parent := self.dkcToolbar;
	
	// The user can access the summarise functionality only if they have at least view security role.
	self.allowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	self.showOffsite := app.myCurrentUserCan( self.myTerminal, PmShipNPNW_Offsite );
	
	self.setupDisplayAndMoveModes();
	self.baseCaption:=self.caption;
	inheritMethod();
	
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	//self.doListCargoBuild();
	self.initFilterTable();
	
	self.beginClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Create_Event), Response_Continuous, 1);
	self.beginClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Update_Event), Response_Continuous, 1);
	self.beginClassNotification( CM_Vehicle, false, self.myTerminal.getTerminalEvent(Vehicle_Move_Current), Response_Continuous, 1);
	self.addDebtorTypes();																									//+TFS36564RocH adding debtor types to allTblDataTransientRows
	self.initTable(self.tblOffsite);
	self.initTable(self.tblOnsite);
	self.initTable(self.tblOnship);
	self.initTable(self.tblPreNote);
	
	self.stbOnship.zOrder(1);
	self.stbOnsite.zOrder(1);
	self.stbPreNote.zOrder(1);
	
	self.setEnableObjects(null);

	self.lblOffsite.backColor := self.colorHeadingColumn;
	self.lblOnship.backColor := self.colorHeadingColumn;
	self.lblOnsite.backColor := self.colorHeadingColumn;		
	self.lblPreNote.backColor := self.colorHeadingColumn;		

	self.buildDischargeCombo();
	
	if self.frmQuery.visible then
		self.frmQuery.cnEcResizeContents();
		self.frmQuery.centreWindow();
		self.frmQuery.visible := true;
		self.frmQuery.zOrder(1);
	endif;
	
	self.chkRORO.value := false;
	self.chkRORO.visible := false;
	if app.myRoot.client = Client_PortEverett then
		self.chkRORO.visible := true;
	endif;
	
	// set the userObject on the floatable form sections to this form, so when they float we have a way of getting back
	self.dkcOnShip.userObject := self;
	self.dkcOnTerminal.userObject := self;
	self.dkcOffSite.userObject := self;
	self.dkcPreNotes.userObject := self;
	
	self.frmDispOffsite.visible := false;
	self.frmUserColours.visible := false;
	
	/* //30/07/2025	navkc1 JIRA MTN 35478  using standard notification framework, no longer needed
	if self.cmbRefreshMins.listCount = 0 then	//16 Mar 2021	NDL	TFS 50796
		//technically possible the first time a user opens the form ever.
		self.cmbRefreshMinsPopulate();
	endif;
	*/
	self.clickDisplayPerformanceModeOpt( null );	//04 Mar 2021	NDL	TFS 50796
	self.fldQuery.topSheet := self.shtVoyage;	//04 Mar 2021	NDL	TFS 50796
	
	//self.startPerformWarnTimer();	//04 Mar 2021	NDL	TFS 50796 //30/07/2025	navkc1 JIRA MTN 35478 using standard notification framework, no longer needed
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryBOL" id="3beb0485-af0f-4238-95d8-94f01ff85bdb">
        <source>showCargoEnquiryBOL(_table : CM_DataTable; _doEdit : Boolean);
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	theObject 	: Object;
	objArray 	: ObjectArray;
	bolArray 	: ObjectArray;
	bol			: CM_BOLIn;
	ti			: CM_TrackedItem;
begin
	
	create objArray transient;
	create bolArray transient;
	_table.allSelectedObjects.copy(objArray);

	if objArray.isEmpty then
		return;
	endif;
	
	foreach theObject in objArray do
		if CM_TrackedItem.hasInstance(theObject) then
			ti := theObject.CM_TrackedItem;
		else
			continue;
		endif;
		bol := ti.myReceivalBOL;
		if bol &lt;&gt; null and (not bolArray.includes(bol)) then
			bolArray.add(bol);
		endif;	
	endforeach;
		
	theObject := bolArray[1];
	
	if theObject &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForBOLs(theObject.CM_BOL, bolArray, self.myMasterMenuAction, _doEdit);	
	endif;
	
epilog
	delete objArray;
	delete bolArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="e35f2625-1a9c-4952-b41c-6e7e9dab6d3f">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating;
//--------------------------------------------------------------
//Created: 20 October 2003 By: cnwgd1
// 02 March 2018	jlgrh7		TFS 36564 AAT - Missing Stevedore field from Column Organiser in Voyage Operations
//--------------------------------------------------------------
vars

begin
	if _dataTable = null then
		return;
	endif;
	
	//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
	
	//_dataTable.showColumnOrganiserFrm(self.myTerminal, self.allTblDataTransientRows);					//-TFS36564
	if _dataTable = self.tblOnship then																																//+TFS36564 begins
		_dataTable.showColumnOrganiserFrm(self.myTerminal, self.allOnShipTblDataTransRows);
	endif;
	if _dataTable = self.tblOnsite then
		_dataTable.showColumnOrganiserFrm(self.myTerminal, self.allOnSiteTblDataTransRows);
	endif;
	if _dataTable = self.tblOffsite then
		_dataTable.showColumnOrganiserFrm(self.myTerminal, self.allOffSiteTblDataTransRows);
	endif;
	if _dataTable = self.tblPreNote then
		_dataTable.showColumnOrganiserFrm(self.myTerminal, self.allPreNoteTblDataTransRows);
	endif;
	

epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
