    <JadeMethod name="differentPortRotations" id="c321a8aa-c07b-4fd4-9027-095d6d28084b">
        <source>differentPortRotations(_originalPR : CM_PortRotationArray; _newPR : CM_PortRotationArray) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwas3	par 23043

*/

vars
	iPortRot,index : Integer;
	tmpOriginalPortArray,tmpNewPortArray : CM_PortArray;
	tmpPort : CM_Port;
begin
	
	iPortRot := _originalPR.size();
	
	if iPortRot &lt;&gt; _newPR.size() then 
		return true;
	endif;
	
	foreach index in 1 to iPortRot do
		tmpOriginalPortArray := _originalPR[index].allTranshipPorts;
		tmpNewPortArray := _newPR[index].allTranshipPorts;
		if tmpOriginalPortArray.size() &lt;&gt; tmpNewPortArray.size() then
			return true;
		endif;
		foreach tmpPort in tmpOriginalPortArray do
			if not tmpNewPortArray.includes(tmpPort) then
				return true;
			endif;
		endforeach;		
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_originalPR" type="CM_PortRotationArray"/>
        <Parameter name="_newPR" type="CM_PortRotationArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayBerthageDetails" id="db2c2be8-7423-48db-ab41-03101c8ded70">
        <source>displayBerthageDetails(_voyageData : HMS_VoyageData) protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
// 03/07/2014   cnwma1		CCMS SFW1328 -HMS Not Available For Entry  
//-----------------------------------------
vars
	tmpPriority : Integer;
	idx			: Integer; // cnwma1  3/7/2014   CCMS SFW 1328
begin
	// Berthage Details
	
	if (not self.shtHMSBerthage.visible) then
		return;
	endif;
	
	if (_voyageData = null) or (_voyageData &lt;&gt; null and _voyageData.allVoyageMovements.size() = 0) then		// 2/9/19 MAP TFS45926
		self.cmbPortFrom.setObject(null);
		self.cmbPortTo.setObject(null);
		self.cmbBerth.listIndex := -1;
		self.optBerth.value := false;
		self.optBerth.click(self.optBerth);
		self.cmbShippingAgent.setObject(null);	
		self.cmbBerthPriority.listIndex := 1;
		self.cmbLineCompany.listIndex := -1;
		self.cmbVisitType.listIndex	:=	CNEC_NULL_INDEX;
		self.txtCrewTieUp.text := null;
		self.txtCrewLetGo.text := null;
		self.txtEstTieUpTime.text := null;
		self.txtTugsArrive.text := null;
		self.txtTugsDepart.text := null;
	else
		self.cmbPortFrom.setObject(_voyageData.myPortFrom);
		self.cmbPortTo.setObject(_voyageData.myPortTo);
		self.cmbBerth.listIndex :=  self.cmbBerth.findObject(_voyageData.getMyBerth);
		self.optBerth.value := (self.cmbBerth.listIndex &gt; 0);
		self.optBerth.click(self.optBerth);
		self.cmbShippingAgent.setObject(_voyageData.myShippingAgent);	
		self.cmbVisitType.cnEcSetObjectIndex(_voyageData.myVisitType);
		
		tmpPriority := _voyageData.berthPriority;
		
		if (tmpPriority &gt;= 2 and tmpPriority &lt;= 4)
		or (tmpPriority &gt;= 6 and tmpPriority &lt;= 9)
		then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, tmpPriority.String);
		elseif tmpPriority = 5 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '5 - Medium');	
		elseif tmpPriority = 10 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '10 - Low');			
		else
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '1 - High');		
		endif;								

		self.cmbLineCompany.listIndex :=  self.cmbLineCompany.findObject(_voyageData.myLineCompany);   // cnwma1  4/7/2014   CCMS SFW 1328
		if self.cmbLineCompany.listIndex = -1 and _voyageData.myLineCompany &lt;&gt; null then			   // cnwma1  3/7/2014   CCMS SFW 1328
			if cmbLineCompany.isKindOf(CMUI_ComboBox) then
				cmbLineCompany.CMUI_ComboBox.addItemObject(_voyageData.myLineCompany.description, _voyageData.myLineCompany);
			else	
				idx := cmbLineCompany.addItem(_voyageData.myLineCompany.description);
				cmbLineCompany.itemObject[idx] := _voyageData.myLineCompany;
			endif;
			self.cmbLineCompany.listIndex := self.cmbLineCompany.findObject(_voyageData.myLineCompany);
		endif;
		
		//////////////////////////////////////////////
		
		self.txtCrewTieUp.text := _voyageData.numLCrewTieUp.asStringJMT;
		self.txtCrewLetGo.text := _voyageData.numLCrewLetGo.asStringJMT;
		self.txtEstTieUpTime.text := _voyageData.estTieUpTime.asStringJMT;
		self.txtTugsArrive.text := _voyageData.numTugsIn.asStringJMT;
		self.txtTugsDepart.text := _voyageData.numTugsOut.asStringJMT;
	endif;				
	
	self.shtHMSBerthage.enabled := true;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="displayCargoVoyageDetails" id="0572b7a2-8aac-4859-9214-e283cd178a6b">
        <updating/>
        <source>displayCargoVoyageDetails(voyage : CM_Voyage) updating, protected;
//--------------------------------------------------------------
//Created: 08 May 2003 By: cnwgd1
//--------------------------------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
21/01/2014	cnwdap1	PAR #33337 
					CCMS PTR 2214 	Default Colour to HMS MovementIsSaved constant value
10/05/2016	cnwns1	TFS 488  		Multi Timezone Support
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
22/06/2021	navdap1	TFS 51326		ASPA Bulk Edit Voyages
============================================================================*/
vars
	shipLine 		  	  : CM_ShippingLine;
	theDefaultCompany 	  : CM_Bank;
	idx 			  	  : Integer;
	structure 			  : CM_CellularVoyageStructure;
	nonPlannedEffectiveDT : TimeStamp;
begin

	//**********************************************************************************************************
	// the following is for the cargo module only			
	//**********************************************************************************************************
	
	if (not self.grpCellulaVoyage.visible) then
		return;
	endif;
	
	self.displayCargoVoyageExchange(voyage);

	// CCMS 1423 clear all here and then set below
	self.optShowAlways.value  := false;
	self.optShowNever.value   := false;
	self.optShowDefault.value := false;					
	
	if voyage = null then

		self.cmbMoveMapRec.listIndex 	:= -1;
		self.cmbMoveMapRel.listIndex 	:= -1;		
		self.cmbVoyPlanCode.listIndex 	:= -1;
		self.cmbVoyOperator.listIndex 	:= -1;
		self.cmbLineGroupDebt.listIndex := -1;
		self.cmbBank.listIndex 			:= -1;
			
	  // Call this for null as well as it clears the list box and changes the lable caption 
	  //self.displayCargoVoyagePortsOfCall(null);    
		
		self.cmbShippingLine.setObject(null);
		self.cmbLineGroupDebt.listIndex := -1;
	
		self.cmbTrade.setObject(null);
		self.displayTrade(null); //ccms 1058
		self.pickColour.setColor(Cn_LightGray);					// PAR #33337
	
		self.dateNonPlanned.text := null;
		self.timeNonPlanned.text := null;
		
		// CCMS 1423 use the default
		self.optShowDefault.value := true;							

		//CCMS 1028 cnwjo3
		self.chkUseVoyageAllo.value := true;  // PAR 33644 new default is YES!!!!
		self.shtVoyageAlloc.enabled := true;
		
		self.chkIsBarge.value		:= false; //jlgka1 TFS 37102
	else
	
	
		// 31232
		if voyage.myCellularVoyageStructure &lt;&gt; null then
			structure := voyage.myCellularVoyageStructure;
		endif;

		self.cmbMoveMapRec.listIndex := self.cmbMoveMapRec.findObject(voyage.myMMReceival);
		self.cmbMoveMapRel.listIndex := self.cmbMoveMapRel.findObject(voyage.myMMRelease);					
	
		self.cmbVoyPlanCode.setObject(voyage.myVoyagePlanningCode);
		self.cmbVoyOperator.listIndex 	:= self.cmbVoyOperator.findObject(voyage.myOperator);
		self.cmbLineGroupDebt.listIndex := self.cmbLineGroupDebt.findObject(voyage.myDefaultLineGroupDebtor);
		self.cmbBank.listIndex 			:= self.cmbBank.findObject(voyage.myDischargeCompany);
	    shipLine 						:= voyage.myShippingLine;
		
		// Call this for null as well as it clears the list box and changes the lable caption 
	
	    if shipLine &lt;&gt; null then
			self.cmbShippingLine.setObject(shipLine);
			self.myAssistant.comboBoxLineGroupDebtor(self.cmbLineGroupDebt, voyage.myDefaultLineGroupDebtor, shipLine);
		else
			self.cmbShippingLine.setObject(null);
			self.cmbLineGroupDebt.listIndex := -1;
	    endif;
	
		self.displayTrade(null); //ccms 1058
		self.cmbTrade.setObject(voyage.myTrade);
		
		self.pickColour.setColor(voyage.colour);
	
		if (self.mode = self.Mode_View
		or (not self.isFirstActivateComplete))		
		and voyage.nonPlannedEffectiveDT.isValid() then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			//nonPlannedEffectiveDT := self.systemToLocalTime(nonPlannedEffectiveDT);			// TFS 51326
			nonPlannedEffectiveDT := self.systemToLocalTime(voyage.nonPlannedEffectiveDT);		// TFS 51326
			self.dateNonPlanned.setDate(nonPlannedEffectiveDT.date());
			self.timeNonPlanned.setTime(nonPlannedEffectiveDT.time());		
		else
			self.dateNonPlanned.text := null;
			self.timeNonPlanned.text := null;
		endif;
		
		// CCMS 1423
		if voyage.displayOption = VoyageDisplayAlways then
			self.optShowAlways.value 	:= true;
		elseif voyage.displayOption = VoyageDisplayNever then
			self.optShowNever.value 	:= true;
		else
			self.optShowDefault.value	:= true;						
		endif;

		//CCMS 1028 cnwjo3
		self.chkUseVoyageAllo.value := voyage.useVoyageAllocations;
		self.shtVoyageAlloc.enabled := voyage.useVoyageAllocations;
		self.chkIsBarge.value 		:= voyage.isBarge; //jlgka1 TFS 37102	
		self.chkDefaultOOS.value 	:= voyage.createOutOfSequenceLoadJobs();//cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
			    
end;</source>
        <access>protected</access>
        <Parameter name="voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="displayCargoVoyageExchange" id="93be0498-0855-41c4-83ee-dee7af62be41">
        <updating/>
        <source>displayCargoVoyageExchange(_voyage : CM_Voyage) updating, protected;
//--------------------------------------------------
// Created:	04 August 2005 By: cnwgd1
//--------------------------------------------------
/****Changes

Date		Name	TFS#		Description
============================================================================
1/12/2009	CNWER1 	CCMS 1900 	Added check seals config 
10/05/2016	cnwns1	TFS 488 	Multi Timezone Support
24/02/2017 	cnwrh7  TFS3464     Voyage definition / voyage status
21/03/2017	cnwdap1	TFS 3818 	Cargo Availability Date
15/03/2018	jlgdap1	TFS 37427 	PEL1 Voyage Status Enhancements
19/03/2018	jlgdap1	TFS 37540 	PEL1 Voyage Statuses Pelindo 1
24/04/2018	jlgdap1	TFS 38214 	PEL1 Voyage Status Changes
09/08/2019	jlgka1 	TFS 45921	PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
============================================================================*/
vars
	statusStr			 	: String;
	terminalObj			 	: CM_Terminal;
	checkShipLanderSeals 	: Any;
	pilotOnBoardDT			: TimeStamp;
	shipExchangeCompleteDT	: TimeStamp;
	labourOnBoard			: TimeStamp;
	shipAnchorDownDT		: TimeStamp;
	shipPilotReturnDT		: TimeStamp;
	labourOnShore			: TimeStamp;
	shipExchangeDate		: TimeStamp;
	departTargetDT			: TimeStamp;
	dateFirstAvailable	 	: TimeStamp;
	voyageProcess 			: CM_VoyageProcess;				// TFS 37427
	voyageStatus 			: CM_VoyageStatus;				// TFS 37427
	nextStatuses 			: CM_VoyageStatusByPriority;	// TFS 37540
	currentStatus 			: Integer;						// TFS 37540
	status 					: CM_VoyageStatus;				// TFS 37540
begin
	// Load Exchange details

	if (not self.shtExchange.visible) then
		return;
	endif;
	
	terminalObj	:=	self.myTerminal;
	
	if _voyage = null then
		self.optStarboard.value 	:= false;
		self.optPort.value 			:= true;		
		self.datePilotOnBoard.text	:= null;
		self.timePilotOnBoard.text	:= null;
		self.dateExchangeComp.text	:= null;
		self.timeExchangeComp.text	:= null;
		self.dateLabourOBD.text		:= null;
		self.timeLabourOB.text		:= null;
		self.dateLabourOSD.text		:= null;
		self.timeLabourOS.text		:= null;
		self.dateExchanStart.text	:= null;
		self.dateAvailable.text		:= null;
		self.timeExchangeStar.text	:= null;
		self.dateDepartTarget.text	:= null;
		self.timeDepartTarget.text	:= null;
		self.dateAnchorDown.text	:= null;
		self.timeAnchorDown.text	:= null;
		
		if terminalObj = null then
			txtWTimeInPort.cnEcSet(null);
			txtWNoChargeTime.cnEcSet(null);
			cmbWStopCharging.cnEcSet(CNEC_NULL_INDEX);
			txtWLoadRate.cnEcSet(null);
			txtWDischargeRat.cnEcSet(null);
			self.ckbCheckSealDish.value:=false;
		else
			txtWTimeInPort.cnEcSet(terminalObj.getConfig(GrossLoadingTime).String);
			txtWNoChargeTime.cnEcSet(terminalObj.getConfig(NonChargeTime).String);
			cmbWStopCharging.cnEcSetTextIndex(terminalObj.getConfig(StopCharging).String);
			txtWLoadRate.cnEcSet(terminalObj.getConfig(VesselLoadRate).String);
			//txtWLoadRate.cnEcSet(terminalObj.getConfig(VesselLoadRate).asStringJMT);
			self.ckbCheckSealDish.value:=terminalObj.getConfig(IsShipLanderSealCheck).Boolean;
		endif;
		
		//self.cmbStatus.listIndex := self.cmbStatus.findString(0,app.getErrorString(VoyageCmb_Status_Pending_Str));	// TFS 37427
		voyageProcess := self.myTerminal.getDefaultVoyageProcess();						// TFS 37427
		self.cmbProcess.listIndex := self.cmbProcess.findObject(voyageProcess);			// TFS 37427
		if voyageProcess &lt;&gt; null then													// TFS 37427
			voyageStatus := voyageProcess.getInitialVoyageStatus;						// TFS 37427
			self.cmbStatus.listIndex := self.cmbStatus.findObject(voyageStatus);		// TFS 37427			
			if self.cmbStatus.listIndex = -1 then										// TFS 38214
				
				 //jlier1 TFS 51963 1/10/21
				self.chkAllStatus.value := voyageProcess.isMTNWOProcess; 
				
				//epr TFS 41523 2/11/18
				self.initComboVoyageStatus(voyageProcess,null);				
				self.checkandsetCmbStatus(voyageProcess, null);	 //jlgka1 TFS 45921				
			endif;																		// TFS 38214
		elseif self.cmbStatus.listCount &gt; 0 then										// TFS 37427
			self.cmbStatus.listIndex := 1;												// TFS 37427
		endif;																			// TFS 37427
	else
		if _voyage.starboardBerthed then
			self.optStarboard.value := true;
		else
			self.optPort.value := true;
		endif;
		
		//CCMS 1273
		if _voyage.pilotOnBoardDT.isValid() then
			global.cnwer1Write(pilotOnBoardDT.String);
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			pilotOnBoardDT := self.systemToLocalTime(_voyage.pilotOnBoardDT); 
			self.datePilotOnBoard.setDate(pilotOnBoardDT.date());
			self.timePilotOnBoard.setTime(pilotOnBoardDT.time());
		else
			self.datePilotOnBoard.text := null;
			self.timePilotOnBoard.text := null;
		endif;
		
		if _voyage.shipExchangeCompleteDT.isValid then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			shipExchangeCompleteDT := self.systemToLocalTime(_voyage.shipExchangeCompleteDT);
			self.dateExchangeComp.setDate(shipExchangeCompleteDT.date());
			self.timeExchangeComp.setTime(shipExchangeCompleteDT.time());
		else
			self.dateExchangeComp.text := null;
			self.timeExchangeComp.text := null;
		endif;
		
		// CCMS 1115 AKB2004JAN
		if _voyage.labourOnBoard.isValid() then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			labourOnBoard := self.systemToLocalTime(_voyage.labourOnBoard);
			self.dateLabourOBD.setDate(labourOnBoard.date());
			self.timeLabourOB.setTime(labourOnBoard.time());
		else
			self.dateLabourOBD.text := null;
			self.timeLabourOB.text := null;
		endif;
		// KPI MODULE CCMS 1002. AKB2007SEP
		if _voyage.shipAnchorDownDT.isValid() then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			shipAnchorDownDT := self.systemToLocalTime(_voyage.shipAnchorDownDT);
			self.dateAnchorDown.setDate(shipAnchorDownDT.date());
			self.timeAnchorDown.setTime(shipAnchorDownDT.time());
		else
			self.dateAnchorDown.text := null;
			self.timeAnchorDown.text := null;
		endif;
		// KPI MODULE CCMS 1002. AKB2007SEP
		if _voyage.shipPilotReturnDT.isValid() then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			shipPilotReturnDT := self.systemToLocalTime(_voyage.shipPilotReturnDT);
			self.datePilotReturn.setDate(shipPilotReturnDT.date());
			self.timePilotReturn.setTime(shipPilotReturnDT.time());
		else
			self.datePilotReturn.text := null;
			self.timePilotReturn.text := null;
		endif;

		if _voyage.labourOnShore.isValid() then		
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			labourOnShore := self.systemToLocalTime(_voyage.labourOnShore);
			self.dateLabourOSD.setDate(labourOnShore.date());		
			self.timeLabourOS.setTime(labourOnShore.time());
		else
			self.dateLabourOSD.text	:=	null;
			self.timeLabourOS.text	:=	null;
		endif;
		
		if _voyage.dateFirstAvailable.isValid() then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			//dateFirstAvailable.cnEcSetDateAndTime(_voyage.dateFirstAvailable,TimeStartOfDay);	// TFS 3818
			//self.dateAvailable.setDate(self.systemToLocalTime(dateFirstAvailable).date);		// TFS 3818
			self.dateAvailable.setDate(_voyage.dateFirstAvailable);								// TFS 3818
		else
			self.dateAvailable.text	:=	null;
		endif;
		
		if _voyage.shipExchangeDate.isValid() then
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			shipExchangeDate := self.systemToLocalTime(_voyage.shipExchangeDate);
			self.dateExchanStart.setDate(shipExchangeDate.date());
			self.timeExchangeStar.setTime(shipExchangeDate.time());
		else
			self.dateExchanStart.text := null;
			self.timeExchangeStar.text := null;
		endif;
	
		if _voyage.departTargetDT.isValid() then	
			// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			departTargetDT := self.systemToLocalTime(_voyage.departTargetDT);
			self.dateDepartTarget.setDate(departTargetDT.date());
			self.timeDepartTarget.setTime(departTargetDT.time());
		else
			self.dateDepartTarget.text := null;
			self.timeDepartTarget.text := null;
		endif;
		
		if _voyage.generalLandingDate.isValid() then	//15 Mar 2016	NDL	TFS 1407
			// don't calculate it, only put up the database recorded value
			self.dateGenLanding.setDate(  _voyage.getGeneralLandingDate(true) );
		else
			self.dateGenLanding.setDate(null);
		endif;
		
		txtWTimeInPort.cnEcSet(_voyage.totalTimeInPort.String);
		txtWNoChargeTime.cnEcSet(_voyage.nonChargeTime.String);
		cmbWStopCharging.cnEcSetTextIndex(_voyage.stopChargingAt);
		//txtWLoadRate.cnEcSet(_voyage.loadRate.String);
		txtWLoadRate.cnEcSet(_voyage.loadRate.asStringJMT);
		txtWDischargeRat.cnEcSet(_voyage.dischargeRate.String);
		
		//self.cmbStatus.listIndex := self.cmbStatus.findString(1, app.voyageStatusEnumToString(_voyage.status, false));
		voyageProcess := _voyage.myVoyageProcess;																			// TFS 37427
		if voyageProcess = null then																						// TFS 37427
			voyageProcess := self.myTerminal.getDefaultVoyageProcess();														// TFS 37427
		endif;																												// TFS 37427
		if voyageProcess &lt;&gt; null then																						// TFS 37427
			self.cmbProcess.listIndex := self.cmbProcess.findObject(voyageProcess);											// TFS 37427
			self.cmbStatus.clear();													// TFS 37540
			self.cmbStatus.sorted := false;											// TFS 37540
			self.cmbStatus.addItem(" ");											// TFS 38214
			create nextStatuses transient;											// TFS 37540
			if self.mode = self.Mode_Add then										// TFS 38214
				currentStatus := null;												// TFS 38214
			else																	// TFS 38214
				currentStatus := self.myCurrentVoyage.status;						// TFS 37540
									
				self.chkAllStatus.value := voyageProcess.isMTNWOProcess(); 				//jlier1 TFS 51963 1/10/21
				
			endif;		
			
			//epr TFS 41523 2/11/18
			self.initComboVoyageStatus(voyageProcess,currentStatus);
			self.checkandsetCmbStatus(voyageProcess, currentStatus);	 //jlgka1 TFS 45921
		endif;																		// TFS 37427
		
		//epr par 21806 1/12/09
		global.getExtraData(_voyage.allStateData,IsShipLanderSealCheck,checkShipLanderSeals);
		self.ckbCheckSealDish.value:=checkShipLanderSeals.Boolean;
	endif;
epilog
	delete nextStatuses;		// TFS 37540
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="displayCommodityStevedores" id="0a9941fb-ff00-4365-a2cb-418ae31d873d">
        <source>displayCommodityStevedores(_voyageData : HMS_VoyageData) protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
//-----------------------------------------
vars

begin
	
	if _voyageData = null then
		// clear selected		
		self.mulStevedoreDisc.setSelected(null);
		self.mulStevedoreLoad.setSelected(null);
	else
		// Stevedores
		self.mulStevedoreDisc.setSelected(_voyageData.allStevedoresDischarge);
		self.mulStevedoreLoad.setSelected(_voyageData.allStevedoresLoad);
	
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="displayEntryOperator" id="a6e8e8d6-3b4a-40f1-86a8-411548d21054">
        <source>displayEntryOperator(pObj : CM_Operator) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2009	cnwer1	Initial creation

*/

vars

begin
	return self.myAssistant.displayEntryOperator(pObj);
epilog

end;</source>
        <Parameter name="pObj" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayHMSDelay" id="c77e3aba-c04f-4dcb-a8d2-263adbef8b90">
        <source>displayHMSDelay() protected;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 HMS_VoyageDelay objects are now CM_Delay objects
vars
	tmpTable : CM_DataTable;
	saveDelay,
	//delay : HMS_VoyageDelay;								// PAR #35397
	delay : CM_Delay;										// PAR #35397
	//delayArray : HMS_VoyageDelayByStartTimeDict;			// PAR #35397
	delayArray : CM_DelayByStartDTDict;						// PAR #35397
	rowArray : EntTableRowArray;
begin

	if (not self.shtHMSMovements.visible) then
		return;
	endif;
		
	tmpTable := self.tblDelays;
	//saveDelay := self.tblDelays.accessRow(tmpTable.row).itemObject.HMS_VoyageDelay;		// PAR #35397
	saveDelay := self.tblDelays.accessRow(tmpTable.row).itemObject.CM_Delay;				// PAR #35397
	tmpTable.rows := tmpTable.fixedRows;
	tmpTable.clearAllSelected();	// 14/05/2012 cnwar2 #14987

	//if self.myCurrentVoyageData = null then												// PAR #35397
	if self.myCurrentVoyage = null then														// PAR #35397
		return;
	endif;

	//delayArray := self.myCurrentVoyage.myHMSVoyageData.allVoyageDelays;					// PAR #35397
	delayArray := self.myCurrentVoyage.allDelays;											// PAR #35397
	rowArray := tmpTable.allTblDataEntRows;
	
	foreach delay in delayArray do
		if saveDelay = delay then
			tmpTable.row := tmpTable.addItemObject(delay, delay.getAttributeStringForDefArray(rowArray));
		else
			tmpTable.addItemObject(delay, delay.getAttributeStringForDefArray(rowArray));		
		endif;
	endforeach;
	
	tmpTable.colourRows(self.colorRow1, self.colorRow2);

	if app.myCurrentUserCan(self.myTerminal, PmHMSVoyageMaint) then
		self.btnAddDelay.enabled := true;
		//self.btnDeleteDelay.enabled := true;	// 11/05/2012 cnwar2 #14987
		//self.btnEditDelay.enabled := true;	// 11/05/2012 cnwar2 #14987
	endif;
 		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayHMSDelaySelected" id="240b2ac6-8bd4-4532-ad2f-f21960cf80c7">
        <source>displayHMSDelaySelected();

/*
Date		Who		Reason
14 May 2012	cnwar2	#14987

*/
vars
	obj 	: CM_Object;
	harbour : HMS_Harbour;

begin
	self.btnDeleteDelay.enabled := false;
	self.btnEditDelay.enabled 	:= false;
	self.btnAddDelay.enabled 	:= (self.mode = self.Mode_View);
	self.tblDelays.userObject 	:= null;
	
	if self.tblDelays.row &lt;= self.tblDelays.fixedRows then
		return;
	endif;

	obj := self.tblDelays.accessRow(self.tblDelays.row).itemObject.CM_Object;
	
	if obj = null then
		return;
	else
		self.tblDelays.userObject := obj;
	endif;
	if self.mode = self.Mode_View then
		self.btnDeleteDelay.enabled := true;
		self.btnEditDelay.enabled 	:= true;		
		self.btnAddDelay.enabled 	:= true;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayHMSMovementResources" id="24f1eb37-d83d-4f4d-84d7-819ba877e722">
        <source>displayHMSMovementResources(_hmsData : HMS_Object) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/01/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
//
vars
	vesselDataHarbour	: HMS_VesselDataHarbour;
	voyageData			: HMS_VoyageData;
	movementResource 	: HMS_ResourceTypeForMovement;
	resourceType		: HMS_ResourceType;
	int 				: Integer;
	coll				: HMS_MovementResourceByMovement;
	
begin
	if (not self.shtHMSMoveRes.visible) then
		return;
	endif;
		
	if _hmsData = null then
		return;
	endif;
	
	if HMS_VesselDataHarbour.hasInstance(_hmsData) then
		vesselDataHarbour := _hmsData.HMS_VesselDataHarbour;
		coll := vesselDataHarbour.allMovementResourcesByMovement;
	elseif HMS_VoyageData.hasInstance(_hmsData) then
		voyageData := _hmsData.HMS_VoyageData;
		coll := voyageData.allDefaultMovementResources;
	else
		return;
	endif;

	foreach movementResource in coll do	
		if movementResource.movementType = HMSMovementTypeArrival then
			self.txtTugsMArrival.text := movementResource.numTugsForMovement.asStringJMT;
			foreach resourceType in movementResource.allResourceTypes discreteLock do 
				if resourceType.isNotAvailableForEntry then // will need to be added to table as will not be in table collection
					if not self.lstResTypeArriva.findObject(resourceType, int) then // final check not already there
						self.lstResTypeArriva.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourceType), resourceType);
					endif;
				endif;
			endforeach;
			self.lstResTypeArriva.setSelected(movementResource.allResourceTypes);
		elseif movementResource.movementType = HMSMovementTypeShift then
			self.txtTugsMShift.text := movementResource.numTugsForMovement.asStringJMT;
			foreach resourceType in movementResource.allResourceTypes discreteLock do 
				if resourceType.isNotAvailableForEntry then // will need to be added to table as will not be in table collection
					if not self.lstResTypeShift.findObject(resourceType, int) then // final check not already there
						self.lstResTypeShift.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourceType), resourceType);
					endif;
				endif;
			endforeach;
			self.lstResTypeShift.setSelected(movementResource.allResourceTypes);					
		elseif movementResource.movementType = HMSMovementTypeDeparture then
			self.txtTugsMDepart.text := movementResource.numTugsForMovement.asStringJMT;
			foreach resourceType in movementResource.allResourceTypes discreteLock do 
				if resourceType.isNotAvailableForEntry then // will need to be added to table as will not be in table collection
					if not self.lstResTypeDepart.findObject(resourceType, int) then // final check not already there
						self.lstResTypeDepart.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourceType), resourceType);
					endif;
				endif;
			endforeach;
			self.lstResTypeDepart.setSelected(movementResource.allResourceTypes);					
		endif;						
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hmsData" type="HMS_Object"/>
    </JadeMethod>
    <JadeMethod name="displayHMSMovementSelected" id="2d54c2fc-af09-4150-a88a-c365c56f9375">
        <source>displayHMSMovementSelected()protected;
//--------------------------------------------------
// Created:	December 2004 By: cnwgd1
//--------------------------------------------------
vars
	obj : CM_Object;
	harbour : HMS_Harbour;
begin

	self.btnDeleteMove.enabled 		:= false;
	self.btnEditMovement.enabled 	:= false;		
	//self.btnAddMovement.enabled 	:= false;							// 11/05/2012 cnwar2 #14987
	self.btnAddMovement.enabled 	:= (self.mode = self.Mode_View);	// 11/05/2012 cnwar2 #14987
	self.tblHMSMovements.userObject := null;
	
	if self.tblHMSMovements.row &lt;= self.tblHMSMovements.fixedRows then
		return;
	endif;

	obj := self.tblHMSMovements.accessRow(self.tblHMSMovements.row).itemObject.CM_Object;
	
	if obj = null then
		return;
	else
		self.tblHMSMovements.userObject := obj;
	endif;
	if self.mode = self.Mode_View then
		self.btnDeleteMove.enabled := true;
		self.btnEditMovement.enabled := true;		
		self.btnAddMovement.enabled := true;
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayHMSMovements" id="1ae745cc-c7ea-49f2-985c-b2210895aa16">
        <source>displayHMSMovements()protected;
//--------------------------------------------------
// Created:	December 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpMovement : HMS_VoyageMovement;
	tmpMovementDict : HMS_VoyageMovementByDateDict;
	rowArray : EntTableRowArray;
begin
	
	if (not self.shtHMSMovements.visible) then
		return;
	endif;
		
	self.tblHMSMovements.rows := self.tblHMSMovements.fixedRows;
	self.tblHMSMovements.clearAllSelected();
	
	self.shtHMSMovements.enabled := true;
			
	if self.myCurrentVoyageData = null then
		return;
	endif;
						
	tmpMovementDict := self.myCurrentVoyage.myHMSVoyageData.allVoyageMovements;
	rowArray := self.tblHMSMovements.allTblDataEntRows;
	
	foreach tmpMovement in tmpMovementDict do
		self.tblHMSMovements.addItemObject(tmpMovement, tmpMovement.getAttributeStringForDefArray(rowArray));
	endforeach;
	
	self.tblHMSMovements.colourRows(self.colorRow1, self.colorRow2);
	self.tblHMSMovements.resort();										// PAR #35397
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayHMSVoyageData" id="c2084f3e-810b-4eff-bc17-b4529b4fc3f2">
        <source>displayHMSVoyageData(_voyageData : HMS_VoyageData) protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 30/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Delays are no longer HMS-reliant
vars

begin

	if (not self.shtHMSHarborData.visible) then
		return;
	endif;
	
	if _voyageData = null then
		if self.shtPortsOfCall.visible then
			// showing both harbour and cargo module data
			self.ckbCreateHMSData.visible := true;
		endif;

		self.ckbCreateHMSData.value := false;					

		// Remarks
		self.txtRemarkGeneral.text := null;
		self.txtRemarksPilot.text := null;
		self.txtRemarksVoyage.text := null;	
		self.txtPreviousNames.text := null;
		
		// Vessel characteristics
		self.optPropFixed.value := false;
		self.optPropVariable.value := (not self.optPropFixed.value);	
		self.ckbBowThrusters.value := false;		
		self.ckbSternThruster.value := false;		
		self.ckbHasRamps.value := false;		
		self.ckbHoldTanks.value := false;
		
		if myCurrentVessel &lt;&gt; null then
		else
			self.loadBerthPreferences(null);		
		endif;		
	else

		// Remarks
		self.txtRemarkGeneral.text := _voyageData.remarksGeneral;
		self.txtRemarksPilot.text := _voyageData.remarksPilotOnly;
		self.txtRemarksVoyage.text := _voyageData.shortComment;	
		self.txtPreviousNames.text := _voyageData.remarksPreviousNames;
		
		// Vessel characteristics
		self.optPropFixed.value := _voyageData.hasFixedProp;
		self.optPropVariable.value := (not self.optPropFixed.value);	
		self.ckbBowThrusters.value := _voyageData.hasBowThrust;		
		self.ckbSternThruster.value := _voyageData.hasSternThrust;		
		self.ckbHasRamps.value := _voyageData.hasRamp;		
		self.ckbHoldTanks.value := _voyageData.hasHoldTanks;

		// The HMS voyage data has already been created
		self.ckbCreateHMSData.enabled := false;
		self.ckbCreateHMSData.value := _voyageData.allVoyageMovements.size() &gt; 0;		// 21/8/19 MAP TFS45296

		self.loadBerthPreferences(_voyageData.allBerthPreferencesArray);
		self.btnResourcesUsed.enabled := true;
	endif;
		
				
	
	// Harbour Details
	self.displayHarbourDetails(_voyageData);

	// Berthage Details
	self.displayBerthageDetails(_voyageData);
			
	// commodity and stevedores
	self.displayCommodityStevedores(_voyageData);

	// Movements/Delays
	self.displayHMSMovements();	
	//self.displayHMSDelay();										// PAR #35397

	// Resources													// PAR #33337
	self.resetLstResourceTables();									// PAR #33337
	self.displayHMSMovementResources(_voyageData);					// PAR #33337
end;</source>
        <access>protected</access>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="displayHarbourDetails" id="01c2c424-4524-4351-a44d-f51781431672">
        <source>displayHarbourDetails(_voyageData : HMS_VoyageData) protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
// 03/07/2014   cnwma1		CCMS SFW1328  HMS Not Available For Entry  
//-----------------------------------------
// 20/05/2016	cnwns1		TFS 488 - Multi Timezone Support
// 23/11/2018	jlgdap1		TFS 4194 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyagevars
vars
	harbour 	: HMS_Harbour;
	pilotExempt : HMS_PilotExemptionCertificate;
	idx			: Integer;						// cnwma1  3/7/2014   CCMS SFW 1328
	pilotExemptLocalTS : TimeStamp;
begin

	// Harbour Details
		
	if (not self.shtHMSHarborData.visible) then
		return;
	endif;
	
	if (_voyageData = null) or (_voyageData &lt;&gt; null and _voyageData.allVoyageMovements.size() = 0) then		// 2/9/19 MAP TFS45926
		
		self.ckbRequiresTow.value := false;		//31 May 2018	NDL	TFS 38905
		self.ckbTaxExemptRes.value := false;	//12 Jun 2018	NDL	TFS 39141	
		self.ckbTaxExemptCargo.value := false;									// TFS 41949
		self.ckbPilotExempt.value := false;	
		self.ckbVisitConfiden.value := false;		
		self.ckbCoastalVessel.value := false;		
		
		self.cmbPilot.listIndex :=  -1;
		self.cmbMaster.listIndex :=  -1;	
		
		self.cmbTidalClassAr.listIndex :=  -1;
		self.cmbTidalClassDpt.listIndex :=  -1;
		self.loadTidalClassTbl();	
		
		self.cmbCatArrive.listIndex := -1;
		self.cmbCatDepart.listIndex := -1;
		self.cmbShipType.listIndex := -1;
		self.cmbCountry.setObject(null);
	
	else

		self.ckbRequiresTow.value := _voyageData.requiresTow;		//31 May 2018	NDL	TFS 38905
		self.ckbTaxExemptRes.value := _voyageData.isZeroRatedTax;	//12 Jun 2018	NDL	TFS 39141
		self.ckbTaxExemptCargo.value := _voyageData.isZeroRatedTaxCargo;		// TFS 41949
		self.ckbPilotExempt.value := _voyageData.isPilotExempt;	
		self.ckbVisitConfiden.value := _voyageData.excludeReport;		
		self.ckbCoastalVessel.value := _voyageData.coastalServiceVessel;	
		
		self.cmbPilot.listIndex :=  self.cmbPilot.findObject(_voyageData.myPilot);
		if self.cmbPilot.listIndex = -1 and _voyageData.myPilot &lt;&gt; null then				// cnwma1  3/7/2014   CCMS SFW 1328
			if cmbPilot.isKindOf(CMUI_ComboBox) then
				cmbPilot.CMUI_ComboBox.addItemObject(_voyageData.myPilot.description, _voyageData.myPilot);
			else	
				idx := cmbPilot.addItem(_voyageData.myPilot.description);
				cmbPilot.itemObject[idx] := _voyageData.myPilot;
			endif;
			self.cmbPilot.listIndex := self.cmbPilot.findObject(_voyageData.myPilot);
		endif;																				// cnwma1  3/7/2014   CCMS SFW 1328
		
		self.cmbMaster.listIndex :=  self.cmbMaster.findObject(_voyageData.myMaster);
		if _voyageData.myMaster &lt;&gt; null then
			harbour := self.myHarbour;	//30 Apr 2012	NDL	Par 29496
			if _voyageData.myMaster.isValidForVessel (null,_voyageData.myVoyage.getMyVessel, _voyageData.myVoyage.arrivedDT.Date) then
				pilotExempt := _voyageData.myMaster.getPECforVessel( harbour, _voyageData.myVoyage.getMyVessel, _voyageData.myVoyage.arrivedDT.Date );
				pilotExemptLocalTS.cnEcSetDateAndTime(pilotExempt.expiryDate,TimeEndOfDay);																			// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.lblMasterStatus.caption := "Exempt Status valid" &amp; CrLf &amp; "Exp Date : " &amp; self.systemToLocalTime(pilotExemptLocalTS).date().format("dd/MM/yyy");// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				
			else
				self.lblMasterStatus.caption := "Exempt Status invalid";
			endif;
		endif;
		
		self.cmbTidalClassAr.listIndex :=  self.cmbTidalClassAr.findObject(_voyageData.myTidalClass);
		self.cmbTidalClassDpt.listIndex :=  self.cmbTidalClassDpt.findObject(_voyageData.myTidalClassDept);
		
		if self.cmbTidalClassAr.listIndex = -1 and _voyageData.myTidalClass &lt;&gt; null then		// cnwma1  3/7/2014   CCMS SFW 1328
			self.cmbTidalClassAr.addItemObject(_voyageData.myTidalClass.description,_voyageData.myTidalClass);
			self.cmbTidalClassAr.listIndex := self.cmbTidalClassAr.findObject(_voyageData.myTidalClass);
		endif;
		
		if self.cmbTidalClassDpt.listIndex = -1 and _voyageData.myTidalClassDept &lt;&gt; null then  // cnwma1  3/7/2014   CCMS SFW 1328
			self.cmbTidalClassDpt.addItemObject(_voyageData.myTidalClassDept.description,_voyageData.myTidalClassDept);
			self.cmbTidalClassDpt.listIndex := self.cmbTidalClassDpt.findObject(_voyageData.myTidalClassDept);
		endif;
		
		self.loadTidalClassTbl();	
		
		self.cmbCatArrive.listIndex :=  self.cmbCatArrive.findObject(_voyageData.myVesselCategoryIn);
		self.cmbCatDepart.listIndex :=  self.cmbCatDepart.findObject(_voyageData.myVesselCategoryOut);
		self.cmbShipType.listIndex :=  self.cmbShipType.findObject(_voyageData.myVesselType);
		self.cmbCountry.setObject(app.myRoot.allCountries[_voyageData.countryCode]);
	
	endif;	

	self.shtHMSHarborData.enabled := true;			
end;</source>
        <access>protected</access>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="displayMultiSelectDetail" id="d89d1100-ce8d-4de7-adc0-91c60fbe89f1">
        <source>displayMultiSelectDetail(_obj : Object) : String protected;
//--------------------------------------------------
// Created:	26 March 2004 By: cnwgd1
//--------------------------------------------------
//call back method used by multi select sheet
vars

begin
	
	if CM_Stevedore.hasInstance(_obj) then
		if self.cmbVessel.isVesselComboByName then
			return self.myAssistant.displayEntryStevedoreByName(_obj.CM_Stevedore);		
		else
			return self.myAssistant.displayEntryStevedore(_obj.CM_Stevedore);
		endif;
	elseif CM_Commodity.hasInstance(_obj) then
		if self.cmbVessel.isVesselComboByName then
			return self.myAssistant.displayEntryCommodityByName(_obj.CM_Commodity);		
		else
			return self.myAssistant.displayEntryCommodity(_obj.CM_Commodity);
		endif;
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayStevedores" id="2c66747b-f131-46f7-94b2-5c5e242f02bc">
        <source>displayStevedores(_voyageData: HMS_VoyageData);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2019	jlgmp6	Initial creation	TFS45926

*/
vars

begin
	
	if _voyageData = null then
		// clear selected
		self.mulStevedoreDisc.setSelected(null);
		self.mulStevedoreLoad.setSelected(null);
	else

		// Stevedores
		self.mulStevedoreDisc.setSelected(_voyageData.allStevedoresDischarge);
		self.mulStevedoreLoad.setSelected(_voyageData.allStevedoresLoad);
	
	endif;
		
end;</source>
        <Parameter name="_voyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="displayTrade" id="213507c6-631b-49cf-8c81-1928553b5961">
        <source>displayTrade(_trade : CM_Trade )protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	allPortsOfCall 		: CM_PortRotationArray;
	allOperators		: CM_OperatorByCodeDict;
	theOperator			: CM_Operator;
begin
	

	
	//if the voyage has port rotations then use voyages
	if  self.myCurrentVoyage &lt;&gt; null and _trade =  null then
		if  self.mode &lt;&gt; self.Mode_Add and self.myCurrentVoyage.allPortRotations.size &gt; 0 then
			allPortsOfCall:=self.myCurrentVoyage.allPortRotations;
		else
			if self.myCurrentVoyage.myTrade &lt;&gt; null then
				allPortsOfCall:=self.myCurrentVoyage.myTrade.allPortRotations;
			endif;
		endif;
		if self.mode &lt;&gt; self.Mode_Add and self.myCurrentVoyage.allOperators.size &gt; 0 then
			allOperators:=self.myCurrentVoyage.allOperators;
		else
			if self.myCurrentVoyage.myTrade &lt;&gt; null then
				allOperators:=self.myCurrentVoyage.myTrade.operators;
			endif;			
		endif;
	else
		if _trade &lt;&gt; null then
			allPortsOfCall:=_trade.allPortRotations;
			allOperators:=_trade.operators;
		endif;
	endif;
	
	
	self.myAssistant.listBoxPortsOfCall(self.lstPortsOfCall,allPortsOfCall);
	// epr par 22194 10/2/10 
	theOperator:= self.cmbVoyOperator.listObject.CM_Operator;
	if theOperator = null and self.myCurrentVoyage &lt;&gt; null then
		theOperator:=self.myCurrentVoyage.myOperator;
	endif;
	if allOperators &lt;&gt; null then
		self.mulOperators.setSelected(allOperators);
		 //epr tfs 39113 8/6/18
		if allOperators.size &gt; 0 then
			self.myAssistant.comboBoxVoyageOperatorWithCol(self.cmbVoyOperator, theOperator, allOperators);
		else
			self.myAssistant.comboBoxOperator(self.cmbVoyOperator, theOperator, null);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trade" type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="displayVoyage" id="6d1bcf31-749c-43e2-8a2d-6a9e0b814ccb">
        <updating/>
        <source>displayVoyage(_lastVisitVoyage : Boolean) updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//
//11 Mar 2013	PJS		PAR # 31232
//-----------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
24/01/2014	cnwdap1	PAR #33337 CCMS PTR 2214 HMS Enhancements
30/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Delays are no longer HMS reliant
05/03/2015	cnwdap1	PAR #35826 CCMS SFW 1410 Added expected arrival/departure date/time
11/05/2016	cnwns1	TFS 488  		Multi Timezone Support
25/01/2017 	cnwns1 	TFS 3214 		LNX - Voyage Operations Enhancements 
18/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
03/05/2017	cnwdap1	TFS 4296 		Voyage External Code not visible 
23/04/2018	jlgdap1	TFS 38215 		PEL1 OOW Confirmation Changes
21/06/2018	jlgrh7	TFS #39105 		LNX - RE: Ticket 38780 - Voyage Definition 'External Code' Value
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
27/02/2019 	jlgzm1 	TFS 43383 		PNL buttons disabled incorrectly
10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
03/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
20/04/2022  navtnr20 TFS 53142 			Cargo Forecast on Voyage &amp; Train
26/12/2022	navvt20	Defect 56046: Incorrect label on Voyage Definition form
18/07/2024 	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
26/11/2024	navdap1	MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
============================================================================*/
vars
	dateTime  : TimeStamp;
	now 	  : TimeStamp;
	tmpStr 	  : String;
	tmpVoyage : CM_Voyage;
begin

	self.btnBayDefinition.enabled 	:= false;	
	self.btnResourcesUsed.enabled 	:= false;
	self.btnROROEnquiry.enabled 	:= false;	//10 Jul 2013	NDL	Par 31965
	self.btnHoldDef.enabled 		:= false;	//10 Jul 2013	NDL	Par 31965
	
	self.btnExchangeSum.enabled 	:= true;  // PAR 35478
	self.btnTranslations.enabled 	:= true;  // PAR 35478
	self.btnCheckList.enabled 		:= true;						// TFS 4793
	self.btnEventTrans.enabled 		:= true;  // PAR 35478
	self.btnEventAlloc.enabled 		:= true;		//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	self.btnShippingLine.enabled 	:= true;  // PAR 35478
	self.btnVesselDef.enabled 		:= true;  // PAR 35478
	
	
	tmpVoyage := self.myCurrentVoyage;
	self.initVoyageAllocationSheet(_lastVisitVoyage);   // PAR 21746
			
	if tmpVoyage = null then
		// clear data
		self.setCaption(app.getErrorString(Voyage_Definition));
		if (not self.isFirstActivateComplete) then
			self.cmbVoyage.setFocus();
		endif;
								
		if self.shtPortsOfCall.visible then
			self.lstPortsOfCall.clear;
			self.mulOperators.clearSelected;
		endif;
		
		// ### JIRA 34233 13MAR 2025 NAVAB1
		self.ckbPrenoteCutoffs.value := self.myTerminal.getConfig(ShipCutoffsForPrenotes).Boolean;
		
		self.dateArrival.text		:=	null;
		self.timeArrival.text		:=	null;
		self.dateDeparture.text		:=	null;
		self.timeDeparture.text		:=	null;
		self.dateArchived.text		:=	null;
		self.timeArchived.text		:=	null;
		
		self.dateExpArrival.text	:= null;							// PAR #35826
		self.timeExpArrival.text	:= null;							// PAR #35826
		self.dateExpDeparture.text	:= null;							// PAR #35826
		self.timeExpDeparture.text	:= null;							// PAR #35826
		
		self.cmbInvoiceStatus.listIndex := -1;
		self.cmbVessel.setObject(null);
		self.cmbAccessType.listIndex := -1;
		if self.grpCellulaVoyage.visible then	
			// PAr # 31232
		//	self.myAssistant.comboBoxVesselStructureType(self.cmbStructureType, CellularStructureStr);
			tblVesselStruct.setValueByName(ETRow_IncludesLOLO,true);
			tblVesselStruct.setValueByName(ETRow_IncludesRORO,false);
			tblVesselStruct.setValueByName(ETRow_IncludesHolds,false);
		else
		//	self.myAssistant.comboBoxVesselStructureType(self.cmbStructureType, StructureTypeNullStr);	
			tblVesselStruct.setValueByName(ETRow_IncludesLOLO,false);
			tblVesselStruct.setValueByName(ETRow_IncludesRORO,false);
			tblVesselStruct.setValueByName(ETRow_IncludesHolds,true);
		endif;
	
	
		// PAR # 31232
		//self.setEnableObjectsForVoyageType(true); // PAR # 31232
		self.handleChangeOfStructure; // 31232
		
		self.txtVoyageCode.text 		:= null;
		self.txtInwardCode.text 		:= null;
		self.txtExternalCode.text 		:= null;						// TFS 4050		
		self.txtVesselName.text 		:= null;
		self.txtVesselCode.text 		:= null;
		self.txtCallSign.text 			:= null;
		self.txtLloydsNum.text 			:= null;	
		self.txtCraneClearanc.text 		:= null;	
		self.txtRemarksVessel.text 		:= null;
		self.picVesselBitmap.picture 	:= null;
		self.txtImasVoyageNum.text 		:= null;		
		self.txtExternalRef.text 		:= null; 	//CCMS 1952 PAR24400 cnwsh3 20/10/2010 Customs Registration Number for SCT 
		self.txtGroupCode.text   		:= null;    //03/06/2020 cnwma1 TFS #49400
		self.txtYearBuild.text			:= null;
		self.cmbVoyOperator.listIndex	:=-1;
		self.cmbTrade.setObject(null);
		self.cmbShippingLine.setObject(null);		
		self.cmbCusresAltVoy.setObject(null);
		
		if self.shtHMSHarborData.visible then
			// licensed for harbour module, populate harbour tables
			self.resetLstResourceTables();								// PAR #33337
			self.displayHMSVoyageData(null);
		endif;
		
		self.loadDimensionsTbl(null, null);	
		self.loadTblWPOpHrs();	//05 Jun 2018	NDL	TFS 39014
		
		self.initRecCutoffsTbl();						// 26/05/2009 cnwar2 CCMS1040/#19796
//		self.tblRecCutoffs.userInputEnabled := false;	// 26/05/2009 cnwar2 CCMS1040/#19796
		self.btnAddOperator.enabled 		:= false;	// 26/05/2009 cnwar2 CCMS1040/#19796
		
		self.pickColour.setColor(14671839);	//27 May 2014	NDL	Par 34218
		
		self.chkUseVoyageAllo.value := true;  //cnwrd1 par 34233		
		self.btnOOWConfirm.enabled 	:= true;  // TFS 38215		
		self.chkIsBarge.value 		:= false; // jlgka1 TFS 37102
	else
		tmpStr := tmpVoyage.description &amp; ' - (' &amp; tmpVoyage.code &amp; ')';
		self.setCaption(tmpStr &amp; ' ' &amp; app.getErrorString(Voyage_Definition));			
		
		if self.mode = self.Mode_View
		or (not self.isFirstActivateComplete) then
			// load form with existing ship details.
			if (not self.viewModeOnly) then
				self.btnDeleteTV.enabled := app.myCurrentUserCan(self.myTerminal, PmShipVoyageEnquiryDel);	//26 Aug 2020	NDL	TFS 49966				
			endif;
		
			dateTime := tmpVoyage.arrivedDT;
			if dateTime.isValid then
				dateTime := self.systemToLocalTime(dateTime);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.dateArrival.setDate(dateTime.date());
				self.timeArrival.setTime(dateTime.time());
			else
				self.dateArrival.text := null;
				self.timeArrival.text := null;
			endif;
	
			dateTime := tmpVoyage.departedDT;
			if dateTime.isValid then		
				dateTime := self.systemToLocalTime(dateTime);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.dateDeparture.setDate(dateTime.date());
				self.timeDeparture.setTime(dateTime.time());
			else
				self.dateDeparture.text := null;
				self.timeDeparture.text := null;
			endif;
			
			dateTime := tmpVoyage.archivedDT;
			if dateTime.isValid then				
				dateTime := self.systemToLocalTime(dateTime);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.dateArchived.setDate(dateTime.date());
				self.timeArchived.setTime(dateTime.time());	
			else
				self.dateArchived.text := null;
				self.timeArchived.text := null;
			endif;
			
		endif;
		
		if self.mode = self.Mode_Add and _lastVisitVoyage and tmpVoyage.hasDeparted then	//12 Nov 2020	NDL	TFS 50339 - Doesn't make sense to use values for dates from a previous voyage
			self.dateExpArrival.text := null;
			self.timeExpArrival.text := null;
			self.dateExpDeparture.text := null;
			self.timeExpDeparture.text := null;
		else
			dateTime := tmpVoyage.estimatedArrivalDT;						// PAR #35826
			if dateTime.isValid then 										// PAR #35826
				dateTime := self.systemToLocalTime(dateTime);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.dateExpArrival.setDate(dateTime.date);					// PAR #35826
				self.timeExpArrival.setTime(dateTime.time);					// PAR #35826
			else															// PAR #35826
				self.dateExpArrival.text := null;							// PAR #35826
				self.timeExpArrival.text := null;							// PAR #35826
			endif;															// PAR #35826
			dateTime := tmpVoyage.estimatedDepartureDT;						// PAR #35826
			if dateTime.isValid then 										// PAR #35826
				dateTime := self.systemToLocalTime(dateTime);// 11 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.dateExpDeparture.setDate(dateTime.date);				// PAR #35826
				self.timeExpDeparture.setTime(dateTime.time);				// PAR #35826
			else															// PAR #35826
				self.dateExpDeparture.text := null;							// PAR #35826
				self.timeExpDeparture.text := null;							// PAR #35826
			endif;															// PAR #35826
		endif;

		// PAr # 31232
		tblVesselStruct.setValueByName(ETRow_IncludesLOLO,tmpVoyage.structureIncludesLOLO);
		tblVesselStruct.setValueByName(ETRow_IncludesRORO,tmpVoyage.structureIncludesRORO);
		tblVesselStruct.setValueByName(ETRow_IncludesHolds,tmpVoyage.structureIncludesHolds);
		
		// dont allow user to add in a structure that is not available on the vessel
		//epr par 35059 21/10/14 use myCurrentVessel as the voyage.myVessel may be null
		if not tmpVoyage.structureIncludesLOLO and  ((self.myCurrentVessel = null)  or (not self.myCurrentVessel.structureIncludesLOLO))  then
			tblVesselStruct.hideRowByName(ETRow_IncludesLOLO,false);
		else
			tblVesselStruct.showRowByName(ETRow_IncludesLOLO,false); //epr TFS 2237 3/8/16
		endif;
		
		if not tmpVoyage.structureIncludesRORO and ((self.myCurrentVessel = null)  or (not self.myCurrentVessel.structureIncludesRORO)) then
			tblVesselStruct.hideRowByName(ETRow_IncludesRORO,false);
		else
			tblVesselStruct.showRowByName(ETRow_IncludesRORO,false);
		endif;
		
		if not tmpVoyage.structureIncludesHolds and ((self.myCurrentVessel = null)  or (not self.myCurrentVessel.structureIncludesHolds)) then
			tblVesselStruct.hideRowByName(ETRow_IncludesHolds,false);
		else
			tblVesselStruct.showRowByName(ETRow_IncludesHolds,false);
		endif;
			
		tblVesselStruct.resetSize();
		
		// if table has nothing to select then hide it and show the label
		
		if tblVesselStruct.getFirstVisibleRow = 0 then
			tblVesselStruct.visible := false;
			//lblStructureNone.visible := true; // 26 Dec 2022 navvt20 TFS 56046
		else
			tblVesselStruct.visible := true;
			//lblStructureNone.visible := false; // 26 Dec 2022 navvt20 TFS 56046
		endif;
		
				
		if tmpVoyage.structureIncludesLOLO or tmpVoyage.structureIncludesRORO  then
			if self.mode = self.Mode_View then
				if tmpVoyage.archived then
					self.btnBayDefinition.enabled := false;
				else
					self.btnBayDefinition.enabled := true;
					self.btnROROEnquiry.enabled := tmpVoyage.structureIncludesRORO; //10 Jul 2013	NDL	Par 31965
				endif;
			endif;
		endif;
		
		//10 Jul 2013	NDL	Par 31965
		if tmpVoyage.myGeneralCargoVoyage &lt;&gt; null then
			self.btnHoldDef.enabled := not tmpVoyage.archived;	
		endif;
		// 31322
		//self.setEnableObjectsForVoyageType(true);	
		self.handleChangeOfStructure;	// 31232  

		self.cmbVessel.setObject(tmpVoyage.getMyVessel());

		self.cmbAccessType.listIndex := self.cmbAccessType.findString(1, app.vesselAccessTypeEnumToStr(tmpVoyage.vesselType));	
		
		self.txtVoyageCode.text 		:= tmpVoyage.code;
		// start navlw1 #63839
		//if tmpVoyage.isAutomaticProcess() then									// MTN-33516
		if tmpVoyage.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then	// MTN-33516
			self.txtInwardCode.text 	:= tmpVoyage.inwardCodeAuto;
			if not _lastVisitVoyage then
				self.txtExternalCode.text := tmpVoyage.voyageCodeExternalAuto;			
			endif;
		else
			self.txtInwardCode.text 	:= tmpVoyage.inwardCode;
			if not _lastVisitVoyage then											//+TFS39105 Not to display external code for when create a new voyage
				self.txtExternalCode.text := tmpVoyage.voyageCodeExternal;			// TFS 4296
			endif;
		endif;
		// end navlw1 #63839
		self.txtVesselName.text 		:= tmpVoyage.vesselName;
		self.txtVesselCode.text 		:= tmpVoyage.vesselCode;
		self.txtCallSign.text 			:= tmpVoyage.callSign;
		self.txtLloydsNum.text 			:= tmpVoyage.lloydsNumber.stripAlpha;	//Bug 46446
		self.txtCraneClearanc.text 		:= tmpVoyage.craneClearance.asStringJMT;	
		self.txtRemarksVessel.text 		:= tmpVoyage.remarks;
		self.picVesselBitmap.picture 	:= tmpVoyage.bitmap;
		self.txtExternalRef.text 		:= tmpVoyage.externalRef; 				//CCMS 1952 PAR24400 cnwsh3 20/10/2010 Customs Registration Number for SCT 
		self.txtGroupCode.text          := tmpVoyage.voyageGroupCode;           //03/06/2020 cnwma1 Tfs #49400
		self.txtYearBuild.text			:= tmpVoyage.yearOfBuild.asStringJMT;		
		self.chkIsBarge.value 			:= tmpVoyage.isBarge; 					// jlgka1 TFS 37102		
		self.chkUseVoyageAllo.value 	:= tmpVoyage.useVoyageAllocations; 		//cnwrd1 par 34233
		self.cmbInvoiceStatus.listIndex := self.cmbInvoiceStatus.findStringExact(1, app.voyageInvStatusEnumToString(self.myCurrentVoyage.statusInvoice));			
		
		self.cmbShippingLine.setObject(tmpVoyage.myShippingLine);		
		self.cmbCusresAltVoy.setObject(tmpVoyage.myCusresAltVoyage);
	
		if self.myHarbour &lt;&gt; null then
			self.txtImasVoyageNum.text := self.myHarbour.getVesselVisitCountStr(tmpVoyage.vesselCode, tmpVoyage.arrivedDT);    
		else
			self.txtImasVoyageNum.text := self.myTerminal.getVesselVisitCount(tmpVoyage.vesselCode, null).asStringJMT;    			
		endif;
		
		if self.shtHMSHarborData.visible
		and (self.mode = self.Mode_View
		or (not self.isFirstActivateComplete)) then
			// licensed for harbour module, populate harbour tables
			self.displayHMSVoyageData(tmpVoyage.myHMSVoyageData);
		endif;		
		self.displayHMSDelay();							// PAR #35397
		self.loadDimensionsTbl(tmpVoyage, null);
		self.loadTblWPOpHrs();	//05 Jun 2018	NDL	TFS 39014
		self.displayStevedores(tmpVoyage.myHMSVoyageData);		// 2/9/19 MAP TFS45926
		
		 if _lastVisitVoyage = false then  // ### JIRA 34525 14APR2025 NAVAB1
			self.ckbOverrideDef.value 			 := tmpVoyage.overrideDefaults;		// 26/05/2009 cnwar2 CCMS1040/#19796
		endif;
			
//		self.tblRecCutoffs.userInputEnabled  := self.ckbOverrideDef.value;		// 26/05/2009 cnwar2 CCMS1040/#19796
		
		 if _lastVisitVoyage = false then  // ### JIRA 34525 14APR2025 NAVAB1
			self.ckbIgnoreCutOff.value			 := tmpVoyage.ignoreCutoffs;		//31.Aug.2023 navsp1 TFS 57809
		endif;
		self.pickColour.setColor( tmpVoyage.colour );	//27 May 2014	NDL	Par 34218
		
//		self.cmbPaymentType.listIndex := self.cmbPaymentType.itemDataIndex(tmpVoyage.paymentType);	// 26/6/18 MAP TFS39250
		self.myAssistant.comboBoxHMSPaymentType(self.cmbPaymentType, tmpVoyage.paymentType);	//20 Apr 2020	NDL	TFS 49143/48653
//		self.btnOOWConfirm.enabled := tmpVoyage.myVoyageProcess = null or 							// TFS 38215
//										tmpVoyage.myVoyageProcess.showOOWConfirmation(tmpVoyage);	// TFS 38215
		self.btnOOWConfirm.enabled 	  := tmpVoyage.myVoyageProcess &lt;&gt; null and tmpVoyage.myVoyageProcess.showOOWConfirmation(tmpVoyage);	//15 Jun 2018	NDL	TFS 39167
		
		//self.enableAllControls(self.mode &lt;&gt; self.Mode_View); //tfs43383

	endif;

	if self.grpCellulaVoyage.visible then	
		// licensed for cargo module, populate cargo tables
		self.displayCargoVoyageDetails(tmpVoyage);
		self.shtVesselStruct.enabled:=true;
	//	self.grpExtRamps.visible:=self.cmbStructureType.text = CellularStructureROROStr ;  // 31232
		self.grpExtRamps.visible := tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean;  // PAr # 31232
	
	else
		self.shtVesselStruct.enabled:=false;
	endif;
	if tmpVoyage &lt;&gt; null 
	and _lastVisitVoyage = false then  // ### JIRA 34525 14APR2025 NAVAB1
		// ### JIRA 34233 06MAR 2025 NAVAB1
		//self.loadVoyageCutoffsTbl(tmpVoyage);	
		self.createProxyCutoffs(tmpVoyage);
		self.loadVoyageCutoffsToTable(tmpVoyage);	
		
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then			
		self.btnCargoForecast.enabled := true;		//20-Apr-2022	TFS 53142
	endif;											
	
	self.loadTankTable();
	self.loadSectionsTable();
	self.loadExternalRampTable();
	
	self.displayVoyageFiles();

	// ### JIRA 34233 06MAR 2025 NAVAB1
	self.frmCutoffDataEntryPN.visible := self.ckbPrenoteCutoffs.value; 
	self.frmCutoffDataEntry.enabled := self.ckbOverrideDef.value;

	
	self.setNavigatorHeading(self.caption);
		
end;</source>
        <access>protected</access>
        <Parameter name="_lastVisitVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayVoyageFileSelected" id="8989e7dc-eb31-4437-a6b3-cca2c86adb98">
        <source>displayVoyageFileSelected()protected;
//--------------------------------------------------
// Created:	December 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	self.btnDocumentDelet.enabled := false;
	self.btnDocumentLoad.enabled := true;		
	self.btnDocumentView.enabled := false;
	
	if self.tblHDocuments.row &lt;= self.tblHDocuments.fixedRows then
		return;
	endif;

	if self.mode = self.Mode_View then
		self.btnDocumentDelet.enabled := true;
		self.btnDocumentLoad.enabled := true;		
		self.btnDocumentView.enabled := true;
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVoyageFiles" id="ffd24ab1-e176-4e24-b118-ca39af5a3713">
        <subschemaFinal/>
        <updating/>
        <source>displayVoyageFiles() subschemaFinal, updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 January 2007
//
//----------------------------------------------------------------------

vars
	tblDocument : CM_DataTable;
	rowArray : EntTableRowArray;
	file : CM_FileData;
	voyage : CM_Voyage;
begin

	//Check if sheet is visible
	tblDocument := self.tblHDocuments;
	//Using the current voyage
	voyage := self.myCurrentVoyage;
	tblDocument.clearAllData();//cnwaer 20.02.07
	if voyage = null then
		return;
	endif;
	
	//check for allFiles
	tblDocument.clearAllData();
	
	rowArray := tblDocument.allTblDataEntRows;
	
	foreach file in voyage.allFiles do
		//Add each file to the table by using the tblDocument.addObjectToTable.
		tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));
	endforeach;
	
	tblDocument.colourRows(self.colorRow1, self.colorRow2);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddOperatorColumn" id="e09fd35c-da8f-40ba-90fc-5375e099e386">
        <updating/>
        <source>doAddOperatorColumn(_operator : CM_Operator) updating, protected;

/*
Date		Who		Reason
27 May 2009	cnwar2	Initial creation
march 2012	cnwcs5	par 29158 - EDI cutoffs
*/
vars
	table			: CM_DataTable;
	idx, saveRow	: Integer;
	opCode,
	lastOp			: String;
	sortedList		: CM_RecCutoffDefsBySortKey;
	recCutoffDef	: CM_ReceivalCutoffTermDef;
	recCutoffOp : CM_ReceivalCutoffVoyage;
begin

	 
	create sortedList transient; // TFS 3912
	
	foreach recCutoffDef in self.myTerminal.allReceivalCutoffDefs where recCutoffDef.isAvailableForEntry do // TFS 3912
		sortedList.add(recCutoffDef); // TFS 3912
	endforeach; // TFS 3912


	if sortedList.isEmpty() then  // TFS 3912 +
		return;  // TFS 3912 +
	endif;

	table := self.tblVoyageCutoffs;
	table.visible := true;
	
	if not self.hasOperatorColumn then
		hasOperatorColumn := true;
	
		table.insertColumn(TblRecCutoffsCol_EarliestHrs);
		table.accessMode 	:= table.AccessMode_Column;
		table.column 		:= TblRecCutoffsCol_Code;
		table.inputType 	:= table.InputType_None;
		table.accessCell(1, TblRecCutoffsCol_Code + 1).text := app.getErrorString(Operator); // ### JIRA 34233 12MAR 2025 NAVAB1
	endif;
	
	//add new rows to table for specified operator
	if _operator &lt;&gt; null then
		foreach idx in table.fixedRows + 1 to table.rows do
			if table.accessCell(idx, TblRecCutoffsCol_Code + 1).text = _operator.code then
				return;	// operator already added
			endif;
		endforeach;
		
		idx := table.fixedRows + 1;
		
		while idx &lt;= table.rows do
			opCode := table.accessCell(idx, TblRecCutoffsCol_Code + 1).text;
			
			if opCode &lt;&gt; null and _operator.code &lt; opCode then
				break;	// insert rows here
			endif;
			idx := idx + 1;
		endwhile;
		
		saveRow := idx;
		
		/* TFS 3912 moved up - if there are no cut offs then do nothing.
		create sortedList transient;
		
		foreach recCutoffDef in self.myTerminal.allReceivalCutoffDefs where recCutoffDef.isAvailableForEntry do
			sortedList.add(recCutoffDef);
		endforeach;
		*/
	
		
		foreach recCutoffDef in sortedList do
		
			// add a row to put the defaults in
			table.addItemAt (null, idx);	
			
			// get operator defaults if they exist
			// ### JIRA 34233 06MAR 2025 NAVAB1
			self.getRecCutoffDefaultsPN (recCutoffDef, _operator, table, idx, self.TblRecCutoffsCol_EarliestHrs + hasOperatorColumn.Integer);	// par 29158 - Feb2012
							
			// fill in operator here
			table.accessCell(idx, self.TblRecCutoffsCol_Code + 1).fontBold := true;
			table.accessedCell.text := _operator.code;
			
			idx := idx + 1;
		endforeach;
		
		
		table.row 		:= saveRow;
		table.column	:= self.TblRecCutoffsCol_EarliestHrs + 1;
	endif;
	
	// reset colours
	lastOp := null;
	
	foreach idx in table.fixedRows + 1 to table.rows do
		//table.accessRow(idx).backColor := self.colorRow1;
		opCode := table.accessCell(idx, TblRecCutoffsCol_Code + 1).text;
		
		if opCode &lt;&gt; lastOp then
			if table.accessRow(idx-1).backColor = self.colorRow1 then
				table.accessRow(idx).backColor := self.colorRow2;
			else
				table.accessRow(idx).backColor := self.colorRow1;
			endif;
			
			lastOp := opCode;
			
		elseif idx &gt; table.fixedRows + 1 then
			table.accessRow(idx).backColor := table.accessRow(idx-1).backColor;
		endif;
	endforeach;
	
//	self.doResizeShtCutoffs(self.shtCutoffs);

epilog
	delete sortedList;
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="0c7c1053-88c3-45eb-a704-b6b8a07cadae">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVoyage : CM_Voyage;
begin
	// ### JIRA 34553 08APR2025 NAVAB1
	self.myProxyCutoff := null;

	self.allProxies.purge();
	self.allProxyCutoffs.purge(); // ### JIRA 34233 11MAR 2025 NAVAB1
	
	self.setToViewMode();

	// ### JIRA 34553 08APR2025 NAVAB1
	self.hideShowCutoffsFrame(false); 
	app.doWindowEvents(0); // the screen update for hiding the frame, if it is open,  was a bit jirky so this smooths it out
	
	if self.cmbVoyage.listObject &lt;&gt; null then
		tmpVoyage := self.cmbVoyage.listObject.CM_Voyage;
	elseif self.cmbVoyage.myObject &lt;&gt; null then
		tmpVoyage := self.cmbVoyage.myObject.CM_Voyage;
	elseif global.isValidObject(self.myLastSelectedVoyage) then
		tmpVoyage := self.myLastSelectedVoyage;
		self.cmbVoyage.setObject(self.myLastSelectedVoyage);
	endif;
	
	if (not global.isValidObject(tmpVoyage)) then
		tmpVoyage := null;
		self.cmbVoyage.clear();
		self.cmbVoyage.initialise(false);		
	endif;
	
	self.setMyCurrentVoyage(tmpVoyage);
	
//	self.doResizeShtCutoffs(self.shtCutoffs);
//	self.tblRecCutoffs.userInputEnabled := false;
	
	//cnwjo3 CCMS 1028
	self.initVoyageAllocationSheet(false);
	
epilog
	self.myLastSelectedVoyage := null;			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="aab7c070-ee24-4c9d-a327-1dba3420719a">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
// 29/09/2022	jlizm1	TFS 54702 CUX MAFI Auto Queueing
vars
	conflictManager : CMIF_HMS_ConflictsManager;
	voyageDeparted	: Boolean;
	priorToSaveDeparted : Boolean;
	oldStatus		: Integer;
	
begin

//	self.changeRecRestrictTblCell();	//20 Apr 2012	NDL	Par 29452 - lost focus on table is too late
	
	priorToSaveDeparted := self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.status = Voyage_Status_Departed; // PAR 35397
	if self.myCurrentVoyage &lt;&gt; null then
		oldStatus := self.myCurrentVoyage.status;
	endif;
	
	// NOTE voyageDeparted and conflictManager are OUTPUT parameters
	if self.doSave(voyageDeparted, conflictManager) then
	
		// reset form back to viewMode
		self.doBaseFormCancel();
		
		/*  // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
		if self.myTerminal.getConfig(QueueExpMAFIClearStops).Boolean then	// TFS 54702
			if self.myCurrentVoyage &lt;&gt; null then
				if (self.myCurrentVoyage.status = Voyage_Status_Arrived or self.myCurrentVoyage.status = Voyage_Status_Loading)
				and not (oldStatus = Voyage_Status_Arrived or oldStatus = Voyage_Status_Loading) then
				
					if self.myCurrentVoyage.hasExportMAFIClearedOfStops() then
						if app.msgBox(app.getErrorString(Queue_exp_mafi_ship_block), app.getErrorString(Queue), MsgBox_OK_Cancel) = MsgBox_Return_OK then
							self.doQueueOnsiteExpMAFIToVoyage();
						endif;
					endif;
					
				endif;
			endif;
		endif;
		
		if self.myTerminal.getConfig(QueueGroundExportRORO).Boolean then	// TFS 54702
			if self.myCurrentVoyage &lt;&gt; null then
				if (self.myCurrentVoyage.status = Voyage_Status_Arrived or self.myCurrentVoyage.status = Voyage_Status_Loading)
				and not (oldStatus = Voyage_Status_Arrived or oldStatus = Voyage_Status_Loading) then
				
					if self.myCurrentVoyage.hasGroundPlacedExpROROCont() then
						if app.msgBox(app.getErrorString(Queue_grnd_exp_roro_cont), app.getErrorString(Queue), MsgBox_OK_Cancel) = MsgBox_Return_OK then
							self.doQueueOnsiteGroundExpROROCont();
						endif;
					endif;
					
				endif;
			endif;
		endif;
		*/
		
		
		// PAR 26891 - moved below from doSave method so is done after self.mode has been reset
		if voyageDeparted then
			if self.myTerminal.getConfig(ShipDelBookRefsOnDepart).Boolean then // PAR 12791
				// CCMS 1076 and PAR 7309 RS 15/1/2004
				app.myTrxDA.trxDeleteVoyageBookingRefs(self.myCurrentVoyage, app.myPassport);
				
				if (not app.myPassport.trxCompletedOK) then
					//app.showErrorWarningDialog('Ship Departed deleting Booking Refs', app.myPassport, ErrWarnMode_Update);
					//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					
					// PAR 26891 - changed to be a message box as user cannot do anything about from here, so
					// just advise them to use Bookings screen to delete manually
					app.msgBox(app.getErrorString1(NotAllVoyBookingsDeleted, self.myCurrentVoyage.code),
								app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				
				endif;
			endif;
			
		endif;
	endif;
	
	 // PAR 35397 - status has been changed to departed
	if not priorToSaveDeparted
	and self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.status = Voyage_Status_Departed 
	and  self.myTerminal.getConfig(ShipCloseBookVoyDepart).Boolean then
		if app.msgBox("The status has changed to departed. Do you want to close all bookings related to this voyage?", "Close Booking", MsgBox_OK_Cancel) = MsgBox_Return_OK then
			self.doSaveBookingRefStatus();
		endif;
	endif;


		
	// PAR 26891 - moved below from doSave method so is done after self.mode has been reset
	if conflictManager &lt;&gt; null then
		if (not conflictManager.allCMIFConflicts.isEmpty) then
			//if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
			if app.msgBox(app.getErrorString(ViewVoyagesWithConflictsQuest), app.getErrorString(View_conflict_report), MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
				self.myAssistant.showConflictsReport(conflictManager, self.myTerminal, self.myTerminal.myHarbour);
			else
				delete conflictManager;			
			endif;
		else
			delete conflictManager;
		endif;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnCrgFcstDef" id="1082c42a-fc87-4a6d-a075-70174f4f09ee">
        <source>doBtnCrgFcstDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	form : CMUI_CargoForecastForm;
begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(PleaseSelectAVoyage) ,app.getErrorString(PleaseSelectAVoyage), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	form := app.loadForm(CMUI_CargoForecastForm, SHP_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoForecastForm;		//13.05.2022 navsrk	53142
	if form = null then
		return;		//13.05.2022 navsrk	53142
	endif;
	if form &lt;&gt; null then
		form.setMyObject(self.myCurrentVoyage);
		form.setParentForm(self);
		form.show();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDocumentDeleteClick" id="649b9c0a-19be-4c54-9994-f03f850c17eb">
        <updating/>
        <source>doBtnDocumentDeleteClick() updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	fileData: CM_FileData;
begin
	
	//beginTransaction;
	//delete self.tblHDocuments.accessRow(self.tblHDocuments.row).itemObject.CM_FileDataVoyage;
	//commitTransaction;
	// or.....
	
	if not app.myCurrentUserCan(self.myTerminal, PmShipFileLoadMaint) then
		app.msgBox(app.getErrorString(NoPermission2), "Voyage File Delete", MsgBox_OK_Only);
		return ;
	endif;
	
	fileData:=self.tblHDocuments.accessRow(self.tblHDocuments.row).itemObject.CM_FileData;
	app.myTrxDA.trxDeleteFile(self.myCurrentVoyage, fileData, app.myPassport);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDocumentLoadClick" id="3d8a3f94-5731-470b-80fe-6784bff72834">
        <updating/>
        <source>doBtnDocumentLoadClick() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 January 2007
//
//----------------------------------------------------------------------
// Changed By	On			Reason
// ----------	--------	--------------------------------------------
// 25/07/2013	cnwdap1		PAR #31585 Check permission before allowing user to add a document
vars
	loadForm: CMUI_FileLoad;
	saveRow	: Integer;
begin
	if self.myCurrentVoyage =  null then
		return;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmShipFileLoadMaint) then									// PAR #31585
		app.msgBox(app.getErrorString(NoPermission2), "Voyage File Add", MsgBox_OK_Only);	// PAR #31585
		return ;																							// PAR #31585
	endif;																									// PAR #31585
	
	
	saveRow := self.tblHDocuments.row;
	
	loadForm := app.loadForm(CMUI_FileLoad, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_FileLoad;
	if loadForm = null then
		return;
	else
		loadForm.init(self.myCurrentVoyage, self.myCurrentVoyage.code);
		loadForm.showModal();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDocumentViewClick" id="2a141633-7fab-4adc-ac4b-c042d5c9f9dd">
        <updating/>
        <source>doBtnDocumentViewClick()  updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyage :CM_Voyage;
	fileDataVoyage :CM_FileData;
begin
	if not app.myCurrentUserCan(self.myTerminal, PmShipFileLoadView) then
		app.msgBox(app.getErrorString(NoPermission2), "Voyage File View", MsgBox_OK_Only);
		return ;
	endif;
	
	fileDataVoyage := self.tblHDocuments.accessRow(self.tblHDocuments.row).itemObject.CM_FileData;
	
	if fileDataVoyage &lt;&gt; null then
		fileDataVoyage.viewFile(fileDataVoyage.fileName);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEdit" id="b43eafd0-34ff-4069-91a9-498cbb16dffa">
        <updating/>
        <source>doBtnEdit() : Boolean updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentVoyage = null then
		app.msgBox('Cannot perform edit as there is no voyage selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
		self.cmbVoyage.setFocus();
		return false;
	endif;
	
	if self.myCurrentVoyage.isVoyageInlandTerminal() then
		app.msgBox('This voyage has been created from terminal (' &amp; self.myCurrentVoyage.CM_VoyageInlandTerminal.myVoyage.myTerminal.name &amp;
					').  You cannot update this voyage from this terminal.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
		self.cmbVoyage.setFocus();
		return false;
	endif;

	self.mode := self.Mode_Update;
		
	self.setControlsForAddEdit(false);
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnEventAlloc" id="aca2fb70-c493-4533-8ac9-65e0ea25d4b3">
        <source>doBtnEventAlloc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2017	cnwns1	Initial creation

*/

vars

	form : Form;
	
begin
	
	form := app.loadForm(SHP_EventAllocationForm, CMUI_Assistant, false, false, false, self.myTerminal, null);
	if form = null or self.myCurrentVoyage = null then
		return;
	endif;	
	form.SHP_EventAllocationForm.setVoyage(self.myCurrentVoyage);
	form.SHP_EventAllocationForm.setMyTerminal(self.myTerminal);

	form.show;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHoldDef" id="d919646f-97aa-490c-ad43-b16320e9a8e8">
        <source>doBtnHoldDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	form : SHP_GCHoldLocationVoyDefnForm;

begin

	if self.myCurrentVoyage = null or self.myCurrentVoyage.myGeneralCargoVoyage = null then
		return;
	endif;

	form := app.getForm(SHP_GCHoldLocationVoyDefnForm.name).SHP_GCHoldLocationVoyDefnForm;
	if form = null then
		form := app.loadForm(SHP_GCHoldLocationVoyDefnForm, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_GCHoldLocationVoyDefnForm;
	endif;
	if form &lt;&gt; null then
		form.setMyVoyage( self.myCurrentVoyage );
		form.setParentForm(self);
		form.showModal;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnNew" id="505bbfed-7695-4a55-9465-de8b28c60408">
        <updating/>
        <source>doBtnNew()updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
// Date			Who		Reason
// 04/11/2019	jlgmd1	TFS 47321 - Changed the voyage defs form buttons to clear the form in a consistent way
vars
	tmpTopSheet	: Sheet;
	
begin
	// Clear the form first
	self.setMyCurrentVoyage(null);
	
	// Then change into Add/Edit mode
	self.mode := self.Mode_Add;

	tmpTopSheet := self.fldMain.topSheet;
	//self.cmbVoyage.setObject(null);
	//self.myCurrentVoyage := null;
	//self.myCopyGCStruct := null;	//10 Jul 2013	NDL	Par 31965
	//self.myCurrentVoyageData := null;
	//self.myCurrentVessel := null;
	self.voyageNumber := 0;

	//self.displayVoyage(false); //&lt;&lt;-- clears the form					

	self.setControlsForAddEdit(false); //&lt;&lt;-- also sets the defaults

	self.btnShippingAgent.enabled := self.cmbShippingAgent.listObject &lt;&gt; null;		
	self.btnShippingLine.enabled := self.cmbShippingLine.listObject &lt;&gt; null;				
	
	self.cmbVessel.setFocus();
	self.fldMain.topSheet := self.shtVoyageDetails;		

	if tmpTopSheet &lt;&gt; self.shtVoyageDetails then
		self.doResizeShtVoyageDetails(self.shtVoyageDetails);
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVAAdd1" id="57f92bbc-184e-417b-a532-c48a732ff1c2">
        <source>doBtnVAAdd1();
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
// Purpose:		add something
//
vars
	item : String;
	ct : CM_YACriteriaType;
begin
	if self.lstAvailable.listIndex &gt; 0 then
		item := self.lstAvailable.itemText[self.lstAvailable.listIndex];
		self.lstAvailable.removeItem(self.lstAvailable.listIndex);
		self.allAvailable.remove(item);
		self.allSelected.add(item);
		self.lstSelected.addItem(item);
	endif;
	
	foreach ct in self.allCriteriaTypesForVoyage where ct.description = item do
		if not ct.isPrimitiveValue() then
			self.cmbDefaultColour.addItem(item);	
		endif;
		break;
	endforeach;
	//self.setVADefaultColourCombo(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVAAddAll" id="176fddf2-dbc8-40d8-a719-7e6242d03c7e">
        <source>doBtnVAAddAll();
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
// Purpose:		add all
//
vars
	s 		: String;
	myText 	: String;
	indx 	: Integer;
	ct 		: CM_YACriteriaType;
begin
	foreach s in self.allAvailable do
		self.allSelected.add(s);
		self.lstSelected.addItem(s);
	endforeach;
	
	self.allAvailable.clear();
	self.lstAvailable.clear();
	
	
	myText := self.cmbDefaultColour.text;	
	self.cmbDefaultColour.clear();
	foreach ct in self.allCriteriaTypesForVoyage do
		if not ct.isPrimitiveValue() then
			self.cmbDefaultColour.addItem(ct.description);	
		endif;		
	endforeach;	
	indx := self.cmbDefaultColour.findString(1,myText);
	if indx &gt; 0 then
		self.cmbDefaultColour.listIndex := indx;
	endif;
	
	//self.setVADefaultColourCombo(false);	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVAMoveDown" id="b336bcff-bf77-4794-bd65-3d9011068a9d">
        <source>doBtnVAMoveDown();
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
// Purpose:		move down
//
vars
	s, item1, item2 : String;
	indx, index1, index2 : Integer;
begin
	if self.lstSelected.listIndex &gt; 0 then
		index1 := self.lstSelected.listIndex;
		index2 := self.lstSelected.listIndex+1;
		
		if index2 &gt; self.lstSelected.listCount() then
			return;
		endif;
		
		item1 := self.lstSelected.itemText[index1];
		item2 := self.lstSelected.itemText[index2];
		self.lstSelected.addItemAt(item2,index1);
		self.lstSelected.addItemAt(item1,index2);
		self.lstSelected.removeItem(index1+2);
		self.lstSelected.removeItem(index1+2);
		self.lstSelected.listIndex := index2;
	endif;

	//reset allSelected string array
	self.allSelected.clear();
	foreach indx in 1 to self.lstSelected.listCount do
		self.allSelected.add(self.lstSelected.itemText[indx]);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVAMoveUp" id="b0813e57-f1c1-4807-846a-7cd2e692facc">
        <source>doBtnVAMoveUp();
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
// Purpose:		move up
//
vars
	item1, item2 : String;
	indx, index1, index2 : Integer;
begin
	if self.lstSelected.listIndex &gt; 0 then
		index1 := self.lstSelected.listIndex;
		index2 := self.lstSelected.listIndex-1;
		
		if index2 &lt;= 0 then
			return;
		endif;
		
		item1 := self.lstSelected.itemText[index1];
		item2 := self.lstSelected.itemText[index2];
		self.lstSelected.addItemAt(item2,index1);
		self.lstSelected.addItemAt(item1,index2);
		self.lstSelected.removeItem(index2+1);
		self.lstSelected.removeItem(index1+1);
		self.lstSelected.listIndex := index2;
	endif;

	//reset allSelected string array
	self.allSelected.clear();
	foreach indx in 1 to self.lstSelected.listCount do
		self.allSelected.add(self.lstSelected.itemText[indx]);
	endforeach;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVARemove1" id="4a53435a-3b2a-49a5-82bc-cc02e99b55fa">
        <source>doBtnVARemove1();
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
// Purpose:		remove 1
//
vars
	item 	: String;
	ct 		: CM_YACriteriaType;
	idx 	: Integer;
begin
	if self.lstSelected.listIndex &gt; 0 then
		item := self.lstSelected.itemText[self.lstSelected.listIndex];
		self.lstSelected.removeItem(self.lstSelected.listIndex);
		self.allSelected.remove(item);
		self.allAvailable.add(item);
		self.lstAvailable.addItem(item);
	endif;
	
	foreach ct in self.allCriteriaTypesForVoyage where ct.description = item do
		if not ct.isPrimitiveValue() then
			idx := self.cmbDefaultColour.findString(1,item);
			if idx &lt;&gt; 0 then
				self.cmbDefaultColour.removeItem(idx);	
			endif;
		endif;
		break;
	endforeach;
	
	//self.setVADefaultColourCombo(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVARemoveAll" id="ebfa2915-5736-4936-bfb7-8cc31d5ce2fb">
        <source>doBtnVARemoveAll();
// --------------------------------------------------------------------------------
// Created:		4 December 2009 by cnwjo3
//
// Purpose:		remove all
//
vars
	s : String;
begin
	foreach s in self.allSelected do
		self.allAvailable.add(s);
		self.lstAvailable.addItem(s);
	endforeach;

	self.allSelected.clear();
	self.lstSelected.clear();

	self.cmbDefaultColour.clear();	
	//self.setVADefaultColourCombo(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="doContextMenuForPortOfCall" id="bef6696b-e189-4bb0-b0f7-b653e4af5af2">
        <updating/>
        <source>doContextMenuForPortOfCall( conwin : Window input; mouse : Boolean; x, y : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2009	cnwer1	Initial creation

*/

vars
	useTranship		: Boolean;
	bItemSelected	: Boolean;
	bItemIsTranship	: Boolean;
	bHasTranship	: Boolean;
	listbox			: CMUI_ListBox;
	x1				: Real; 
	y1				: Real;
	
begin
	if mode &lt;&gt; self.Mode_Add and mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	x1 := x;
	y1 := y;
	
	self.mnuEditPortGroup.visible	:= false;
	
	// cnwrl1 27/05/2009 PAR 19672 - start of coding
	// Establish if a list entry is selected and if it is a tranship port or not.
	useTranship		:= app.myRoot.isTerminal_PortsOfCallTranship( null );
	bItemSelected	:= false;
	bItemIsTranship	:= false;
	listbox			:= self.lstPortsOfCall;
	if listbox.listIndex &gt;= 1 then		// a specific list item has been selected rather than just the listbox
		// If the listbox level is &gt;= 1 then have a tranship port.
		bItemSelected	:= true;
		bItemIsTranship	:= listbox.itemLevel[ listbox.listIndex ] &gt; 1;
		bHasTranship	:= listbox.itemHasSubItems( listbox.listIndex );
	endif;
	
	// now make the context menu dependent on the current state.
	self.mnuPOCAdd.visible	:= true;
	self.mnuPOCAdd.caption	:= app.getErrorString( Add_Port );
	
	if useTranship then
		self.mnuPOCAddTranship.visible	:= bItemSelected and not bItemIsTranship;
		self.mnuPOCAddTranship.caption	:= app.getErrorString( Add_Tranship_Port );
		
		self.mnuPOCMakeTranship.visible	:= bItemSelected and not bItemIsTranship and not bHasTranship;
		self.mnuPOCMakeTranship.caption	:= app.getErrorString( Make_Tranship_Port );
		
		self.mnuPOCMakeActual.visible	:= bItemIsTranship;
		self.mnuPOCMakeActual.caption	:= app.getErrorString( Make_Actual_Port_Of_Call );
	endif;
	
	self.mnuPOCRemove.visible	:= bItemSelected;
	self.mnuPOCRemove.caption	:= app.getErrorString( Remove_Port );
	// cnwrl1 27/05/2009 PAR 19672 - end of coding
	
	conwin.windowToScreen( x1, y1 );
	self.screenToWindow( x1, y1 );
	
	self.popupMenu( self.mnuPortsOfCallContext, x1.Integer, y1.Integer );
	
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCopyAsNewVoyage" id="5fce01e4-e8b5-4412-a75c-d1fc9d6be169">
        <updating/>
        <source>doCopyAsNewVoyage()updating;
//--------------------------------------------------
// Created:	11 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTopSheet	: Sheet;
begin

	// CCMS 1009
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	self.voyageNumber := 0;
	self.myLastSelectedVoyage := self.myCurrentVoyage;
	self.myCopyGCStruct := self.myCurrentVoyage.myGeneralCargoVoyage;	//10 Jul 2013	NDL	Par 31965

	tmpTopSheet := self.fldMain.topSheet;
	self.cmbVoyage.setObject(null);
	self.myCurrentVoyage := null;
	self.myCurrentVoyageData := null;

	self.mode := self.Mode_Add;
	self.setControlsForAddEdit(true); //&lt;&lt;-- also sets the defaults	

	// Clear selected data
	self.setForCopyVoyage();

	self.btnShippingAgent.enabled := self.cmbShippingAgent.listObject &lt;&gt; null;		
	self.btnShippingLine.enabled := self.cmbShippingLine.listObject &lt;&gt; null;				
	
	self.fldMain.topSheet := self.shtVoyageDetails;		

	if tmpTopSheet &lt;&gt; self.shtVoyageDetails then
		self.doResizeShtVoyageDetails(self.shtVoyageDetails);
	endif;
	
	self.txtVoyageCode.setFocus();  //PAR11433
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCutoffTableContextMnu" id="251043a6-55b2-4848-9594-e9f0a5e3dc7d">
        <updating/>
        <source>doCutoffTableContextMnu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x, y : Integer):Boolean updating;
/*
Purpose - 	
Who - NAVAB1
Date - 18MAR025
ADO - JIRA 34233
*/

vars
	x1, 
	y1					: Real;
	row : Integer;
	object : CM_ReceivalCutoffVoyage;
begin
	
	if self.mode &lt;&gt; self.Mode_Update then
		return true;
	endif;
	
	x1 := x;
	y1 := y;
		
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	
	row := self.tblVoyageCutoffs.row;
	if row &lt;= self.tblVoyageCutoffs.fixedRows then
		return true;
	endif;
	
	object := self.tblVoyageCutoffs.accessRow(row).itemObject.CM_ReceivalCutoffVoyage;
	
	self.mnuRemoveOperator.visible := false;
	self.mnuEditOperator.visible := false;
	
	if object.myOperator &lt;&gt; null then
		self.mnuRemoveOperator.visible := true;
		self.mnuEditOperator.visible := true;
		self.mnuRemoveOperator.userObject := object;
		self.mnuEditOperator.userObject := object;
	
	endif;
	
	self.mnuInspectCutoffObj.visible := app.isAllowedToInspect;
	self.mnuInspectCutoffObj.userObject := object;
	self.popupMenu(self.mnuCutoffsContext, x1.Integer, y1.Integer);
	return true;
	
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataTableContextMnu" id="7b68bd71-5b3b-4cd3-b0d0-04a09da327be">
        <updating/>
        <source>doDataTableContextMnu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x, y : Integer):Boolean updating;
//--------------------------------------------------
// Created:	12 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	x1, 
	y1					: Real;
begin
	
	if self.mode &lt;&gt; self.Mode_View then
		return true;
	endif;
	
	x1 := x;
	y1 := y;
		
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	
	self.mnuColumnOrganiser.userObject := table;
	self.mnuInspect.visible:=app.isAllowedToInspect;
	self.mnuInspect.userObject:=table.userObject;
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return true;
	
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
