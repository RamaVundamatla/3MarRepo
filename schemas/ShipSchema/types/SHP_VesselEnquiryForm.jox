    <JadeMethod name="showHideSearcher" id="8622f597-52b5-4888-b054-2206eaf687de">
        <source>showHideSearcher();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.btnSearch.enabled := false;

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmSearch.centreWindow();
		//We're showing the searcher, move to the first row ready for new values.
		self.txtVesselCode.setFocus();
	endif;
	

end;</source>
