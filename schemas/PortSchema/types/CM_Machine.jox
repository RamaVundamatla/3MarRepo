    <JadeMethod name="isAfterPhysicalLimitEnd" id="04b62465-3ca9-4409-9588-4df0160edb04">
        <source>isAfterPhysicalLimitEnd(_column : CM_RTGColumn) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars

	endCol : CM_RTGColumn;
	taMaster  		: CM_TerminalAreaMaster;
	rtgLane 		: CM_RTGLane;
begin
	
	if _column = null then
		return false;
	endif;
	
	endCol:=self.myPhysicalEndBay;
	if endCol = null then
		return false;
	endif;
	
	if _column.myGridArea = endCol.myGridArea then	
		//check the physical start bay isn't after the start of the workzone
		if endCol.myGridArea.allGridColumns.indexOf(_column) &gt; endCol.myGridArea.allGridColumns.indexOf(endCol) then
			return true;
		endif;
	else
		//get the rtgLane 
		rtgLane:=_column.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if rtgLane &lt;&gt; null then
			if rtgLane.allTAsByTypeId.indexOf(_column.myGridArea) &gt; rtgLane.allTAsByTypeId.indexOf(endCol.myGridArea) then
				return true;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_column" type="CM_RTGColumn"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBeforePhysicalLimitStart" id="ad872680-1d46-4041-acdf-058e838fdc59">
        <source>isBeforePhysicalLimitStart(_column : CM_RTGColumn) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	startCol,endCol : CM_RTGColumn;
	taMaster  		: CM_TerminalAreaMaster;
	rtgLane 		: CM_RTGLane;
begin
	if _column = null then
		return false;
	endif;
	
	startCol:=self.myPhysicalStartBay;
	if startCol = null then
		return false;
	endif;
	
	if _column.myGridArea = startCol.myGridArea then	
		//check the physical start bay isn't after the start of the workzone
		if startCol.myGridArea.allGridColumns.indexOf(_column) &lt; startCol.myGridArea.allGridColumns.indexOf(startCol) then
			return true;
		endif;
	else
		//get the rtgLane 
		rtgLane:=_column.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if rtgLane &lt;&gt; null then
			if rtgLane.allTAsByTypeId.indexOf(_column.myGridArea) &lt; rtgLane.allTAsByTypeId.indexOf(startCol.myGridArea) then
				return true;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_column" type="CM_RTGColumn"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
