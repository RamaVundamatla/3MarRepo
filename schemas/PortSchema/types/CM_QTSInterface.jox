    <JadeMethod name="exportCreditToFile" id="d40e9067-fcd9-40f4-9fb0-878aa8c0d37f">
        <source>exportCreditToFile(_credit: CM_CashCredit input; _fileNameBase: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	file1,
	file2,
	file3		: File;
	folder  	: FileFolder;
	debtor		: CM_Debtor;
	fileName    : String;
begin
	
	debtor := _credit.getDebtor();
	
	if debtor = null or
	   debtor.isRDT() then
		return;
	endif;
	
	if _fileNameBase.cnContains(".csv") then
		fileName := _fileNameBase.replaceString('.csv','');
	else
		fileName := _fileNameBase;
	endif;
	
	create file1;
	file1.allowReplace 			   := true;
	file1.hidden    			   := false;
	file1.fileName 	  			   := fileName &amp; "-1.csv";  
	file1.mode 		  			   := File.Mode_Output;
	file1.usePresentationFileSystem := true;			
	
	self.createCashCredit1(file1,_credit);
	self.fileReset(file1,true,folder);
	
	create file2;
	file2.allowReplace 			   := true;
	file2.hidden    			   := false;
	file2.fileName 	  			   := fileName &amp; "-2.csv"; 
	file2.mode 		  			   := File.Mode_Output;
	file2.usePresentationFileSystem := true;		
	self.createCashCredit2(file2,_credit);
	self.fileReset(file2,true,folder);
	
	create file3;
	file3.allowReplace 			   := true;
	file3.hidden    			   := false;
	file3.fileName 	  			   := fileName &amp; "-3.csv"; 
	file3.mode 		  			   := File.Mode_Output;
	file3.usePresentationFileSystem := true;		
	self.createCashCredit3(file3,_credit);
	self.fileReset(file3,true,folder);
epilog
	

end;</source>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_fileNameBase" type="String"/>
    </JadeMethod>
