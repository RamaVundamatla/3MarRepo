    <JadeMethod name="removeFromDeleteSet" id="1b5e0404-dbf4-4c3a-8992-537dba1e6839">
        <source>removeFromDeleteSet(_obj : Object) protected;
// ---------------------------------------------------------------------------
// Created:     12 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// should arm a local exception handler and catch the exception
	if self.allObjectsToDelete.includes(_obj) then
		self.allObjectsToDelete.remove(_obj);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resetAllMenuDetails" id="2e5f7858-1d4e-40e2-88f4-d3f14c048a06">
        <source>resetAllMenuDetails();
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	user				: CM_User;
	userTerminal		: CM_UserTerminal;
	tmpDict				: CM_UserByCodeDict;	
begin

	self.trxCreateSpecialToolbarButtons();
	self.trxLoadJMTNavMenu();
	self.trxLoadJMTReportMenu();
	self.trxLoadJMTSysEntMenu();
	self.trxRefreshAllToolbarEntities();
	self.trxLoadJMTToolbarMenu();
	tmpDict := app.myRoot.allUsers;
	beginTransaction;
	foreach user in tmpDict do
		//these do nothing if already created
		user.createMenuRootToolbar();
		user.createMenuRootForSysEntities();
		user.createMenuRootReportsCurrent();
		user.createMenuRootReportsSaved();
		user.createMenuRootReportsTemplate();
		//////
		//cnwth2 no longer done here - resetting of security roles does this later in the release code
		//user.checkMenuNavAgainstSecurity();
		//user.checkSysMenuAgainstPermissions();
		
		user.checkReportMenuAgainstSecurity();
		
	endforeach;
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="trxCreateJMTMenuReportRoot" id="66a4ecbb-ad24-44cd-9572-fc135fd24189">
        <updating/>
        <source>trxCreateJMTMenuReportRoot()updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	reportMenuRoot	: CM_MenuRootReportForRoot;
	
begin
	
	reportMenuRoot := app.myRoot.myReportMenuRoot;
	
	if reportMenuRoot = null then
		beginTransaction;
		create reportMenuRoot persistent;
		app.myRoot.setPropertyValue('myReportMenuRoot', reportMenuRoot);
		commitTransaction;
	endif;
	
	self.myJMTMenuReportRoot := reportMenuRoot;

end;</source>
    </JadeMethod>
