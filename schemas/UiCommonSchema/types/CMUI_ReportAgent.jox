    <JadeMethod name="getValueByNameForDateIfVisible" id="8540401b-4f90-4922-83fd-45f8d765abfd">
        <source>getValueByNameForDateIfVisible(_string : String) : Date;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 16 May 2008
//
// Created to enable the report agent to consider how date value has been 
// passed as well as what locale is being used.  
// If the receiver is passing in a string then we'll parse it for the locale the 
// app server is running on.
// Refer PAR16192 - Locale not recognising date format.
//----------------------------------------------------------------------

vars
	theDate : Date;
begin
	if self.getValueByNameIfVisible(_string).isKindOf(Date) then
		theDate := self.getValueByNameIfVisible(_string).Date;
	elseif self.getValueByNameIfVisible(_string).isKindOf(TimeStamp) then
		theDate := self.getValueByNameIfVisible(_string).TimeStamp.date;
	else
		//Made sure I am being evaluated based on locale also.
		theDate := self.getValueByNameIfVisible(_string).String.asDateJMT;
	endif;
	
	return theDate;
epilog

end;</source>
        <Parameter name="_string" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
