    <JadeMethod name="utlUpdateInvoiceStatusReason" id="66db6440-8341-4843-89be-cdf2bdd21967">
        <updating/>
        <source>utlUpdateInvoiceStatusReason(	_proxy : CM_InvoiceStatusReason input;
								_passport : CM_Passport input) updating;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars
	real : CM_InvoiceStatusReason;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	_proxy.raiseExceptionIfNotProxy(method);

	app.myValUA.valCM_Object(_proxy,_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	real:=_proxy.pxyGetRealObject();
	
	real.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvoiceStatusReason" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceSystemDefaults" id="cc0d0d81-1bb0-4ca2-8b13-a8c5dfac8b78">
        <source>utlUpdateInvoiceSystemDefaults(_controller : CMIF_InvoiceSystemDefaults; _passport : CM_Passport input; _doAuditing : Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/04/2018	jlgdap1		TFS 38248 Next Invoice Number not updated on Invoice Configuration
// 10 Mar 2020	NDL			TFS 48407 - Rework for auditing issues
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// 24 Nov 2023 	navra1 		TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR-61386/Task-61389)
// 30 Apr 2024	navnk30		Bug 63894: MTN - Stop Creating Unqualified Audits for invoices Config not showing correct setting
// 11 Jun 2024  navbk1      Bug 64564: MTN - Invoice Configuration Screen doesn't show correct values
vars
	cancelSave:Boolean;
	extFinance : CM_ExtFinanceIO;
	theTerminal : CM_Terminal;
	bank		: CM_Bank;
	errCode, dPlaces : Integer;
	currSymbol : Integer;
	
begin

	self.initialiseActivity();
	extFinance := _controller.financialIOClass;
	theTerminal := _passport.myTerminal;
	
	exclusiveLock(extFinance);

	if _passport.noErrors and _doAuditing then
		self.myUpdateAuditAgent.audUpdateGeneric(theTerminal, true);
	endif;
	
	if app.myCurrentUserCan(theTerminal, PmAdmInvoiceSDExInterfaceMaint) then
		extFinance.updateBasicsFromController( _controller, _passport );	//06 Mar 2015	NDL	Par 35816	
	endif;
	
	if _passport.noErrors then
		if app.myCurrentUserCan(theTerminal, PmAdmInvoiceSDInvoicingMaint) then
			theTerminal.setConfig(FinancialsEnabled, _controller.financialsEnabled);
			dPlaces := _controller.financialRateDPlaces;
			if dPlaces &gt; 6 then
				dPlaces := 6;
			elseif dPlaces &lt; 0 then
				dPlaces := 0;
			endif;
			theTerminal.setConfig(FinancialRateDPlaces, dPlaces);
			// ### $CM_RateMoney is a Currency Format edit in PortSchema Formats
			currSymbol := _controller.currencySymbol.Character.Integer;
			if currSymbol = null then
				currSymbol := 36; // $
			endif;
			
			app.myRoot.setInvoiceCurrencySymbol(currSymbol);	// PAR 17016
			theTerminal.setConfig(InvoiceAPIOpModeConfig, _controller.invoiceAPIOutputMode);	//navra1 - TFS 54090(CR-61386/Task-61389) - 24th Nov 2023
			theTerminal.setConfig(OutputBaseDirConfig, _controller.outputBaseDir);				//navra1 - TFS 54090(CR-61386/Task-61389) - 24th Nov 2023
			//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - start
			//theTerminal.setConfig(ExtWebServiceConfig, _controller.externalWebService);			//navra1 - TFS 54090(CR-61386/Task-61389) - 24th Nov 2023
			//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - end
			theTerminal.setConfig(InvPostWithoutAuditQual, _controller.invPostWithoutAuditQual);	// PAR 33572
			theTerminal.setConfig(InvUseInvoiceCargoAlloc, _controller.invUseInvoiceCargoAlloc);	// PAR 35833
			theTerminal.setConfig(InvInvoicePrintJRW, _controller.invInvoicePrintJRW);	// PAR 36180
			theTerminal.setConfig(InvWOVoyageTranOnAction, _controller.invWOVoyageTranOnAction);	// TFS 42161
			theTerminal.setConfig(InvoiceHMSNoShiftCharge, _controller.invoiceHMSNoShiftCharge);	// PAR 33572
			theTerminal.setConfig(CashOnlyInDebtOption, _controller.cashOnlyInDebtOption);	//30 May 2018	NDL	TFS 38952
			theTerminal.setCalendar(_controller.myCalendar);	// PAR 33572
			theTerminal.setConfig(InvPostWithoutAuditQual, _controller.invPostWithoutAuditQual);
			theTerminal.setConfig(CashProcessingEnabled, _controller.cashProcessingEnabled);	//17 Jul 2012	NDL	Par 29968
			theTerminal.setConfig(DotMatrixInvoiceRep, _controller.dotMatrixInvoiceRep);	//14 Nov 2012	NDL	Par 30683
			theTerminal.setConfig(AutoNormalReefers, _controller.autoNormalReefers);
			theTerminal.setConfig(AutoVoidExternalReefers, _controller.autoVoidExternalReefers);
			theTerminal.setConfig(InvShowAllSeparation, _controller.invShowAllSeparation); //16/03/2023  navmv20 TFS 56128 Task 56129
			theTerminal.setConfig(InvAuditCargoEdits, _controller.invAuditCargoEdits);		//30/04/2024 navnk30 #63894
			
			$CM_InvoiceMoney.defineCurrencyFormat($CM_InvoiceMoney.decimalPlaces,
							$CM_InvoiceMoney.decimalSeparator,
							$CM_InvoiceMoney.thousandSeparator,
							$CM_InvoiceMoney.positiveFormat,
							$CM_InvoiceMoney.negativeFormat,
							$CM_InvoiceMoney.showLeadingZeros,
							currSymbol.Character);

		endif;
		if app.myCurrentUserCan(theTerminal, PmAdmInvoiceSDExInterfaceMaint) then
			theTerminal.setConfig(FinancialIOClass, extFinance);
		endif;
		if app.myCurrentUserCan(theTerminal, PmAdmInvoiceSDReeferMaint) then
			theTerminal.setConfig(ChargeFirstTemperatureOnly, _controller.chargeFirstTemperatureOnly);
		endif;
		
		if app.myCurrentUserCan(theTerminal, PmAdmInvoiceSDBusUnitsMaint) and app.myCurrentUserCan(theTerminal, PmAdmMultiCompany) then
			theTerminal.setConfig(MultiCompany, _controller.multiCompany);
			theTerminal.setDefaultCompanyBank(_controller.defCompany);	//17 Apr 2012	NDL	Par 29393
		endif;
		
		if app.myCurrentUserCan(theTerminal, PmAdmInvoiceSDDebtorMaint) then
			theTerminal.setConfig(DefDebtor, _controller.defDebtor);
			theTerminal.setConfig(MTsByDebtor, _controller.mTsByDebtor);
			theTerminal.setConfig(MTsByDebtorExport, _controller.mTsByDebtorExport);
			theTerminal.setConfig(InvoiceMultiTaxRates, _controller.invoiceMultiTaxRates);		
		endif;
		
		theTerminal.setConfig( StorageConfigType, _controller.storageConfigType );	//02 Nov 2017	NDL	TFS 7032
		theTerminal.setConfig(InvoiceRoundLineTotal, _controller.invoiceRoundLineTotal);		// 20/8/18 MAP TFS40270
		theTerminal.setConfig(InvoiceRoundDownLineTax, _controller.invoiceRoundDownLineTax);	// 20/8/18 MAP TFS40272
		theTerminal.setConfig(DeferredCharging, _controller.invoiceDeferredCharging);			// 11/06/24 navbk1 #64564
		
	endif;

	if _passport.noErrors and _doAuditing then
		self.myUpdateAuditAgent.audUpdateGeneric(theTerminal, false);
	endif;

epilog

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceSystemDefaults"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_doAuditing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTMComMvPurge" id="87fcdd99-7123-4887-bf68-07608eaf9222">
        <source>utlUpdateInvoiceTMComMvPurge(_realCommodityMap : CM_CommodityMap; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realCommodityMap	: CM_CommodityMap;
	expectedEdition	: Integer;
	
begin
	realCommodityMap := _realCommodityMap;
	self.initialiseActivity();


	exclusiveLock(realCommodityMap);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCommodityMap, true);
	endif;
	
	if _passport.noErrors then
		realCommodityMap.setForUpdateMvPurge();
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_MOVEPURGE),false,realCommodityMap);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCommodityMap, false);
	endif;

end;</source>
        <Parameter name="_realCommodityMap" type="CM_CommodityMap"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTMDebtor" id="b57925e2-c1d6-49c0-af6c-b667db6b89d9">
        <source>utlUpdateInvoiceTMDebtor(_pxyDebtorMap : CM_DebtorMap;  _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2010	cnwjre1	24051	add debtor type
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	expectedEdition	: Integer;
	real : CM_DebtorMap;
begin
	self.initialiseActivity();

	_pxyDebtorMap.pxyGetRealObjectAndEdition(real, expectedEdition);
	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice TM Debtor', null, null);
		return;
	endif;
	
	app.myValCA.valInvoiceTMDebtorMap(_pxyDebtorMap);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(real);

	if _passport.noErrors then
		real.setForUpdate(_pxyDebtorMap);
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,real);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

end;</source>
        <Parameter name="_pxyDebtorMap" type="CM_DebtorMap"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTMQty" id="b4b9f42f-15a4-4a65-bb2d-65ba30da84c5">
        <source>utlUpdateInvoiceTMQty(_pxyQuantityMap : CM_QuantityMap; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	createQRMs		: Boolean;
	expectedEdition	: Integer;
	real : CM_QuantityMap;
begin
	self.initialiseActivity();

	_pxyQuantityMap.pxyGetRealObjectAndEdition(real, expectedEdition);
	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice TM Quantity', null, null);
		return;
	endif;
	
	exclusiveLock(real);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	if _passport.noErrors then
		// 1279 on change of calculation type where the new one has quantity ranges, create quantity range maps from them
		if real.myCalculationType &lt;&gt; _pxyQuantityMap.myCalculationType and
		   _pxyQuantityMap.myCalculationType &lt;&gt; null and
		   _pxyQuantityMap.myCalculationType.allQuantityRanges.size &gt; 0 then
			createQRMs := true;
		endif;
		real.setForUpdate(_pxyQuantityMap);
		if createQRMs then
			app.myUtilityCA.utlCreateInvoiceTMQRFromCT(real, _pxyQuantityMap.myCalculationType, _passport);
		endif;
		if _passport.noErrors then
			if createQRMs then
				_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_NEWQRMS),false,real);
			else
				_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,real);
			endif;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

end;</source>
        <Parameter name="_pxyQuantityMap" type="CM_QuantityMap"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTMQtyRange" id="af601e79-2120-4650-9654-6ef4839c7220">
        <source>utlUpdateInvoiceTMQtyRange(_pxyQualityRMap : CM_QuantityRangeMap; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	expectedEdition	: Integer;
	real : CM_QuantityRangeMap;
begin
	self.initialiseActivity();

	_pxyQualityRMap.pxyGetRealObjectAndEdition(real, expectedEdition);
	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice TM Quantity', null, null);
		return;
	endif;

	
	app.setContinueCMExceptions(true);
	
	app.myValUA.valInvoiceTMQuantityRangeMap(_pxyQualityRMap);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	
	exclusiveLock(real);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	if _passport.noErrors then
		real.setForUpdate(_pxyQualityRMap);
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,real);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

end;</source>
        <Parameter name="_pxyQualityRMap" type="CM_QuantityRangeMap"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTMTransaction" id="e45681cf-6286-4656-b8c2-c05326802476">
        <source>utlUpdateInvoiceTMTransaction(_updateController :CMIF_TranMapLinesController; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realServiceBroker	: CM_ServiceBroker;
	expectedEdition	: Integer;
	pProxyServiceBroker : CM_ServiceBroker;
	pxyDM, realDM : CM_DebtorMap;
	pxyQR, realQR : CM_QuantityRangeMap;
	pxyObj, realObject : CM_Object;
begin
	pxyQR := _updateController.pxyQRMap;
	pxyObj := pxyQR;
	if pxyObj = null then // PAR 18490
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Quantity Range Proxy'); // PAR 18490
		return; // PAR 18490
	endif;
	
	self.initialiseActivity();

	pxyObj.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pxyObj.pxyGetRealObjectAndEdition(realObject, expectedEdition);
	
	if realObject = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, "Invoice Line Mappings", null, null);
		return;
	endif;
	
	realQR := realObject.CM_QuantityRangeMap;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realObject);
	if _passport.noErrors and realObject.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Line Maps', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;
	
	if _passport.noErrors then
		realQR.setForUpdate(pxyQR);

		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,realObject);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_updateController" type="CMIF_TranMapLinesController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTMVCheckMaps" id="bbc224fb-3958-480f-ba0a-ecc25ba6ed71">
        <source>utlUpdateInvoiceTMVCheckMaps(_realTMV : CM_TranMapVoyage; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realTranMapVoyage	: CM_TranMapVoyage;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	_realTMV.doCheck();
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);


end;</source>
        <Parameter name="_realTMV" type="CM_TranMapVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceTaxCode" id="56d0bc63-31a1-401e-803d-0da0c63d26ba">
        <updating/>
        <source>utlUpdateInvoiceTaxCode(_pxyInvoice : CM_Invoice;_taxCode :String;_taxDT :TimeStamp;_passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Nov 2018	jlgma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date

*/


vars
	expectedEdition :Integer;
	realInvoice     : CM_Invoice;
	taxCode         : String;
begin

	self.initialiseActivity();
	
	_pxyInvoice.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
	
	if realInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);

	if _passport.noErrors and realInvoice.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	if _passport.noErrors then
		realInvoice.setTaxDetails(_taxCode,_taxDT);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		realInvoice.causeEvent(realInvoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);	
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyInvoice" type="CM_Invoice"/>
        <Parameter name="_taxCode" type="String"/>
        <Parameter name="_taxDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceToCredit" id="8d66afab-a9d2-47db-b606-de0636014ebd">
        <source>utlUpdateInvoiceToCredit(_allInvoices : CM_InvoiceSet; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navkc1	Initial creation TFS CR 55305 Task 55533: Jade - Invoice Credit Note Jade Code
30/01/2023		navkc1	Task 55533: Jade - Invoice Credit Note Jade Code

*/

vars
	invoice : CM_Invoice;
	realInvoice	: CM_Invoice;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	foreach invoice in _allInvoices do
		invoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
		
		if realInvoice = null then
			app.raiseCMException1(ProxyMgrCannotLocateReal, invoice.sequenceNum.String, null, null);
		endif;
		
		app.myValUA.valInvoicetoCredit(invoice, realInvoice);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	foreach invoice in _allInvoices do
		invoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
		
		exclusiveLock(realInvoice);
		
		//30/01/2023	navkc1	Task 55533: Jade - Invoice Credit Note Jade Code
		if _passport.noErrors() then
			self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
		endif;
		
		if _passport.noErrors() then
			realInvoice.setCategory(InvoiceCategory_CreditNote);
			realInvoice.setExtNumberForCreditNote();
		endif;
		
		//30/01/2023	navkc1	Task 55533: Jade - Invoice Credit Note Jade Code
		if _passport.noErrors() then
			self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
			realInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allInvoices" type="CM_InvoiceSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceUnitOfMeasure" id="820f53d0-efa3-4466-bc05-733ca10a2781">
        <source>utlUpdateInvoiceUnitOfMeasure(_pxyInvoiceUnitOfMeasure : CM_InvoiceUnitOfMeasure io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 December 2022	navvt20	TFS CR 55621 Task 55693: Jade - UOM TRX

*/

vars
	realInvoiceUnitOfMeasure: CM_InvoiceUnitOfMeasure;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyInvoiceUnitOfMeasure, 'Invoice Unit Of Measure proxy ');
	
	_pxyInvoiceUnitOfMeasure.pxyGetRealObjectAndEdition(realInvoiceUnitOfMeasure, expectedEdition);
	self.raiseExceptionIfNull(realInvoiceUnitOfMeasure, 'Invoice Unit Of Measure Category');
	
	_pxyInvoiceUnitOfMeasure.validateForUpdate();
		
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceUnitOfMeasure, true);
	endif;
	
	realInvoiceUnitOfMeasure.setForUpdate(_pxyInvoiceUnitOfMeasure);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceUnitOfMeasure, false);
	endif;
epilog

end;

</source>
        <Parameter name="_pxyInvoiceUnitOfMeasure" type="CM_InvoiceUnitOfMeasure" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
