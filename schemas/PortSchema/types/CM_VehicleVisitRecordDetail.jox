    <JadeMethod name="isTypeOfJobAction" id="b8a28e42-6c19-46fe-b2b3-ab10767fb99b">
        <source>isTypeOfJobAction() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/03/2024	navkc1 CR63258  Task 63259: Jade - Start Stop API call TRX

*/

vars

begin
	if 	self.recordType = VisitRecord_JobStart or
		self.recordType = VisitRecord_JobStop or
		self.recordType = VisitRecord_JobResume or
		self.recordType = VisitRecord_JobComplete then
		
		return true;
	endif;
	
	return false;
epilog

end;</source>
