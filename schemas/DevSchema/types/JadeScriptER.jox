    <JadeMethod name="testNotes" id="3f7a9d94-d545-45ae-9721-0489f00289c8">
        <source>testNotes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	jlier1	Initial creation

*/

vars
	noteRecord		: CMIF_NotificationRecord;
	allNoteRecords  : CMIF_NoteRecordByObjDict;
	wle , wle2 : CM_YardWLE;
	set : ObjectSet;
	obj : Object;
begin

	create allNoteRecords transient;
	
	create wle transient;
	
		create noteRecord transient;
		noteRecord.eventTag := 0;
		noteRecord.eventType := WLE_Create_Event;
		noteRecord.myObject := wle;
		noteRecord.userInfoString := null;
	
		allNoteRecords.addNoDuplicates(noteRecord, false);
	
		create wle2 transient;
	
		create noteRecord transient;
		noteRecord.eventTag := 0;
		noteRecord.eventType := WLE_Update_Event;
		noteRecord.myObject := wle2;
		noteRecord.userInfoString := null;
		allNoteRecords.addNoDuplicates(noteRecord, false);
	
	
		create noteRecord transient;
		noteRecord.eventTag := 0;
		noteRecord.eventType := Wagon_Create_Event;
		noteRecord.myObject := null;
		noteRecord.userInfoString := null;	
	
	
		allNoteRecords.addNoDuplicates(noteRecord, false);
	
	foreach noteRecord in allNoteRecords do
		write noteRecord.eventType;
	
	endforeach;
	
	write " Set order";
	
	create set transient;
	allNoteRecords.copy(set);
	foreach obj in set do
		write obj.CMIF_NotificationRecord.eventType;
	endforeach;
	
	
	
epilog
	allNoteRecords.purge;
	delete allNoteRecords;
	
	delete wle;
	delete wle2;
end;	</source>
    </JadeMethod>
