    <JadeMethod name="doResizeGridContainer" id="cb296f85-87db-4c04-9e8a-7f1afec36643">
        <source>doResizeGridContainer() protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
