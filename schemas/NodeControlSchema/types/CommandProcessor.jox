<Class name="CommandProcessor" id="3896b184-0c41-4727-b69b-002889580253">
    <superclass name="Misc"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>To use, include the following in your code, 
where cp is a CommandProcessor ....

	beginTransientTransaction;
	if cp = null then
		create cp sharedTransient;
		app.doWindowEvents(1000);
	endif;
	cp.cmdLine := tCmdLine.text; // or whatever.....
	cp.stdOut := "";
	commitTransientTransaction;

	cp.run;
	
The StdOut will be in cp.stdOut.

REMEMBER TO delete cp WHEN YOU'VE FINISHED!</text>
    <DbClassMap file="JetPlusMap"/>
    <PrimAttribute name="cmdLine" id="272dd5af-2bfe-4f34-bfb3-12d249d131c6">
        <type name="String"/>
    </PrimAttribute>
