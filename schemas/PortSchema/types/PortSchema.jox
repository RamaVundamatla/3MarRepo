    <JadeMethod name="executeLoadEntTableDef" id="76a25870-031f-42c3-ae5e-f1d9b3f77da9">
        <source>executeLoadEntTableDef();
// ---------------------------------------------------------------------------
// Created:     17 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entTblAgent	: EntTableAgent;
	rtnValue	: Boolean;
	str, rtnStr	: String;
	int 		:	String;
	
begin
	
	app.initialize();
	create entTblAgent transient;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	rtnValue := entTblAgent.trxLoadFromGlobalConstants();
	// If we have true then we will only have warnings.
	if rtnValue then
		foreach str in entTblAgent.allErrorStrings do
			rtnStr := rtnStr &amp; str &amp; CrLf;
		endforeach;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Fatal Error');
	endif;

	return;
	
	// include any global constants to extract here

	int := ETRow_Colour;
	int := ETDef_CommodityGroupMaint;
	int := ETDef_CommodityGroupTbl;
	int := ETDef_ISOTypeGroupMaint;
	int := ETDef_ISOTypeGroupTbl;
	
epilog
	delete entTblAgent;

end;</source>
    </JadeMethod>
