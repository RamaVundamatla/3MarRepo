    <JadeMethod name="initFilterTable" id="77278990-ea15-4017-869d-8cb453b08b84">
        <updating/>
        <source>initFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	controller : CMUI_Controller;
	entTableDef : EntTableDef;
	theTable : CM_EntryTable;

begin
	
	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_VehicleFilter);
	
	theTable := self.tblSearch;
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(210);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef vehicle Filter not found');
	endif;
	
	self.setFilterDefaults;

epilog

end;</source>
    </JadeMethod>
