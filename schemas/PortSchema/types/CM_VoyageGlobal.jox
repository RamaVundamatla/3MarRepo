    <JadeMethod name="setFinalDepartureMovement" id="5af92ad9-0b8f-4308-b070-b2aed30cfe61">
        <source>setFinalDepartureMovement(_movement : HMS_Movement; _isGiveError:Boolean);
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// cnwdad1 16/09/2008 - PAR #17027: Added the _isGiveError parameter.
vars
	tmpSeaRegion	: HMS_HarbourRegion;
	tmpMove			: HMS_Movement;
	prevMoveBerth	: HMS_Berth; //epr par 16932 10/6/08
	tmpSteamingTime	: Integer;
	
begin
	tmpMove	:=	self.allHMSMovements.last();
	
	if tmpMove &lt;&gt; null
	and tmpMove.moveType = HMSMovementTypeDeparture
	then
		if _movement = null then
			tmpSeaRegion	:=	app.myRoot.getSeaHarbourRegion();
			tmpMove.setBerthForFinalDeparture(tmpSeaRegion.myPreferredBerth);
				//epr par 16932 10/6/08
			prevMoveBerth	:=	tmpMove.getMyBerthPrevious();
			
			if prevMoveBerth &lt;&gt; null and prevMoveBerth.myHarbourRegion &lt;&gt; null then
				tmpSteamingTime	:=	prevMoveBerth.myHarbourRegion.getSteamingTimeToRegion(self.getMyVessel, tmpSeaRegion, _isGiveError);
			endif;
			
			tmpMove.setStreamingTime(tmpSteamingTime);
		else
			tmpMove.setBerthForFinalDeparture(_movement.getMyBerth());
			tmpMove.setStreamingTime(_movement.steamingTime);
		endif;
	endif;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_isGiveError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFirstArrivalMovement" id="894bd11a-f5ce-4689-bc3f-a4a0d886193e">
        <source>setFirstArrivalMovement(_movement : HMS_Movement; _isGiveError:Boolean);
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// cnwdad1 16/09/2008 - PAR #17027: Added the _isGiveError parameter.
vars
	tmpSeaRegion	: HMS_HarbourRegion;
	tmpMove			: HMS_Movement;
	tmpSteamingTime	: Integer;
	
begin
	tmpMove	:=	self.allHMSMovements.first();
	
	if tmpMove &lt;&gt; null
	and tmpMove.moveType = HMSMovementTypeArrival
	then
		if _movement = null then
			tmpSeaRegion	:=	app.myRoot.getSeaHarbourRegion();
			tmpMove.setMyPreviousMovement(null);
			tmpSteamingTime	:=	tmpSeaRegion.getSteamingTimeToRegion(self.getMyVessel, tmpMove.getHarbourRegion, _isGiveError);
			tmpMove.setStreamingTime(tmpSteamingTime);

		else
			tmpMove.setMyPreviousMovement(_movement);
		endif;
	endif;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_isGiveError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2221be23-cea5-4a39-b4a6-8e092a5c093f">
        <updating/>
        <source>setForCreate(_pxyVoyageGlobal : CM_VoyageGlobal; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
19/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	prevMovement,
	pxyMovement		: HMS_Movement;
	//newMovement		: HMS_PassageMovement; // jlgkla1 TFS 45620
	firstTime		: Boolean;
begin
	// we need to process the movements that apply only to the global voyage i.e. the passage movements
	
	firstTime := true;
	
	foreach pxyMovement in _pxyVoyageGlobal.allHMSMovements do
		if firstTime then
			pxyMovement.setIsFirstForGlobalVoyage(true);
			firstTime := false;
		else
			pxyMovement.setIsFirstForGlobalVoyage(false);
		endif;
		// jlgkla1 TFS 45620 --&gt;
		/*if pxyMovement.isMovementTypePassage then
			create newMovement persistent;
			newMovement.setMyVoyageGlobal(self);
			newMovement.setForCreateMovement(pxyMovement, prevMovement, false, _passport);
		endif;
		prevMovement := newMovement;*/
		// jlgkla1 TFS 45620 &lt;--
	endforeach;
	
	self.setForUpdate(_pxyVoyageGlobal, null, false, _passport);
	
end;</source>
        <Parameter name="_pxyVoyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateBasics" id="ca6f0ced-fee3-447a-9852-aea777ba59f3">
        <updating/>
        <source>setForCreateBasics(_pxyVoyageGlobal : CM_VoyageGlobal; _passport : CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	30 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _pxyVoyageGlobal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, ' global voyage is null');
		return;
	endif;

	self.code		:= _pxyVoyageGlobal.code;
	self.numHatches := _pxyVoyageGlobal.numHatches;
	self.vesselName	:= _pxyVoyageGlobal.vesselName;
	self.setMyRoot();

end;</source>
        <Parameter name="_pxyVoyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromScenarioVoyage" id="5d3b82fa-1c7e-478c-b831-6a332b608e73">
        <updating/>
        <source>setForCreateFromScenarioVoyage(_voyage : CM_Voyage) updating;
/* ---------------------------------------------------------------------------
Created:	07 May 2009	by cnwvu1

Purpose:	Par Par16752
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.code		:= _voyage.code;
	self.vesselName	:= _voyage.vesselName;
	self.setMyRoot();

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a2a62c40-d402-4f3b-8cf3-24697ed56586">
        <updating/>
        <source>setForUpdate(_pxyVoyageGlobal : CM_VoyageGlobal; _cmifVoyageGlobal : CMIF_VoyageGlobal; _update : Boolean; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//
// NOTE: This is also called for by the setForCreate method BUT the _update parameter is false
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning.
============================================================================*/
vars
	tmpTerminal				: CM_Terminal;
	termCode,voyCode		: String;
	pxyVoy,
	realVoy,
	voyage					: CM_Voyage;
	hasCurrentVoyages 		: Boolean;
	tmpVoyagesToDelete		: CM_VoyageSet;
	tmpMovementsToDelete	: HMS_MovementSet;
	arrGV, depGV			: CM_VoyageGlobal;
	pxyMovement,
	realMovement,
	firstSubMovement		: HMS_Movement;
	tempTime				: TimeStamp;
	tmpTerminalByVoyageDict	: CM_ObjectByStringDict;
	iter 					: Iterator;
	tmpVoyageGlobal			: CM_VoyageGlobal;
	
begin
	create tmpVoyagesToDelete transient;
	//self.allVoyages.copy(tmpVoyagesToDelete);
	foreach voyage in self.allVoyages do			// MAP 18/1/17 TFS 3229 - don't populate with all voyages, just the ones the user is allowed to see
		if app.getMyUser().allUserTerminals[voyage.myTerminal] = null then
			continue;
		endif;
		tmpVoyagesToDelete.add(voyage);
	endforeach;
	

	// detach voyages from terminal dict so do not 
	// get a dup key error if we update terminal 
	// as part of the update
	create tmpTerminalByVoyageDict transient;
	
	foreach realVoy in tmpVoyagesToDelete do
		tmpTerminalByVoyageDict.putAtKey(realVoy.String, realVoy.myTerminal);		
		realVoy.setMyTerminal(null); //setting the terminal of all voyages to null causes problems in the multi-terminal mode such as two voyages have the same operator
	endforeach;

	create tmpMovementsToDelete transient;
	
	foreach realMovement in	self.allHMSMovements where realMovement.isMovementTypePassage do
		tmpMovementsToDelete.add(realMovement);
	endforeach;

	self.code					:=	_pxyVoyageGlobal.code;
	self.numHatches				:=	_pxyVoyageGlobal.numHatches;
	self.vesselName				:=	_pxyVoyageGlobal.vesselName;
	self.vesselCode				:=	_pxyVoyageGlobal.vesselCode;
	self.laycanDateFrom			:=	_pxyVoyageGlobal.laycanDateFrom;
	self.laycanDateTo			:=	_pxyVoyageGlobal.laycanDateTo;
	self.arrivalDT				:=	_pxyVoyageGlobal.arrivalDT;
	self.laycanTimeBegins		:=	_pxyVoyageGlobal.laycanTimeBegins;

	// update to prior voyage is done at end of method
	//self.myPriorVoyageGlobal	:=	_pxyVoyageGlobal.myPriorVoyageGlobal;	
	
	// update of subsequent voyage is only done through prior voyage
	//self.mySubsVoyageGlobal		:=	_pxyVoyageGlobal.mySubsVoyageGlobal;

	//self.setForPathSegmentDuration(_pxyVoyageGlobal);

	if _update then
		// Need to do this first so we don't run into validation issues
		
		foreach pxyVoy in _pxyVoyageGlobal.allVoyages do
			realVoy := pxyVoy.pxyGetRealObject();
			if realVoy &lt;&gt; null then
				if tmpVoyagesToDelete.includes(realVoy) then
					tmpVoyagesToDelete.remove(realVoy);								
				endif;
			endif;
		endforeach;

		//par18628.  The code below has been commented out because if we delete (erase)
		//the voyage the proxy object is also removed because it does not point to anything.
		//This code has now been moved below after the 'new' object has been added to the
		//proxy

		/*foreach realVoy in tmpVoyagesToDelete do
			tmpTerminal := tmpTerminalByVoyageDict.getAtKey(realVoy.String).CM_Terminal;			
			realVoy.causeEvent(tmpTerminal.getTerminalEvent(Voyage_Delete_Event), false, realVoy);	
			realVoy.validateForDelete(true, app.myPassport);
			realVoy.validateCargoCanBeDeleted(tmpTerminal);
			realVoy.erase(NORMAL_ERASE);
		endforeach;*/
	
	endif;

	// need to create voyages
	foreach pxyVoy in _pxyVoyageGlobal.allVoyages do
		tmpTerminal := pxyVoy.myTerminal;
		termCode := tmpTerminal.code;
		
		if _update then
			realVoy := pxyVoy.pxyGetRealObject();
			
			if realVoy &lt;&gt; null then
				//1/08/2008 cnwdz2 the following 3 lines of code are duplicate of line 69-71. 
				//if tmpVoyagesToDelete.includes(realVoy) then
				//	tmpVoyagesToDelete.remove(realVoy);
				//endif;
				
				if pxyVoy.myVoyageGlobalArrival = null or pxyVoy.myVoyageGlobalArrival.isTransient then
					arrGV := realVoy.myVoyageGlobalArrival;
				else
					arrGV := pxyVoy.myVoyageGlobalArrival;
				endif;
				
				if pxyVoy.myVoyageGlobalDeparture = null or pxyVoy.myVoyageGlobalDeparture.isTransient then
					depGV := realVoy.myVoyageGlobalDeparture;
				else
					depGV := pxyVoy.myVoyageGlobalDeparture;
				endif;
				
				realVoy.setForUpdate(false, pxyVoy, arrGV, depGV, _passport); 
				
				// AT THIS POINT THE REAL VOY HAS A NULL TERMINAL - DON'T KNOW WHY IT WAS SET NULL. BUT I CAN GET IT FROM THIS EXT KEY DICT ???
				// IF THE TERMINAL HAS CHANGED UPDATE THE PROXY COMMODITY OBJECTS - OR RAISE EXCEPTION IF CARGO IS ACTUAL
				
				//jlgka1 TFS 45620 --&gt;
				/*iter	:=	tmpTerminalByVoyageDict.createIterator();
				
				while iter.next(tmpTerminal) do
					tmpTerminalByVoyageDict.getIteratorKeys(voyCode, iter);
					
					if voyCode = realVoy.String then
						if realVoy.myTerminal &lt;&gt; tmpTerminal then
							if realVoy.allDischgVoyCommodPlanningObjs.size() &gt; 0 then
								realVoy.updateCommodityCargo(tmpTerminal, realVoy.myTerminal, false);
							endif;
							
							if realVoy.allLoadVoyCommodPlanningObjs.size() &gt; 0 then
								realVoy.updateCommodityCargo(tmpTerminal, realVoy.myTerminal, true);
							endif;
						endif;
						
						break;
					endif;
				endwhile;
				
				delete iter;*/
				//jlgka1 TFS 45620 &lt;--
				
				// updating of movements now done in HMS_VoyageData.setForUpdate
				/*
				if pxyVoy.myHMSVoyageData &lt;&gt; null then
					// create any movements that are new on the proxy
					foreach pxyMovement in pxyVoy.myHMSVoyageData.allVoyageMovements do
						realMovement := pxyMovement.pxyGetRealObject();
						if realMovement = null then
							// create it
							create realMovement as HMS_VoyageMovement persistent;
							realMovement.setMyVoyageGlobal(self);
							realMovement.setPropertyValue(HMS_VoyageMovement::myHMSVoyageData.name, realVoy.myHMSVoyageData);		
							realMovement.setForCreateMovement(pxyMovement, prevMovement, _passport);
						endif;
						
						prevMovement := realMovement;
					endforeach;
				endif;
				*/
	
				app.myEventManager.createSingleObjInfoNoteEvt(realVoy, 
										realVoy.myTerminal.getTerminalEvent(Voyage_Update_Event), realVoy);
			else
				app.myUtilityCA.zUtlCreateVoyage(pxyVoy, realVoy, null, self, false, app.myPassport);
			endif;
		else
			app.myUtilityCA.zUtlCreateVoyage(pxyVoy, realVoy, null, self, false, app.myPassport);
		endif;
		
		// end of Comalco changes
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		realVoy := null;			
	endforeach;	
	
	//par18628.  Moved here so that the proxy object is not destroyed before
	//the new object is added to it. 
	if _update then
		foreach realVoy in tmpVoyagesToDelete do
			tmpTerminal := tmpTerminalByVoyageDict.getAtKey(realVoy.String).CM_Terminal;			
			realVoy.causeEvent(tmpTerminal.getTerminalEvent(Voyage_Delete_Event), false, realVoy);	
			realVoy.validateForDelete(true, app.myPassport);
			//realVoy.validateCargoCanBeDeleted(tmpTerminal); jlgka1 TFS 45620
			realVoy.erase(NORMAL_ERASE);
		endforeach;
	endif;
	
	
	foreach pxyMovement in _pxyVoyageGlobal.allHMSMovements where pxyMovement.isMovementTypePassage do
		realMovement := pxyMovement.pxyGetRealObject();
		if realMovement = null then
			create realMovement as pxyMovement.class persistent;
			realMovement.setMyVoyageGlobal(self);
			realMovement.setForUpdateMovement(pxyMovement, _passport, false, false);
		else
			tmpMovementsToDelete.remove(realMovement);
		endif;
	endforeach;

	foreach realMovement in tmpMovementsToDelete do
		realMovement.erase(NORMAL_ERASE);
	endforeach;

	// Check if all voyages are archived so
	// can set flag on Global Voyage
	foreach realVoy in self.allVoyages do
		if (not realVoy.archived) then
			hasCurrentVoyages := true;
			break;
		endif;
	endforeach;

	if hasCurrentVoyages then
		self.isArchived := false;
		self.archivedDT := null;	
	else
		self.isArchived := true;
		if _pxyVoyageGlobal.archivedDT &lt;&gt; null then
			self.archivedDT := _pxyVoyageGlobal.archivedDT;		
		else
			self.archivedDT := app.serverTimestampAtTrxStart;
		endif;
	endif;
	
	self.maintainMovementLinkedList();
	self.setMyVessel(_pxyVoyageGlobal.getMyVessel());
	self.setMyRoot();
	
	// ----------- Handle the updating of Prior Voyage ----------- 
	if _pxyVoyageGlobal.myPriorVoyageGlobal &lt;&gt; null then
		// prior voyage has changed so need to update final departure movement on prevous voyage
		self.myPriorVoyageGlobal	:=	_pxyVoyageGlobal.myPriorVoyageGlobal;
		realMovement := self.allHMSMovements.first();
		if realMovement &lt;&gt; null then
			realMovement.setMyPreviousMovement(self.myPriorVoyageGlobal.allHMSMovements.last());
			self.myPriorVoyageGlobal.setFinalDepartureMovement(realMovement, true);
		endif;

	elseif self.myPriorVoyageGlobal &lt;&gt; null and _pxyVoyageGlobal.myPriorVoyageGlobal = null then
		// prior voyage has been removed
		realMovement := self.allHMSMovements.first();
		if realMovement &lt;&gt; null then
			// clear the reference on the first movement
			realMovement.setMyPreviousMovement(null);
		endif;
		self.myPriorVoyageGlobal.setFinalDepartureMovement(null, true);
		self.myPriorVoyageGlobal	:=	null;
	endif;
	
	// ----------- Handle the updating of Subsequent Voyage ----------- 
	// There is no ability for users to update the subsequent voyage so just need
	// to filter any time changes through.
	if self.mySubsVoyageGlobal &lt;&gt; null then
		firstSubMovement := self.mySubsVoyageGlobal.allHMSMovements.first();
		
		if firstSubMovement &lt;&gt; null then
			tempTime := self.allHMSMovements.last.occursOnDTNEW.cnEcAddMinutes(self.allHMSMovements.last.steamingTime);// + firstSubMovement.steamingTime);
			self.mySubsVoyageGlobal.setNewArrivalDateAndFilter(tempTime);
		endif;
	endif;

	if app.myPassport.hasErrors then
		return;
	endif;
	//jlgka1 TFS 45620 --&gt;
	// now update cargo objects
	//self.updateCargo(_pxyVoyageGlobal, app.myPassport);
	//jlgka1 TFS 45620 &lt;--
epilog
	delete tmpVoyagesToDelete;
	delete tmpMovementsToDelete;
	delete tmpTerminalByVoyageDict;
	delete iter;
end;</source>
        <Parameter name="_pxyVoyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_cmifVoyageGlobal" type="CMIF_VoyageGlobal"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="b857d662-1c8e-43a5-9efe-e96cce224f13">
        <updating/>
        <source>setMyRoot()updating;
//--------------------------------------------------------------
//Created: 02 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	root		: CM_Root;
begin
	//CNWTH2 - root taken out of method signature due to conflict with 
	//superclass implementation of CM_Object::setMyRoot by CNWRS1
	root := app.myRoot;
	if self.isArchived or root = null then
		self.myRoot			:= null;
		self.myRootArchived := root;
		return;
	endif;
	
	self.myRoot := root;
	self.myRootArchived	:= null;	

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVessel" id="77e5d643-6d6c-4bee-9198-bd391faeb781">
        <updating/>
        <source>setMyVessel(_vessel : CM_Vessel) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2008 by cnwrs2
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Sep 2019 jlgka1 TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin
	self.myVessel := _vessel;	
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setNewArrivalDateAndFilter" id="1e61ec2c-6f72-4e1a-9f48-084b3069520b">
        <updating/>
        <source>setNewArrivalDateAndFilter(_value : TimeStamp) updating;
//-----------------------------------------------------------------------
//	Created:	27 November 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	firstMovement	: HMS_Movement;
	diff			: Integer;
	
begin
	self.arrivalDT	:=	_value;
	firstMovement	:=	self.allHMSMovements.first();
	
	if firstMovement = null then
		return;
	endif;
	
	diff	:=	firstMovement.occursOnDTNEW.getDifferenceInMinutes(_value); //only gives positive value
	
	if _value &lt; firstMovement.occursOnDTNEW then
		diff	:=	-diff;
	endif;
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' ' &amp; self.code &amp; ' updating from ' &amp;
			firstMovement.occursOnDTNEW.asStringJMT &amp; ' to ' &amp;
			_value.asStringJMT &amp; ' diff ' &amp; diff.String, LogERROR);

	firstMovement.setOccursOnFromTimeDiff(diff); //jlgka1 TFS 45620
	
end;</source>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b9c3cbe1-5efb-459a-9d6c-cb3c8950f952">
        <updating/>
        <source>setProxy(	_code:String;
			_vesselName:String;
			_vesselCode : String;
			_laycanDateFrom:TimeStamp;
			_laycanDateTo:TimeStamp;
			_laycanArrivalDT:TimeStamp;
			_laycanTimeBegins : TimeStamp;
			_numHatches : Integer;
			_priorVoyageGlobal : CM_VoyageGlobal;
			_root : CM_Root)updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
//	self.code 					:=	_code;		// cnwrl1 14/05/2010 PAR 24216 - what it was
	self.code 					:=	_code.toUpper;
	self.numHatches 			:=	_numHatches;
	self.vesselName 			:=	_vesselName;
	self.vesselCode 			:=	_vesselCode;
	self.laycanDateFrom 		:=	_laycanDateFrom;
	self.laycanDateTo 			:=	_laycanDateTo;
	self.arrivalDT				:=	_laycanArrivalDT;
	self.laycanTimeBegins 		:=	_laycanTimeBegins;
	self.myPriorVoyageGlobal	:= _priorVoyageGlobal;
	self.setMyRoot();
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_laycanDateFrom" type="TimeStamp"/>
        <Parameter name="_laycanDateTo" type="TimeStamp"/>
        <Parameter name="_laycanArrivalDT" type="TimeStamp"/>
        <Parameter name="_laycanTimeBegins" type="TimeStamp"/>
        <Parameter name="_numHatches" type="Integer"/>
        <Parameter name="_priorVoyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="valMovementsAfterLinkListUpd" id="a57ccb6d-cc1f-4e9a-9198-9c0cc06bfb41">
        <source>valMovementsAfterLinkListUpd();
// ---------------------------------------------------------------------------
// Created:     06 March 2008 by cnwrs2
//
// Purpose:     Called before the call to maintainLinkedList to check the
//				updates have still left in a sensible state
// ---------------------------------------------------------------------------
vars
	tmpMove	: HMS_Movement;
	tmpVoyage	: CM_Voyage;
	
begin
	tmpMove := self.allHMSMovements.first;
	if tmpMove &lt;&gt; null and (not tmpMove.isMovementTypeArrival) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This update would result in voyage ' &amp;
			self.code &amp; ' having a first movement that is not an arrival movement (' &amp;
			tmpMove.moveType &amp; ' (' &amp; tmpMove.getDescription &amp; ') ' &amp; tmpMove.occursOnDTNEW.asStringJMT);
		return;
	endif;

	tmpMove := self.allHMSMovements.last;
	if tmpMove &lt;&gt; null and (not tmpMove.isMovementTypeDeparture) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This update would result in voyage ' &amp;
			self.code &amp; ' having a last movement that is not a departure movement (' &amp;
			tmpMove.moveType &amp; ' (' &amp; tmpMove.getDescription &amp; ') ' &amp; tmpMove.occursOnDTNEW.asStringJMT);
		return;
	endif;
	
	foreach tmpMove in self.allHMSMovements do
		if tmpMove.isMovementTypeShift then
			tmpVoyage := tmpMove.getVoyage();
			if tmpMove.occursOnDTNEW &lt;= tmpVoyage.arrivedDT or
			   tmpMove.occursOnDTNEW &gt;= tmpVoyage.departedDT then
				app.raiseUnexpectedProgramError(class.name, method.name, 'This update would result in voyage ' &amp;
					self.code &amp; ' having a shift movement (' &amp;
					tmpMove.getDescription &amp; ' on ' &amp; tmpMove.occursOnDTNEW.asStringJMT &amp;
					' that is outside its arrival (' &amp; tmpVoyage.arrivedDT.asStringJMT &amp;
					') and departure (' &amp;  tmpVoyage.departedDT.asStringJMT &amp;
					') at terminal ' &amp; tmpVoyage.myTerminal.code);
				return;
			endif;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="valMovementsBeforeLinkListUpd" id="32705e14-eabf-4ddc-9509-bb3abfae1090">
        <source>valMovementsBeforeLinkListUpd();
// ---------------------------------------------------------------------------
// Created:     06 March 2008 by cnwrs2
//
// Purpose:     Called before the call to maintainLinkedList to check the
//				updates have still left in a sensible state
// ---------------------------------------------------------------------------
vars
	tmpMove	: HMS_Movement;
	
begin
	tmpMove := self.allHMSMovements.first;
	if tmpMove &lt;&gt; null and (not tmpMove.isMovementTypeArrival) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This update would result in voyage ' &amp;
			self.code &amp; ' having a first movement that is not an arrival movement (' &amp;
			tmpMove.moveType &amp; ' (' &amp; tmpMove.getDescription &amp; ') ' &amp; tmpMove.occursOnDTNEW.asStringJMT);
		return;
	endif;

	tmpMove := self.allHMSMovements.last;
	if tmpMove &lt;&gt; null and (not tmpMove.isMovementTypeDeparture) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This update would result in voyage ' &amp;
			self.code &amp; ' having a last movement that is not a departure movement (' &amp;
			tmpMove.moveType &amp; ' (' &amp; tmpMove.getDescription &amp; ') ' &amp; tmpMove.occursOnDTNEW.asStringJMT);
		return;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fae34bf8-c252-4216-a7cb-5a1027efeb33">
        <source>validateForCreate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.validateForUpdate(_passport, null);

/*	if self.code = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);	
	endif;
	if self.myVessel = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Vessel', null, null);	
