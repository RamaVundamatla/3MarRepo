<Class name="CMIF_StateChangeController" id="45c79673-f241-485b-974a-475318a74b95">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ExplicitInverseRef name="allStateChangeObjects" id="fc476aa8-774b-4c9e-a046-c1209b5ba48e">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CMIF_StateChangeObjectDict"/>
        <Inverse name="CMIF_StateChangeObject::myController"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allStateMappings" id="81843216-3bb7-48f0-aac1-4d2286be2ee0">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CMIF_StateClassMapDict"/>
