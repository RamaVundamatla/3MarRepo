    <JadeMethod name="txtWagonIn_change" id="32695e16-47d8-4568-b507-524283ebedd0">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtWagonIn_change(textbox: TextBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vehicleID		: String;
begin
	vehicleID := textbox.text.trimBlanks();
	if vehicleID.length &gt;= 4 and vehicleID &lt;&gt; self.previousWagonIDIn then
		self.clearInwardInfo();
		self.doGetWagonDetailsIn(vehicleID);
		self.previousWagonIDIn := vehicleID;
	endif;
	
end;


</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
