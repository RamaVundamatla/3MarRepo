    <JadeMethod name="getTotalContainers" id="47379487-661c-4258-9b58-2719dba4735b">
        <source>getTotalContainers():Integer;
/*
	Purpose:		Return sum of discharged/loaded/od containers	
	Parameters:			
	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/

vars

begin
	return self.getDisch20AllItems() + self.getDisch30AllItems() + self.getDisch40AllItems() + self.getDisch45AllItems() + self.getDisch53AllItems() +
			self.getLoad20AllItems() + self.getLoad30AllItems() + self.getLoad40AllItems() + self.getLoad45AllItems() + self.getLoad53AllItems() ; 
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalLidMoves" id="09c78328-0ec2-42dd-bee1-0982bab3907c">
        <source>getTotalLidMoves():Integer;
/*
	Purpose:		Add up movesLids for each crane		
	Parameters:			
	Return Value:		

Date			Who		Reason
07 August 2008	concms1	Initial creation
*/

vars
	result	:Integer;
	kpi		:CM_KPI;
begin
	foreach kpi in self.myVoyage.allVoyageKPIEntities  discreteLock where kpi.type = KPI_Type_VoyageCraneShift do
		result := result + kpi.CM_KPIVoyageCraneShift.movesLid.Integer;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalMoves" id="8863638e-ac2b-4887-a0b9-1097a6e76ee3">
        <source>getTotalMoves():Integer;
/*
Date		Who		Reason
31 July 2008	concms1	Initial creation
*/

vars
	kpi		:CM_KPI;
	result	:Integer;
begin
	
	result := result + self.getTotalContainers +
					self.getDLRAllItems + 
					self.getSOBAllItems +
					self.getNumLashingBinMoves
					+ self.movesLid.Integer;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTwinLiftPercentage" id="a00cc4e0-d567-4c20-91a6-93c8ace9f530">
        <source>getTwinLiftPercentage():Decimal;
/*
	Purpose:		To return the percentage of twin lifts.	
	Parameters:			
	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/

vars
	total, totTL	:Integer;
begin
	totTL := self.getAllTwinLift();
	total := totTL + self.getAllSingleLift();
	
	if totTL = null or total = null then
		return null;
	endif;
	
	return ((totTL/total)*100).roundedTo(2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
