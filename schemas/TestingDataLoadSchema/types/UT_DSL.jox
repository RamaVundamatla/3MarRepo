    <JadeMethod name="resetTransactionDate" id="bad27d22-cd39-4dd4-81a7-98f0288aa1b2">
        <source>resetTransactionDate(_trackedItem : CM_TrackedItem; _dateTime : TimeStamp);

vars
	orderNo	: Integer;
	tranTS	: TimeStamp;
	tran : CM_TITransaction;
	oa		: ObjectArray;
	obj		: Object;
begin
	create oa transient;
	foreach tran in _trackedItem.allTransactions do
		if tran.orderNo &gt; orderNo then
			orderNo := tran.orderNo;
		endif;
		oa.add(tran);
	endforeach;
	
	beginTransaction;
	foreach obj in oa do
		tran := obj.CM_TITransaction;
		orderNo := orderNo + 1;
		tranTS.setDate(_dateTime.date);
		tranTS.setTime(tran.dateTime.time);
		tran.setPropertyValue("orderNo", orderNo);
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	commitTransaction;
epilog
	delete oa;
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="roadExit" id="376972a9-1fe2-47ef-92f1-f7950e18cde1">
        <source>roadExit(_vvr: CM_VehicleVisitRecord input);
//19 August 2009	cnwdw1	
//16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
vars

	expectErrors : Boolean;

begin
	
	expectErrors := self.opts.bool("ExpectErrors");
	
	//app.myTrxDA.trxRoadExit(_vvr.myRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit(_vvr.myRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
	
	if expectErrors then
		return;
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	if not _vvr.allReceivedTrackedItems.isEmpty() then										// 16/08/2012 cnwmh5
		self.checkTIsForTxnOfType(_vvr.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);
	endif;
	if not _vvr.allReleasedTrackedItems.isEmpty() then										// 16/08/2012 cnwmh5
		self.checkTIsForTxnOfType(_vvr.allReleasedTrackedItems, TRANS_TYPE_REL_ROAD);
	endif;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runCamsAdhoc" id="4aec3516-e00f-44a2-aea9-96b7be19e754">
        <source>runCamsAdhoc(_startDateTime, _endDateTime : TimeStamp; _runDateTime : TimeStamp io; _camProtocol : CM_CamProtocol io);
// cnwrs1 
// 17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
// 07/06/2012	cnwcs5		New profile setting so we can select local directory for CAMS files and leave server directory for CAMS BGP
// 09/07/2014	cnwmh5		Change runDateTime to use actualServerTime
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//
vars
	terminal 		: CM_Terminal;
	camsController 	: CM_CamControllerAgent;
//	runDateTime 	: TimeStamp;
	dir, saveDir	: String;	// cnwcs5 June 2012
	resetConfig		: Boolean;	// cnwcs5 June 2012
	assoc			:CM_Association;
begin
	_runDateTime := app.actualTimeServer;//.addSeconds(2);						// 09/07/2014 cnwmh5
	terminal 	:= self.getTerminal();
/*	if we are running unit tests then CAMS uses the thin-client file system
	so each profile can optionally set its own CAMS directory */	
	assoc := self.getProfileSetting (UT_Profile.P_CAMS_DIRECTORY);
	
	if assoc &lt;&gt; null then
		dir := assoc.asString;
	endif;
	
	if dir &lt;&gt; null then 
		// save off "proper" setting for the CAMS directory
		///self.setTerminalConfig(CamsFileDirectory, dir);
	endif;
	
	create camsController transient;
	
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(_camProtocol, _startDateTime, _endDateTime, _runDateTime, true, true);
epilog
	delete camsController;
	
end;
</source>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_endDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp" usage="io"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="io"/>
    </JadeMethod>
    <JadeMethod name="runCamsNow" id="038cfa6d-e4e9-4fd2-a759-e0e0f9eefb64">
        <source>runCamsNow(_startDateTime : TimeStamp; _camProtocol : CM_CamProtocol io);
// cnwrs1 
//26 May 2016	cnwrs1	this setups and runs proper cams so can be used to test single transaction per file
//
vars
	terminal 		: CM_Terminal;
	camsController 	: CM_CamControllerAgent;
//	runDateTime 	: TimeStamp;
	dir, saveDir	: String;	// cnwcs5 June 2012
	resetConfig		: Boolean;	// cnwcs5 June 2012
	assoc			:CM_Association;
begin
write class.name&amp;'::'&amp;method.name&amp;' _startDateTime='&amp;_startDateTime.String;
write class.name&amp;'::'&amp;method.name&amp;' lastRunDateTime='&amp;_camProtocol.lastRunDateTime.String;
	terminal 	:= self.getTerminal();
/*	if we are running unit tests then CAMS uses the thin-client file system
	so each profile can optionally set its own CAMS directory */	
	assoc := self.getProfileSetting (UT_Profile.P_CAMS_DIRECTORY);
	
	if assoc &lt;&gt; null then
		dir := assoc.asString;
	endif;
	
	if dir &lt;&gt; null then 
		// save off "proper" setting for the CAMS directory
		///self.setTerminalConfig(CamsFileDirectory, dir);
	endif;
	
	create camsController transient;
	
	camsController.setMyTerminal(terminal);
	beginTransaction;
	terminal.setConfig(CamsDelayTime, 0);
	_camProtocol.setPropertyValue(CM_CamProtocol::firstRunDateTime.name, _startDateTime.addSeconds(-2));
	_camProtocol.lastRunDateTime := _startDateTime;
//	_camProtocol.setStatus(CAM_HOLDSTATUS);
	commitTransaction;
write class.name&amp;'::'&amp;method.name&amp;' firstRunDateTime='&amp;_camProtocol.firstRunDateTime.String&amp;' lastRunDateTime='&amp;_camProtocol.lastRunDateTime.String;
	camsController.runNow(_camProtocol);
epilog
	delete camsController;
	beginTransaction;
	terminal.setConfig(CamsDelayTime, 5);
	commitTransaction;
end;

</source>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="io"/>
    </JadeMethod>
    <JadeMethod name="runCamsRequest" id="01a795da-7346-44ef-af05-fb1f4d552f98">
        <source>runCamsRequest();
//
//03 Aug 2012	cmwrs1	runs cams as if from BGP
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
begin
	terminal := self.getTerminal();
	if terminal = null then
		app.writeStatement('Can not find required terminal.');
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;

</source>
    </JadeMethod>
    <JadeMethod name="setActiveProfileMDHONLY" id="f5ac560d-219d-4b52-8df0-2a2b9bde725f">
        <updating/>
        <source>setActiveProfileMDHONLY() updating; //, protected;
//23 October 2008	cnwdw1	
//
begin
	self.testProfile := self.getTestProfile();
	if self.testProfile &lt;&gt; null then
		self.activeProfile := self.testProfile;
	elseif self.testerProfile &lt;&gt; null then
		self.activeProfile := self.testerProfile;
	else
		self.testProfile := self.getDefaultProfile();
		if self.testProfile &lt;&gt; null then
			self.activeProfile := self.testProfile;
		endif;
	endif;
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString]);
	app.myPassport.setMyUserFromCode(self.getProfileSetting(UT_Profile.P_USER).asString);
//	app.setSpecial('31/12/3000'.TimeStamp);

end;</source>
    </JadeMethod>
    <JadeMethod name="setBankCmifFromBank" id="16c71013-3919-4fcd-927e-eaf7b8655f1b">
        <source>setBankCmifFromBank( _controller : CMIF_BankDetails input; _bank : CM_Bank; _pxyBank : CM_Bank io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwndl1	Initial creation	Par 29393

*/

vars

	ls : Boolean;

begin

	if _pxyBank &lt;&gt; null then
		delete _pxyBank;
	endif;

	_controller.isBU := true;

	_controller.allBankDetails.clear();
	_controller.mailingAddress.clear();
	_controller.remittanceAddress.clear();
	
	_bank.allBankDetails.copy(_controller.allBankDetails);	
	_bank.mailingAddress.copy(_controller.mailingAddress);	
	_bank.physicalAddress.copy(_controller.remittanceAddress);

	_controller.myParentCompany := _bank.parentCompany;
	_controller.code := _bank.code;	
	_controller.emailAddress := _bank.emailAddress;
	_controller.faxNumber := _bank.faxNumber;
	_controller.mailingName := _bank.mailingName;
	_controller.onsiteStorageChargeTime := _bank.onsiteStorageChargeTime;
	_controller.phoneNumber := _bank.phoneNumber;
	_controller.retrospectiveRates := _bank.retrospectiveRates;
	_controller.isSuspended := _bank.isSuspended;
	_controller.taxNarration := _bank.taxNarration;
	_controller.taxNumber := _bank.taxNumber;
	_controller.taxPercentageRate := _bank.taxPercentageRate;
	_controller.myBusinessUnitDebtor := _bank.businessUnitDebtor;
	
	app.cmsBeginLoad(ls);
	_pxyBank := app.createUpdateProxy(_bank).CM_Bank;
	app.cmsEndLoad(ls);
	
	_controller.myProxyBank := _pxyBank;

epilog

end;</source>
        <Parameter name="_controller" type="CMIF_BankDetails" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_pxyBank" type="CM_Bank" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setCargoAsTranshipTo" id="7625ff2c-a11c-4513-991d-32bce470f8d8">
        <source>setCargoAsTranshipTo( _ti : CM_TrackedItem; _voyageOut : CM_Voyage ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwndl1	Initial creation

*/

vars

	cont : CMIF_TranshipTIController;
	port : CM_Port;

begin

	port := app.myRoot.allPorts["NZAKL"];
	
	create cont transient;
	cont.clear();
	cont.allTrackedItems.add( _ti );
	cont.myExportDestPort := port;
	cont.myExportDisPort := port;
	cont.myExportVoyage := _voyageOut;
	cont.remarks := null;
	//cont.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	cont.bookingRef := null;
	cont.billOfLading := null;
	cont.myTranshipToPort := null;			
	
	app.myTrxCA.trxCreateTrackeditemsTranShip(cont, app.myPassport); 
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"0. Failed to make " &amp; _ti.id &amp; " a tranship. " &amp; app.myPassport.getErrorsAndWarningsAsString);

epilog

	delete cont;

end;</source>
        <access>protected</access>
