    <JadeMethod name="doTblDataDragDrop" id="1084459a-a1ab-406e-b0d4-149e0e0b026f">
        <updating/>
        <source>doTblDataDragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//19 Aug 2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning
//2 Nov 2022  navhl20   ChangeRequest 54281: EUP - Wagon Track Planning
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	theRow : Integer;
	lc : CM_LocationsController;
	moveController : CMIF_MoveController;
	tmpTi : CM_TrackedItem;
begin
	moveController := app.myMoveController;

	theRow := self.tblData.getRowFromY(y);
	if theRow &gt; self.tblData.fixedRows then
		wagon := self.tblData.accessRow(theRow).itemObject.CM_Wagon;
	endif;

	//if app.myWagonMoveController &lt;&gt; null and self.wagonReceiveDrop(wagon) then	//2.11.2022	navhl20	TFS 54281
	if app.myWagonMoveController &lt;&gt; null then	//2.11.2022	navhl20	TFS 54281
		return;
	endif;
	
	if moveController &lt;&gt; null then
		tmpTi := moveController.myTrackedItem; //19 Aug 2022	navsj20	TFS 54281
	endif;
	if tmpTi = null then
		return;
	endif;

	if wagon &lt;&gt; null then
		lc := wagon.getNextFreeWagonControllerPN(tmpTi, moveController.moveMode);
		if lc &lt;&gt; null then
			self.assignTIToTransport(lc);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
