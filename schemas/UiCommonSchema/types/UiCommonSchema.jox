    <JadeMethod name="createAndCommitStringAlert" id="3ae61d39-31b6-48ca-89b1-3de38008f9ca">
        <source>createAndCommitStringAlert(heading : String; detail : String);
/*
------------------------------------------------------------------------
Created:			29 July 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	alert : CM_SystemAlert;
begin
	create alert;
	alert.details := heading;
	alert.addLogEntry(detail.trimRight);
	alert.setSeverity(SEVERE_INFO);
	alert.add;
	app.commitAlert();
end;</source>
        <Parameter name="heading" type="String"/>
        <Parameter name="detail" type="String"/>
    </JadeMethod>
