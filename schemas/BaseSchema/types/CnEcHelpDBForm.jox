    <JadeMethod name="listboxHasSelected" id="fbe22911-2163-4636-a880-7b8f1a6349f5">
        <source>listboxHasSelected(listbox : ListBox) : Boolean;

//	returns true if listbox item is currently selected.
//	returns false if list item is not selected, or no item is selected

vars
	listPointer		: Integer;
	
begin
	listPointer := listbox.listIndex;
	
	if listPointer &lt; 0 then
		return false;
	endif;
	
	return listbox.itemSelected[listPointer];
end;</source>
