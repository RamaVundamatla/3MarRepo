    <JadeMethod name="status" id="45cc10d1-f7f3-4f18-a224-c84587a35494">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>status(set: Boolean; _value: Integer io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTA	: CM_TerminalArea;
begin

	if set then
		exclusiveLock(self);

		// this will always return something as there is a
		// mapping method on myTerminalArea
		tmpTA := self.myTerminalArea;

		if _value &lt;&gt; self.status then
		
			self.statusDateTime := app.serverTimestampAtTrxStart;

			if _value = LC_Status_Archived then
				// we are archiving the area
				self.myTerminalAreaWhenArchived	:= tmpTA;	//self.myTerminalArea;
			   	self.myTerminalArea 			:= null;

			elseif _value &lt;&gt; LC_Status_Archived and 
				self.myTerminalAreaWhenArchived &lt;&gt; null then
				// we are un-archiving the area
			   	self.myTerminalArea 			:= tmpTA;	//self.myTerminalAreaWhenArchived;
			   	self.myTerminalAreaWhenArchived := null;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="terminalAreaId" id="22308d9d-71e6-4025-bfe3-963c14deb156">
        <methodInvocation>mapping</methodInvocation>
        <source>terminalAreaId(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		_value := self.myTerminalArea.id;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
