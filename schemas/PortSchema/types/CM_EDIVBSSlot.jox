    <JadeMethod name="getVbsSlotByExtId" id="24362591-41e8-4731-86a0-31997090ac14">
        <source>getVbsSlotByExtId(): CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2023	navma1	Bug 59805: EUP - VBS EDI Validation
*/
vars
	vbsSlot 			: CM_VehicleBookingTimeSlot;
	term				: CM_Terminal;
	vehicleBookingTerm	: CM_VehicleBookingTerminal;
begin
	
	if self.externalReference = null then
		return null;
	endif;
	
	term := self.getMyTerminal;
	
	if term = null then
		return null;
	endif;
	
	vehicleBookingTerm := term.myVehicleBookingTerminal;
	
	if vehicleBookingTerm = null then
		return null;
	endif;
	
	vbsSlot := vehicleBookingTerm.allVBTimeslotsByExtRef[self.externalReference.toUpper.trimBlanks];
	
	return vbsSlot;
epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="getVbsSlotById" id="ecf45937-aa80-49b6-bbf5-6dc0df28e3fa">
        <source>getVbsSlotById(): CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate
14 Aug 2023	navma1	Bug 59805: EUP - VBS EDI Validation

*/

vars
	vbsSlot 			: CM_VehicleBookingTimeSlot;
	term				: CM_Terminal;
	vehicleBookingTerm	: CM_VehicleBookingTerminal;
begin
	
	if self.id = null then
		return null;
	endif;
	
	term := self.getMyTerminal;
	
	if term = null then
		return null;
	endif;
	
	vehicleBookingTerm := term.myVehicleBookingTerminal;
	
	if vehicleBookingTerm = null then
		return null;
	endif;
	
	vbsSlot := vehicleBookingTerm.allVBTimeslotsById[self.id.toUpper.trimBlanks];
	
	return vbsSlot;
epilog

end;</source>
