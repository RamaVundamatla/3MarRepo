<Class name="CM_AuditTranDeleted" id="e2d2218d-21c1-490f-b222-9a8f6035248e">
    <superclass name="CM_Audit"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myObject" id="6e03d8ff-48fb-46e1-a7ba-c7449c00e7e1">
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="52125b9b-f464-4038-a9cb-7e6d953e5a94">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTransaction" id="d056dcb7-6d93-49ed-b197-5c1089190a67">
        <embedded/>
        <type name="CM_TITransaction"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getDateTime" id="195ebde9-2c46-4320-933d-f9c70acf05c3">
        <source>getDateTime() : TimeStamp;

vars

begin
	if self.myTransaction = null then
		return null;
	endif;
	return self.myTransaction.dateTime;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8302f14a-d00b-46c9-81e1-8bd014505bc3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	invalid			: Boolean;
	returnVal		: String;
	transTS			: TimeStamp;
	
begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.getDetails();	
	elseif _attrName = ETRow_User  then
		if self.myTransaction = null then
			return null;
		else
			on Exception do app.handleDeletedObject(exception, self.myTransaction, invalid);
			returnVal :=  self.myTransaction.userId;
			return returnVal;
		endif;
	elseif _attrName = ETRow_EndDate  then
		if self.myTransaction = null then 
			return null;
		else
			on Exception do app.handleDeletedObject(exception, self.myTransaction, invalid);
			transTS := self.systemToLocalTime(self.myTransaction.dateTime);
			returnVal := transTS.date.shortFormat() &amp; " " &amp; transTS.time.currentLocaleFormatJMT();	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
			return returnVal;
		endif;
	elseif _attrName = ETRow_Ti  then
		if self.myTrackedItem &lt;&gt; null then 
			on Exception do app.handleDeletedObject(exception, self.myTrackedItem, invalid);
			returnVal := self.myTrackedItem.id;
			return returnVal;
		else
			return null;	
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="88a0f943-7356-4b01-a40b-9fbd02ba4df6">
        <updating/>
        <source>init(_ti: CM_TrackedItem; _tran : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     30 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myTrackedItem := _ti;
	self.myTransaction := _tran;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
