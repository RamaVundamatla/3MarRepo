    <JadeMethod name="getTAViewPositionXYs" id="b3df108a-0d77-4781-9dd8-252643a8ad4b">
        <source>getTAViewPositionXYs(_taViewPos: CM_TerminalAreaViewPosition; x, y: Real io) protected;
//28 August 2008	cnwdw1	
//
vars
	terminalAreaViewPos: CM_TerminalAreaViewPosition;
	invalidPositions	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _taViewPos, invalidPositions);//3 Nov 2009 cnwdz2 par20772
	if _taViewPos &lt;&gt; null then
		x := _taViewPos.origin.x * self.scaleFactor;
