    <JadeMethod name="getAllMethods" id="40971ed6-c677-472b-821f-2602169305f7">
        <source>getAllMethods(_klass: Class; _methods: MethodSet io);
//07 January 2009	cnwdw1	
//
vars
	schema: Schema;
	klass: Class;
	methods: MethodSet;
	meth: Method;
begin

	create methods transient;
	foreach schema in schemas do
		klass := schema.getClass(_klass.name);
		if klass &lt;&gt; null then
			methods.clear;
			klass.allMethods(methods);
			foreach meth in methods do
				if _methods.includes(meth) then
					continue;
				endif;
				if app.isUnitTestMethod(meth) then
					_methods.add(meth);
				endif;
			endforeach;
		endif;
	endforeach;
	
epilog
	delete methods;
end;</source>
        <Parameter name="_klass" type="Class"/>
        <Parameter name="_methods" type="MethodSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDetailsForClass" id="7bebc2c7-48e7-4db3-a552-2f5e0153603a">
        <source>getDetailsForClass(_line, _fileName : String; _detailsArray : HugeStringArray io);

/*

Purpose:		Get details from class of methods changed.  Will work only if the developer has put the par number in the code.

Date			Who		Reason
31/058/2012		cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	klass				: Class;
	meth				: Method;
	
	methodsDict			: MethodNDict;

	parNumber			: Integer;
	posParFile			: Integer;
	posSlash			: Integer;
	posUnderscore		: Integer;
	posParLine			: Integer;
	className 			: String;
	schemaName			: String;
	methodSource		: String;
	
begin

	// get the par number
	// check the file name to see if includes par # (\XXX_Par?????)
	posParFile := _fileName.toUpper().pos("_PAR", 1);
	if posParFile &gt; 0 then
		posSlash := _fileName.pos("\", posParFile);
		if posSlash &gt; 0 then
			parNumber := _fileName[posParFile+4:posSlash-1-posParFile+4].Integer;
		endif;
	endif;
	
	// not found in the file name then check the line
	if parNumber = 0 then
		posParLine := _line.toUpper().pos("_PAR", 1);
		if posParLine &gt; 0 then
			parNumber := _line[posParLine+4:end].Integer;
		endif;
	endif;
	
	// no par number so get out of here
	if parNumber = 0 then
		return;
	endif;
	
	// get the class name
	if posParLine = 0 then
		className := _line[7:end].trimBlanks();
	else
		className := _line[7:posParLine-7];
	endif;
	if className.toUpper() = "JADESCRIPT" then
		return;
	endif;
		
	// get the schema name
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		return;
	endif;
	posSlash := _fileName.reversePos("\");
	posUnderscore := _fileName.pos("_", posSlash);
	schemaName := _fileName[posSlash+1:posUnderscore-1-posSlash];
	schema := schema.getSchema(schemaName);
	if schema = null then
		return;
	endif;
	
	// get the class
	klass := schema.getClass(className);
	if klass = null then
		return;
	endif;
	
	// get the methods
	create methodsDict transient;
	klass.getMethods(methodsDict);
	
	// check the methods for the par number
	foreach meth in methodsDict do
		methodSource := meth.getSource();
		if methodSource.cnContains(parNumber.String) then
			if not _detailsArray.includes(klass.name &amp; " " &amp; meth.name) then
				_detailsArray.add(klass.name &amp; " " &amp; meth.name);
			endif;
		endif;
	endforeach;
	
epilog
	delete methodsDict;				// 13/09/2012 cnwmc5
end;</source>
        <Parameter name="_line" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_detailsArray" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMethodClass" id="2674249b-2ff6-4504-93cd-c662d71b287d">
