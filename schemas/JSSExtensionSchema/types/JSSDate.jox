    <DbClassMap file="jssxs_datavalue_primitive"/>
    <PrimAttribute name="dateClient" id="b21c0236-f5dc-4be5-9cc3-c1ba8fedc6d6">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dateServer" id="208c21b4-01e5-4f9d-a0f3-59edcc7b7464">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addDays" id="92c3772a-7e78-43f6-b9ed-61767d50715a">
        <updating/>
        <source>addDays(pDays:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				client date.
//
// Parameters:	pDays (Integer) - The number of days to add (or subtract).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.dateClient	:=	self.dateClient + pDays;
end;</source>
        <Parameter name="pDays" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMonths" id="8f667827-2d5b-45af-9dca-0f3160816372">
        <updating/>
        <source>addMonths(pMonths:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				client date.
//
// Parameters:	pMonths (Integer) - The number of months to add (or subtract).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.dateClient	:=	self.dateClient.jssAddMonths(pMonths);
end;</source>
        <Parameter name="pMonths" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addYears" id="8bb12677-cda7-45fd-bb11-b4c218c86ec5">
        <updating/>
        <source>addYears(pYears:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of years to the
//				client date.
//
// Parameters:	pYears (Integer) - The number of years to add (or subtract).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.dateClient	:=	self.dateClient.jssAddYears(pYears);
end;</source>
        <Parameter name="pYears" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="95618fe5-9247-4ee3-8b52-c320cede9a70">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setDateClient();
	self.setDateServer();
end;</source>
    </JadeMethod>
    <JadeMethod name="setDateClient" id="f033e2c8-ea7b-4b50-8c59-c0917e036664">
        <updating/>
        <source>setDateClient() updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentDate	: Date;
	
begin
	self.dateClient	:=	currentDate;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDateServer" id="7e8c49a5-d13f-464b-9a7c-2ad54123587e">
        <updating/>
        <source>setDateServer() updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.dateServer	:=	app.actualTimeServer().date();
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="0e91930d-1f87-4727-8029-ac9dfe267a40">
        <updating/>
        <source>updateMe(pDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dateClient &lt;&gt; pDate then
		self.dateClient	:=	pDate;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
</Class>
