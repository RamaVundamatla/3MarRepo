    <JadeMethod name="initialise" id="535e11bf-f155-4224-b7a5-0b48b33688ee">
        <updating/>
        <source>initialise(	_category				: XLAT_Category; 
			_constant 				: GlobalConstant; 
			_constantCategoryName	: String; 
			_defaultText			: String;
			_defaultShortText 		: String) updating;

// ---------------------------------------------------------------------------
// R Barr 	8/8/06	Set basic properties, use updateLocaleTranslation to create
//					or update each locale specific translation
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
					Change code to always set number from linked EntTableRow for 
					EntTableRows category translations, to keep them in step and
					prevent duplicates during upgrades

*/

vars
	root : CM_Root;
begin
	self.myGlobalConstant := _constant;
	if self.number = 0 or _constantCategoryName = EntTableRows then
		self.number := self.getUniqueNumber(_category, self.myGlobalConstant);
	endif;
	
	if self.number = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'number', null, null);
		return;
	endif;
	
	// any new item should be set to be reviewed
	if self.myRoot = null then
		self.toBeReviewedFlag := true;
	endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;self.vConstantName&amp;' '&amp;self.number.String;
	self.myConstantCategoryName := _constantCategoryName;
	
	if self.myCategory &lt;&gt; _category then
		self.myCategory := _category;
	endif;

	root := self.myCategory.myRoot;
	if self.myRoot &lt;&gt; root then
		self.myRoot := root;
	endif;
	

	if self.myConstantCategoryName = XLAT_Exceptions then	// error messages only
		self.myRoot.setBaseErrorNum(number);
	endif;

	// set default locale text if supplied
	if _defaultText &lt;&gt; null or _defaultShortText &lt;&gt; null then
		self.updateLocaleTranslation(self.myCategory.myRoot, self.myRoot.getLocale(StandardTextLocaleStr, true), _defaultText, _defaultShortText, null, false);
	endif;
	
end;</source>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <Parameter name="_constantCategoryName" type="String"/>
        <Parameter name="_defaultText" type="String"/>
        <Parameter name="_defaultShortText" type="String"/>
    </JadeMethod>
    <JadeMethod name="isToBeReviewed" id="8386d7ca-6007-4ef7-8187-8046bff5c7e6">
        <condition/>
        <source>isToBeReviewed():Boolean condition;

begin
	return toBeReviewedFlag ;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchKeywords" id="64d2baf4-d9ae-44ad-9d44-2e98debc3cda">
        <source>matchKeywords(_selectedLocale : CM_Locale; _keywords : StringArray; _matchAll : Boolean):Boolean;

vars
	locale			: CM_Locale;
	translation		: XLAT_Translation;

begin
	translation := getTranslation(locale);
	if translation &lt;&gt; null then
		return translation.matchKeywords(_keywords, _matchAll);
	endif;

end;</source>
        <Parameter name="_selectedLocale" type="CM_Locale"/>
        <Parameter name="_keywords" type="StringArray"/>
        <Parameter name="_matchAll" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputAsCSV" id="54e94f72-5718-4913-8d24-4cc9ba128110">
        <source>outputAsCSV(_file : File; _targetLocale : String; _categoryName : String; 
		_doShortText : Boolean; _createTestLoadFile : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
/*	Comma = #'2C';
	Text = XLAT_Translation::text.name;
	ShortText = XLAT_Translation::shortText.name; */
	//30 Nov 2017	NDL	TFS 7718
	Text = "text";
	ShortText = "shortText";

vars
	translation : XLAT_Translation;
	csvRecord : String;

begin
	csvRecord := _targetLocale.csvEncode &amp; Comma &amp;
				 _categoryName.csvEncode &amp; Comma &amp;
				 self.number.String.csvEncode &amp; Comma &amp;
				 Text.csvEncode &amp; Comma &amp;
				 self.vDefaultMessage.csvEncode;

	if _createTestLoadFile then
		csvRecord := csvRecord &amp; Comma &amp; ('ZZZ ' &amp; self.vDefaultMessage).csvEncode;
		//csvRecord := csvRecord &amp; Comma &amp; ('ZZZZZZZZZZZZZZZZZZZZZZZZZZ').csvEncode;
	else
		// If there is a translation for the first selected locale, add as the sixth field of the csv record
		translation := self.allTextByLocale[_targetLocale];
		
		if translation &lt;&gt; null then
			csvRecord := csvRecord &amp; Comma &amp; translation.text.csvEncode;
		else
			csvRecord := csvRecord &amp; Comma;
		endif;
	endif;
	_file.writeLine(csvRecord);

	// Where required, export a translation record for 'shortText' too.
	if _doShortText and self.vDefaultShortMessage &lt;&gt; null then

		// Build the first five fields of the csv record for short text.
		csvRecord := _targetLocale.csvEncode &amp; Comma &amp;
					 _categoryName.csvEncode &amp; Comma &amp;
					 self.number.String.csvEncode &amp; Comma &amp;
					 ShortText.csvEncode &amp; Comma &amp;
					 self.vDefaultShortMessage.csvEncode;
					 
		if _createTestLoadFile then
				//csvRecord := csvRecord &amp; Comma &amp; ('ZZZZZZZZZZZZZZZZZZ ' ).csvEncode;
				csvRecord := csvRecord &amp; Comma &amp; ('ZZZ ' &amp; self.vDefaultShortMessage).csvEncode;
		else
			// If there is a translation for the first selected locale, add as the sixth field of the csv record
			translation := self.allTextByLocale[_targetLocale];
			if translation &lt;&gt; null then
				csvRecord := csvRecord &amp; Comma &amp; translation.shortText.csvEncode;
			else
				csvRecord := csvRecord &amp; Comma;
			endif;
		endif;
		_file.writeLine(csvRecord);
	endif;

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_targetLocale" type="String"/>
        <Parameter name="_categoryName" type="String"/>
        <Parameter name="_doShortText" type="Boolean"/>
        <Parameter name="_createTestLoadFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setToBeReviewedFlag" id="0409dc1d-0c92-444f-a7ab-1bd2a15431df">
        <updating/>
        <source>setToBeReviewedFlag(set : Boolean) updating;

// The To Be Reviewed flag indicates that a developer has updated the System Default Locale text, and users should
// review their translation(s). The flag is not currently automatically reset when the text is updated
// in case there are multiple translations (for different locales) to be reviewed, so the flag needs to be 
// explicitly reset (from the menu). This could be changed if it becomes a pain
	
begin
	if toBeReviewedFlag &lt;&gt; set then
		toBeReviewedFlag := set;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFromConstant" id="51130829-b59b-487c-9a84-656a6698cfac">
        <updating/>
        <source>updateFromConstant(_category : XLAT_Category; _constant	: GlobalConstant; _constantCategoryName : String) updating;

// ---------------------------------------------------------------------------
// R Barr 	8/8/06	Parse XML on constant and create or update locale speciifc translations
//
// ---------------------------------------------------------------------------

vars
	root		: CM_Root;
	text		: String;
	shortText	: String;
	
	xmlDoc		: CM_XMLDocument;
	xmlArray	: JadeXMLElementArray;
	xmlElem		: JadeXMLElement;
	localeName	: String;
	permObj		: CM_PermissionObject;
	defaultLocale	: CM_Locale;
begin
	
	root := _category.myRoot;
	self.initialise(_category, _constant, _constantCategoryName, null, null);

	
	if _category.constantCategoryName = XLAT_Permissions then
		// uses not-well-formed xml
		create permObj transient;
		permObj.setFromXML(_constant);
		self.updateLocaleTranslation(root, root.getStandardTextLocale(false), permObj.description, null, null, false);

	else
	
		defaultLocale := root.getLocale(StandardTextLocaleStr, true);
	
		// parse xml text and update each locale translation	
		create xmlDoc transient;
		create xmlArray transient;
		
		xmlDoc.parseString(self.myGlobalConstant.text);
		xmlDoc.getElementsByTagName(XMLTag_LocaleMsg, xmlArray);
	
		foreach xmlElem in xmlArray where xmlElem.attributes.size &gt; 0 do
			localeName := xmlElem.attributes[1].value;
			if localeName = null then
				app.raiseCMException2(MethodWithNullParam, method.name, 'localeName', null, null);
				return;
			endif;
			if localeName &lt;&gt; StandardTextLocaleStr then
				// Only update Standard Locale from Global Constant
				continue;
			endif;
			
			text 	  := xmlElem.getTagValueOfName(XMLTag_Msg);
			shortText := xmlElem.getTagValueOfName(XMLTag_ShortMsg);
	
			self.updateLocaleTranslation(root, defaultLocale, text, shortText, null, false);
		endforeach;

	endif;

		
epilog
	delete xmlDoc;
	delete xmlArray;
	delete permObj;
end;</source>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <Parameter name="_constantCategoryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateGlobalConstant" id="4c1505e7-626e-4d3c-82fe-29af60a8d7bf">
        <source>updateGlobalConstant(_proxyIn : XLAT_TranslationsAndGCProxy);

// new translatable text item - create a corresponding global constant

vars
	localProxy 	: XLAT_TranslationsAndGCProxy;
	proxy		: XLAT_TranslationsAndGCProxy;
	translation	: XLAT_Translation;
begin

	if _proxyIn = null then
		create localProxy transient;
		foreach translation in allTextByLocale do
			localProxy.addText(translation.myLocale, translation.text, translation.shortText, myCategory);
		endforeach;
		proxy := localProxy;
	else
		proxy := _proxyIn;
	endif;

	if self.hasGlobalConstant then
		proxy.setConstant(self.myGlobalConstant);
		// udpate global constant text
	
		self.myGlobalConstant.setText(proxy.buildXml);
	endif;

epilog
	delete localProxy;
end;
</source>
        <Parameter name="_proxyIn" type="XLAT_TranslationsAndGCProxy"/>
    </JadeMethod>
    <JadeMethod name="updateLocaleTranslation" id="1848b303-b411-4d95-aad1-d897f091dba3">
        <updating/>
        <source>updateLocaleTranslation(_root : CM_Root; _locale : CM_Locale; _text, _shortText : String; _proxy : XLAT_TranslationsAndGCProxy; _updateConstant : Boolean) updating;

// R Barr 	8/8/06	Create or update a locale-specific translation

vars
	translation	: XLAT_Translation;
	isNew		: Boolean;
	isChanged	: Boolean;
	defaultTranslation : XLAT_Translation;
	defaultLocale : CM_Locale;
	keyword : XLAT_Keyword;

begin
	translation := self.getTranslation(_locale);

	// create translation, only if required
	if translation = null and (_text &lt;&gt; null or _shortText &lt;&gt; null) then
		create translation persistent;
		isNew := true;
	endif;

	// store the new translated text values, if any
	if translation &lt;&gt; null then

		isChanged := _text &lt;&gt; translation.text or _shortText &lt;&gt; translation.shortText;

		// developer updating System Default Locale text - set the To Be Reviewed flag
		if _locale.localeId = StandardTextLocaleStr and (isNew or isChanged) then
			self.setToBeReviewedFlag(true);
		endif;

		translation.update(_root, self, _locale, _text, _shortText);
	endif;

// 22/02/2011 cnwcs5 par 27084 - start		
	// only update global constant xml text if the developer has updated the system default locale text
	if app.isDevelopmentSystemMain() and app.isSpecial() then	// new

		if self.hasGlobalConstant and
		   _locale.localeId = StandardTextLocaleStr and _updateConstant then
			self.updateGlobalConstant(_proxy);
		endif;
	endif;														// new
// 22/02/2011 cnwcs5 par 27084 - end	
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_shortText" type="String"/>
        <Parameter name="_proxy" type="XLAT_TranslationsAndGCProxy"/>
        <Parameter name="_updateConstant" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="usesShortText" id="5dbdd034-ee18-459b-ab8f-e2df85e5ef70">
        <source>usesShortText():Boolean;

begin
	return myCategory.usesShortText;
end;</source>
