    <JadeMethod name="setActionTypeCombo" id="9e161b8e-9165-4849-abbd-52867e067afd">
        <source>setActionTypeCombo(_cmb: ComboBox input);
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_cmb.clear;
	
	_cmb.addItem(EDIAction_Add);
	_cmb.addItem(EDIAction_Complete);
	_cmb.addItem(EDIAction_Remove);
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="6b6bd6e6-529f-4284-8196-d386a88c901c">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
 	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_Keyword);
		theForm.tblInput1.enableRowByName(ETRow_EDIFileType);
		theForm.tblInput1.enableRowByName(ETRow_ActionObject);
		theForm.tblInput1.enableRowByName(ETRow_ActionType);
	
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_EDIAction);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_Keyword);
		theForm.tblInput1.enableRowByName(ETRow_EDIFileType);
		theForm.tblInput1.enableRowByName(ETRow_ActionObject);
		theForm.tblInput1.enableRowByName(ETRow_ActionType);
	endif;

	

end;</source>
    </JadeMethod>
