    <JadeMethod name="translateForm" id="cf830919-c4d3-46a2-89de-16d265fc18ba">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015185, locale);
	btnChecks.translateCaption(Xlat_0015186, locale);
	btnRemove.translateCaption(Xlat_0015187, locale);
	btnSearch.translateCaption(Xlat_0019065, locale);
	lblId.translateCaption(Xlat_0015188, locale);
	lblIsoType.translateCaption(Xlat_0015189, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtIsoType_change" id="086e7013-132f-4d17-934a-461e6bba921a">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtIsoType_change(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwndl1	Initial creation

*/

vars

begin

	if self.txtIsoType.text &lt;&gt; null then
		self.txtIsoType.text := self.txtIsoType.text.toUpper;
