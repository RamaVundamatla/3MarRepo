    <JadeMethod name="setFilterString" id="0ddd5db1-2716-4b15-8863-eec0b398a339">
        <source>setFilterString();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2013	cnwndl1	Initial creation
16/03/2015	cnwmh5	Transient Leaks
18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
20 Oct 2020	jlgdap1	TFS 50193 PRP VBS Error: 14025 Maximum Number of ListBox entries exceeded
*/

vars

	yesString : String;
	noString : String;
	outputString : String;
	
	strArray : StringArray;
	str : String;
	localTS : TimeStamp;
	systemDate : Date;
begin

	create strArray transient;
	
	localTS.cnEcSetDateAndTime(self.txtDate.getDate,TimeStartOfDay);									// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	systemDate := self.localToSystemTime(localTS).date();												// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.myTerminal.myVehicleBookingTerminal.getBookingSummaryData(systemDate,	//self.txtDate.getDate,// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
																	self.chkInclUnbooked.value,
																	self.chkInclBooked.value,
																	self.chkInclUsed.value,
																	self.myFilterCarrier,  
																	self.myFilterDriver,
																	self.myFilterVehicle,
																	false,
																	strArray
																	);

	if self.chkInclUnbooked.value then
		yesString := self.chkInclUnbooked.caption;
	else
		noString := self.chkInclUnbooked.caption;
	endif;
	
	if self.chkInclBooked.value then
		if yesString &lt;&gt; null then
			yesString := yesString &amp; ", " &amp; self.chkInclBooked.caption;
		else
			yesString := self.chkInclBooked.caption;
		endif;
	else
		if noString &lt;&gt; null then
			noString := noString &amp; ", " &amp; self.chkInclBooked.caption;
		else
			noString := self.chkInclBooked.caption;
		endif;
	endif;
	
	if self.chkInclUsed.value then
		if yesString &lt;&gt; null then
			yesString := yesString &amp; ", " &amp; self.chkInclUsed.caption;
		else
			yesString := self.chkInclUsed.caption;
		endif;
	else
		if noString &lt;&gt; null then
			noString := noString &amp; ", " &amp; self.chkInclUsed.caption;
		else
			noString := self.chkInclUsed.caption;
		endif;
	endif;

	outputString := "*** " &amp; app.getErrorString(Filter_criteria) &amp; " ***" &amp; CrLf;
	
	if yesString &lt;&gt; null then
		outputString := outputString &amp; Tab &amp; yesString &amp; " = " &amp; true.getYesNo &amp; CrLf;
	endif;
	if noString &lt;&gt; null then
		outputString := outputString &amp; Tab &amp; noString &amp; " = " &amp; false.getYesNo &amp; CrLf;
	endif;
	outputString :=  outputString &amp; Tab &amp; app.getErrorString(Carrier) &amp; " = " &amp; self.cmbCarrier.text &amp; ", ";
	outputString := outputString &amp; app.getErrorString(Driver) &amp; " = " &amp; self.cmbDriver.text &amp; ", ";
	if self.cmbVehicle.visible then 																			// TFS 50193
		outputString := outputString &amp; app.getErrorString(Vehicle) &amp; " = " &amp; self.cmbVehicle.text &amp; CrLf;
	elseif self.txtVehicle.visible then																			// TFS 50193
		if self.txtVehicle.text.trimBlanks = null then															// TFS 50193
			outputString := outputString &amp; app.getErrorString(Vehicle) &amp; " = " &amp; Any_String &amp; CrLf;				// TFS 50193
		else																									// TFS 50193
			outputString := outputString &amp; app.getErrorString(Vehicle) &amp; " = " &amp; self.txtVehicle.text &amp; CrLf;	// TFS 50193
		endif;																									// TFS 50193
	endif;																										// TFS 50193
	
	outputString := outputString &amp; "*** " &amp; app.getErrorString(Vehicle_bookings_summary) 
								&amp; " *** " &amp; app.getErrorString1(As_At_Date,self.systemToLocalTime(app.actualTimeServer).Time.asStringJMT) &amp; CrLf;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach str in strArray do
		outputString := outputString &amp; Tab &amp; str &amp; CrLf;
	endforeach;
	
	self.txtFilterSummary.text := outputString;

epilog
	delete strArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="ccfd3f89-74be-4a1d-8f50-dd243174a3cf">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

