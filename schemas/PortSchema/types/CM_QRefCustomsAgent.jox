    <JadeMethod name="setComboValues" id="70b55891-dbe4-4bd2-903c-bb3fe5f518e2">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	con			: CM_CustomsAgent;
	conDict		: CM_CustomsAgentByCodeDict;
	qrl				: CM_QReferenceLookup;
begin
	_combo.clear();
	conDict := app.myRoot.allCustomsAgents;
	foreach con in conDict do
		_combo.itemObject[_combo.addItem(con.code &amp; Tab &amp; con.name)] := con;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="d1399a12-772d-4c56-88f3-f31b6774e838">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	ca		: CM_CustomsAgent;
	conDict	: CM_CustomsAgentByCodeDict;
	tmpValue: String;
	
begin

	if _value.isKindOf( CM_CustomsAgent ) then
		return _value;
	endif;
	
	tmpValue := _value.String.toUpper();
	conDict	:= app.myRoot.allCustomsAgents;
	
	foreach ca in conDict do
		if ca.code.toUpper() = tmpValue then
			return ca;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="60aaaea0-3e24-4dcb-aac5-4188f719a474">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _value &lt;&gt; null then
		return _value.CM_CustomsAgent.code;
	endif;

	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="d2cfd52b-ebed-43fe-ac42-ac545708befd">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
*/

vars
	returnVal		: CM_CustomsAgent;
	
begin
	if _value &lt;&gt; null and _value.isKindOf(CM_CustomsAgent) then
		returnVal := _value.CM_CustomsAgent;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="9171ab40-ed39-46f0-a426-dedbab499dfa">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	customsAgent : CM_CustomsAgent;

begin
	if _value.isKindOf(CM_CustomsAgent) then
		if _sending then
			return _value.CM_CustomsAgent.code;
		else
			return _value;
		endif;
	elseif _value.isKindOf(String) then
		customsAgent := app.myRoot.allCustomsAgents[_value.String];
		if customsAgent &lt;&gt; null then
			if _sending then
				return customsAgent.code;
			else
				return customsAgent;
			endif;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
