    <JadeMethod name="doSave" id="c150f553-2b06-44a9-acf4-dba3de79ad75">
        <updating/>
        <source>doSave() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/

vars
	saveOk: Boolean;
	saveAs : Boolean;
	invalidYA	: Boolean;
	ya : CM_YardAllocation;
begin
	//par 19363
	invalidYA := false;
	on Exception do app.handleDeletedObject(exception, self.myYardAllocation, invalidYA);

	if self.myYardAllocation &lt;&gt; null then  //creating new YA
		if not self.isBulkEdit() then  //check self.myYardAllocation is single allocation edit
			create ya transient;
			//par 19363 if self.myYardAllocation is invalid exception occurs and invalidYA set to true
			ya.setCode(self.myYardAllocation.code);  
			
			if invalidYA = true then
				saveAs := true;
			else
				saveAs := false;
			endif;
		endif;
	endif;

	if self.isBulkEdit() then
		saveOk := self.saveDataBulk(false);
	else
		saveOk := self.saveData(saveAs);  //originally 'false', but set to saveAs if invalid object or not
	endif;
	
	if saveOk then
		//par 23253 cnwjo3.  Can't unload form since it clears myYardAllocation value
		//self.unloadForm();
		self.visible := false;
	endif;
epilog
	delete ya;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAs" id="52fa0888-1aea-4ea8-b86c-0ef8364d432f">
        <updating/>
        <source>doSaveAs() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/

vars
	saveOk: Boolean;
begin
	if self.isBulkEdit() then
		saveOk := self.saveDataBulk(true);
	else
		saveOk := self.saveData(true);
	endif;
	
	if saveOk then
		//par 23253 cnwjo3.  Can't unload form since it clears myYardAllocation value
		//self.unloadForm();
		self.visible := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearchYATemplates" id="b8f56b52-b007-4581-9a56-8f4339c4c196">
        <source>doSearchYATemplates();
//Date		        Who		   Reason
//30 January 2009	cnwdw1	
//25 Feb 2022       navnk20    BUG 52933 MTN - Yard Allocation Manager - Unhandled exception when searching for a template
//
vars
	theForm : CMUI_YACriteriaSearchForm;
	yardAlloc : CM_YardAllocation;
	searcher: CMIF_YACriteriaSearch;
begin
	create searcher transient;
	theForm := app.loadForm(CMUI_YACriteriaSearchForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YACriteriaSearchForm;
	if theForm = null then
		return;
	endif;

	theForm.set(searcher);
	theForm.setParentForm(self);
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		// Do the search and update the list used by the combo
		self.allYATemplates.clear();
		searcher.search(self.allYATemplates, self.myTerminal.allYATemplates);
		if self.allYATemplates.size = 0 then
			self.getTerminal.allYATemplates.copy(self.allYATemplates);
		endif;
		self.populateTemplates();
		//self.cmbYATemplate.listIndex := 1;               //25.02.2022 navnk20 #52933
	    if self.cmbYATemplate.listCount &gt; 0 then           //25.02.2022 navnk20 #52933 
			self.cmbYATemplate.listIndex := 1;             //25.02.2022 navnk20 #52933 
			self.doTemplateSelected(self.cmbYATemplate.listObject.CM_YATemplate);	//25.02.2022 navnk20 #52933 
		else                                               //25.02.2022 navnk20 #52933 
			app.msgBox(app.getErrorString(No_Template), app.getErrorString(Warning), MsgBox_OK_Only);    //25.02.2022 navnk20 #52933 
		endif;                                             //25.02.2022 navnk20 #52933 
	endif;

epilog
	delete theForm;
	delete searcher;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTemplateSelected" id="6d616dc5-cc1f-401e-a881-d90b252b03fd">
        <source>doTemplateSelected(_yaTemplate: CM_YATemplate);
//04 August 2008	cnwdw1	
// adm 190509 Par 19238 
vars
	templateYA : CM_YardAllocation;
	criteria,proxyCriteria	: CM_YACriteria;
begin
	self.allTemplateCriteria.purge;
	if _yaTemplate &lt;&gt; null then
		templateYA := _yaTemplate.myYardAllocation;
		foreach criteria in templateYA.allCriteria
		where not criteria.myYACriteriaType.isKindOf(CM_YATypeImexStatus) do
			create proxyCriteria transient;
			proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
			self.allTemplateCriteria.add( proxyCriteria.getTransient() );
		endforeach;
	endif;
	
	self.displayCriteriaDesc();
	
	self.formatName(false);
	
end;</source>
        <Parameter name="_yaTemplate" type="CM_YATemplate"/>
    </JadeMethod>
    <JadeMethod name="doTestOperTemplCriteriaClash" id="46086f46-03ed-4580-a033-3cbb490375a2">
        <updating/>
        <source>doTestOperTemplCriteriaClash(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		20 July 2009 by cnwjo3
//
// Purpose:		show warning if operational and template criteria are the same
//				Note:  Possibly this will be removed if if the criteria are just shifted from template to operational
//
vars
	tempOperDuplicates	: String;
	criteria,
	templateCrit		: CM_YACriteria;
	criteriaType 		: CM_YACriteriaType;
	cmifObj				: CMIF_Object;
	cmif_yaCritPri		: CMIF_YACriteriaPriority;
	yatemp				: CM_YATemplate;
begin
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	yatemp := combobox.listObject.CM_YATemplate;

	if yatemp = null then
		return;
	endif;
	
	tempOperDuplicates := "";
	foreach cmifObj in self.allOperationalCriteria do
		if cmifObj.isKindOf(CMIF_YACriteriaPriority) then
			cmif_yaCritPri := cmifObj.CMIF_YACriteriaPriority; 
			criteriaType := cmif_yaCritPri.myProxy.myYACriteriaType;
			foreach templateCrit in yatemp.myYardAllocation.allCriteria do
				if templateCrit.myYACriteriaType = criteriaType then
					tempOperDuplicates := tempOperDuplicates &amp; criteriaType.description &amp; ",";
				endif;
			endforeach;
		endif;
	endforeach;

	if tempOperDuplicates.length &gt; 0 then
		tempOperDuplicates := tempOperDuplicates[1:tempOperDuplicates.length-1];
		app.raiseCMWarning2(Err_YA_OperTempCritDuplicates,combobox.text,tempOperDuplicates,null,null,null);
	endif;	

	if app.myPassport.hasWarnings then
		app.showErrorWarningDialog(	app.getErrorString( YardAllocation ),app.myPassport, ErrWarnMode_AddUpdate );
		combobox.setFocus();
	endif;	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnload" id="b0afcde6-0243-482e-a9f9-eec60efe5a1d">
        <updating/>
        <source>doUnload() updating;

/*

Purpose:		Performed on unload of form			

Parameters:			

Return Value:		


Date			Who		Reason
05 August 2008	consw1	Initial creation

