    <JadeMethod name="getPaymentType" id="8f80c38b-cbd9-4706-b67d-d175c4e5e16a">
        <source>getPaymentType() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgab1	Initial creation	TFS39250

*/

vars
	paymentType : Integer;
	debtorTerminal : CM_DebtorTerminal;
	firstInvoiceLine : CM_InvoiceLine;
begin
	if self.myVoyage &lt;&gt; null then
		paymentType := self.myVoyage.paymentType;
		if paymentType = PaymentType_AutoCollection
		or paymentType = PaymentType_PrePay
		or paymentType = PaymentType_PostPay then
			return paymentType;
		endif;
		
	endif;
	
	debtorTerminal:= self.myDebtorTerminal;
	if debtorTerminal &lt;&gt; null then
		paymentType := debtorTerminal.paymentType;
	endif;
	
	if paymentType = PaymentType_AutoCollection
	or paymentType = PaymentType_PrePay
	or paymentType = PaymentType_PostPay then
		return paymentType;
	endif;
		

	return PaymentType_AutoCollection; // Default
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProformaInvoiceType" id="ba2cde1a-5f4a-4602-81b0-646222023600">
        <source>getProformaInvoiceType() : CM_InvoiceDesc;

/*

Purpose:			TFS 41026	

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2018	jlgab1	Initial creation

*/

vars
	proforma : CM_ProformaDetails;
begin
	proforma := self.allProformaDetails.first;
	
	if proforma&lt;&gt; null then
		if proforma.myInvoiceLineType&lt;&gt; null then
			return proforma.myInvoiceLineType.invoiceType;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
