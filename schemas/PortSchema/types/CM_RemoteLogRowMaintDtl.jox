    <JadeMethod name="doCreateUpdateLogRow" id="1a5d2321-ccae-4c85-9c94-3d6169fe7226">
        <source>doCreateUpdateLogRow(): String;
/* ---------------------------------------------------------------------------
Created:	03 May 2011	by cnwvu1

Purpose:	ccms 1119, PAR 27433
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	rtnStr			: String;
	cmifLogRow		: CMIF_LogRowRestriction;
	passport		: CM_Passport;
	errorStr		: String;
	newRow			: CM_LogController;
	err				: CM_Error;
	actionAdd		: Boolean;
	
begin
	
	create cmifLogRow transient;
	passport	:= app.myPassport;

	errorStr	:= self.setCmifLogRow(cmifLogRow, passport);
	if errorStr &lt;&gt; null then
		return errorStr;
	endif;
	

	if self.action = self.ACTION_ADD then
		actionAdd := true;
	else
		actionAdd := false;
	endif;
	
	if actionAdd then
		app.writeLog('Log row creation via XML: Before trxCreateLogRow', LogINFO);
		app.myTrxCA.trxCreateLogRow(cmifLogRow, newRow, passport);
	else
		app.writeLog('Log row update via XML: Before trxUpdateLogRow', LogINFO);
		app.myTrxUA.trxUpdateLogRow(cmifLogRow, passport);
	endif;
	
	if passport.trxCompletedOK() then
		if actionAdd then
			app.writeLog('After trxCreateLogRow successful', LogINFO); 
		else
			app.writeLog('After trxUpdateLogRow successful', LogINFO); 
		endif;
		return null;
		
	else
		if actionAdd then
			app.writeLog('After trxCreateLogRow unsuccessful', LogINFO); 
		else
			app.writeLog('After trxUpdateLogRow unsuccessful', LogINFO); 
		endif;
		foreach err in passport.allErrors do
			if rtnStr = null then
				rtnStr	:=	"Log Row " &amp; self.logAreaId &amp; ", " &amp; self.logRowId &amp; " - " &amp; err.text;
			else
				rtnStr	:=	rtnStr &amp; ", Log Row " &amp; self.logAreaId &amp; ", " &amp; self.logRowId &amp; " - " &amp; err.text;
			endif;
		endforeach;
		if rtnStr.length &gt; 1 then
			app.writeLog(rtnStr, LogINFO);
			return rtnStr;
		endif;
	endif;
	
	return rtnStr;

epilog
	if cmifLogRow &lt;&gt; null then			// 10/06/2011 cnwmh5 #27713
		delete cmifLogRow.myProxyLogController;
	endif;
	delete cmifLogRow;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTokensForDelimiterTrimBlank" id="fef732f9-76d7-429c-85e3-d92ab308581a">
        <source>getTokensForDelimiterTrimBlank(_str: String; _arr: StringArray input) protected;
/* ---------------------------------------------------------------------------
Created:	06 May 2011	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	i : Integer;
	
begin
	
	_arr.clear();
	if _str = null then
		return;
	endif;
	
	_str.getTokensForDelimiter(",", _arr);
	foreach i in 1 to _arr.size do
		_arr[i] := _arr[i].trimBlankCharacters();
	endforeach;


end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_arr" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCmifLogRow" id="11f4f29c-5bce-4605-9d64-1167bfb90b7a">
        <source>setCmifLogRow(_cmifLogRow: CMIF_LogRowRestriction input; _passport : CM_Passport): String protected;
/* ---------------------------------------------------------------------------
Created:	03 May 2011	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	terminal		: CM_Terminal;
	terminalArea	: CM_TerminalArea;
	actionUpdate	: Boolean;
	logRowFound		: Boolean;
	locn			: CM_LocationsController;
	logRow			: CM_LogController;
	logRowRestrict	: CM_LocationRestrictLog;
	tmpStrArray		: StringArray;
	tmpStr			: String;
	tmpOperator		: CM_Operator;
	logRowInfo		: String;
	tmpObj			: Object;
	tmpCode			: CM_Code;
	tmpCodeColl		: CM_CodesByCodeDict;
	loadStateSet	: Boolean;
	tmpPreviousName	: String;
	mixedRowSet		: Boolean;
	// following variables with p_ means p_ means parameter variables for setting _cmifLogRow
	p_isMixedRow	: Boolean;
	p_rowArea		: CM_LogArea;
	p_logRowId		: String;
	p_allOperators,		// 
	p_allSpecies,
	p_allGrades,
	p_allLogTypes,
	p_allTreatments,
	p_allLengths	: ObjectArray;
	p_status		: Integer;
	p_comment		: String;
	p_docketChecked,
	p_checkScaled,
	p_inspected,
	p_fumigated		: Boolean;
	// following parameters are beyond XML file
	p_estimatedMaxVolume: Real;
	p_transport			: Integer;
	p_ignoreArchiving	: Boolean;
	p_width				: Real;
	p_isSplit			: Boolean;
	p_user				: String;
	p_myRowAreaRowTo	: CM_RowAreaRow;
	p_previousRow		: String;
	p_distanceFromPrevious: Real;
	
	
begin

	create p_allOperators	transient;
	create p_allSpecies		transient;
	create p_allGrades		transient;
	create p_allLogTypes	transient;
	create p_allTreatments	transient;
	create p_allLengths		transient;
	create tmpStrArray		transient;

	if self.action = self.ACTION_ADD then
		actionUpdate := false;// it is ok - do nothing
	elseif self.action = self.ACTION_UPDATE then 	// it is ok - do nothing
		actionUpdate := true;
	else //*************************************************************************************************************************
		return app.getErrorString5(UnknowXmlLogRowMntAction, self.action, self.logAreaId, self.logRowId, self.ACTION_ADD, self.ACTION_UPDATE);
	endif;

	terminal:= _passport.myTerminal;
	p_user	:= _passport.getUserCode(); // recording who is making changes

	// permission for Log Row Maintenance should be on for a user
	if not _passport.myUser.canDo(terminal, PmLogRowMaint) then
		return app.getErrorString1(NoLogRowMaintenancePermission, p_user);
	endif;
	
	// -----------------------------------------------------------------
	// 							Terminal Area
	// -----------------------------------------------------------------
	if self.logAreaId = null then
	//	return app.getErrorString1(REQUIRED_FIELD, app.getErrorString(TerminalArea));
		return app.getErrorString1(Input_required_field_Required, app.getErrorString(TerminalArea)); // cnwdb2	PAR 35364


	
	endif;
	terminalArea:= terminal.allTerminalAreas[self.logAreaId];
	if (terminalArea = null) or (not terminalArea.isKindOf(CM_LogArea)) then
		return app.getErrorString1(ERR_INVALID_TA_ID, self.logAreaId &amp; ", "&amp; self.logRowId);
	endif;
	p_rowArea := terminalArea.CM_LogArea;

	// -----------------------------------------------------------------
	// 							Log Row
	// -----------------------------------------------------------------
	p_logRowId := self.logRowId;
	if p_logRowId = null then
	//	return app.getErrorString1(REQUIRED_FIELD, app.getErrorString(LogRow));
		return app.getErrorString1(Input_required_field_Required, app.getErrorString(LogRow)); // cnwdb2	PAR 35364
	endif;
	// 27957 Aug 2011 cnwjre1 extend the code to handle archived and empty areas
	foreach locn in p_rowArea.allLocationsControllers do
		if locn.ident = p_logRowId then
			logRowFound := true;
			break;
		endif;
	endforeach;
	if not logRowFound then
		foreach locn in p_rowArea.allEmptyLogControllers do
			if locn.ident = p_logRowId then
				logRowFound := true;
				break;
			endif;
		endforeach;
	endif;
	if not logRowFound then
		foreach locn in p_rowArea.allLCsArchived do
			if locn.ident = p_logRowId then
				logRowFound := true;
				break;
			endif;
		endforeach;
	endif;
	if logRowFound then
		if not locn.isKindOf(CM_LogController) then
			return app.getErrorString1(Err_InvalidLocation, self.logAreaId &amp; ", "&amp; p_logRowId);
		endif;
		logRow			:= locn.CM_LogController;
		logRowRestrict	:= logRow.myLocationRestriction.CM_LocationRestrictLog;
	endif;
	if actionUpdate then	// update
		if logRow = null then	//doesn't exist for update - not found for update
			return app.getErrorString1(LocationNotFoundForUpdate, self.logAreaId &amp;", "&amp; p_logRowId);
		endif;
	else		// creation
		if logRow &lt;&gt; null then	// exists already
			return app.getErrorString1(ExistinLocationNotCreated, self.logAreaId &amp;", "&amp; p_logRowId);
		endif;
	endif;
	
	logRowInfo := " " &amp; app.getErrorString(LogRow) &amp; " " &amp; self.logAreaId &amp; ", " &amp; p_logRowId;

	
	// -----------------------------------------------------------------
	// 							Suppplier
	// -----------------------------------------------------------------
	if actionUpdate and (not self.supplierXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		foreach tmpObj in logRowRestrict.allOperators do	
			p_allOperators.add(tmpObj);
		endforeach;
		
	else	// when create or XML tag included - need to correct values from XML file
		if self.supplier &lt;&gt; null then
			self.getTokensForDelimiterTrimBlank(self.supplier, tmpStrArray);
			foreach tmpStr in tmpStrArray do
				tmpOperator := app.myRoot.allOperators[tmpStr];
				if tmpOperator = null then
					return app.getErrorString1(Err_InvalidSupplier, tmpStr) &amp; logRowInfo;
				endif;
				p_allOperators.add(tmpOperator);
			endforeach;
			if p_allOperators.size &gt; 1 then
				p_isMixedRow := true;
				mixedRowSet := true;		// 28580 Nov 2011 save if set explicitly
			endif;
		endif;
		
	endif;
	
	// -----------------------------------------------------------------
	// 							Species
	// -----------------------------------------------------------------
	if actionUpdate and (not self.speciesXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		foreach tmpObj in logRowRestrict.allLogSpecies do	
			p_allSpecies.add(tmpObj);
		endforeach;
		
	else	// when create or XML tag included - need to correct values from XML file
		if  (p_allOperators &lt;&gt; null) and (self.species &lt;&gt; null) then
			self.getTokensForDelimiterTrimBlank(self.species, tmpStrArray);
			foreach tmpStr in tmpStrArray do
				foreach tmpObj in p_allOperators do
					tmpOperator	:= tmpObj.CM_Operator;
					tmpCodeColl	:= tmpOperator.getAllLogSpecies();
					tmpCode		:= tmpCodeColl[tmpStr];
					if not tmpCode.isKindOf(CM_LogSpecies) then
						return app.getErrorString1(LogSpeciesInvalid, tmpStr) &amp; logRowInfo;
					endif;
					if tmpCode &lt;&gt; null then
						break;
					endif;
				endforeach;
				if tmpCode = null then
					return app.getErrorString1(LogSpeciesInvalid, tmpStr) &amp; logRowInfo;
				endif;
				p_allSpecies.add(tmpCode);
			endforeach;
			if p_allSpecies.size &gt; 1 then
				p_isMixedRow := true;
				mixedRowSet := true;		// 28580 Nov 2011 save if set explicitly
			endif;
		endif;
		
	endif;
	
	// -----------------------------------------------------------------
	// 							Grades
	// -----------------------------------------------------------------
	if actionUpdate and (not self.gradeXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		foreach tmpObj in logRowRestrict.allLogGrades do	
			p_allGrades.add(tmpObj);
		endforeach;
		
	else	// when create or XML tag included - need to correct values from XML file
		if  (p_allSpecies &lt;&gt; null) and (self.grade &lt;&gt; null) then
			self.getTokensForDelimiterTrimBlank(self.grade, tmpStrArray);
			foreach tmpStr in tmpStrArray do
				foreach tmpObj in p_allSpecies do
					tmpCode		:= tmpObj.CM_LogSpecies.allLogGrades[tmpStr];
					if not tmpCode.isKindOf(CM_LogGrade) then
						return app.getErrorString1(LogGradeInvalid, tmpStr) &amp; logRowInfo;
					endif;
					if tmpCode &lt;&gt; null then
						break;
					endif;
				endforeach;
				if tmpCode = null then
					return app.getErrorString1(LogGradeInvalid, tmpStr) &amp; logRowInfo;
				endif;
				p_allGrades.add(tmpCode);
			endforeach;
			if p_allGrades.size &gt; 1 then
				p_isMixedRow := true;
				mixedRowSet := true;		// 28580 Nov 2011 save if set explicitly
			endif;
		endif;
		
	endif;
	
	
	// -----------------------------------------------------------------
	// 							Log Types
	// -----------------------------------------------------------------
	if actionUpdate and (not self.logTypeXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		foreach tmpObj in logRowRestrict.allLogTypes do	
			p_allLogTypes.add(tmpObj);
		endforeach;
		
	else	// when create or XML tag included - need to correct values from XML file
		if (p_allGrades &lt;&gt; null) and (self.logType &lt;&gt; null) then
			self.getTokensForDelimiterTrimBlank(self.logType, tmpStrArray);
			foreach tmpStr in tmpStrArray do
				foreach tmpObj in p_allGrades do
					tmpCode		:= tmpObj.CM_LogGrade.allLogTypes[tmpStr];
					if not tmpCode.isKindOf(CM_LogType) then
						return app.getErrorString1(LogTypeInvalid, tmpStr) &amp; logRowInfo;
					endif;
					if tmpCode &lt;&gt; null then
						break;
					endif;
				endforeach;
				if tmpCode = null then
					return app.getErrorString1(LogTypeInvalid, tmpStr) &amp; logRowInfo;
				endif;
				p_allLogTypes.add(tmpCode);
			endforeach;
			if p_allLogTypes.size &gt; 1 then
				p_isMixedRow := true;
				mixedRowSet := true;		// 28580 Nov 2011 save if set explicitly
			endif;
		endif;
		
	endif;
	
	// -----------------------------------------------------------------
	// 							Log Treatment
	// -----------------------------------------------------------------
	if actionUpdate and (not self.treatmentXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		foreach tmpObj in logRowRestrict.allLogTreatments do	
			p_allTreatments.add(tmpObj);
		endforeach;
		
	else	// when create or XML tag included - need to correct values from XML file
		if (p_allGrades &lt;&gt; null) and (self.treatment &lt;&gt; null) then
			self.getTokensForDelimiterTrimBlank(self.treatment, tmpStrArray);
			foreach tmpStr in tmpStrArray do
				foreach tmpObj in p_allGrades do
					tmpCode		:= tmpObj.CM_LogGrade.allLogTreatments[tmpStr];
					if not tmpCode.isKindOf(CM_LogTreatment) then
						return app.getErrorString1(LogTreatmentInvalid, tmpStr) &amp; logRowInfo;
					endif;
					if tmpCode &lt;&gt; null then
						break;
					endif;
				endforeach;
				if tmpCode = null then
					return app.getErrorString1(LogTreatmentInvalid, tmpStr) &amp; logRowInfo;
				endif;
				p_allTreatments.add(tmpCode);
			endforeach;
			if p_allTreatments.size &gt; 1 then
				p_isMixedRow := true;
				mixedRowSet := true;		// 28580 Nov 2011 save if set explicitly
			endif;
		endif;
		
	endif;
	
	// -----------------------------------------------------------------
	// 							Log Length
	// -----------------------------------------------------------------
	if actionUpdate and (not self.lengthXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		foreach tmpObj in logRowRestrict.allLogLengths do	
			p_allLengths.add(tmpObj);
		endforeach;
		
	else	// when create or XML tag included - need to correct values from XML file
		if (p_allGrades &lt;&gt; null) and (self.length &lt;&gt; null) then
			self.getTokensForDelimiterTrimBlank(self.length, tmpStrArray);
			foreach tmpStr in tmpStrArray do
				foreach tmpObj in p_allGrades do
					tmpCode		:= tmpObj.CM_LogGrade.allLogLengths[tmpStr];
					if not tmpCode.isKindOf(CM_LogLength) then
						// this is for 781 hotfix: return "Log Length " &amp; tmpStr &amp; " is invalid." &amp; logRowInfo;	//***************************************************
						return app.getErrorString1(LogLengthInvalid, tmpStr) &amp; logRowInfo;
					endif;
					if tmpCode &lt;&gt; null then
						break;
					endif;
				endforeach;
				if tmpCode = null then
					// this is for 781 hotfix: return "Log Length " &amp; tmpStr &amp; " is invalid." &amp; logRowInfo;	//***************************************************
					return app.getErrorString1(LogLengthInvalid, tmpStr) &amp; logRowInfo;
				endif;
				p_allLengths.add(tmpCode);
			endforeach;
			if p_allLengths.size &gt; 1 then
				p_isMixedRow := true;
				mixedRowSet := true;		// 28580 Nov 2011 save if set explicitly
			endif;
		endif;
		
	endif;

	// -----------------------------------------------------------------
	// 							Status
	// -----------------------------------------------------------------
	if actionUpdate and (not self.statusXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		p_status := logRow.status;
	else	// when create or XML tag included - need to correct values from XML file
		p_status := global.lcStatusStringToEnum(self.status);
	endif;
	
	// -----------------------------------------------------------------
	// 							Comment
	// -----------------------------------------------------------------
	if actionUpdate and (not self.statusXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		p_comment := logRowRestrict.comment;
	else	// when create or XML tag included - need to correct values from XML file
		p_comment := self.comment;
	endif;
	
	// -----------------------------------------------------------------
	// 							Docket Checked
	// -----------------------------------------------------------------
	if actionUpdate and (not self.docketCheckedXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		p_docketChecked := logRow.docketChecked;
	else	// when create or XML tag included - need to correct values from XML file
		p_docketChecked := self.docketChecked;
	endif;

	// -----------------------------------------------------------------
	// 							Check Scaled
	// -----------------------------------------------------------------
	if actionUpdate and (not self.checkScaledXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		p_checkScaled := logRow.checkScaled;
	else	// when create or XML tag included - need to correct values from XML file
		p_checkScaled := self.checkScaled;
	endif;

	// -----------------------------------------------------------------
	// 							Inspected
	// -----------------------------------------------------------------
	if actionUpdate and (not self.inspectedXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		p_inspected := logRow.isInspected;
	else	// when create or XML tag included - need to correct values from XML file
		p_inspected := self.inspected;
	endif;
	
	// -----------------------------------------------------------------
	// 							Fumigated
	// -----------------------------------------------------------------
	if actionUpdate and (not self.fumigatedXMLPresent) then	// if not XML tag included, keep existing value from the real location.
		p_fumigated := logRow.isFumigated;
	else	// when create or XML tag included - need to correct values from XML file
		p_fumigated := self.fumigated;
	endif;
	

	//****************************************************************************************************************
	//			The following parameters are beyond of XML file - need only keep existing on real log row
	//****************************************************************************************************************
	
	if not actionUpdate then // when create
		p_transport				:= 3; // by default
	
	else	// when update
		app.cmsBeginLoad(loadStateSet);
		_cmifLogRow.myProxyLogController := logRow.pxyCreateUpdateProxy();// self.myProxyObject.CM_LogController;
		app.cmsEndLoad(loadStateSet);
		
		p_estimatedMaxVolume	:= logRow.estimatedMaxVolume;
		p_transport				:= logRowRestrict.transportMode;
		p_ignoreArchiving		:= logRow.ignoreArchiving;
		if not mixedRowSet then
			p_isMixedRow		:= logRow.myLocationRestriction.CM_LocationRestrictLog.mixedRow;	// 28580 Nov 2011 use existing value
		endif;
		p_isSplit				:= false;
		if logRow.myRow &lt;&gt; null then
			p_width						:= logRow.myRow.width;
			_cmifLogRow.myRowAreaRow	:= logRow.myRow;
			// 27957 aug 2011 code moved inside test to handle null myRow on archived or empty areas
			if logRow.myRow.allRowControllers.size &gt; 1 then 
				p_isSplit		:= true;
			endif;
		endif;
		
		if p_isSplit then
			p_myRowAreaRowTo := null;		// cannot update from here.  Leave as null and does not update
		endif;

		// previous row
		terminalArea.CM_LogArea.getPreviousData(p_logRowId, tmpPreviousName, p_distanceFromPrevious, CM_RowArea.SEARCH_ACTUAL);
		if tmpPreviousName &lt;&gt; null and tmpPreviousName &lt;&gt; p_logRowId then
			p_previousRow := tmpPreviousName;
		endif;
		
		// distance from previous
		if p_distanceFromPrevious = null and
		   logRow.myRow &lt;&gt; null then	// it can be figured out at previous row
			p_distanceFromPrevious := logRow.myRow.getPrevGap();
		endif;
		
	endif;
	
	_cmifLogRow.set(p_rowArea,
					p_logRowId,
					p_allOperators,
					p_allSpecies,
					p_allGrades,
					p_allLogTypes,
					p_allTreatments,
					p_allLengths,
					p_status,
					p_comment,
					p_docketChecked,
					p_checkScaled,
					p_inspected,
					p_fumigated,
					p_isMixedRow,
					p_estimatedMaxVolume,
					p_transport,
					p_ignoreArchiving,
					p_width,
					p_isSplit,
					p_user,
					p_myRowAreaRowTo,
					p_previousRow,
					p_distanceFromPrevious,
					true); //cnwrd1 ccms 1134 par 35101 set this true here for isExternallyVisible for now
	
	return null;

epilog
	app.cmsEndLoad(loadStateSet);
	delete p_allOperators;
	delete p_allSpecies;
	delete p_allGrades;
	delete p_allLogTypes;
	delete p_allTreatments;
	delete p_allLengths;
	delete tmpStrArray;

end;</source>
        <access>protected</access>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0d17d0cc-4896-4db7-aa3c-8ae215dacdc3">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteLogRowMaintDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;
/* ---------------------------------------------------------------------------
Created:	03 May 2011	by cnwvu1
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_proxy, _realRemoteHdr);

	self.logAreaId				:= _proxy.logAreaId;
	self.logRowId				:= _proxy.logRowId;
	self.action					:= _proxy.action;
	self.supplier				:= _proxy.supplier;
	self.supplierXMLPresent		:= _proxy.supplierXMLPresent;
	self.species				:= _proxy.species;
	self.speciesXMLPresent		:= _proxy.speciesXMLPresent;
	self.grade					:= _proxy.grade;
	self.gradeXMLPresent		:= _proxy.gradeXMLPresent;
	self.logType				:= _proxy.logType;
	self.logTypeXMLPresent		:= _proxy.logTypeXMLPresent;
	self.treatment				:= _proxy.treatment;
	self.treatmentXMLPresent	:= _proxy.treatmentXMLPresent;
	self.length					:= _proxy.length;
	self.lengthXMLPresent		:= _proxy.lengthXMLPresent;
	self.status					:= _proxy.status;
	self.statusXMLPresent		:= _proxy.statusXMLPresent;
	self.comment				:= _proxy.comment;
	self.commentXMLPresent		:= _proxy.commentXMLPresent;
	self.docketChecked			:= _proxy.docketChecked;
	self.docketCheckedXMLPresent:= _proxy.docketCheckedXMLPresent;
	self.checkScaled			:= _proxy.checkScaled;
	self.checkScaledXMLPresent	:= _proxy.checkScaledXMLPresent;
	self.inspected				:= _proxy.inspected;
	self.inspectedXMLPresent	:= _proxy.inspectedXMLPresent;
	self.fumigated				:= _proxy.fumigated;
	self.fumigatedXMLPresent	:= _proxy.fumigatedXMLPresent;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteLogRowMaintDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForLogRowEntry" id="5a86133e-6ac2-4aac-94a9-6b3c6ee56fae">
        <updating/>
        <source>setProxyForLogRowEntry(	_logAreaId,
						_logRowId,
						_action,
						_supplier				: String;
						_supplierXMLPresent		: Boolean;
						_species				: String;
						_speciesXMLPresent		: Boolean;
						_grade					: String;
						_gradeXMLPresent		: Boolean;
						_logType				: String;	
						_logTypeXMLPresent		: Boolean;
						_treatment				: String;
						_treatmentXMLPresent	: Boolean;
						_length					: String;
						_lengthXMLPresent		: Boolean;
						_status					: String;
						_statusXMLPresent		: Boolean;
						_comment				: String;
						_commentXMLPresent		: Boolean;
						_docketChecked			: String;
						_docketCheckedXMLPresent: Boolean;
						_checkScaled			: String;
						_checkScaledXMLPresent	: Boolean;
						_inspected				: String;
						_inspectedXMLPresent	: Boolean;
						_fumigated				: String;
						_fumigatedXMLPresent	: Boolean;
						_remoteHeader 			: CM_RemoteDataHdr) updating;
/* ---------------------------------------------------------------------------
Created:	02 May 2011	by cnwvu1

Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.logAreaId				:= _logAreaId;
	self.logRowId				:= _logRowId;
	self.action					:= _action;
	self.supplier				:= _supplier;
	self.supplierXMLPresent		:= _supplierXMLPresent;
	self.species				:= _species;
	self.speciesXMLPresent		:= _speciesXMLPresent;
	self.grade					:= _grade;
	self.gradeXMLPresent		:= _gradeXMLPresent;
	self.logType				:= _logType;
	self.logTypeXMLPresent		:= _logTypeXMLPresent;
	self.treatment				:= _treatment;
	self.treatmentXMLPresent	:= _treatmentXMLPresent;
	self.length					:= _length;
	self.lengthXMLPresent		:= _lengthXMLPresent;
	self.status					:= _status;
	self.statusXMLPresent		:= _statusXMLPresent;
	self.comment				:= _comment;
	self.commentXMLPresent		:= _commentXMLPresent;
	self.docketChecked			:= _docketChecked.Boolean;
	self.docketCheckedXMLPresent:= _docketCheckedXMLPresent;
	self.checkScaled			:= _checkScaled.Boolean;
	self.checkScaledXMLPresent	:= _checkScaledXMLPresent;
	self.inspected				:= _inspected.Boolean;
	self.inspectedXMLPresent	:= _inspectedXMLPresent;
	self.fumigated				:= _fumigated.Boolean;
	self.fumigatedXMLPresent	:= _fumigatedXMLPresent;

	self.setProxy(_remoteHeader);

end;</source>
