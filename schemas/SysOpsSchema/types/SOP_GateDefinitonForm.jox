    <JadeMethod name="setMyDataClass" id="04a950d1-42b0-4c29-9f38-f01624ffc02e">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myDataClass := CM_Gate;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="9ff535d5-181f-471f-9e59-08082987d033">
        <updating/>
        <source>setTableDataFromOrganiser(_table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     27 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if _table = tblGateAreas then
		if self.mode = self.Mode_Add or self.mode = self.Mode_Update then
			self.loadGateAreas (self.myProxyObject.CM_Gate);
		else
			self.loadGateAreas (self.myCurrentObject.CM_Gate);
		endif;
	elseif _table = tblGateLanes then
		self.loadGateLanes;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTroubleInCombo" id="d968d1bc-bc4f-460d-89d5-668554573989">
        <source>setTroubleInCombo(_gate :CM_Gate) protected;
// ---------------------------------------------------------------------------
// Created:     04 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if _gate &lt;&gt; null and 
		_gate.hasPGateAreas_IN  and 
		_gate.hasTroubleGateArea_IN  then
		if _gate.allGateAreas_IN.last.isTrouble then
			cmbTroubleIn.listIndex	:= cmbTroubleIn.findStringExact (1, app.getErrorString (XLAT_P_THEN_T));
		else
			cmbTroubleIn.listIndex	:= cmbTroubleIn.findStringExact (1, app.getErrorString (XLAT_T_THEN_P));
		endif;
		
		if _gate.isTransient then
			// only enable if we are maintaing the proxy - not for the real object
			cmbTroubleIn.enabled	:= true; 
		endif;
		return;
	endif;
	
	cmbTroubleIn.listIndex 	:= -1;
	cmbTroubleIn.enabled	:= false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0a2493da-d194-4010-ba5b-c8842f325a0e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by concms1
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	canAdd	:Boolean;
begin
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	inheritMethod();
	
	self.setNavigatorHeading(self.caption);
	
	sptMain.setLeftToRightSizeAndResize(100);
	
	self.loadInterchangeAreaCombo;
	self.loadTroubleCombo;
	
	self.myAssistant.comboBoxPrinterDefs(self.cmbPrinter, app.myCurrentUserCan (self.myTerminal, PmCmpPortTableMaint), null);
	
	self.myAssistant.comboBoxWeighBridges(self.cmbWeighBridge, self.myTerminal, null);
	
	self.myAssistant.comboBoxScanReaders(self.cmbScanReader, self.myTerminal, null);
	
	canAdd	:= app.myCurrentUserCan (self.myTerminal, PmAdmRFIDTagReadMaint);
	
	self.myAssistant.comboBoxRFIDTagReaders (self.cmbRFIDReader, canAdd, null);
	self.myAssistant.comboBoxRFIDTagReaders (self.cmbRFIDReaderA, canAdd, null);
	
	//19 Mar 2019 NDL	TFS 43811 - remove add
	//canAdd	:= app.myCurrentUserCan (self.myTerminal, PmAdmBoomMaint);
	
	self.myAssistant.comboBoxBooms (self.cmbBoom, canAdd, null);
	self.myAssistant.comboBoxBooms (self.cmbBoomOut, canAdd, null);
	
	self.myAssistant.comboBoxKiosks (self.cmbKiosk, app.myCurrentUserCan (self.myTerminal, PmAdmKioskMaint), null);
	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATE_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATE_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_GATE_UPDATE), Response_Continuous, null);
	
	self.zLstDataShow;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupPopupMenuA" id="c12528f6-e148-47d2-89b3-3e32e0431250">
        <source>setupPopupMenuA()protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by concms1
// Purpose:     CCMS 1061 - gate config
//				Enable/disable popup menu items depending on the gate areas
//				selected.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2010	cnwcs5		par 22746
// ---------------------------------------------------------------------------

vars
	gate	:CM_Gate;
	usage	:CM_GateAreaUsage;
	area	:CM_GateArea;
begin
	gate	:= self.myProxyObject.CM_Gate;
	
	if gate = null then
		mnuPopupAddGateArea.enabled		:= false;
		mnuPopupRemoveGateArea.enabled	:= false;
		return;
	endif;
		
	// add gate area
	mnuPopupAddGateArea.enabled := true;

	// remove gate area
	usage	:= self.getSelected_GateAreaUsage;

	if usage = null then
		// nothing selected
		mnuPopupRemoveGateArea.enabled	:= false;
		
		return;
	endif;
	
	area := usage.myGateArea;
		
	if area.isAGate then
		mnuPopupRemoveGateArea.enabled	:= false;
	elseif area.isPGate and 
		usage.isOut and 
		gate.allGateAreas_OUT.size = 2 and		// par 22746
		gate.hasTroubleGateArea_OUT then		// par 22746
		// p-check must be first area goiing out.  if they are currently "PT" then they can't remove
		// the p-check b4 they remove trouble.  Must remove trouble first
		mnuPopupRemoveGateArea.enabled	:= false;
	else
		mnuPopupRemoveGateArea.enabled	:= true;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showLstData" id="99f51711-878c-472e-8b67-35fd1799516d">
        <source>showLstData();
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int 		:Integer;
	listbox		:CMUI_ListBox;
	gate		:CM_Gate;
	usage		:CM_GateAreaUsage;
	gateArea	:CM_GateArea;
begin 
	listbox := lstData;
	
	foreach gate in self.myTerminal.allGates do
		int := self.addTreeObject (gate.name, gate, 1, true);
		listbox.itemPicture[int] := picGate.picture;
		
		// make sure current object is selected
		if gate = self.myCurrentObject then
			listbox.listIndex := int;
		endif;
		
		if gate.allGateAreas_IN.size &gt; 0 then
			int := self.addTreeObject ('In', gate, 2, true);	
			listbox.itemPicture[int] 	:= picIn.picture;
			
			foreach usage in gate.allGateAreas_IN do
				gateArea := usage.myGateArea;
				if gateArea &lt;&gt; null then
					int := self.addTreeObject (gateArea.id, usage, 3, true);	
					listbox.itemPicture[int]	:= self.getPictureForGateArea (gateArea);
				endif;
			endforeach;
		endif;
		if gate.allGateAreas_OUT.size &gt; 0 then
			int := self.addTreeObject ('Out', gate, 2, true);		
			listbox.itemPicture[int]	:= picOut.picture;
			
			foreach usage in gate.allGateAreas_OUT do
				gateArea := usage.myGateArea;
				
				int := self.addTreeObject (gateArea.id, usage, 3, true);	
				listbox.itemPicture[int]	:= self.getPictureForGateArea(gateArea);
			endforeach;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="aa3e1297-d04c-4e58-8691-e4a2bb9925cf">
        <updating/>
        <source>showThumbnailData(_gate:CM_Gate)updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2010	cnwcs5	par 18016 - RFID tag prompt
// ---------------------------------------------------------------------------
vars
	obj : Object;
	idx : Integer;
	
begin
	if self.mode = self.Mode_View then
		self.btnEditTV.enabled := self.allowUpdate;
	endif;
		
	txtName.text		:= _gate.name;
	
	cmbICArea.refreshEntries (_gate.myDefaultInterchangeArea); 
	cmbICArea.setIndexFromObject (_gate.myDefaultInterchangeArea); 
	
	chkEntry.value		:= _gate.isInGate;
	chkExit.value		:= _gate.isOutGate;
	chkPrompt.value		:= _gate.promptForRFIDTag;	// 23/02/2010 cnwcs5 
	self.chkBarrierCodes.value:=_gate.useBarrierCodes; //jlier1 TFS 57936 19/5/23
	
	self.setTroubleInCombo (_gate);
	self.loadGateAreas (_gate);
		
	// select the gate area and display the gate lanes for it
	if tblGateAreas.rows &gt; tblGateAreas.fixedRows then
		tblGateAreas.row := tblGateAreas.fixedRows + 1;	// select a-gate by default
		
		obj := self.lstData.listObject;
		if obj &lt;&gt; null and obj.isKindOf(CM_GateAreaUsage) then
			foreach idx in tblGateAreas.fixedRows + 1 to tblGateAreas.rows do
				if tblGateAreas.accessRow(idx).itemObject = obj then
					tblGateAreas.row := idx;
					break;
				endif;
			endforeach;
		endif;
	else
		tblGateAreas.row := tblGateAreas.fixedRows;
	endif;
	
	tblGateAreas.selectRow (tblGateAreas.row, false);
	
	self.loadGateLanes;
epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
