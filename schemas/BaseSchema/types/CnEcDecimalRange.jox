    <JadeMethod name="getValueFrom" id="2770bf8a-92fe-4cee-a6a7-29aac0e23827">
        <source>getValueFrom():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the decimal from value.
//
// Parameters:	None
//
// Returns:		The decimal from value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.integerFrom.String &amp; "." &amp; self.decimalFrom.String).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getValueTo" id="9cc00328-6de6-499f-b1e1-7d01d6296819">
        <source>getValueTo():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the decimal to value.
//
// Parameters:	None
//
// Returns:		The decimal to value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.integerTo.String &amp; "." &amp; self.decimalTo.String).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setDecimalParts" id="53dd6a41-57da-45f2-8968-756ce331f024">
        <source>setDecimalParts(pValue:Decimal;
				pInteger:Integer io;
				pDecimal:Integer io;
				pPlaces:Integer io) protected;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the decimal value's component properties.
//
// Parameters:	pValue - The decimal value.
//				pInteger - The integer part of the decimal value.
//				pDecimal - The decimal part of the decimal value.
//				pPlaces - The number of decimal places in the decimal value.
//
// Returns:		The integer and decimal values, plus the number of decimal places,
//				as IO parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	integerPart		: Integer;
	decimalPart		: Integer;
	decimalPlaces	: Integer;
	
begin
	integerPart		:=	pValue.truncated;
	decimalPart		:=	(pValue - integerPart).String[3:end].Integer;
	decimalPlaces	:=	pValue.getDeclaredScaleFactor();
epilog
	pInteger	:=	integerPart;
	pDecimal	:=	decimalPart;
	pPlaces		:=	decimalPlaces;
end;</source>
        <access>protected</access>
        <Parameter name="pValue" type="Decimal"/>
        <Parameter name="pInteger" type="Integer" usage="io"/>
        <Parameter name="pDecimal" type="Integer" usage="io"/>
        <Parameter name="pPlaces" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValueFrom" id="38d1c4de-016a-4e37-98d4-7d8a3e4fd5cf">
        <updating/>
        <source>setValueFrom(pValueFrom:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the decimal from value.
//
// Parameters:	pValueFrom - The decimal from value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pValueFrom, self.getValueTo()) then
		self.setDecimalParts(pValueFrom, self.integerFrom, self.decimalFrom, self.placesFrom);
	endif;
end;</source>
        <Parameter name="pValueFrom" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setValueTo" id="8db849b8-796c-483f-b383-fa4e219dfecd">
        <updating/>
        <source>setValueTo(pValueTo:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the decimal to value.
//
// Parameters:	pValueTo - The decimal to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.getValueFrom(), pValueTo) then
		self.setDecimalParts(pValueTo, self.integerTo, self.decimalTo, self.placesTo);
	endif;
end;</source>
        <Parameter name="pValueTo" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="8be36db1-d5a8-4a7d-ba1a-088197d7ec2f">
        <updating/>
        <source>updateMe(pValueFrom:Decimal; pValueTo:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's decimal range.
//
// Parameters:	pValueFrom - The decimal from value.
//				pValueTo - The decimal to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setValueTo(pValueTo);
	self.setValueFrom(pValueFrom);
end;</source>
        <Parameter name="pValueFrom" type="Decimal"/>
        <Parameter name="pValueTo" type="Decimal"/>
    </JadeMethod>
</Class>
