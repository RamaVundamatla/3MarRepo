    <JadeMethod name="btnShowWorkOrder_click" id="a7936ff2-ada4-494b-a64f-1228f28a8b70">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowWorkOrder_click(btn: Button input) updating;
// -----------------------------------------------------------------------------
// Created:		29 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 13 Sep 2022 	navma1		ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
// 08 Feb 2023  navma1 		ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
// -----------------------------------------------------------------------------

vars
	job 	: CM_Job;
	task	: CM_WorkOrderDtl;
begin
	if self.optViewJob.value then
		job 	:= self.getCurrentJob();
	else
		if self.myCurrentWLE &lt;&gt; null then
			job := self.myCurrentWLE.job;
		endif;
	endif;
	
	if job &lt;&gt; null then
		task := job.myWODtl;						   //08.02.2023 navma1 #56457 Task#56458
		self.showWorkOrder(job.getWorkOrder(),task);   //13.09.2022 navma1 #54645
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canCompleteToDoWLE" id="8e76ba6c-f93d-48ae-ad58-d9db8dded59a">
        <source>canCompleteToDoWLE(_wle: CM_WOToDoWLE) : Boolean;
// -----------------------------------------------------------------------------
// Created:		29 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//	24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
// -----------------------------------------------------------------------------
//

vars
	task : CM_ToDoTask;
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	trxType : CM_TransactionType; //23/05/2023 navmv20 CR 57925 Task 57921
begin
	toDoTaskDesc := _wle.job.CM_WOToDoTaskJob.myToDoTaskDesc; //23/05/2023 navmv20 CR 57925 Task 57921
	trxType := app.myRoot.allTransactionTypes[toDoTaskDesc.trxTypeOnCompletion]; //23/05/2023 navmv20 CR 57925 Task 57921
	if trxType &lt;&gt; null and trxType.trxGroup &lt;&gt;  TRANS_TYPE_GROUP_WO then //23/05/2023 navmv20 CR 57925 Task 57921
		if _wle.myTrackedItem = null then
			return false;
		endif;
	endif;//23/05/2023 navmv20 CR 57925 Task 57921

	toDoTask := self.getToDoTask(_wle);

	if toDoTask = null or toDoTask.status = STATUS_COMPLETE then
		return false;
	endif;
	
	return app.myPassport.myUser.canCompleteTodoTask(toDoTask.myTerminal, toDoTask.toDoTaskDesc);

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearJobWLELines" id="cd52c800-c94e-49d8-850d-b3faa1ae2033">
        <source>clearJobWLELines( _theJob : CM_Job);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwrd1	Initial creation

*/

vars
	theRow	: Integer;
	theTable : CM_DataTable;	
	invalidOject : Boolean;
	aWLE 		: CM_WorkListEntry;
begin
	//14/02/2011 cnwdz2 par26987
	on Exception do app.handleDeletedObject(exception, aWLE, invalidOject);
	

	theTable := self.tblWorkEntries;
	
	foreach aWLE in _theJob.workListEntries do
		theTable.findObjectInRow(aWLE, theRow);		
		if theRow &gt; 0 then	
			theTable.removeDeletedObject(aWLE);	
		endif;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_theJob" type="CM_Job"/>
    </JadeMethod>
