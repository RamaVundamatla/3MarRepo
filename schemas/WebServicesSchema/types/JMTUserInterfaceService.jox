	create bookingStatus transient;
	bookingStatus.description := app.bookingRefStatusEnumToString(BOOKING_REF_CLOSED);
	bookingStatus.id := BOOKING_REF_CLOSED;
	response.allBookingStatuses.add(bookingStatus);
	
	create bookingStatus transient;
	bookingStatus.description := app.bookingRefStatusEnumToString(BOOKING_REF_ARCHIVED);
	bookingStatus.id := BOOKING_REF_ARCHIVED;
	response.allBookingStatuses.add(bookingStatus);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
