    <JadeMethod name="populateCargoType" id="0a18286f-5881-4612-b76f-a972cdae7272">
        <source>populateCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars

	existingCargoType : CM_CargoType;
	cargoType : CM_CargoType;
	coll : CM_CargoTypeSet;
	index : Integer;

begin

	self.cmbNewProduct.clear();
	
	existingCargoType := self.myTrackedItem.myCargoType;
	
	create coll transient;
	self.myTerminal.getAllCargoTypes (coll, false);
	
	if existingCargoType.isBulkByWeight then
		foreach cargoType in coll do
			if cargoType.isBulkByQuantity then
				index := self.cmbNewCargoType.addItem( cargoType.description );
				self.cmbNewCargoType.itemObject[index] := cargoType;
			endif;
		endforeach;
		
	elseif existingCargoType.isBulkByVolume then
		foreach cargoType in coll do
			if cargoType.isBulkByQuantity then
				if cargoType.mySystemProductType &lt;&gt; null then
					if cargoType.mySystemProductType.myVolume &lt;&gt; null and cargoType.mySystemProductType.myVolume.isViewable then
						index := self.cmbNewCargoType.addItem( cargoType.description );
						self.cmbNewCargoType.itemObject[index] := cargoType;
					endif;
				elseif cargoType.mySystemProductType = null then
					if cargoType.allAttributesOnProduct.includes(ETRow_MyVolume) then
						index := self.cmbNewCargoType.addItem( cargoType.description );
						self.cmbNewCargoType.itemObject[index] := cargoType;
					endif;
				endif;
				
			endif;
		endforeach;
	
	endif;
	
	self.populateSubCargoType();

epilog

	delete coll;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateNewItems" id="9ff17df3-4935-4972-bf84-cf5a4569f69d">
        <source>populateNewItems();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars

	amountToProcess : Decimal [16,4];
	amountPerItem : Decimal [16,4];
	numItems : Decimal [16,4];
	numItemsInteger : Integer;
	volume : Decimal [16,4];

begin
	//epr TFS 7268 4/10/17
	self.txtNewItems.text := "1";

	amountToProcess := self.tblAmountToProc.getConvertedValue;
	amountPerItem := self.tblAmountPerItem.getConvertedValue;
	
	if amountPerItem &gt; 0 then
		amountPerItem := amountPerItem;
	
		numItems := amountToProcess / amountPerItem;
		numItemsInteger := numItems.Integer;
		self.txtNewItems.text := numItemsInteger.String;
		//epr TFS 7268 4/10/17
		self.resetProposedId();
		
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSubCargoType" id="9946d367-5a76-417f-9471-b0d85532d8f0">
        <source>populateSubCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars

	newCargoType : CM_CargoType;
	prod : CM_Product;
begin

	self.cmbNewProduct.clear();
	
	newCargoType := self.cmbNewCargoType.listObject.CM_CargoType;
	
	if newCargoType &lt;&gt; null then
		foreach prod in newCargoType.allProducts do
			//epr TFS 1846 19/4/16
			if prod.isNotActive then
				continue;
			endif;
			 self.cmbNewProduct.addItemObject( prod.description,prod  );	
		endforeach;
	endif;
	
	self.cmbNewProduct.enabled := cmbNewProduct.listCount &gt; 0;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetProposedId" id="f7fe7813-d3fe-4008-9399-3b165e05005d">
        <source>resetProposedId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	quantity : Integer;
	startSuffixValue : Integer;
	endSuffixValue : Integer;
	suffixLength : Integer;
	newBaseId : String;

begin

	self.lblProposedId.caption := null;
	
	if self.optBreakBulk.value then
		return;
	endif;
	
	quantity := self.txtNewItems.text.Integer;
	if quantity &lt; 1 then
		return;
	endif;
	
	newBaseId := self.txtId.text.trimBlanks.toUpper;
	if newBaseId = null then
		return;
	endif;
	
	suffixLength := self.txtIdSuffix.text.trimBlanks.length;
	if suffixLength &lt; 1 then
		return;
	endif;
	startSuffixValue := self.txtIdSuffix.text.Integer;
	endSuffixValue := ((startSuffixValue + quantity ) -1 );
	
	if endSuffixValue.String.length &gt; suffixLength then
		suffixLength := endSuffixValue.String.length;
	endif;
	
	self.lblProposedId.foreColor := Blue;
	self.lblProposedId.caption := newBaseId &amp; startSuffixValue.padLeadingWith('0',suffixLength);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="84aae1be-f280-435c-b994-876580d85641">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	msg : String;

begin

	self.myTrackedItem := _ti;
	
	if _ti &lt;&gt; null and _ti.canSplitTotalQuantity then
		self.lblExistingCargo.caption := _ti.id &amp; " (" &amp; _ti.totalQuantity.String &amp; ")";
		return true;
		
	else
		self.lblExistingCargo.caption := null;
		if _ti = null then
			msg := app.getErrorString(No_Cargo_selected);
		else
			msg := app.getErrorString(No_split_cargo_not_BB);
		endif;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return false;
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="153650cd-453a-46df-abb1-56c0bff62177">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
19 Jun 2015 cnwma1  PAR #36372 		    14074 exception when attempting to package bulk cargo
*/

vars
	ct : CM_CargoType;
	convertedAmount : String;
	weightMeasureType : CM_MeasurementType;
	volumeMeasureType : CM_MeasurementType;
	decimalSeparator  : String;
begin

	
	self.handleMenusForModalDisplay();
	
	self.optBreakBulk.value := true;
	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;   //19/06/2015  cnwma1 PAR# 36372
	self.clickOptions();

	inheritMethod();
	
	self.myAssistant.comboBoxOperator(cmbOperator, self.myTrackedItem.myOperator, null);
	self.cmbOperator.listIndex := self.cmbOperator.findObject( self.myTrackedItem.myOperator );

	ct:=self.myTrackedItem.myCargoType;
	weightMeasureType := app.getDefaultMeasurementForType(Type_Weight);
	if ct.myWeightMeasurementType &lt;&gt; null then
		weightMeasureType := ct.myWeightMeasurementType;
	endif;
	volumeMeasureType := app.getDefaultMeasurementForType(Type_Volume);
	if ct.myVolumeMeasurementType &lt;&gt; null then
		volumeMeasureType := ct.myVolumeMeasurementType;
	endif;
	
	self.tblAmountToProc.visible:=true;
	//epr TFS 7268 4/10/17
	self.txtNewItems.visible:=true;
	self.lblINewItems.visible := true;
	// 36794 make txtNewItems longer 
	self.txtNewItems.maxLength := 8;
	if ct.isTrackByWeight then
		self.tblAmountToProc.setup(Type_Weight, self.backColor);
		convertedAmount:=self.myTrackedItem.getConvertedTotalWeightIn(weightMeasureType.shortName);
		self.tblAmountToProc.setValues(convertedAmount &amp; " " &amp; weightMeasureType.shortName);
		self.tblAmountPerItem.setup(Type_Weight, self.backColor);
		//convertedAmount:="0.00";									 //19/06/2015  cnwma1 PAR# 36372
		convertedAmount := "0" &amp; decimalSeparator &amp;"00";			 //19/06/2015  cnwma1 PAR# 36372
		self.tblAmountPerItem.setValues(convertedAmount &amp; " " &amp; weightMeasureType.shortName);
	else
		convertedAmount:=self.myTrackedItem.getConvertedTotalVolumeIn(volumeMeasureType.shortName);
		self.tblAmountToProc.setup(Type_Volume, self.backColor);		
		self.tblAmountToProc.setValues(convertedAmount &amp; " " &amp; volumeMeasureType.shortName);
		//convertedAmount:="0.00";									 //19/06/2015  cnwma1 PAR# 36372
		convertedAmount := "0" &amp; decimalSeparator &amp;"00";			 //19/06/2015  cnwma1 PAR# 36372
		self.tblAmountPerItem.setup(Type_Volume, self.backColor);		
		self.tblAmountPerItem.setValues(convertedAmount &amp; " " &amp; volumeMeasureType.shortName);
	endif;
	
	
	self.tblPkgingWeight.setup(Type_Weight, self.backColor);
	//convertedAmount:="0.00";									 //19/06/2015  cnwma1 PAR# 36372
	convertedAmount := "0" &amp; decimalSeparator &amp;"00";			 //19/06/2015  cnwma1 PAR# 36372
	self.tblPkgingWeight.setValues(convertedAmount &amp; " " &amp; weightMeasureType.shortName);
	
	self.lblExistingCargo.caption := app.getErrorString(Create_package_breakbu_items) &amp; CrLf &amp; app.getErrorString1(MOVE_FROM, "'" &amp; self.myTrackedItem.id &amp; "'" );
	
	self.populateCargoType();
	self.cmbOperator.listIndex := self.cmbOperator.findObject( self.myTrackedItem.myOperator );
	self.defaultAmountPerItem(true);
	self.txtNewLocation.text := self.myTrackedItem.myPrimaryActualLocation.getFullId;
	
epilog
	
end;</source>
    </JadeMethod>
