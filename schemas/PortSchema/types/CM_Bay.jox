    <JadeMethod name="validateTierIDs" id="5765af3b-274d-4a4b-9094-f9946d4ca96f">
        <source>validateTierIDs();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTierIds : StringArray;
	aTier : CM_TierDefn;
	errorTierID : String;

begin
	
	create theTierIds transient;
	
	// CHECK that the 20 and 40 Tier ids are unique
	errorTierID := "";
	foreach aTier in self.allTiersOnDeck do
		if aTier.id &lt;&gt; null then
			if not theTierIds.includes(aTier.id) then
				theTierIds.add(aTier.id);
			else
				errorTierID := aTier.id;
				break;
			endif;
		endif;
	endforeach;
	foreach aTier in self.allTiersUnderDeck do
		if aTier.id &lt;&gt; null then
			if not theTierIds.includes(aTier.id) then
				theTierIds.add(aTier.id);
			else
				errorTierID := aTier.id;
				break;
			endif;
		endif;
	endforeach;
	if errorTierID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Bay " &amp; self.id &amp; " Tier IDs.", " Tier ID '" &amp; errorTierID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorTierID := "";
epilog
	delete theTierIds;


end;</source>
    </JadeMethod>
</Class>
