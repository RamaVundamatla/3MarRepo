    <JadeMethod name="getDetailForDisplay" id="ea11c93d-6908-40fd-a4fa-0274ab18ccb5">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/11/2020	jlgdap1		Initial creation TFS 50199 MTN Navis API - Audit Log
//
vars

begin
	if not inheritMethod(_array) then
		return false;
	endif;
	
	self.addToArray(app.getErrorString(Event_type), self.eventType, _array);
	self.addToArray(app.getErrorString(Created_At), self.createdAt.String, _array);
	self.addToArray(app.getErrorString(App_Name), self.appName, _array);
	self.addToArray(app.getErrorString(App_Version), self.appVersion, _array);
	self.addToArray(app.getErrorString(API_Version), self.apiVersion, _array);
	self.addToArray(app.getErrorString(General_payload), self.generalPayload, _array);
	
	return true;

epilog

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
