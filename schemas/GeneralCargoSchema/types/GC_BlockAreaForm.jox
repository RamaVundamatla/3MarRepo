    <JadeMethod name="switchViewMode" id="f567ad44-947d-4510-b966-0c393cb89a9d">
        <updating/>
        <source>switchViewMode(_viewMode : Integer) updating, protected;
vars
	
begin
	if self.myDrawingController = null then
		return;
	endif;

// PAR 32308	self.btnViewYardAllEd.enabled := _viewMode = VIEW_YARD_ALLOC;

	self.frmStatusLine.myFrameCaption.caption := self.frmBlockArea.setViewMode(_viewMode);
	
	self.frmBlockArea.refresh();
	
	self.setNotifications(false);
	self.frmColLegendTIs.doChangeViewModeEx(_viewMode, self.myDrawingController.myDrawingAttrController);
	self.setNotifications(true);
		
	self.doSetCaption();
epilog
		
end;</source>
        <access>protected</access>
        <Parameter name="_viewMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblGridAreaInfo_contextMenu" id="35d34deb-01db-4eea-885d-9181f49d290a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_contextMenu(_table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars

begin
	if self.myDrawingController = null then //PAR 17125 cnwgb1
		return false;
	endif;
	self.doTurnOffContextMenus();
	
	self.mnuGridSeperator02.visible := true;
	self.mnuZoomSub.visible := true;
	self.mnuGridSelector.visible := true;
	
	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideMacro.visible := true;
	self.mnuGridBigFont.visible := true;
	self.mnuGridSeperator01.visible := false;

	return self.showContextMenu(mnuGridAreaContext, _table, conwin, mouse, x, y);
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ef262dd0-f80e-4a6e-b669-b497a4f1f589">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 July 2022 08:23:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005635, locale);
	btnMoveBotLeft.translateBubbleHelp(Xlat_0005636, locale);
	btnMoveBotLeft.translateCaption(Xlat_0005637, locale);
	btnMoveBotRight.translateBubbleHelp(Xlat_0005638, locale);
