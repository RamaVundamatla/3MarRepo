    <JadeMethod name="doMnuCreateQuickLog_Click" id="3228119a-eaa5-407c-9c9b-d33d6f6d30b2">
        <source>doMnuCreateQuickLog_Click();
/*
Purpose:			
Date		Who		Reason
14 May 2014	cnwab1	Initial creation
*/

vars
	numItems : Integer;
begin
	if self.myCurrentTerminalArea = null then
		app.msgBox("Select a Log Area","No Area",MsgBox_OK_Only);
		
		return;
	endif;
	
	numItems := 10;
	read numItems;
	
	if app.msgBox("Create " &amp; numItems.String &amp; " Quick LOG Items in " &amp; self.myCurrentTerminalArea.id &amp; "?", "Quick Logs", MsgBox_Yes_No) = MsgBox_Return_Yes then
	
		self.myCurrentTerminalArea.CM_LogArea.createQuickCargoGC(numItems);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuEditClick" id="040cb04c-d203-41c0-9d3b-9ad9bb3cf96a">
        <updating/>
        <source>doMnuEditClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTower : CM_Tower;
	lTowerEdit	: YRD_TowerEdit;
	anObject	: Object;
	theTI : CM_Container;
begin

	if menuItem.userObject = null then
		return;
	endif;
	
	if menuItem.userObject.isKindOf(CM_Tower) then
		create lTowerEdit;
		lTowerEdit.centreWindow;
		lTowerEdit.myTower := menuItem.userObject.CM_Tower;
		lTowerEdit.myContainerNext := lTowerEdit.myTower.nextPortHole;
		lTowerEdit.myContainerPrev := lTowerEdit.myTower.prevPortHole;
		lTowerEdit.setMyTerminal(self.myTerminal);
		lTowerEdit.myParent := self;
		lTowerEdit.myTerminalArea := self.myCurrentTerminalArea;
		lTowerEdit.show;
	elseif menuItem.userObject.isKindOf(CM_TrackedItem)  then
		self.myAssistant.showCargoEnquiryForm(menuItem.userObject.CM_TrackedItem, self.myMasterMenuAction, true, true);	
	endif;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridBulkEditClick" id="36b90d8c-af82-48d5-9579-e5c0af362d2a">
        <updating/>
        <source>doMnuGridBulkEditClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	objArray : CM_ObjectArray;
begin
	create objArray transient;

	menuItem.userObject.Collection.copy(objArray);//CM_ObjectArray;
	
	if not objArray.isEmpty then
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, true);
	else
	endif;
epilog
	delete objArray;
	delete menuItem.userObject;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
