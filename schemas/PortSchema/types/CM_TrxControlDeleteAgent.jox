    <JadeMethod name="trxDeleteDBPurgeXlations" id="27fd8a46-9f77-41a7-b4bc-e13a8434101c">
        <updating/>
        <source>trxDeleteDBPurgeXlations(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created Sept 2006 cnwrs1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars
	voyageSet : ObjectSet;
	iter : Iterator;
	voyage : CM_Voyage;
	object : Object;
	xlation : CM_Xlation;
	count,
	count2,
	theSize,
	completed : Integer;
	setAll,
	setErrors : CM_ObjectSetActual;
	numOfLockExceptions	: Integer;
	hadLock : Boolean;
	errTxt : String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt, true);
	
	create voyageSet transient;
	create setAll transient;
	create setErrors transient;
	
	iter := _terminal.allVoyagesArchived.createIterator();
	while iter.next(voyage) do
		if voyage.archived and 
			voyage.archivedDT &lt;= _ts then //DWQ 29/10/2010: Added in check to check the _ts being passed in.
			if voyage.allOnsiteTIsByIdCargoType.size = 0 and
			   voyage.allXlations.size &lt;&gt; 0 then
				voyageSet.add(voyage);
			endif;
		endif;
	endwhile;

	if _agent.abort() then
		return;
	endif;

	theSize := voyageSet.size;
	foreach object in voyageSet do
		voyage := object.CM_Voyage;
		foreach xlation in voyage.allXlations do
			count := count + 1;
			setAll.add(xlation);
			if count = _agent.Commit_Block_Size_Medium then
				if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
					return;
				endif;
				completed := completed + setAll.size;
				setAll.clear();
				count2 := count2 + count;
				count := 0;
				if _agent.abort() then
					return;
				endif;
				if count2 mod _agent.Activity_Progress_Count_Large = 0 then
					_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, false);
				endif;
			endif;
		endforeach;
	endforeach;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; "Translations" &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog		
	delete voyageSet;
	delete iter;
	delete setAll;
	delete setErrors;
	self.finaliseActivityWithPassport(_passport);
end;</source>
