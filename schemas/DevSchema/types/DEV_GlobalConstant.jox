    <JadeMethod name="create" id="a47673be-1707-4b86-8c98-6ff4a51dfd4c">
        <updating/>
        <source>create(_name,
		_type,
		_value, 
		_documentationTextData	: String;
		_reason 				: Integer;
		_constantCategory 		: DEV_GlobalConstantCategory) ::super(_name, _type, _value, _documentationTextData) updating;
/*

Purpose:			Constructor for DEV_GlobalConstant class

Parameters:			_name:					String						The name of the global constant
					_type:					String						The type of the global constant
					_value:					String						The value of the global constant
					_documentationTextData:	String						The documentation text on the global constant
					_reason:				Integer						Reason for adding the GlobalConstant to the report either 1 (Missing) or 2 (Different)
					_constantCategory:		CM_GlobalConstantCategory	The global constant category object the global constant belongs to

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.reason 		:= _reason;
	
	//Set References
	self.myGcCategory 	:= _constantCategory;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
