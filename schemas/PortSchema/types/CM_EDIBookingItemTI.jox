    <JadeMethod name="addLinkedBookings" id="c3bd73cd-b466-42fc-9ebb-d32558e1dd2f">
        <source>addLinkedBookings( _cmif_bookingRefItem : CMIF_BookingRefItem; _bookingRefSet : CM_BookingRefSet input );

/*
Purpose:	This method will find and add the appropriate bookingRef(s) to be linked to this bookingItem.
			NOTE: Because this data should have already been validated (method validateLinkedBookingIDs)
			then there should be no errors if there are then just log them and continue the users can
			do the linking manually later.
			
Date				Who		Reason
16 April 2010		cnwrl1	Initial creation as part of PAR 23624 - Add new fields to EDI Booking
*/
//06 June 2014	cnwrs1	par34261 find booking for the booking reaf and voyage specified.
	
vars
	idString		: String;
	allIDsString	: String;
	tempStr			: String;
	bookingIDs		: StringArray;
	bookingRef		: CM_BookingRef;
	proxyBookingRef	: CM_BookingRef;
	operator		: CM_Operator;
	terminal		: CM_Terminal;
	voyage			: CM_Voyage;
	
begin
	allIDsString	:= self.linkedBookingIDs.trimBlanks;
	if allIDsString = null then
		return;					// nothing to do so continue
	endif;
	
	// de-referencing etc
	if _cmif_bookingRefItem.myCMIF_BookingRef = null or
	   _cmif_bookingRefItem.myCMIF_BookingRef.myProxyBookingRef = null then
		// should never happen but ...
		// just log it here and ignore it, the users can do it manually later.
		tempStr	:= 'ERROR: The proxy BookingRef for BookingItem ' &amp; self.id.display &amp; ' has not been set up';
		app.writeLog( tempStr, LogINFO );
		return;
	endif;
	
	proxyBookingRef	:= _cmif_bookingRefItem.myCMIF_BookingRef.myProxyBookingRef;
	operator		:= proxyBookingRef.myOperator;
	terminal		:= proxyBookingRef.myTerminal;
	voyage			:= proxyBookingRef.myVoyage;
	
	if terminal = null or operator = null or voyage = null then		// Note that the _voyage can be the NULL voyage.
		// should never happen but ...
		// just log it here and ignore it, the users can do it manually later.
		tempStr	:= 'ERROR: The proxy BookingRef Terminal, Operator or Voyage for BookingItem ' &amp; self.id.display &amp; ' has not been set up';
		app.writeLog( tempStr, LogINFO );
		return;
	endif;
	
	create bookingIDs transient;
	
	// Break the Linked Booking IDs into separate IDs.
	// Convert all single quotes into double quotes (neither are allowed in the IDs).
	allIDsString	:= allIDsString.cnEcFindReplace( SingleQuote, DoubleQuote, false );
	
	// Add each of the IDs into the array delimited on Space.
	allIDsString.csvToStringArray( bookingIDs, Space.Character );
	
	// Now for each of these IDs in turn do the required validation
	foreach idString in bookingIDs do
		bookingRef	:= terminal.getBookingReferenceForVoyage(idString, voyage);	//06 June 2014	cnwrs1	par34261 find booking for the booking reaf and voyage specified.
		if bookingRef = null then
			// should never happen but ...
			// just log it here and ignore it, the users can do it manually later.
			tempStr	:= 'ERROR: The BookingRef for link ' &amp; bookingIDs.display &amp; ' for BookingItem ' &amp; self.id.display &amp; ' does not exist';
			app.writeLog( tempStr, LogINFO );
			continue;
		endif;
		_bookingRefSet.addNoDuplicates( bookingRef, false );
	endforeach;
	
epilog
	delete bookingIDs;
	
end;
</source>
        <Parameter name="_cmif_bookingRefItem" type="CMIF_BookingRefItem"/>
        <Parameter name="_bookingRefSet" type="CM_BookingRefSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="assignValueSpecial" id="227c4bd4-1a91-451e-a83a-57383906547c">
        <updating/>
        <source>assignValueSpecial(_name: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*
Date			Who		Reason
11 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
10 May 2013		cnwcs5	par 31626 - make method public so can be used for hook code
*/
vars
	imCodes : StringArray;
begin
	if  _name = CM_EDIBookingItemTI::imCodes.name then	// this is a string array
		// par 31258 - code moved from setEDITIProperty
		self.setImCodes(_processedValue.String);
		return true;
	endif;
	
	return inheritMethod(_name, _processedValue, _xlationOperator);

epilog

end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="02c230da-5995-453d-ad86-d352bac29fdd">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 19 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if _propName = CM_EDIBookingItemTI::myBookingRefItem.name or
//	   _propName = CM_EDIBookingItemTI::imCodes.name or
	   _propName = CM_EDIBookingItemTI::linkedBookingIDs.name then
		return false;
	elseif _propName = CM_EDIBookingItemTI::directDelivery.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeDescr" id="b21eb777-7cdc-465b-b681-673bd0ca494f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>cargoTypeDescr(set : Boolean; _value : String io) mapping, updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	cType : CM_CargoType;
	int : Integer;
begin
	if set then
		int := app.myRoot.getCargoTypeIDFromDescription(_value);
		if int &lt;&gt; 0 then
			self.cargoType := int;
		endif;
	else
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType &lt;&gt; null then
			_value := cType.description;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="7dc079a7-7442-4c05-9663-b5faf099f844">
        <updating/>
        <source>create() updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars

begin
	self.messageMode 	:= null; //par 21396 cnwrs1 oct 2009
	self.temperature 	:= NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setHumidity( NULL_HUMIDITY );
	self.setOxygen( NULL_OXYGEN );
	self.vent 			:= NULL_VENTILATION; //par19252 cnwrs1 may 2009
	self.messageNum 	:= 1;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getAllEDIItemHazards" id="5a52aebb-8729-4a07-b123-3ca20b1a7cae">
        <source>getAllEDIItemHazards( _allEDITiHazards : ObjectSet io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
	ediTi : CM_EDITrackedItem;
begin
	_allEDITiHazards.clear();
	foreach ediTi in self.myEDIData.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIHazDetailsTI) and
		   ediTi.CM_EDIHazDetailsTI.bookingId = self.id and
		   ediTi.CM_EDIHazDetailsTI.bookingItemSeq = self.sequence then
			_allEDITiHazards.add(ediTi);
		endif;
	endforeach;
end;</source>
        <Parameter name="_allEDITiHazards" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllEDITaskRemarks" id="c42bb8e6-c7b0-4adb-89f7-5179ea0724f4">
        <source>getAllEDITaskRemarks(_allEDITiTaskRemarks : ObjectSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	ediTi : CM_EDITrackedItem;
begin
	_allEDITiTaskRemarks.clear();
	foreach ediTi in self.myEDIData.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDITaskRemarkRelBookTI) and
		   ediTi.CM_EDITaskRemarkRelBookTI.bookingId = self.id and
		   ediTi.CM_EDITaskRemarkRelBookTI.bookingItemSeq = self.sequence then
			_allEDITiTaskRemarks.add(ediTi);
		endif;
	endforeach;
end;
</source>
        <Parameter name="_allEDITiTaskRemarks" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllStopsToApply" id="df29e46b-e1cc-4421-b268-6fdbd3c3cfb7">
        <source>getAllStopsToApply( _stopsToApply : ObjectSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwndl1	Initial creation	TFS 2650 / 2001

*/

vars
	allStrings : HugeStringArray;
	str : String;
	selectedStopTable : CM_StopsTable;
	stopTable : CM_StopsTable;
	iter : Iterator;
begin
	create allStrings transient;
	
	if self.stopsToApply.trimBlanks() &lt;&gt; null then
		_stopsToApply.clear();
		self.stopsToApply.trimBlanks().getHugeTokensForDelimiter(Space.Character, allStrings);
		
		iter := app.myRoot.allStopsTable.createIterator;
		
		foreach str in allStrings do
			if str.trimBlanks() = null then
				continue;
			endif;
			selectedStopTable := null;
			
			if str.isInteger() then
				selectedStopTable := app.myRoot.allStopsTable[str.Integer];
			else
				iter.reset();
				str := str.toUpper;
				while iter.next(stopTable) do
					if str = stopTable.code
					or str = stopTable.shortHeading
					then
						selectedStopTable := stopTable;
						break;
					endif;
				endwhile;
			endif;
			
			if selectedStopTable = null then
				app.raiseCMException1(Stops_Id_Does_Not_Exist, str, ETRow_StopsToApply, self);	//22 Sep 2016	NDL
				continue;
			endif;
			
			_stopsToApply.add(selectedStopTable);
			
		endforeach;
	endif;
epilog
	delete allStrings;
	delete iter;
end;</source>
        <Parameter name="_stopsToApply" type="ObjectSet" usage="input"/>
    </JadeMethod>
