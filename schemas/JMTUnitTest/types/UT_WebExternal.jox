											&lt;xs:element name="FROM_LOCATION_CODE" msdata:Caption="From Location Code" msprop:MaxLength="20" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0"/&gt;
											&lt;xs:element name="FROM_LOCATION_TYPE" msdata:Caption="From Location Type" msprop:MaxLength="9" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="False" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:int" minOccurs="0"/&gt;
											&lt;xs:element name="FROM_LOCATION_TYPE_NAME" msdata:Caption="From Location Type Name" msprop:MaxLength="100" msprop:WrapText="False" msprop:Order="-2147483648" msprop:DecimalLength="0" msprop:Default_Visible="False" msprop:AllowDBNull="True" msprop:Visible="True" msprop:ReadOnlyWeb="False" msprop:ReadOnly="False" type="xs:string" minOccurs="0"/&gt;
