    </JadeMethod>
    <JadeMethod name="doSave" id="9188d6a5-0da4-42a8-b74c-fde685bf4a03">
        <updating/>
        <source>doSave() updating, protected;
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars
	result	: Boolean;
	code	: String;
	i		: Integer;
	numTIs	: Integer;
	str		: String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	code := self.tblReplaceConsig.getValueByName('consignCode').String;
	
	if code = null then
		i := app.msgBox("You must enter a valid code.", "Invalid Code", MsgBox_Stop_Icon + MsgBox_OK_Only); 
		if i = MsgBox_Return_OK then
			return;
		endif;
	endif;

	self.correctConsign := app.myRoot.allConsigneeConsignors[code];

	if self.incorrectConsign = self.correctConsign then
		i := app.msgBox("Incorrect code " &amp; incorrectConsign.code &amp; " and " &amp; " Replacement code " &amp; correctConsign.code &amp; " are the same."
						&amp; CrLf &amp; "You must enter a different replacement code.", "Invalid Code", MsgBox_Stop_Icon + MsgBox_OK_Only); 
		if i = MsgBox_Return_OK then
			return;
		endif;
	endif;	
	
	i := app.msgBox("All tracked items with a Consignee/Consignor code of " &amp; self.incorrectConsign.code &amp;
	 				" will have this code replaced with " &amp; correctConsign.code &amp; CrLf &amp; 
					"During conversion system performance may be degraded." &amp; CrLf &amp;
					"Do you wish to continue?", "Replacing Tracked Items Consignee/Consignor Code.", 
					MsgBox_Information_Icon + MsgBox_OK_Cancel);
	if i = MsgBox_Return_Cancel then              
	    return;
	endif;				
	app.mousePointer := MousePointer_HourGlass;
	numTIs := 0;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIConsigneeConsignor(self.incorrectConsign, self.correctConsign, app.myPassport, numTIs);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Consignee/Consignor Conversion', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	if numTIs = 0 then
		str := "No";
	else
		str := numTIs.String;
	endif;
	
	i := app.msgBox(str &amp; " Tracked Items changed. Deletion of incorrect code is recommended.",
					 "Conversion Complete", MsgBox_Information_Icon + MsgBox_OK_Only); 
	if i = MsgBox_Return_OK then
		self.unloadForm();	
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getConsignCodes" id="727c33c5-168c-4c3e-bccd-e0f41d4a6e67">
        <source>getConsignCodes(): String; 
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	consign	: CM_ConsigneeConsignor;
	iter 	: Iterator;
	str 	: String;	

begin
	iter := app.myRoot.allConsigneeConsignors.createIterator;
	while iter.next(consign) do
		if not global.isValidObject(consign) then
			continue;
		endif;
		if str &lt;&gt; null then
			str := str &amp; Tab;
		endif;
		str := str &amp; consign.code.trimBlanks;
	endwhile;
	return str;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeData" id="8d7f46da-f9d8-400b-a557-f5743e255bc7">
        <source>initializeData() protected;
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setTblReplaceConsign();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTblReplaceConsign" id="4a689d56-7096-4e7c-a3b5-4f287086964e">
        <source>setTblReplaceConsign() protected;
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars
	theRow			: Integer;
begin
	theRow := tblReplaceConsig.addAttribute('incorrectConsign','Incorrect code',tblReplaceConsig.InputType_None,0,true);
	tblReplaceConsig.setValue(theRow, self.incorrectConsign.code);
	theRow := tblReplaceConsig.addAttribute('consignCode','Replace with code',tblReplaceConsig.InputType_ComboBox,0,true);
	tblReplaceConsig.setComboValues(theRow, self.getConsignCodes);
end;</source>
        <access>protected</access>
    </JadeMethod>
