    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="myGcCategory" id="6647c83e-7a79-4991-85c7-5f4ef9c095da">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
