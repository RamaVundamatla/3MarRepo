    <JadeMethod name="setClearanceExpiryDate" id="853a57d8-7a51-4005-839d-11da4c45a056">
        <updating/>
        <source>setClearanceExpiryDate( _value : Date ) updating;

/*
Date				Who		Reason
01 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.

