    <JadeMethod name="canUserSet" id="1b58650c-cb3e-4c97-b33f-5f1b120e8769">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDIBOLDtlTI::allEDICargoShipTIs.name or
	   _propName = CM_EDIBOLDtlTI::myHeader.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d5474484-ec72-48c6-b2e3-e5231fab6adb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
// 02/12/2022   navma1	 	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//
vars
	rowName, type	: String;

begin
	//02.12.2022 navma1 #55424
	if _attrName = ETRow_Id then
		return self.id;
	elseif _attrName = ETRow_HasChanged then
		return false.String;
	elseif _attrName = ETRow_CargoTypeDescr then
		return self.cargoTypeDescr;
	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_Quantity then
		return self.quantity.String;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Colour then
		return self.colour;
	elseif _attrName = ETRow_Mark then
		return self.mark;
	elseif _attrName = ETRow_Consignee then
		return self.consignee;
	elseif _attrName = ETRow_Consignor then
		return self.consignor;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;	
	//02.12.2022 navma1 #55424
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
