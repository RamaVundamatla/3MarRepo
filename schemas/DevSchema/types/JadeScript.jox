    <JadeMethod name="aatest" id="e963b19f-7eae-479a-b27b-ddf1c34af113">
        <source>aatest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2025	naviv1	Initial creation

*/

vars
	classObj	 		: Class;
	methodObj			: Method;
	allMethodsObj		: MethodNDict;
	allParametersObj	: ParameterColl;
	param 				: Parameter;
begin
	classObj := CM_TrackedItem;
	create allParametersObj transient;
	create allMethodsObj transient;
	create allParametersObj transient;
	classObj.getMethods(allMethodsObj);
	
	foreach methodObj in allMethodsObj do
		allParametersObj.clear();
		methodObj.cnGetParameters.copy(allParametersObj);
		foreach param in allParametersObj do
			write methodObj.name &amp; ',' &amp; param.name &amp; ',' &amp; param.type.name; 
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ab001" id="5d2915f8-401a-45a0-a714-4216f26ecbad">
