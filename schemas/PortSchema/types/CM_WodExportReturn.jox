    <JadeMethod name="addTIAvailable" id="fc5c04f9-3163-4fbe-acba-8cbf99351bff">
        <updating/>
        <source>addTIAvailable(_theTI: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2018	jlgndl1	Initial creation	TFS 40156

*/

vars

	term : CM_Terminal;
	holdCode : String;
	holdVoyage : CM_Voyage;
	tmpVoyage : CM_Voyage;
	control : CMIF_MoveController;
	qdWleArray : CM_WLEArray;
	pdWleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;

begin

	inheritMethod( _theTI );
	
	
	if _theTI = null then
		return;
	endif;
	
	ti := _theTI;
	if not self.allAvailableTIs.includes( ti ) then
		return;
	endif;
	
	term := ti.myTerminal;
	if term &lt;&gt; null then
//		holdVoyage := term.getConfig(HoldVoyageCode).CM_Voyage;
//		if holdVoyage = null then
//			holdVoyage := term.getNullVoyage();
//		endif;
		//27 Aug 2018	NDL	TFS 40157
		holdCode := term.getConfig(HoldVoyageCode).String;
		if holdCode &lt;&gt; null then
			tmpVoyage := term.allVoyagesByCode.getAtKeyGeq(holdCode, null);
			if tmpVoyage &lt;&gt; null and tmpVoyage.code = holdCode then
				holdVoyage := tmpVoyage;
			endif;
		endif;
		if holdVoyage = null then
			holdVoyage := term.getNullVoyage;
		endif;
	endif;
	
	if holdVoyage = null then
		return;
	endif;
	
	if ti.myVoyage &lt;&gt; holdVoyage then
	
		if app.myPassport.hasErrors then
			return;
		endif;
		
		create qdWleArray transient;
		create pdWleArray transient;
	
		create control transient;
		
		control.setMyTrackedItem( ti);
		control.setMyToPrimaryLocation(null);
		control.isForcedMove := true;
		control.isSystemMove := true;
		
		foreach wle in _theTI.allWorklistEntries do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if wle.isQueued then
				qdWleArray.add( wle );
			endif;
		endforeach;
		
		if not qdWleArray.isEmpty then
			foreach wle in qdWleArray do
				control.setMyWorkListEntry(wle);
				control.setMoveMode(QUEUE_MODE);
				app.myUtilityUA.utlUpdateMoveTIUndo(control, app.myPassport);
				
				if app.myPassport.hasErrors then
					return;
				endif;
			endforeach;
		endif;
		
		foreach wle in ti.allWorklistEntries do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			pdWleArray.add( wle );
		endforeach;
		
		if not pdWleArray.isEmpty then
			foreach wle in pdWleArray do
				control.setMyWorkListEntry(wle);
				control.setMoveMode(PLANNING_MODE);	
				app.myUtilityUA.utlUpdateMoveTIUndo(control, app.myPassport);
				
				if app.myPassport.hasErrors then
					return;
				endif;
			endforeach;
		endif;
		
		ti.changeVoyage( holdVoyage, app.myPassport );
	
	endif;

epilog

	delete control;
	delete qdWleArray;
	delete pdWleArray;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskKnown" id="4565c08a-aa63-4b6e-adab-47ffbe8db4db">
        <updating/>
        <source>doActionTaskKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks

*/

vars
	workOrder 			: CM_WorkOrderTI;
	releaseRequest 		: CM_BulkRelease;
	ti					: CM_TrackedItem;
begin
	inheritMethod(_woActionIF, _realJob, _passport);
	
	workOrder			:= self.myParent.CM_WorkOrderTI;
	releaseRequest 		:= self.createBulkRelease(BR_TYPE_ROAD);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	
	if releaseRequest &lt;&gt; null then										
		self.myReleaseRequest := releaseRequest;
	endif;
	
	if not _woActionIF.useYardJobs then
		// complete the work order
		foreach ti in self.allActionedTIs do
			self.setTIComplete(ti,null);			
		endforeach;
		workOrder.completeMe();
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="6148cf10-7bd3-48a4-8712-7a06601aa7cb">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TIEXPRET_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TIEXPRET_UPDATED;
	else
		return TRANS_TYPE_WO_TIEXPRET_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="974a18c4-482c-4af1-a4cc-100f6ee3b882">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 29 Sep 2021  navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 06 Mar 2023  navma1 		ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
//
vars
	displayStr : String;
	typeDesc	  : String;
	code		  : String;
begin
	
	typeDesc := self.getTypeDescription();											//29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayStr := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;	//29.09.2021 navma1 #51925
	else
		if self.getMyReleaseRequest &lt;&gt; null then
			code :=  self.getMyReleaseRequest.code;
		endif;
		displayStr :=  self.getLongDescription(typeDesc,code);						//29.09.2021 navma1 #51925
	endif;
	
	return displayStr;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
