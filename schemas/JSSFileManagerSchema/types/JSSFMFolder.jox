    <DbClassMap file="jssfm_file_node"/>
    <JadeMethod name="create" id="cc16302c-139a-4a11-87ae-582041a39c53">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		Constructor to set default values etc..
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isFile		:=	false;
	self.isFolder	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="8e563ffd-f83d-408b-8d85-21987c3415b7">
        <source>getTableDisplay(): String;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Returns the receiver's properties formatted for display in a table
//				control on a form.
//
// Parameters:	None
//
// Returns:		The formatted string of the receiver's properties.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	"" &amp; Tab &amp;
					self.fileName &amp; Tab &amp;
					"" &amp; Tab &amp;
					"" &amp; Tab &amp;
					"" &amp; Tab &amp;
					self.fileNodeFlag.String &amp; Tab &amp;
					self.pathName &amp; Tab &amp;
					self.nodeType.String &amp; Tab &amp;
					self.isUnix.String;
epilog
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setNodeFlag" id="c3e388f9-d4ff-4270-845c-10e660257702">
        <updating/>
        <source>setNodeFlag() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Updates the receiver's node type flag.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.fileNodeFlag	:=	self.NODE_FLAG_FOLDER;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
