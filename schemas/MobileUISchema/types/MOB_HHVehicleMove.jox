        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleAreaSelect" id="ab321869-9292-4d8b-ac51-282cc8a8faf8">
        <updating/>
        <source>handleAreaSelect() updating, protected;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Handle selection of a terminal area in the area combo box. 
//			Typically this loads up the locations in that area in the location
//			combo box.
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	obj : Object;
	ta : CM_TerminalArea;
	lcSet : CM_LCSet;
begin

	self.txtTargLocn.text := null;
	
	obj := self.cmbTerminalArea.listObject;
	if obj &lt;&gt; null then 
		ta := obj.CM_TerminalArea;
		if ta &lt;&gt; null then
			if ta.isKindOf(CM_RTGArea) then
				self.selectedArea := self.cmbTerminalArea.text;
			else
				self.selectedArea := self.cmbTerminalArea.text &amp; " ";
			endif;
			self.selectedLocation := null;
			self.txtTargLocn.text := self.selectedArea;
			self.setMoveEnabledDisabled();
			//if ta.isKindOf( CM_RTGArea) or ta.isKindOf( CM_StraddleStack
			if ta.isKindOf(CM_Rail) then
				create lcSet transient;
				ta.CM_Rail.getValidLCsCollectionForMove(lcSet);
				self.getSessionAgent().loadLCCmb( self.cmbYardLocation, lcSet, false );
			elseif ta.isKindOf(CM_IrregularBlockArea) then	//23 Aug 2013	NDL	Par 32308
				create lcSet transient;
				ta.CM_IrregularBlockArea.getValidLCsCollectionForMove(lcSet);
				self.getSessionAgent().loadLCCmb( self.cmbYardLocation, lcSet, false);
				delete lcSet;
			else
				self.getSessionAgent().loadLCCmb( self.cmbYardLocation, ta.getLCsCollectionForDisplay(), false );
			endif;
		endif;
	endif;
	
	if self.cmbYardLocation.listCount = 1 then
		self.cmbYardLocation.listIndex := 1;
	elseif self.cmbYardLocation.listIndex &lt; 1 then
		self.cmbYardLocation.addItemAt("&lt;Yard Location&gt;",1);
		self.cmbYardLocation.itemEnabled[1] := false;
		self.cmbYardLocation.listIndex := 1;
	endif;
	
epilog

	delete lcSet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleAreaTypeSelect" id="8c23fa62-5605-47a9-82a4-28beae6d7f1a">
        <updating/>
        <source>handleAreaTypeSelect() updating, protected;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Handle selection of an area type in the area type combo box. 
//			This loads up the areas of this type into the area combo box
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	obj : Object;
	terminalAreaType : CM_TerminalAreaType;
begin
	
	obj := self.cmbAreaType.listObject;
	if obj &lt;&gt; null then
		terminalAreaType := obj.CM_TerminalAreaType;
		if terminalAreaType &lt;&gt; null then
			self.getSessionAgent().loadTermAreaCmb( self.cmbTerminalArea, terminalAreaType.type );
		else
			self.getSessionAgent().loadTermAreaCmb( self.cmbTerminalArea, TA_TYPE_NULL );  //cnwgb1 PAR 19010 5.2.09
		endif;
	else
		self.getSessionAgent().loadTermAreaCmb( self.cmbTerminalArea, TA_TYPE_NULL );  //cnwgb1 PAR 19010 5.2.09
	endif;
	
	if self.cmbTerminalArea.listCount = 1 then
		self.cmbTerminalArea.listIndex := 1;
	elseif self.cmbTerminalArea.listIndex &lt; 1 then
		self.cmbTerminalArea.addItemAt("&lt;Terminal Area&gt;",1);
		self.cmbTerminalArea.itemEnabled[1] := false;
		self.cmbTerminalArea.listIndex := 1;
	endif;

	self.cmbYardLocation.clear;
	self.handleAreaSelect();
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
