Purpose: This abstract class is a sub class of Object. Its function is to
		 allow for communication to a serial (RS232) device.  Requires an
		 external DLL basecomm.dll. This DLL must be present in the search
		 path.

Changes

	1.0.02	: Added a version number</text>
    <DbClassMap file="basemap"/>
    <PrimAttribute name="port" id="3f4fd073-f50e-45c6-a7f8-a338d29c236b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="readBuffer" id="467adcee-4974-4f91-9b4e-8bcf942a7afc">
        <type name="Binary"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="readBufferLen" id="3b298a50-f967-469e-acd9-e872d22591cb">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="clearCommError" id="b0d74ba4-9277-4624-93e9-2287e2633e44">
        <source>clearCommError() : Boolean;

begin
	return call cnEcClearCommError(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearReadBuffer" id="18c13f5e-08e5-4834-8473-6c2c7af00417">
        <updating/>
        <source>clearReadBuffer() updating;

begin
	readBuffer := null;
	readBufferLen := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="close" id="9cf92a6c-22de-47c0-8713-71f362e354a1">
        <source>close() : Boolean;

begin
	return call cnEcCloseComm(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doATCommand" id="f351caff-7d72-4ee0-85d5-72fc72e34538">
        <updating/>
        <source>doATCommand(line:String; timeout:Integer) :String updating;

vars
    buffer:String;
begin
	writeString(line);	

	if readString(buffer, timeout) then

		return buffer;
 	else
		return  'Read failed: ' &amp; buffer;
	endif;

end;</source>
        <Parameter name="line" type="String"/>
        <Parameter name="timeout" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dtrDisable" id="72dd210d-b56e-4a91-8a4c-c782a082988f">
        <source>dtrDisable() : Boolean;

begin
	return call cnEcClearDTR(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dtrEnable" id="97ec971a-c21d-418b-ac51-4846175523ac">
        <source>dtrEnable() : Boolean;

begin
	return call cnEcSetDTR(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpen" id="f21358e8-30b5-4a2e-8443-c5e94f06e746">
        <source>isOpen() : Boolean;

begin
	if port = 0 then
		// port has not been set up yet
		return false;
	else
		return call cnEcIsOpen(port);
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="open" id="fed61230-1ab8-4a04-b392-d92fa73cb44f">
        <updating/>
        <source>open(portNum:Integer;baud:Integer;byteSize:Integer;parity:Character;stopBits:Integer) : Boolean updating;

begin
	self.clearReadBuffer();
	port := portNum;
	call cnEcSetPort(port, "COM" &amp; port.String);
	call cnEcSetBaud(port, baud.String);
	call cnEcSetParity(port, parity);
	call cnEcSetDataBits(port, byteSize.String);
	call cnEcSetStopBits(port, stopBits.String);
	return call cnEcOpenComm(port);
end;</source>
        <Parameter name="portNum" type="Integer"/>
        <Parameter name="baud" type="Integer"/>
        <Parameter name="byteSize" type="Integer"/>
        <Parameter name="parity" type="Character"/>
        <Parameter name="stopBits" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="purgeCommIn" id="ebc5ce7e-cd61-40dc-bff4-84df17d37157">
        <source>purgeCommIn() : Boolean;

begin
	// clears the input buffer (if the device driver has one).
	return call cnEcPurgeCommIn(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="purgeCommOut" id="c5802c42-73e7-41f0-8008-cfc6c8bfb017">
        <source>purgeCommOut() : Boolean;

begin
	// clears the output buffer (if the device driver has one).
	return call cnEcPurgeCommOut(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="readBinaryWait" id="0f5ce9b7-9e94-44aa-84ef-7418b102043c">
        <updating/>
        <source>readBinaryWait(buffer : Binary output;  chars : Integer; timeout : Integer) : Boolean updating;

vars
	tempBinary : Binary;
	numberOfBytesRead : Integer;
	nowTime, endTime : Integer;
	retVal : Boolean;
begin
	// wait for upto 'timeout' milli seconds for 'chars' characters to come in
	nowTime := call cnEcGetTickCount;
	endTime := nowTime + timeout;
	while (nowTime &lt; endTime) and (readBufferLen &lt; chars) do
		if call cnEcReceiveByte(port, tempBinary) then
			readBuffer[readBufferLen + 1] := tempBinary[1];
			readBufferLen := readBufferLen + 1;
		endif;
		app.doWindowEvents(0);
		nowTime := call cnEcGetTickCount;
	endwhile;
	if (readBufferLen &lt;&gt; chars) then
		retVal := false;
	else
		buffer := readBuffer[1:readBufferLen];
		self.clearReadBuffer();
		retVal := true;
	endif;
	return retVal;
end;</source>
        <Parameter name="buffer" type="Binary" usage="output"/>
        <Parameter name="chars" type="Integer"/>
        <Parameter name="timeout" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="readString" id="95002783-553b-4809-a876-c9a49cc22b7d">
        <updating/>
        <source>readString(buffer : String output; timeout : Integer):Boolean updating;

vars
	tempBinary	: Binary;
	nowTime		: Integer;
	endTime		: Integer;
	
begin

	self.rtsDisable();	// drop RTS
	self.dtrEnable();	// raise DTR

	// wait for upto 'timeout' milli seconds
	nowTime := call cnEcGetTickCount;
	endTime := nowTime + timeout;

	// read buffer 1 byte at a time	
	while (nowTime &lt; endTime) do
		if call cnEcReceiveByte(port, tempBinary) then
			readBuffer[readBufferLen + 1] := tempBinary[1];
			readBufferLen := readBufferLen + 1;
		endif;
		app.doWindowEvents(0);
		nowTime := call cnEcGetTickCount;
	endwhile;       

	// valid response?
	if readBufferLen = 0 then
		return false;
	else
		buffer := readBuffer[1:readBufferLen].String;
		self.clearReadBuffer();
		return true;
	endif;
end;</source>
        <Parameter name="buffer" type="String" usage="output"/>
        <Parameter name="timeout" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="5705b164-37c3-4372-9436-5fbfdea88aa9">
        <updating/>
        <source>reset() updating;

begin
	self.purgeCommIn();
	self.purgeCommOut();
	self.clearReadBuffer();
	self.clearCommError();
end;</source>
    </JadeMethod>
    <JadeMethod name="rtsDisable" id="003b2721-74de-4123-8a2a-07295f83e0ad">
        <source>rtsDisable() : Boolean;

begin
	return call cnEcClearRTS(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rtsEnable" id="b1972e8b-d07f-43de-8c96-21d5f8765029">
        <source>rtsEnable() : Boolean; 

begin
	return call cnEcSetRTS(port);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeBinary" id="f9e483df-2873-498e-92cc-b897978109d7">
        <source>writeBinary(buffer : Binary) : Boolean;

vars
	i : Integer;
	retVal : Boolean;
begin
	retVal := true;
	i := 1;
	while (i &lt;= buffer.length) and (retVal = true) do
		retVal := call cnEcSendByte(port, buffer[i].Byte);	// 8/3/16 cnwmp6 PAR 36286 unicode version
		i := i + 1;
		app.doWindowEvents(0);
	endwhile;
	return retVal;
end;</source>
        <Parameter name="buffer" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeString" id="0f79c29d-1987-4b0d-b9c6-75873ee2e639">
        <source>writeString(textString : String) : Boolean;

begin
	return writeBinary(textString.asANSI(0));	// 9/3/16 cnwmp6 PAR 36286 unicode version
end;</source>
        <Parameter name="textString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
