    <JadeMethod name="doMnuTaskStatusComplete" id="27dd1abc-1780-438f-b89d-a6ac470ee900">
        <updating/>
        <source>doMnuTaskStatusComplete() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2011	cnwer1	Initial creation

*/

vars
	taskMach, imvMach : CM_Machine;
	completeTaskForm : YRD_CompleteTaskForm;
	modalResult, taskType, quantity: Integer;
	completeAll, completePickupAndSetdown, invalidObj : Boolean;
	theTask, initTask	 	: CM_RTQueueTask;
	weight 	: Decimal [14,4];
begin
	// 14/03/2013 cnwar2 #29581
	if self.myCurrentTask = null then
		return;
	endif;	

	if self.tblQEntries.allSelectedObjects.size &gt;  1 then
		self.doTaskStatus(TASK_COMPLETE);	
	else		
		create completeTaskForm transient;
		if completeTaskForm.initDetails(self.myTerminal,self.myCurrentTask) then
			modalResult:=completeTaskForm.showModal;
		else
			return;
		endif;
		
		if modalResult &lt;&gt; IDOK then
			return;
		endif;
		completeAll:=completeTaskForm.optMove.value;
		if not completeAll then
			if completeTaskForm.cmbMach.visible then
				taskMach:=completeTaskForm.cmbMach.listObject.CM_Machine;
			endif;
			if completeTaskForm.cmbIMV.visible then
				imvMach:=completeTaskForm.cmbIMV.listObject.CM_Machine;
			endif;
		endif;
		
		//epr par 31092 14/2/12
	    on Exception do app.handleDeletedObject(exception, initTask,invalidObj);
		initTask:=completeTaskForm.myInitQueueTask;
		taskType:=initTask.taskType; //dereference
		
		if invalidObj then
			return;
		endif;
		
		completePickupAndSetdown:=false;
		if completeTaskForm.optPickSetTask.value and initTask.isPickUp then
			theTask:=self.myCurrentEntry.getDirectorOrSetDownTask();
			completePickupAndSetdown:=true;
		else
			theTask:=completeTaskForm.myInitQueueTask;
		endif;
		
		if self.myCurrentTask.taskType = TASK_BREAKBULK then
			completePickupAndSetdown:=completeTaskForm.optPickSetTask.value;
			if completeTaskForm.txtQuantity.visible then
				quantity:=completeTaskForm.getQuantity;
			else
				weight := completeTaskForm.getWeightMovedKgs;
			endif;
		endif;
		
		self.doSingleTaskComplete(theTask,completeAll,completePickupAndSetdown,taskMach,imvMach, quantity,weight); //cnwrd1 quantity
	
	endif;

	
epilog
	delete completeTaskForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveMachine" id="1c79843c-b139-4caf-92ef-c3060691a75e">
        <updating/>
        <source>doMoveMachine(pMachine : CM_Machine; pQueue : CM_RadioTelemetryQueue input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Mar 2008	cnwkpd1		PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
//							Corrected spelling error in msgBox calls
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 27 Mar 2012	cnwkpd1		PAR #29338 - ensure delete of the proxy machine is done first in the epilog, to prevent leaks if
//							there is a lock exception trying to redisplay the queue
// ---------------------------------------------------------------------------

vars
	lReturn : Boolean;
	loadStateSet : Boolean;
	lProxyMachine : CM_Machine;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	if pMachine = null then
		app.msgBox('Could not determine machine from drag drop',"Move Machine",MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
		return;
	elseif pQueue = null then
		app.msgBox('Could not determine queue from drag drop',"Move Machine",MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	app.cmsBeginLoad(loadStateSet);
	lProxyMachine := pMachine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	self.refresh;

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
		app.myTrxUA.trxUpdateMachineQueue(lProxyMachine, pQueue,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Move Machine', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog	
	delete lProxyMachine;				// PAR #29338
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	self.showQueueThumbnail(pQueue);

end;</source>
        <Parameter name="pMachine" type="CM_Machine"/>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveMachines" id="f9201382-52a1-43de-91e2-17cee57e1e61">
        <updating/>
        <source>doMoveMachines(_queue : CM_RadioTelemetryQueue input) updating;
// ---------------------------------------------------------------------------
// Created:     August 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 20474
// 08/04/2011		cnwmh5			PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 27 Mar 2012		cnwkpd1			PAR #29338 - ensure delete of the proxy machine is done first in the epilog, to prevent leaks if
//									there is a lock exception trying to redisplay the queue
// ---------------------------------------------------------------------------
vars
	loadStateSet : Boolean;
	pxyMachine, realMachine : CM_Machine;
	pxyMachs, realMachs : CM_MachineSet;
	allErrors : CM_ErrorSet;
	error : CM_Error;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	create realMachs transient;
	create pxyMachs transient;
	
	self.getSelectedMachines(realMachs);
	
	if realMachs.isEmpty then 
		app.msgBox('Could not determine machine to move.',"Move Machine", MsgBox_Exclamation_Mark_Icon);
		return;
	elseif _queue = null then
		app.msgBox('Could not determine queue from drag drop',"Move Machine", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//epr CCMS 1395 dragging a whole lot of machines to a queue we don't want the whole lot to fail if one machine 
	//can't work the queue just show the erorr at the end for that machine and commit the rest
	create allErrors transient;
	foreach realMachine in realMachs  discreteLock do
		app.cmsBeginLoad(loadStateSet);
		pxyMachine := app.createUpdateProxy(realMachine).CM_Machine;
		app.cmsEndLoad(loadStateSet);
		
		pxyMachs.add(pxyMachine);
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateMachineQueue(pxyMachine, _queue,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Move Machine', app.myPassport, ErrWarnMode_Add);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endforeach;

epilog
	if pxyMachs &lt;&gt; null then			// PAR #29338
		pxyMachs.purge();
		delete pxyMachs;
	endif;
	delete realMachs;
	delete allErrors;
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	self.showQueueThumbnail(_queue);
end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPeekForJadeThinRTApp" id="c2e08597-5a11-4548-915d-2902f0215962">
        <source>doPeekForJadeThinRTApp(_device : CM_RTDeviceVehicleMount input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 Oct 2006	cnwer1	Initial creation - PAR#xxxx
02 Apr 2008	cnwkpd1	PAR #16421 - Rework to remove locking on system objects
07 dec 2009	 cnwer1 refactored code to get process onto device
*/

vars

	aProcess 		: Process;

begin
	if _device = null then
		return;
	endif;

	aProcess:=_device.getProcessForMachine();

	if aProcess &lt;&gt; null then
		app.showScreenForProcess(aProcess);
	endif;
	
	
epilog
	
end;</source>
        <Parameter name="_device" type="CM_RTDeviceVehicleMount" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPinQueue" id="67d79610-d9aa-4524-a381-8ce4912162fc">
        <updating/>
        <source>doPinQueue() protected, updating;
// -------------------------------------------
// Created 30 December 2003 by cnwdvb1
// -------------------------------------------
vars

	obj		: Object;		
	queue	: CM_RadioTelemetryQueue;

begin

	if self.btnPin.value then
		obj := self.lstQueues.listObject;
		if obj.isKindOf(CM_RadioTelemetryQueue) then
			queue := obj.CM_RadioTelemetryQueue;
			self.mySelectedQueue := queue;
			self.setCaption(app.getErrorString(Radio_Telemetry_Queue) &amp; ' ' &amp; queue.id);
		endif;
	else
		self.mySelectedQueue := null;
		self.setCaption(app.getErrorString(Radio_Telemetry_Queue));
	endif;
	self.loadQueues(false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPositionMachineAtQueue" id="3d99f8c9-297a-4766-a7aa-7dcda5fd6744">
        <updating/>
        <source>doPositionMachineAtQueue(_queue : CM_RadioTelemetryQueue) updating;
// ---------------------------------------------------------------------------
// Created:     17 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	
begin

	if _queue = null then
		app.msgBox('Machine has no associated primary queue', 'Position At Queue', MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	idx := lstQueues.findObject(_queue);
	if idx &lt;= 0 then
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  invalid queue');
		return;
	endif;
	
	lstQueues.itemExpanded[idx] := true;
		
	lstQueues.listIndex := idx;
	
	self.showQueueThumbnail(_queue);

end;</source>
