    <JadeMethod name="isTandemLift" id="8663d636-3f1a-40a3-b615-9664e5593777">
        <source>isTandemLift():Boolean;
// ---------------------------------------------------------------------------
// Created:     01 December 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	machine	:CM_Machine;
begin
	machine := self.getMyMachine;
	
	if machine = null or not machine.isTandemLift then
		return false;
	endif;
	
	return self.allKPIMachineMoves.size = 2;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTwinLift" id="14ba4b0e-c6ce-4ffa-a774-23ac42a7f9e4">
        <source>isTwinLift():Boolean;
// ---------------------------------------------------------------------------
// Created:     01 December 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	machine	:CM_Machine;
begin
	machine := self.getMyMachine;
	
	if machine = null or not machine.isTwinLift then
		return false;
	endif;
	
	return self.allKPIMachineMoves.size = 2;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForMoveLift" id="9268f6fa-6bee-4929-84c3-f2e74f0a38ab">
        <updating/>
        <source>setForMoveLift(_history :CM_MachineMoveHistory; _kpi :CM_KPIMachineEntity)updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Create lift and moves for a move
// Parameters:  _history - the last setdow for the lift
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiMove				:CM_KPIMachineMoveDtl;
	liftColl			:CM_MachineHistoryByDateTime;
	history, 
	moveHistory			:CM_MachineHistory;
	firstPickupTS, 
	lastSetDownTS		:TimeStamp;
	type				:Integer;
begin
	// it helps if some of the local variables are initialised to null
	firstPickupTS	:= null;
	lastSetDownTS	:= null;
	// get all machine history items that make up the lift
	create liftColl transient;
	
	_history.getAllLiftEntries (liftColl); 
	
	// create the move kpi details - group the history items into moves
	// then create a move for each group and add it to the lift
	// they will be in order that the move was started
	foreach history in liftColl reversed do 
		if history.CM_MachineMoveHistory.isEndOfMove then 
			// create a move KPI object
			kpiMove := self.createKPIMoveDtl (history.CM_MachineMoveHistory);
			// add the move to the lift
			self.allKPIMachineMoves.insert (1, kpiMove);
			// kpiMove will tell us all the history items that are part of the move
			kpiMove.allMachineHistory.copyNoDuplicates (self.allMachineHistory, false);
			// remove this move from our lift collection
			foreach moveHistory in kpiMove.allMachineHistory do
				type := moveHistory.type;
				// save off time of 1st pickup/move
				if moveHistory.CM_MachineMoveHistory.isStartOfLift then
					firstPickupTS := moveHistory.dateTime;
				endif;
				
				if moveHistory.CM_MachineMoveHistory.isEndOfLift then
					lastSetDownTS := moveHistory.dateTime;
				endif;
				// remove history we have processed
				liftColl.removeIfPresent (moveHistory);
			endforeach;
		endif;
	endforeach;
	// in theory when we get to here liftColl should be empty
	executeWhen JMTDevelopmentEnvironment;
	if not liftColl.isEmpty then
		//app.raiseUnexpectedProgramError (self.class.name, method.name, 'Coll should be empty');
	endif;
	endExecuteWhen;
		
	self.slackTime	:= null;

	if lastSetDownTS &lt;&gt; null and firstPickupTS &lt;&gt; null then
		self.duration	:= lastSetDownTS.getDifferenceInSeconds (firstPickupTS).rounded;
	endif;
	
	self.grossDuration	:= self.duration;
	
	self.acceptTS		:= null;
	self.startTS		:= firstPickupTS;
	self.finishTS		:= lastSetDownTS;		// last setdown formove
	self.weight			:= self.weight + _history.weight;
		
	self.myKPIMachineEntity		:= _kpi;
epilog
	delete liftColl;
end;</source>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <Parameter name="_kpi" type="CM_KPIMachineEntity"/>
    </JadeMethod>
    <JadeMethod name="setForSetDown" id="9825f817-9c0b-44a8-9303-2440bd5dec89">
        <updating/>
        <source>setForSetDown(_history :CM_MachineMoveHistory; _kpi :CM_KPIMachineEntity)updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Create lift and moves for a setdown
// Parameters:  _history - the last setdow for the lift
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/10/2012	cnwcs5		par 30382 - use 1st pickup TS if no accept
// ---------------------------------------------------------------------------
vars
	kpiMove				:CM_KPIMachineMoveDtl;
	liftColl, moveColl	:CM_MachineHistoryByDateTime;
	history, 
		moveHistory		:CM_MachineHistory;
	firstAcceptTS, firstPickupTS, 
	lastSetDownTS		:TimeStamp;
	type				:Integer;
begin
	// it helps if some of the local variables are initialised to null
	firstAcceptTS 	:= null;
	firstPickupTS	:= null;
	lastSetDownTS	:= null;
	// get all machine history items that make up the lift
	create liftColl transient;
	create moveColl transient;
	_history.getAllLiftEntries (liftColl); 
	
	// create the move kpi details - group the history items into moves
	// then create a move for each group and add it to the lift
	// they will be in order that the move was started
	foreach history in liftColl reversed do 
		if history.type = CM_MachineHistory.Type_SetDown and  history.CM_MachineMoveHistory.isEndOfMove then 
			// create a move KPI object
			kpiMove := self.createKPIMoveDtl (history.CM_MachineMoveHistory);
			// add the move to the lift
			self.allKPIMachineMoves.insert (1, kpiMove);
			// kpiMove will tell us all the history items that are part of the move
			kpiMove.allMachineHistory.copyNoDuplicates (self.allMachineHistory, false);
			// remove this move from our lift collection
			foreach moveHistory in kpiMove.allMachineHistory do
				type := moveHistory.type;
				// save time of 1st accept
				if type = CM_MachineMoveHistory.Type_AcceptMove and (firstAcceptTS = null or firstAcceptTS &gt; moveHistory.dateTime) then
					firstAcceptTS := moveHistory.dateTime;
				endif;
				// save off time of 1st pickup/move
				if (type = CM_MachineMoveHistory.Type_PickUp or type = CM_MachineMoveHistory.Type_Move) and
					(firstPickupTS = null or firstPickupTS &gt; moveHistory.dateTime) then
					firstPickupTS := moveHistory.dateTime;
				endif;
				
				if type = CM_MachineMoveHistory.Type_SetDown then
					if moveHistory.dateTime &gt; lastSetDownTS then
						lastSetDownTS := moveHistory.dateTime;
					endif;
				endif;
				// remove history we have processed
				liftColl.removeIfPresent (moveHistory);
			endforeach;
		endif;
		

	endforeach;
	// in theory when we get to here liftColl should be empty
	executeWhen JMTDevelopmentEnvironment;
	if not liftColl.isEmpty then
		//app.raiseUnexpectedProgramError (self.class.name, method.name, 'Coll should be empty');
	endif;
	endExecuteWhen;
		
	// if there was no accept (maybe manual overstow) then use first pickup TS
	if firstAcceptTS = null then			// par 30382 oct 2012
		firstAcceptTS := firstPickupTS;		// par 30382 oct 2012
	endif;									// par 30382 oct 2012
	
	if firstAcceptTS &lt;&gt; null and firstPickupTS &lt;&gt; null then
		self.slackTime	:= firstPickupTS.getDifferenceInSeconds (firstAcceptTS).rounded;
	endif;

	if lastSetDownTS &lt;&gt; null and firstPickupTS &lt;&gt; null then
		self.duration	:= lastSetDownTS.getDifferenceInSeconds (firstPickupTS).rounded;
	endif;
	
	if firstAcceptTS &lt;&gt; null and lastSetDownTS &lt;&gt; null then
		self.grossDuration	:= lastSetDownTS.getDifferenceInSeconds (firstAcceptTS).rounded;
	endif;
	
	self.acceptTS		:= firstAcceptTS;
	self.startTS		:= firstPickupTS;
	self.finishTS		:= lastSetDownTS;		// last setdown formove
	self.weight			:= self.weight + _history.weight;
		
	self.myKPIMachineEntity		:= _kpi;
epilog
	delete liftColl;
	delete moveColl;
end;</source>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <Parameter name="_kpi" type="CM_KPIMachineEntity"/>
    </JadeMethod>
    <JadeMethod name="updateForDelay" id="36bf840c-a417-4594-8284-9b1010f6a275">
        <updating/>
        <source>updateForDelay(_delay: CM_Delay) updating;
/*
Purpose:			

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	move	:CM_KPIMachineMoveDtl;
begin
	inheritMethod(_delay);

	foreach move in self.allKPIMachineMoves do
		move.updateForDelay (_delay);
	endforeach;
epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
</Class>
