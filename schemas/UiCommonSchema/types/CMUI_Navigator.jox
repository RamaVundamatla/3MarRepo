    <JadeMethod name="saveAsJMTDefault" id="1ae04afb-e1f8-402c-b4cf-6eed215e77d1">
        <source>saveAsJMTDefault() protected;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuAgent			: CM_MenuAgent;
	obj					: Object;	
	userRoot			: CM_MenuRoot;
	menuEntity			: CM_MenuEntity;
	menuRoot			: CM_MenuRoot;
begin
	app.mousePointer := MousePointer_HourGlass;
	create menuAgent transient;

	if (not app.isSpecial()) then
		app.raiseUnexpectedProgramError(class.name, method.name,'User became able to define JMT menu');
		return;
	endif;
	
	if not app.msgBox("You're about to re-define global constant text that defines the" &amp; CrLf &amp;
 					'parent child relationship of system menu entities ' &amp; CrLf &amp;
 					'This operation will create MenuHdr global constants for any ' &amp; CrLf &amp;
 					'menu headers that do not already exist - these can only be removed in the IDE.','READ ME FIRST', MsgBox_OK_Cancel) = MB_OK then
		return;
	endif;
	
	userRoot := self.lstTest.getRootOfCurrentEntity;	
	if userRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User menu root could not be found');
		return;
	endif;

	if userRoot.isKindOf(CM_MenuRootForUser) then //system item menu
		menuAgent.trxSaveSysEntMenuAsJMTDefault(menuAgent.myJMTMenuRootForSysEntites, userRoot);
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									"System Item Menu, Save Menu as JMT Default",	//_description : String;
									false,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	elseif userRoot.isKindOf(CM_MenuRootUserTerminal) then  //nav menu
		menuAgent.trxSaveNavMenuAsJMTDefault(menuAgent.myJMTMenuRoot, userRoot);
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									"Terminal Menu, Save Menu as JMT Default",	//_description : String;
									false,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown user menu root type');
	endif;
	
epilog
	self.lstTest.displayTree(true, null);
	app.mousePointer := MousePointer_Default;
	delete menuAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveAsSystemDefault" id="a85e73fd-a2d7-4993-9f6a-b933f604c995">
        <source>saveAsSystemDefault() protected;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	menuAgent			: CM_MenuAgent;
	obj					: Object;	
	userRoot			: CM_MenuRoot;

begin
	app.mousePointer := MousePointer_HourGlass;
	
	if not self.canDo(PmAdmAdminMenuAccess) then
		app.msgBox('You do not have sufficient permission to perform this task','Error',0);
		return;
	endif;
	
	create menuAgent transient;
	userRoot := self.lstTest.getRootOfCurrentEntity;
	if userRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User menu root could not be found');
		return;
	endif;
	
	beginTransaction;
	if userRoot.isKindOf(CM_MenuRootForUser) then //system item menu
		menuAgent.trxSaveToSourceMenuRoot(userRoot, menuAgent.mySystemMenuRootForSysEntities, null, true);
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									"System Menu, Save Menu as System Default",	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	elseif userRoot.isKindOf(CM_MenuRootUserTerminal) then  //nav menu
		menuAgent.trxSaveToSourceMenuRoot(userRoot, menuAgent.mySystemMenuRoot, null, true);
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									"Terminal Menu, Save Menu as System Default",	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown user menu root type');
	endif;
	//permission should have been checked before this - but small overhead - belts/braces etc.
	
	commitTransaction;
epilog
	self.lstTest.displayTree(true, null);
	app.mousePointer := MousePointer_Default;
	
	delete menuAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
