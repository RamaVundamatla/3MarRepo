<CollClass name="CM_YABlockArray" id="3fd4a1b8-0a7a-4634-8bb5-c144f4c07731">
    <loadFactor>66</loadFactor>
    <memberType name="CM_YABlock"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="auditIdDisplay" id="9293f5a8-0a09-4201-9231-0f0ea2cd74f5">
        <source>auditIdDisplay(): String;

// ---------------------------------------------------------------------------
// Created:     August 2008 by consw1 (SFW1030)
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj : CM_Object;
	rtnStr : String;
begin
	foreach obj in self do
		if rtnStr = null then
			rtnStr := obj.auditId();
		else
			rtnStr := rtnStr &amp; '::' &amp; obj.auditId();
		endif;
	endforeach;
	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridRowBlock" id="501cf5b5-44f4-4dbd-a801-278665a5930a">
        <source>getGridRowBlock(pGridRowObj:CM_GridRow):CM_YABlock;
// --------------------------------------------------------------------------------
// Created:		19 April 2005 by cnwdad1
//
// Purpose:		Returns a reference to a YA Block for the specified Grid Row.
//
// Parameters:	pGridRowObj - A reference to the Grid Row who's YA Block to get.
//
// Returns:		A reference to a YA Block, or null if no Block exists for the Grid Row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	
begin
	foreach blockObj in self do
		if CM_YABlockStraddle.hasInstance(blockObj) then
			if blockObj.CM_YABlockStraddle.getGridRow() = pGridRowObj then
				return blockObj;
			endif;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pGridRowObj" type="CM_GridRow"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="getIrregularControllerBlock" id="9a9b6b46-51ff-475a-8e4d-1e06ec7214e0">
        <source>getIrregularControllerBlock(_controller : CM_IrregularBlockController) : CM_YABlock;
/* ---------------------------------------------------------------------------
Created:     25 June 2008 by cnwrs2

Purpose:     PAR 17217
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	blockObj	: CM_YABlock;
	
begin
	foreach blockObj in self do
		if CM_YAIrregularBlock.hasInstance(blockObj) and
		   blockObj.CM_YAIrregularBlock.getIrregularBlockController() = _controller then
			return blockObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_controller" type="CM_IrregularBlockController"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="getRoRoLaneControllerBlock" id="1b48d377-141e-4198-bfe7-cf0c3fc2bb3d">
