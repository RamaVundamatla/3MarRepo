    <JadeMethod name="reScaleWeekMonthHeight" id="647017ca-610d-47b2-9a28-c54a073527c0">
        <source>reScaleWeekMonthHeight() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2010	cnwndl1	Initial creation

*/

vars

	baseCellHeight : Integer;
	row : Integer;
	vHeight : Real;
	vRowHeight : Integer;
	usedHeight : Real;
	
begin

	if self.tblCalendar.rows = 1 then
		return;
	endif;
	
	baseCellHeight := 16;	// the heading.

	vHeight := self.tblCalendar.height - baseCellHeight - self.tblCalendar.rows;
	vRowHeight := ( vHeight / ( self.tblCalendar.rows - 1 ) ).Integer;
	
	foreach row in 2 to self.tblCalendar.rows do
		self.tblCalendar.accessRow(row).height := vRowHeight;
	endforeach;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetListBoxContents" id="83e82929-0b8f-401f-ac54-f88a2cfefbb1">
        <source>resetListBoxContents( _listBox : CMUI_ListBox; _date : Date; _time : TimeStamp; _row : Integer; _column : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

	newIndex : Integer;
	calendarDate : CM_CalendarDate;
	calendarYear : CM_CalendarYear;
	calendar : CM_Calendar;
	checkDayType : Boolean;
	checkCalendar : Boolean;
	term : CM_Terminal;
	allCalendarDates : CM_CalendarDatesByDateTimedict;
	calDateEndTime : Time;
	nullTime : Time;
	midnightTime : Time;
	timeDisplayStr : String;
	
begin

	_listBox.clear();

	checkDayType := not self.allSelectedDayTypes.isEmpty;
	checkCalendar := not self.allSelectedCalendars.isEmpty;
	term := self.myTerminal;
	
	create allCalendarDates transient;
	
	if _time = null then
	
		newIndex := _listBox.addItem( _date.asStringJMT );
		_listBox.itemBackColor[newIndex] := xmlColourDateBack;
		
		foreach calendar in app.myRoot.allCalendars do
			
			if term = null then
				// show everything, have been called from Sys ops
			else
				// show for this terminal only, called from individual terminal view.
				if not calendar.allTerminals.includes(term) then
					continue;
				endif;
			endif;
			
			if checkDayType and not self.allSelectedDayTypes.includes( calendar.myDayType ) then
				continue;
			endif;
	
			if checkCalendar and not self.allSelectedCalendars.includes( calendar ) then
				continue;
			endif;
			
			calendar.getAllCalendarDatesForDay( _date, allCalendarDates);
			
			foreach calendarDate in allCalendarDates do
			
				timeDisplayStr := calendarDate.getTimeDisplay.trimBlanks;
				if timeDisplayStr = null then
					newIndex := _listBox.addItem( calendarDate.description );
				else
					newIndex := _listBox.addItem( timeDisplayStr &amp; " " &amp; calendarDate.description );
				endif;
				_listBox.itemObject[newIndex] :=  calendarDate;
				self.allCalendarDatesDisplayed.addNoDuplicates(calendarDate, false);
				
			endforeach;
			
		endforeach;
	
	else
	
		nullTime := "00:00:00".Time;
		midnightTime := "23:59:59.999".Time;
	
		foreach calendar in app.myRoot.allCalendars do
			
			if term = null then
				// show everything, have been called from Sys ops
			else
				if not calendar.allTerminals.includes(term) then
					continue;
				endif;
			endif;
			
			if checkDayType and not self.allSelectedDayTypes.includes( calendar.myDayType ) then
				continue;
			endif;
		
			if checkCalendar and not self.allSelectedCalendars.includes( calendar ) then
				continue;
			endif;
			
			calendar.getAllCalendarDatesForDay( _date, allCalendarDates);
			
			foreach calendarDate in allCalendarDates do	
			
				timeDisplayStr := calendarDate.getTimeDisplay.trimBlanks;

				if timeDisplayStr = null then
					// this is data for the whole day, not per hour.
					continue;
				endif;
			
				calDateEndTime := calendarDate.endTime;
				if calDateEndTime = nullTime then
					calDateEndTime := midnightTime;
				endif;
				
				if ( calendarDate.startTime &lt;= _time.time and _time.time &lt; calDateEndTime ) then
					newIndex := _listBox.addItem( timeDisplayStr &amp; " " &amp; calendarDate.description );
					_listBox.itemObject[newIndex] :=  calendarDate;
					self.allCalendarDatesDisplayed.addNoDuplicates(calendarDate, false);
				endif;
				
			endforeach;
			
		endforeach;


	
	endif;

	self.displaycellText( _row, _column );
	
epilog

	delete allCalendarDates;
	
end;</source>
        <Parameter name="_listBox" type="CMUI_ListBox"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCellDataForDay" id="42548246-28cf-4370-a6c1-2ccacd67fbd0">
        <source>setCellDataForDay( date : Date );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	rowIndex : Integer;
	listBox : CMUI_ListBox;
	tableCell : JadeTableCell;
	tableRow : JadeTableRow;
	baseTimeIndex : Integer;
	baseTime : Time;
	baseTimeStamp : TimeStamp;
	index : Integer;
	now : TimeStamp;
	baseCellHeight : Integer;

begin
	
	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	now := self.systemToLocalTime(app.actualTimeServer());// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	baseTime.setTime(0,0,0,0);
	baseTimeStamp.setDate( date );
	baseTimeStamp.setTime( baseTime );
	baseTimeIndex := 100;	// The hour of the day plus 100. (i.e. this is midnight)
	listBox := self.lstActivity.getControl(100).CMUI_ListBox;
	baseCellHeight := 16;

	if listBox = null then
	
		self.tblCalendar.setCellText(1,1,date.asStringJMT);
		
		self.setHeadingForDayColumnDisplay( date, baseCellHeight );

		index := baseTimeIndex;
		foreach rowIndex in 2 to 25 do
			self.tblCalendar.rows := self.tblCalendar.rows + 1;
			tableCell := self.tblCalendar.accessCell(rowIndex,1);
			tableCell.alignment := Table.Alignment_Left_Top;
			tableCell.text := (baseTimeStamp.Time.asStringJMT);
			tableCell := self.tblCalendar.accessCell(rowIndex,2);
			tableCell.alignment := Table.Alignment_Left_Top;
			tableRow := self.tblCalendar.accessRow(rowIndex);
			tableRow.backColor := xmlColourDateBack; // by default.
			tableRow.foreColor := xmlColourDateBack.getInverseColour();
			if now.Time.hour = baseTimeStamp.Time.hour then
				if now.Date = baseTimeStamp.Date then
					tableRow.backColor := xmlColourCurrentDay;
					tableRow.foreColor := xmlColourCurrentDay.getInverseColour();
				endif;
			endif;
			listBox := self.lstActivity.loadControl(index).CMUI_ListBox;
			self.listBoxIndexArray.add(index);
			listBox.visible := true;
			listBox.enabled := true;
			tableCell.cellControl := listBox;
			self.resetListBoxContents( listBox, date, baseTimeStamp, rowIndex, 2 );
			if listBox.listCount &gt; 5 then
				tableRow.height := (baseCellHeight * 5);
			elseif listBox.listCount &gt; 1 then
				tableRow.height := (baseCellHeight * listBox.listCount);				
			else
				tableRow.height := baseCellHeight;
			endif;
			baseTime.setTime(baseTime.Time.hour + 1,00,00,000);
			baseTimeStamp.setTime(baseTime);
			index := 100 + baseTime.hour;
		endforeach;
		
	endif;
		
epilog

end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setCellDataForWeek" id="ce28a707-4fdb-48f5-b854-167b0afb07c6">
        <source>setCellDataForWeek( date : Date );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	rowIndex : Integer;
	colIndex : Integer;
	listBox : CMUI_ListBox;
	tableCell : JadeTableCell;
	tableRow : JadeTableRow;
	baseDayIndex : Integer;
	baseDay : Date;
	index : Integer;
	newIndex : Integer;
	today : Date;
	baseCellHeight : Integer;
	listCount : Integer;

begin
	
	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	today := self.systemToLocalTime(app.actualTimeServer()).date();// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// find the first date that will be in the row, i.e. the Monday.
	if date.dayOfWeek = 1 then
		baseDay := date;
	else
		baseDay := date.lastMonday;
	endif;
	
	baseDayIndex := baseDay.dayOfYear;
	listBox := self.lstActivity.getControl(baseDayIndex).CMUI_ListBox;
	listCount := 1;
	baseCellHeight := 16;
	tableRow := self.tblCalendar.accessRow(1);
	tableRow.height := ( baseCellHeight );
	
	if listBox = null then
		// we don't have a row that includes the monday, so have to build one.
		
		self.tblCalendar.rows := self.tblCalendar.rows + 1;
		rowIndex := self.tblCalendar.rows;
		tableRow := self.tblCalendar.accessRow(rowIndex);
		
		index := baseDayIndex;
		
		foreach colIndex in 1 to self.tblCalendar.columns do
			tableCell := self.tblCalendar.accessCell(rowIndex,colIndex);
			tableCell.alignment := Table.Alignment_Left_Top;
			if today = baseDay then
				tableCell.backColor := xmlColourCurrentDay;
				tableCell.foreColor := xmlColourCurrentDay.getInverseColour();
			elseif baseDay.month &lt;&gt; date.month then
				tableCell.backColor := xmlColourNonCurrMth;
				tableCell.foreColor := xmlColourNonCurrMth.getInverseColour();
			else
				tableCell.backColor := xmlColourDateBack;
				tableCell.foreColor := xmlColourDateBack.getInverseColour();
			endif;
			listBox := self.lstActivity.loadControl(index).CMUI_ListBox;
			self.listBoxIndexArray.add(index);
			listBox.visible := true;
			listBox.enabled := true;
			tableCell.cellControl := listBox;
			self.resetListBoxContents( listBox, baseDay, null, rowIndex, colIndex );
			baseDay := baseDay + 1;
			index := baseDay.dayOfYear;
			if listBox.listCount &gt; listCount then
				listCount := listBox.listCount;
			endif;
		endforeach;
		
		if listCount &gt; 5 then
			tableRow.height := (baseCellHeight * 5);
		elseif listCount &gt; 3 then
			tableRow.height := (baseCellHeight * listCount);				
		else
			tableRow.height := baseCellHeight * 3;
		endif;
		
	else
		// we have the row with Monday in it
		// so now we find the row of the control
		listBox := self.lstActivity.getControl(date.dayOfYear).CMUI_ListBox;
		rowIndex := 0;
		colIndex := date.dayOfWeek;
		foreach index in 1 to self.tblCalendar.rows do
			tableCell := self.tblCalendar.accessCell(index,colIndex);
			if tableCell.cellControl = listBox then
				rowIndex := index;
				self.resetListBoxContents( listBox, date, null, rowIndex, colIndex );
				break;
			endif;
		endforeach;
	endif;
		
epilog

end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setColours" id="aefd665d-17f1-4bab-80c8-f4c906c58bc0">
        <updating/>
        <source>setColours() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2010	cnwndl1	Initial creation

*/

vars

begin

	if self.xmlColourCurrentDay = 0 then
		self.xmlColourCurrentDay := self.colorValueColumn;
	endif;
	if self.xmlColourNonCurrMth = 0 then
		self.xmlColourNonCurrMth := self.colorRow2;
