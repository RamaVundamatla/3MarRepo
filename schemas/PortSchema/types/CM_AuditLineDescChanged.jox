    <JadeMethod name="getDatetimeLocalTZ" id="78cbb12c-12e2-42a6-896c-2f31319da23b">
        <source>getDatetimeLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support


*/

vars

begin
	return self.systemToLocalTime(self.datetime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0c4f34e1-820a-4a90-99af-63841657995f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.remarks;	
	elseif _attrName = ETRow_User  then
		return self.userId;	
	elseif _attrName = ETRow_EndDate  then
		return self.systemToLocalTime(self.datetime).String;	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Ti  then
		return null;	
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="50bf5a26-fb17-44ef-8a37-d695ac1f8e94">
        <source>getPropertyCol(): String;

// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	str : String;
	dateTimeLocal : TimeStamp;
begin
	dateTimeLocal := self.systemToLocalTime(datetime);
	str := sequenceNum.String &amp; Tab;
	str := str &amp; remarks &amp; Tab;
	str := str &amp; userId &amp; Tab;
	str := str &amp; dateTimeLocal.date.shortFormatJMT() &amp; " " &amp; dateTimeLocal.time.currentLocaleFormatJMT() &amp; Tab;// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	str := str &amp; "";

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
