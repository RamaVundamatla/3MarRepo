    <JadeMethod name="getWLEForMove" id="3d6b59ad-2f63-4588-a718-83bb4c1d41f7">
        <source>getWLEForMove() : CM_WorkListEntry;
/*
Purpose:			

Date		Who		Reason
24 January 2022	navab1	TFS 51855
*/

vars
	sourceLC, targetLC : CM_LocationsController;
	move : CM_Move;
	wle : CM_WorkListEntry;

begin
	
	move := self;
	if move &lt;&gt; null then
		sourceLC := move.getSourceLocationsController();
		
		if sourceLC &lt;&gt; null then
			wle := sourceLC.getWLEForTI(self.myTrackedItem); // ### TFS 51855 10FEB2022 NAVAB1
			if wle = null then
				targetLC := move.getTargetLocationsController();
				
				if targetLC &lt;&gt; null then
					wle := targetLC.getWLEForTI(self.myTrackedItem); // ### TFS 51855 10FEB2022 NAVAB1
				endif;
			endif;
			
		endif;
	endif;

	return wle;

epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="hasStockMovements" id="a3954ee4-de5b-40be-8078-95b339d20081">
        <source>hasStockMovements(): Boolean;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myStockMovementIn &lt;&gt; null or
	   self.myStockMovementOut &lt;&gt; null then
	   	return true;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasStockMovementsOtherThanMe" id="0ea2c589-d454-4ae2-ade1-2f90de85733d">
        <source>hasStockMovementsOtherThanMe(_stockMovementBeingDeleted: CM_StockMovement input): Boolean;
// Created by cnwdvb1 on 26 July 2006

vars

begin

	if (self.myStockMovementIn &lt;&gt; null and (self.myStockMovementIn &lt;&gt; _stockMovementBeingDeleted)) or
	   (self.myStockMovementOut &lt;&gt; null and (self.myStockMovementOut &lt;&gt; _stockMovementBeingDeleted)) then
	   	return true;
	endif;
	
	return inheritMethod(_stockMovementBeingDeleted);

end;</source>
        <Parameter name="_stockMovementBeingDeleted" type="CM_StockMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="a651c9fc-1648-45e1-b44e-0e279a8cbf57">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
15 December 2021	navab1	TFS 51855

// ### TFS 51855 013AN2022 NAVAB1 N4 has 1 move event that represents all the pickup setdowns for moving cargo from a to b. In MTN there is a sequence of seperate move transactions.
									SO MTN will send a single INV_MOVE_EVENT for the whole sequence based on the final move transaction.
									The final move transaction in most cases will be a setdown. However if loading to a vessel and the lander app is being used then the last move transaction is a crane move.
//									
*/

vars
	opsviewtable : CMIF_InvMoveEvent;
	isLoad : Boolean;
	sourceLC, targetLC, useLC : CM_LocationsController;
	moves : CM_TITransactionByDateOrdDict;
	move, pickup, pickup2, setdown, justmove : CM_Move;
	mach : CM_Machine;
	machHistory : CM_MachineHistory;
	transport : CM_Object;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	crane : CM_Crane;
	req : CM_Request;
	isLanderPickup, isLanderSetdown : Boolean;
	slotreq : CM_SlotRequest;
	sourceLabel, targetLabel : String;
	prefix : String;
	wp : CM_WorkPoint;
begin
	opsviewtable := _opsViewTable.CMIF_InvMoveEvent;
	

	opsviewtable.move_kind := opsviewtable.n4MoveKind(self);
	//navra1 TFS-53069 May 11th 2022			
	if opsviewtable.move_kind = opsviewtable.Move_Kind_Shift then
		opsviewtable.rehandle_count := 1;				
	endif;
	opsviewtable.ufv_gkey := opsviewtable.generateFullGKey(self.myTrackedItem, "");
	opsviewtable.freight_kind := opsviewtable.n4FreightKind(self.myTrackedItem);
	opsviewtable.category := opsviewtable.n4Category(self.imExStatus);
	
	if self.voyage &lt;&gt; null then // ### TFS 51855 01FEB2022 NAVAB1
		opsviewtable.berth := self.voyage.getBerthCodeCurrent(); // ### TFS 51855 01FEB2022 NAVAB1
	endif;
	
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		if ti.receiptTransportMode = TI_TRANSMODE_SHIP then
			opsviewtable.t_discharge := ti.receivedDT.asEpochFormat(); // Pickup in CTA
		endif;
		
		opsviewtable.line_op :=  opsviewtable.generateFullGKey(ti.myOperator, ""); // ### TFS 51855 24JAN2022 NAVAB1 
	endif;
	
	create moves transient;
	self.myTrackedItem.getAllMovesForMove(self, moves);
	if not moves.includes(self) then
		moves.add(self);
	endif;
	
	move := moves.first.CM_Move;
	opsviewtable.mve_gkey := opsviewtable.generateFullGKey(move, ""); // ### TFS 51855 013AN2022 NAVAB1 use the first move in this sequence for the GKEY
	opsviewtable.gkey		:= opsviewtable.generateFullGKey(move, ""); // ### TFS 51855 25MAY2022 NAVAB1

	// ### THESE could be a simple MOVE or pickup and setdown
	foreach move in moves as CM_Move do
		// first pickup, mightbe a CM_Move if a discharge using the lander
		if not move.isKindOf(CM_Pickup) 
		and not move.isKindOf(CM_SetDown)
		and move.isKindOf(CM_CraneMove)
		and move.operational then
			if pickup = null then
				pickup := move;
				isLanderPickup := true;
			endif;
		
		
		endif;
		if not move.isKindOf(CM_Pickup) 
		and not move.isKindOf(CM_SetDown)
		and move.isLanderLoadMove() then
			setdown := move;
			isLanderSetdown := true;
		endif;
		
		if  move.isKindOf(CM_Pickup) then
			if pickup = null then
				pickup := move;
			endif;
			
			pickup2 := move;
		endif;
		
		// last setdown
		if  move.isKindOf(CM_SetDown) then
			setdown := move;
		endif;
		
		
	endforeach;
	
	// SIMPLE MOVE
	if pickup = null and setdown = null and moves.size = 1 then
		move := moves.first.CM_Move;
		sourceLC := move.getSourceLocationsController();
		targetLC := move.getTargetLocationsController();
		
		sourceLabel := sourceLC.getStowageId(move.myTrackedItem);
		if sourceLabel = null then
			sourceLabel := move.sourceLocn;
		endif;
		
		targetLabel := targetLC.getStowageId(move.myTrackedItem);
		if targetLabel = null then
			targetLabel := move.targetLocn;
		endif;
		
		opsviewtable.move_kind := opsviewtable.n4MoveKind(move);
		//navra1 TFS-53069 May 11th 2022			
		if opsviewtable.move_kind = opsviewtable.Move_Kind_Shift then
			opsviewtable.rehandle_count := 1;				
		endif;
		opsviewtable.che_fetch_login_name := self.userId; // ### TFS 51855 31JAN2022 NAVAB1
		opsviewtable.che_carry_login_name := self.userId; // ### TFS 51855 31JAN2022 NAVAB1
		opsviewtable.che_put_login_name := self.userId; // ### TFS 51855 31JAN2022 NAVAB1
		
		// SOURCE
		opsviewtable.fm_pos_loc_gkey := opsviewtable.generateFullGKey(sourceLC,"");
		opsviewtable.fm_pos_slot := sourceLabel;  // slot id e.g. 830688
		opsviewtable.fm_pos_name := move.sourceLocn; // FULL LOCN ID e.g. VOY1223 830688 or GBS A01 1
		opsviewtable.fm_pos_bin := opsviewtable.generateFullGKey(sourceLC,""); // GKEY of spatial bin which is the location controller. // ### TFS 53369 28APR2022 NAVAB1
		opsviewtable.fm_pos_tier := sourceLC.allTrackedItems.size() + 1;  // 1,2,3 etc. with in locations controller // ### TFS 53369 22APR2022 NAVAB1, plus one since the ti is not there anymore
		
		
		
		opsviewtable.fm_pos_loctype := opsviewtable.n4LocationType(move.getInvMoveSourceString());
		
		opsviewtable.t_put :=  move.dateTime.asEpochFormat();  // Last Setdown TS
		
		// TARGET
		opsviewtable.to_pos_loc_gkey := opsviewtable.generateFullGKey(targetLC,"");
		opsviewtable.to_pos_slot := targetLabel;  // slot id e.g. 830688
		opsviewtable.to_pos_name := move.targetLocn; // FULL LOCN ID e.g. VOY1223 830688 or GBS A01 1
		opsviewtable.to_pos_bin := opsviewtable.generateFullGKey(targetLC,""); // GKEY of spatial bin which is the location controller.  // ### TFS 53369 28APR2022 NAVAB1
		opsviewtable.to_pos_tier := targetLC.getActualStackPositionOfTI(ti);  // 1,2,3 etc. with in locations controller // ### TFS 53369 22APR2022 NAVAB1
		
		opsviewtable.t_carry_complete := move.dateTime.asEpochFormat();		
		opsviewtable.to_pos_loctype := opsviewtable.n4LocationType(move.getInvMoveTargetString());
		
		wle := self.getWLEForMove(); // ### TFS 51855 24JAN2022 NAVAB1
		if wle &lt;&gt; null then // ### TFS 51855 24JAN2022 NAVAB1
		
			if wle.myRequest.isSOB() then // ### TFS 51855 10FEB2022 NAVAB1
				opsviewtable.fm_pos_locid := wle.myRequest.getMyVoyageObject().code; // ### TFS 51855 10FEB2022 NAVAB1
				opsviewtable.to_pos_locid := wle.myRequest.getMyVoyageObject().code; // ### TFS 51855 10FEB2022 NAVAB1
			else
			
				self.getFromToTransportCodes(wle,move,opsviewtable.fm_pos_locid, opsviewtable.to_pos_locid); // ### TFS 51855 11FEB2022 NAVAB1
			endif;
			
			if wle.myRequest.isSlotRequest() then // ### TFS 51855 24JAN2022 NAVAB1
				slotreq := wle.myRequest.CM_SlotRequest;
				
				crane := slotreq.getCrane(); // ### TFS 51855 24JAN2022 NAVAB1
				if crane &lt;&gt; null then // ### TFS 51855 24JAN2022 NAVAB1
					opsviewtable.che_qc := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 24JAN2022 NAVAB1
					opsviewtable.che_fetch := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 24JAN2022 NAVAB1
					if not slotreq.isDischarge then // ### TFS 51855 31JAN2022 NAVAB1
						opsviewtable.che_put := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 24JAN2022 NAVAB1
					elseif slotreq.isSOB then // ### TFS 51855 31JAN2022 NAVAB1
						opsviewtable.che_put := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 31JAN2022 NAVAB1
						opsviewtable.che_carry := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 31JAN2022 NAVAB1
						
					endif;
				endif;
			elseif wle.myRequest.isHoldRequest() then // ### TFS 53105 16JUN2022 NAVAB1
				wp := wle.job.CM_VoyageHoldJob.getMyWorkPointObject().CM_WorkPoint; // ### TFS 53105 16JUN2022 NAVAB1
				if wp &lt;&gt; null then // ### TFS 53105 16JUN2022 NAVAB1
					opsviewtable.che_qc := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
					opsviewtable.che_fetch := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
					if not wle.myRequest.CM_HoldRequest.isDischarge then  // ### TFS 53105 16JUN2022 NAVAB1
						opsviewtable.che_put := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
					elseif wle.myRequest.isSOB then  // ### TFS 53105 16JUN2022 NAVAB1
						opsviewtable.che_put := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
						opsviewtable.che_carry := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
						
					endif;
				
				
				endif;
			endif;
		else	
			self.getFromToTransportCodes(null,move,opsviewtable.fm_pos_locid, opsviewtable.to_pos_locid); // ### TFS 53105 03JUN2022 NAVAB1
		endif;

		
	else
		// PICKUP and SETDOWN
		if pickup &lt;&gt; null then

		
			sourceLC := pickup.getSourceLocationsController();
			sourceLabel := sourceLC.getStowageId(pickup.myTrackedItem);
			if sourceLabel = null then
				sourceLabel := pickup.sourceLocn;
			endif;
			
			wle := pickup.getWLEForMove(); // ### TFS 51855 28JAN2022 NAVAB1   // ### TFS 51855 24MAY2022 NAVAB1 moved up in the code
			if wle &lt;&gt; null  // ### TFS 51855 24MAY2022 NAVAB1
			and wle.isReceipt then  // ### TFS 51855 24MAY2022 NAVAB1 only use the pickup if the WLE is a discharge
				opsviewtable.move_kind := opsviewtable.n4MoveKind(pickup);
			endif;
			
			//navra1 TFS-53069 May 11th 2022			
			if opsviewtable.move_kind = opsviewtable.Move_Kind_Shift then
				opsviewtable.rehandle_count := 1;				
			endif;
		
			machHistory := pickup.allMachineMoveHistories.first;
			mach := null;
			if machHistory &lt;&gt; null then
				mach := machHistory.machine;
				opsviewtable.che_fetch_login_name := machHistory.userId;
				opsviewtable.che_fetch := opsviewtable.generateFullGKey( mach, ""); 
			elseif isLanderPickup then
				mach := pickup.getCraneForMove();
				opsviewtable.che_fetch := opsviewtable.generateFullGKey( mach, ""); 
				opsviewtable.che_fetch_login_name := pickup.userId;
			endif;


			opsviewtable.t_fetch := pickup.dateTime.asEpochFormat(); // First Pickup TS 
			opsviewtable.twin_fetch := false;
			
			//SOURCE
			opsviewtable.fm_pos_loc_gkey := opsviewtable.generateFullGKey(sourceLC,"");
			
			opsviewtable.fm_pos_slot := sourceLabel;  // slot id e.g. 830688
			opsviewtable.fm_pos_name := pickup.sourceLocn; // FULL LOCN ID e.g. VOY1223 830688 or GBS A01 1
			opsviewtable.fm_pos_bin := opsviewtable.generateFullGKey(sourceLC,"");  // GKEY of spatial bin which is the location controller. // ### TFS 53369 22APR2022 NAVAB1
			opsviewtable.fm_pos_tier := sourceLC.allTrackedItems.size() + 1;  // 1,2,3 etc. with in locations controller // ### TFS 53369 22APR2022 NAVAB1, plus one since the ti is not there anymore
			opsviewtable.fm_pos_loctype := opsviewtable.n4LocationType(pickup.getInvMoveSourceString());
			
		    opsviewtable.che_qc:= opsviewtable.generateFullGKey( mach, ""); //navra1 - TFS-51855 - 25th May 2022
			
			// ### TFS 51855 24MAY2022 NAVAB1 wle := pickup.getWLEForMove(); // ### TFS 51855 28JAN2022 NAVAB1
			if wle &lt;&gt; null then // ### TFS 51855 28JAN2022 NAVAB1

				self.getFromToTransportCodes(wle,pickup,opsviewtable.fm_pos_locid, opsviewtable.to_pos_locid); // ### TFS 51855 11FEB2022 NAVAB1

			
				if wle.myRequest.isSlotRequest() then // ### TFS 51855 28JAN2022 NAVAB1
					slotreq := wle.myRequest.CM_SlotRequest;
				
					crane := slotreq.getCrane(); // ### TFS 51855 28JAN2022 NAVAB1
					if crane &lt;&gt; null then // ### TFS 51855 28JAN2022 NAVAB1
						opsviewtable.che_qc := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 28JAN2022 NAVAB1
					endif;
				elseif wle.myRequest.isHoldRequest() then // ### TFS 53105 16JUN2022 NAVAB1
					wp := wle.job.CM_VoyageHoldJob.getMyWorkPointObject().CM_WorkPoint; // ### TFS 53105 16JUN2022 NAVAB1
					if wp &lt;&gt; null then // ### TFS 53105 16JUN2022 NAVAB1
						opsviewtable.che_qc := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
					endif;
				endif;
			endif;
			
		endif;
		
		if setdown &lt;&gt; null then
			targetLC := setdown.getTargetLocationsController();
			
			targetLabel := targetLC.getStowageId(setdown.myTrackedItem);
			if targetLabel = null then
				targetLabel := setdown.targetLocn;
			endif;
			
			wle := setdown.getWLEForMove(); // ### TFS 51855 28JAN2022 NAVAB1 // ### TFS 51855 24MAY2022 NAVAB1 moved up in the code
			if wle &lt;&gt; null  // ### TFS 51855 24MAY2022 NAVAB1
			and not wle.isReceipt then  // ### TFS 51855 24MAY2022 NAVAB1 only use the setdown if the WLE is a load
				opsviewtable.move_kind := opsviewtable.n4MoveKind(setdown);
			endif;
			
			machHistory := setdown.allMachineMoveHistories.first;
			mach := null;
			if machHistory &lt;&gt; null then
				mach := machHistory.machine;
				opsviewtable.che_put_login_name := machHistory.userId;
				opsviewtable.che_carry_login_name := machHistory.userId;
			elseif isLanderSetdown then // ### TFS 51855 28JAN2022 NAVAB1
				sourceLC := setdown.getSourceLocationsController(); // ### TFS 51855 28JAN2022 NAVAB1
				if sourceLC &lt;&gt; null  // ### TFS 51855 28JAN2022 NAVAB1
				and sourceLC.isMachineController() then // ### TFS 51855 28JAN2022 NAVAB1
					mach := sourceLC.CM_MachineController.myMachine; // ### TFS 51855 28JAN2022 NAVAB1
				endif;
			endif;
			
			opsviewtable.t_put :=  setdown.dateTime.asEpochFormat();  // Last Setdown TS
			opsviewtable.che_put := opsviewtable.generateFullGKey( mach, ""); 
			opsviewtable.twin_put := false;

			opsviewtable.twin_carry := false;
			opsviewtable.che_carry := opsviewtable.generateFullGKey(mach, ""); 
			
			opsviewtable.to_pos_loc_gkey := opsviewtable.generateFullGKey(targetLC,"");
			opsviewtable.to_pos_slot := targetLabel;  // slot id e.g. 830688
			opsviewtable.to_pos_name := setdown.targetLocn; // FULL LOCN ID e.g. VOY1223 830688 or GBS A01 1
			opsviewtable.to_pos_bin := opsviewtable.generateFullGKey(targetLC,"");  // GKEY of spatial bin which is the location controller. // ### TFS 53369 22APR2022 NAVAB1
			opsviewtable.to_pos_tier := targetLC.getActualStackPositionOfTI(ti);  // 1,2,3 etc. with in locations controller  // ### TFS 53369 22APR2022 NAVAB1
			
			opsviewtable.t_carry_complete := setdown.dateTime.asEpochFormat();		
			opsviewtable.to_pos_loctype := opsviewtable.n4LocationType(setdown.getInvMoveTargetString());
			
   		    opsviewtable.che_qc:= opsviewtable.generateFullGKey( mach, ""); //navra1 - TFS-51855 - 25th May 2022
			
			// ### TFS 51855 24MAY2022 NAVAB1 wle := setdown.getWLEForMove(); // ### TFS 51855 28JAN2022 NAVAB1
			if wle &lt;&gt; null then // ### TFS 51855 28JAN2022 NAVAB1
			
				if opsviewtable.to_pos_locid = "" then // already set by PICKUP

					self.getFromToTransportCodes(wle,setdown,opsviewtable.fm_pos_locid, opsviewtable.to_pos_locid); // ### TFS 51855 11FEB2022 NAVAB1


					if wle.myRequest.isSlotRequest() then // ### TFS 51855 28JAN2022 NAVAB1
						crane := wle.myRequest.CM_SlotRequest.getCrane(); // ### TFS 51855 28JAN2022 NAVAB1
						if crane &lt;&gt; null then // ### TFS 51855 28JAN2022 NAVAB1
							opsviewtable.che_qc := opsviewtable.generateFullGKey(crane,""); // ### TFS 51855 28JAN2022 NAVAB1
						endif;
					elseif wle.myRequest.isHoldRequest() then // ### TFS 53105 16JUN2022 NAVAB1
						wp := wle.job.CM_VoyageHoldJob.getMyWorkPointObject().CM_WorkPoint; // ### TFS 53105 16JUN2022 NAVAB1
						if wp &lt;&gt; null then // ### TFS 53105 16JUN2022 NAVAB1
							opsviewtable.che_qc := opsviewtable.generateFullGKey(wp,"");  // ### TFS 53105 16JUN2022 NAVAB1
						endif;
					endif;
				endif;	
			endif;

		endif;
		
		// try to get the IMV, overwrite if there is a 2nd pickup
		if pickup2 &lt;&gt; null 
		and pickup2 &lt;&gt; pickup then
			machHistory := pickup2.allMachineMoveHistories.last;
			mach := null;
			if machHistory &lt;&gt; null then
				mach := machHistory.machine;
				opsviewtable.che_carry_login_name := machHistory.userId;
			endif;
			opsviewtable.twin_carry := false;
			opsviewtable.che_carry := opsviewtable.generateFullGKey( mach, ""); 
		endif;
		
	endif;
	

	if sourceLC &lt;&gt; null then
		if sourceLC.isVoyageController()
		or sourceLC.isWagon() 
		or sourceLC.isVehicle() then
			useLC:= sourceLC;
		endif;
	else
	
	
	endif;
	
	if useLC = null then
		if targetLC &lt;&gt; null then
			if targetLC.isVoyageController()
			or targetLC.isWagon() 
			or targetLC.isVehicle() then
				useLC:= targetLC;
				isLoad := true;
			endif;
		endif;
	endif;
	
	if useLC &lt;&gt; null then
		transport := useLC.getTransport(isLoad);
		
		 // ### TFS 51855 19MAY2022 NAVAB1
		if transport.isKindOf(CM_Train) then
			if isLoad then
				prefix := _opsViewTable.Prefix_Outbound;
			else
				prefix := _opsViewTable.Prefix_Inbound;
			endif;
		endif;
		
		opsviewtable.carrier_gkey := opsviewtable.generateFullGKey(transport, prefix); // ### TFS 51855 19MAY2022 NAVAB1
//		opsviewtable.pow := ""; // this is the queue useLC.getJobSheetCode(isLoad); // not used by OpsView
	endif;

	
epilog

	 // ### TFS 53105 17JUN2022 NAVAB1
	opsviewtable.fm_pos_loctype := opsviewtable.fm_pos_loctype[1:16];
	opsviewtable.fm_pos_locid := opsviewtable.fm_pos_locid[1:16];
	opsviewtable.fm_pos_slot := opsviewtable.fm_pos_slot[1:16];
	opsviewtable.fm_pos_orientation := opsviewtable.fm_pos_orientation[1:16];
	opsviewtable.to_pos_loctype := opsviewtable.fm_pos_loctype[1:16];
	opsviewtable.to_pos_locid := opsviewtable.to_pos_locid[1:16];
	opsviewtable.to_pos_slot := opsviewtable.to_pos_slot[1:16];
	opsviewtable.to_pos_orientation := opsviewtable.to_pos_orientation[1:6];
	opsviewtable.to_pos_name := opsviewtable.to_pos_name[1:42];
	opsviewtable.fm_pos_name := opsviewtable.fm_pos_loctype[1:42];
	
	delete moves;
end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
