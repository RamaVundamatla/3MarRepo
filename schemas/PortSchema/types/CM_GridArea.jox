    <JadeMethod name="getReeferWalkPositions" id="f986d71d-b981-436b-b7dc-cf171a3f428a">
        <source>getReeferWalkPositions(_pxyReeferBlock : CM_ReeferBlock input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 August 2023	navpw1	Initial creation TFS: 57947 (59757)

*/

vars
	lc					: CM_LocationsController;
	gridController		: CM_GridController;
	availability,
	gridMaxHeight,
	tier,
	count				: Integer;
	proxyReeferBlockPos	: CM_ReeferBlockPosition;
	
begin
	if not _pxyReeferBlock.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, "Cannot call this method, with a non-transient reefer block.");
		
	endif;
	
	//create a proxy for each of the potential positions.
	foreach lc in self.allLocationsControllers do
		if not lc.isGridLocation then
			continue;
		endif;
		
		gridController := lc.CM_GridController;
		availability := gridController.getAvailability(); //availability lives on CM_StackController &amp; CM_RTGController &amp; CM_OverhangController and is not inherited
		
		if availability &lt;&gt; PAD_AVAILABLE then
			//Ignore unavailable locations if pads are unavailable, safer than changing getMaxStackingHeight that does this as its called elsewhere.
			gridMaxHeight := self.heightOfStack;
			
		else
			gridMaxHeight := lc.getMaxStackingHeight;
			
		endif;
		
		if gridMaxHeight &lt; 1 then
			continue;
			
		endif;
		
		tier := 1;
		foreach tier in 1 to gridMaxHeight do
			count := count + 1;
			create proxyReeferBlockPos transient;	
			proxyReeferBlockPos.setDetails(lc, _pxyReeferBlock, count, tier);
			
		endforeach;
		
	endforeach;
	
end;</source>
        <Parameter name="_pxyReeferBlock" type="CM_ReeferBlock" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRowForLabel" id="66458796-0169-41c4-839b-3e9e9f628d98">
        <source>getRowForLabel(pLabel : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridRow	: CM_GridRow;
	
begin

	gridRow	:= self.allGridRowsByLabel[pLabel];
	if gridRow = null then
		return 0;
	endif;
	
	return gridRow.row;

end;</source>
        <Parameter name="pLabel" type="String"/>
