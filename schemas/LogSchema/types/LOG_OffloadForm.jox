    <JadeMethod name="doDeleteNoNumbers" id="603ef416-0a86-4c07-98c1-86a2301b4078">
        <updating/>
        <source>doDeleteNoNumbers(_trackedItems : CM_TISet io) : Boolean protected, updating;

vars
	log			: CM_Log;
	iter		: Iterator;
	rtnValue	: Boolean;
	nnReconDtl	: CMIF_LogNNReconDtl;
	tmpTISet	: CM_TISet;

begin

	create tmpTISet transient;	//#26532 10/12/2010. Need to saving _trackedItems, because trx can be repeated after a blue warning.
	_trackedItems.copy(tmpTISet);

	create nnReconDtl transient;
	nnReconDtl.mode := CMIF_LogNNReconDtl.Mode_OffLoadNN;
	nnReconDtl.myLogVoyageStructure := self.myLogVoyage.myLogVoyageStructure;

	iter := _trackedItems.createIterator;
	while iter.next(log) do
		if log.isNoNumber then
			nnReconDtl.allNoNumberLogs.add(log.CM_LogNoNumber);
			_trackedItems.remove(log);
		endif;
	endwhile;

	if nnReconDtl.allNoNumberLogs.size &gt; 0 then		
		app.myTrxUA.trxUpdateLogNNReconDtl(nnReconDtl, app.myPassport);

		if (not app.myPassport.trxCompletedOK) then
			//#26532 10/12/2010. Restore ti set - it can be proceeded once again when a user accepts a blue warning.
			nnReconDtl.allNoNumberLogs.clear;
			_trackedItems.clear;
			tmpTISet.copy(_trackedItems);
			return false;
		endif;
	endif;
	
	return true;

epilog
	delete nnReconDtl;
	delete iter;
	delete tmpTISet;
	
end;</source>
        <access>protected</access>
        <Parameter name="_trackedItems" type="CM_TISet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFind" id="7095a04d-d738-443e-bb23-3277bdaa742d">
        <updating/>
        <source>doFind() protected, updating;

vars

	tiStr			: String;
	itemsFound		: Boolean;
begin

	app.mousePointer := MousePointer_HourGlass;
	itemsFound := false;
	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	self.allLogs.clear;		
	self.setButtons(false);
	
	if self.myLogVoyage &lt;&gt; null then
		if self.selection = DOCKET and self.myBolOut &lt;&gt; null then
			itemsFound := self.doLoadDocket();
		elseif self.selection = TICKET then
			tiStr := self.tblSelection.getValueByName(ETRow_LogId).String;
			if tiStr &lt;&gt; null then
				itemsFound := self.doLoadTI(tiStr);
			endif;
		elseif self.selection = NONUMBER then
			itemsFound := self.doLoadNoNumber();
		endif;
		if itemsFound then
			self.tblSelectData.userInputEnabled := true;
			self.setButtons(true);
		endif;
		if self.selection = LOT then
			self.getAllLoadedSOHLocnsForLot();			
		endif;
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadDocket" id="b1c8a046-f4dc-4216-92d3-bfaaab75abe6">
        <updating/>
        <source>doLoadDocket() : Boolean protected, updating;

vars
	def			: CMIF_DocketLogDef;
	itemsFound	: Boolean;
begin


	if self.myBolOut &lt;&gt; null then
		self.tblSelectData.rows := 1;
		self.allDocketLogDef.purge;
		// Process tracked items to determine various log specs.
		self.myBolOut.myExtension.CM_BOLExtLog.getLogLocations(self.allDocketLogDef, CM_LogVoyageController, self.myTerminal);
		if not self.allDocketLogDef.isEmpty then
			itemsFound := true;
		endif;
		
		foreach def in self.allDocketLogDef do
			self.addDetailLine(def.displayOffload);
		endforeach;		
	endif;

	return itemsFound;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadNoNumber" id="6c0678d4-45d9-4df7-95b8-1309b174f289">
        <source>doLoadNoNumber() : Boolean protected;

vars

	lot				: CM_LogLot;
	hatch,
	place			: Integer;
	ext				: CM_BOLExtLogOut;
	noNumber		: CM_LogNoNumber;
	placeStr		: String;
	itemsFound		: Boolean;

begin

	self.tblSelectData.rows := 1;
	self.allLogs.clear;
	
	if self.myLogVoyage &lt;&gt; null then
		lot := self.cmbLot.listObject.CM_LogLot;
		hatch := self.tblSelection.getValueByName(ETRow_Hatch).Integer;
		placeStr := self.tblSelection.getValueByName(ETRow_Place).String;
	endif;
	
	if placeStr = 'DECK' then
		place := PlaceDeck;
	elseif placeStr = 'HOLD' then
		place := PlaceHold;
	endif;
	
	if lot &lt;&gt; null then
		foreach ext in lot.allBOLExtLogOuts do
			if hatch = null or ext.hatch = hatch then
				if place = null or ext.place = place then
					foreach noNumber in ext.allNoNumberLogs do
						//self.addDetailLine(noNumber.displayNoNumberDetail());
						self.addDetailLine(noNumber.getAttributeStringForDefArray(self.tblSelectData.allTblDataEntRows));
						self.allLogs.add(noNumber);
						itemsFound := true;
					endforeach;
				endif;
			endif;
		endforeach;
	else
		if self.myLogVoyage &lt;&gt; null and self.myLogVoyage.myLogVoyageStructure &lt;&gt; null then 	
			foreach noNumber in self.myLogVoyage.myLogVoyageStructure.allLogNoNumbers do
	//			self.addDetailLine(noNumber.displayNoNumberDetail());
				self.addDetailLine(noNumber.getAttributeStringForDefArray(self.tblSelectData.allTblDataEntRows));
				self.allLogs.add(noNumber);
				itemsFound := true;
			endforeach;
		endif;
	endif;
	
	return itemsFound;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTI" id="36bf2e13-2bae-46b9-b101-e56441142158">
        <updating/>
        <source>doLoadTI(_ti	: String) : Boolean protected, updating;

vars
	itemsFound			: Boolean;
begin


	self.myLog := self.myLogVoyage.allOnshipTIsByCargoTypeId[TI_CargoType_Log, _ti].CM_Log;

	if self.myLog = null and self.lastTISearch &lt;&gt; _ti then
		self.lastTISearch := _ti;
		self.txtDetail.text := null;
		app.raiseCMException1(LogNotFoundOnVoyage, _ti, null, null);
	endif;

	if self.myLog &lt;&gt; null then
		itemsFound := true;
	endif;
		
	self.displayTrackedItem(self.myLog);
	return itemsFound;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOptDocketClick" id="f8733eb6-8668-4e34-8b60-648794ad5fbe">
