    <JadeMethod name="getCraneRate" id="461b2404-1503-4549-90ef-715049e9f1b5">
        <source>getCraneRate(js : CM_VoyageJobSheet) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jun 2013	cnwmc5	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	totalTIs 	: Real;
	now			: TimeStamp;
	job			: CM_Job;
	wle			: CM_WorkListEntry;
	txn			: CM_Transaction;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	now := now.addMinutes(-10);
	
	foreach job in js.allJobsByOrder discreteLock do			//06.03.2025 navma1 #MTN-34179
		foreach wle in job.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
			if wle.status = WLE_COMPLETED and 
			   wle.allRTQueueEntries.size() = 0 and
			   wle.myTrackedItem &lt;&gt; null then  // 34856
				txn := wle.myTrackedItem.getLastTransOfType(TRANS_TYPE_MOVE_SETDOWN);
				if txn &lt;&gt; null and txn.createdTime &gt; now then
					totalTIs := totalTIs + 1;
				endif;
			endif;
		endforeach;
	endforeach;	
	
	return (6 * totalTIs).Integer;
epilog

end;</source>
        <Parameter name="js" type="CM_VoyageJobSheet"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
