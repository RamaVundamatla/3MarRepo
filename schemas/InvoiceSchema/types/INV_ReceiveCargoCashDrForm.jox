    <JadeMethod name="bringMainFormToFront" id="b44cac73-f97a-4793-a92d-5fdc0550584d">
        <source>bringMainFormToFront() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.myParentForm &lt;&gt; null then
		self.myParentForm.zOrder(1);
		self.myParentForm.setFocus();
	endif;

epilog

end;</source>
