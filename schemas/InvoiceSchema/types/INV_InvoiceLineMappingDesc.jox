    <JadeMethod name="setEnableObjects" id="36a8dd70-88de-4634-ac7e-070d58b55eb6">
        <source>setEnableObjects() protected;
/*

Purpose:			Sets whether or not buttons are enabled or disabled

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	theTable : Table;
	
begin
	theTable := self.tblData;
	
