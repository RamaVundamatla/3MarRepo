			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_thursday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(Last_thursday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_friday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(Last_friday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_saturday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(Last_saturday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(First_sunday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
			create calendarDate transient;
			self.allTemplateDatesByMonth.add(calendarDate);
			calendarDate.setProxy(	null,	//_date : Date;
									app.getErrorString(Last_sunday_month),	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									sourceByMonth	//_dataSource : Integer
									);
		
		endif;
		
		check := false;
		index := 0;
		foreach calendarDate in allTemplateDatesByMonth do
			index := index + 1;
			tblTemplates.accessRow(tblTemplates.addItem(check.cnEcGetTableCheckBoxValue &amp; Tab &amp; calendarDate.description )).itemObject := calendarDate;
			tblLabels.addItemAt( calendarDate.description, index);
			jadeTableCell := tblLabels.accessCell(index, 1);
			jadeTableCell.inputType := Table.InputType_TextBox;
		endforeach;
		
	
	elseif optYear.value then
	
		txtYear.visible := true;
		lblUsing.visible := true;
		if txtYear.text = null then
			txtYear.text := date.year.String;
		endif;
		
		year := txtYear.text.Integer;
		if self.myCalendar= null then
			return;
		endif;

		calendarYear := self.myCalendar.allCalendarYears.getAtKey(year);
		
		dateFrom := self.txtDateFrom.getDate;
		dateFrom.setDate(dateFrom.day, dateFrom.month, year);
		dateTo := self.txtDateTo.getDate;
		dateTo.setDate(dateTo.day, dateTo.month, year);
		
		if calendarYear &lt;&gt; null then
	
			check := false;
			index := 0;
			foreach calendarDate in calendarYear.allCalendarDates do
			
				if calendarDate.dataSource &gt; 0 then
					// this is a monthly or weekly created date.
					continue;
				endif;
			
				templateCalDate := calendarDate.date;
				if dateFrom.isValid then
					if templateCalDate &lt; dateFrom then
						continue;
					endif;
				endif;
				if dateTo.isValid then
					if templateCalDate &gt; dateTo then
						continue;
					endif;
				endif;
				
				index := index + 1;
				tblTemplates.accessRow(tblTemplates.addItem(check.cnEcGetTableCheckBoxValue &amp; Tab &amp; calendarDate.description &amp; "  [" &amp; calendarDate.date.asStringJMT &amp; "]" )).itemObject := calendarDate;
				tblLabels.addItemAt( calendarDate.description, index);
				jadeTableCell := tblLabels.accessCell(index, 1);
				jadeTableCell.inputType := Table.InputType_TextBox;
			endforeach;
		
		endif;
	
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
