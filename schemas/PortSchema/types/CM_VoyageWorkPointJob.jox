    <JadeMethod name="areWLEsAllDone" id="6f681547-fc5a-4ee9-a199-bdee6ea460a1">
        <source>areWLEsAllDone(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/

vars
	wle : CM_WorkListEntry;
	job	: CM_WOReceiveCargoJob;
begin
	job := self.myWorkOrderReceiveJob;
	if job &lt;&gt; null then
		if job.allCompletedWLEsByDate.size &lt;&gt; job.workListEntries.size then
			return false;
		endif;
		
		return true;
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
