    <JadeMethod name="zDoAdd" id="b71ac221-3320-4cd3-a1eb-0c6bbc70937b">
        <updating/>
        <source>zDoAdd(_placeHolderHeirarchy: Integer) updating, protected;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	success : Boolean;
	tmpObj 	: Object;
begin

	success := true;
	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;
	if _placeHolderHeirarchy = New_Child and
	   self.myCurrentVMObject = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	self.lstData.enabled := false;
	
	self.zClearProxyDetails();
	self.myLastCurrentObject := self.myCurrentObject;
	self.myCurrentObject := null;
	self.clearErrorWarnings();

	self.mode := Mode_Add;
	self.zSetControlsForAddEdit();
	if _placeHolderHeirarchy = New_Child then
		success:= self.addChild();
	elseif _placeHolderHeirarchy = New_Peer then
		success := self.addPeer();
	endif;
	
	if success then	
		self.showThumbnailData(null);		
		self.zSetControlsForAddEdit();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_placeHolderHeirarchy" type="Integer"/>
    </JadeMethod>
