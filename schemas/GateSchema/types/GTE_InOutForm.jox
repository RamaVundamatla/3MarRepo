// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sheet	: GTE_Sheet;
	bulkRelease : CM_BulkRelease;
	i : Integer;
	
begin

	sheet := combobox.mySheet;
	
	self.setCellTextFromControl(sheet, combobox, combobox.text.toUpper);
	
	//Par16601	17 July 2008. Try to find bulk release in the drop-down ist and organize listObject. Sometimes it can happen - Jade controll
	if combobox.listObject = null and combobox.text &lt;&gt; null then
		foreach i in 1 to combobox.listCount do
			if combobox.text.toUpper = combobox.itemObject[i].CM_BulkRelease.code then
				combobox.listObject := combobox.itemObject[i].CM_BulkRelease;
				break;
			endif;
		endforeach;
	endif;
	
	if combobox.listObject &lt;&gt; null then
		bulkRelease := combobox.listObject.CM_BulkRelease;
		if global.isValidObject(bulkRelease) then
			self.setValuesFromBulkRelease( bulkRelease, sheet );	//Par16601	17 July 2008
			self.showBRDetails(bulkRelease);
		endif;

	endif;

end;</source>
