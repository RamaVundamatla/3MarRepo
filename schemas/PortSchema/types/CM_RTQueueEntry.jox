02 February 2009	cnwer1	Initial creation

*/



begin
	return self.status = ENTRY_WORKING;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="locateTaskForTI" id="16dcc563-7003-4634-956f-a5008683b8be">
        <source>locateTaskForTI(tiToSearch	:	CM_TrackedItem; _taskType : Integer) : CM_RTQueueTask;

vars
	aTask		: CM_RTQueueTask;
	invalidTask	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, aTask, invalidTask);		// 27/07/2012 cnwar2 #30001

	foreach aTask in self.allTasks do
		if not aTask.ti = tiToSearch then
			continue;
		endif;
		if invalidTask then			// 27/07/2012 cnwar2 #30001
			invalidTask := false;
			continue;
		endif;
		
		if _taskType &gt;= 0 then	// 29 Apr 2011	NDL	CCMS 1216
			if aTask.taskType &lt;&gt; _taskType then
				continue;
			endif;
		endif;
		if aTask.status &lt;&gt; TASK_COMPLETE  then
			return aTask;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="tiToSearch" type="CM_TrackedItem"/>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="queueId" id="ac95d39c-289c-4651-af47-d65b91faa81b">
        <methodInvocation>mapping</methodInvocation>
        <source>queueId(set: Boolean; value: String io) mapping;
// 15/08/2016 cnwma1  TFS #2522 PAR #38134 MSL - 1035 String Too Long Error in RTQ
//11/05/2018 	JLGNS1	Bug 38521: STWR - Error message when logging into vmt (queue)

vars

begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myQueue = null then
		return;
	endif;
	value := self.myQueue.id;  //15/08/2016 cnwma1 TFS #2522  PAR # 38134//Bug 38521
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeFromAlerts" id="0ff52c03-8a24-405a-a799-93660c2bcb5c">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::removeFromAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>removeFromAlerts(alert: CM_SystemAlert) updating;
//Remove the passed in alert from the action.
vars
	terminal : CM_Terminal;
begin
	if not self.alerts.includes(alert) then
		return;
	endif;
	alerts.remove(alert);

	terminal := self.getTerminalForAlert;
	if terminal &lt;&gt; null and alert.mySystemAlertType &lt;&gt; null and not alert.reviewed then
		terminal.causeEvent(alert.mySystemAlertType.type,false,alert);	//25662 24/09/2010  set to false
	endif;
end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="replicate" id="7c766a36-4666-41d7-834f-32d8a19b7a42">
        <updating/>
        <source>replicate() updating;
/*
 ------------------------------------------------------------------------
Created:			28 August 2002 by cnwdwq1
Purpose:			If this entry's job is a yardInternal that is an autorepeating type
					then replicate myself and my tasks for the NEXT machine to pick up.
					Basically auto-repeating tasks continue forever until they are deleted.
					As soon as a machine accepts one, a new one is created ad-infinitum.

Changed On			Changed By			Reason
--------------		--------------		-----------------------------------------
29 Aug 2012			cnwcs5				par 30292 - use updateObjectEdition instead of updateEdition 
---------------------------------------------------------------------------
*/
vars
	proxyQEntry : CM_RTQueueEntry;
	newQEntry 	: CM_RTQueueEntry;
	futureMove	: CM_FutureMove;
begin
	exclusiveLock(self);
	
	if self.myJob = null then
		return;
	endif;
	
	if not self.myJob.isYardInternalJob() then
		return;
	endif;
	
	if self.myJob.CM_YardInternalJob.type &lt;&gt; Auto_Repeating then
		return;
	endif;
	
	if not self.myJob.allRequests.first.isKindOf(CM_YardMoveRequest) then
		return;	
	endif;
	//--------------------
	//OK, I AM a replicating job entry, reproduce myself and my tasks
	//--------------------
	//-----------------
	//Create the entry
	//-----------------
	create proxyQEntry transient;
	proxyQEntry.setProxy(self.myWorkListEntry);
	
	create newQEntry persistent;
	newQEntry.setForCreate(proxyQEntry);

	self.updateObjectEdition(self.myJob);	// par 30292 //Cause a note.
	
	//-----------------
	//Replicate the tasks
	//-----------------
 	self.replicateTasks(newQEntry);
	//-----------------
	//Add us to the Queue
	//-----------------
	self.myQueue.addQueueEntry(newQEntry);
	// DVB Added 23 March 04. 
	futureMove := self.myWorkListEntry.myFutureMove;
	
	if futureMove &lt;&gt; null then
		self.exclusiveLock(futureMove);
		futureMove.CM_FutureMoveQueued.setRTQueueEntry(newQEntry, false);
	endif;
epilog
	unlock(self);
	delete proxyQEntry;
end;</source>
    </JadeMethod>
    <JadeMethod name="replicateTasks" id="18a2f2c9-d95b-4045-a013-e8379109ed9e">
        <source>replicateTasks(toEntry : CM_RTQueueEntry input) protected;
/*
 ------------------------------------------------------------------------
Created:			28 August 2002 by cnwdwq1
Purpose:			Replicates the task(s) required for the new passed in qEntry
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	arbiter: CM_RTQueueArbiter;
	req : CM_YardMoveRequest;
begin
	if toEntry = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'toEntry is null');
		return;
	endif;
	create arbiter transient;
	req := self.myJob.allRequests.first.CM_YardMoveRequest;
	arbiter.targetLocation := req.myTargetLocation;
	arbiter.entry := self;
	req.mySourceLocation.getQueueDirectorTasks(arbiter);
epilog
	arbiter.erase(0);
end;</source>
        <access>protected</access>
        <Parameter name="toEntry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetOfferedTask" id="c22b4406-7f4c-4fa0-8e49-70e512e2a6a7">
        <source>resetOfferedTask();
// -------------------------------------------
// Created 19 December 2003 by cnwdvb1
// -------------------------------------------
vars

	oldTask,
	task,
	newTask		: CM_RTQueueTask;
	machine		: CM_Machine;

begin
		
	
	
	oldTask := self.getTaskOfType(TASK_PICKUP, TASK_OFFERED);

	if oldTask = null then
		return;
	endif;
	machine := oldTask.machine;

	foreach task in self.allTasks do
		task.status := TASK_UNACTIONED;
	endforeach;	

	machine.setMachineStatus(STATUS_IDLE  , "", false);
	oldTask.setMachine(null);
	newTask := self.getTaskOfType(TASK_PICKUP, null);
	newTask.setMachine(machine);
	newTask.setStatus(TASK_OFFERED);
	machine.sendBroadcastMessage("Control move override.", false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="restoreTaskStatuses" id="8cccc7dd-a634-4e75-8bcd-eeebc11e7103">
        <updating/>
        <source>restoreTaskStatuses() updating;
/*
	method that reverts all task statuses from their previous error
	condition (TASK_ERROR, TASK_MACH_OFFLINE or TASK_HELD) back to
	what they were before.
	As these statues affect all statues in the entry, we must revert them all 
	at the same time. If the task status has already been changed, then no effect.
*/
vars
	task	: CM_RTQueueTask;
	term	: CM_Terminal;
	isManualHold : Boolean;
begin

//	term := app.getMyTerminal();
	term := self.myQueue.getMyTerminal();
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
	endif;
	
	//22 Apr 2015	NDL Par 36014
	if not self.allTasks.isEmpty then
		isManualHold := self.allTasks.first().status = TASK_USER_HELD;
	endif;
	
	foreach task in self.allTasks do
		exclusiveLock(task);
		task.restoreStatus;
		unlock(task);
		//22 Apr 2015	NDL Par 36014
		if isManualHold then
			if task.status = TASK_SYS_HELD then
				//If system held, then all the other tasks will also be system held by now.
				break;
			endif;
		endif;
	endforeach;
	if self.statusToRestoreTo &lt;&gt; ENTRY_NULL  then
		self.status := statusToRestoreTo;
	endif;
	self.statusToRestoreTo := ENTRY_NULL;

end;</source>
    </JadeMethod>
    <JadeMethod name="retrospectivelyUpdateEntry" id="d7788f03-c017-4ab2-aae1-1dcfb86cd247">
        <source>retrospectivelyUpdateEntry();

// Created by cnwdvb1 on 13 September 2006

vars

	task : CM_RTQueueTask;
	nextEntry : CM_RTQueueEntry;
begin
	//epr par 35702 4/3/15
	nextEntry:=self.getNextRelatedEntry();
	if nextEntry = null then
		return;
	endif;
	
	if nextEntry.machineTypeGroup = MACHINETYPEGRP_IMV and self.machineTypeGroup &lt;&gt; MACHINETYPEGRP_RTG then
		task := self.getTaskOfType(TASK_SETDOWN, null);
		if task &lt;&gt; null then
			task.setTargetLocation (null);
		endif;		
		
		//cnwrd1 par 25681 18.11.2010 multi machine director moves
		task := self.getTaskOfType(TASK_DIRECTOR, null);
		if task &lt;&gt; null then
			task.setTargetLocation (null);
		endif;
	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="revertLocnsToUnactionedState" id="dbc932b8-ecfe-4559-af74-ef4fe7b0c0cb">
        <updating/>
        <source>revertLocnsToUnactionedState()	updating;
//Reverts all the task locations in this entry back 
//to their unactioned locations.
vars
	task	:	CM_RTQueueTask;
	origSourceLC	:	CM_LocationsController;
	origTargetLC	:	CM_LocationsController;
begin

	task := self.getTaskOfType(TASK_PICKUP, null);
	if task = null then
		task := self.getTaskOfType(TASK_MOVE, null);
	endif;
	if task = null then
		//Hmm, a problem!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC, queueId, null, null);
		return;
	endif;	
	origSourceLC := task.sourceLocation;	
	if task.taskType &lt;&gt; TASK_MOVE then
		task := getTaskOfType(TASK_SETDOWN, null);	
		if not self.isPlanOnPickup then //cnwrd1 ccms 2014 22.3.2011 can have pickup &amp; no setdown on POP.		
			if task = null then
				//Hmm, a problem!
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_SETDOWN_DESC, queueId, null, null);
				return;
			endif;	
			origTargetLC := task.targetLocation;	
		endif;
	endif;
	foreach task in self.allTasks do
		if task.taskType = TASK_PICKUP then
			if task.targetLocation &lt;&gt; origTargetLC then
				task.setTargetLocation( origTargetLC);
			endif;
		endif;
		if task.taskType = TASK_SETDOWN then
			if task.sourceLocation &lt;&gt; origSourceLC then
				task.setSourceLocation( origSourceLC);
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="sendNotesForRelatedEntry" id="56266e8a-c0ef-4074-9681-b7ce6ab6b60e">
        <source>sendNotesForRelatedEntry();
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2007	cnwer1	Initial creation - PAR#xxxx
25 Nov 2010	cnwkpd1	PAR #25681 - Multi Machine Director task changes

*/
vars
	terminal : CM_Terminal;
	prevEntry,
	nextEntry : CM_RTQueueEntry;
begin
	terminal := self.getMyTerminal();
	//Par 14363 2/8/07
	if self.myQueue &lt;&gt; null and  terminal &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue , terminal.getTerminalEvent(Event_Update_Queue_Entry), self );
		
		prevEntry:=self.getPreviousRelatedEntry();
		if prevEntry &lt;&gt; null and prevEntry.status &lt;&gt; ENTRY_COMPLETE  then
			app.myEventManager.createSingleObjInfoNoteEvt(prevEntry.myQueue, terminal.getTerminalEvent(Event_Update_Queue_Entry), prevEntry);
			app.myEventManager.createSingleObjInfoNoteEvt(prevEntry, terminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
		endif;
		//epr par 17490 9/7/08
		nextEntry:=self.getNextRelatedEntry();
		if nextEntry &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(nextEntry.myQueue, terminal.getTerminalEvent(Event_Update_Queue_Entry), nextEntry);
			app.myEventManager.createSingleObjInfoNoteEvt(nextEntry, terminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEntryStatus" id="1ff2cd2a-40a8-4921-91ef-62c09d98d1dc">
        <updating/>
        <source>setEntryStatus(queueStatus : Integer) updating;
//Called from the queue whenever these is a status change.
//Updates the status of the entry and its tasks as well.
//STATUS HERE CAN ONLY BE HELD OR RUNNING!!!
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------------------------------
// 21/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 Check if entry can be restored or if it needs to remain Held
vars
	term		: CM_Terminal;
	reason		: String;			// PAR #30762
begin
	exclusiveLock(self);
	if queueStatus = QSTATUS_HELD then
		if status = ENTRY_USER_HELD then
			return;	//Nothing to do..
		endif;
		if status = ENTRY_COMPLETE then
			return;	//Complete Entry, no point in updating
		endif;
		if status = ENTRY_SYSTEM_HELD then
			return;	//Nothing to do..
		endif;
		
	elseif queueStatus = QSTATUS_RUNNING then
		if status &lt;&gt; ENTRY_SYSTEM_HELD then
			return;	//Nothing to do..
		endif;
		if self.myQueue.status &lt;&gt; QSTATUS_RUNNING then
			//---------------
			//Cannot set the entry status to ok if the Queue is dead.
			//---------------
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_PARENT_QSTATUS, '"' &amp; self.myQueue.id &amp; '"', null, null);
			return;
		endif;
	endif;

	//-----------------
	//Store the current in statusToRestoreTo
	//-----------------
	if queueStatus = QSTATUS_HELD then
		statusToRestoreTo := status;
		status := ENTRY_SYSTEM_HELD;
		//Update the 1st task, it looks after the rest
		if self.allTasks.isEmpty then
			return;
		endif;
		self.allTasks.first.setStatusSystemHeld();
	else
		//----------------
		//Test to see if any TI's in this entry have any reason NOT to Restore
		//(Only if we are restoring a held entry)
		//----------------
	//	if status = ENTRY_HELD and not myQueue.isInStartup then //cnwrd1 20.6.2008 par #17012 ++
		if status = ENTRY_SYSTEM_HELD and not myQueue.isInStartup then	//22 Apr 2015	NDL	Par 36014
	    	if self.hasTIWithStops() then
	    		app.setContinueCMExceptions(false);
				app.raiseCMException2(VB_STOPS_EXIST, 'Tracked item', '', null, null);
	    	endif;
			//--------------
			//Test for load jobs not able to be released
			//--------------
			self.hasHeldShipLoadTIs();
		endif;		
		//-----------------
		//Restoring the entry.. (ie, the queue status == running)
		//-----------------
		// PAR #30762 Check if the TI associated with this entry can have its held status removed
	//	if (self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.myTrackedItem &lt;&gt; null and not self.myWorkListEntry.myTrackedItem.isHeldRTQueueStatus(false, null, reason)) or	// PAR #30762
	//	   (not self.allTasks.isEmpty and self.allTasks.first.taskType = TASK_DIRECTOR and self.status = ENTRY_USER_HELD) then														// PAR #30762
	//		status := statusToRestoreTo;
	//		self.restoreTaskStatuses;
	//	endif;
		
		//22 Apr 2015	NDL	Par 36014
		if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.myTrackedItem &lt;&gt; null then
			if not self.myWorkListEntry.myTrackedItem.isHeldRTQueueStatus(false, null, reason) then											
				status := statusToRestoreTo;
				self.restoreTaskStatuses;
			endif;
		elseif not self.allTasks.isEmpty and self.allTasks.first.taskType = TASK_DIRECTOR then
			if not self.allTasks.first.requiresSystemHold(false, null, reason) then
				status := statusToRestoreTo;
				self.restoreTaskStatuses;
			endif;
		endif;
		
		
	endif;
//	term := app.getMyTerminal();
	term := self.myQueue.getMyTerminal();
	
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
		//Par 14363 2/8/07
		self.sendNotesForRelatedEntry();
		
	endif;
	
	
	
	
end;</source>
        <Parameter name="queueStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setEntryStatusUnactioned" id="edba5321-1069-4bf2-8e6c-1a7472393241">
        <updating/>
        <source>setEntryStatusUnactioned() protected, updating;
/*

Date		Who		Reason
05 December 2013	cnwer1	Initial creation PAR

*/

vars

	terminal : CM_Terminal;
begin
	self.status := ENTRY_UNACTIONED;
	
	terminal := self.getMyTerminal();
	
	if self.myQueue &lt;&gt; null and  terminal &lt;&gt; null then
		//not going to work because if rejected 
	//	app.myEventManager.createSingleObjInfoNoteEvt(self.myQueue , terminal.getTerminalEvent(RTQueueEntry_Available_Event), self );
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEntryStatusUserHeld" id="f1a83a04-5a1d-46d1-805d-2d67d4be5afa">
        <updating/>
        <source>setEntryStatusUserHeld() updating;
/*
Purpose:			Set Entry status to ENTRY_USER_HELD, and all tasks to TASK_SYSTEM_HELD

Parameters:			None

Return Value:		None

Date		Who		Reason
20/11/2012	cnwdap1	Initial creation PAR #30762 CCMS QNS 2233
*/
vars

begin

	
	if status.isOneOf(ENTRY_USER_HELD, ENTRY_COMPLETE, ENTRY_SYSTEM_HELD) then
		return;	//Nothing to do..
	endif;
	
	self.statusToRestoreTo := self.status;
	self.status := ENTRY_USER_HELD; //epr par 37330 18/1/16 called when creating internal jobs needs to be user held
	//Update the 1st task, it looks after the rest
	if self.allTasks.isEmpty then
		return;
	endif;
	self.allTasks.first.setStatusUserHeld();
	
epilog

end;</source>
    </JadeMethod>
