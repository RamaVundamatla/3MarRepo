07 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	theTable 	    : CM_DataTable;
	colNewTaxCode,
	colIsOverridden,
	row,
	rowSt,
	rowEnd,
	index 			: Integer;
begin
	theTable := self.tblInvTable;
	colNewTaxCode := theTable.getColumnByRowName(ETRow_NewTaxCode);
	colIsOverridden := theTable.getColumnByRowName(ETRow_TaxOverridden);
	rowSt := theTable.fixedRows + 1;
	rowEnd := theTable.rows;
	
	foreach index in rowSt to rowEnd do
		if theTable.accessRow(index).selected then
			theTable.setCellText(index, colNewTaxCode, "");
			theTable.setCellText(index,colIsOverridden,"No");
		endif;
	endforeach;
end;</source>
