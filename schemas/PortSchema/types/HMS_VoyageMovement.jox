    <JadeMethod name="validateForDelete" id="4438e264-457f-4628-af3d-82e0742b479a">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars

	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;

begin

	inheritMethod(_passport);
	
	if self.moveType = HMSMovementTypeDeparture
	or self.moveType = HMSMovementTypeArrival then
		app.raiseCMException(ArrDeptMoveNoDelete, null, null);
	endif;
	
	//20 Mar 2019	NDL	TFS 43894 
	if self.myHMSVoyageData &lt;&gt; null and self.myHMSVoyageData.myVoyage &lt;&gt; null then
		foreach wo in self.myHMSVoyageData.myVoyage.allWorkOrders discreteLock do
			foreach woDtl in wo.allWoDtls discreteLock do
				if woDtl.isKindOf(CM_WodShiftMovement) and woDtl.CM_WodShiftMovement.myHMSVoyageMovement = self then
					app.raiseCMException1(Not_delet_movem_that_assoc_wor, wo.id, null, null);
				endif;
			endforeach;
		endforeach;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
