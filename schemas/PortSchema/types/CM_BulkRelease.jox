    <JadeMethod name="getTotalsByUnit" id="3b45d123-56ba-4b41-b912-4fd92b2ed417">
        <source>getTotalsByUnit(_isRemaining : Boolean;
				 _isReleased : Boolean;
				_measureType : CM_MeasurementType) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlger1	Initial creation 41398
08/02/2024	navcs2	Bug 62384: MTN - Total Requested/Outstanding value is wrong on the Release Request
*/

vars
	reserveDetail			: CM_ReserveDetail;
	currentCargoType : CM_CargoType;
	density,
	amount,
	released 	: Decimal[20,6];
	total: String;
	measureType : CM_MeasurementType;
	totRequested : Integer;
begin

	foreach reserveDetail in self.allReserveDetails discreteLock do
		currentCargoType:=reserveDetail.getCargoType;
		
		if currentCargoType = null then
			continue;
		endif;
		
		if currentCargoType.isTrackByWeight then
			measureType:=currentCargoType.myWeightMeasurementType;
		elseif currentCargoType.isTrackByVolume then
			measureType:=currentCargoType.myVolumeMeasurementType;
		else
			measureType := null;
		endif;
		
		if reserveDetail.byTypeByWeight and _measureType &lt;&gt; null then		// 08/02/2024	navcs2	Bug 62384
			amount:=amount + reserveDetail.weightRequested;
			released:=released + reserveDetail.getWeightReleased;
		endif;
		
		if measureType &lt;&gt; _measureType  then
			continue;
		endif;
		density:=reserveDetail.getDensity;
		if currentCargoType &lt;&gt; null and currentCargoType.isBulkMulti then
			if currentCargoType.isBulkByVolume and density &gt; 0 then
				amount:=amount + (reserveDetail.weightRequested/density);
				released:=released + (reserveDetail.getWeightReleased/density);
			else
				amount:=amount + reserveDetail.weightRequested;
				released:=released + reserveDetail.getWeightReleased;
			endif;
		else
			totRequested := reserveDetail.getTotalRequested();  // ### TFS 52328 04NOV2021 NAVAB1
			 // ### TFS 52328 04NOV2021 NAVAB1 totRequested := reserveDetail.totalRequested.max(1);
			amount:=amount + totRequested;	
			released:=released + reserveDetail.getTotalReleased;		
		endif;	
	endforeach;

	
	if _isRemaining then
		amount:=amount - released;
	elseif _isReleased then
		amount:=released;
	endif;
	
	if _measureType &lt;&gt; null and  ( _measureType.isVolume or _measureType.isWeight) then
		total:=app.convertMeasurementForDisplay(_measureType.shortName, amount);
		if total = null then
			total:="0";
		endif;
		total:=total &amp;  Space &amp; _measureType.shortName;
	else
		total:=amount.Integer.asStringJMT;
	endif;
	
	return total;
	
epilog

end;</source>
        <Parameter name="_isRemaining" type="Boolean"/>
        <Parameter name="_isReleased" type="Boolean"/>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrainsUsed" id="7f0e9c2a-b8ac-4311-8991-21ec887d0dd4">
        <source>getTrainsUsed() : String;
// ---------------------------------------------------------------------------
// Created:     13 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 25980
// ---------------------------------------------------------------------------

vars
	resDet : CM_ReserveDetail;
	tmpStr : String;
begin
	foreach resDet in self.allReserveDetails discreteLock do
		tmpStr := tmpStr &amp; resDet.getTrainsUsed();
	endforeach;
	
	return tmpStr;
epilog

