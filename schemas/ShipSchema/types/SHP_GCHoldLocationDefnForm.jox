    </JadeMethod>
    <JadeMethod name="doDelete" id="3f57baeb-db80-4872-b720-dbb31b218b0f">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	obj : CM_Object;
	result : Integer;

begin

	obj := self.tblItems.accessRow(self.tblItems.row).itemObject.CM_Object;
	
	if obj &lt;&gt; null then
		
		while true do
			app.myTrxDA.trxDeleteCMObject( obj, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.clearEditControls();
				self.populateData();
				return;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Location) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
	
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			self.clearEditControls();
			self.populateData();
			return;
		endwhile;		
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="cf215c88-98aa-4b16-9db9-1a6defaa8fb1">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	delRight : Real;
	gap : Real;
	midPoint : Real;

begin

	
	
	self.grpDetail.left := 1;
	self.grpList.left := 1;
	
	self.grpDetail.top := 1;
	self.grpList.top := self.grpDetail.top + self.grpDetail.height;
	self.grpList.height := ( (self.clientHeight - self.grpList.top ) - 35 );
	
	self.btnAdd.top := self.clientHeight - 30;
	self.btnDelete.top := self.btnAdd.top;
	self.btnSort.top := self.btnAdd.top;	//03 Feb 2017	NDL	TFS 3216/3047
	self.btnClose.top := self.btnAdd.top;
	self.btnAdd.left := 3;
	self.btnDelete.left := self.btnAdd.left + self.btnAdd.width + 10;
	self.btnClose.left := self.clientWidth - self.btnClose.width - 3;
	
	//03 Feb 2017	NDL	TFS 3216/3047
	delRight := self.btnDelete.left + self.btnDelete.width;
	gap := self.btnClose.left - delRight;
	midPoint := delRight + ( gap / 2 );
	self.btnSort.left := midPoint - (self.btnSort.width / 2);		
	
	self.btnCancel.left := btnClose.left;
	self.btnSave.left := self.btnCancel.left - self.btnCancel.width - 10;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e09ec309-d98e-4bbe-8f67-2a96cf9a41c1">
        <updating/>
        <source>doSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation
16/0282016	cnwdap1	PAR #36766 Bulk Graphical Representation
*/

vars
	
	isCreate : Boolean;
	result : Integer;
	realGCHoldLocnDefn : CM_GCHoldLocationDefn;
	realGCController : CM_VoyageController;
	msg : String;
	onShipCrane: Integer;

begin

	if self.myProxyObject = null then
		//create the proxy.
		isCreate := true;
		if self.myVessel &lt;&gt; null then
			create self.myProxyObject as CM_GCHoldLocationDefn transient;
		elseif self.myVoyage &lt;&gt; null then
			create self.myProxyObject as CM_GeneralCargoController transient;
		endif;
		
	endif;
	
	if self.myProxyObject = null then
		//raise error...
		msg := app.getErrorString(Proxy_object_null_update);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return;
	endif;
	
	//populate proxy
	if self.myVessel &lt;&gt; null then
		self.myProxyObject.CM_GCHoldLocationDefn.setProxy(	self.txtHoldNum.text.Integer,	//_hatch : Integer;
															self.txtLocationName.text,	//_name : String;
															self.txtLocationNum.text.Integer,	//_place : Integer;
															self.chkIsOnDeck.value,		// _isOnDeck : Boolean;					// PAR #36766
															self.txtMaxWeight.text.Integer,		// _maxWeight : Integer			// PAR #36766
															self.txtMaxVolume.text.Decimal,		// _maxVolume: Decimal			// 19/7/16 cnwmp6 TFS 1601
															self.txtMaxHeight.text.Decimal,		// _maxHeight: Decimal	07 Feb 2017 NDL TFS 3216
															self.cmbOnShipCrane.itemData[self.cmbOnShipCrane.listIndex],		// 13/7/16 cnwmp6 TFS 1601
															self.myVessel.myGeneralCargoVesselStructure	//_myGCVesselStructure : CM_GeneralCargoVesselStructure
															);
	elseif self.myVoyage &lt;&gt; null then
		self.myProxyObject.CM_GeneralCargoController.setProxy(	self.myVoyage.myGeneralCargoVoyage,	//_gcVoyage : CM_GeneralCargoVoyageStructure;
																self.txtHoldNum.text.Integer,	//_hatch : Integer;
																self.txtLocationNum.text.Integer,	//_place : Integer;
																self.txtLocationName.text,	//_name : String;
																self.chkIsOnDeck.value,		// _isOnDeck : Boolean				// PAR #36766
																self.txtMaxWeight.text.Integer,	// _maxWeight : Integer			// PAR #36766
																self.txtMaxVolume.text.Decimal,		// _maxVolume: Decimal		// 19/7/16 cnwmp6 TFS 1601
																self.txtMaxHeight.text.Decimal,		// _maxHeight: Decimal	07 Feb 2017 NDL TFS 3216
																self.cmbOnShipCrane.itemData[self.cmbOnShipCrane.listIndex]		// 18/7/16 cnwmp6 TFS 1601
																);
	endif;
		
	
	while true do
		if isCreate then
			if self.myVessel &lt;&gt; null then
				app.myTrxCA.trxCreateGCHoldLocnDefn(self.myProxyObject.CM_GCHoldLocationDefn, realGCHoldLocnDefn, app.myPassport);
			elseif self.myVoyage &lt;&gt; null then
				app.myTrxCA.trxCreateVoyageController(self.myProxyObject.CM_GeneralCargoController, realGCController, app.myPassport);
			endif;
				
		else
			if self.myVessel &lt;&gt; null then
				app.myTrxUA.trxUpdateGCHoldLocnDefn(self.myProxyObject.CM_GCHoldLocationDefn, app.myPassport);
			elseif self.myVoyage &lt;&gt; null then
				app.myTrxUA.trxUpdateGenGCController(self.myProxyObject.CM_GeneralCargoController, app.myPassport);
			endif;
				
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearEditControls();
			self.populateData();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Location), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
			else
				self.setAllErrorWarnings(app.myPassport);
				break;
			endif;	
		endif;
	
	endwhile;
	

epilog

	if isCreate then
		delete self.myProxyObject;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectItem" id="d96d39b9-f6ca-463b-a1e8-69f95cae479e">
        <updating/>
        <source>doSelectItem( _obj : CM_Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	holdDef : CM_GCHoldLocationDefn;
	gcCont : CM_GeneralCargoController;

begin

	if _obj = null then
		self.clearEditControls();
	else
		if _obj.isKindOf(CM_GCHoldLocationDefn) then
			holdDef := _obj.CM_GCHoldLocationDefn;
			self.btnSave.enabled := true;
			self.btnDelete.enabled := true;
			self.setControlsForAddEdit( holdDef );
		elseif _obj.isKindOf(CM_GeneralCargoController) then
			gcCont := _obj.CM_GeneralCargoController;
			self.btnSave.enabled := true;
			self.btnDelete.enabled := true;
			self.setControlsForAddEdit( gcCont );
		else
			self.btnSave.enabled := false;
			self.btnDelete.enabled := false;
		endif;
		
		self.tblItems.selectMode := Table.SelectMode_CurrentRow;
		
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.btnSave.enabled := false;
			self.btnDelete.enabled := false;
			self.grpDetail.enabled:= false;
	endif;
	
	self.btnSort.enabled := not self.btnSave.enabled;	//03 Feb 2017	NDL	TFS 3216/3047

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doSort" id="399028de-96e2-4e80-b6a9-97d3d96a27b9">
        <source>doSort();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwndl1	Initial creation

*/

vars

begin

	if self.myVoyage &lt;&gt; null
	and self.myVoyage.myGeneralCargoVoyage &lt;&gt; null
	and not self.myVoyage.myGeneralCargoVoyage.allLocationsByOrdinal.isEmpty() then
		self.myAssistant.SHP_Assistant.showROROVoyageDeckSortingForm(self,null,self.myVoyage.myGeneralCargoVoyage);	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadLocations" id="dbda76d1-d811-4a06-a9ba-2de714ced4e8">
        <source>loadLocations(  _obj : CM_Object  );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

	holdDef : CM_GCHoldLocationDefn;
	gcCont : CM_GeneralCargoController;

begin

	self.btnDelete.enabled := false;
	self.btnSave.enabled := false;
	self.btnDelete.enabled := false;

	//self.tblItems.columns := 3;											// PAR #36766
	self.tblItems.columns := 8;												// PAR #36766
	self.tblItems.accessColumn(4).inputType := Table.InputType_CheckBox;	// PAR #36766
	self.tblItems.userInputEnabled := false;								// PAR #36766
	self.tblItems.fixedColumns := 0;
//	self.tblItems.setCellText( 1, 1, app.getErrorString(Hold) &amp; Tab &amp; app.getErrorString(CM_Location) &amp; Tab &amp; app.getErrorString(Location_name) );
	//07 Aug 2013	NDL	Par 31804
	//self.tblItems.setCellText( 1, 1, self.lblHoldNum.caption.removeString(":") &amp; Tab &amp; self.lblLocationNum.caption.removeString(":") &amp; Tab &amp; self.lblLocationName.caption.removeString(":") );	// PAR #36766
	self.tblItems.setCellText( 1, 1, self.lblHoldNum.caption.removeString(":") &amp; Tab &amp; 				// PAR #36766
									self.lblLocationNum.caption.removeString(":") &amp; Tab &amp; 			// PAR #36766
									self.lblLocationName.caption.removeString(":") &amp; Tab &amp; 			// PAR #36766
									self.lblIsOnDeck.caption.removeString(":") &amp; Tab &amp;				// PAR #36766
									self.lblMaxWeight.caption.removeString(":") &amp; Tab &amp;				// PAR #36766
									self.lblMaxVolume.caption.removeString(":") &amp; Tab &amp;				// 19/7/16 cnwmp6 TFS 1601
									self.lblMaxHeight.caption.removeString(":") &amp; Tab &amp;	//07 Feb 2017	NDL	TFS 3216
									self.lblOnShipCrane.caption.removeString(":") );				// 19/7/16 cnwmp6 TFS 1601

	if _obj = null then
		return;
		
	elseif _obj.isKindOf( CM_Vessel ) then
		if _obj.CM_Vessel.myGeneralCargoVesselStructure = null then
			return;
		endif;
		foreach holdDef in _obj.CM_Vessel.myGeneralCargoVesselStructure.allHoldLocnDefnByHatchPlace do
			//self.tblItems.addItemObject( holdDef, holdDef.hatch.String &amp; Tab &amp; holdDef.place.String &amp; Tab &amp; holdDef.name );																	// PAR #36766
			self.tblItems.addItemObject( holdDef, holdDef.hatch.String &amp; Tab &amp; holdDef.place.String &amp; Tab &amp; holdDef.name &amp; Tab &amp; holdDef.isOnDeck.getYes &amp; Tab &amp; holdDef.maxWeight.String &amp; Tab &amp; holdDef.maxVolume.String &amp; Tab &amp; holdDef.maxHeight.String &amp; Tab &amp; holdDef.getOnShipCraneDescription() );	// PAR #36766
		endforeach;
		self.btnAdd.enabled := true;
			
	elseif _obj.isKindOf( CM_Voyage ) then
		if _obj.CM_Voyage.myGeneralCargoVoyage = null then
			return;
		endif;
		foreach gcCont in _obj.CM_Voyage.myGeneralCargoVoyage.allLocationsByHatchPlace do
			//self.tblItems.addItemObject( gcCont, gcCont.hatch.String &amp; Tab &amp; gcCont.place.String &amp; Tab &amp; gcCont.name );																// PAR #36766
			self.tblItems.addItemObject( gcCont, gcCont.hatch.String &amp; Tab &amp; gcCont.place.String &amp; Tab &amp; gcCont.name &amp; Tab &amp; gcCont.isOnDeck.getYes &amp; Tab &amp; gcCont.maxWeight.String &amp; Tab &amp; gcCont.maxVolume.String &amp; Tab &amp; gcCont.maxHeight.String &amp; Tab &amp; gcCont.getOnShipCraneDescription() );	// PAR #36766
		endforeach;
		self.btnAdd.enabled := true;
	
	else
		return;
	
	endif;

epilog

	self.btnSort.enabled := not self.btnSave.enabled;	//03 Feb 2017	NDL	TFS 3216/3047

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="populateData" id="b6f50f39-898c-4390-90ab-26b5fb478064">
        <updating/>
        <source>populateData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new fields
*/

vars

begin

	self.clearEditControls();
	
	self.tblItems.rows := 1;
	//self.tblItems.columns := 3;			// PAR #36766
	self.tblItems.columns := 5;				// PAR #36766
	self.tblItems.fixedRows := 1;

	if self.myVessel &lt;&gt; null then
		self.loadLocations( self.myVessel );
		
	elseif self.myVoyage &lt;&gt; null then
		self.loadLocations( self.myVoyage );
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="b774bb56-66e9-4d07-863f-a3d12642d318">
        <updating/>
        <source>setControlsForAddEdit( _obj : CM_Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

	now : TimeStamp;
	loadState : Boolean;
	
begin

	delete self.myProxyObject;	// delete any pre-existing proxy.
	
	btnSave.enabled := false;
	btnDelete.enabled := false;
	
	if _obj &lt;&gt; null then
		// updating an existing obj
		if _obj.isKindOf(CM_GCHoldLocationDefn) then
			self.txtHoldNum.text := _obj.CM_GCHoldLocationDefn.hatch.String;
			self.txtLocationName.text := _obj.CM_GCHoldLocationDefn.name;
			self.txtLocationNum.text := _obj.CM_GCHoldLocationDefn.place.String;
			self.chkIsOnDeck.value := _obj.CM_GCHoldLocationDefn.isOnDeck;					// PAR #36766
			if _obj.CM_GCHoldLocationDefn.maxWeight &lt;&gt; null then							// PAR #36766
				self.txtMaxWeight.text := _obj.CM_GCHoldLocationDefn.maxWeight.String;		// PAR #36766
			else																			// PAR #36766
				self.txtMaxWeight.text := null;												// PAR #36766
			endif;																			// PAR #36766
			if _obj.CM_GCHoldLocationDefn.maxVolume &lt;&gt; null then
				self.txtMaxVolume.text := _obj.CM_GCHoldLocationDefn.maxVolume.String;
			else
				self.txtMaxVolume.text := null;
			endif;
			//07 Feb 2017	NDL	TFS 3216
			if _obj.CM_GCHoldLocationDefn.maxHeight &lt;&gt; null then						
				self.txtMaxHeight.text := _obj.CM_GCHoldLocationDefn.maxHeight.String;	
			else																			
				self.txtMaxHeight.text := null;											
			endif;
			self.cmbOnShipCrane.listIndex := self.cmbOnShipCrane.findString(1, _obj.CM_GCHoldLocationDefn.getOnShipCraneDescription());
		elseif _obj.isKindOf(CM_GeneralCargoController) then
			self.txtHoldNum.text := _obj.CM_GeneralCargoController.hatch.String;
			self.txtLocationName.text := _obj.CM_GeneralCargoController.name;
			self.txtLocationNum.text := _obj.CM_GeneralCargoController.place.String;
			self.chkIsOnDeck.value := _obj.CM_GeneralCargoController.isOnDeck;				// PAR #36766
			if _obj.CM_GeneralCargoController.maxWeight &lt;&gt; null then						// PAR #36766
				self.txtMaxWeight.text := _obj.CM_GeneralCargoController.maxWeight.String;	// PAR #36766
			else																			// PAR #36766
				self.txtMaxWeight.text := null;												// PAR #36766
			endif;																			// PAR #36766
			if _obj.CM_GeneralCargoController.maxVolume &lt;&gt; null then
				self.txtMaxVolume.text := _obj.CM_GeneralCargoController.maxVolume.String;
			else
				self.txtMaxVolume.text := null;
			endif;
			//07 Feb 2017	NDL	TFS 3216
			if _obj.CM_GeneralCargoController.maxHeight &lt;&gt; null then						
				self.txtMaxHeight.text := _obj.CM_GeneralCargoController.maxHeight.String;	
			else																			
				self.txtMaxHeight.text := null;											
			endif;
			self.cmbOnShipCrane.listIndex := self.cmbOnShipCrane.findString(1, _obj.CM_GeneralCargoController.getOnShipCraneDescription());
		else
			return;
		endif;
		
		app.cmsBeginLoad(loadState);
		self.myProxyObject := _obj.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		
		self.lblLocationName.enabled := true;
		self.txtLocationName.enabled := true;
		self.lblLocationNum.enabled := true;
		self.txtLocationNum.enabled := true;
		self.lblHoldNum.enabled := true;
		self.txtHoldNum.enabled := true;
		self.lblIsOnDeck.enabled := true;													// PAR #36766
		self.chkIsOnDeck.enabled := true;													// PAR #36766
		self.lblMaxWeight.enabled := true;													// PAR #36766
		self.txtMaxWeight.enabled := true;													// PAR #36766
		self.lblMaxVolume.enabled := true;													// 19/7/16 cnwmp6 TFS 1601
		self.txtMaxVolume.enabled := true;													// 19/7/16 cnwmp6 TFS 1601
		self.lblOnShipCrane.enabled := true;												// 12/7/16 cnwmp6 TFS 1601
		self.cmbOnShipCrane.enabled := true;												// 12/7/16 cnwmp6 TFS 1601
		self.btnSave.enabled := true;
		self.btnDelete.enabled := true;
		
	else
		// adding a new one
		self.lblHoldNum.enabled := true;
		self.txtHoldNum.enabled := true;
		self.lblLocationName.enabled := true;
		self.txtLocationName.enabled := true;
		self.lblLocationNum.enabled := true;
		self.txtLocationNum.enabled := true;
		self.lblIsOnDeck.enabled := true;													// PAR #36766
		self.chkIsOnDeck.enabled := true;													// PAR #36766
		self.lblMaxWeight.enabled := true;													// PAR #36766
		self.txtMaxWeight.enabled := true;													// PAR #36766
		self.lblMaxVolume.enabled := true;													// 19/7/16 cnwmp6 TFS 1601
		self.txtMaxVolume.enabled := true;													// 19/7/16 cnwmp6 TFS 1601
		self.lblOnShipCrane.enabled := true;												// 12/7/16 cnwmp6 TFS 1601
		self.cmbOnShipCrane.enabled := true;												// 12/7/16 cnwmp6 TFS 1601
		self.txtHoldNum.setFocus();
		self.btnSave.enabled := true;
		
	endif;
	
	self.lblMaxHeight.enabled := true;	//07 Feb 2017	NDL	TFS 3216
	self.txtMaxHeight.enabled := true;	//07 Feb 2017	NDL	TFS 3216
	
	self.btnAdd.enabled := false;
	
	
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	self.btnSort.enabled := not self.btnSave.enabled;	//03 Feb 2017	NDL	TFS 3216/3047
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyVesselVoyage" id="1b653007-40ee-4f75-ab0b-2215aea83140">
        <updating/>
        <source>setMyVesselVoyage( _vessel : CM_Vessel; _voyage : CM_Voyage ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

begin

	self.myVessel := _vessel;
	self.myVoyage := _voyage;

epilog

