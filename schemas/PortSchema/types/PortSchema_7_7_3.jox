<Class name="PortSchema_7_7_3" id="19449c97-2f9f-4e0a-a699-cad318988d38">
    <superclass name="PortSchemaRelease"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="newRel"/>
    <JadeMethod name="mes1008CamUpgrade" id="41e72b4d-5b02-47ed-913e-74c56adcca3a">
        <source>mes1008CamUpgrade();

vars
	camProtocolDesc : CM_CamUserDefRepDesc;
	camProtocol 	: CM_CamProtocol;
	field, existField		: CM_Field;
	fields 			: CM_FieldByTypeSysNameDict;
begin
//	app.initialize;
	beginTransaction;
	camProtocolDesc := CM_CamUserDefRepDesc.firstInstance;
    if camProtocolDesc = null then
        create camProtocolDesc.CM_CamUserDefRepDesc;
        //  camProtocolDesc.name := CM_CamUserDefRepDesc.UserDefinedDescName; // the create method does this
        camProtocolDesc.setMyRoot();
    endif;
	
	create fields transient;
	self.getCamTriggerFields(fields, CM_CamEditTriggerField);
	
	// first look for ones we should delete 
	foreach existField in camProtocolDesc.allCamEditTriggerFields do
		if    fields.getAtKey (existField.systemTypeName, existField.systemName) = null then // has been removed
			  write ('Removing edit trigger field ' &amp; existField.systemTypeName &amp; " " &amp; existField.systemName);
			  delete existField;
		endif;
	endforeach;
	
	foreach field in fields do
		if camProtocolDesc.allCamEditTriggerFields[field.systemTypeName,field.systemName] = null then
			field.CM_CamEditTriggerField.setCamUserDefRepDesc(camProtocolDesc);
		else
			delete field;	// we don't need it, already exists
		endif;
	endforeach;
	

	commitTransaction;
epilog
	delete fields;
end;
</source>
    </JadeMethod>
</Class>
