    <JadeMethod name="getEDIDataClass" id="2bf3f52c-29d7-40d1-8333-01e1ef534a47">
        <source>getEDIDataClass() : Class;
//
// ccms 1008 Messina cnwrs1 Sept 2009
//
vars
	ediDataClass : Class;
begin
	ediDataClass := app.myRoot.myEdiConfig.getEDIDataClassForType(self.myEDIFieldMappingType.ediDataType);	
	return ediDataClass;
end;
</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getStripCharsAsString" id="74bcc271-d4e9-455e-94c9-a5f9d9d27dac">
        <source>getStripCharsAsString() : String;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	char	: Character;
	str		: String;
begin
	foreach char in self.allStripChars do
		str := str &amp; char;
	endforeach;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importMeXML" id="b5b90757-d56e-471d-a568-cffbdf3a5868">
        <updating/>
        <source>importMeXML(_classBlock: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2016	cnwndl1	Initial creation	TFS 2959 / 2420

*/

vars

	workStr : String;
	shortName : String;
	pos : Integer;
	len : Integer;
	measure : CM_MeasurementType;
	
	entTableGroup : EntTableGroup;
	entTableRow : EntTableRow;

begin
	inheritMethod(_classBlock);
	
	workStr :=  self.fieldDescr.trimBlanks;
	if workStr = null then
		return;
	endif;
	
	if workStr[workStr.length:1] = ")" then
		pos := workStr.pos("(",1);
		if pos &gt; 0 then
			len := workStr.length-(pos+1);
			if len &gt; 0 then
				shortName := workStr[pos+1:len];
			endif;
		endif;
	endif;
	
	if shortName = null then
		return;
	endif;
	
	measure := app.myRoot.allMeasurementTypesByShortName[shortName];
	if measure = null then
		return;
	endif;
	
	
	entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_EdiMaint];
	if entTableGroup = null then
		return;
	endif;
	
	entTableRow := entTableGroup.allEntTableRowsByName[propName];
	if entTableRow = null then
		return;
	endif;
	
	if entTableRow.measurementType &lt;&gt; measure.measurementType then
		return;
	endif;
	
	self.setMeasurementType(measure);

epilog

end;</source>
        <Parameter name="_classBlock" type="String"/>
    </JadeMethod>
