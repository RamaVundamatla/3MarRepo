    <JadeMethod name="cmbFreightFwdr_lostFocus" id="0c589433-37ab-4385-82b5-aedc5b87ea84">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFreightFwdr_lostFocus(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	forwarderObj	: CM_ConsigneeConsignor;
	operatorObj		: CM_Operator;
	
begin
	self.tblMain.setValueByControlName(combobox.name, combobox.text);
	combobox.doChangedCompareForEntryTable();
	
	if self.canViewBookingRef() then
		if combobox.listObject = null or self.myCurrentObject = null then
			tblMain.hideRowByName(ETRow_BookingReference, false);
		else
			tblMain.hideRowByName(ETRow_BookingReference, false);
			operatorObj		:=	self.myCurrentObject.CM_TrackedItem.myOperator;
			forwarderObj	:=	combobox.listObject.CM_ConsigneeConsignor;
			
			if operatorObj = null or forwarderObj = null then
				tblMain.hideRowByName(ETRow_BookingReference, false);
			else
				if operatorObj.allFFsForBookRefUpdate.includes(forwarderObj) then
// The following was only required for the 7.5.3 and 7.6.2 hotfixes.
//			if operatorObj.getConfig(OperatorForwarder).Object = forwarderObj then
					tblMain.showRowByName(ETRow_BookingReference, false);
				else
					tblMain.hideRowByName(ETRow_BookingReference, false);
				endif;
			endif;
		endif;
	endif;
end;


</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
