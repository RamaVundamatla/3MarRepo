<CollClass name="CMGTE_EntityArray" id="069e2ab4-8a1f-4ac3-b279-9fca59221347">
    <loadFactor>66</loadFactor>
    <memberType name="CMGTE_Entity"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmgte_data"/>
    <JadeMethod name="getIdxFromId" id="5e5f7dd1-75e9-497c-9f53-f0c5c00f9340">
        <source>getIdxFromId(_id : String) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwas3	Initial creation

*/

vars
	idx : Integer;
	entity : CMGTE_Entity;
begin
	foreach entity in self where entity.getID()=_id do
		return self.indexOf(entity);
	endforeach;
	return 0;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
