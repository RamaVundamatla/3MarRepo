    <Function name="winDrawTextExA" id="78eab151-71a9-4efe-9741-111e7812d2b7">
        <entrypoint>DrawTextExA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="user32"/>
        <source>winDrawTextExA
(
	hDC      : Integer; // handle to device context
	lpString : String; // pointer to string to be drawn
	nCount   : Integer; // string length; if -1 string must be null-terminated
	lpRect   : String; // pointer to rectangle in which text is to be drawn
	uFormat  : Integer; // formatting method
	lpParams : String  // pointer to more formatting parameters; may be null
)
is DrawTextExA in user32;</source>
        <Parameter name="hDC" type="Integer"/>
        <Parameter name="lpString" type="String"/>
        <Parameter name="nCount" type="Integer"/>
        <Parameter name="lpRect" type="String"/>
        <Parameter name="uFormat" type="Integer"/>
        <Parameter name="lpParams" type="String"/>
    </Function>
