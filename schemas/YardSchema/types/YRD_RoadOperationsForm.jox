    <JadeMethod name="turnAroundAsRelease" id="44890f98-e2ee-457b-a9e2-4a169cc4752c">
        <updating/>
        <source>turnAroundAsRelease()updating, protected;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
//This option enables the users to create a RELEASE for a Tracked Item receipt
//into the Terminal. They can do this if the receipt is NOT correct for some reason
//and needs to be accounted for on its way out of the Terminal area.
//We manually set the Original Receipt's status to ACTIONED

// 02/09/2009	cnwcs5	ccms 1061 - fixed leak where wleArray not being deleted
//nds TFS 2867 17/01/17 PKT - Bulk Process
vars
	proxyWLE	: CM_WorkListEntry;
	result		: Integer;
	wleArray 	: CM_WLEArray;
	wleTable 	: CM_DataTable;
	wle			: CM_WorkListEntry;
	reason 		: String; // cnwrd1 par 22624 3.5.2010
begin 
	wleTable := self.mnuTableContext.userObject.CM_DataTable;

	if wleTable = null then
		return;
	endif;

	reason := self.getTurnaroundReason(); // cnwrd1 par 22624 3.5.2010
	
	if reason = null then  // no reason must have canceled.
		return;
	endif;

	app.mousePointer 	:= MousePointer_HourGlass;	

	// get all WLE's that are selected in the table
	create wleArray transient;

	self.getAllWLEsInTableSelected(wleArray, wleTable,false);		//nds TFS 2867 17/01/17 PKT - Bulk Process

	foreach wle in wleArray do 		
		proxyWLE := app.createUpdateProxy(wle).CM_WorkListEntry;
		
		while true do
			app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, reason ,  app.myPassport); // cnwrd1 par 22624 3.5.2010
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(self.mnuTurnAround.caption,
													 app.myPassport, 
													 ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				// copies errors to this form and shows in err/warnings window			
				self.setAllErrorWarnings(app.myPassport);	
			endif;
			break;
		endwhile;	
		delete proxyWLE;
	endforeach;

epilog
	delete proxyWLE;
	delete wleArray;
	
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="txtFind_firstChange" id="5897b0a9-709e-48e6-9700-14dbf9f669b6">
