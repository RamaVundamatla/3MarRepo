        <controlMethod name="Table::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_keyPress(table: Table input; keyCode: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
