        <source>updateToDoTaskTs(_toDoTaskCode : Integer; _ts : TimeStamp; _dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 31 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;

begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	app.myTrxRT.trxUpdateToDoTaskTs(_toDoTaskCode, _ts, self.myMediator, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
	
	self.setMediatorState(self.Display_TI);
	_stateInfo.guiState	:= self.Display_TI;
		
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));

end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
