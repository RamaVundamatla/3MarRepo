    <JadeMethod name="canOverstow" id="74dfcbcf-e857-4812-ba73-ef7d9f5e0821">
        <source>canOverstow(_location : CM_YardController; _topTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

	isFound	: Boolean;
	str		: String;

begin

	if self.type = TI_Test_Voyage then
		return self.canOverstowVoyage(_location, _topTi, _yaAgent);
	elseif self.type = TI_Test_Weight then
		return self.canOverstowWeight(_topTi, _yaAgent);
	else
		str := self.getTypeAsString(null);
		return self.canOverstowStandard(str, _topTi, _yaAgent);
	endif;
	return false;

end;</source>
        <Parameter name="_location" type="CM_YardController"/>
        <Parameter name="_topTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canOverstowStandard" id="e23fa53e-05e7-477c-bb05-b0e88e9e5012">
        <source>canOverstowStandard(_errStr : String; _topTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if not _yaAgent.myCurrentCMIFYAAutoPlan.hasSameUnderStowAttribute(_topTi, self.type) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,_topTi.id &amp; ' is not able to be overstowed. Failed ' &amp; _errStr &amp; ' evaluation.', true);
		return false;
	endif;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Passed ' &amp; _errStr &amp; ' evaluation.', true);
	
	return true;


end;</source>
        <access>protected</access>
        <Parameter name="_errStr" type="String"/>
        <Parameter name="_topTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canOverstowVoyage" id="da79a4e9-c0f1-4203-b899-2cfb1c0d76b5">
        <source>canOverstowVoyage(_location : CM_YardController; _topTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars


	currentTi			: CM_TrackedItem;
	
begin

	if not _yaAgent.myCurrentCMIFYAAutoPlan.hasSameUnderStowAttribute(_topTi, self.type) then
		return self.overstowLaterVoyages(_location, _topTi, _yaAgent);
	endif;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Passed voyage overstow evaluation.', true);
	
	if not  self.overstowVoyageJobChecks(_location, _topTi, _yaAgent) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,_topTi.id &amp; ' is not able to be overstowed.', true);
		return false;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_YardController"/>
        <Parameter name="_topTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canOverstowWeight" id="f23d50d0-d431-42a5-8d9f-bdf6f841c88b">
        <source>canOverstowWeight(_topTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
// This method determines whether a box can be placed on top of the passed in ti 
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars

	underStowWeight:	Integer;
	currentItemWeight	: Decimal[14,4];
	tmpMoveMode		: Integer;
	minimumWeight	: Decimal[12,2];
	weightRange		: CM_WeightRange;
	measure 		: CM_MeasurementType;					// PAR #31155

begin

	// Get total weight of auto planning box.
	currentItemWeight	:= _yaAgent.myCurrentCMIFYAAutoPlan.totalWeight();
	// Get bottom box's total weight.
	underStowWeight		:= _topTi.totalWeight.Integer;
	
	// Find weigth range object for bottom box.
	//weightRange := app.myRoot.allWeightRanges.getAtKeyGeq(underStowWeight);		// PAR #31155
	measure := app.getDefaultMeasurementForType(Type_Weight);						// PAR #31155
	weightRange := measure.allWeightRanges.getAtKeyGeq(measure, underStowWeight);	// PAR #31155
	
	if weightRange = null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'No weight range defined for ' &amp; underStowWeight.String, false);
		return false;
	endif;
	
	// Use below calculationn to determine minimum weight that overstowing box must be.
	minimumWeight := (underStowWeight - (underStowWeight * (weightRange.percentage / 100)));
	
	if not (currentItemWeight &gt;= minimumWeight) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Minimum overstow weight for understow tracked item is ' &amp; minimumWeight.String, true);
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item weight is ' &amp; currentItemWeight.String, true);
		return false;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_topTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTypeAsString" id="63473d5a-731e-4abe-ae46-a4c0ef183d55">
        <source>getTypeAsString(_type : Integer) : String;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	theType	: Integer;

begin
	
	if _type &lt;&gt; 0 then
		theType := _type;
	else
		theType := self.type;
	endif;
	
	if theType = TI_Test_Carrier then
		return app.getErrorString(Carrier);
	elseif theType = TI_Test_CommodityGroup then
		return app.getErrorString(CommodityGroup);
	elseif theType = TI_Test_DischargePort then
		return app.getErrorString(DischargePort);
	elseif theType = TI_Test_ImExStatus then
		return app.getErrorString(IMEX);
	elseif theType = TI_Test_Consignee then
		return app.getErrorString(Consignee);
	elseif theType = TI_Test_Operator then
		return app.getErrorString(Operator);
	elseif theType = TI_Test_Voyage then
		return 'Voyage';
	elseif theType = TI_Test_Weight then
		return 'Weight';
	else
		return null;
	endif;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="overstowLaterVoyages" id="17441c27-4dc4-4f17-87ee-e7c6ed5378f6">
        <source>overstowLaterVoyages(_location : CM_YardController; _topTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
// -------------------------------------------
// Created 14 September 2005 by cnwdvb1
// -------------------------------------------
vars

	voyage	: CM_Voyage;

begin

	if	self.myYAOverstowRule.overstowLaterVoyages = CM_YAOverstowRule.NeverOverstowLaterVoyage or 
		self.myYAOverstowRule.overstowLaterVoyages = 0 then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _location.getFullId() &amp; ' has failed overstow voyage test.', true);
		return false;
	endif;
	
	voyage := _yaAgent.myCurrentCMIFYAAutoPlan.getVoyage();
	
	if voyage = null or _topTi.myVoyage = null then
		// Can't make decision.
		return false;
	endif;
	
	// Ok if overstow box's voyge is due on later date. But if before it's a no no.
	if voyage.arrivedDT &gt; _topTi.myVoyage.arrivedDT then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _location.getFullId() &amp; ' has broken voyage overstow rule and overstowed box voyage is ealier', true);
		return false;
	endif;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Location  - ' &amp; _location.getFullId() &amp; ' has a different voyage but overstowed box voyage is later', true);
	_yaAgent.addLocationToAgent(_location, CM_YAAutoplanAgent.Temp_LastResort);
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_YardController"/>
        <Parameter name="_topTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="overstowVoyageJobChecks" id="f8c92cf9-f6f0-45bd-a3a6-12cb08409972">
        <source>overstowVoyageJobChecks(_location : CM_YardController; _topTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean protected;
// -------------------------------------------
// Created 14 September 2005 by cnwdvb1
// -------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars

	currentTi			: CM_TrackedItem;
	isStarboard,
	isCurrentPlanned,	
	isTopPlanned		: Boolean;
	wleTop,
	wleCurrent			: CM_VoyageWLE;
	jobTop,
	jobCurrent			: CM_VoyageJob;
	rtnValue			: Boolean;

begin

	if not self.myYAOverstowRule.doVoyageJobChecks then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Not doing voyage job checks', true);
		return true;
	endif;
	
	// Let is through. It's a senario and we don't have enough
	// info to make these decisions.
	if not _yaAgent.isSingleProcessing() then
		return true;
	endif;
	
	currentTi := _yaAgent.getMyCurrentTrackedItem();
	
	if currentTi = null then
		return true;
	endif;
	
	// Get tranship tracked item for export.
	//if currentTi.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
		//currentTi := currentTi.myTranshipExport;	// PAR #23645 CCMS 1116
	//endif;										// PAR #23645 CCMS 1116

	// Get ship release jobs for both boxes.
	jobTop 		:= _topTi.allJobsShipRelease.last;
	jobCurrent	:= currentTi.allJobsShipRelease.last;
	
	// Only deal with ship jobs.
	if jobTop = null or jobCurrent = null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'No ship jobs to evaluate in overstow voyage job check', true);
		return true;
	endif;
	
	// Both boxes are on the same job.
	if jobTop = jobCurrent then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Evaluating overstow sequencing for same job.', true);
		isStarboard := jobTop.myVoyage.starboardBerthed;
		// Get wles for both tis from job.
		wleTop := jobTop.getWLEForTI(_topTi).CM_VoyageWLE;
		wleCurrent := jobTop.getWLEForTI(currentTi).CM_VoyageWLE;
		// Get sequences numbers depending on setup of job and voyage.
		if isStarboard then
			if jobTop.isTwinLift then
				rtnValue := wleCurrent.numSeqStarboardTwinCustom &lt; wleTop.numSeqStarboardTwinCustom;
				if not rtnValue then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item has a later starboard twin sequence number than overstow box.', true);
				endif;
				return rtnValue;
			else
				rtnValue := wleCurrent.seqNumCustomStarboard &lt; wleTop.seqNumCustomStarboard;
				if not rtnValue then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item has a later starboard sequence number than overstow box.', true);
				endif;
				return rtnValue;
			endif;
		else
			if jobTop.isTwinLift then
				rtnValue := wleCurrent.numSeqPortTwinCustom &lt; wleTop.numSeqPortTwinCustom;
				if not rtnValue then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item has a later port twin sequence number than overstow box.', true);
				endif;
				return rtnValue;
			else
				rtnValue := wleCurrent.seqNumCustomPort &lt; wleTop.seqNumCustomPort;
				if not rtnValue then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item has a later port sequence number than overstow box.', true);
				endif;
				return rtnValue;
			endif;
		endif;
	// Different jobs. 
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Evaluating overstow sequencing for different job', true);
		// If a job does not have an assigned crane we can't tell the order so bail.
		if jobTop.myJobSheet = null or jobCurrent.myJobSheet = null then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Unable to determine sequeunce as cranes not assigned to jobs.', true);
			return false;
		// Same crane so is the overstowing box being worked before the overstowed box?
		//elseif 	jobTop.myJobSheet.CM_VoyageJobSheet.crane = jobCurrent.myJobSheet.CM_VoyageJobSheet.crane then
		elseif 	jobTop.myJobSheet = jobCurrent.myJobSheet then
			rtnValue := jobTop.myJobSheet.allJobsByOrder.indexOf(jobTop) &gt; jobCurrent.myJobSheet.allJobsByOrder.indexOf(jobCurrent);
			if not rtnValue then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item has a later job sequence than overstow box.', true);
			endif;
			return rtnValue;
		else
			return false;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_YardController"/>
        <Parameter name="_topTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ce206fa9-9cf0-4e37-adee-96c57b799571">
        <updating/>
        <source>setForUpdate(_proxyAttribute : SelfType; _realRule : CM_YAOverstowRule) updating;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.type 				:= _proxyAttribute.type;
	self.myYAOverstowRule	:= _realRule;

end;</source>
        <Parameter name="_proxyAttribute" type="SelfType"/>
        <Parameter name="_realRule" type="CM_YAOverstowRule"/>
    </JadeMethod>
    <JadeMethod name="setMyYaOverstowRule" id="2bed19d5-a287-4a2a-ad2d-7d5a45fa2765">
        <updating/>
        <source>setMyYaOverstowRule(_overstowRule : CM_YAOverstowRule) updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myYAOverstowRule := _overstowRule;


end;</source>
        <Parameter name="_overstowRule" type="CM_YAOverstowRule"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="33b18f9c-e465-4794-85e5-2968d944796e">
        <updating/>
        <source>setProxy(_type : Integer; _yaOverstowRule	: CM_YAOverstowRule) updating;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myYAOverstowRule	:= _yaOverstowRule;
	self.type				:= _type;


end;</source>
        <Parameter name="_type" type="Integer"/>
