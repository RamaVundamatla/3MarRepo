    <JadeMethod name="erase" id="975af4cf-8eb0-4489-9686-04c1a96305bb">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateArea	:CM_GateArea;
begin
	gateArea	:= self.myGateArea;
	
	// do the delete of the receiver
	inheritMethod(_level);
	
	if gateArea &lt;&gt; null and 		// not already deleted by another usage
		not gateArea.hasUsages then	// no longer used
		gateArea.erase (_level);
	endif;
epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4568ddf9-fbda-4e51-99d5-40c0f2c9c97a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     27 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_Area_in_out then
		return self.type.String;	
	elseif _attrName = ETRow_Area_Type or
		_attrName = ETRow_Area_id or
		_attrName = ETRow_Area_comment or
		_attrName = ETRow_Area_laneCount then
		return self.myGateArea.getDisplayStringForAttribute (_attrName, _short);
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
