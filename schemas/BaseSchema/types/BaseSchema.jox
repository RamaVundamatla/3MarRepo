//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	self.cnEcInitializeBaseSchema();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcIsBaseException" id="504ad14c-3e86-422a-aad3-480d2851dbcc">
        <source>cnEcIsBaseException(pExceptionObj:Exception):Boolean;
// --------------------------------------------------------------------------------
// Created:		22 October 2002 by cnwdad1
//
// Purpose:		Return a boolean flag to indicate whether the specified exception
//				is a BaseSchema exception object.
//
// Parameters:	pExceptionObj - The exception object to check.
//
// Returns:		True if the exception was raised by BaseSchema, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return CnEcBaseException.hasInstance(pExceptionObj);
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsOneOf" id="bf6e4d59-b56c-4138-9082-01309423745d">
        <source>cnEcIsOneOf(pValue:Any; pParamList:ParamListType):Boolean;
// --------------------------------------------------------------------------------
// Created:		03 March 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the pValue parameter
//				metches any of the values in the parameter list.
//
// Parameters:	pValue - The value to compare to the parameter list.
//				pParamList - A list of any number of parameters to compare to the
//					pValue parameter.
//
// Returns:		True if the pValue parameter matches one of the values in the
//				parameter list, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramCount	: Integer;
	
begin
	if pValue = null then
		return false;
	endif;
	
	paramCount	:=	app.getParamListTypeLength(pParamList);
	
	foreach paramCount in 1 to paramCount do
		if app.getParamListTypeEntry(paramCount, pParamList) = pValue then
			return true;
		endif;
	endforeach;
end;</source>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pParamList" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMaybe" id="f145d109-81f8-48fb-8e67-f271b13ed873">
        <source>cnEcMaybe():Boolean;
// --------------------------------------------------------------------------------
// Created:		29 January 2002 by cnwdad1
//
// Purpose:		Randomly returns a boolean flag.
//
// Parameters:	None
//
// Returns:		Either true or false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (app.random(100).isEven);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcNotImplemented" id="0e9867cc-b6cf-4499-8180-a1ba521c1d99">
        <source>cnEcNotImplemented();
// --------------------------------------------------------------------------------
// Created:		11 February 2001 by cnwdad1
//
// Purpose:		Displays a dialog informing the User that the function they just
//				tried is not yet implemented.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/04/2002	cnwdad1		Changed to fetch the second element of the call stack,
//							not the first.
// --------------------------------------------------------------------------------
vars
	callStackObj	: ProcessStackArray;
	
begin
	create callStackObj transient;
	self.cnEcGetPreviousMethods(callStackObj);
	
	app.msgBox(	"Sorry, this functionality has not yet been implemented.",
				callStackObj[2].MethodCallDesc.display,
				MsgBox_OK_Only + MsgBox_Information_Icon);
epilog
	callStackObj.purge();
	delete callStackObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcSetBaseAgent" id="4bac1d66-7bca-4c6d-9668-5dee19ed76fd">
        <updating/>
        <source>cnEcSetBaseAgent() updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad2
//
// Purpose:		Instantiates the CnEcBaseSchemaAgent reference (transient).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.myBaseAgent transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcSetBaseRoot" id="4a13f482-588f-4dd4-8c98-e3ba6014fe80">
        <updating/>
        <source>cnEcSetBaseRoot(pIsCreateIfNotFound:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Sets the BaseSchema root class on the app class.
//
// Parameters:	pIsCreateIfNotFound (Boolean) - If true, and if an instance of the
//				CnEcBaseRoot class isn't found, then one will be created (note that
//				this will require a database transaction).
//
// Returns:		True if the set was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	baseRootObj	: CnEcBaseRoot;

begin
	baseRootObj	:=	CnEcBaseRoot.firstInstance();

	if baseRootObj = null and pIsCreateIfNotFound then
		beginTransaction;
		create baseRootObj;
		commitTransaction;
	endif;

	self.myBaseRoot	:=	baseRootObj;
epilog
	return (app.myBaseRoot &lt;&gt; null);
end;</source>
        <Parameter name="pIsCreateIfNotFound" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetXmlSchema" id="d1471eee-e2a5-4cf8-a5d6-185ff2a5a501">
        <updating/>
        <source>cnEcSetXmlSchema(pSchemaName : String) updating;

vars
	schemaObj	: Schema;
	
begin
	self.myCnEcXmlSchema	:=	null;

	foreach schemaObj in Schema.instances do
		if schemaObj.name = pSchemaName then
			self.myCnEcXmlSchema	:=	schemaObj;
			
			return;
		endif;
	endforeach;
end;</source>
        <Parameter name="pSchemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcStartupJDBrowser" id="d6babdf3-d364-41d8-ba8b-6ee4553dd308">
        <source>cnEcStartupJDBrowser();
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Initialize method for the JDBrowser application.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	schemaCollObj	: SchemaColl;

begin
	on Exception do cnEcJDBrowserExceptionHandler(exception) global;
	on LockException do app.globalLockException(exception) global;

	app.mdiFrame	:=	CnEcJDBrowserMdi;
	create schemaCollObj transient;
	rootSchema.allSubschemas(schemaCollObj);

	foreach schemaObj in schemaCollObj do
		if app.startupForm = null then
			app.startupForm	:=	schemaObj.findMeForm('CnEcJDBrowserMdi');
		endif;

		if app.aboutForm = null then
			app.aboutForm	:=	schemaObj.findMeForm('CnEcBrowserAboutForm');
		endif;

		if app.startupForm &lt;&gt; null
		and app.aboutForm &lt;&gt; null
		then
			break;
		endif;
	endforeach;
epilog
	delete schemaCollObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcTeachDisplayTutorial" id="2d30c961-f742-47d8-ac0f-1baec14f58bc">
        <source>cnEcTeachDisplayTutorial(pTutorialFormObj:Form; pNotifyOnNotFound:Boolean);

vars
	tutorialObj	: CnEcTTeachShowForm;
//	theFile		: File;						// cnwdad1 26/09/2000.

begin
	if not cnEcTeachLessonAvailable(pTutorialFormObj) then
		if pNotifyOnNotFound then
			app.msgBox($CNEC_LESSON_NOT_DEFINED, $CNEC_LESSON_ERROR, MsgBox_OK_Only);
		endif;
		
		return;
	endif;	

	// create and show the tutor form
	if tutorialObj = null then
		create tutorialObj;
	endif;

//	create theFile;							// cnwdad1 26/09/2000.

	tutorialObj.startup(pTutorialFormObj, false);
	tutorialObj.setFormParent(pTutorialFormObj);
	tutorialObj.show();
epilog
//	delete theFile;							// cnwdad1 26/09/2000.
end;

/*
cnEcTeachDisplayTutorial(form : Form );

vars
	tutorial	: CnEcTTeachShowForm;
	lesson		: CnEcTLesson;
	file		: File;
	found		: Boolean;
	nm			: String;
begin
	found 	:= false;
	nm 		:= form.name;

	// check that there is a lesson for the form
	foreach lesson in app.myBaseRoot.allTLessons do
		if lesson.formName = nm then
			found := true;
			break;
		endif;
		if lesson.formName &gt; nm then
			break;
		endif;	
	endforeach;
	if not found then
		app.msgBox($CnEcLessonNotDefined, $CnEcLessonError,MsgBox_OK_Only);
		return;
	endif;	

	// create and show the tutor form
	if tutorial = null then
		create tutorial;
	endif;

	create file;

	tutorial.startup( form, false );
	tutorial.setFormParent( form );
	tutorial.show;
epilog
	delete file;	
end;
*/</source>
        <Parameter name="pTutorialFormObj" type="Form"/>
        <Parameter name="pNotifyOnNotFound" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcTeachLessonAvailable" id="ed17088d-52a8-47dd-a9a8-3e1ee3b443c2">
        <source>cnEcTeachLessonAvailable(pFormObj : Form) : Boolean;

vars
	formName	: String;
	lessonObj	: CnEcTLesson;
	
begin
	formName 	:= pFormObj.name;

	// check that there is a lesson for the form
	lessonObj	:=	self.myBaseRoot.allTLessons.getAtKeyGeq(formName, null);

	return (lessonObj &lt;&gt; null) and (lessonObj.formName = formName);
end;</source>
        <Parameter name="pFormObj" type="Form"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXHandler" id="661ed3aa-1236-4783-b004-427e27cd047a">
        <source>cnEcXHandler(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		General global exception handler which deals with BaseSchema
//				exceptions.  If the exception was raised by BaseSchema, then an
//				error message box will display the error, otherwise the CardSchema
//				unhandled exception dialog will be shown.
//
// Parameters:	pExceptionObj - The exception object.
//
// Returns:		The exception action return code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/03/2003	cnwdad1		Changed to report BaseSchema exceptions with a dialog
//							box, instead of showing all of the exception details.
//							If the exception is not a BaseSchema exception, then
//							the handler will pass back to the next one in the stack.
// --------------------------------------------------------------------------------
begin
	if pExceptionObj.cnEcIsBaseException() then
		abortTransaction;		// This will do nothing if the database is not in transaction state.
//		pTheException.cnEcShowDialog();
		app.msgBox(pExceptionObj.errorItem, $CNEC_ERROR, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		
		return Ex_Abort_Action;
	else
//		return pTheException.cnEcShowException();
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcXhandlerInvalidRef" id="cbf66a0d-a8a8-4095-8df5-b7662bf6ba76">
        <source>cnEcXhandlerInvalidRef(pExceptionObj:Exception; pObject:Object; pIsInvalid:Boolean io):Integer;
// --------------------------------------------------------------------------------
// Created:		28 May 2008 by cnwdad1
//
// Purpose:		General exception handler to deal with invalid object references.
//				Needs to be armed with a specific object reference to be checked.
//
// Parameters:	pExceptionObj - A reference to the exception object.
//				pObject - A reference to the object being referenced.  Note that
//					this reference does not have to be set at the time the handler
//					is armed.
//				pIsInvalid - Returns true if the exception handler is tripped.
//					This should be reset after each time it is tripped.
//
// Returns:		Standard Exception return codes, and the pIsInvalid parameter set
//				to true if the specified object reference caused the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
	InvalidClass	: Integer = 1046;
	
vars
	returnVal		: Integer;
	
begin
	returnVal	:=	Ex_Pass_Back;
	
	if pExceptionObj.errorCode = ObjectNotFound
	or pExceptionObj.errorCode = ObjectDeleted
	or pExceptionObj.errorCode = InvalidClass
	then
		if pExceptionObj.errorObject = pObject then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			pIsInvalid	:=	true;
			
			if pExceptionObj.resumable then
				returnVal	:=	Ex_Resume_Next;
			endif;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsInvalid" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSingleton" id="335c4215-a254-4e69-9393-15fad80ab36c">
        <updating/>
        <source>getSingleton(pClassObj : Class) : Object updating;
// -----------------------------------------------------------------------------
// Created:		16 April 1999 by cnwrjs1
//
// Purpose:		Returns the first instance of the requested class if one exists,
//				otherwise an instance is created and then returned.  If the class
//				is Persistent by default, then the method will handle the
//				transaction state, unless the process is already in transaction
//				state.
//
// Parameters:	pClassObj - The class whose singleton is required.
//
// Returns:		The first instance of the class, or the newly instantiated singleton.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 06/01/2001	cnwdad1		This method used to use the Object::cnEcTransactionBegin
//							and Object::cnEcTransactionCommit methods.  Changed
//							this method to handle the transaction state itself
//							because the former two methods have been removed
//							from BaseSchema.
// -----------------------------------------------------------------------------
vars
	singletonObj	: Object;
	isCommitTrx		: Boolean;

begin
	singletonObj	:=	pClassObj.firstInstance();

	if singletonObj = null then
		// Check whether we need to handle the transaction state.
		
		if pClassObj.cnEcIsPersistent() then
			// If the process is already in transaction state, then we don't need to do anything.
			if process.isInTransactionState() then
				isCommitTrx	:=	false;
			else
				isCommitTrx	:=	true;
			endif;
		else
			isCommitTrx	:=	false;
		endif;
		
		if isCommitTrx then
			beginTransaction;
		endif;
		
		create singletonObj as pClassObj;

		if isCommitTrx then
			commitTransaction;
		endif;
	endif;

	return singletonObj;
end;</source>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="Object"/>
    </JadeMethod>
