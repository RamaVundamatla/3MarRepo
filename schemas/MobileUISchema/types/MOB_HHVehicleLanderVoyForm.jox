    <JadeMethod name="setupForm" id="e51db2bd-d732-4f1f-9b92-afcef743d351">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
