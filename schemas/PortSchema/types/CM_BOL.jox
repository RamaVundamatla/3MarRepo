    <JadeMethod name="getTransferTransWithChildren" id="11fa951a-1404-4101-b3b4-69fd12b744bb">
        <source>getTransferTransWithChildren() : CM_BOLTrnsactByTypeDateDict;
// 27/04/2016  TFS 1904 for reporting
vars
	dict	: CM_BOLTrnsactByTypeDateDict;
	tran	: CM_BOLTransaction;
begin

	create dict transient;
	foreach tran in self.allBOLTransactions do
		if tran.isKindOf(CM_BOLTransferTransaction) then
			dict.add(tran);
		endif;
	endforeach;

	return dict;
end;
</source>
        <ReturnType type="CM_BOLTrnsactByTypeDateDict"/>
    </JadeMethod>
