    </PrimAttribute>
    <PrimAttribute name="regNumber" id="0726907b-31e9-4e4c-807b-59268e05fcd5">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="timeIn" id="a354cc90-6f99-4f97-9b74-a642d5c85e07">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="timeOut" id="9083ba18-48dc-4089-9883-2224dd192de1">
