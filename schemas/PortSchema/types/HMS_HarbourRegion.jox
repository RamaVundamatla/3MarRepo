    <JadeMethod name="hasCheckpointsWithTidalModel" id="b1a71c1b-8fe2-4d24-80f4-01b3a3f10ac1">
        <source>hasCheckpointsWithTidalModel() :Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	16 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	checkPoint : HMS_CheckPoint;
begin
	if self.allCheckpoints.size = 0 then
		return false;
	endif;
	
	//with changes for rio tinto now its not always the case that if you have a checkpoint that it relates to tidal data
	if self.myHeightCheckpoint &lt;&gt; null then
		return true;
	endif;
	
	if self.myCurrentCheckpoint &lt;&gt; null then
		return true;
	endif;
	
	if self.myHiLoCheckpoint &lt;&gt; null then
	//	return true;
	endif;
	
	return false;
			

end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTerminal" id="9759fed1-4f83-4be7-9fbb-b127df270ffa">
        <source>isTerminal():Boolean;
// --------------------------------------------------------------------------------
// Created:		22 September 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is actually
//				a Terminal.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Terminal, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// OK to use self.myTermnal and not self.getTerminalForScenario() as
	// just want to know if this is a terminal based region
	return (self.myTerminal &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
