    <JadeMethod name="setProxyFromObject" id="157861c2-143d-411c-86f7-82e4c9395800">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodVoyageRequest) updating;
/*
Purpose:	TFS 40029		
Date				Who			Reason
AUGUST 2018			CNWAB1		Initial creation
26 August 2022		jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
*/

vars
		voyage 	: CM_Voyage;
		file : CM_FileData;
		wsDocument 	: WS_Document;
		wo : CM_WorkOrder;
begin
	inheritMethod(_object);
	
	self.cargoOperatorCodeDischarge := _object.cargoOperatorCodeDischarge;
	self.cargoOperatorCodeLoad := _object.cargoOperatorCodeLoad;
	self.estimatedArrivalTS := _object.estimatedArrivalTS.asStringForWebInterface();
	self.estimatedDepartureTS := _object.estimatedDepartureTS.asStringForWebInterface();
	self.externalCode := _object.externalCode;
	self.portCode1 := _object.portCode1;
	self.portCode2 := _object.portCode2;
	self.portCode4 := _object.portCode4;
	self.portCode5 := _object.portCode5;
	self.vesselCategoryCode := _object.vesselCategoryCode;
	self.visitTypeCode := _object.visitTypeCode;
	self.voyageCodeIn := _object.voyageCodeIn;
	self.voyageCodeOut := _object.voyageCodeOut;
	self.voyage := _object.voyageCode;
	self.voyageOperatorCode := _object.voyageOperatorCode;
	//jlier1 TFS 51963 7/10/21
	self.generalRemarks:=_object.generalRemarks;
	self.hasCargo:=_object.hasCargo;
	
	voyage := _object.getMyVoyageObject();
	if voyage &lt;&gt; null then
		self.vesselCode := voyage.vesselCode;
	endif;	
	
	wo := _object.myParent;							// TFS 54298
	if wo &lt;&gt; null then								// TFS 54298
		foreach file in wo.allFiles do				// TFS 54298
			create wsDocument transient;			// TFS 54298
			wsDocument.setProxyFromObject(file);	// TFS 54298
			self.allDocuments.add(wsDocument);		// TFS 54298
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_WodVoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="3bd7be68-4053-47f9-90e0-8d418367eadb">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodVoyageRequest input);
/*

Purpose:			TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2018	jlgab1	Initial creation
07 Oct 2021 jlier1	TFS 50963
*/

vars

begin
	inheritMethod(_pxyWorkOrder);

	_pxyWorkOrder.setProxyVoyageRequest(self.cargoOperatorCodeDischarge,
																	self.cargoOperatorCodeLoad,
																	"",
																	self.estimatedArrivalTS.asTimeStampFromWebInterface(),
																	self.estimatedDepartureTS.asTimeStampFromWebInterface(),
																	self.externalCode,
																	self.portCode1,
																	self.portCode2,
																	self.portCode4,
																	self.portCode5,
																	self.vesselCategoryCode,
																	"",
																	self.visitTypeCode,
																	self.voyage,
																	self.voyageCodeIn,
																	self.voyageCodeOut,
																	self.voyageOperatorCode,
																	self.generalRemarks,
																	self.hasCargo);
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodVoyageRequest" usage="input"/>
    </JadeMethod>
</Class>
