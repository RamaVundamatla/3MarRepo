    <JadeMethod name="addToUserMenuFromMenu" id="25fd74ee-db61-44f5-bd11-a1734de149fc">
        <source>addToUserMenuFromMenu(_menuRoot: CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	sharedLock(self);

	if (not self.myMenuDtl.canDoForRoot(_menuRoot)) then
		return;
	endif;

	self.myMenuDtl.addToUserMenuRoot(_menuRoot);
	
	inheritMethod(_menuRoot);

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneFromSource" id="b1920e89-7a9d-46ce-8226-6b24c0cf64fe">
        <updating/>
        <source>cloneFromSource(_parent : CM_MenuEntity; 
				_source : SelfType; 
				_terminal : CM_Terminal;
				_targetMenuRoot : CM_MenuRoot input;
				_user : CM_User;
				_clearFirst : Boolean;
				_deleteSet : CM_MenuEntitySet input) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myUserTerminalIFOnToolbar := _source.myUserTerminalIFOnToolbar;
	inheritMethod(_parent, _source, _terminal, _targetMenuRoot, _user, _clearFirst, _deleteSet);
	
end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_source" type="SelfType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_targetMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDblClick" id="0a69eca3-50c1-4b44-8ee7-9effb32b2c53">
        <source>doDblClick(_userWindow : CM_UserWindow);

vars
	menuAction	: CM_MenuAction;
	tmpClassName	: String;
	tmpClass	: Class;
	foundExisting		: Boolean;
begin

	if self.myMenuDtl.CM_MenuDtlNav.classNameToCreate = null then
		// Do we need a default class on root (ie CMUI_MenuAction)
	else
		tmpClassName := self.myMenuDtl.CM_MenuDtlNav.classNameToCreate;
	endif;
	
	tmpClass := currentSchema.getClass(tmpClassName);
	if tmpClass = null then
		return;
	endif;

	create menuAction as tmpClass transient;
	menuAction.setFromMenuDtl(self, self.myMenuDtl.CM_MenuDtlNav);
	menuAction.actionFromMenuDtl(true, _userWindow);
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getItemsToDelete" id="1a0f1164-1803-4279-a300-f3951510e567">
        <source>getItemsToDelete(_delSet: CM_MenuEntitySet input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.myMenuDtl.canDoForRoot(self.getMyMenuRoot)) then
		_delSet.add(self);
	endif;

	inheritMethod(_delSet);

end;</source>
        <Parameter name="_delSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
