<GUIClass name="CnEcUserInputForm" id="52ac4a1d-57d1-477d-a14a-54a656cabf2a">
    <superclass name="CnEcBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
