    <JadeMethod name="adjustFrameXYs" id="42039ab8-a6b9-4f15-871b-91ba4fc0c9ab">
        <source>//adjustFrameXYs(realX1, realY1: Integer io; tmpFrame : SHP_BayDrawingFrame);
adjustFrameXYs(realX1, realY1: Integer io; tmpFrame : CMUI_GridAreaDrawingFrame);
// ---------------------------------------------------------------------------
// Created:		08 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 16/02/2016	cnwdap1		PAR #36766 Bulk Graphical Representation
vars
	frmX1, frmX2, frmY1, frmY2 : Integer;
	objX1, objX2, objY1, objY2 : Integer;
begin

		if tmpFrame = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'the bay drawing frame is null');
			return;
		endif;

		frmX1 := tmpFrame.left.Integer;
		frmX2 := tmpFrame.clientWidth + tmpFrame.left.Integer;
		frmY1 := tmpFrame.top.Integer;
		frmY2 := tmpFrame.clientHeight + tmpFrame.top.Integer;
		
		objX1 := realX1 - frmX1 + 5;
		objY1 := realY1 - frmY1 + 5;

		realX1 := objX1;
		realY1 := objY1;
end;</source>
        <Parameter name="realX1" type="Integer" usage="io"/>
        <Parameter name="realY1" type="Integer" usage="io"/>
        <Parameter name="tmpFrame" type="CMUI_GridAreaDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="24eec379-d7a6-4222-8ef7-700332bf935a">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>contextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		08 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpFrame : CMUI_GridAreaDrawingFrame;
	frmX1, frmY1 : Integer;
begin
	tmpFrame := self.myScrollingFrame.getBayFrameFromXY(x,y);
	if tmpFrame  = null then 
		return false;
	endif;
	
	frmX1 := self.origXPos.Integer;
	frmY1 := self.origYPos.Integer;
	self.adjustFrameXYs(frmX1, frmY1,tmpFrame);

	return tmpFrame.contextMenu(tmpFrame, conwin, mouse,frmX1, frmY1);
	
//	return inheritMethod(frame, conwin, mouse, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="7e02cac8-130d-40d6-a7ce-b1287d6442b1">
        <controlMethod name="Frame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(frame: Frame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpFrame : CMUI_GridAreaDrawingFrame;
	frmX1, frmY1 : Integer;
begin
	tmpFrame := self.myScrollingFrame.getBayFrameFromXY(self.origXPos,self.origYPos);
	
	if tmpFrame &lt;&gt; null then
		frmX1 := self.origXPos.Integer;
		frmY1 := self.origYPos.Integer;
		self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
		tmpFrame.dblClick(tmpFrame);
	endif;
	
	inheritMethod(frame);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="2a646e2e-9c48-4cd8-b192-bf0ef2520567">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	frmX1		: Integer;
	frmY1		: Integer;
	tmpFrame	: CMUI_GridAreaDrawingFrame;
	
begin
	if not self.isDrawDeskTopRectangle then
		tmpFrame	:=	self.myScrollingFrame.getBayFrameFromXY(x, y);
		
		if tmpFrame &lt;&gt; null then
			frmX1	:=	x.Integer;
			frmY1	:=	y.Integer;
			self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
			tmpFrame.dragDrop(tmpFrame, win, frmX1, frmY1);
		endif;
	endif;
	
	self.clearGraphics();
	
	inheritMethod(frame, win, x, y);
epilog
	self.enableEvent("MouseMove",false);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="33dd5964-2cdf-4e75-9e0d-cb50fedaed5d">
        <controlMethod name="CMUI_ScrollingFrame::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpFrame : CMUI_GridAreaDrawingFrame;
	frmX1, frmY1 : Integer;
begin
	if self.isControllKey then
		self.drawDragFrame(x,y);
	else
		tmpFrame := self.myScrollingFrame.getBayFrameFromXY(x,y);
		if tmpFrame &lt;&gt; null then
			frmX1 := x.Integer;
			frmY1 := y.Integer;
			self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
			tmpFrame.dragOver(tmpFrame, win, frmX1, frmY1, state);
		endif;
	endif;
	
	inheritMethod(frame, win, x, y, state);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawDragFrame" id="312058d4-71e0-4381-96ce-baa49b40d68e">
        <updating/>
        <source>drawDragFrame( x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	WIDTH	= 1;
vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
begin
	self.clearGraphics;

	self.drawStyle := Frame.DrawFillStyle_Transparent;
	self.drawWidth := 1;

	self.drawFillStyle := Frame.DrawFillStyle_Transparent;
	self.drawFillColor := Black;

	self.drawFilledRectangle(self.origXPos.Integer, self.origYPos.Integer,x,y, Black);



end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="dd1deb2f-73aa-4377-b690-0c99462c7fc3">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
//	tmpFrame : SHP_BayDrawingFrame;
	tmpFrame : CMUI_GridAreaDrawingFrame;
	frmX1, frmY1 : Integer;
begin
	self.isControllKey := shift.isControlKeyPressed;
	self.enableEvent("MouseMove",true);
	tmpFrame := self.myScrollingFrame.getBayFrameFromXY(x,y);
	if tmpFrame = null then 
		return;
	endif;	
	
	frmX1 := x.Integer;
	frmY1 := y.Integer;
	self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
	tmpFrame.mouseDown(tmpFrame, button, shift, frmX1, frmY1);
	
	self.origXPos := x;
	self.origYPos := y;
	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="ea43c9a6-a3b8-40be-8bd1-acca4e2ce7b1">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpFrame : CMUI_GridAreaDrawingFrame;
	holdFrame : SHP_BulkDrawingFrame;
	shipForm : SHP_VoyageAreaForm2;
	holdForm : SHP_BulkVoyagePlanningForm;
	frmX1, frmY1 : Integer;
begin
	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		if self.isControllKey then
			
			if self.myScrollingFrame.form.isKindOf(SHP_VoyageAreaForm2) then
				shipForm := self.myScrollingFrame.form.SHP_VoyageAreaForm2;
				self.dragCursor := shipForm.chkDragSelect.dragCursor;
			elseif self.myScrollingFrame.form.isKindOf(SHP_BulkVoyagePlanningForm) then
				holdForm := self.myScrollingFrame.form.SHP_BulkVoyagePlanningForm;
				self.dragCursor := holdForm.chkAutoColorCode.dragCursor;
			endif;
			self.isDrawDeskTopRectangle := true;
	
			self.dragMode := DragMode_Drag;
			//self.dragCursor := shipForm.chkDragSelect.dragCursor;
		else
			app.isDragging := true;
//			tmpFrame := self.myScrollingFrame.getBayFrameFromXY(x,y);
			tmpFrame := self.myScrollingFrame.getBayFrameFromXY(self.origXPos, self.origYPos); // PAR 11832
			if tmpFrame = null then 
				return;
			endif;	
			frmX1 := x.Integer;
			frmY1 := y.Integer;
			self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
			tmpFrame.mouseMove(tmpFrame, button, shift, frmX1, frmY1);
		endif;

	else
		if self.myScrollingFrame.form.isKindOf(SHP_VoyageAreaForm2) then
			tmpFrame := self.myScrollingFrame.getBayFrameFromXY(x,y);
		elseif self.myScrollingFrame.form.isKindOf(SHP_VoyageAreaForm2) then
			holdFrame := self.myScrollingFrame.getHoldFrameFromXY(x,y);
		endif;
		if tmpFrame &lt;&gt; null then
			frmX1 := x.Integer;
			frmY1 := y.Integer;
			self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
			tmpFrame.mouseMove(tmpFrame, button, shift, frmX1, frmY1);
		endif;
		if holdFrame &lt;&gt; null then
			frmX1 := x.Integer;
			frmY1 := y.Integer;
			self.adjustFrameXYs(frmX1, frmY1, holdFrame);
			holdFrame.mouseMove(tmpFrame, button, shift, frmX1, frmY1);
		endif;
	endif;
	
	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="6eb1b44e-b1c1-4617-8931-ce9682b72a08">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 31/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
vars
	frmX1, frmX2, frmY1, frmY2 : Integer;
	shipForm : SHP_VoyageAreaForm2;
	bulkForm : SHP_BulkVoyagePlanningForm;						// PAR #36766
	cdc : SHP_BayDrawingController;
	//tmpFrame : SHP_BayDrawingFrame;							// PAR #36766
	tmpFrame : CMUI_GridAreaDrawingFrame;						// PAR #36766
	theLCs : CM_LCArray;
	theObj : Object;
begin
	


	if not self.isDrawDeskTopRectangle then
		tmpFrame := self.myScrollingFrame.getBayFrameFromXY(x,y);
		if tmpFrame = null then 
			return;
		endif;	
		frmX1 := x.Integer;
		frmY1 := y.Integer;
		self.adjustFrameXYs(frmX1, frmY1,tmpFrame);
		tmpFrame.mouseUp(tmpFrame, button, shift, frmX1, frmY1);
	endif;
	if self.myScrollingFrame.form.isKindOf(SHP_VoyageAreaForm2) then				// PAR #36766
		shipForm := self.myScrollingFrame.form.SHP_VoyageAreaForm2;
		cdc := shipForm.myBayDrawingController;
	elseif self.myScrollingFrame.form.isKindOf(SHP_BulkVoyagePlanningForm) then		// PAR #36766
		bulkForm := self.myScrollingFrame.form.SHP_BulkVoyagePlanningForm;			// PAR #36766
	endif;																			// PAR #36766

	self.isControllKey := false;
	self.lastMouseX := x.Integer;
	self.lastMouseY := y.Integer;
	self.clearGraphics;
	self.dragMode := DragMode_None;


	if self.isDrawDeskTopRectangle then
		self.myScrollingFrame.selectBlockOfObjectsFromXYs( CM_SlotController, self.origXPos.Integer,self.origYPos.Integer,self.lastMouseX, self.lastMouseY);

		if cdc &lt;&gt; null 
		and cdc.displayMode = ShpDisplayMode_ColCodeLoad
		and cdc.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan
		and app.myMoveController &lt;&gt; null
		and cdc.allSelectedObjects.size &gt; 1 then
			create theLCs transient;
			foreach theObj in cdc.allSelectedObjects do
				if theObj.isKindOf(CM_SlotController) then
					theLCs.add(theObj.CM_SlotController);
				endif;
			endforeach;
			app.myMoveController.updateAllToLocations(theLCs);
		endif;

	
		if shipForm  &lt;&gt; null then
			shipForm.SHP_VoyageAreaForm2.frmStatusLine.myFrameCaption.caption := null;
			shipForm.SHP_VoyageAreaForm2.frmStatusLine.myFrameCaption.caption := " Selected: " &amp; cdc.allSelectedObjects.size.asStringJMT;
		endif;
	endif;

	self.isDrawDeskTopRectangle := false;

	inheritMethod(frame, button, shift, x, y);
epilog
	delete theLCs;
	self.enableEvent("MouseMove",false);
	if bulkForm &lt;&gt; null then						// PAR #36766
		if bulkForm.picStern.visible then			// PAR #36766
			bulkForm.picStern.zOrder(1);			// PAR #36766
		else										// PAR #36766
			bulkForm.picBowRev.zOrder(1);			// PAR #36766
		endif;										// PAR #36766
	endif;											// PAR #36766
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f370c802-0438-4a75-830b-cbdaa985a05b">
        <updating/>
        <source>setForCreate() updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.name := "Overlay DRAG Frame";

	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.borderStyle := Frame.BorderStyle_None;
	
//	self.boundaryWidth := 3;
//	self.boundaryColor := Red;
//	self.backColor := Blue;
	
	self.caption := null;
	self.transparent := true;
	self.visible := true;
	self.lockBottom := true;
	self.lockRight := true;
	self.stretchHeight := true;
	self.stretchWidth := true;
	self.distanceFromBottom := 0;
	self.distanceFromRight := 0;

end;</source>
    </JadeMethod>
