    </JadeMethod>
    <JadeMethod name="doSlotTableContextMenu" id="85b09f92-698c-46aa-8b23-d3760e83d3be">
        <updating/>
        <source>doSlotTableContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Sep 2022	nvacs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuVbsAdvancedSearch, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="51605e3a-a876-4d2f-88eb-654d58b4840c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 Sep 2022		navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot

*/

vars
	rtnString	:	String;
begin
	rtnString := inheritMethod();
	rtnString := rtnString &amp; self.enquiryTypeDef_Slots;
	
	return rtnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
