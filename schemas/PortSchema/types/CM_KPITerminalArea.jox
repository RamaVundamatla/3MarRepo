    <JadeMethod name="isRoRoLane" id="7905a4b7-c44f-4123-92dd-964bf9a1f51e">
        <source>isRoRoLane() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars
	term		: CM_Terminal;
	termArea	: CM_TerminalArea;
begin
	
	term := self.myTerminal;
	
	if term = null then
		return false;
	endif;
	
	termArea := term.lookupTerminalArea(self.terminalAreaCode);
	
	return termArea &lt;&gt; null and termArea.isRoRoLaneArea();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pcCapacity" id="b43b7f44-2b73-4897-ae9c-e5e2f9e5935b">
        <methodInvocation>mapping</methodInvocation>
        <source>pcCapacity(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		// set code here
	else
		//08/09/2025	navkc1 JIRA 35622 
		if self.isRoRoLane() then
			_value := self.pcCapacityForRORO();
			return;
		endif;
		//22 Jun 2016	NDL	TFS 1752
		if self.maxTIs &lt;&gt; 0 then
			_value :=  ((self.totalTEUs / self.maxTIs) * 100);
		elseif self.capacityLength &lt;&gt; 0 then
			_value :=  ((self.totalLength / self.capacityLength) * 100);
		elseif self.capacityVolume &lt;&gt; 0 then
			_value :=  ((self.totalVolume / self.capacityVolume) * 100);
		elseif self.capacityWeight &lt;&gt; 0 then
			_value :=  ((self.totalWeight / self.capacityWeight) * 100);
		else
			_value := 0;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pcCapacityForRORO" id="0375e0c9-167a-4161-89c2-c7c13f9c3cf5">
        <source>pcCapacityForRORO() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars

begin
	return ((self.totalLength / self.capacityLength) * 100).roundedTo(2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="pcFull" id="282b3cf5-70c7-4b9a-8b41-9b69b0dfbd99">
        <methodInvocation>mapping</methodInvocation>
        <source>pcFull(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		// set code here
	else
		if self.isRoRoLane() then //05/09/2025	navkc1 JIRA 35622
			_value := self.pcFullForRORO().roundedTo(2);
			return;
		endif;
		if self.totLocations &lt;&gt; 0 then
			_value := ((self.totalLocnFull / self.totLocations) * 100).roundedTo(2);
		else
			_value := 0;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pcFullForRORO" id="626e07a6-6230-44d2-a50b-f34afe268bb0">
        <source>pcFullForRORO() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars

begin
	if self.capacityLength &lt;&gt; null then
		return ((self.totalLength / self.capacityLength) * 100).roundedTo(2);
	else
		return 0;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="pcMT" id="f7653a7c-3395-40b6-a3e1-fdcc1d9e13ff">
        <methodInvocation>mapping</methodInvocation>
        <source>pcMT(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		// set code here
	else
		if self.isRoRoLane() then  //05/09/2025	navkc1 JIRA 35622
			_value := self.pcMTForRORO().roundedTo(2);
			return;
		endif;
		
		if self.totLocations &lt;&gt; 0 then
			_value := ((self.totalLocnEmpty / self.totLocations) * 100).roundedTo(2);
		else
			_value := 0;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pcMTForRORO" id="be5d829e-1563-4dc9-b65b-15961039f7da">
        <source>pcMTForRORO() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars

begin
	if self.capacityLength &lt;&gt; null then
		return (((self.capacityLength - self.totalLength) / self.capacityLength) * 100).roundedTo(2);
	else
		return 0;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="pcOccupied" id="6bf61715-bf7d-432b-a52a-c162eee4ba5f">
        <methodInvocation>mapping</methodInvocation>
        <source>pcOccupied(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		// set code here
	else
		//08/09/2025	navkc1 JIRA 35622 
		if self.isRoRoLane() then
			_value := self.pcOccupiedForRORO();
			return;
		endif;
		if self.pcMT = 0 and pcFull = 0 then
			_value := 0;
		else
			_value := (100 - self.pcMT).roundedTo(2);
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pcOccupiedForRORO" id="7919ba2a-4b72-4c91-a9ad-b9def2a1d252">
        <source>pcOccupiedForRORO() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars

begin
	return (100 - self.pcMTForRORO()).roundedTo(2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fdbdb346-7629-47b8-9297-c5a2f2b1dbb2">
        <updating/>
        <source>setForCreate(_pxyMe : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_pxyMe);
	
	self.maxStackHeight := _pxyMe.maxStackHeight;
	self.maxTIs := _pxyMe.maxTIs;
	//self.terminalAreaCode := _pxyMe.terminalAreaCode;
	self.setTerminalAreaCode( _pxyMe.terminalAreaCode );
	self.totLocations := _pxyMe.totLocations;
	self.totalLocnEmpty := _pxyMe.totalLocnEmpty;
	self.totalLocnFull := _pxyMe.totalLocnFull;
	self.totalLocnOccupied := _pxyMe.totalLocnOccupied;
	self.totalTEUs := _pxyMe.totalTEUs;
	self.totalTIs := _pxyMe.totalTIs;
	
	//22 Jun 2016	NDL	TFS 1752
	self.capacityLength := _pxyMe.capacityLength;
	self.capacityVolume := _pxyMe.capacityVolume;
	self.capacityWeight := _pxyMe.capacityWeight;
	self.totalLength := _pxyMe.totalLength;
	self.totalQuantity := _pxyMe.totalQuantity;
	self.totalVolume := _pxyMe.totalVolume;
	self.totalWeight := _pxyMe.totalWeight;

	_pxyMe.allQryCargoTypes.copy(self.allQryCargoTypes);
	_pxyMe.allQryContents.copy(self.allQryContents);
	_pxyMe.allQryIMEX.copy(self.allQryIMEX);
	_pxyMe.allQryISOGroups.copy(self.allQryISOGroups);
	_pxyMe.allQryOperator.copy(self.allQryOperator);
	_pxyMe.allQryPorts.copy(self.allQryPorts);
	_pxyMe.allQryVoyages.copy(self.allQryVoyages);
	_pxyMe.availStackHeights.copy(self.availStackHeights);
end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setTerminalAreaCode" id="a1fa1904-683b-4158-9b5b-08fa5cc81dae">
        <updating/>
        <source>setTerminalAreaCode( _terminalAreaCode : String ) updating;
/*

Purpose:			

