    <JadeMethod name="getTempString" id="521c184b-5579-4e39-bbbc-acf3ea02b9f8">
        <source>getTempString(_fahrenheit : Boolean) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if temperature &lt;&gt; NULL_TEMPERATURE then
		return app.getTemperatureDisplay(temperature, false, _fahrenheit);
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_fahrenheit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVentilationAsString" id="ceb0f15f-52ae-466c-97eb-5d656271a294">
        <source>getVentilationAsString() : String;
/*
Date		Who		Reason
27 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if self.ventilation &lt;&gt; NULL_VENTILATION then
	   return self.ventilation.asStringJMT;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVentilationUnitDesc" id="2efbe7e3-593f-49c3-9bac-8a61b620be0a">
        <source>getVentilationUnitDesc() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if self.ventilationUnits = Metres3perHour then
		return Metres3perHourDesc.asStringJMT;
	elseif self.ventilationUnits = Feet3perHour then
		return Feet3perHourDesc.asStringJMT;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
