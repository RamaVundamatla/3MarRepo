    <JadeMethod name="setupForm" id="799528bf-978f-44f2-a03c-9fcf8568e394">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			Perform any form initialisation (set caption, load combo boxes, etc)

Parameters:			None

Return Value:		None

Date		Who		Reason
22/0/72009	cnwdap1	Initial creation
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
17/04/2023  navmk20	Bug 57311: MTN - Contract Screens Not Saving Columns
*/
vars

begin
	inheritMethod();
	
	//self.centreOverParent(20); // 17.4.2023 navmk20 TFS 57311
	self.alignButtons();
	
	self.setupMeasurementControls();					// PAR #31155
	
	// override captions on base form buttons so hot-keys work at this level
	self.btnSaveBase.caption := "Save";
	self.btnCancelBase.caption := "Cancel";
epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="69b191a6-63f5-404a-b090-cb15aaba3911">
        <source>setupMeasurementControls();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
