Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation

*/

vars

	bookingIdGen : CM_AutoReleaseIdGen;

begin

	bookingIdGen := self.getMyAutoIdGenerator( CM_AutoReleaseIdGen ).CM_AutoReleaseIdGen;
