    <JadeMethod name="getDebtorForInvoiceLine" id="86e77c58-8bd5-457b-94b9-55f38ae78496">
        <source>getDebtorForInvoiceLine(_invLineDesc : CM_InvoiceLineDesc) : CM_Debtor;
/*
Purpose:	TFS 42221	This sub class derives the debtor from the cargo work order request, where possible.	
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
05/06/2019			jlgdap1		TFS 44554 AAT Stevedore Data Access
04 Nov 2020			cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
01.06.2022 			navak20		ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	doLog					: Boolean;
	debtor					: CM_Debtor;
	chargeableBusinessUnit  : CM_Bank;
	tmpCode,
	lMessageText			: String;
	tmpConsigneeOr			: CM_ConsigneeConsignor;
	tmpVoyage				: CM_Voyage;
	tranOperator, 
	tmpOperator				: CM_Operator;
	tmpCA 					: CM_CustomsAgent;
	tmpCarrier				: CM_Carrier;
	myDebtorTypeCode 		: String;
	deriveDebtorTypeFrom	: CM_DebtorType;
	debtorType 				: CM_DebtorType;
	tmpPoolParty 			: CM_MTPoolingParty;						
	opTerm 					: CM_OperatorTerminal;							
	cargoReq 				: CM_WodCargoRequest;
	tmpStevedore 			: CM_Stevedore;					// TFS 44554
	tmpShipLine				: CM_ShippingLine;				// TFS 53195
begin
	
	doLog    := app.canLogExtraDetail(); 					//28.02.2025 navah1	#34141
	cargoReq := self.myWorkOrderDetailVoyage;
	
	if cargoReq = null then
		return null;
	endif;
	
	tmpCode := cargoReq.getOperatorCode();
	if tmpCode &lt;&gt; null then
		tranOperator := app.myRoot.allOperators[tmpCode];
	endif;
	
	deriveDebtorTypeFrom := _invLineDesc.myDebtorType;
	if deriveDebtorTypeFrom &lt;&gt; null then
		myDebtorTypeCode := deriveDebtorTypeFrom.code;
	
		if myDebtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
			lMessageText := "Debtor for Cargo Operator Charge";
			tmpCode := cargoReq.getOperatorCode();
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					debtor := tmpOperator.debtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			lMessageText := "Debtor for Consignee Charge";
			tmpCode := cargoReq.getConsigneeCode();
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtor := tmpConsigneeOr.debtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			lMessageText := "Debtor for Consignor Charge";
			tmpCode := cargoReq.getConsignorCode();
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtor := tmpConsigneeOr.debtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			lMessageText := "Debtor for Ship Operator Charge";
			tmpVoyage := cargoReq.getMyVoyageObject();
			if tmpVoyage &lt;&gt; null then 
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then 
					debtor := tmpOperator.debtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_BUSINESS_UNIT then
			lMessageText := "Debtor for Business Unit Charge";
			chargeableBusinessUnit := self.getChargeableBusinessUnit; // Get BU from transaction BU is not on cargo request
			if chargeableBusinessUnit &lt;&gt; null then
				debtor := chargeableBusinessUnit.businessUnitDebtor;
				if doLog and debtor &lt;&gt; null then
					app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
			lMessageText := "Debtor for Freight Forwarder Charge";
			tmpCode := cargoReq.getFreightForwarderCode();
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtor := tmpConsigneeOr.debtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_CUSTOMS_AGENT then
			lMessageText := "Debtor for Customs Agent Charge";
			tmpCode := self.customsAgentCode; // Get customs agent from transaction customs agent is not on cargo request
			if tmpCode &lt;&gt; null then
				tmpCA := app.myRoot.allCustomsAgents[tmpCode];
				if tmpCA &lt;&gt; null then
					debtor := tmpCA.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
			// 24094 add carrier
		elseif myDebtorTypeCode = CM_DebtorType.DT_CARRIER then
			lMessageText := "Debtor for Carrier Charge";
			if self.myTrackedItem &lt;&gt; null then
				tmpCode := self.myTrackedItem.carrier; // Get carrier from transaction carrier is not on cargo request
				if tmpCode &lt;&gt; null then
					tmpCarrier := app.myRoot.allCarriers[tmpCode];
					if tmpCarrier &lt;&gt; null then
						debtor := tmpCarrier.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY then						
			lMessageText := "Debtor for Empty Pool Party";										
			if self.myTrackedItem &lt;&gt; null then											
				tmpCode := self.myTrackedItem.myPoolingPartyCode;	 // Get pool party from transaction pool party is not on cargo request					
				if tmpCode &lt;&gt; null then															
					tmpPoolParty := self.myTrackedItem.myTerminal.allMTPoolingParties[tmpCode];	
					if tmpPoolParty &lt;&gt; null then												
						tmpCode := self.myTrackedItem.operatorCode;						
						foreach opTerm in tmpPoolParty.allOperatorTerminals do					
							if opTerm.myTerminal &lt;&gt; self.myTrackedItem.myTerminal or opTerm.myOperator.code &lt;&gt; tmpCode then	
								continue;														
							endif;																
							if opTerm.myOperator.debtor &lt;&gt; null then							
								if not opTerm.myOperator.debtor.isRDT then						
									debtor := opTerm.myOperator.debtor;							
								endif;															
							endif;																
						endforeach;																
					endif;																		
				endif;																			
			endif;																				
			if debtor = null then																
				debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_EMPTY_POOL_PARTY];		
				debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);			
			endif;																				
		
		// TFS 44554 Stevedore
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_VOYAGE then
			lMessageText := "Debtor for Stevedore for Voyage Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					debtor := tmpStevedore.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
		// TFS 44554 end
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then  //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Receive Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					debtor := tmpStevedore.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then   //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Release Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					debtor := tmpStevedore.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
			
		// 01.06.2022 navak20 TFS 53195 Start
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE then 
			lMessageText := "Debtor for Shipping Line";
			tmpCode := self.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					debtor := tmpShipLine.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
		
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then  
			lMessageText := "Debtor for Shipping Line Description";
			tmpCode := self.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					debtor := tmpShipLine.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				endif;
			endif;
		// TFS 53195 End
		else
			debtorType := deriveDebtorTypeFrom;
			
			//User defined debtor type
			lMessageText := "Debtor for" &amp; debtorType.description;
			debtor := self.allDebtorsByType[myDebtorTypeCode];
			if debtor = null then
				debtor := debtorType.myDefaultDebtor;	
			endif;
		endif;
	
	endif;
	
	if debtor &lt;&gt; null then
		if debtor.isSuspended then
			if doLog and debtor &lt;&gt; null then
				app.invLog(debtor.name &amp; " is suspended, not used", LogTRACE.String);
			endif;
			debtor := null;
		endif;
	endif;
	
	if debtor = null then	
		debtor := _invLineDesc.getDefaultDebtorFromTran(doLog,self);
	endif;

	return debtor;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a8cb8813-d419-4228-bc54-f64a55b41468">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars
	lDetail : String;
	invalidWO : Boolean;
	workOrder	: CM_WorkOrder;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
			
			if self.myWorkOrderDetailVoyage &lt;&gt; null then
				workOrder := self.myWorkOrderDetailVoyage.getMyParent();
			endif;
			
			if workOrder &lt;&gt; null then
				lDetail := workOrder.id &amp; " - " &amp; workOrder.getDisplayString(); 
			endif;
			return lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="281fc5bc-9034-4680-bb67-23483aeebcf4">
        <source>getEnquiryRow(): String;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars
	lDetail 	: String;
	lInvalidBR 	: Boolean;
	lReturn		: String;
	str 		: String;
	invalidWO	: Boolean;
	workOrder	: CM_WorkOrder;
begin

	on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 


	lDetail := inheritMethod();
	
	if self.myWorkOrderDetailVoyage &lt;&gt; null then
		workOrder := self.myWorkOrderDetailVoyage.myParent;
	endif;
	
	if workOrder &lt;&gt; null then
		str := "Assigned to " &amp; workOrder.id;
	endif;
	
	return lDetail &amp; str;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceQuantityForWOExtra" id="964d9b9e-4fc4-4fec-98b7-12a8e5f4d28d">
        <source>getInvoiceQuantityForWOExtra(_blockUnit: Integer): Decimal;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars

begin

	if self.myWorkOrderDetailVoyage = null then
		return inheritMethod(_blockUnit);
	endif;
	
	return self.myWorkOrderDetailVoyage.getInvoiceQuantityForWOExtra(_blockUnit);

epilog

end;</source>
        <Parameter name="_blockUnit" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceWOPermitType" id="96943606-202b-47db-b492-6dd9e6ed6461">
        <source>getInvoiceWOPermitType(): Integer;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars

begin
	if self.myWorkOrderDetailVoyage = null then
		return inheritMethod();
	endif;
	
	return self.myWorkOrderDetailVoyage.getPermitType();

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTransferType" id="5d51a651-af8e-49c8-83f9-c3787dd66176">
        <source>getTransferType() : Integer;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars

begin

	if self.myWorkOrderDetailVoyage = null then
		return VESSEL_TYPE_RORO;
	endif;
	
	return self.myWorkOrderDetailVoyage.transferType;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="fef5e229-f7e3-43ca-9bfe-2105e3186a60">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_WorkOrderTransController; _passport: CM_Passport input) updating;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/


vars

begin
	// TFS 42221 myWorkOrderDetailVoyage is not used.
	// TFS 42221 IAN Said that we should always use the amounts on the cargo request, then he changed his mind
	// TFS 42221 have added a many to 1 inverse, rather than one to one.
	self.myWorkOrderDetailVoyage := _tiTransCntrl.myWorkOrderDetail.CM_WodCargoRequest;
	
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_WorkOrderTransController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
