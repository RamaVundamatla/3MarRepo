    <JadeMethod name="saveVersionCopyRefs" id="8d8d977c-5cd8-46f8-a8f1-492eaf76e1a4">
        <source>saveVersionCopyRefs(toClone: CM_Unpack input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
