    <JadeMethod name="doShowHideAreas" id="6b7a4ec8-4973-43a9-9750-26dfab994c24">
        <updating/>
        <source>doShowHideAreas(_areas : IntegerArray; _values : BooleanArray) updating;
/*
Date		Who		Reason
26 September 2006	cnwer1	Initial creation - PAR#xxxx
*/
vars
	area,i : Integer;
begin
	i:=1;
	foreach area in _areas do
		self.showHideArea(area,_values[i]);		
		i:=i+1;
	endforeach;
	self.resizeWidths();
epilog

end;</source>
