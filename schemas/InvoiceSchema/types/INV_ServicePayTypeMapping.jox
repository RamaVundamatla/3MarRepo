    <JadeMethod name="doPrint" id="76233a4f-4977-4590-8274-665aef582958">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	mess, head : String;

begin

	self.doTblDataPrint(mess,head,self.caption);

end;</source>
