    <JadeMethod name="preProcessRequest" id="8876a118-26b6-434a-b6cf-67bd2e09b620">
        <updating/>
        <source>preProcessRequest() updating, protected;
/*

Purpose:			Modify the incomingMessage to ensure JADE Web Service framework can correctly parse it
					
Parameters:			None

Return Value:		None

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	methodName		: String;
	
begin
	inheritMethod();
	
	self.createPreProcessActivity();
	// What web service is being called?
	methodName := self.getMethodName();
	
	if methodName = JMTExternalInterfaceService::entryRKBM.name then
		self.preProcessEntryRKBM();
	elseif methodName = JMTExternalInterfaceService::entryPPK.name then
		self.preProcessEntryPPK();
	elseif methodName = JMTExternalInterfaceService::entrySPB.name then
		self.preProcessEntrySPB();
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeWebServicesMethod name="updateCustomerSAP" id="76cd1416-ea16-4a54-aad5-abdbb4711fdc">
        <source>updateCustomerSAP(request : WS_UpdateCustomerRequest) : WS_SAPResponse webService;

/*

Purpose:			
	Request from SAP to update a Customer's Details in JMT
	WSDL 2.3 - Customer Master

Parameters:

Return Value:		


Date		Who		Reason
03/05/2018	jlgkpd1	TFS - Pelindo 1 SAP Integration
17/07/2018	jlgdap1	TFS 38640 PEL1 SAP Receive Csustomer Master Data
08/08/2018	jlgdap1	TFS 40092 PEL1 Adding Changes to Debtors
*/

vars
	response		: WS_SAPResponse;
	completedOK		: Boolean;
	permission 		: Integer;
	customerDetail	: WS_CustomerDetail;
	debtor,
	pxyDebtor		: CM_Debtor;
	cmifDebtorNode	: CMIF_DebtorNode;
	name,
	address,
	remarks			: String;
	debtorNode ,
	proxyDebtorNode	: CM_DebtorNode;
	theBank 		: CM_Bank;
	rdg	 			: CM_RootDebtorGroup;
	msg 			: String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Initialise the passport for the new transaction
	self.initialisePassportExternal();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check there is a request created (will be null if the input message is invalid)
	if request = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	else
		// Validate the credentials passed in the request
		permission := PmWebUpdateCustomerSAP;
		request.validateCredentials( permission );
		
		// Populate known response attributes from the request
		response.populateFromRequest(request);
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	// is the user specified in the message allowed to maintain debtors?
	app.checkCurrentUserHasAccess(PmAdmDebtorregisterMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// check we can find a customer (debtor) using the customerData::customerID
	customerDetail := request.customerData;
	if customerDetail = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	endif;
	
	if customerDetail &lt;&gt; null then
		if customerDetail.action.toUpper = "CHANGE" then  //Update  //08.8.2018 cnwma1 TFS #340092
			debtor := app.myRoot.myRootCompany.allDebtorsByCode[customerDetail.customerCode];
			if debtor = null then
				app.raiseCMException3(Value_field_not_resolve, customerDetail.customerCode, WS_CustomerDetail::customerCode.name, app.getErrorString(Debtor_GC), null, null);
			endif;
		endif;
	endif;
	
	create cmifDebtorNode transient;
	cmifDebtorNode.code     := customerDetail.customerCode[1:100];
	cmifDebtorNode.name 	:= customerDetail.customerName1[1:100];			// TFS 40092
	cmifDebtorNode.longName := customerDetail.customerName2[1:100];
	
	if debtor &lt;&gt; null then
		pxyDebtor := app.createUpdateProxy(debtor).CM_Debtor;
		cmifDebtorNode.setFromDebtor(debtor);
		cmifDebtorNode.myPxyDebtorNode := pxyDebtor;
		cmifDebtorNode.name := customerDetail.customerName1[1:100];
		cmifDebtorNode.code := customerDetail.customerCode[1:100];
		pxyDebtor.setProxy(customerDetail.customerName1[1:100], customerDetail.customerCode[1:100]);	// TFS 40092
	else
		theBank := app.myRoot.myRootCompany;    //08.8.2018 cnwma1 TFS #340092
		rdg := theBank.getRootDebtorGroup();    //08.8.2018 cnwma1 TFS #340092
		create proxyDebtorNode as CM_Debtor transient;
		cmifDebtorNode.myPxyDebtorNode := proxyDebtorNode;
		cmifDebtorNode.myParentDebtorNode := rdg;
		proxyDebtorNode.setProxy(customerDetail.customerName1[1:100], customerDetail.customerCode[1:100]);
	endif;
	

	
	address := customerDetail.address1;
	if address &lt;&gt; null and customerDetail.address2 &lt;&gt; null then
		address := address &amp; CrLf &amp; customerDetail.address2;
	endif;
	if address &lt;&gt; null and customerDetail.address3 &lt;&gt; null then
		address := address &amp; CrLf &amp; customerDetail.address3;
	endif;
	if address &lt;&gt; null and customerDetail.city &lt;&gt; null then
		address := address &amp; CrLf &amp; customerDetail.city;
	endif;
	if address &lt;&gt; null and customerDetail.postCode &lt;&gt; null then
		address := address &amp; CrLf &amp; customerDetail.postCode;
	endif;
	cmifDebtorNode.billingAddress := address;
	
	if customerDetail.contactPerson &lt;&gt; null then
		remarks :='Contact Person: ' &amp; customerDetail.contactPerson  ;
	endif;
	if customerDetail.phoneNumberCP &lt;&gt; null then
		remarks := remarks &amp; CrLf &amp;'Contact Person Phone: ' &amp; customerDetail.phoneNumberCP  ;
	endif;
	if customerDetail.telephone1 &lt;&gt; null then
		remarks := remarks &amp; CrLf &amp;'Telephone1: ' &amp; customerDetail.telephone1  ;
	endif;
	
	if customerDetail.telephone2 &lt;&gt; null then
		remarks := remarks &amp; CrLf &amp;'Telephone2: ' &amp; customerDetail.telephone2  ;
	endif;
	
	if customerDetail.fax1 &lt;&gt; null then
		remarks := remarks &amp; CrLf &amp;'Fax: ' &amp; customerDetail.fax1  ;
	endif;
	
	if customerDetail.emailAddress1 &lt;&gt; null then
		remarks := remarks &amp; CrLf &amp;'Email1: ' &amp; customerDetail.emailAddress1  ;
	endif;
	
	if customerDetail.emailAddress2 &lt;&gt; null then
		remarks := remarks &amp; CrLf &amp;'Email2 :' &amp; customerDetail.emailAddress2  ;
	endif;

	
	if remarks &lt;&gt; null then
		cmifDebtorNode.remarks	 := remarks;
	endif;

	
	if customerDetail.npwp &lt;&gt; null then
		cmifDebtorNode.additionalInformation1 := customerDetail.npwp;
	endif;
	
	if customerDetail.nppkp &lt;&gt; null then
		cmifDebtorNode.additionalInformation2 := customerDetail.nppkp;
	endif;
	if customerDetail.active &lt;&gt; null then
		cmifDebtorNode.isSuspended := not customerDetail.active.asBooleanJMT;
	endif;
	
	if debtor &lt;&gt; null then
		app.myTrxUA.trxUpdateDebtorNode(cmifDebtorNode, app.myPassport);
	else
		app.myTrxCA.trxCreateDebtorNode(cmifDebtorNode,debtorNode,app.myPassport);
	endif;

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		msg :=  method.qualifiedName &amp; 
				' ' &amp; "SAP"        									   &amp;
				' ' &amp; "WSDL : "    &amp; BGP_SAPWSRequest.WSDL23 		   &amp;
				' ' &amp; "Customer Code :"  &amp; customerDetail.customerCode        &amp;
				' ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString;
		app.writeLog(msg,LogINFO);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	cmifDebtorNode.allDebtorTerminalDetails.purge; // ### TFS 52237 27OCT2021 NAVAB1
	delete cmifDebtorNode;
	delete pxyDebtor;
	delete proxyDebtorNode;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_UpdateCustomerRequest"/>
        <ReturnType type="WS_SAPResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updateInvoiceSAP" id="0038f7b1-59e3-454c-b157-aea880f4e204">
        <source>updateInvoiceSAP(request : WS_UpdateInvoiceRequest) : WS_SAPResponse webService;

/*

Purpose:			
	SAP request to change the status of an invoice for a Post Pay or AutoCollection debtor from OPEN to PENDING
	WSDL 2.2: Post-Billing - Update Invoice Status (Paid)
	PaymentType_PostPay
Parameters:

Return Value:		


Date		Who		Reason
03/05/2018	jlgkpd1	TFS - Pelindo 1 SAP Integration
04/07/2018	jlgdap1	TFS 38639 PEL1 SAP Receive Paid Status
27/07/2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
02/10/2018  cnwma1	Bug 41186: PEL1 - SAP Integration - Unit Test issues
05/11/2018  cnwma1  ChangeRequest 41765: PEL1 - SAP Invoice Auto Posting (Auto-collection and Post-pay)
23/01/2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/

vars
	response		: WS_SAPResponse;
	completedOK		: Boolean;
	permission 		: Integer;
	invoice,
	pxyInvoice		: CM_Invoice;
	invoices 		: CM_InvoiceBySeqNumDict;
	statuses		: CMIF_Array;
	cmifStatus 		: CMIF_InvoiceStatus;
	msg				: String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Initialise the passport for the new transaction
	self.initialisePassportExternal();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check there is a request created (will be null if the input message is invalid)
	if request = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	else
		// Validate the credentials passed in the request
		permission := PmWebUpdateInvoiceSAP;
		request.validateCredentials( permission );
		
		// Populate known response attributes from the request
		response.populateFromRequest(request);
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	// Perform validation - must be able to find an invoice
	invoice := request.getInvoice(app.myPassport.myTerminal, request.invoiceID);
	if invoice = null then
		app.raiseCMException3(Value_field_not_resolve, request.invoiceID, WS_UpdateInvoiceRequest::invoiceID.name, 
							app.getErrorString(Invoice), null, null);
	endif;
	
	// invoice must be for a post-paid or auto-collection debtor
	if invoice &lt;&gt; null then
		if invoice.paymentType &lt;&gt; PaymentType_PostPay then 
			app.raiseCMException3(Debtor_invoice_not_debtor, invoice.debtor.decfinName, invoice.exportCurrencyCode.String, 
			app.getErrorString(PaymentType_PostPayStr), null, null);
			invoice := null;
		endif;
	endif;
	
	if invoice &lt;&gt; null and invoice.status &lt;&gt; CM_Invoice.INVOICE_PENDING then
		app.raiseCMException3(Invoice_status_should, invoice.exportCurrencyCode.String, app.getInvoiceStatusString(invoice.getMyInvoiceProcess, invoice.status), // TFS 39618
		app.getErrorString(Pending), null, null);
		invoice := null;
	endif;
	if invoice &lt;&gt; null then
		// TFS 39618 PATCH 1 app.checkCurrentUserHasAccess(PmAdmInvListStatusClose);
		if invoice.bank &lt;&gt; null then
			invoice.bank.checkCurrentUserHasAccess(CM_Invoice.INVOICE_POSTED);
			if app.myPassport.hasErrors then
				invoice := null;
			endif;
		endif;
	endif;
	
	if invoice &lt;&gt; null then
		
		pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
		if pxyInvoice.paymentStatus &lt;&gt; CM_Invoice.INVOICE_PAYMENT_PAID then
			app.myTrxUA.trxUpdateInvoicePaymentStatus(pxyInvoice,CM_Invoice.INVOICE_PAYMENT_PAID,app.myPassport);
		endif;
		
		if app.myPassport.noErrors then  //04.10.2018 cnwma1 41186
			invoice.updateCashRecSAP(CM_CashReceipt.PAID,BGP_SAPWSRequest.WSDL22);
		endif;
		
		/*	
		05.11.2018 cnwma1 TFS #41765
		41628.020 
		Post-pay Invoice Auto Posting
		c.	Once Paid, JMT automatically changes the Status of the Invoice from "Pending" to "Posted". 
		*/
		if app.myPassport.noErrors then 
			if invoice.status = CM_Invoice.INVOICE_PENDING then
				if pxyInvoice &lt;&gt; null then
					delete pxyInvoice;
				endif;
				
				pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
				
				create statuses transient;
				create cmifStatus transient;
				cmifStatus.myInvoice := pxyInvoice;
				cmifStatus.newStatus := CM_Invoice.INVOICE_POSTED;
				statuses.add(cmifStatus);
				
				msg :=  method.qualifiedName  &amp; 
						' ' &amp; "SAP"        								    &amp;
						' ' &amp; "WSDL : "    &amp; BGP_SAPWSRequest.WSDL22        &amp;
						' ' &amp; "Update Invoice status : Posted"              &amp;
						' ' &amp; "Invoice :"  &amp; invoice.exportCurrencyCode;
				app.writeLog(msg,LogINFO);
				
				app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
				
				if app.myPassport.hasErrors then
					msg :=  method.qualifiedName &amp; 
							' ' &amp; "SAP"        									   &amp;
							' ' &amp; "WSDL : "    &amp; BGP_SAPWSRequest.WSDL22 		   &amp;
							' ' &amp; "Invoice :"  &amp; invoice.exportCurrencyCode        &amp;
							' ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString;
					app.writeLog(msg,LogINFO);
				endif;
			endif;
		endif;
		//05.11.2018 cnwma1 TFS #41765
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete pxyInvoice;
	delete cmifStatus;
	delete statuses;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;
</source>
        <Parameter name="request" type="WS_UpdateInvoiceRequest"/>
        <ReturnType type="WS_SAPResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="updatePreInvoiceSAP" id="4f5d69fe-c370-4ac7-84fa-d93ecf2db0d0">
        <source>updatePreInvoiceSAP(request : WS_UpdatePreInvoiceRequest) : WS_SAPResponse webService;

/*

Purpose:			
	SAP request to change the status of an invoice for a PrePay debtor from PREPEND to PENDING
	WSDL 2.1 Pre-Billing: Update Pre-Invoice Status (Paid)
	PaymentType_PrePay
Parameters:

Return Value:		


Date		Who		Reason
03/05/2018	jlgkpd1	TFS - Pelindo 1 SAP Integration
03/07/2018	jlgdap1	TFS 38639 PEL1 SAP Receive Paid Status
27/07/2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
22/11/2018	cnwma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date
23/01/2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
29/01/2019  cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues
*/

vars
	response		: WS_SAPResponse;
	completedOK		: Boolean;
	permission 		: Integer;
	invoice,
	pxyInvoice		: CM_Invoice;
	statuses		: CMIF_Array;
	cmifStatus 		: CMIF_InvoiceStatus;
	msg             : String;
	wo : CM_WorkOrder;	//14 Mar 2019	NDL	TFS 43405
	woExt : CM_WodReleaseExtension;	//14 Mar 2019	NDL	TFS 43405 
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Initialise the passport for the new transaction
	self.initialisePassportExternal();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check there is a request created (will be null if the input message is invalid)
	if request = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	else
		// Validate the credentials passed in the request
		permission := PmWebPreInvoiceSAP;
		request.validateCredentials( permission );
		
		// Populate known response attributes from the request
		response.populateFromRequest(request);
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	// Perform validation - must be able to find an invoice
	invoice := request.getInvoice(app.myPassport.myTerminal, request.preInvoiceID);
	if invoice = null then
		app.raiseCMException3(Value_field_not_resolve, request.preInvoiceID, WS_UpdatePreInvoiceRequest::preInvoiceID.name, app.getErrorString(Invoice), null, null);
	endif;
	
	// invoice must be for a pre-paid debtor
	if invoice &lt;&gt; null then
		if invoice.paymentType &lt;&gt; PaymentType_PrePay then
			//app.raiseCMException3(Debtor_invoice_not_debtor, invoice.debtor.decfinName, invoice.externalFinancialId.String, 
			app.raiseCMException3(Debtor_invoice_not_debtor, invoice.debtor.decfinName, invoice.getExternalFinancialId(), //08/12/2025	navkc1 JIRA 36262
			app.getErrorString(PaymentType_PrePayStr), null, null);
			invoice := null;
		endif;
	endif;
	
	// Check the invoice is at status PREPEND, and the user is allowed to change to status PENDING
	if invoice &lt;&gt; null and invoice.status &lt;&gt; CM_Invoice.INVOICE_PREPEND then 
		app.raiseCMException3(Invoice_status_should, invoice.exportCurrencyCode.String, app.getInvoiceStatusString(invoice.getMyInvoiceProcess, invoice.status),
		app.getInvoiceStatusString(invoice.getMyInvoiceProcess, CM_Invoice.INVOICE_PREPEND), null, null);
		invoice := null;
	endif;
	if invoice &lt;&gt; null then
		// TFS 39618 PATCH 1  app.checkCurrentUserHasAccess(PmAdmInvListStatusClose);
		if invoice.bank &lt;&gt; null then
			invoice.bank.checkCurrentUserHasAccess(CM_Invoice.INVOICE_PENDING);
			if app.myPassport.hasErrors then
				invoice := null;
			endif;
		endif;
		if app.myPassport.hasErrors then
			invoice := null;
		endif;
	endif;
	
	// Got a valid invoice at the right status for a valid debtor who is a prepay debtor
	// Move the invoice to pending (the trx will validate whether the invoice is in the correct status)
	if invoice &lt;&gt; null then
		/*
		22.8.2018 cnwma1 TFS #39698
		WSDL 2.1 Pre-Billing: Update Pre-Invoice Status (Paid)
		*/
		
		if not invoice.isPaymentPaid then
			
			pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
			app.myTrxUA.trxUpdateInvoicePaymentStatus(pxyInvoice,CM_Invoice.INVOICE_PAYMENT_PAID,app.myPassport);
			
			if app.myPassport.noErrors then  	 					//23.01.2019 cnwma1 TFS #42942
				invoice.updateCashRecSAP(CM_CashReceipt.PAID,BGP_SAPWSRequest.WSDL21);
			endif;
			
			//14 Mar 2019	NDL	TFS 43405
			if app.myPassport.noErrors then
				wo := invoice.myWorkOrder;	
				if wo &lt;&gt; null and wo.isWorkOrderForReleaseExtension then
					woExt := wo.allWoDtls.first.CM_WodReleaseExtension;
					if woExt &lt;&gt; null then
						app.myTrxUA.trxUpdateDoWORelExtForSap( woExt, app.myPassport );
					endif;
				endif;
			endif;

			if app.myPassport.noErrors then
				/*
				22.11.2018 cnwma1 TFS #42118
				41877.030 Tax number and Invoice Date generation for Pre-pay Invoice
				*/
				if pxyInvoice &lt;&gt; null then
					delete pxyInvoice;
				endif;
				invoice.generateTax();
			endif;
			
			/*
			23.01.2019 cnwma1 TFS #42942
			b. Change the Invoice Status from Prepend to Pending
			*/
			if pxyInvoice &lt;&gt; null then
				delete pxyInvoice;
			endif;
			pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
			create statuses transient;
			create cmifStatus transient;
			cmifStatus.myInvoice := pxyInvoice;
			cmifStatus.newStatus := CM_Invoice.INVOICE_PENDING;
			statuses.add(cmifStatus);
			
			msg :=  method.qualifiedName  &amp; 
					' ' &amp;  BGP_SAPWSRequest.WSDL21    			    &amp;
					' ' &amp; "Update Invoice status : Pending"         &amp;
					' ' &amp; "Invoice :"  &amp; invoice.exportCurrencyCode ;
			app.writeLog(msg,LogINFO);
					
			app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
			
			if app.myPassport.hasErrors then
				msg :=  method.qualifiedName &amp; 
						' ' &amp; BGP_SAPWSRequest.WSDL21 		   				   &amp;
						' ' &amp; "Invoice :"  &amp; invoice.exportCurrencyCode        &amp;
						' ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString;
				app.writeLog(msg,LogINFO);
			endif;	
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	delete cmifStatus;
	delete pxyInvoice;
	delete statuses;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_UpdatePreInvoiceRequest"/>
        <ReturnType type="WS_SAPResponse"/>
    </JadeWebServicesMethod>
</JadeWebServiceProviderClass>
