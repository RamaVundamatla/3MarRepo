<Class name="CnEcHtmlUnorderedListTag" id="cd7339de-f49d-43af-bc6b-4570d6899fae">
    <superclass name="CnEcHtmlListTag"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
