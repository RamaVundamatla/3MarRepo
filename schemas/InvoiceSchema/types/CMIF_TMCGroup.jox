    <JadeMethod name="exportCargoCSV" id="32287455-242e-4ba8-b2ff-0b307918d640">
        <updating/>
        <source>exportCargoCSV(_file : File input; _line : String) updating;
// ---------------------------------------------------------------------------
// Created:		October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//	33095 put quotes around each field in case it contains commas
// ---------------------------------------------------------------------------

vars
	tranMap : CM_TranMap;
	tmctig : CMIF_TranMapController;
	tmpString : String;
begin
	self.setControllerCurrent();	// 23659

	tmpString := _line;
	if tmpString &lt;&gt; null then
		// from 23659 don't write a resource mapping as a column as it gets out of step with the others
		if self.isKindOf(CMIF_TMCTaskResourceTypeHeader) then
			// 23659 wait for the child to write the item
		elseif self.myGroup.isKindOf(CMIF_TMCTaskResourceTypeHeader) then
			tmpString := tmpString &amp; "," &amp; (self.myGroup.extractName &amp; ":" &amp; self.extractName).csvEncode();
		else
			tmpString := tmpString &amp; "," &amp; self.extractName.csvEncode();
		endif;
	else
		tmpString := self.myGroup.extractName.csvEncode() &amp; "," &amp; self.extractName.csvEncode();
	endif;

	foreach tmctig in self.allGroupMembers do
		tmctig.exportCargoCSV(_file, tmpString);
	endforeach;


	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
