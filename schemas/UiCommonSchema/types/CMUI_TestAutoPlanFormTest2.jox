    <JadeMethod name="mnuPlanItems_click" id="703bd3dd-5971-48dd-a523-553c78886b2c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPlanItems_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	table : CM_DataTable;
	obj : Object;
	testResults : CM_TestAutoPlanResultSet;
	testResult : CM_TestAutoPlanResult;
	ti : CM_TrackedItem;
	moveController : CMIF_MoveController;
	wle : CM_WorkListEntry;
	targetLocn : CM_LocationsController;
	result : Integer;

begin

	table := menuItem.userObject.CM_DataTable;
	
	if table = null or table &lt;&gt; self.tblWouldPlan or  table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create testResults transient;
	foreach obj in table.allSelectedObjects do
		testResult := obj.CM_TestAutoPlanResult;
		testResults.add( testResult );
	endforeach;
	
	foreach testResult in testResults do
	
		ti := testResult.myTrackedItem;
		targetLocn := testResult.CM_TestAutoPlanPlanned.myPlannedLocation;
		
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.isRehandleMove := ti.isRehandle;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.setMyToPrimaryLocation(targetLocn);
		
		wle := ti.getWLEforFailedAutoPlan();	// in case this move it is to override of a failed auto plan
		if wle &lt;&gt; null then
			moveController.setMyWorkListEntry(wle);	
			moveController.setJobForMove(wle.job);	
		endif;
		
		while true do
			if targetLocn.isWagon() then
				app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
			else
				app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
			endif;
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				table.removeItemObject(testResult);
				break;
			else
				result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				break;
			endif;
		endwhile;	
		
		delete moveController;
		
		if app.myPassport.hasErrors then
			break;
		endif;
		
	endforeach;
	
	self.doRefresh();
	

epilog

	delete moveController;
	delete testResults;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuRemoveItems_click" id="7cfeb657-c9c0-4cd9-b996-d3af73d54f3f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRemoveItems_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	objArray : ObjectArray;
	obj : Object;
	rowIndex : Integer;

begin

	if not self.tblSelected.allSelectedObjects.isEmpty then
	
		create objArray transient;
		self.tblSelected.allSelectedObjects.copy( objArray );
		
		foreach obj in objArray do
			self.tblSelected.removeItemObject(obj);
			self.removeNotableTi( obj.CM_TrackedItem );
		endforeach;
		
		self.refreshTable( self.tblSelected, false );
		self.clearWouldPlanAndFailed();
		
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuRemovePlanned_click" id="12b928b6-2c12-4d61-ab2d-890115d02851">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRemovePlanned_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	obj : Object;
	rowIndex : Integer;
	size : Integer;

begin

	create tiArray transient;

	foreach rowIndex in self.tblSelected.fixedRows to self.tblSelected.rows do
		ti := self.tblSelected.accessRow(rowIndex).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null and ti.myPrimaryPlannedLocation &lt;&gt; null then
			tiArray.add( ti );
		endif;
	endforeach;
	
	if not tiArray.isEmpty then
		foreach ti in tiArray do
			self.tblSelected.removeItemObject(ti);
			self.removeNotableTi( ti );
		endforeach;
		
		self.refreshTable( self.tblSelected, false );
	endif;

epilog

	delete tiArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
