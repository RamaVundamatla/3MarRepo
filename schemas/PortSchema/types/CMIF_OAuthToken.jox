    <JadeMethod name="create" id="0be71ff1-193b-41cb-8524-e93df0172f18">
        <updating/>
        <source>create(_term : CM_Terminal; _tokenType : Integer) updating;
/*

Purpose:			

Parameters:			_term 			: The Terminal the token is for. Null represents a system wide one.
					_ tokeType		: An Class Constant used to identify what the token is used for. eg TYPE_EMAIL

Return Value:		

Date				Who		Reason
03 October 2022		navmd1	Initial creation TFS 55020

*/

vars

begin
	self.myTerminal := _term;
	self.tokenType := _tokenType;
	
	app.allExtOAuthTokens.add(self);
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_tokenType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="expiresIn" id="3c0f3bab-4f9d-491c-9b17-aa7a7db25d95">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>expiresIn(set : Boolean; _value : Integer io) mapping, updating, protected;
/*

Purpose:			A ... close enough approximation to when the token expires in seconds from now

Parameters:			

Return Value:		

Date				Who		Reason
03 October 2022		navmd1	Initial creation TFS 55020

*/

vars
	now : TimeStamp;
	diff : TimeStampInterval;
begin
	if set then
		self.expiresInTimestamp := now.addSeconds(_value);
	else
		diff := self.expiresInTimestamp - now;
		_value := (diff.getMilliseconds / 1000).Integer.max(0);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
