    <JadeMethod name="checkRoadQueue" id="59e5b0f1-ea57-47fe-928d-152dc961817e">
        <source>checkRoadQueue(_isOut : Boolean) : Boolean;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	iter	: Iterator;
	roadJob	: CM_RoadJob;
	count	: Integer;

begin


	iter := self.allJobsByOrder.createIterator;
	while iter.next(roadJob) do
		if roadJob.isRelease = _isOut then
			count := count + 1;
		endif;
	endwhile;
	if count &gt; 10 then
		return true;
	endif;
	return false;
	
epilog
	delete iter;	

end;</source>
        <Parameter name="_isOut" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="5b5c4f60-1c2b-4e02-aed9-40f4297a198e">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	 unknownLC : CM_BlockController;
begin
	if not self.isTransient then
		create unknownLC persistent;
		unknownLC.setMyRoadJobSheet(self);
		unknownLC.setID(unknownLC.getID);
	endif;

epilog

end;</source>
    </JadeMethod>
