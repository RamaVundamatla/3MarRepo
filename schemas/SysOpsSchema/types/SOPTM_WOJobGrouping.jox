    <JadeMethod name="doSave" id="66eb822e-0ddf-4048-8c43-f5e23450d810">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	type					: Integer;
	isNotAvailForEntry,
	isSystemType			: Boolean;
	pxyWOJobGroup,
	newWOJobGroup			: CM_WorkOrderJobGroupMethod;
	terminal				: CM_Terminal;
	allVessels				: CM_VesselSet;
	allGroupingCrit			: IntegerArray;
	allGrpCrit				: ObjectArray;
	crit					: CM_Association;
	allWODtlTypes			: CM_WorkOrderDetailTypeArray;
begin
	theForm 			:= self.myForm;
	tbl 				:= theForm.tblInput1;
	
	code 				:= tbl.getValueByName(ETRow_Code).String;
	description 		:= tbl.getValueByName(ETRow_Description).String;
	isNotAvailForEntry 	:= tbl.getValueByName(ETRow_IsNotAvailForEntry).Boolean;
	terminal			:= self.myForm.myTerminal;
	
	create allGrpCrit transient;
	theForm.mulSelect1.getSelected(allGrpCrit);
	
	create allGroupingCrit transient;
	foreach crit in allGrpCrit as CM_Association do
		allGroupingCrit.add(crit.getValue().Integer);
	endforeach;
	
	create allVessels transient;
	theForm.mulSelect2.getSelected(allVessels);
	
	create allWODtlTypes transient;
	theForm.lstWODtlType.allSelectedObjects.copy(allWODtlTypes);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WorkOrderJobGroupMethod transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyWOJobGroup := theForm.myProxyObject.CM_WorkOrderJobGroupMethod;
	pxyWOJobGroup.setProxy(code, description, isNotAvailForEntry,terminal,allGroupingCrit,allVessels,allWODtlTypes);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateWOJobGrouping(pxyWOJobGroup, newWOJobGroup, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateWOJobGrouping(pxyWOJobGroup, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog
	delete allGroupingCrit;
	delete allVessels;
	delete allWODtlTypes;
	delete allGrpCrit;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
