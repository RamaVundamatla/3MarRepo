    <JadeMethod name="getReportOrd" id="e5eef8cd-5021-46da-8f70-7e7373fde7ef">
        <source>getReportOrd(_usercode : String) : String;
/*

Purpose:			

Parameters:			_usercode	String	The user to filter out of the report

Return Value:		

Date		Who		Reason
23 December 2021	navpw1	Initial creation TFS: 52791

*/

vars
	concatenatedString 			: String;
	devSchema 					: DEV_Schema;
	devGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	devGlobalConstant 			: DEV_GlobalConstant;
	devClass 					: DEV_Class;
	devAttribute 				: DEV_Attribute;
	devConstant 				: DEV_ClassConstant;
	devReference 				: DEV_Reference;
	devMethod 					: DEV_Method;
	wroteHeaderLine 			: Boolean;
	
	globalCnstCatMissingCount,
 	globalCnstCatDifferentCount,
	globalCnstMissingCount,
	globalCnstDifferentCount,
	classesMissingCount,
	methodsMissingCount,
	methodsDifferentCount,
	attributesMissingCount,
	attributesDifferentCount,
	constantsMissingCount,
	constantsDifferentCount,
	referencesMissingCount,
	referencesDifferentCount	: Integer;

begin
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategoriesOrd where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing do
			if _usercode &lt;&gt; null and devGlobalConstantCategory.modifiedBy &lt;&gt; _usercode then
				continue;
			endif;
			
			if not wroteHeaderLine then
				concatenatedString &amp;= "Missing Global Constant Categories:";
				wroteHeaderLine := true;
			endif;
			
			concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp; " - " &amp; devGlobalConstantCategory.modifiedBy &amp;  " | " &amp; devGlobalConstantCategory.modifiedTimeStamp.String;
			globalCnstCatMissingCount += 1;
		endforeach;
	endforeach;
	
	if globalCnstCatMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Global Constant Categories Count: " &amp; globalCnstCatMissingCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategoriesOrd where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Different and devGlobalConstantCategory.resolvedBy = null do
			if _usercode &lt;&gt; null and devGlobalConstantCategory.modifiedBy &lt;&gt; _usercode then
				continue;
			endif;
			
			if not wroteHeaderLine then
				concatenatedString &amp;= "DIffering Global Constant Categories:";
				wroteHeaderLine := true;
			endif;
			
			concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp; " - " &amp; devGlobalConstantCategory.modifiedBy &amp;  " | " &amp; devGlobalConstantCategory.modifiedTimeStamp.String;
			globalCnstCatDifferentCount += 1;
		endforeach;
	endforeach;
	
	if globalCnstCatDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Global Constant Categories Count: " &amp; globalCnstCatDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do		
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategoriesOrd where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allGlobalConstantsOrd where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if _usercode &lt;&gt; null and devGlobalConstant.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Missing Global Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp;  "::" &amp; devGlobalConstant.name &amp; " - " &amp; devGlobalConstant.modifiedBy &amp;  " | " &amp; devGlobalConstant.modifiedTimeStamp.String;
				globalCnstMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if globalCnstMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Global Constants Count: " &amp; globalCnstMissingCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	

	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategoriesOrd where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allGlobalConstantsOrd where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Different and devGlobalConstant.resolvedBy = null do
				if _usercode &lt;&gt; null and devGlobalConstant.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Differing Global Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp;  "::" &amp; devGlobalConstant.name &amp; " - " &amp; devGlobalConstant.modifiedBy &amp;  " | " &amp; devGlobalConstant.modifiedTimeStamp.String;
				globalCnstDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if globalCnstDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Global Constants Count: " &amp; globalCnstDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Missing do
			if _usercode &lt;&gt; null and devClass.modifiedBy &lt;&gt; _usercode then
				continue;
			endif;
			
			if not wroteHeaderLine then
				concatenatedString &amp;= "Missing Classes:";
				wroteHeaderLine := true;
			endif;
			
			concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; " - " &amp; devClass.modifiedBy &amp;  " | " &amp; devClass.modifiedTimeStamp.String;
			classesMissingCount += 1;
		endforeach;
	endforeach;
	
