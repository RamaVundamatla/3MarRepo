    <JadeMethod name="getNumSlotReqs" id="ecbb29fe-ca1f-4912-8f9c-dac9778861ab">
        <source>getNumSlotReqs() : Integer;
// ---------------------------------------------------------------------------
// Created:     02 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slotReq : CM_SlotRequest;
	idx, qty : Integer;
	
	roroReq : CM_VoyageRequest;
begin
	foreach slotReq in self.allSlotRequests discreteLock do
		
		if slotReq.getAttrIsBackend() then
			continue;
		endif;
		
		idx := idx + 1;
	endforeach;
	foreach roroReq in self.allRequests discreteLock do
		
		if roroReq.getAttrIsBackend() then
			continue;
		endif;
		qty := roroReq.quantity.Integer;
		if qty &lt;= 0 then 
			qty := 1;
		endif;
		idx := idx + qty;
	endforeach;
	
	return idx;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPriority" id="92b3e020-31d7-402d-8dd5-ab0cf14b9513">
        <source>getPriority() : Integer;
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyPriority : Integer;
	criteria			: CM_YACriteria;
begin

	
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_IsTransShip then // PAR 25833
			voyPriority := voyPriority + 4194304;
		elseif criteria.myYACriteriaType.type = YACriteriaType_Hazardous then
			voyPriority := voyPriority + 2097152;
		elseif criteria.myYACriteriaType.type = YACriteriaType_IsHazardous then
			voyPriority := voyPriority + 1048576;
		elseif criteria.myYACriteriaType.type = YACriteriaType_RequiresPower then
			voyPriority := voyPriority + 524288;
		elseif criteria.myYACriteriaType.type = YACriteriaType_WaterCooled then
			voyPriority := voyPriority + 262144;
		elseif criteria.myYACriteriaType.type = YACriteriaType_SpecialStow then
			voyPriority := voyPriority + 131072;
		elseif criteria.myYACriteriaType.type = YACriteriaType_IsOverDimension then
			voyPriority := voyPriority + 65536;
		elseif criteria.myYACriteriaType.type = YACriteriaType_IsFiftyThree then
			voyPriority := voyPriority + 32768;
		elseif criteria.myYACriteriaType.type = YACriteriaType_IsForty then
			voyPriority := voyPriority + 16384;
		elseif criteria.myYACriteriaType.type = YACriteriaType_IsThirty then
			voyPriority := voyPriority + 8192;
		elseif criteria.myYACriteriaType.type = YACriteriaType_IsFortyFive then
			voyPriority := voyPriority + 4096;
		elseif criteria.myYACriteriaType.type = YACriteriaType_CargoType then
			voyPriority := voyPriority + 2048;
		elseif criteria.myYACriteriaType.type = YACriteriaType_Product then
			voyPriority := voyPriority + 1024;
		elseif criteria.myYACriteriaType.type = YACriteriaType_TranshipDischPt then // PAR 25833
			voyPriority := voyPriority + 256;
		elseif criteria.myYACriteriaType.type = YACriteriaType_DischargePort then
			voyPriority := voyPriority + 128;
		elseif criteria.myYACriteriaType.type = YACriteriaType_TranshipToPort then
			voyPriority := voyPriority +64;
		elseif criteria.myYACriteriaType.type = YACriteriaType_DestinationPort then
			voyPriority := voyPriority + 32;
		elseif criteria.myYACriteriaType.type = YACriteriaType_BookingRef then
			voyPriority := voyPriority + 16;
		elseif criteria.myYACriteriaType.type = YACriteriaType_CommodityGroup then
			voyPriority := voyPriority + 8;
		elseif criteria.myYACriteriaType.type = YACriteriaType_ISOGroup then
			voyPriority := voyPriority + 4;
		elseif criteria.myYACriteriaType.type = YACriteriaType_ISO then
			voyPriority := voyPriority + 2;
		elseif criteria.myYACriteriaType.type = YACriteriaType_Weight then
			voyPriority := voyPriority + 1;
		else
		
			voyPriority := voyPriority + 1;
		endif;
	endforeach;

	return voyPriority;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSlotCollections" id="6140970c-b6cf-46dd-9fca-beb9c90e301c">
        <source>getSlotCollections( _export, _rh, _sob : CM_RequestSet io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2012	cnwndl1	Initial creation	Par 28896
08 Jul 2014	cnwer1	PAR 30787	- export totals should not include SOB &amp; DLR lifts
*/

vars

	slot : CM_SlotRequest;
	roroReq : CM_VoyageRequest;

begin

	foreach slot in self.allSlotRequests discreteLock do
		if slot.getAttrIsBackend() then
			continue;
		endif;
		
		if slot.isRehandle then 
			_rh.addNoDuplicates(slot,false);
			continue;
		endif;
		if slot.isSOB then 
			_sob.addNoDuplicates(slot,false);
			continue;
		endif;
		_export.addNoDuplicates(slot,false);
	endforeach;
	
	foreach roroReq in self.allRequests discreteLock do
		if roroReq.getAttrIsBackend() then
			continue;
		endif;
		
		if roroReq.isRehandle then 
			_rh.addNoDuplicates(roroReq,false);
			continue;
		endif;
		if roroReq.isSoB then 
			_sob.addNoDuplicates(roroReq,false);
			continue;
		endif;
		_export.addNoDuplicates(roroReq,false);
	endforeach;

epilog

end;</source>
        <Parameter name="_export" type="CM_RequestSet" usage="io"/>
        <Parameter name="_rh" type="CM_RequestSet" usage="io"/>
        <Parameter name="_sob" type="CM_RequestSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="f7a83c1f-80b2-4a92-a331-220606525a1f">
        <source>getTerminal(): CM_Terminal;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2012	cnwdw1	Initial creation
*/
vars

	term : CM_Terminal;
begin
	if self.myVoyage &lt;&gt; null then
		term := self.myVoyage.myTerminal;
	endif;
	
	if term = null then
		return inheritMethod();
	endif;
	
	return term;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocationGroupDesc" id="d79ef202-4070-4709-8066-177715e71813">
        <source>getVoyageAllocationGroupDesc(): String;
/*
Purpose:			
Date		Who		Reason
20 May 2014	cnwab1	Initial creation
*/

vars

	isGen			: Boolean;
	groupDesc		: String;
	cargoTyp		: CM_CargoType;
		criteria : CM_YACriteria;	
begin

	
		
	groupDesc := null;
	
	cargoTyp := self.getCargotype();
	if cargoTyp = null or cargoTyp.id = TI_CargoType_Container then
		if self.getIs40() then
			groupDesc := app.getErrorString(FortyFoot);
		elseif self.getIs30() then
			groupDesc := app.getErrorString(ThirtyFoot);
		elseif self.getIs45() then
			groupDesc := app.getErrorString(FortyFiveFoot);
		elseif self.getIs53() then
			groupDesc := app.getErrorString(FiftyThreeFoot);
		else
			groupDesc := app.getErrorString(TwentyFoot);
		endif;
		
		
		// Now check special attributes
		if self.getIsFlatRack() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_FlatRack);
		elseif self.getIsCrib() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Crib);
		elseif self.getIsFrame() then	//05 Feb 2018	NDL	TFS 36752
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Frame);
		elseif self.getIsTank() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Tank);
		elseif self.getIsOpenTop() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_OpenTop);
		elseif self.getIsFantainer() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Fantainer);
		else
			isGen := true;
		endif;
		
		// Now empty or power
		if self.getIsEmpty() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Empty);
		elseif self.getIsPowerRequired() then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Integral);
		elseif isGen then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_General);
		endif;
		
		// Finally High Cube
		if self.isHiCubed	 then
			groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_HighCube);
		endif;
			
	else
		// Non-container cargo, so use Cargo Type Description
		groupDesc := cargoTyp.description;
	endif;
	
	return groupDesc.truncatedAt(30);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasCargoType" id="2126a25c-b6f1-4faf-b2b4-f6dec4b4c10d">
        <source>hasCargoType(_type : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
	obj : Object;
	ct : CM_CargoType;
begin
		criteria := self.getCriteriaOfTypeValue(YACriteriaType_CargoType);
		if criteria = null then
			return false;
		endif;
		
		foreach obj in criteria.myYAData.CM_YADataObjects.allObjects  discreteLock do
			ct := obj.CM_CargoType;
			
			if ct.id = _type then
				return true;
			endif;
		endforeach;

		return false;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isColourCodedForLength" id="3d053ecf-30d7-4a1b-9d5f-a07f4f326c14">
        <source>isColourCodedForLength() : Integer;
// ---------------------------------------------------------------------------
// Created:     07 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;	
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsThirty);
	if criteria &lt;&gt; null then
		if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
			return YACriteriaType_IsThirty;
		endif;
	endif;
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsForty);
	if criteria &lt;&gt; null then
		if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
			return YACriteriaType_IsForty;
		endif;
	endif;
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive);
	if criteria &lt;&gt; null then
		if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
			return YACriteriaType_IsFortyFive;
		endif;
	endif;
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsFiftyThree);
	if criteria &lt;&gt; null then
		if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
			return YACriteriaType_IsFiftyThree;
		endif;
	endif;

		return 0;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isForBulk" id="c755630b-c090-45c7-a4df-9100b90d9d2b">
        <source>isForBulk():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2019	jlgndl1	Initial creation	TFS 46875

*/

vars

	criteria : CM_YACriteria;
	obj : Object;
	
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_CargoType);
	if criteria &lt;&gt; null then
		foreach obj in criteria.myYAData.CM_YADataObjects.allObjects  discreteLock do
			if obj.isKindOf(CM_CargoType) then
				if obj.CM_CargoType.isTrackByVolume or obj.CM_CargoType.isTrackByWeight then 
					return true;
				endif;
			endif;
		endforeach;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForContainer" id="f6ca28c7-6549-4192-9714-86fb7c1af3f0">
        <source>isForContainer() : Boolean;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	criteria : CM_YACriteria;
	obj : Object;
begin
		criteria := self.getCriteriaOfTypeValue(YACriteriaType_CargoType);
		if criteria &lt;&gt; null then
			foreach obj in criteria.myYAData.CM_YADataObjects.allObjects  discreteLock do
				if obj.CM_CargoBOLType.id = TI_CargoType_Container then
					return true;
				endif;
			endforeach;
		endif;
		
		return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isHiCubed" id="10e4604e-b8e9-44ca-847a-26f9420a70e9">
        <source>isHiCubed() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
begin
		criteria := self.getCriteriaOfTypeValue(YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType.isNonStandardHeight();								
		endif;
		
		criteria := self.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); // cnwas3 par 23988 CHECK ISO GROUP
		if criteria &lt;&gt; null then
			return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup.isNonStandardHeight();								
		endif;
		
		return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
