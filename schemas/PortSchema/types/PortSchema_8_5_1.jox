		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Resetting CargoType.myWeightMeasurementType complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Resetting CargoType.myWeightMeasurementType complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixupVoyageProcess" id="b57eca45-3844-4ca0-80a6-c3f8770bccee">
        <source>fixupVoyageProcess();
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	iter01 : Iterator;
	workorder : CM_Voyage;
	oArray : ObjectArray; 
	voyProcess : CM_VoyageProcess;

begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ": Setting default voyage process. ", LogINFO);
	
	create oArray transient;
	CM_Voyage.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;

	voyProcess := CM_Root.firstInstance.allVoyageProcesses["JMT"];
	
	while iter01.next(workorder) do
		if workorder.myVoyageProcess = null then
			beginTransaction;
			workorder.setPropertyValue("myVoyageProcess",voyProcess);
			commitTransaction;
		endif;
		
		
	endwhile;
	
	app.writeLog(method.qualifiedName &amp; ": Setting default voyage process complete. ", LogINFO);
	
	
	self.addScriptRun(method.name);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupWorkOrderTransactions" id="c35237c0-0dca-4b27-b08f-e8a44c38bd5b">
        <source>fixupWorkOrderTransactions();
// TFS 39237
vars
	iter01 : Iterator;
	workorder : CM_WorkOrder;
	oArray : ObjectArray; 
	tran : CM_WOTransaction;
	newType : Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting terminal reference on WORK ORDER transactions", LogINFO);
	
	create oArray transient;
	CM_WorkOrder.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;

	while iter01.next(workorder) do
		beginTransaction;
			foreach tran in workorder.allTransactions	discreteLock do
				
				
				if tran.type = WO_TRANS_ACTION then
					newType :=  TRANS_TYPE_WO_ACTION;
				elseif tran.type = WO_TRANS_COMPLETE then
					newType :=  TRANS_TYPE_WO_COMPLETE;
				endif;		
	
				if tran.type &lt;&gt; newType then
					tran.setPropertyValue("type",newType);
				endif;
			
				if tran.myTerminal = null then
					tran.setPropertyValue("myTerminal",workorder.myTerminal);
				endif;
			endforeach;
		commitTransaction;
	
	endwhile;

	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Setting terminal reference on WORK ORDER transactions complete", LogINFO);	
epilog
	delete oArray;
	delete iter01;

end;</source>
    </JadeMethod>
    <JadeMethod name="migrateHHRootConfigToTerm" id="99161726-6803-48a9-9bcc-0789ed40f947">
        <source>migrateHHRootConfigToTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2015	cnwndl1	Initial creation	Par 36866

*/

vars

	allowLoadMoreCargo : Boolean;
	allowPackMoreCargo : Boolean;
	allowUnloadMoreCargo : Boolean;
	allowUnpackMoreCargo : Boolean;
	term : CM_Terminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ": Migrating Hand Held configs, Root --&gt; Terminal ...", LogINFO);
	
	allowLoadMoreCargo := app.myRoot.getConfig(AllowLoadMoreCargo).Boolean;
	allowPackMoreCargo := app.myRoot.getConfig(AllowPackMoreCargo).Boolean;
	allowUnloadMoreCargo := app.myRoot.getConfig(AllowUnloadMoreCargo).Boolean;
	allowUnpackMoreCargo := true;	// new one, default to true so existing behaviour is not changed.
	
	foreach term in app.myRoot.allTerminals do
		beginTransaction;
		term.setConfig( AllowLoadMoreCargo, allowLoadMoreCargo );
		term.setConfig( AllowPackMoreCargo, allowPackMoreCargo );
		term.setConfig( AllowUnloadMoreCargo, allowUnloadMoreCargo );
		term.setConfig( AllowUnpackMoreCargo, allowUnpackMoreCargo );
		commitTransaction;
	endforeach;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rebuildCalculationTypeHookCode" id="b67677ac-7add-4a3e-8dc1-218b228ea7d3">
        <source>rebuildCalculationTypeHookCode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwmc5	Initial creation

*/

vars
	pxyCalc,
	calcType			: CM_CalculationType;
	currentRateCode,
 	currentQuantCode,
	currentRemarksCode	: String;
	newRateCode,
	newQuantCode,
	newRemarksCode		: String;
	
	loadState 			: Boolean;
	line 				: String;
	pos 				: Integer;
	
	realQtyRange,
	pxyQtyRange			: CM_QuantityRange;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; ": Rebuilding Calculation Type hook code...", LogINFO);
	
	// Loop through all CM_CalculationType's and update the Hook Code objects 
	// to work with the new signature.
	foreach calcType in CM_CalculationType.instances do
		if calcType.myHookCodeQuantity = null and calcType.myHookCodeRate = null then
			continue;
		endif;
		
		newQuantCode := null;
		newRateCode := null;
		currentRemarksCode := calcType.myHookCodeRemarks.getCurrentJadeCode();
		
		// Update the Hook Code for Quantity
		if calcType.myHookCodeQuantity &lt;&gt; null then
			currentQuantCode := calcType.myHookCodeQuantity.getCurrentJadeCode();
			
			// Modifiy the current code
			if currentQuantCode &lt;&gt; null then
				pos := 1;
				line := currentQuantCode.cnEcGetNextLine(pos);
				newQuantCode := "amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;";
				while pos &lt;&gt; 0 do
					line := currentQuantCode.cnEcGetNextLine(pos);
					line.cnReplaceString("_tran", "_cmif.myTransaction");
					line.cnReplaceString("_origQty", "_cmif.origQty");
					newQuantCode := newQuantCode &amp; CrLf &amp; line;
				endwhile;
			endif;
		endif;
		
		// Update the Hook Code for Rates
		if calcType.myHookCodeRate &lt;&gt; null then
			currentRateCode := calcType.myHookCodeRate.getCurrentJadeCode();
			
			// Modifiy the current code
			if currentRateCode &lt;&gt; null then
				pos := 1;
				line := currentRateCode.cnEcGetNextLine(pos);
				newRateCode := "amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;";
				while pos &lt;&gt; 0 do
					line := currentRateCode.cnEcGetNextLine(pos);
					line.cnReplaceString("_tran", "_cmif.myTransaction");
					line.cnReplaceString("_origRate", "_cmif.origRate");
					line.cnReplaceString("_invoiceLine", "_cmif.myInvoiceLine");
					newRateCode := newRateCode &amp; CrLf &amp; line;
				endwhile;
			endif;
		endif;
		
		app.cmsBeginLoad(loadState);
		pxyCalc := calcType.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		foreach realQtyRange in calcType.allQuantityRanges do
			create pxyQtyRange transient;
			pxyQtyRange.setup(	realQtyRange.formula, 
								pxyCalc, 
								realQtyRange.daysIncrement, 
								realQtyRange.percentage, 
								realQtyRange.rangeStart, 
								realQtyRange.rangeEnd,
								realQtyRange.rangeType);
		endforeach;
		
		pxyCalc.setProxy(	calcType.booleanList,
							calcType.calculationType,
							calcType.code,
							calcType.description,
							calcType.hoursFree,
							calcType.hoursMax,
							calcType.hoursMin,
							calcType.hoursBlock,
							calcType.integerRange1,
							calcType.isNotAvailableForEntry,
							calcType.timeFrom,
							calcType.timeTo,
							calcType.amountMin,
							calcType.amountMax,
							calcType.theCalcTypeUnit,
							newQuantCode,
							newRateCode,
							currentRemarksCode,
							app.myPassport.getUserCode(),
							calcType.isCargoCalcType,
							calcType.isVoyageCalcType,
							calcType.isEventCalcType,
							calcType.isWorkOrderType, // TFS 39198
							calcType.myCalendarType1,
							calcType.myCalendarType2,
							calcType.myMeasurementType,
							calcType.rateType,	//22 Mar 2019	NDL	TFS 43687
							false, false, // ### TFS 51219 25MAY2021 NAVAB1
							calcType.weightOptionToUse //02/10/2025	navkc1 JIRA 36149
							);
		
		app.myTrxUA.trxUpdateCalculationType(pxyCalc, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			// SOMETHING WENT WRONG
			app.writeLog(method.qualifiedName &amp; ": " &amp; app.myPassport.getErrorsAndWarningsAsString(), LogINFO);
			break;
		endif;
		
		delete pxyCalc;
	endforeach;
	
	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; ": Rebuilding Calculation Type hook code complete.", LogINFO);
	
epilog
	delete pxyCalc;
	
	app.cmsEndLoad(loadState);
end;</source>
    </JadeMethod>
    <JadeMethod name="rebuildOperatorInvalidKey" id="fd11d761-45c9-42fa-90c7-0a9acb9b1d82">
        <source>rebuildOperatorInvalidKey();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	PAR #36424 Model issue in handling of Operator code change for Bookings

*/


vars
	t				: CM_Terminal;
	v				: CM_Voyage;
	c				: CM_ConsigneeConsignor;
	b				: CM_BookingRef;
	voyages,
	terminals,
	consignees		: ObjectArray;
	iter, iter2		: Iterator;
	codeKey			: String;
	refKey			: String;
	refVoy          : CM_Voyage;
	badOne			: Boolean;
	count           : Integer;

begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	///////////////////////////////////////////////////////////////CM_Terminal
	app.writeLog(method.qualifiedName &amp; "rebuild operator Invalid Keys from CM_Terminal.allBookingRefsByOperatorRef ", LogINFO);
	create terminals transient;
	CM_Terminal.allInstances(terminals, 0, true);
	delete iter;
	iter := terminals.createIterator();
	
	while iter.next(t) do
		delete iter2;
		iter2 := t.allBookingRefsByOperatorRef.createIterator();
		badOne := false;
		while iter2.next(b) do
			
			t.allBookingRefsByOperatorRef.getIteratorKeys(codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
		
		endwhile;
			
		if badOne then
			beginTransaction;
			t.allBookingRefsByOperatorRef.rebuild;
			commitTransaction;
			count := count +1;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; " Completed rebuild CM_Terminal.allBookingRefsByOperatorRef  from 8.4.2 , " &amp; count.String &amp; " Fixed", LogINFO);
	///////////////////////////////////////////////////////////////CM_Voyage
	app.writeLog(method.qualifiedName &amp; "rebuild operator Invalid Keys from CM_Voyage.allBookingRefs", LogINFO);
	count :=0;
	create voyages transient;
	CM_Voyage.allInstances(voyages, 0, true);
	delete iter;
	iter := voyages.createIterator();
	
	while iter.next(v) do
		delete iter2;
		iter2 := v.allBookingRefs.createIterator();
		
		badOne := false;

		while iter2.next(b) do
			v.allBookingRefs.getIteratorKeys(codeKey, refKey, iter2);
			
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
		endwhile;
		
		if badOne then
			beginTransaction;
			v.allBookingRefs.rebuild;
			count := count+1;
			commitTransaction;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; " Completed rebuild CM_Voyage.allBookingRefs  from 8.4.2 , " &amp; count.String &amp; " Fixed", LogINFO);

	///////////////////////////////////////////////////////////////CM_ConsigneeConsignor
	app.writeLog(method.qualifiedName &amp; "rebuild operator Invalid Keys from CM_ConsigneeConsignor.allBookingRefsByOperatorRef", LogINFO);
	count :=0;
	create consignees transient;
	CM_ConsigneeConsignor.allInstances(consignees, 0, true);
	delete iter;
	iter := consignees.createIterator();

	while iter.next(c) do
		delete iter2;
		iter2 := c.allBookingRefsByOperatorRef.createIterator();
		badOne := false;
		while iter2.next(b) do
			
			c.allBookingRefsByOperatorRef.getIteratorKeys(t,codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;

			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
			
		endwhile;
		if badOne then
			beginTransaction;
			c.allBookingRefsByOperatorRef.rebuild;
			commitTransaction;
			count := count+1;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; " Completed rebuild CM_ConsigneeConsignor.allBookingRefsByOperatorRef  from 8.4.2 , " &amp; count.String &amp; " Fixed", LogINFO);
	
	self.addScriptRun(method.name);
epilog
	delete voyages;
	delete terminals;
	delete consignees;
	delete iter;
	delete iter2;
end;</source>
    </JadeMethod>
    <JadeMethod name="renameRenumberPELVoyageSatuses" id="52bd1c91-3333-437c-ac83-1d68911cf211">
        <source>renameRenumberPELVoyageSatuses(_controller: CnEcReleaseController);
/*
Purpose:	TFS 41539		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
// 11 Oct 2021	jlier1		TFS 51963
*/


vars

	pelindoProcess : CM_VoyageProcess;
	inaPortNetProcess : CM_VoyageProcess;
	inaportnetAction : Boolean;
	rootRole : CM_SecurityRoleTerminalRoot;
	pxyStatus, realStatus : CM_VoyageStatus;
	priority : Integer;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		//return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Adding 'Voyage Status Cancelled' ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Adding 'Voyage Status Cancelled'") ;	
	endif;
	
	pelindoProcess := app.myRoot.allVoyageProcesses[VoyageProcessPelindo1];
	
	beginTransaction;
	// #### CHANGE SOME OF THE EXISTING DESCRIPTIONS
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_VoyRequested];
	if realStatus&lt;&gt; null then
		if realStatus.description = "Voyage Requested (Manual PKK)" then // still has the 'old' description
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Voyage Requested - Manual Etmal Required", pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;

	realStatus := pelindoProcess.allStatusesById[Voyage_Status_ApprovalPending];
	if realStatus&lt;&gt; null then
		if realStatus.description = "Approval Pending" then // still has the 'old' description
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Initial Marine Service Approved", pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;

	realStatus := pelindoProcess.allStatusesById[Voyage_Status_ApprovalRejected];
	if realStatus&lt;&gt; null then
		if realStatus.description = "Approval Rejected" then // still has the 'old' description
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Initial Marine Service Rejected", pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;
	
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_VoyCancelled];
	if realStatus = null then
		app.writeLog(method.qualifiedName &amp; " PEL1 Voyage Cancelled Status Does Not Exist", LogINFO);
		abortTransaction;
		return;
	endif;
	
	if realStatus.priority &lt;&gt; 240 then
		// RENUMBER ALL THE PRIORITIES
		foreach realStatus in pelindoProcess.allStatusesById reversed, 	discreteLock do
				priority := realStatus.priority * 10;
				pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
				pxyStatus.setProxy(realStatus.id, priority, realStatus.description, pelindoProcess, null, realStatus.reportToRun,false);
				app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
				delete pxyStatus;
			
		endforeach;
	endif;
	
	if app.myPassport.noErrors then
		commitTransaction;
	else
		abortTransaction;
		return;
	endif;
	
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_VoyCancelled];
	
	if realStatus = null then
		app.writeLog(method.qualifiedName &amp; " PEL1 Voyage Cancelled Status Does Not Exist", LogINFO);
	else
		if realStatus.priority &lt;&gt; 240 then
			app.writeLog(method.qualifiedName &amp; " PEL1 Voyage Cancelled Status RENUMBERING ISSUE", LogINFO);
		endif;

	endif;
	
	
	// ADD NEW STATUS
	pelindoProcess := app.myRoot.allVoyageProcesses[VoyageProcessPelindo1];
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_DepServRejected];
	if realStatus = null then
		create pxyStatus transient;
		pxyStatus.setProxy(Voyage_Status_DepServRejected, 195, 'Departure Marine Services Rejected', pelindoProcess, null, null,false);
		
		beginTransaction;
		app.myUtilityCA.utlCreateVoyageStatus(pxyStatus, realStatus, app.myPassport);
		
		if app.myPassport.noErrors then
			foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
				rootRole.allVoyageStatusesMaint.addNoDuplicates(realStatus, false);
			endforeach;	
			commitTransaction;
		else
			abortTransaction;
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageStatus Departure Marine Services Rejected!!!", LogINFO);
			app.writeLog(method.qualifiedName &amp; " " &amp; app.myPassport.getErrorsAsString, LogINFO);
			return;
		endif;
		
		delete pxyStatus;
	
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Adding 'Voyage Status Departure Marine Services Rejected' complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" Adding 'Voyage Status Departure Marine Services Rejected' complete") ;	
	endif;
	
	//self.addScriptRun(method.name);
	
epilog
	delete pxyStatus;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="renumberPriPELVoyageSatuses" id="c4f748fc-740f-4b13-b418-b285911bb43d">
        <source>renumberPriPELVoyageSatuses(_controller: CnEcReleaseController);
/*
Purpose:	TFS 41539		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/


vars

	pelindoProcess : CM_VoyageProcess;
	inaPortNetProcess : CM_VoyageProcess;
	inaportnetAction : Boolean;
	rootRole : CM_SecurityRoleTerminalRoot;
	pxyStatus, realStatus : CM_VoyageStatus;
	priority : Integer;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Renumbering PEL1 Priorities' ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renumbering PEL1 Priorities'") ;	
	endif;
	
	pelindoProcess := app.myRoot.allVoyageProcesses[VoyageProcessPelindo1];
	beginTransaction;
	// #### CHANGE SOME OF THE EXISTING PRIORITIES
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_VesselDeparted];
	if realStatus&lt;&gt; null then
		if realStatus.priority = 220 then // still has the 'old' priority
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, 900, pxyStatus.description, pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;

	realStatus := pelindoProcess.allStatusesById[Voyage_Status_ServPreInvGen];
	if realStatus&lt;&gt; null then
		if realStatus.priority = 200 then // still has the 'old' priority
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, 910, pxyStatus.description, pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;

	realStatus := pelindoProcess.allStatusesById[Voyage_Status_ServTaxInvGen];
	if realStatus&lt;&gt; null then
		if realStatus.priority = 210 then // still has the 'old' priority
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, 920, pxyStatus.description, pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;
	
	realStatus := pelindoProcess.allStatusesById[Voyage_Status_VesselDeparted];
	if realStatus&lt;&gt; null then
		if realStatus.priority = 900 then // still has the 'old' priority
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, 200, pxyStatus.description, pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;

	realStatus := pelindoProcess.allStatusesById[Voyage_Status_ServPreInvGen];
	if realStatus&lt;&gt; null then
		if realStatus.priority = 910 then // still has the 'old' priority
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, 210, pxyStatus.description, pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;

	realStatus := pelindoProcess.allStatusesById[Voyage_Status_ServTaxInvGen];
	if realStatus&lt;&gt; null then
		if realStatus.priority = 920 then // still has the 'old' priority
			pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
			pxyStatus.setProxy(pxyStatus.id, 220, pxyStatus.description, pelindoProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
	endif;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Renumbering PEL1 Priorities' complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renumbering PEL1 Priorities' complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog
	delete pxyStatus;


end;</source>
