    <JadeMethod name="tCoarri_BulkXlation" id="06ca6486-b42a-47a1-9c68-a4265aaa4b9e">
        <updating/>
        <source>tCoarri_BulkXlation()updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	LocalVoyageCode 	= "UT_VOYAGE";
	LocalVesselCode 	= "UTSTRA";
	ForeignCode			= "12022022";
	ManifestCode		= "UTMANIFEST";
	ContainerName1		= 'UTOP000001';
	ContainerName2		= 'UTOP000002';
	ContainerName3		= 'UTOP000003';
	ContainerName4		= 'UTOP000004';
	TRUCK				= 'UT_TRUCK';
	BlockStackName		= 'BS53181';
	DestPort			= "NZZQN";
	PortName			= "NZAKL";
	DRIVER				= 'UT_DRIVER';
	CamGroup 			= "UT-STD";
	CamProtocol 		= "UT_STD_COARRI_BULK";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";
	FacilityCode 		= "UT_FACILITY";
	RecipientCode 		= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage 				: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; 
	isDoClearanceCheck 	: Boolean;
	operatorCount		: Integer;		
	vessel 				: CM_Vessel;	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	self.deleteVoyage(LocalVoyageCode);
	voyage := self.getVoyage(LocalVoyageCode);
	self.assertIsDeleted(voyage);
	
	voyage := self.createVesselVoyage(LocalVoyageCode, LocalVesselCode, operator);
	self.assertNotNullMsg(voyage, 'Creating voyage failed...');
	operatorCount := voyage.allOperators.size;	
	
	//Create Bulk Translations for Voyage
	self.createVoyBulkXlation(ForeignCode, ManifestCode, voyage);
	
	// it should be x2 as the count for both in and out xlations
	assertEqualMsg(voyage.allXlations.size, operatorCount * 2, "Creating translations per operator failed");
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	
	self.opts.addAssoc( UTTI_BOL, "20940687");		
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003,OPER103");
	container3.setSealNumShippers("SHIP003,SHIP103,SHIP203");
	container3.setSealNumVent("VENT003");
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	
	self.opts.addAssoc( UTTI_BOL, "20940688");	
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	commitTransaction;
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	// ### 20 MT
	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940685");	
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	self.opts.purge();	
	self.opts.addAssoc( UTTI_BOL, "20940686");
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs(voyage, PortName, crane.id);
	self.planLoadItems(voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo(voyage);
	
	beginTransaction; 
		container4.changeState(TI_STATE_DELETED, passport); 
	commitTransaction; 
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	self.opts.addAssoc('includeRFFBM162', true);	
	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG162", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_BulkXlation);	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_BulkXlation213" id="999574c4-5556-4d55-b075-30e159a7f079">
        <updating/>
        <source>tCoarri_BulkXlation213()updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	LocalVoyageCode 	= "UT_VOYAGE";
	LocalVesselCode 	= "UTSTRA";
	ForeignCode			= "12022022";
	ManifestCode		= "UTMANIFEST";
	ContainerName1		= 'UTOP000001';
	ContainerName2		= 'UTOP000002';
	ContainerName3		= 'UTOP000003';
	ContainerName4		= 'UTOP000004';
	TRUCK				= 'UT_TRUCK';
	BlockStackName		= 'BS53181';
	DestPort			= "NZZQN";
	PortName			= "NZAKL";
	DRIVER				= 'UT_DRIVER';
	CamGroup 			= "UT-STD";
	CamProtocol 		= "UT_STD_COARRI_BULK";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";
	FacilityCode 		= "UT_FACILITY";
	RecipientCode 		= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage 				: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; 
	isDoClearanceCheck 	: Boolean;
	operatorCount		: Integer;		
	vessel 				: CM_Vessel;	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	self.deleteVoyage(LocalVoyageCode);
	voyage := self.getVoyage(LocalVoyageCode);
	self.assertIsDeleted(voyage);
	
	voyage := self.createVesselVoyage(LocalVoyageCode, LocalVesselCode, operator);	
	self.assertNotNullMsg(voyage, 'Creating voyage failed...');
	operatorCount := voyage.allOperators.size;	
	
	//Create Bulk Translations for Voyage
	self.createVoyBulkXlation(ForeignCode, ManifestCode, voyage);
	
	// it should be x2 as the count for both in and out xlations
	assertEqualMsg(voyage.allXlations.size, operatorCount * 2, "Creating translations per operator failed");
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	self.opts.purge();
	self.opts.addAssoc( UTTI_BOL, "20940687");
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003,OPER103");
	container3.setSealNumShippers("SHIP003,SHIP103,SHIP203");
	container3.setSealNumVent("VENT003");
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	
	self.opts.addAssoc( UTTI_BOL, "20940688");	
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	commitTransaction;
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	// ### 20 MT
	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940685");	
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	self.opts.purge();	
	self.opts.addAssoc( UTTI_BOL, "20940686");
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs(voyage, PortName, crane.id);
	self.planLoadItems(voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo(voyage);
	
	beginTransaction; 
		container4.changeState(TI_STATE_DELETED, passport); 
	commitTransaction; 
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	self.opts.addAssoc('includeRFFBM162', true);	
	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG213", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_BulkXlation213);	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_CCMS_SCT_2058" id="55fe4e6f-f2e0-48f0-9536-ae43bdf5cd24">
        <updating/>
        <source>tCoarri_CCMS_SCT_2058()updating;
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     22 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/05/2016	cnwdap1		TFS #2061 COARRI/CODECO/COPARN/EDI VGM Updates
// 10 Sep 2019	cnwrs1	TFS 46030
// ---------------------------------------------------------------------------
constants
	VoyageName		= 'UT_VOYAGE';				
	BoatName		= 'UT_VESSEL';
	PortName		= "NZAKL";
	ContainerName1	= 'UTUT000001';// Can't change these container numbers without changing the z... routines 
	ContainerName2	= 'UTUT000002';
	ContainerName3	= 'UTUT000003';
	ContainerName4	= 'UTUT000004';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT-GRP1";
	CamProtocol 	= "UT_COARRI_2058";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	tempStr		: String;
	idx 		: Integer;
	container1, container2, container3, container4 : CM_Container;
	operator 	: CM_Operator;
	voyage 		: CM_Voyage;
	passport 	: CM_Passport;
	bs 			: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
//	time 			: Time;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	booking			: CM_BookingRef;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	// delete bookings we will use
	self.deleteBooking("BK001");
	self.deleteBooking("BK002");
	self.deleteBooking("BK003");
	self.deleteBooking("BK004");
	

	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	self.deleteBooking("UT_BOOKING3");
	booking := self.addBookingForContainer("UT_BOOKING3", operator, null, null, "2200", "MT");
	assertNotNull(booking);
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setPropertyValue (CM_TrackedItem::myBookingRef.name, booking);
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.deleteBooking("UT_BOOKING1");
	booking := self.addBookingForContainer("UT_BOOKING1", operator, null, null, "2200", "MT");
	assertNotNull(booking);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	container1.setPropertyValue (CM_TrackedItem::myBookingRef.name, booking);
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs (voyage, PortName, crane.id);
	self.planLoadItems (voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo (voyage);
	
	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);

	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	beginTransaction;
	container1.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR001');
	container2.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR002');
	container3.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR003');
	container4.setPropertyValue (CM_TrackedItem::deliveryRelease.name, 'DR004');
	
	container1.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK001');
	container2.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK002');
	container3.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK003');
	container4.setPropertyValue (CM_TrackedItem::bookingReference.name, 'BK004');

	booking := container1.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK001');
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR001');
	endif;
	booking := container2.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK002');
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR002');
	endif;
	booking := container3.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK003');
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR003');
	endif;
	booking := container4.myBookingRef;
	if booking &lt;&gt; null then
		booking.setPropertyValue (CM_BookingRef::bookingReference.name, 'BK004');
		booking.setPropertyValue (CM_BookingRef::operatorReferenceNumber.name, 'CR004');
	endif;

	commitTransaction;
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);

	self.zRunCAMS (CamProtocol&amp; "_UN", camGroup, "UN/EDIFACT Coarri", operator, self.zCoarri_UN, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_UN2", camGroup, "UN/EDIFACT Coarri", operator, self.zCoarri_UN2, false, container1, container2, container3, container4, false );
	
	//cnwmc5 - 11 Feb 2016 - PAR 37503
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, true);
	self.zRunCAMS (CamProtocol&amp; "_ANL", camGroup, "ANL Coarri", operator, self.zCoarri_ANL, false, container1, container2, container3, container4, false );
	self.opts.addAssoc(CM_CamProtocol::changeCOARRIBGM.name, false);
	
	self.zRunCAMS (CamProtocol&amp; "_CMA", camGroup, "CMA Coarri", operator, self.zCoarri_CMA, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_CON", camGroup, "ContShip Coarri", operator, self.zCoarri_CON, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_COS", camGroup, "Cosco Coarri", operator, self.zCoarri_COS, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_EUR", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_EUR2", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR2, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_EUR3", camGroup, "UN/EDIFACT Coarri  Europe", operator, self.zCoarri_EUR3, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_HLC", camGroup, "Hapag COARRI", operator, self.zCoarri_HLC, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_MOT", camGroup, "MOT-ECN COARRI", operator, self.zCoarri_MOT, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_MSC", camGroup, "MSC Coarri", operator, self.zCoarri_MSC, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_MSK", camGroup, "Maersk Coarri", operator, self.zCoarri_MSK, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_NYK", camGroup, "NYK Coarri", operator, self.zCoarri_NYK, false, container1, container2, container3, container4, false );
	self.zRunCAMS (CamProtocol&amp; "_OOCL", camGroup, "OOCL Coarri", operator, self.zCoarri_OOCL, false, container1, container2, container3, container4, false );
	//self.zRunCAMS (CamProtocol&amp; "_PANDO", camGroup, "PON Coarri", operator, self.zCoarri_PANDO, false, container1, container2, container3, container4 );
	self.zRunCAMS (CamProtocol&amp; "_ZIM", camGroup, "UN/EDIFACT Coarri Zim", operator, self.zCoarri_ZIM, false, container1, container2, container3, container4, false );	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
