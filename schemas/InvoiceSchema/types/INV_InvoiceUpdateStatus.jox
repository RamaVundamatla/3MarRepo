<GUIClass name="INV_InvoiceUpdateStatus" id="a6051be2-43ab-4671-a7c8-487be5a0708b">
    <superclass name="INV_InvoiceUpdate"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allInvoices" id="ca113511-96ca-4285-8d0b-4aedbea8d272">
        <memberTypeInverse/>
        <type name="CM_InvoiceSet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="isMulti" id="a1f2c335-335d-427c-a780-41d8dc0cedf6">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="mskDueDate" id="3dae30a2-c40e-408b-9b63-a2dcc852a4d3">
        <embedded/>
        <type name="CMUI_DateMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mskEndDate" id="2bb49540-1b3d-43e4-ba07-8e37ecc0c777">
        <embedded/>
        <type name="CMUI_DateMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mskInvoiceDate" id="6c5087a2-f50b-4121-95fb-e36b3c3474bb">
        <embedded/>
