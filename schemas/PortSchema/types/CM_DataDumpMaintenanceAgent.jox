    <JadeMethod name="xCM_TITransaction" id="370b4b8e-438b-4f0a-97e7-185dd2689cc9">
        <updating/>
        <source>xCM_TITransaction(_features : CMIF_ExternalDBFeatureSet input) updating;
// 
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 26/02/2013	cnwdap1		PAR #31213 CCMS PNL 2255 Additional SQL Fields
//25 Jun 2014	cnwrs1	Par 34470 New SQL native classes are missing edition 
// 19/05/2016   cnwma1	TFS #1999 MSL - Unable to distinguish Moved/Queued/Planned Transactions in Data Export+
// 08/09/2016   cnwma1  TFS #2589:PAR38142 STWR - TFS2239 " Double assign to release" -fix not OK
// 08 May 2017  cnwma1	TFS # 4292:POL - New Edit Transactions SQL Extract added to wrong class
// 12 Jul 2017	jlgrs1	TFS 5354 make otherTrackedItem extract for all Tr types that support otherTrackedItem
// 14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI
// 29 Apr 2019	jlgsl4	TFS 44546 - AAT - IsChild cargo invoice allocation - SQL extract isChild missing
// 19 Sep 2019	jlgdi1		46043 - STWO - Include the new attribute billOfLading
// 22 Apr 2020	jlgdap1		TFS 49171 ASPA April SQL Data Export Field Exposure
// 25 Feb 2021  cnwma1      ChangeRequest 50851: ASPA - IsBarge on Ship Transactions
// 21 Mar 2022  navlw1	TFS	#52579 - Added remarks for the CM_StowageConfirmation
// 09/06/2022 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// 31 Jan 2023  navhl20 ChangeRequest 55111: GPHA -- Adding Workpoint to Tracked Item and Transaction Views
// 24 May 2024	jlika1	TFS 63963 CUX | MAFI - MAFI Fields on Cargo Invoice Allocations and Transactions - SQL
// 09 Apr 2025	jlizm1		MTN 34568 PEN Expose vessel fields to event stream
vars
	xdbFeature  : CMIF_ExternalDBFeature;
begin
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Attach::action.name, "CM_TITransaction", "action", "CM_Attach", _features);

