    <JadeMethod name="setupForm" id="3de46f05-1f6b-4f3b-bf95-abf6d6ef1368">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
18 August 2008	consw1	Initial creation

*/

vars

begin
	if self.maxCriteria = 0 then
		self.maxCriteria := self.MAX_CRITERIA;
	endif;
	
	self.initializeControls();
	
	inheritMethod();

	self.modalResult := IDCANCEL;

	self.populateCriteriaFrames();
	
	self.centreWindow();

epilog

end;</source>
