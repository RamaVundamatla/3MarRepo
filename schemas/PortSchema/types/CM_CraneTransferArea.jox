    <JadeMethod name="createLC" id="756160d6-a4fd-413a-9542-052750618c5d">
        <updating/>
        <source>createLC(_pxyCraneTransferArea : CM_CraneTransferArea) updating;
//Creates the appropriate Locations controllers.
//By here, we know how many lanes there are in the area.
// 3 Apr 2013 	cnwer1 	PAR 31244
vars
	pxyLC, realLC				: CM_CraneLaneController;
	tmpLC			: CM_LocationsController;
	lanesToDelete			: CM_LCSet;

begin
	create lanesToDelete transient;
	self.lanes.copy(lanesToDelete);
	
	self.lanes.clear;
	self.dischargeLanes.clear;
	self.loadLanes.clear;
	foreach tmpLC in _pxyCraneTransferArea.lanes do
		pxyLC:=tmpLC.CM_CraneLaneController;
		realLC:=pxyLC.pxyGetRealObject.CM_CraneLaneController;
		
		if realLC &lt;&gt; null then
			lanesToDelete.remove(realLC);
			self.lanes.add(realLC);
			realLC.setForUpdate(pxyLC,self);
		else
			create realLC;
			self.lanes.add(realLC);
			realLC.setForCreate(pxyLC, self);
		endif;
		
		if _pxyCraneTransferArea.loadLanes.includes(pxyLC) then
			self.loadLanes.add(realLC);
		endif;
		
		if _pxyCraneTransferArea.dischargeLanes.includes(pxyLC) then
			self.dischargeLanes.add(realLC);
		endif;
	endforeach;
	
	lanesToDelete.purge;
	
epilog
	delete lanesToDelete;
end;</source>
        <Parameter name="_pxyCraneTransferArea" type="CM_CraneTransferArea"/>
    </JadeMethod>
    <JadeMethod name="erase" id="5311c1fa-4083-48ee-a5b9-ebf2f6121841">
        <updating/>
        <source>erase(_eraseLevel	:	Integer) updating;

vars
	lc	:	CM_LocationsController;
begin
	while lanes.size &gt; 0 do
		lc := lanes[lanes.size];
		lc.erase(_eraseLevel);
		lanes.remove(lc);
//		delete lc;
	endwhile;
	crane := null;
	inheritMethod(_eraseLevel);	//Call Terminal Area's erase
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="dd0afa6f-4714-4148-b13e-14d24cb76957">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*
 ------------------------------------------------------------------------
Created:			06 July 2001 by cnwdwq1
Purpose:			!     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------			--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	lane : Integer;
begin
	
	//20 Feb 2014	NDL	Par 33550
	//inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	_foundLC := null;	//20 Feb 2014	NDL	Par 33550
	_foundHeight := NULLINDEX;	//20 Feb 2014	NDL	Par 33550

	//We need to look for the optional LANE part of the location string, ie "CTA 3" = lane 3.
	if _strs.size = 0 then
		//----------------
		//If users have not supplied a lane, default to lane 1
		//----------------
		if self.lanes.isEmpty then
			return;
		endif;
		//----------------
		//return 1st in array
		//----------------
		_foundLC := self.lanes[1];		
		return;
	endif;
	//------------------
	//We have a lane label, locate in the lanes array
	//------------------
	if not _strs[1].Character.isNumeric then
		return;
	endif;
	lane := _strs[1].Integer;
	
	if lane &gt; self.lanes.size then
		if _noException then
			_foundLC := null;
			_foundHeight := NULLINDEX;
			return;
		else
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_CTA_NO_LANE_AT, _strs[1], self.id, null, null);
			return;	
		endif;
	endif;
	_foundLC := self.lanes[lane];
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCrane" id="3df357d8-2478-4be8-88bd-c47335d8c53b">
        <source>getCrane() : CM_Crane;

vars
	machine: CM_Machine;
	crane: CM_Crane;
begin
	foreach machine in self.myTerminal.machines do
		if machine.isCrane then
			crane := machine.CM_Crane;
			if crane.getCraneTransferArea = self then
				return crane;
			endif;
		endif;
	endforeach;
	return null;
end;
</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getCraneLaneDisplayString" id="315042a1-0cd8-4289-b611-7be960cc7937">
        <source>getCraneLaneDisplayString(_laneIdx : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2009	cnwer1	Initial creation

*/

vars

begin
	if self.lanes.size &gt;= _laneIdx then
		return (self.lanes[_laneIdx].CM_CraneLaneController.numOfTwinLiftCages &gt; 0).asStringJMT;
	else
		return false.asStringJMT;
	endif;
epilog

end;</source>
        <Parameter name="_laneIdx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f4e0da4f-f0d6-48e7-b201-3b4c37a0a3e0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation CCMS 1076

*/

vars

begin
	if _attrName = ETRow_NumLanes then
		return self.numLanes.asStringJMT;
	elseif _attrName = ETRow_CraneLane1 then
		return getCraneLaneDisplayString(1);
	elseif _attrName = ETRow_CraneLane2 then
		return getCraneLaneDisplayString(2);
	elseif _attrName = ETRow_CraneLane3 then
		return getCraneLaneDisplayString(3);
	elseif _attrName = ETRow_CraneLane4 then
		return getCraneLaneDisplayString(4);
	elseif _attrName = ETRow_CraneLane5 then
		return getCraneLaneDisplayString(5);
	elseif _attrName = ETRow_CraneLane6 then
		return getCraneLaneDisplayString(6);
	elseif _attrName = ETRow_CraneLane7 then
		return getCraneLaneDisplayString(7);
	elseif _attrName = ETRow_CraneLane8 then
		return getCraneLaneDisplayString(8);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstAvailableDischLane" id="bc97c9b7-9459-4aaf-9428-74845420c1cc">
        <source>getFirstAvailableDischLane() : CM_LocationsController;
//Returns the first available discharge lane for this crane, as per the setup.
vars
	lc	:	CM_LocationsController;
	firstFullIndex	:	Integer;
	laneIdx : Integer;
begin
	if dischargeLanes.isEmpty then
		//--------------
		//No discharge lanes setup.
		//--------------
		return null;
	endif;
	//---------------
	//The ONLY lc's in the dischargeLanes coll are the ones being used. (not all lanes)
	//---------------
	foreach lc in dischargeLanes do
		laneIdx := laneIdx +1;
		//--------------
		//Find - EITHER, the 1st lc AFTER a full lc, with nothing in it..
		//OR if all are mt, the 1st lc.
		//The progression is through the nominated lanes IN THE ORDER they specify.
		//--------------
		if lc.allTrackedItems.isEmpty = false then
			firstFullIndex := laneIdx;
			break;
		endif;
	endforeach;

	if firstFullIndex = 0 then
		//--------------
		//None with anything in, return 1st
		//--------------
		return dischargeLanes[1];		
	endif;
	if firstFullIndex = dischargeLanes.size then
		//--------------
		//Last one is full, return 1st.
		//--------------
		return dischargeLanes[1];		
	endif;

	if (firstFullIndex + 1)  &gt; dischargeLanes.size then
		return dischargeLanes[firstFullIndex];		
	endif;
	//--------------
	//Return the 1st AFTER first full
	//--------------
	return dischargeLanes[firstFullIndex +1];		
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFirstAvailableLoadLane" id="4003d891-e0d6-43d4-88ef-773c06053c79">
        <source>getFirstAvailableLoadLane()	:	CM_LocationsController;
//Returns the first available load lane for this crane, as per the setup.
vars
	lc	:	CM_LocationsController;
	firstFullIndex	:	Integer;
	alert	:	CM_SystemAlert;
	lanePos : Integer;
begin
	if loadLanes.isEmpty then
		//--------------
		//No load lanes setup.
		//--------------
		create alert transient;
		alert.details := "Crane Transfer Area " &amp; self.id &amp; " does NOT have any Load Lanes setup. (In Queue properties window)";
		alert.setSeverity(SEVERE_INFO);
		//-----------
		//Tell alert to add itself to system
		//-----------
		alert.add;
		return null;
	endif;
	//---------------
	//The ONLY lc's in the dischargeLanes coll are the ones being used. (not all lanes)
	//---------------
	foreach lc in loadLanes do
		lanePos := lanePos +1;
		//--------------
		//Find - EITHER, the 1st lc AFTER a full lc, with nothing in it..
		//OR if all are mt, the 1st lc.
		//The progression is through the nominated lanes IN THE ORDER they specify.
		//--------------
		if lc.allTrackedItems.isEmpty = false then
			firstFullIndex := lanePos;
			break;
		endif;
	endforeach;

	if firstFullIndex = 0 then
		//--------------
		//None with anything in, return 1st
		//--------------
		return loadLanes[1];		
	endif;
	if firstFullIndex = loadLanes.size then
		//--------------
		//Last one is full, return 1st.
		//--------------
		return loadLanes[1];		
	endif;
	//--------------
	//Return the 1st AFTER first full
	//--------------
	return loadLanes[firstFullIndex +1];		
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLaneLC" id="f6205d9a-27da-4d73-8434-883aab7496e4">
        <source>getLaneLC(laneId	:	String)	:	CM_LocationsController;
//Returns the locations controller with the id ==  the passed in laneId
vars
	lc : CM_LocationsController;
	useGetId : Boolean;
	laneIdx : Integer;
begin
	if laneId = null then
		return null;
	endif;
	if lanes.isEmpty then
		return null;
	endif;
	//---------------
	//What sort of laneId have we been passed? is is "Parent lane" or just the lane num?
	//---------------
	if laneId[1 : self.id.length] = self.id then
		useGetId := true;
	endif;
	foreach lc in self.lanes do
		laneIdx := laneIdx +1;
		if useGetId then
			//---------------
			//Full terminal area plus lane passed in.
			//---------------
			if lc.CM_BlockController.getID = laneId then
				return lc;
			endif;
		else
			//---------------
			//Number only lane passed in.
			//---------------
			//if lc.CM_BlockController.getLaneId.trimRight = laneId then
			if laneIdx.String = laneId then
				return lc;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="laneId" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLocationforVehicleMove" id="8d25ec41-5804-43bb-9a57-70420af6239d">
        <source>getLocationforVehicleMove(): CM_YardController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	lc : CM_YardController;

begin

	lc := self.getFirstAvailableLoadLane().CM_YardController;
	
	if lc = null then
		lc := self.getFirstAvailableDischLane().CM_YardController;
	endif;
	
	return lc;

epilog

end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getNextCraneLaneForTwin" id="3e5be949-a826-4dfd-97ae-da804dd2a845">
        <source>getNextCraneLaneForTwin(_lastCraneId : Integer) : Integer;
// -------------------------------------------
// Created 29 September 2005 by cnwdvb1
// -------------------------------------------
vars

	lane	: CM_LocationsController;
	count	: Integer;
	twoTimes,
	found	: Boolean;

begin

	// If this is the first time then we grab the first available.
	found := _lastCraneId = 0;
	
	// Go through all load crane lanes.
	while true do
		foreach lane in self.lanes discreteLock do
			// Keep track of index of crane lane.
			count := count + 1;
			
			// If time to look then check that current lane is in the load lanes and is able to have a cage.
			if  found and (self.loadLanes.includes(lane) and lane.CM_CraneLaneController.numOfTwinLiftCages &gt; 0) then
				return count;
			endif;
			
			// If found hasn't been set but this one was used last time then the next
			// one is maybe the one we want.
			if not found and count = _lastCraneId then
				found := true;
			endif;
		endforeach;
		if twoTimes then
			break;
		endif;
		twoTimes := true;
		count := 0;
	endwhile;
	
	// Didn't find anything hmmm.
	return 0;
	
	


end;</source>
        <Parameter name="_lastCraneId" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="3d3123b7-1e17-43eb-9788-110ee32dee2a">
        <source>getQueues(queueSet: CM_RTQueueSet io);
// Get the queue associated with the crane
// epr par 34825 	2/9/14  also get any queues associated with the CTA 
vars
	cq : CM_VoyageCraneQueue;
	q 	: CM_RadioTelemetryQueue;
begin
	
	if self.crane &lt;&gt; null then
		foreach cq in self.crane.allCraneQueues discreteLock do // PAR 20474
			queueSet.add(cq);
		endforeach;
	endif;
	
	foreach q in self.allSubRTQueues discreteLock do
		queueSet.addNoDuplicates(q,false);
	endforeach;
	
	if queueSet.size = 0 then
		inheritMethod(queueSet);
	endif;
end;
</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="81fde7dc-91f9-4589-8a0f-de426ffe06f8">
        <source>getTIs(tis: CM_TIArray input; _mode : Integer);
//Add all of the TI's in this Terminal Area to the TIArray passed in.
vars
	lc : CM_LocationsController;
begin
	inheritMethod(tis, _mode);
	tis.clear;
	foreach lc in self.lanes do
		if lc.CM_BlockController.allTrackedItems.size &gt; 0 then
			lc.CM_BlockController.allTrackedItems.copy(tis);
		endif;
	endforeach;
end;</source>
        <Parameter name="tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIsForLane" id="6dde76a1-ec78-4f99-ac80-99dffdb9ce74">
        <source>getTIsForLane(lane	:	Integer; tis	: CM_TIArray io);
//Add all of the TI's for lane supplied to the TIArray passed in.
vars
	lc : CM_LocationsController;
begin
	tis.clear;
	if lane &lt;= 0 or lane &gt; self.numLanes then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_CTA_NO_LANE_AT, lane.String, id, null, null);
		return;
	endif;
	lc := lanes[lane];
	if lc.CM_BlockController.allTrackedItems.size &gt; 0 then
		lc.CM_BlockController.allTrackedItems.copy(tis);
	endif;
end;</source>
        <Parameter name="lane" type="Integer"/>
        <Parameter name="tis" type="CM_TIArray" usage="io"/>
    </JadeMethod>
