    <JadeMethod name="applyDeckingRulesToCellOrder" id="0d79cbc3-47ae-41ab-a4e3-47951d273a18">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
constants
	IN = true;
	OUT = false;
vars
	rule		: CM_YADeckingRule;
	index		: Integer;
begin
	//the rules have just been updated - we need to rearrange the YALocnCells based on new rules
	index := 0;
	//IN
	foreach rule in self.myDeckingOptions.allDeckingRulesIn do
		if rule.isAdvancedRule then
			self.applyAdvancedDeckingRules(rule, IN, self.allYardControllers, 0);
		else	
			self.applyInDeckingRule(rule, index, self.myDeckingOptions.allYALocationCellsIn);
		endif;
	endforeach;
	
	index := 0;
	//OUT
	if self.myDeckingOptions.useReverseOfIn then
		self.myDeckingOptions.setOutDeckingReverseOfIn();
	else
		foreach rule in self.myDeckingOptions.allDeckingRulesOut do
			if rule.isAdvancedRule then
				self.applyAdvancedDeckingRules(rule, OUT, self.allYardControllers, 0);
			else	
				self.applyOutDeckingRule(rule, index, self.myDeckingOptions.allYALocationCellsOut);
			endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="applyInDeckingRule" id="2a3cf14b-d1b6-4d2e-b8b9-a84a66b21e0a">
        <source>applyInDeckingRule(_rule: CM_YADeckingRule; _index: Integer io; _allYALocationCellsIn: CM_YALocationCellArray input);
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridCntrlDict	: CM_MemberKeyDictionary;
	theRuleType		: Integer;
	gridController	: Object;
	intLayer		: Integer;
begin
	theRuleType := _rule.deckingRuleType;

	self.getGridControllersForDecking(gridCntrlDict);
	
	if gridCntrlDict = null
	or gridCntrlDict.isEmpty then
		//must be a non-grid area and doesn't require decking
		if CM_GridArea.hasInstance(self.myTerminalArea) then
			app.raiseUnexpectedProgramError(class.name, method.name, "No grid controllers found for Terminal Area (" &amp; self.myTerminalArea.id &amp; ")");
		endif;
		return;
	endif;

	if theRuleType = Height_Then_Next_Col_Pos
	or theRuleType = Height_Then_Next_Row_Pos then
		foreach gridController in gridCntrlDict do
			gridController.CM_YardController.setForDeckingIn(_rule.heightFrom, _rule.heightTo, _allYALocationCellsIn, _index);
		endforeach;
		
	elseif theRuleType = Layer_Then_First_Col_Pos
	or theRuleType = Layer_Then_First_Row_Pos then
		foreach intLayer in _rule.heightFrom to _rule.heightTo do
			foreach gridController in gridCntrlDict do
				gridController.CM_YardController.setForDeckingIn(intLayer, intLayer, _allYALocationCellsIn, _index);
			endforeach;
		endforeach;
		
	elseif theRuleType = Height_Then_Prev_Col_Pos
	or theRuleType = Height_Then_Prev_Row_Pos then
		foreach gridController in gridCntrlDict reversed do
			gridController.CM_YardController.setForDeckingIn(_rule.heightFrom, _rule.heightTo, _allYALocationCellsIn, _index);
		endforeach;
		
	elseif theRuleType = Layer_Then_Last_Col_Pos
	or theRuleType = Layer_Then_Last_Row_Pos then
		foreach intLayer in _rule.heightFrom to _rule.heightTo do
			foreach gridController in gridCntrlDict reversed do
				gridController.CM_YardController.setForDeckingIn(intLayer, intLayer, _allYALocationCellsIn, _index);
			endforeach;
		endforeach;
	endif;
	
epilog
	delete gridCntrlDict;
end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <Parameter name="_allYALocationCellsIn" type="CM_YALocationCellArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="applyOutDeckingRule" id="c86e85c2-7de3-4d3d-8f69-78d1e1d2a6fd">
        <source>applyOutDeckingRule(_rule: CM_YADeckingRule; _index: Integer io; _allYALocationCellsOut: CM_YALocationCellArray input);
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridCntrlDict	: CM_MemberKeyDictionary;
	theRuleType		: Integer;
	gridController	: Object;
	intLayer		: Integer;
begin
	theRuleType := _rule.deckingRuleType;

	self.getGridControllersForDecking(gridCntrlDict);
	
	if gridCntrlDict = null
	or gridCntrlDict.isEmpty then
		//must be a non-grid area and doesn't require decking
		if CM_GridArea.hasInstance(self.myTerminalArea) then
			app.raiseUnexpectedProgramError(class.name, method.name, "No grid controllers found for Terminal Area (" &amp; self.myTerminalArea.id &amp; ")");
		endif;
		return;
	endif;
	
	if theRuleType = Height_Then_Next_Col_Pos
	or theRuleType = Height_Then_Next_Row_Pos then
		foreach gridController in gridCntrlDict do
			gridController.CM_GridController.setForDeckingOut(_rule.heightFrom, _rule.heightTo, _allYALocationCellsOut, _index);
		endforeach;
		
	elseif theRuleType = Layer_Then_First_Col_Pos
	or theRuleType = Layer_Then_First_Row_Pos then
		foreach intLayer in _rule.heightTo to _rule.heightFrom step-1 do
			foreach gridController in gridCntrlDict do
				gridController.CM_GridController.setForDeckingOut(intLayer, intLayer, _allYALocationCellsOut, _index);
			endforeach;
		endforeach;
		
	elseif theRuleType = Height_Then_Prev_Col_Pos
	or theRuleType = Height_Then_Prev_Row_Pos then
		foreach gridController in gridCntrlDict reversed do
			gridController.CM_GridController.setForDeckingOut(_rule.heightFrom, _rule.heightTo, _allYALocationCellsOut, _index);
		endforeach;	
		
	elseif theRuleType = Layer_Then_Last_Col_Pos
	or theRuleType = Layer_Then_Last_Row_Pos then
		foreach intLayer in _rule.heightTo to _rule.heightFrom step-1 do
			foreach gridController in gridCntrlDict reversed do
				gridController.CM_GridController.setForDeckingOut(intLayer, intLayer, _allYALocationCellsOut, _index);
			endforeach;
		endforeach;
	endif;
epilog
	delete gridCntrlDict;
end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <Parameter name="_allYALocationCellsOut" type="CM_YALocationCellArray" usage="input"/>
    </JadeMethod>
