    <JadeMethod name="removeCargoFromTable" id="77d0ea58-6cb4-4332-8b05-1476165e9961">
        <source>removeCargoFromTable( _ti : CM_TrackedItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation

*/

vars

	size : Integer;
	index : Integer;
	rowIndex : Integer;
	mmg : CM_MultiMoveGroup;

begin

	if self.allMultiMoveCargo.includes( _ti ) then
		self.allMultiMoveCargo.remove( _ti );
	endif;
	
	mmg := _ti.myMultiMoveGroup;
	if mmg &lt;&gt; null then
		app.myTrxUA.trxClearFromMultiMoveGroup(_ti, app.myPassport);
	endif;
	
	size := self.tblProspects.rows;
	if size &gt; self.tblProspects.fixedRows then
		foreach index in 1 to size do
			if self.tblProspects.accessRow(index).itemObject = _ti then
				rowIndex := index;
				break;
			endif;
		endforeach;
		if rowIndex &gt; 0 and rowIndex &lt;= size then
			 self.tblProspects.removeItem( rowIndex );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="dc38afd3-f339-4405-9060-681865648a6d">
        <updating/>
        <source>selectCargoItem( manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	cargoIdLength : Integer;
	tiSelectedArray : CM_TIArray;
	
begin

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if ti.isChild then
					// can't dirctly move or pack a child...
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
	endif;
		
	if tiArray.size = 1 then
		self.addCargoToTable( tiArray.first, true );
		self.txtCargoId.setFocus();
		return;
		
	else
	
		create tiSelectedArray transient;
		self.getSelectedCargo( tiSelectedArray );
		self.myMobileGenericAgent.setAllMultiMoveCargo( tiSelectedArray );
		if self.optMove.value then
			self.myMobileGenericAgent.setMyLocationsController( txtLocation.userObject.CM_LocationsController );
		endif;
		if self.optPack.value then
			self.myMobileGenericAgent.setPackContainerDetails(	null,	//_stockBookingRef : CM_BookingRef;
																	null,	//_stockBookingRefItem : CM_BookingRefItem;
																	null,	//_exportBookingRef : CM_BookingRef;
																	null,	//_exportBookingRefItem : CM_BookingRefItem;
																	txtParent.userObject.CM_TrackedItem	//_trackedItem : CM_TrackedItem
																	);
		endif;
		
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( true );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setHideOnTransportTIs(true);			// TFS 38111 13/04/2018 jlgmd1
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete tiSelectedArray;

end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="e0fcb9ae-8826-4677-9f71-0b01653b56d7">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	isMove : Boolean;
	isPack : Boolean;
	errMsg : String;

begin

	self.doResizeControls(true);

	if not self.myMobileGenericAgent.allMultiMoveCargo.isEmpty then
		iter := self.myMobileGenericAgent.allMultiMoveCargo.createIterator;
		while iter.next( ti ) do
			self.addCargoToTable( ti, false );
		endwhile;
		self.myMobileGenericAgent.setAllMultiMoveCargo( null );
	endif;
	
	if self.myMobileGenericAgent.myLocationsController &lt;&gt; null then
		self.txtLocation.text := self.myMobileGenericAgent.myLocationsController.getFullId();
		self.myMobileGenericAgent.setMyLocationsController(null);
		self.optPack.value := false;
		self.optMove.value := true;
		self.clickOptions();
	endif;
	if self.myMobileGenericAgent.myPackTi &lt;&gt; null then
		if self.myMobileGenericAgent.myPackTi.getLastTransOfType(TRANS_TYPE_PackComplete) &lt;&gt; null then
			//Has been pack completed. Don't re-display by default.
			self.txtParent.text := null;
		else
			self.txtParent.text := self.myMobileGenericAgent.myPackTi.id;
		endif;
		self.myMobileGenericAgent.setPackContainerDetails(	null,	//_stockBookingRef : CM_BookingRef;
																null,	//_stockBookingRefItem : CM_BookingRefItem;
																null,	//_exportBookingRef : CM_BookingRef;
																null,	//_exportBookingRefItem : CM_BookingRefItem;
																null	//_trackedItem : CM_TrackedItem
																);
		self.optMove.value := false;
		self.optPack.value := true;
		self.clickOptions();
	endif;
	
	isMove := self.optMove.value;
	isPack := self.optPack.value;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		self.txtCargoId.text := ti.id;
		if ti.isChild and isMove then
			errMsg := app.getErrorString(ERR_MOVING_CHILD) &amp; " (" &amp; ti.id &amp; ")";
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		elseif ti.isChild and isPack then
			errMsg := app.getErrorString1(Already_packed, ti.id );
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		else
			self.addCargoToTable( ti, true );
		endif;
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	endif;
	
	self.txtCargoId_lostFocus( self.txtCargoId );
	self.txtLocation_lostFocus( self.txtLocation );
	self.txtParent_lostFocus( self.txtParent );
	
	self.txtCargoId.setFocus();

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="827047ec-4162-4924-ba5b-3214b5f7a06d">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Move), app.getErrorString(Back), null, null, null );
	
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="89ccc24e-8a43-4437-afe0-125b5be10a76">
        <source>setupTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

begin

	self.tblProspects.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblProspects.rows := 1;
	self.tblProspects.columns := 2;
	self.tblProspects.fixedColumns := 0;
	self.tblProspects.accessColumn(1).width := (self.tblProspects.width * 0.20).Integer;
	self.tblProspects.accessColumn(1).inputType := Table.InputType_CheckBox;
	self.tblProspects.accessColumn(1).alignment := Table.Alignment_Center_Top;
	self.tblProspects.accessCell(1,2).alignment := Table.Alignment_Center_Top;
	self.tblProspects.accessCell(1,1).text := app.getErrorString(Selected);
	self.tblProspects.accessCell(1,2).text := app.getErrorString(Cargo_ID);
	self.tblProspects.selectMode := Table.SelectMode_None;
	self.tblProspects.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="803b5fe0-a5a6-4ebf-9fb6-1828067eb5fd">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020940, locale);
	lblCargoId.translateCaption(Xlat_0020941, locale);
	lblLocation.translateCaption(Xlat_0020942, locale);
	lblParent.translateCaption(Xlat_0020943, locale);
	optMove.translateCaption(Xlat_0020944, locale);
	optPack.translateCaption(Xlat_0020945, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
