    <JadeMethod name="chkMoveJob_click" id="49279c90-68ce-40cc-8ccb-607a2338b50a">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkMoveJob_click(checkbox: CheckBox input) updating;
// ---------------------------------------------------------------------------
// Created:     06 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	checked : Boolean;
begin
	
	checked := checkbox.value;
	self.txtNewJobID.enabled := true;// not checked; // PAR 25968 //epr TFS 830 they should be able to rename when job is moved
		
	//20 Apr 2012	NDL	Par	29411 
	self.tblCargoList.enabled := not checked;
	if checked then
		self.tblCargoList.selectAll();
		
		self.txtNewJobID.text := self.myVoyageJob.jobNum; // PAR 36850
	endif;
	
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
