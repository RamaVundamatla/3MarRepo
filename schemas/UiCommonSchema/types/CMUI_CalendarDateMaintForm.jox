    <JadeMethod name="doResize" id="bdd1c2d3-481a-4c30-851c-62256d813e27">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

	vLeft : Real;
	vWidth : Real;
	vHeight : Real;

begin

	inheritMethod();
	
	self.grpBaseData.top := 1;
	
	vLeft := 1;
	self.grpBaseData.left := vLeft;
	
	vWidth := self.width - 10;
	self.grpBaseData.width := vWidth;
	
	vHeight :=  self.clientHeight - 2;
	self.grpBaseData.height := vHeight;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="b7be52f3-6c79-4689-8cf7-76f6548526db">
        <updating/>
        <source>doSave()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

	calendarDateProxy : CM_CalendarDate;
	loadState : Boolean;
	date : Date;
	description : String;
	year : Integer;
	startTime : Time;
	endTime : Time;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;
	theReturn : Integer;
	errString : String;

begin

	if self.myCalendarDate = null then
		create calendarDateProxy transient;
	else
		calendarDateProxy := self.myCalendarDate.pxyGetProxyObject();
		if calendarDateProxy = null then
			app.cmsBeginLoad(loadState);
			calendarDateProxy := self.myCalendarDate.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
		endif;
	endif;
	
	date := txtDate.getDate;
	if not date.isValid then
	//	errString := app.getErrorString1(REQUIRED_FIELD, lblDate.caption);
		errString := app.getErrorString1(Input_required_field_Required, lblDate.caption); // cnwdb2	PAR 35364

		app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		txtDate.setFocus();
		return;
	endif;
	
	description := txtDescription.text.trimBlanks;
	if description = null then
	//	errString := app.getErrorString1(REQUIRED_FIELD, lblDescription.caption);
		errString := app.getErrorString1(Input_required_field_Required, lblDescription.caption); // cnwdb2	PAR 35364
		app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		txtDescription.setFocus();
		return;
	endif;
	
	startTime := self.txtTimeFrom.getTime;
	endTime := self.txtTimeTo.getTime;
	
	year := date.year;
	
	calendarYear := self.myCalendar.allCalendarYears.getAtKey(year);
	
	if calendarYear = null then
	
		// have to create a new calendar year first...
		create calendarYearProxy transient;
		calendarYearProxy.setProxy( year, self.myCalendar);
	
		while true do
			app.myTrxCA.trxCreateCalendarYear(calendarYearProxy, calendarYear, app.myPassport, false);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				delete calendarYearProxy;
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
		
	endif;
	
	// set up the calendar and calendar year on the calendar date transient.
	calendarDateProxy.setProxy(	date,	//_date : Date;
								description,	//_description : String;
								self.myCalendar,	//_myCalendar : CM_Calendar;
								calendarYear,	//_myCalendarYear : CM_CalendarYear
								calendarDateProxy.dataSource	//_dataSource : Integer
								);
								
	calendarDateProxy.setStartEndTime( startTime, endTime );
							
	
	while true do
		if self.myCalendarDate = null then
			app.myTrxCA.trxCreateCalendarDate(calendarDateProxy, self.myCalendarDate, app.myPassport);
		else
			app.myTrxUA.trxUpdateCalendarDate(calendarDateProxy, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			delete calendarDateProxy;
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	self.myCalendar.causeEvent(EVENT_Calendar_Update, true, self.myCalendar);
	
	self.unloadForm();

epilog

	app.cmsEndLoad(loadState);
	delete calendarDateProxy;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCalendarDate" id="b23528f4-ffa6-4514-a094-d9ce0e8f2e3f">
        <source>populateCalendarDate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

begin

	self.txtTimeFrom.enabled := self.myCalendar.hasTime;
	self.txtTimeTo.enabled := self.myCalendar.hasEndTime;

	if self.myCalendarDate = null then
		self.txtDate.setDate(null);
		self.txtDescription.text := null;
		self.txtTimeFrom.setTime(null);
		self.txtTimeTo.setTime(null);
		
	else
		self.txtDate.setDate(self.myCalendarDate.date);
		self.txtDescription.text := self.myCalendarDate.description;
		if self.myCalendar.hasTime then
			self.txtTimeFrom.setTime(self.myCalendarDate.startTime);
			if self.myCalendar.hasEndTime then
				self.txtTimeTo.setTime(self.myCalendarDate.endTime);
			endif;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCalendar" id="aa711648-0a1f-493f-80ad-afc3af9e14a9">
        <updating/>
        <source>setMyCalendar( _calendar : CM_Calendar; _calendarDate : CM_CalendarDate ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

begin

	self.myCalendar := _calendar;
	self.myCalendarDate := _calendarDate;
	
	if self.myCalendar &lt;&gt; null then
		lblCalendar.caption := self.myCalendar.description;
	endif;
	
epilog

end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_calendarDate" type="CM_CalendarDate"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="68812b00-4cdb-4ee1-adc9-9937fd510d4f">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

begin

	self.width := 450;
	self.height := 228;

	self.doResize();
	self.populateCalendarDate();
	
	inheritMethod();
	
	self.minimumWidth := 450;
	self.minimumHeight := 228;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="059a2618-304a-43e3-9216-4d2a712ae31c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015922, locale);
	btnCancel.translateCaption(Xlat_0015923, locale);
	btnSave.translateCaption(Xlat_0015924, locale);
	lblCalendar.translateCaption(Xlat_0015925, locale);
	lblDate.translateCaption(Xlat_0015926, locale);
	lblDescription.translateCaption(Xlat_0015927, locale);
	lblEndTime.translateCaption(Xlat_0015928, locale);
	lblStartTime.translateCaption(Xlat_0015929, locale);
end;</source>
    </JadeMethod>
</GUIClass>
