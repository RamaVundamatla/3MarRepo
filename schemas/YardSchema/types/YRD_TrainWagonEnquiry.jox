    <JadeMethod name="buildComboAreas" id="a9656e0b-d4c4-4a1a-a87e-c8013f116f18">
        <source>buildComboAreas();
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx				: Integer;
	lRail				: CM_TerminalArea;
	termAreaDict				: CM_TAByIdDict;
begin
	self.cmbAreas.clear;
	termAreaDict := self.myTerminal.getAllTAsOfType(TA_TYPE_RAILWAY_TRACK);

	foreach lRail in termAreaDict do // RR1 RR2
		idx := self.cmbAreas.addItem(lRail.id);
		self.cmbAreas.itemObject[idx] := lRail;
	endforeach;
	
	if self.cmbAreas.listCount &gt; 0 then
		self.cmbAreas.listIndex := 1;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboPosition" id="346d7fd1-a0c1-4a8d-b026-e3319305fdf3">
        <updating/>
        <source>buildComboPosition(pRail : CM_Rail) updating;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRow, lCol,idx, firstMT	: Integer;
	lID				: String;
	lRailLine	: CM_RailLine;
begin
	self.cmbPosition.clear;
	if pRail = null then
		return;
	endif;
	
	foreach lRow in 1 to  pRail.allRailLinesByIndex.size do
		lRailLine := pRail.allRailLinesByIndex[lRow];
		foreach lCol in 1 to lRailLine.maximumWagons do
			lID := lRailLine.getIdString.trimBlanks &amp; ' ' &amp; lCol.String.padLeadingZeros(2);
			idx := self.cmbPosition.addItem(lID);
			self.cmbPosition.itemObject[idx] := lRailLine;
			self.cmbPosition.itemData[idx] := lCol;
			
		endforeach;
	endforeach;
	if self.cmbPosition.listCount &gt; 0 and firstMT &gt; 0 then
		self.cmbPosition.listIndex := firstMT;
	endif;
end;</source>
        <Parameter name="pRail" type="CM_Rail"/>
    </JadeMethod>
