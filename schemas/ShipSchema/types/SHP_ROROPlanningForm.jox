    <JadeMethod name="doGetQuantity" id="f6156bd8-5e5f-4960-a461-25eb6026aa23">
        <updating/>
        <source>doGetQuantity(_voyAllocation : CM_VoyageAllocation; _qtyType : Integer; _req : CM_RORORequest) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars
	theReturn : Integer;
	lForm : CMUI_GetData;
begin

	self.myCurrentAllocation := _voyAllocation;

	if _voyAllocation = null then
		return;
	endif;
	
	create lForm;
	lForm.centreWindow;
	app.mousePointer := MousePointer_Default;
	
	lForm.lblTextCaption := app.getErrorString(Quantity).cnEcFirstToUpper &amp; ":";
	if _req = null then
		lForm.txtData.text := "1";
		self.myCurrentRORORequest := null;
	else
		lForm.txtData.text := _req.quantity.Integer.String; // PAR 28985
		self.myCurrentRORORequest := _req;
	endif;
//	lForm.txtData.maxLength := 3;
	lForm.txtData.maxLength := 9;	//06 Dec 2019	NDL	TFS 46875 - make same as Voyage Ops call for quantity
	lForm.txtData.dataType := TextBox.DataType_Numeric;
	lForm.txtData.decimals := 0;		
	lForm.myCaller := self;
	//lForm.bigSize := true;
	lForm.formCaption := app.getErrorString(Quantit_load_colour_coding);
	lForm.type := _qtyType; // PAR 28985 self.GetData_Quantity;
	lForm.doResize;
	lForm.show;
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
        <Parameter name="_qtyType" type="Integer"/>
        <Parameter name="_req" type="CM_RORORequest"/>
    </JadeMethod>
