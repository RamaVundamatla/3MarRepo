    <JadeMethod name="getTwinController" id="a0df9e6b-c627-4cee-b3d7-99c7359b85b1">
        <source>getTwinController() : CM_SlotController;
//05 June 2008	cnwdw1	
// If this is a twin request then return the matching twin controller
vars
	aftSlot : CM_SlotController;
begin
	if self.isTwinLift(true) then
		// starboard twinlift
		aftSlot := self.mySlotControllerLoad.myAftSlot;
		if aftSlot &lt;&gt; null and aftSlot.mySlotRequestLoad &lt;&gt; null and aftSlot.mySlotRequestLoad.isTwinLift(false) then
			return aftSlot;
		endif;
		return self.mySlotControllerLoad.myForwardSlot;
	else
		if self.isTwinLift(false) then
			// port twinlift
			aftSlot := self.mySlotControllerLoad.myAftSlot;
			if aftSlot &lt;&gt; null and aftSlot.mySlotRequestLoad &lt;&gt; null and aftSlot.mySlotRequestLoad.isTwinLift(true) then
				return aftSlot;
			endif;
			return self.mySlotControllerLoad.myForwardSlot;
		endif;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
