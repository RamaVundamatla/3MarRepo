    <JadeMethod name="tCargoGroupAssignAction" id="cb2e267b-e444-4c80-8430-0dc7bcf0972f">
        <source>tCargoGroupAssignAction();
//
//11 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalCargoGroupAssign";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	cargGroupAiignmebt : CM_CargoGroupAssignment;
	str : String;
	str2 : String;
begin
	passportObj := app.myPassport;
	self.deleteCargoGroupAassignment(self.getTerminal, "GROUP01");
	self.deleteCargoGroupAassignment(self.getTerminal, "GROUP02");
	self.deleteCargoGroup("GROUP01");
	self.deleteCargoGroup("GROUP02");
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoGroupAssign xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoGroupAssign.xsd"&gt;
	&lt;AllCargoGroupAssignment&gt;
		&lt;CargoGroupAssignment&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description&gt;ISO Container&lt;/description&gt;
			&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
			&lt;id&gt;GROUP01&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;allCargoIds&gt;CONT1 CONT2 CONT3&lt;/allCargoIds&gt;
		&lt;/CargoGroupAssignment&gt;
		&lt;CargoGroupAssignment&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description&gt;ISO Container&lt;/description&gt;
			&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
			&lt;id&gt;GROUP02&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;allCargoIds&gt;&lt;/allCargoIds&gt;
		&lt;/CargoGroupAssignment&gt;
	&lt;/AllCargoGroupAssignment&gt;
&lt;/JMTInternalCargoGroupAssign&gt;';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 2, "incorrect number of EDI trackedItems");

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoGroupAssign xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoGroupAssign.xsd"&gt;
  &lt;AllCargoGroupAssignment&gt;
    &lt;CargoGroupAssignment&gt;
      &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
      &lt;description&gt;ISO Container&lt;/description&gt;
      &lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
      &lt;id&gt;GROUP01&lt;/id&gt;
      &lt;messageMode&gt;D&lt;/messageMode&gt;
      &lt;allCargoIds&gt;&lt;/allCargoIds&gt;
	&lt;/CargoGroupAssignment&gt;
	&lt;CargoGroupAssignment&gt;
		&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
		&lt;description&gt;ISO Container&lt;/description&gt;
		&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
		&lt;id&gt;GROUP02&lt;/id&gt;
		&lt;messageMode&gt;D&lt;/messageMode&gt;
		&lt;allCargoIds&gt;&lt;/allCargoIds&gt;
	&lt;/CargoGroupAssignment&gt;
  &lt;/AllCargoGroupAssignment&gt;
/JMTInternalCargoGroupAssign&gt;';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 2, "incorrect number of EDI trackedItems");

end;
</source>
    </JadeMethod>
    <JadeMethod name="tCargoGroupNotifiedAction" id="68a3ca5d-e52c-4374-9ce8-a8235dfb3637">
        <source>tCargoGroupNotifiedAction();
//
//11 August 2017	jlgrs1	Initial creation
//
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
constants
	USER_DEF_NAME : String = "JMTInternalCargoGroupNotified";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
begin
	passportObj := app.myPassport;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoGroupNotified xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoGroupNotified.xsd"&gt;
	&lt;AllCargoGroup&gt;
		&lt;CargoGroup&gt;
			&lt;maxWeight&gt;10000&lt;/maxWeight&gt;
			&lt;minWeight&gt;1000&lt;/minWeight&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;defaultLocation&gt;UTBSCG&lt;/defaultLocation&gt;
			&lt;description&gt;ISO Container&lt;/description&gt;
			&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
			&lt;id&gt;Group01&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;Stuff&lt;/remarks&gt;
			&lt;allPreAssignedCargoIds&gt;CONT1 CONT2 CONT3&lt;/allPreAssignedCargoIds&gt;
		&lt;/CargoGroup&gt;
	&lt;/AllCargoGroup&gt;
&lt;/JMTInternalCargoGroupNotified&gt;';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);

	foreach str in ediFileObj.ediData.allEDITrackedItems.first.CM_EDICargoGroupNotified.allPreAssignedCargoIds do
		str2 := str2&amp;str&amp;' ';
	endforeach;
	self.assertEqualMsg(str2, "CONT1 CONT2 CONT3 ", "incorrect allPreAssignedCargoIds");

end;
</source>
    </JadeMethod>
    <JadeMethod name="tCargoOnSite" id="1840f36a-abf6-4ced-aaa7-a814f87d6443">
        <source>tCargoOnSite();
//
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
//26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName = 'VOY002BOL';
	ShipName = 'Ship001';
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalCargoOnSite";
	CONTAINER01 : String = "UTCL0111";
	CONTAINER02 : String = "UTCL0121";
	CONTAINER03 : String = "UTCL0131";
	CONTAINER04 : String = "UTCL0141";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	tempStr : String;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiCargoByAllowPartial, true);
	self.deleteContainer(CONTAINER01);
	self.deleteContainer(CONTAINER02);
	self.deleteContainer(CONTAINER03);
	self.deleteContainer(CONTAINER04);
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(ShipName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCargoOnSite xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoOnSite.xsd"&gt;
	&lt;AllCargoOnSite&gt;
		&lt;CargoOnSite&gt;
			&lt;weight&gt;2000.0000&lt;/weight&gt;
			&lt;site&gt;1&lt;/site&gt;
			&lt;bol&gt;BOL01&lt;/bol&gt;
			&lt;bookingRef&gt;BK01&lt;/bookingRef&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity&gt;MT&lt;/commodity&gt;
			&lt;companyCode&gt;DFBU&lt;/companyCode&gt;
