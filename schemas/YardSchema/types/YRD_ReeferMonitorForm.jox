        <updating/>
        <source>mnuContainerEnquiry_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	obj	: CM_TrackedItem;
	objArray : ObjectArray;
begin
	if tblData.row &gt; tblData.fixedRows then
		obj := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
		
		if obj &lt;&gt; null then
			//6/11/2009 cnwdz2 21202
		//	self.myAssistant.showCargoEnquiryForm(obj, self.myMasterMenuAction, true, false);
			objArray := self.tblData.allSelectedObjects;
			self.myAssistant.showCargoEnquiryForTIs(objArray.first().CM_TrackedItem, objArray, self.myMasterMenuAction, false);
		endif;		
	endif;
	
end;</source>
