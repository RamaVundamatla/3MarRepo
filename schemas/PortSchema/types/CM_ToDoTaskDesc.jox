    <JadeMethod name="canUserAdd" id="f103d3e5-b39d-4b7b-a268-7b2c193f35c8">
        <source>canUserAdd(_passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if (not _passport.myUser.canAddRemoveTodoTask(_passport.myTerminal, self)) then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ErrToDoTaskAdd, self.description, null, null);
		return false;		
	endif;
	
	return true;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkMandatoryResourceGrps" id="fb5f96ad-f762-4d09-8f22-650f320eedc8">
        <source>checkMandatoryResourceGrps(_resourceUsageProxys : CM_ResourceTypeUsageSet) protected;
/*

Purpose:			Validates that resources for the task's mandatory resource groups have been provided

Parameters:			_resourceUsageProxys	CM_ResourceTypeUsageSet	The resource usages to use for checking

Return Value:		NONE

Date				Who		Reason
12 December 2023	navpw1	Initial creation TFS: 58758 (60742)
30 August	2024	navcs2	Bug 64746: EUP | VAS - Without adding resources for the mandatory resource group, able to complete the job in Thin Client
*/

vars
	taskCriteria				: CM_TaskCriteria;
	resourceTypeGroup			: CM_ResourceTypeGroup;
	resourceUsageProxy			: CM_ResourceTypeUsage;
	mandatoryGroupsArr			: ObjectArray;
	strResourceTypeGroupsError	: String;
	
begin
	
	if _resourceUsageProxys = null then													// 30 August	2024	navcs2	Bug 64746
		return;																			// 30 August	2024	navcs2	Bug 64746
	endif;																				// 30 August	2024	navcs2	Bug 64746
	
	taskCriteria := self.allTaskCriteria.getAtKeyGeq(app.myPassport.myTerminal, self.code);	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	
	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	if taskCriteria = null or 
		app.myPassport.myTerminal.code &lt;&gt; taskCriteria.myTerminal.code or //The terminal could be different, as this is first keyed by terminal. Was cuasing issues elsewhwere in code
		taskCriteria.myToDoTaskDesc = null or 
		taskCriteria.myToDoTaskDesc.code &lt;&gt; self.code 
	then
		return;
	endif;
	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	
	if taskCriteria = null then
		return;
	endif;
	
	create mandatoryGroupsArr transient;
	
	taskCriteria.allMandatoryResourceGroups.copy(mandatoryGroupsArr);
	
	foreach resourceUsageProxy in _resourceUsageProxys do
		resourceTypeGroup := resourceUsageProxy.myResourceType.myResourceTypeGroup;
		
		if not mandatoryGroupsArr.includes(resourceTypeGroup) then
			continue;
		endif;
		
		mandatoryGroupsArr.remove(resourceTypeGroup);
		
	endforeach;
	
	if mandatoryGroupsArr.isEmpty then
		return;
		
	endif;
	
	foreach resourceTypeGroup in mandatoryGroupsArr as CM_ResourceTypeGroup do
		strResourceTypeGroupsError &amp;= resourceTypeGroup.code &amp; Comma &amp; Space;
	endforeach;
	
	app.raiseCMException2(Mandatory_res_type_grps_miss, self.description, strResourceTypeGroupsError.stripTrailingChar(Comma), null, null);
	
epilog
	delete mandatoryGroupsArr;
	
end;</source>
        <access>protected</access>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
    </JadeMethod>
    <JadeMethod name="checkMandatoryResources" id="07d63f66-b0cc-430f-943f-22465ee64bd9">
        <source>checkMandatoryResources(_resourceUsageProxys : CM_ResourceTypeUsageSet) protected;
/*

Purpose:			Validates that mandatory resources have been provided for the task

Parameters:			_resourceUsageProxys	CM_ResourceTypeUsageSet	The resource usages to use for checking

Return Value:		NONE

Date				Who		Reason
12 December 2023	navpw1	Initial creation TFS: 58758 (60742) - code moved here from validateResourceUsage

*/

vars
	resType				: CM_ResourceType;
	resUsage		    : CM_ResourceTypeUsage;
	mandatoryArray		: ObjectArray;
	resourceTypes		: CM_ObjectSetActual;
	
begin
	create mandatoryArray transient;
	
	if not self.hasMandatoryResources then
		return;
		
	endif;
	
	resourceTypes := self.allResourceTypes;
	
	foreach resType in resourceTypes as CM_ResourceType do
		if not resType.mandatory then
			continue;
		endif;
		
		mandatoryArray.add(resType);
		
	endforeach;
	
	if _resourceUsageProxys = null or  _resourceUsageProxys.isEmpty()then
		app.raiseCMException1(Usage_resou_categ_not_been_rec,self.description &amp; " - " &amp; 
							  mandatoryArray.listString(Comma,CM_ResourceType::code.name), null, null);
		return;
	endif;
	
	foreach resUsage in _resourceUsageProxys do
		resType := resUsage.myResourceType;
		
		if not mandatoryArray.includes(resType) then
			continue;
			
		endif;
		
		mandatoryArray.remove(resType);
		
	endforeach;
	
	if mandatoryArray.isNotEmpty then
		app.raiseCMException1(Usage_resou_categ_not_been_rec,self.description &amp; " - " &amp; 
							  mandatoryArray.listString(Comma,CM_ResourceType::code.name), null, null);
	endif;
	
epilog
	delete mandatoryArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="3576caa2-a7e7-4cf5-8b74-94c47d912f13">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : Integer;
	todo : CM_ToDoTaskDesc;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).Integer; 
	
	if code &gt; 0 then
		todo := app.myRoot.allToDoTaskDescriptions.getAtKey( code );
	endif;

epilog

	return todo;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="02f2e586-399a-4ffc-8d7c-c4e7f63e3156">
        <updating/>
        <source>delete() updating;
// cnwrs1 june 2006 was missing
//24 Aug 2023 navma1 Defect 60009: 59284 - EUP | FR - VAS Work Order Transactions - CMQFs not cleaned up if TODO tasks deleted 
vars
	
	//15 Jul 2016	NDL	TFS 2329
	iter   : Iterator;
	cmqfTT : CMQF_TerminalTIs;
	cmqfRU : CMQF_ResourceUsage;
	cmqfWO : CMQF_WOTransactions;
begin

	iter := CMQF_TerminalTIs.instances.createIterator;
	while iter.next(cmqfTT) do
		if cmqfTT.allTasks.includes(self) then
			cmqfTT.allTasks.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_ResourceUsage.instances.createIterator;
	while iter.next(cmqfRU) do
		if cmqfRU.allToDoTaskDescs.includes(self) then
			cmqfRU.allToDoTaskDescs.remove(self);
		endif;
	endwhile; 
	delete iter;

	iter := CMQF_WOTransactions.instances.createIterator;		//24.08.2023  navma1 #60009
	while iter.next(cmqfWO) do
		if cmqfWO.allToDoTaskDescs.includes(self) then
			cmqfWO.allToDoTaskDescs.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="786d73f8-33c8-4750-9d10-2ca053d69244">
        <source>getAuditText(): String;

vars
	txt		: String;
	tmpStr	: String;
	cargoType	: CM_CargoType;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach cargoType in self.allCargoTypes do
		if tmpStr = null then
			tmpStr := cargoType.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; cargoType.description;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Cargo Types' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2c4e6a89-b001-4a8d-847b-5add6f2331fa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Apr 2014	cnwdb2		PAR #33977  
//31 Oct 2022 navma1 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
// ---------------------------------------------------------------------------


vars
	transType : CM_TransactionType;
	eventType : CM_EventType;
begin
	if _attrName = ETRow_TrxToCreateOnCreation then
		if self.type = TODO_TYPE_GROUP_TI // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		or self.type = TODO_TYPE_GROUP_CARGOGROUP then // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
			transType:=self.getTrxTypeOnCreation();
			
			if transType &lt;&gt; null	then		
				return transType.description;
			endif;
		else // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
			eventType := app.myRoot.allEventTypesByType[self.trxTypeOnCreation];
			if eventType &lt;&gt; null then
				return eventType.description;
			endif;
		endif;
		
		return null; 
	elseif _attrName = ETRow_TransactionToCreate then
		if self.myEventType &lt;&gt; null then // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
			return self.myEventType.description; // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		endif;
		
		transType:=self.getTrxTypeOnCompletion();
		
		if transType &lt;&gt; null	then		
			return transType.description;
		endif;
		return null ; 
	elseif _attrName = ETRow_Type then       						//31/10/2022 navds20 #56634[54259]
		return app.getToDoTaskIntToString(self.type); 				//31/10/2022 navds20 #56634[54259]
	
	endif ; 		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
