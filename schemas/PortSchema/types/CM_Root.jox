									'Invoice', sa);	

	self.setupInvStatusEmailDefault(PINEmail_InvProcPel1Offset + CM_Invoice.INVOICE_PREPEND, // ie. 348
									app.invoiceStatusEnumToString(CM_InvoiceProcessPel1.firstInstance, CM_Invoice.INVOICE_PREPEND),
									'Invoice', sa);

	self.setupInvStatusEmailDefault(PINEmail_InvProcPel1Offset + CM_Invoice.INVOICE_DISPUTED, // ie. 349
									app.invoiceStatusEnumToString(CM_InvoiceProcessPel1.firstInstance, CM_Invoice.INVOICE_DISPUTED),
									'Invoice', sa);

	self.setupInvStatusEmailDefault(PINEmail_InvProcPel1Offset + CM_Invoice.INVOICE_PENDING_REVERSE, // ie. 350
									app.invoiceStatusEnumToString(CM_InvoiceProcessPel1.firstInstance, CM_Invoice.INVOICE_PENDING_REVERSE),
									'Invoice', sa);

	//navra1 - TFS 54090 - CR - 61386, Task - 61564 - 29th Nov 2023
	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_OPEN,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_OPEN),
									'Invoice', sa);

	self.setupInvStatusEmailDefault(PINEmail_InvProcAPIOffset + CM_Invoice.INVOICE_PENDING,
									app.invoiceStatusEnumToString(CM_InvoiceProcessInvoiceAPI.firstInstance, CM_Invoice.INVOICE_PENDING),
