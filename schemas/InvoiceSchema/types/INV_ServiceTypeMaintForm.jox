    <JadeMethod name="setMyCurrentBank" id="9eae0672-4478-4106-8862-fb07a49b1cc2">
        <updating/>
        <source>setMyCurrentBank(_bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

