/*

Purpose:			Creates a new GateScan Record from Proxy object passed in and gives a new gate scan record out

Parameters:			_pxyGateScanRecord	CM_GenericGateScanRecord	Proxy gate scan record to create real object from (Input meaning it gets passed in as a constant)
					_newGateScanRecord	CM_GenericGateScanRecord	Real gate scan record created (Output meaning it is passed outwards)
					_passport			CM_Passport					Passport to use for our Trx that holds errors and other useful data

Return Value:		None

Date		Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateGateScanRecord(_pxyGateScanRecord, _newGateScanRecord, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
