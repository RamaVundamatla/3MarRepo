    <JadeMethod name="initializeForActivity" id="b261dbba-7bb4-45b4-9b49-04b64eba0a87">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
01 Sep 2021 navpw1 ChangeRequest 51853: MTN - Opsview Container - Gate
*/

vars
	shift 	: CM_Shift;
	job   	: CM_Job;
	voyage  : CM_Voyage;
	train : CM_Train;
	delay   : CM_Delay;
	obj     : CM_Object;
	vvr : CM_VehicleVisitRecord;
begin
	inheritMethod(_any, _ewsOpsView);

	 // ### TFS 53569 10MAY2022 NAVAB1 moved the delete to the top
	self.tableName				:= self.Xps_craneshift;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey			 := self.generateFullGKey(_any, "");
		self.pkey            := self.generateFullGKey(_any, "");
		self.owner_pow		 := self.generateFullGKey(_any, "");
		self.owner_pow_gkey	 := self.generateFullGKey(_any, "");
		return;
	endif;
	
	
	if _any.isKindOf(CM_Job) then // ### TFS 53569 10MAY2022 NAVAB1
		job 	:= _any.CM_Job; // ### TFS 53569 10MAY2022 NAVAB1
		job.initializeForActivity(_ewsOpsView,self); // ### TFS 53569 10MAY2022 NAVAB1
	elseif  _any.isKindOf(CM_Delay) then // ### TFS 53569 10MAY2022 NAVAB1
		delay 	:= _any.CM_Delay; // ### TFS 53569 10MAY2022 NAVAB1
		delay.initializeForActivity(_ewsOpsView,self); // ### TFS 53569 10MAY2022 NAVAB1
	endif;
	
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
