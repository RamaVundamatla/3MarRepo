    <JadeMethod name="getTEU20" id="976561b9-fb7b-4bf4-855a-5719befdcf1e">
        <source>getTEU20() : Decimal;
/*

Date		Who		Reason
09 July 2015	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
begin	
	ct:=self.getCargoType;
	if ct.isContainer then
		return self.total20 * ct.getTEUConversionValue(TEUConversionIndex20);
	endif;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
