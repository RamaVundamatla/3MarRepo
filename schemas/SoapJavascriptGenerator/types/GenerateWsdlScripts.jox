<Class name="GenerateWsdlScripts" id="5a1e91aa-d34f-461f-87f0-109a30e25f0b">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="richinternettoolset"/>
    <PrimAttribute name="directory" id="3d952fd8-8eb6-4168-80d4-93e3ef77d167">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="namespace" id="c0f189cc-ddb5-4117-9e06-0f2527e2a2ec">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="webservices" id="0e46db16-286b-4d6a-8724-2ad0e1253bdc">
