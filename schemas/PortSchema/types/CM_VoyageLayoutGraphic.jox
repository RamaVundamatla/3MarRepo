	&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;6&lt;/TP&gt;&lt;X1&gt;1&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;1&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;StartX&gt;0&lt;/StartX&gt;&lt;EndX&gt;0&lt;/EndX&gt;&lt;StartY&gt;0&lt;/StartY&gt;&lt;EndY&gt;0&lt;/EndY&gt;&lt;/CMD&gt;
	&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;7&lt;/TP&gt;&lt;X1&gt;9&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;106&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;StartX&gt;0&lt;/StartX&gt;&lt;EndX&gt;0&lt;/EndX&gt;&lt;StartY&gt;0&lt;/StartY&gt;&lt;EndY&gt;0&lt;/EndY&gt;&lt;/CMD&gt;
	&lt;/CRN1&gt;";
vars
	
	
begin
	//test if the commands have already been created
	if self.allCommandsAft.size &gt; 0 then
		return;
	endif;
		
	self.setXMLData(NullVoyageGraphic);

end;</source>
    </JadeMethod>
    <JadeMethod name="drawFills" id="ac4053cf-63aa-4d09-9053-e5f498b4b2ea">
        <source>drawFills(_frame : Frame input; _type : Integer; _scale : Real;_offsetX, _offsetY : Integer;_flippedH : Boolean);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aGraphic : CM_Graphic;
	theCommands : CM_GraphicArray;
	aCommand : CM_GraphicCommand;
	theX, theY : Integer;
	maxX,oMaxX : Integer;
begin
	theCommands := self.getCommands(_type);
	if _type = self.INDEX_AFT then
		oMaxX := (self.maxXAft * _scale).Integer ;
	elseif _type = self.INDEX_FORWARD then
		oMaxX := (self.maxXForward * _scale).Integer ;
	else
		oMaxX := (self.maxXBridge * _scale).Integer ;
	endif;
//_frame.drawRectangle(_offsetX,20,_offsetX + 2,22,Red); //for testing
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_FILL then
			theX := (aCommand.x1 * _scale).Integer + _offsetX;
			theY := (aCommand.y1 * _scale).Integer + _offsetY;
		
			if _flippedH then
				theX := (aCommand.x1 * _scale).Integer;
				theX := oMaxX - theX;
				theX := theX +  _offsetX;
				theX := theX - oMaxX;
			endif;


			_frame.drawFillColor := aCommand.lineColour;
			_frame.drawFloodFill(theX,theY, 0,Black);
//			_frame.drawRectangle(theX,theY,theX + 2,theY - 2,Red); //for testing
		endif;
	endforeach;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawPolygonOLD" id="a75b2b84-5f6f-416d-8e06-050f2ded5048">
        <source>drawPolygonOLD(_frame : Frame; _type : Integer; _scale : Real;_offsetX, _offsetY : Integer;_flippedH : Boolean; _stretchOffset : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aGraphic : CM_Graphic;
	theCommands : CM_GraphicArray;
	aCommand : CM_GraphicCommand;
	thePoints : RealArray;
	theX, theY : Integer;
	stretchOffset,stretchX, stretchY : Integer;
	maxX : Integer;
begin
	theCommands := self.getCommands(_type);
	self.getStretchXY(_type,stretchX, stretchY); // the point from which to stretch
	if stretchY &gt; 0 then
		stretchOffset := _stretchOffset;
		/*
		if _type = self.INDEX_AFT then
			stretchOffset := self.stretchOffsetAft;
		elseif _type = self.INDEX_FORWARD then
			stretchOffset := self.stretchOffsetForward;
		else
			stretchOffset := 0;
		endif;
		*/
	endif;
	if _type = self.INDEX_AFT then
		maxX :=  (_scale * self.maxXAft).Integer; // + _offsetX;
	elseif _type = self.INDEX_FORWARD then
		maxX :=  (_scale * self.maxXForward).Integer; // + _offsetX;
	else
		maxX :=  (_scale * self.maxXBridge).Integer; // + _offsetX;
	endif;
	
	create thePoints transient;
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_STOP then
			_frame.drawPolygon(thePoints,aCommand.lineColour);
			thePoints.clear;
		elseif aCommand.type = CM_GraphicCommand.TYPE_DRAW then
			if _flippedH then
				theX := (_scale * aCommand.x1).Integer + 1;
			else
				theX := (_scale * aCommand.x1).Integer + _offsetX;
			endif;
			theY := (_scale * aCommand.y1).Integer + _offsetY;
			
			
			if _flippedH then
				theX := maxX - theX;
				theX := theX +  _offsetX;
				theX := theX - maxX;
			endif;
			if aCommand.y1 &gt; stretchY then
				theY := theY + stretchOffset;
			endif;

			thePoints.add(theX);
			thePoints.add(theY);
			
		endif;
	endforeach;
epilog
	delete thePoints;
end;</source>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_stretchOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawPolygonsLocal" id="a17e397b-d7c4-4480-b4a0-77620bec6618">
        <source>drawPolygonsLocal(_frame : Frame; _type : Integer; _scale : Real;_offsetX, _offsetY : Integer;_flippedH : Boolean; _stretchOffset : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	maxX : Integer;
begin
	if _type = self.INDEX_AFT then
		maxX :=  (_scale * self.maxXAft).Integer; // + _offsetX;
	elseif _type = self.INDEX_FORWARD then
		maxX :=  (_scale * self.maxXForward).Integer; // + _offsetX;
	elseif _type = self.INDEX_BRIDGE then
		maxX :=  (_scale * self.maxXBridge).Integer; // + _offsetX;
	elseif _type = self.INDEX_CRANE1 then
		maxX :=  (_scale * self.maxXCrane1).Integer; // + _offsetX;
	else
		
	endif;
	self.drawPolygons(_frame,_type,_scale,_offsetX,_offsetY,_flippedH,_stretchOffset, maxX, NullColour);
end;</source>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_stretchOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCommands" id="e81215b5-5019-4f1d-91f6-6bdcf3a32375">
        <source>getCommands(theType : Integer) : CM_GraphicArray;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theCommands : CM_GraphicArray;
begin
	if theType = self.INDEX_AFT then
		theCommands := self.allCommandsAft;
	elseif theType = self.INDEX_BRIDGE then
		theCommands := self.allCommandsBridge;
	elseif theType = self.INDEX_FORWARD then
		theCommands := self.allCommandsForward;
	elseif theType = self.INDEX_CRANE1 then
		theCommands := self.allCommandsCrane1;
	endif;
	
	return theCommands;

end;</source>
        <Parameter name="theType" type="Integer"/>
        <ReturnType type="CM_GraphicArray"/>
    </JadeMethod>
    <JadeMethod name="getFirstLastPoints" id="e84a54b5-a883-419b-b0fa-a303c0dcbd28">
        <source>getFirstLastPoints(theType : Integer; _firstX,_firstY,_lastX,_lastY : Integer output;_flipH : Boolean) ;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		These points are used to line the graphic up on the GUI
//
// ---------------------------------------------------------------------------

vars
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	theCommands : CM_GraphicArray;
begin
	if theType = self.INDEX_AFT then
		theCommands := self.allCommandsAft;
	elseif theType = self.INDEX_CRANE1 then
		theCommands := self.allCommandsCrane1;
	elseif theType = self.INDEX_BRIDGE then
		theCommands := self.allCommandsBridge;
	elseif theType = self.INDEX_FORWARD then
		theCommands := self.allCommandsForward;
	endif;
	
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_FIRST_POINT then
			_firstX := aCommand.x1;
			_firstY := aCommand.y1;
			
		endif;
		if aCommand.type = CM_GraphicCommand.TYPE_LAST_POINT then
			_lastX := aCommand.x1;
			_lastY := aCommand.y1;
		endif;
	endforeach;

	if _flipH then
		// reverse the X by taking it away from the maxX of the graphic
		if theType = self.INDEX_AFT then
			_firstX := self.maxXAft - _firstX;
			_lastX := self.maxXAft - _lastX;
		elseif theType = self.INDEX_CRANE1 then
			_firstX := self.maxXCrane1 - _firstX;
			_lastX := self.maxXCrane1 - _lastX;
		elseif theType = self.INDEX_BRIDGE then
			_firstX := self.maxXBridge - _firstX;
			_lastX := self.maxXBridge - _lastX;
		elseif theType = self.INDEX_FORWARD then
			_firstX := self.maxXForward - _firstX;
			_lastX := self.maxXForward - _lastX;
		endif;
	endif;
end;</source>
        <Parameter name="theType" type="Integer"/>
        <Parameter name="_firstX" type="Integer" usage="output"/>
        <Parameter name="_firstY" type="Integer" usage="output"/>
        <Parameter name="_lastX" type="Integer" usage="output"/>
        <Parameter name="_lastY" type="Integer" usage="output"/>
        <Parameter name="_flipH" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStretchXY" id="51b59f96-9eb3-4b4b-8f60-12fe15802cac">
        <source>getStretchXY(theType : Integer; _stretchX,_stretchY : Integer output) : CM_GraphicCommand;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		These points are used to line the graphic up on the GUI
//
// ---------------------------------------------------------------------------

vars
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	theCommands : CM_GraphicArray;
begin
	if theType = self.INDEX_AFT then
		theCommands := self.allCommandsAft;
	elseif theType = self.INDEX_BRIDGE then
		theCommands := self.allCommandsBridge;
	elseif theType = self.INDEX_CRANE1 then
		theCommands := self.allCommandsCrane1;
	elseif theType = self.INDEX_FORWARD then
		theCommands := self.allCommandsForward;
	endif;
	
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_STRETCHXY then
			_stretchX := aCommand.x1;
			_stretchY := aCommand.y1;
			return aCommand;
		endif;
	endforeach;

end;</source>
        <Parameter name="theType" type="Integer"/>
        <Parameter name="_stretchX" type="Integer" usage="output"/>
        <Parameter name="_stretchY" type="Integer" usage="output"/>
        <ReturnType type="CM_GraphicCommand"/>
    </JadeMethod>
    <JadeMethod name="getXMLData" id="dd8cd9a9-f820-48e7-8caa-569b3811d9d7">
        <source>getXMLData() : String;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCommands : CM_GraphicArray;
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	theAML,theBML,theFML,theCML,theXML : String;
begin
	theXML := "";
	theXML := "&lt;maxAft&gt;" &amp; self.maxXAft.String &amp; "&lt;/maxAft&gt;&lt;maxBridge&gt;" &amp; self.maxXBridge.String &amp; 
				"&lt;/maxBridge&gt;&lt;maxForward&gt;" &amp; self.maxXForward.String &amp; "&lt;/maxForward&gt;";
	theAML := "&lt;AFT&gt;";
	foreach aGraphic in self.allCommandsAft do
		aCommand := aGraphic.CM_GraphicCommand;
		
		theXML := theXML &amp; aCommand.getXMLData();
	endforeach;
	theAML := theAML &amp; theXML &amp; "&lt;/AFT&gt;";

	theBML := "&lt;BRD&gt;";
	theXML := "";
	foreach aGraphic in self.allCommandsBridge do
		aCommand := aGraphic.CM_GraphicCommand;
		
		theXML := theXML &amp;  aCommand.getXMLData();
	endforeach;
	theBML := theBML &amp; theXML &amp; "&lt;/BRD&gt;";

	theFML := "&lt;FWD&gt;";
	theXML := "";
	foreach aGraphic in self.allCommandsForward do
		aCommand := aGraphic.CM_GraphicCommand;
		
		theXML := theXML &amp;  aCommand.getXMLData();
	endforeach;
	theFML := theFML &amp; theXML &amp; "&lt;/FWD&gt;";
	
	theCML := "&lt;CRN1&gt;";
	theXML := "";
	foreach aGraphic in self.allCommandsCrane1 do
		aCommand := aGraphic.CM_GraphicCommand;
		
		theXML := theXML &amp;  aCommand.getXMLData();
	endforeach;
	theCML := theCML &amp; theXML &amp; "&lt;/CRN1&gt;";
	
	theXML := theAML &amp; theBML &amp; theFML &amp; theCML;
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a6c2781f-08e0-4731-b95e-a7976429acaa">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyGraphic : CM_VoyageLayoutGraphic;
	completedOK		: Boolean;
begin
	pxyGraphic :=  inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGraphic;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGraphic;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateGraphic" id="9f3c1e8f-a0d5-44c9-86a2-a527ea06bb67">
        <updating/>
        <source>setForUpdateGraphic(_theController : CMIF_GraphicCommandController ) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theType : Integer;
	theCommands : CM_GraphicArray;
	pxyCommand : CM_Graphic;
	aCommand : CM_GraphicCommand;
	maxX : Integer;
begin
	theType := _theController.type;
	
	if theType = self.INDEX_AFT then
		theCommands := self.allCommandsAft;
	elseif theType = self.INDEX_BRIDGE then
		theCommands := self.allCommandsBridge;
	elseif theType = self.INDEX_CRANE1 then
		theCommands := self.allCommandsCrane1;
	elseif theType = self.INDEX_FORWARD then
		theCommands := self.allCommandsForward;
	else
		return;
	endif;

	if theCommands = null then
		return;
	endif;
	
	theCommands.purge;
	
	foreach pxyCommand in _theController.allGraphicCommands do
//		aCommand := pxyCommand.cloneSelfAs(CM_GraphicCommand,false).CM_GraphicCommand;
		aCommand := pxyCommand.cloneSelf(false).CM_GraphicCommand;
		if theType = self.INDEX_AFT then
			aCommand.myVLGAft := self;
		elseif theType = self.INDEX_BRIDGE then
			aCommand.myVLGBridge := self;
		elseif theType = self.INDEX_FORWARD then
			aCommand.myVLGForward := self;
		elseif theType = self.INDEX_CRANE1 then
			aCommand.myVLGCrane1 := self;
		endif;
		if aCommand.type = CM_GraphicCommand.TYPE_DRAW then
			maxX := maxX.max(aCommand.x1);
		else
			maxX := maxX.max(aCommand.x2);
		endif;
	endforeach;

	if theType = self.INDEX_AFT then
		self.maxXAft := maxX;
	elseif theType = self.INDEX_BRIDGE then
		self.maxXBridge := maxX;
	elseif theType = self.INDEX_CRANE1 then
		self.maxXCrane1 := maxX;
	elseif theType = self.INDEX_FORWARD then
		self.maxXForward := maxX;
	endif;

end;</source>
        <Parameter name="_theController" type="CMIF_GraphicCommandController"/>
    </JadeMethod>
