    <JadeMethod name="coolingTypeStringToENum" id="523c1e90-0911-4725-92f7-58ea40295fbc">
        <source>coolingTypeStringToENum(_coolingType : String):Integer;
//--------------------------------------------------
// Created:	2 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVal	: String;

begin

	tmpVal := _coolingType.toUpper;
	
	if tmpVal = ContainerAirCooledStr.toUpper() then
		return ContainerAirCooled;
	elseif tmpVal = ContainerWaterCooledStr.toUpper() then
		return ContainerWaterCooled;
	elseif tmpVal = ContainerCooledNullStr.toUpper() then
		return ContainerCooledNull;		
	else
		return ContainerCooledNull;
	endif;		

end;</source>
        <Parameter name="_coolingType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyFileToAppServer" id="225321f3-aae1-46e3-8fd4-d672b01fd60a">
        <source>copyFileToAppServer(_sourceFileName : String) : String;
// ---------------------------------------------------------------------------
// Created:     14 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  The fully pathed name of the source file on the
//				client
//
// Returns:     The fully pathed name of file on the app server
//
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
17/03/2015	cnwnh5	Transient Leak	
*/

vars
	targetDir	: String;
	targetFile	: String;
	nodeOptions	: Integer;
	ff			: FileFolder;
	ts			: TimeStamp;
		
begin

	targetDir := self.getAppServerLogDir();
	
	create ff transient;
	ff.usePresentationFileSystem := false;	// use the appServer file system
	ff.fileName := targetDir;

	if (not ff.isAvailable) then
		app.raiseCMException2(Err_DirectoryNotAvailable, targetDir, app.computerNameAppServer, null, null); 
		return null;
	endif;

	targetDir := targetDir &amp; '\tmpFiles';
	ff.fileName := targetDir;
	
	if (not ff.isAvailable) then
		ff.make;
	endif;

	ts := app.actualTimeServer;
	targetFile := ts.date.formatAsYYYYMMDD()  &amp;
				  ts.time.formatAsHHMMSS() &amp; '_' &amp; 
				  self.getInstanceIdForObject64(process).String &amp; '.txt';
	
	targetFile := targetDir &amp; '\' &amp; targetFile;
	
	nodeOptions := JSSFMPublicInterface.NODE_SOURCE_CLIENT +
					JSSFMPublicInterface.NODE_TARGET_APPSERVER;
	self.myFileManager.copyFile(_sourceFileName, targetFile, nodeOptions);

	return targetFile;

epilog
	delete ff;	
end;</source>
        <Parameter name="_sourceFileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyFileToLocalMachine" id="68980820-2cae-4b2a-afd9-69df0492f690">
        <source>copyFileToLocalMachine(_sourceFileName, _targetFileName : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	sourceDir,
	targetDir		: String;
	nodeOptions		: Integer;
	ff				: FileFolder;
	lf				: FileFolder;
	
begin
	create ff transient;
	ff.usePresentationFileSystem := false;	// use the appServer file system
	sourceDir := _sourceFileName.cnEcGetPathOfFileName();
	ff.fileName := sourceDir;

	if (not ff.isAvailable) then
		app.raiseCMException2(Err_DirectoryNotAvailable, sourceDir, app.computerNameAppServer, null, null); 
		return null;
	endif;
	
	create lf transient;
	lf.usePresentationFileSystem := true;	// use the local file system
	targetDir := _targetFileName.cnEcGetPathOfFileName();
	lf.fileName := targetDir;

	if (not lf.isAvailable) then
		lf.make;
	endif;
	
	if (not lf.isAvailable) then
		app.raiseCMException2(Err_DirectoryNotAvailable, targetDir, app.computerName, null, null); 
		return null;
	endif;
	
	nodeOptions := JSSFMPublicInterface.NODE_SOURCE_APPSERVER + 
					JSSFMPublicInterface.NODE_TARGET_CLIENT;
	
	self.myFileManager.copyFile(_sourceFileName, _targetFileName, nodeOptions);

	return _targetFileName;

epilog
	delete ff;
	delete lf;
	
end;</source>
        <Parameter name="_sourceFileName" type="String"/>
        <Parameter name="_targetFileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="couTypeEnumToString" id="3c76f104-3d7d-465c-8472-bba774c35ab4">
        <source>couTypeEnumToString(pNum : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     09 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pNum = COU_TYPE_SHORT then
		return COU_SHORT_NAME;
	elseif pNum = COU_TYPE_LONG then
		return COU_LONG_NAME;
	elseif pNum = COU_TYPE_MARINE then
		return COU_MARINE_NAME;
	elseif pNum = COU_TYPE_LAND then
		return COU_LAND_NAME;
	endif;
	
	return COU_UNDEFINED_NAME;

end;</source>
        <Parameter name="pNum" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
