    <JadeMethod name="validateForCreate" id="9b0d8c89-8597-4930-af19-461baa762dfa">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     11 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwcs5		ccms1023 - snapshot summaries
// ---------------------------------------------------------------------------
vars
	xtab	:CM_OutputFormat_XTAB;
	ss		:CM_OutputFormat_SS;
	coll	:IntegerArray;
begin
	inheritMethod();

	if self.decimals &gt; 9 or self.decimals &lt; 0 then
		app.raiseCMException( XTAB_DecimalPlacesError, null, self );
	endif;
	
	// if the xtab is local to a snapshot check that the function is valid for the snapshot
	if self.myOutputFormat.isXTABFormat then
		xtab := self.myOutputFormat.CM_OutputFormat_XTAB;
		if xtab.isSnapshotMode then
			// xtab is local to a snapshot
			ss := xtab.myOutputFormat_SS;
			
			create coll transient;
			
			ss.getFunctionsForProperty (self.propertyName, coll);
			
			if not coll.includes (self.function) then
				// we expect the GUI to take care of this
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid function for field');
			endif;
		endif;
	endif;
epilog
	delete coll;
end;</source>
    </JadeMethod>
</Class>
