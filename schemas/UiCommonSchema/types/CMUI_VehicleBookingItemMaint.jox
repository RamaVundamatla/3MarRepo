    <JadeMethod name="stub_ValidateParentState" id="a8ef4c2c-97f4-430c-bb83-041cc93b874f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::validateParentState"/>
        </interfaceImplements>
