    <JadeMethod name="buildLocationStatistics" id="6bcc4dd6-075f-4b6f-b498-7650208ae704">
        <source>buildLocationStatistics();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2010	cnwer1	Initial creation

*/

vars
lc                  : CM_LocationsController;
	locationStatistics  : CM_LocationStatistics;
	plocationStatistics : CM_LocationStatistics;
	terminal            : CM_Terminal;
	statsAgent			: CMIF_StatisticsAgent;
	locations			: CM_LCArray;
	
	usedCount			: Integer;
begin

	create statsAgent transient;

	if self.myLocationStatistics = null then
		create plocationStatistics transient;
		plocationStatistics.setParent(self);
		create locationStatistics  persistent;
		locationStatistics.setupForCreate(plocationStatistics);
	endif;

    create locations transient;

	
	// Columns are in order here, so no need to resort
	self.allControllersByRow.copy(locations);

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts;

	// Calculate future queued/planned (unchanged from original code)
	foreach lc in locations do
		self.myLocationStatistics.processALocationController(lc, 1, self.getHeightOfStack());
	endforeach;
	
	self.myLocationStatistics.c20Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c30Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c40Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_40, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c45Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c53Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, self.myGridArea.getHeight());
	//cnwjo3 par 21189
	self.myLocationStatistics.total := self.myLocationStatistics.c20Total;  //in gridrows total = total TEUs

	self.myLocationStatistics.c20Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations,1, self.myGridArea.getHeight());  //cnwjo3 par 20470
	self.myLocationStatistics.c30Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_30, locations,1, self.myGridArea.getHeight());  //added min/maxHeight
	self.myLocationStatistics.c40Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_40, locations,1, self.myGridArea.getHeight());
	self.myLocationStatistics.c45Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_45, locations,1, self.myGridArea.getHeight());
	self.myLocationStatistics.c53Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_53, locations,1, self.myGridArea.getHeight());
	//cnwjo3 par 21189
	//self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used + self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used + self.myLocationStatistics.c53Used;
/*	foreach lc in self.allControllersByRow do
		usedCount := usedCount + lc.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
	endforeach;
	self.myLocationStatistics.used := usedCount; */
	//	15 Apr 2015	NDL	Par 35969 - Don't include Break-Bulk
	self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used
									+ self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used
									+ self.myLocationStatistics.c53Used;
	
	self.myLocationStatistics.c20Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c30Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c40Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_40, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c45Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, self.myGridArea.getHeight());
	self.myLocationStatistics.c53Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, self.myGridArea.getHeight());
	//cnwjo3 par 21189
	self.myLocationStatistics.free := self.myLocationStatistics.c20Free;  //for CM_GridRow free = free TEUs
	
	self.myLocationStatistics.setUpdateTimestamp;
	//
	// Now notify everyone
	//
	terminal := self.myGridArea.myTerminal;
	terminal.causeEvent(terminal.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), false, self.myLocationStatistics);

epilog
	delete locations;
	delete statsAgent;
	delete plocationStatistics;

end;</source>
    </JadeMethod>
    <JadeMethod name="buildLocationStatsTranisent" id="6ad152c4-3b60-4764-9a52-79b6071ea1cb">
        <source>buildLocationStatsTranisent( _ls : CM_LocationStatistics output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2012	cnwndl1	Initial creation	Par 29350

*/

vars

	lc                  : CM_LocationsController;
	statsAgent			: CMIF_StatisticsAgent;
	locations			: CM_LCArray;
	
	usedCount			: Integer;
	
begin

	create _ls transient;
	create statsAgent transient;
    create locations transient;

	// Columns are in order here, so no need to resort
	self.allControllersByRow.copy(locations);

	// Calculate future queued/planned (unchanged from original code)
	foreach lc in locations do
		_ls.processALocationController(lc, 1, self.getHeightOfStack());
	endforeach;
	
	_ls.c20Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, self.myGridArea.getHeight());
	_ls.c30Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, self.myGridArea.getHeight());
	_ls.c40Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_40, locations, 1, self.myGridArea.getHeight());
	_ls.c45Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, self.myGridArea.getHeight());
	_ls.c53Total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, self.myGridArea.getHeight());
	_ls.total := _ls.c20Total; 

	_ls.c20Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_20, locations,1, self.myGridArea.getHeight());  
	_ls.c30Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_30, locations,1, self.myGridArea.getHeight());  
	_ls.c40Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_40, locations,1, self.myGridArea.getHeight());
	_ls.c45Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_45, locations,1, self.myGridArea.getHeight());
	_ls.c53Used := statsAgent.calcUsed(CMIF_StatisticsAgent.ContainerSize_53, locations,1, self.myGridArea.getHeight());
	
/*	foreach lc in self.allControllersByRow do
		usedCount := usedCount + lc.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
	endforeach;
	_ls.used := usedCount; */
	//	15 Apr 2015	NDL	Par 35969 - Don't include Break-Bulk
	_ls.used := _ls.c20Used + _ls.c30Used + _ls.c40Used + _ls.c45Used + _ls.c53Used;
	
	
	_ls.c20Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, self.myGridArea.getHeight());
	_ls.c30Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_30, locations, 1, self.myGridArea.getHeight());
	_ls.c40Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_40, locations, 1, self.myGridArea.getHeight());
	_ls.c45Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, self.myGridArea.getHeight());
	_ls.c53Free := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_53, locations, 1, self.myGridArea.getHeight());
	
	_ls.free := _ls.c20Free; 
	
	_ls.setUpdateTimestamp;
	

epilog

	delete locations;
	delete statsAgent;

end;</source>
        <Parameter name="_ls" type="CM_LocationStatistics" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsControllers" id="5f590172-0a61-4eec-88d0-8f7c1f27466b">
        <source>getAllLocationsControllers(_locationControllerArray: ObjectArray io; _withCargoOnly : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	locController : CM_LocationsController;

begin

	foreach locController in self.allControllersByRow discreteLock do
		// no tracked items then don't require it
		if _withCargoOnly and locController.allTrackedItems.isEmpty then
			continue;
		endif;
		// if not already in the array then add to the array
		if not _locationControllerArray.includes(locController) then
			_locationControllerArray.add(locController);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
        <Parameter name="_withCargoOnly" type="Boolean"/>
    </JadeMethod>
