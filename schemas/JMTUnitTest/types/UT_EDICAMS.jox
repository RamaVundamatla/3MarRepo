	camTaskHistory.rawDataToHSA(theLines);
	
	self.assertTrueMsg(theLines.size &gt; 0, 'Nothing was recorded in the history');
	
	//DEBUG
	if debug then
		write CrLf &amp; "output of UC 5 " &amp; CrLf;		
