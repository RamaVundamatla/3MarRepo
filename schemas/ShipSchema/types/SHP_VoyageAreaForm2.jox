    <JadeMethod name="doUpdateBaySelectionPreference" id="5a25afe2-33a5-4fcc-8be6-7ad38d42d124">
        <updating/>
        <source>doUpdateBaySelectionPreference(_holdsMulti,_baysOne,_baysMulti : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		15 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	newVoyage : CM_Voyage;

begin
	self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByHolds := _holdsMulti;
	self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayOne := _baysOne;
	self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayMulti := _baysMulti;
	app.myTrxUA.trxUpdateUserConfig(app.getMyUser, self.myConfig, app.myPassport);
	self.mnuBaySelHolds.checked := _holdsMulti;
	self.mnuBaySelOne.checked := _baysOne;
	self.mnuBaySelMulti.checked := _baysMulti;

	if _holdsMulti then
		self.mnuGridLayout.visible := true;
		self.mnuWorkDisplayLayout.visible := true;
		self.selectMode := self.SelectModeHold;
		self.showHoldSelector(self.SelectModeHold);
		self.frmSelectBay.visible := false;
		
		newVoyage := self.myCurrentVoyage;
		if newVoyage = null then
			newVoyage := self.cmbVoyage.listObject.CM_Voyage;
		endif;
		self.initSelectorControlsForVoyage(newVoyage,true,true);
	elseif _baysOne then
		self.mnuGridLayout.visible := false;
		self.mnuWorkDisplayLayout.visible := false;
		self.selectMode := self.SelectModeOne;
		self.showSelectBays(0,0);
		self.frmSelectVoyage.visible := false;
	elseif _baysMulti then
		self.mnuGridLayout.visible := true;
		self.mnuWorkDisplayLayout.visible := true;
		self.selectMode := self.SelectModeMulti;
		self.showHoldSelector(self.SelectModeMulti);
		self.frmSelectBay.visible := false;
		newVoyage := self.myCurrentVoyage;
		if newVoyage = null then
			newVoyage := self.cmbVoyage.listObject.CM_Voyage;
		endif;
		self.initSelectorControlsForVoyage(newVoyage,true,true);
	endif;


end;</source>
        <Parameter name="_holdsMulti" type="Boolean"/>
        <Parameter name="_baysOne" type="Boolean"/>
        <Parameter name="_baysMulti" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doViewImportExport" id="8af31e30-15bd-49b5-85f4-15c04e04efb6">
