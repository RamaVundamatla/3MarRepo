    <JadeMethod name="createProperties" id="4701f360-cecb-4279-9ddd-6ad6d932fb6a">
        <source>createProperties();
/*
Date		Who		Reason
23 November 2009	cnwndl1	Initial creation	CCMS 1028
10/05/2010			cnwcs5	par 23818 - change method used for Length property
20/10/2010			cnwcs5	par 25708 - change method used for ISO Type Group property
23/05/2011			cnwcs5	ccms sct 2058 / par 27460 - add carrier reference
21/08/2014			cnwdap1	PAR #33235 Measurement types in Summaries
25/08/2017			jlgrh7 		TFS #5495 - [Fwd: ##5009## : Summary Definition Fault in Jade]
10/11/2017			JLGAB1 TFS 7449 // TFS 7449 backing out TFS 5495 - 
*/

vars
	tmpProp		: CM_QueryProperty;
begin
