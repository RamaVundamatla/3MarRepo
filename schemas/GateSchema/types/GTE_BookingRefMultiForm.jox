    <JadeMethod name="setupTextTable" id="97fffb35-31b8-43f2-a4f0-f1dbf55b0429">
        <source>setupTextTable();
/*
	Created on 04 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	entTableDef : EntTableDef;
begin
	tblBRItems.columns := 1;
	tblBRItems.fixedColumns := 0;
	tblBRItems.fixedRows := 0;
	tblBRItems.allSelectedObjects.clear;
	tblBRItems.selectionType := tblBRItems.SelectionType_Row;
	entTableDef := app.myController.getEntTableDef(ETDef_BookRefText);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_BookRefText &amp; ') not found');
		return;
	endif;
	tblBRItems.setTableTextDisplayFields(entTableDef, self.xmlStrTblText);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="0b980a5d-6aa9-42d2-8288-60a390db82a1">
        <source>showColourLegend();
/*
Purpose:			// TFS 2814
Date		Who		Reason
27 October 2016	cnwab1	Initial creation
*/

vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
	colLegend.centreWindow;
	
	colLegend.addLegendItem(app.getErrorString(Quanti_matche_number_attach_pr), Black, LightRed, null, false);
	colLegend.addLegendItem(app.getErrorString(Quanti_matche_number_attach_re), Black, PaleGreen, null, false);
	colLegend.addLegendItem(app.getErrorString(Quant_does_not_match_numbe_pre), Black, White, null, false);
	colLegend.width := 400;
	colLegend.height := 150;
	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="3dddbb2c-9163-4b57-8b05-b7f36abceba1">
        <updating/>
        <source>showThumbnailData(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/08/2010	cnwdap1		PAR #23925 CCMS MES 1076 Display Stock/Linked booking details
// 17/06/2013	cnwcs5		par 31670
// 19/09/2014   cnwma1		PAR# 34920 1090 in GateSchema::GTE_BookingRefMultiForm::showThumbnailData
// 21/06/2016   cnwma1 		PAR #37953 TFS #2170 MSL - Differences between Booking created and Booking received via EDI file
// 20 Oct 2022 	navtnr20 	ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 22 Aug 2023 	navhl20 	ChangeRequest 58717: EUP - Additional Operational Instructions on the Order - Enhancement 1
// ---------------------------------------------------------------------------
vars
	entTableDef			: EntTableDef;
	viewName			: String;
	terminal 			: CM_Terminal;
	thumbTable			: CM_ThumbnailTable;
	itemTable			: CM_TextTable;
	booking				: CM_BookingRef;
	bookingItem			: CM_BookingRefItem;
	gotException, dummy	: Boolean;
	locale				: CM_Locale;
begin
	if _obj = null then
		return;
	endif;

	terminal 	:= self.myTerminal;
	thumbTable	:= self.tblThumb;
	locale 		:= app.myCurrentLocale;
		
	if _obj.isKindOf(CM_BookingRef) then							//+cnwml2 PAR20173 SFW CCMS 1091
		booking := _obj.CM_BookingRef;
	else
		on Exception do app.handleDeletedObject (exception, bookingItem, gotException);
		
		bookingItem := _obj.CM_BookingRefItem;
		booking		:= bookingItem.myBookingReference;
	endif;

	if not gotException then
		// make sure booking is valid
		on Exception do app.handleDeletedObject (exception, booking, gotException);

		dummy := booking.isTransient;
	endif;
	
	if not gotException then
		itemTable	:= self.tblBRItems;
		entTableDef := app.myController.getEntTableDef(ETDef_BookRefThumb);
		
		//- 21/06/2016 cnwma1 PAR #37953 TFS#2170
		/*if bookingItem = null and booking.isMultiItemBookingRef then
			viewName := ETView_MultiBR;
			self.sptThumbEdit.showRightControl(65, true);
			
			self.loadBookRefItems(booking, false, false);
			
			itemTable.visible := true;
		else
			if not terminal.getConfig(AllowMultiBookingRef).Boolean then
				viewName 	:= ETView_BookRefNoMulti;
			else
				viewName	:= null;
			endif;
			
			self.sptThumbEdit.hideRightControl(true);
			
			itemTable.clearAllSelected;
			itemTable.clear;
		endif;*/
		//+ 21/06/2016 cnwma1 PAR #37953 TFS#2170
		if bookingItem = null and booking.isMultiItemBookingRef then
			if terminal.getConfig(ShowMultiBookingRef).Boolean then
				viewName := ETView_MultiBR;
				self.sptThumbEdit.showRightControl(65, true);
				self.loadBookRefItems(booking, false, false);
				itemTable.visible := true;
			else
				viewName 	:=  null;
				self.sptThumbEdit.hideRightControl(true);
				itemTable.clearAllSelected;
				itemTable.clear;
			endif;		
		else
			if not terminal.getConfig(AllowMultiBookingRef).Boolean then
				viewName 	:= ETView_BookRefNoMulti;
				self.sptThumbEdit.hideRightControl(true);
				itemTable.clearAllSelected;
				itemTable.clear;
			else
				if terminal.getConfig(ShowMultiBookingRef).Boolean then
					viewName := ETView_MultiBR;
					self.sptThumbEdit.showRightControl(65, true);
					self.loadBookRefItems(booking, false, false);
					itemTable.visible := true;
				else
					viewName 	:=  null;
					self.sptThumbEdit.hideRightControl(true);
					itemTable.clearAllSelected;
					itemTable.clear;
				endif;
			endif;
		endif;
		//+ 21/06/2016 cnwma1 PAR #37953 TFS#2170
		
		self.setNavigatorHeading(app.getErrorString1 (Booking_display, booking.bookingReference));
		
		thumbTable.rows := 0;
		
		// *** should we be showing booking items instead of booking reference here ***
		if bookingItem = null then
			self.showThumbnailForDefWithView(ETDef_BookRefThumb, viewName, booking);
		else
			self.showThumbnailForDefWithView(ETDef_BookRefThumb, viewName, bookingItem);
		endif;
		
		//23 Oct 2014	NDL	Par 35008
		if not app.isVehicleBookingEnabled then
			thumbTable.hideRowFromHeading(ETRow_VehicleBookingSlots);
		endif;
		
		if app.isSpecial() then
			thumbTable.addItem(_obj.String);
		endif;
		
		// 28/05/2009 cnwar2 CCMS1040	
		if booking.isMultiItemBookingRef then
			self.myAssistant.GTE_Assistant.mainExtraSplitterRatio(thumbTable, itemTable, sptThumbEdit);
			self.sptMain.cnEcResizeContents();
		/*else																												// 19/09/2014   cnwma1		PAR# 34920
			thumbTable.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_CutoffEarliestTS).getHeading(null, null, locale));
			thumbTable.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_EarliestRecLatestTS).getHeading(null, null, locale));
		*/	
		endif;
		
		// CCMS MES 1076 PAR #23925 display linked stock/export bookings depending on type
		if booking.isStockBookingRef then
			thumbTable.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_AllLinkStkBookItemInfo).getHeading(null, null, locale));
			thumbTable.showRowFromHeading(ETRow_AllLinkedExpBookingsInfo);
		else
			thumbTable.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_AllLinkedExpBookingsInfo).getHeading(null, null, locale));
			thumbTable.showRowFromHeading(ETRow_AllLinkStkBookItemInfo);
		endif;
		
		if not terminal.getConfig(ShowPortOfCallTranship).Boolean then	///ccms 1096 par 21773		// 19/09/2014   cnwma1		PAR# 34920
			//thumbTable.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_CutoffEarliestTS).getHeading(null, null, locale));	// 19/09/2014   cnwma1		PAR# 34920
			self.tblMain.hideRowByName(ETRow_MyTranshipToPort, false);		
			self.tblData.hideColumnByColName(ETRow_MyTranshipToPort);
			self.tblExtra.showRowByName(ETRow_MyTranshipToPort, false);	
		endif;
	endif;		
	/*if booking.status = BOOKING_REF_CLOSED then	//20.10.2022 navtnr20 TFS 54967			//22.8.2023 navhl20 #58717
		self.btnInstruction.enabled := false;	//20.10.2022 navtnr20 TFS 54967
	endif;	//20.10.2022 navtnr20 TFS 54967*/

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
