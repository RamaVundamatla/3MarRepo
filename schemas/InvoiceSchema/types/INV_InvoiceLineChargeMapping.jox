    <JadeMethod name="doTblDataRowColChange" id="ec9e3cec-81d3-4cbc-9871-0baf2d7c722a">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
*/

vars
	theRow, theCol : Integer;
begin

	self.myCurrentInvLineType := null;
	self.myCurrentCombinationObject := null;
	inheritMethod(table);
	theRow := table.row;
	theCol := table.column;
	
	if theRow &gt; table.fixedRows then
		self.myCurrentInvLineType := table.accessRow(theRow).itemObject.CM_InvoiceLineDesc;
		if theCol &gt; table.fixedColumns then
			self.myCurrentCombinationObject := table.accessColumn(theCol).itemObject.CM_Object;
			self.myCurrentMapping := table.accessCell(theRow,theCol).itemObject.CM_InvoiceLineChargeMapping;
		endif;
	endif;
	
	self.setEnableObjects ();
epilog

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="bd8132a7-9ea9-41d1-9ec3-15fade0ed77c">
        <source>haltProgress(pe : CM_ProgressException; ls : Boolean io) : Integer;

vars

begin
	app.cmsEndLoad(ls);		// from 35872 testing, to avoid an error with msg box in load state

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then

		cmbChargeType.listIndex := 1;
		self.tblData.columns := 1;

		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <Parameter name="ls" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedObject" id="233dccf5-f315-4db6-a478-94271e8ae375">
        <source>handleDeletedObject(_exc : Exception) : Integer;

constants
	ObjectNotFound	= 4;
vars
	
begin	
	if _exc.errorCode = ObjectNotFound then
		return Ex_Resume_Next;	
	endif;
	return Ex_Pass_Back;	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="f5a3a44a-b8fa-475c-a5e6-a5e6a5ec55ac">
        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	sht			: CMUI_Sheet;
begin
	
	sht := self.shtQuery1;
	sht.caption := "Charge Mappings";
	
	// 35872 get business unit from user, show business unit combo only if more than one
	if self.cmbBank.listCount &gt; 1 then
		self.setQueryControl(self.cmbBank);
		self.setQueryControl(self.lblBank);
		self.frmQuery.height :=	270;	// set to 250 in CMUI_QueryEnquiry::positionQueryFrame just before this method is called
		self.cmbBank.setFocus();
	else
		self.cmbBank.visible := false;
		self.lblBank.visible := false;
		self.lblChargeTypeCom.top := self.lblParentObject.top;
		self.cmbChargeTypeCom.top := self.cmbParentObject.top;
		self.lblParentObject.top := self.lblChargeType.top;
		self.cmbParentObject.top := self.cmbChargeType.top;
		self.lblChargeType.top := self.lblBank.top;
		self.cmbChargeType.top := self.cmbBank.top;
	endif;
	self.setQueryControl(self.cmbChargeType);
	self.setQueryControl(self.cmbChargeTypeCom);
	self.setQueryControl(self.cmbParentObject);
	self.setQueryControl(self.lblChargeType);
	self.setQueryControl(self.lblChargeTypeCom);
	self.setQueryControl(self.lblParentObject);

	sht.visible := true;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadLines" id="bca98fa7-b378-4644-91f2-d5727d7ed3f7">
        <source>loadLines();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars

	i : Integer;
	invoiceLineDesc : CM_InvoiceLineDesc;
	str : String;
	mappingTable : CM_DataTable;
	bank : CM_Bank;
begin
	mappingTable := self.tblData;
	bank := self.myCurrentBank;

	mappingTable.columns := 1;
	mappingTable.fixedColumns := 1;
	mappingTable.rows := 1;
	mappingTable.clear;
	mappingTable.row := 1;
	mappingTable.columnWidth[1] := 260;
	i := 1;
	mappingTable.accessCell(1,1).text := "Invoice Line Types";
	mappingTable.accessedCell.fontBold := true;
	mappingTable.accessedCell.alignment := Table.Alignment_Left_Top;
	foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock where not invoiceLineDesc.isNotAvailableForEntry do
		if self.myCurrentDebtorType &lt;&gt; null and invoiceLineDesc.myDebtorType &lt;&gt; self.myCurrentDebtorType then //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
			continue;
		endif;
		
		mappingTable.addItemObject(invoiceLineDesc, invoiceLineDesc.narration);
	endforeach;
	mappingTable.accessColumn(1).backColor := self.colorHeadingColumn;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mnuViewAudits_click" id="70a8728f-221f-4578-a032-6cbfc0f9bfe4">
        <controlMethod name="MenuItem::click"/>
