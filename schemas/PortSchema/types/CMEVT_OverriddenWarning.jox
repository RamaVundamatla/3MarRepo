    </PrimAttribute>
    <ExplicitInverseRef name="mySubject" id="0c73d4a2-f1fb-4fbb-a5bc-044b40edaead">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
