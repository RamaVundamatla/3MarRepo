    </JadeMethod>
    <JadeMethod name="setStateData" id="c93bd237-cda0-4013-8606-93da7385ff76">
        <updating/>
        <source>setStateData(_code	: String; _value : Any) updating, protected;
// -------------------------------------------
// Created 06 December 2005 by cnwdvb1
// -------------------------------------------
vars

	stateObj	: CM_StateObject;
	
begin

	stateObj := self.myStateObject;
	
	if stateObj = null then
		create stateObj transient;
		self.myStateObject := stateObj;
 	endif;
	
	stateObj.setStateData(_code, _value, true);
end;</source>
        <access>protected</access>
        <Parameter name="_code" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateAttributeOfType" id="2ec8b923-d852-4c76-9a7a-71723a3e0eae">
        <updating/>
        <source>updateAttributeOfType(_extAttributeName : String;  _value : Any) updating;
// -------------------------------------------
// Created 06 December 2005 by cnwdvb1
// -------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
 10/03/2023	jlika1	TFS 56923 - Add width to Trailer
============================================================================*/

vars


begin

	if _extAttributeName = Type_CanHaveFlexibleLengths then
		self.canHaveFlexibleLengths := _value.Boolean;
	elseif _extAttributeName = Type_IsReefer then
		self.isReefer	:= _value.Boolean;
	elseif _extAttributeName = Type_Length then
		self.length	:= _value.Integer;
	elseif _extAttributeName = Type_MaxHeight then
		self.maxHeight	:= _value.Integer;
	elseif _extAttributeName = Type_MaxWeight then
		self.maxWeight	:= _value.Integer;
	elseif _extAttributeName = Type_NumLocationControllers then
		self.numControllers	:= _value.Integer;
	elseif _extAttributeName = Type_Description then
		self.description	:= _value.String[1:30];
	elseif _extAttributeName = Type_Colour then
		self.colour	:= _value.Integer;
	elseif _extAttributeName = Type_Width then
		self.width	:= _value.Integer;
	else
	endif;

	// Call this if we need any attributes which we don't want
	// to store as primitives on the class	
//	self.setStateData(_extAttributeName, _value);


	

end;</source>
        <Parameter name="_extAttributeName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateForNonInversedReference" id="4f1789e9-a7d1-44e4-8548-8d998ca9a9a3">
        <updating/>
        <source>updateForNonInversedReference()updating;
/*
Date		Who		Reason
06 Dec 2012	cnwcs5	Initial creation - par 30852
*/
vars

begin
	if self.hasNoNonInversedUsages then
		self.hasNoNonInversedUsages := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTotalWeightConfigOnCargo" id="1b1bb52e-6a42-424b-97f8-44bb204a953d">
        <source>updateTotalWeightConfigOnCargo();
/*

Purpose:			This method goes through all the cargo of this trailer type and update the typeAttributes TILCTypeEnableTotalWeightEdit on the cargo
					based on the self.allowUpdateTotalWeight

Parameters:			

Return Value:		

Date		Who		Reason
15/10/2025	navkc1 JIRA 36057 CUX | Total Weight Specification for Trailers - DB Changes / Form /Jade

*/

vars
	ti 				: CM_TrackedItem;
	trailer			: CM_TILC;
	allowUpdate		: Boolean;
	allTrailers 	: CM_TIByState;
	stateInProgress : Integer;
	iter			: Iterator;
begin
	
	allowUpdate := self.allowUpdateTotalWeight;
	
	create allTrailers transient;
	
	self.allTILCs.copy(allTrailers);
	
	iter := allTrailers.createIterator();
	
	// State Normal
		stateInProgress := TI_STATE_NORMAL;
		ti := allTrailers.getAtKeyGeq(stateInProgress, null, null); // 28/11/2025	navkc1	JIRA MTN 36769
		if ti &lt;&gt; null then
			iter.startAtObject(ti);		
		endif;
		
		while iter.next(ti) do
			if ti.state &lt;&gt; stateInProgress then
				break;
			endif;
			
			trailer := ti.CM_TILC;
			
			trailer.updateTILCTotalWeightConfig(allowUpdate);
		endwhile;
	
	// State Onship
		stateInProgress := TI_STATE_ONSHIP;
		ti := allTrailers.getAtKeyGeq(stateInProgress, null, null); // 28/11/2025	navkc1	JIRA MTN 36769
		if ti &lt;&gt; null then
			iter.startAtObject(ti);		
		endif;
		
		while iter.next(ti) do
			if ti.state &lt;&gt; stateInProgress then
				break;
			endif;
			
			trailer := ti.CM_TILC;
			
			trailer.updateTILCTotalWeightConfig(allowUpdate);
		endwhile;	
	
	// State Notified
		stateInProgress := TI_STATE_NOTIFIED;
		ti := allTrailers.getAtKeyGeq(stateInProgress, null, null);	// 28/11/2025	navkc1	JIRA MTN 36769
		if ti &lt;&gt; null then
			iter.startAtObject(ti);		
		endif;
		
		while iter.next(ti) do
			if ti.state &lt;&gt; stateInProgress then
				break;
			endif;
			
			trailer := ti.CM_TILC;
			
			trailer.updateTILCTotalWeightConfig(allowUpdate);
		endwhile;	
	
epilog
	delete allTrailers;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="66aaf537-9921-4607-bb5f-27c60075836c">
