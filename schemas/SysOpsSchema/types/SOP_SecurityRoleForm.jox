    <JadeMethod name="includeObject" id="b6c79da5-85be-41cf-9ce3-59b582889f7a">
        <source>includeObject(_user:CM_User ; _passport: CM_Passport): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2022	navmv20	Bug 54803: MTN - Superuser/Opsview/JMTSupport appearing on security roles form
*/

vars

begin
	if _user.isInternalSystemUser then
		if app.myPassport.myUser = null then
			return app.isSpecial;
		else
			return app.isSpecial or app.myPassport.myUser.isSuperUser;
		endif;
	endif;
	return true;
epilog

end;</source>
