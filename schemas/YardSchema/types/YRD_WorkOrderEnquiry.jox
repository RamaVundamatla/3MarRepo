    <JadeMethod name="isWorkOrderNeedGrpMethod" id="3977db29-4f23-433b-8169-e1377cb06fec">
        <source>isWorkOrderNeedGrpMethod(_task : CM_WorkOrderDtl input) :Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen

*/

vars
	grpMethod		: CM_WorkOrderJobGroupMethod;
	relReq			: CM_BulkRelease;
	needGrp			: Boolean;
	grpData			: Any;
begin
	if _task.myParent &lt;&gt; null and _task.myParent.myWorkOrderJobGroupMethod = null then
		if _task.isKindOf(CM_WodReceive) and _task.CM_WodReceive.transport = TI_TRANSMODE_SHIP then
			needGrp := true;
		elseif _task.isKindOf(CM_WodRelease) and _task.CM_WodRelease.transport = TI_TRANSMODE_SHIP then
			needGrp := true;
			relReq	:= _task.CM_WodRelease.myReleaseRequest;
			if relReq &lt;&gt; null and relReq.releaseByType and _task.CM_WodRelease.allSelectedTIs.isEmpty() then
				needGrp := false;
			endif;
		endif;
		if needGrp then
			grpData := self.doShowWOJobMethod(_task.myParent.CM_WorkOrderTI,_task.CM_WorkOrderTIDtl);
			return grpData;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_task" type="CM_WorkOrderDtl" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
