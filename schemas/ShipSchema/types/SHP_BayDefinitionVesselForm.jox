    <JadeMethod name="getCurrentBayTierCellLabels" id="af53dc72-d6f3-4a6e-80bc-957b9b8b152f">
        <source>getCurrentBayTierCellLabels(_isCell, _onDeck : Boolean; _labels : String output; _typeDisplay : String output) protected;
/*

Date		Who		Reason
29 August 2014	cnwer1	Initial creation PAR 34819

*/

vars

begin
	if _isCell then
		if _onDeck then
			_typeDisplay:="On Deck Cell";
			if self.myCurrentBay &lt;&gt; null then
				_labels:=self.myCurrentBay.getAllCellsOnDeck();
			endif;
		else
			_typeDisplay:="Under Deck Cell";
			if self.myCurrentBay &lt;&gt; null then
				_labels:=self.myCurrentBay.getAllCellsUnderDeck();
			endif;
		endif;
	else
		if _onDeck then
			_typeDisplay:= "On Deck Tier";
			if self.myCurrentBay &lt;&gt; null then
				_labels:=self.myCurrentBay.getAllTiersOnDeck();
			endif;
		else
			_typeDisplay:="Under Deck Tier";
			if self.myCurrentBay &lt;&gt; null then
				_labels:=self.myCurrentBay.getAllTiersUnderDeck();
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isCell" type="Boolean"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_labels" type="String" usage="output"/>
        <Parameter name="_typeDisplay" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="2798e72c-9496-4f0e-b978-0b8a715c1811">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	26 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if eventType = Object_Delete_Event then
		if theObject = self.myCurrentCellularVessel then
			if self.cmbVessel.listObject &lt;&gt; null then
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only + MsgBox_Information_Icon);			
			endif;
			self.cmbVessel.setObject(null);			
			self.myCurrentCellularVessel := null;
			self.doBaseFormCancel();
		endif;		
	elseif eventType = Object_Update_Event then
		if theObject = self.myCurrentCellularVessel then
			if self.mode &lt;&gt; self.Mode_View then
				if app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), 'Warning', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
					self.doBaseFormCancel();
					self.doBtnEdit();
				else
					self.doBaseFormCancel();
				endif;
			else
				self.setMyCurrentVessel(self.cmbVessel.listObject.CM_CellularVesselStructure);		
			endif;
		endif;	
	endif;	

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="36d5b9fc-b782-43fd-961f-7be2be95a8fe">
        <updating/>
        <source>includeObject(_obj : CM_Object; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	failedDAC  :CM_DataAccessController;

begin

	if _obj.canUserAccessSelf(null, failedDAC, _passport) then
		return true;
	endif;

	return false;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCellularData" id="ae5c142e-8162-46aa-9c4f-f897f18190c9">
        <source>initCellularData();
//--------------------------------------------------
// Created:	09 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	entTableDef	: EntTableDef;
begin

//	if (not app.getMyUser.canDo(self.myTerminal, PmShipPlanning)) then
/* // ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)
	if (not app.getMyUser.canDo(self.myTerminal, Mod_CargoShip)) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;
*/
	self.doBuildComboStowageNumber();
	self.doBuildComboBayType();
	self.doBuildComboDirection();
		
	self.doBuildComboBay(self.cmbBayLayout);
	self.doBuildComboBay(self.cmbBayList);
	self.doBuildComboBay(self.cmbBridgeAftBay);	
	self.doBuildComboHolds(self.myCurrentCellularVessel);
	
	self.btnBaySeqBay.caption := self.CAPTION_BTN_SEQNUM;
	self.btnBaySeqBay.bubbleHelp := self.BUBBLE_SEQNUM;
	self.btnBayPrintBay.bubbleHelp := "Print The Selected Bay Details and Graphic Layout Only, no vessel information is printed.";
			
	self.splLayout.setLeftToRightRatioAndResize(80);

	self.btnBayApplyBay.visible := false;
	self.frmToolBarBay.positionToolbarControls();
	self.frmLegend.visible := true;
	self.frmLegend.ignoreSkin := true;
	self.frmLegend.caption := null;
	self.setupBtnPens();
	
	self.frmToolBarBay.positionToolbarControls();

end;</source>
    </JadeMethod>
    <JadeMethod name="initComboBoxes" id="95131e6d-00d0-4e23-ae39-d27093e5457e">
        <source>initComboBoxes();
//--------------------------------------------------
// Created:	29 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
	theCmb : CMUI_ComboBox;
begin
	self.cmbVessel.initialise(false);

	theCmb := self.cmbOnShipCrane;
	theCmb.clear;
	theCmb.sorted := false;
		
	idx := theCmb.addItem(BayOnShipCraneStr_None);
	theCmb.itemData[idx] := BayOnShipCrane_None;

	idx := theCmb.addItem(BayOnShipCraneStr_OnP);
	theCmb.itemData[idx] := BayOnShipCrane_OnP;

	idx := theCmb.addItem(BayOnShipCraneStr_OnC);	// cnwvu1 14/11/2006	ccms1048
	theCmb.itemData[idx] := BayOnShipCrane_OnC;

	idx := theCmb.addItem(BayOnShipCraneStr_OnS);
	theCmb.itemData[idx] := BayOnShipCrane_OnS;

	idx := theCmb.addItem(BayOnShipCraneStr_Before);
	theCmb.itemData[idx] := BayOnShipCrane_Before;

	idx := theCmb.addItem(BayOnShipCraneStr_After);
	theCmb.itemData[idx] := BayOnShipCrane_After;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="cdcb73e5-66fc-4bb3-94d1-2bd737a2a972">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTerm : CM_Terminal;
	tmpUserT : CM_UserTerminal;
	tmpUser : CM_User;
begin
	
	self.setNavigatorHeading(self.caption);

	// Prioritise self.myTerminal over the application call as this can result in the incorrect terminal being returned due
	// to notes changing the terminal in the passport - cnwcp2 - 20/2/2009 - PAR#18073
	tmpTerm := self.myTerminal;
	if tmpTerm = null then
		tmpTerm := app.getMyTerminalDO_NOT_USE();
		if tmpTerm = null then
			tmpUser := app.getMyUser();
			if tmpUser &lt;&gt; null then
				tmpUserT := tmpUser.allUserTerminals.first;
				if tmpUserT &lt;&gt; null then
					tmpTerm := tmpUserT.getRealTerminal;
				endif;
			endif;
		endif;
	endif;
	
	if tmpTerm &lt;&gt; null then
		self.cmbVessel.isDisplayByName := tmpTerm.getConfig(VesselComboByName).Boolean;		
	endif;	
	
	self.cmbVessel.initialise(false);

	self.fldVessel.stretchToParent := true;
	self.fldVessel.tabsStyle := Folder.TabsStyle_RightSloped;

	self.fldVessel.useSheetBackColors := true;
	self.fldVessel.setDefaultSheetBackColors();
	self.fldVessel.initSheetBackColors();

	self.initCellularData();
		
	self.frmReport.zOrder(0); // ### PAR 13165

	self.beginClassNotification(CM_Vessel, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Vessel, false, Object_Delete_Event, Response_Continuous, 0);	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initSDF" id="30c29b8b-4582-4c12-bd6f-26dfa1e39991">
        <source>initSDF(_theSDF : CMUI_ScrollableDrawingFrame input);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayAreaAboveDeck :SHP_BayAreaAboveDeck;
	bayFrame : CMUI_GridAreaFrame;

begin
	_theSDF.allGridAreasByColumnRow.clear;
	_theSDF.allGridAreasByRowColumn.clear;
	self.frmGridArea.bubbleHelp := app.getErrorString(UseThisFormToPaintAttributes);
	_theSDF.setupDrawingAttributes();
	_theSDF.myHLabels.visible := false;
	_theSDF.myVLabels.visible := false;
	_theSDF.myParentForm := self;
	
	_theSDF.setHLabelDetails(0);
	_theSDF.setVLabelDetails(0);
	_theSDF.labels := ScrollBars_None;
	
	bayAreaAboveDeck := self.frmGridArea.myGridArea.SHP_BayAreaAboveDeck;
	delete bayAreaAboveDeck;

	self.shtBayDetails.caption := app.getErrorString(Bay_Details);
	self.shtBayLayout.caption := app.getErrorString(Bay_Layout);

	bayFrame := self.frmGridArea.getControl(ONDECK) ;
	if bayFrame &lt;&gt; null then
		if bayFrame.myGridArea &lt;&gt; null then
			bayFrame.myGridArea.myHLabelsFrame.clearGraphics();
		endif;
		delete	bayFrame;
	endif;
	bayFrame := self.frmGridArea.getControl(UNDERDECK) ;
	if bayFrame &lt;&gt; null then
		if bayFrame.myGridArea &lt;&gt; null then
			bayFrame.myGridArea.myHLabelsFrame.clearGraphics();
		endif;
		delete	bayFrame;
	endif;
	
end;</source>
        <Parameter name="_theSDF" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b05c6b83-f22d-4660-97a3-4778d9df9421">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2010	cnwndl1	Initial creation CCMS 1140	/ Par 25127 - To enable tabbing around the 'On deck' 'Under deck' tables.
										

*/

vars

	theActiveControl : Control;
	theBay : CM_Bay;
	editMode : Boolean;
	
begin

	if self.fldVessel.topSheet = self.shtBayCellLimit then	// only relevant when the 'Bay Cell Limits' sheet has focus.
	
		if keyCode = J_key_Tab then
			
			theActiveControl := app.activeControl;	// where we are tabbing from
			
			theBay := self.myCurrentBay;
			if theBay &lt;&gt; null then
				editMode := theBay.isTransient;
			endif;
			if editMode then
				if theActiveControl.name = "_inputTypeText" and theActiveControl.parent &lt;&gt; null and theActiveControl.parent.isKindOf(Table) then
					theActiveControl := theActiveControl.parent.Control;
				endif;
			endif;
			
			if shift = 0 then
				// Ok we have a normal Tab, are we interested in it?
				if theActiveControl = self.fldVessel then
					// moving forward into ' on deck' table
					self.tblOnCellDims.clearAllSelected;
					self.tblOnCellDims.row := self.tblOnCellDims.fixedRows + 1;
					if self.tblOnCellDims.columns &gt; self.tblOnCellDims.fixedColumns then
						self.tblOnCellDims.column := self.tblOnCellDims.fixedColumns + 1;
					endif;
			
				elseif theActiveControl = self.tblOnCellDims then 
					if ( self.tblOnCellDims.row = self.tblOnCellDims.rows )
					and ( self.tblOnCellDims.column = self.tblOnCellDims.columns ) then
						// moving forward into 'under deck' table
						self.tblUnderCellDim.clearAllSelected;
						self.tblUnderCellDim.row := self.tblUnderCellDim.fixedRows + 1;
						if self.tblUnderCellDim.columns &gt; self.tblUnderCellDim.fixedColumns then
							self.tblUnderCellDim.column := self.tblUnderCellDim.fixedColumns + 1;
						endif;
						self.tblOnCellDims.clearAllSelected;	// don't leave with cell selected..
					endif;
				elseif theActiveControl = self.tblUnderCellDim then 
					if ( self.tblUnderCellDim.row = self.tblUnderCellDim.rows )
					and ( self.tblUnderCellDim.column = self.tblUnderCellDim.columns ) then
						// moving forward from 'under deck' table
						self.tblUnderCellDim.clearAllSelected;	// don't leave with cell selected..
					endif;
				endif;
		
			elseif shift = 1 then
				// This one is a back Tab, are we interested in it?
				if theActiveControl = self.cmbBayList then
					// moving back into 'under deck' table
					self.tblUnderCellDim.clearAllSelected;
					self.tblUnderCellDim.row := self.tblUnderCellDim.rows;
					self.tblUnderCellDim.column := self.tblUnderCellDim.columns;
				
				elseif theActiveControl = self.tblUnderCellDim then 
					if ( self.tblUnderCellDim.row = self.tblUnderCellDim.fixedRows + 1 )
					and ( self.tblUnderCellDim.column = self.tblUnderCellDim.fixedColumns + 1 ) then
						// moving back into 'on deck' table
						self.tblOnCellDims.clearAllSelected;
						self.tblOnCellDims.row := self.tblOnCellDims.rows;
						self.tblOnCellDims.column := self.tblOnCellDims.columns;
						self.tblUnderCellDim.clearAllSelected;	// don't leave with cell selected..
					endif;
					
				elseif theActiveControl = self.tblOnCellDims then 
					if ( self.tblOnCellDims.row = self.tblOnCellDims.fixedRows + 1 )
					and ( self.tblOnCellDims.column = self.tblOnCellDims.fixedColumns + 1 ) then
						// moving back from 'on deck' table
						self.tblOnCellDims.clearAllSelected;	// don't leave with cell selected..
					endif;
				endif;
				
			endif;
			
		endif;
			
	endif;
	
	inheritMethod(keyCode, shift);	
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="b28396d7-c773-4938-b69f-6b77e31e1fe5">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.initComboBoxes();	

	if self.myCurrentCellularVessel &lt;&gt; null then
		if self.cmbVessel.findObject(self.myCurrentCellularVessel) &gt; 0 then
			self.cmbVessel.setObject(self.myCurrentCellularVessel);
		else
			self.myCurrentCellularVessel := null;
		endif;
	endif;

	self.setMyCurrentVessel(self.myCurrentCellularVessel);	

	self.cmbVessel.setFocus();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onDeckTierChange" id="b338a238-6fd6-457e-88c1-7f8603fc1828">
        <updating/>
        <source>onDeckTierChange()updating;
//--------------------------------------------------
// Created:	20 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	theTierOrder : String;
begin
	
	theTierOrder := self.txtOnDeckTier.text;
		
	if self.validateTierCellLabels('On Deck Tiers', theTierOrder) then
		self.doBuildComboBayString(self.cmbLashFrom, theTierOrder);	
		self.doBuildComboBayString(self.cmbUnlashFrom, theTierOrder);
	endif;
	
end;</source>
    </JadeMethod>
