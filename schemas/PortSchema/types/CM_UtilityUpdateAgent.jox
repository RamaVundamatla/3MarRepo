	self.setupInvoiceStatus(pelProcess, CM_Invoice.INVOICE_POSTED,	 		5, 	app.getErrorString(Posted), PINEmail_InvProcPel1Offset);	 // ### TFS 52184 20OCT2021 NAVAB1
	self.setupInvoiceStatus(pelProcess, CM_Invoice.INVOICE_POSTED_CREDIT, 	6, 	app.getErrorString(Posted_credit), PINEmail_InvProcPel1Offset);	 // ### TFS 52184 20OCT2021 NAVAB1
