    <JadeMethod name="getClientConnectionDetails" id="0ce7886b-0f38-481e-8078-e5e731eed127">
        <source>getClientConnectionDetails(_deviceName, _terminalCode, _username : String output) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iniFileName : String;
begin
	iniFileName 			:= app.getIniFileName();
	_terminalCode			:= app.getProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedTerminal, null);
	_deviceName				:= app.getProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedDevice, null);
	_username				:= app.getProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedUser, null);
	/*
	if _terminalCode = null then
		app.msgBox('Ini file [' &amp; VehicleMountedIniSection &amp; '] section has not been configured correctly.' &amp; CrLf &amp;
		'It is missing a "' &amp; Key_VehicleMountedTerminal &amp; '" parameter', 'Inialization file error', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	*/
	if _deviceName = null then
		//app.msgBox('Ini file [' &amp; VehicleMountedIniSection &amp; '] section has not been configured correctly.' &amp; CrLf &amp;
		//'It is missing a "' &amp; Key_VehicleMountedDevice &amp; '" parameter', 'Inialization file error', MsgBox_Exclamation_Mark_Icon);
		//return false;
	else
	// on the rt queue screen the way we can peek at form is via process therefore setting the process userInfo to the device
		beginTransaction;
			process.userInfo := _deviceName;
		commitTransaction;
	endif;
	
	return true;
	
end;

</source>
        <Parameter name="_deviceName" type="String" usage="output"/>
        <Parameter name="_terminalCode" type="String" usage="output"/>
        <Parameter name="_username" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
