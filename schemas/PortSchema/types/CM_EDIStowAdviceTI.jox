    <JadeMethod name="isForLocal" id="2ef7d3bf-9e39-4c26-9628-02e164ece31d">
        <source>isForLocal(_localPort :String): Boolean;
//----------------------------------------------------------------
//	Created:	21 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 05/09/2012	cnwcs5	par 29842 - pass in local port to save looking up config multiple times when in loop

vars
	
begin
	if self.mode = CM_EDIStowAdviceTI.MODE_LOA
	or self.mode = CM_EDIStowAdviceTI.MODE_SHI				// cnwrl1 09/11/2010 PAR 25918.
	or self.mode = CM_EDIStowAdviceTI.MODE_RES then
		return true;
	endif;
	
	return false;
	
end;
</source>
