    <JadeMethod name="doBtnHazardsRemove" id="40818044-6b52-4185-9ac8-3c081d08cab8">
        <updating/>
        <source>doBtnHazardsRemove() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	locations : CM_LCArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

	
begin
	self.frmGridArea.enabled := false;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Hazards","Removing...");
	self.tblOther.clearValues();
	self.mulNotifyEmails.setSelected( null );
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteRestrictionHazards(self.myCurrentHazardDetail, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Hazards', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.myCurrentHazardDetail := null;
	
epilog
	self.frmModalDialog.visible := false;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHazardsSave" id="34de4e49-3996-4527-866e-0c45471106a7">
        <updating/>
        <source>doBtnHazardsSave() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	index : Integer;
	currLocations, newLocations : CM_LCArray;
	loadStateSet : Boolean;
	point : CMUI_GridPoint;
	controller : CM_LocationsController;
	newHazDetails : CM_TerminalAreaHazDetails;
	result : Integer;
	hazClass : CM_HazardClass;
	flashpoints : CM_HazTempRangeByValueDict;
	packingGroups : StringArray;
	row : Integer;
	obj : Object;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Hazards","Saving...");
	// ################################
	// ### SET UP PROXY
	if self.myCurrentHazardDetail &lt;&gt; null then
		index := self.lstRestrictions.findObject(self.myCurrentHazardDetail);
	else
		index := self.getListIndexForAdd();
	endif;
	if self.mode = self.Mode_Add then
		// Create a proxy
		create self.myProxyHazardDetails as CM_TerminalAreaHazDetails transient;
	endif;
	
	create currLocations transient;
	if self.mode = self.Mode_Update then
		// keep these for updating GUI
		self.myCurrentHazardDetail.allLocationsControllers.copy(currLocations);
	
		app.cmsBeginLoad(loadStateSet);
		self.myProxyHazardDetails := self.myCurrentHazardDetail.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadStateSet);
	endif;	

	create newLocations transient;

	if self.myCurrentTerminalArea.isRestrictionBlockStack() then
		if self.myCurrentTerminalArea.isKindOf(CM_Depot) then
			newLocations.add(self.myCurrentTerminalArea.CM_Depot.myLocationsController);
		// TFS 3422 add more area types, handle bulk area
		elseif self.myCurrentTerminalArea.isKindOf(CM_BulkArea) then
			newLocations.add(self.myCurrentTerminalArea.CM_BulkArea.myLocationsController);
		else
			newLocations.add(self.myCurrentTerminalArea.CM_BlockStack.myLocationsController);	
		endif;
	else
		foreach point in self.frmGridArea.myGridArea.allSelectedPoints do
			controller := point.myLocationsController;
			if controller &lt;&gt; null then
				if not newLocations.includes(controller)then
					newLocations.add(controller);
				endif;
			endif;
		endforeach;
	endif;
	
	if self.cmbHazClass.listIndex &gt; 0 then
		hazClass := self.cmbHazClass.itemObject[self.cmbHazClass.listIndex].CM_HazardClass;
	endif;
	create flashpoints transient;
	foreach obj in self.tblFlashpoints.allSelectedObjects do
		flashpoints.add(obj.CM_HazTempRange);
	endforeach;
	create packingGroups transient;
	foreach row in self.tblPackGroups.fixedRows + 1 to self.tblPackGroups.rows do
		if self.tblPackGroups.accessCell(row, 1).text = "1" then
			packingGroups.add(self.tblPackGroups.accessCell(row, 2).text);
		endif;
	endforeach;
	
	self.myProxyHazardDetails.setProxy(	self.tblOther.getValueByName(ETRow_Id).String,
										self.tblOther.getValueByName(ETRow_Colour).Integer,
										hazClass,
										flashpoints,
										packingGroups,
										self.tblOther.getValueByName(ETRow_AcidsBases).String,
										self.tblOther.getValueByName(ETRow_AllowNonHazardous).Boolean, 
										self.tblOther.getValueByName(ETRow_ShowError).Boolean, 
										newLocations,
										self.myCurrentTerminalArea	);
	
	self.modalDialogShow(null, 'Cancel', null, null, "Hazard " &amp; self.myProxyHazardDetails.id, "Saving...");
	// ################################
	// ### TRX IT
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateTermAreaHazDetail(self.myProxyHazardDetails, newHazDetails, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.myCurrentHazardDetail := newHazDetails.CM_TerminalAreaHazDetails;
			endif;
		else
			app.myTrxUA.trxUpdateTermAreaHazDetail(self.myProxyHazardDetails, self.myCurrentHazardDetail, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Hazard', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	// ################################
	// ### CLEAN UP GUI
	self.frmGridArea.enabled := false;
	self.doEnableControls(false);
	self.displayHazardDetails(self.myCurrentHazardDetail);
	
	//22 May 2017	NDL	TFS 4332
	self.doComboTermAreaClick(self.cmbTermAreas);	
	if index &gt; 0 and index &lt;= self.lstRestrictions.listCount then
		self.lstRestrictions.listIndex := index;
		self.lstRestrictions.click(self.lstRestrictions);
	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);
	self.frmModalDialog.visible := false;
	delete self.myProxyHazardDetails;
	delete newLocations;
	delete currLocations;
	delete flashpoints;
	delete packingGroups;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHeightCancel" id="3a2c3171-c0f3-47c0-a82d-93ea1eb79384">
        <updating/>
        <source>doBtnHeightCancel() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;
	theReturn : Integer;
	dataChanged : Boolean;
begin
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	dataChanged := self.tblOther.hasChanged;
	if not dataChanged and theArea &lt;&gt; null then
		dataChanged := theArea.dataChanged;
	endif;
	if dataChanged  then
		theReturn := app.msgBox("You have changed data on this Height Restriction." &amp; Cr &amp; "Do you want to save now?","Confirm Save",
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
		if theReturn = MsgBox_Return_Yes then
			self.doBtnHeightSave();
			return;
		endif;
	endif;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doMenuHeightsUndo();
	self.allInterfaceObjects.purge();
	
	theArea.doLockAll(false);
	theArea.clearAllSelectedItems();
	theArea.editMode := false;
	self.doDrawGridArea();
//	self.mySDF.drawSelf();
	self.frmGridArea.enabled := false;
	self.doMenuHeightsHide(true, false);
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHeightEdit" id="14a3f884-cfc6-4ee6-a669-27bb9e61f7f1">
