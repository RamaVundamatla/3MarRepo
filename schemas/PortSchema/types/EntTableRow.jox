    <JadeMethod name="getHeading" id="7a9ef8d3-4c91-42b8-b06c-11e01574b7b0">
        <source>getHeading(_cargoBOLType : CM_CargoBOLType; _terminal : CM_Terminal; _locale : CM_Locale) : String;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     heading is protected - retrieval of value must come through here.
//				returns alternate heading if terminology relivant
//
// Changes:     8/8/2006 RBarr Retrieve from new TranslatableText structure
//
// 12 Jan 2026  navlc30  JIRA 36954 Story MTN | Highlight Mandatory fields
// ----------   ----------  --------------------------------------------------
vars
	translation	: XLAT_Translation;
	tmpHeading	: String;
begin

	tmpHeading := self.getTerminologyHeading(_cargoBOLType, _terminal, false);
	if tmpHeading &lt;&gt; null then
		return tmpHeading;
	endif;

	if _locale = null then
		//return self.heading;						//12.01.2026 navlc30 #36954
		if self.isMandatoryField then				//12.01.2026 navlc30 #36954
			return self.heading &amp; "*";
		else
			return self.heading;
		endif;		
	endif;
	
	translation := self.getTranslation(_locale);

	if translation = null or translation.text = null then
		//return self.heading;						//12.01.2026 navlc30 #36954
		if self.isMandatoryField then				//12.01.2026 navlc30 #36954
			return self.heading &amp; "*";
		else
			return self.heading;
		endif;
	endif;

	return translation.text;
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInputTypeDetails" id="444294b6-607a-4f93-83f5-adfc194ed00d">
        <source>getInputTypeDetails(inputTypeDescr : String output; inputTypeClass : Class output);
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if self.inputType = Table.InputType_None then
		 inputTypeDescr := 'None';
	elseif self.inputType = Table.InputType_CheckBox then
		inputTypeDescr := 'CheckBox';
	elseif self.inputType = Table.InputType_TextBox then
		inputTypeDescr := 'TextBox';
		inputTypeClass :=  EntTableTextBox;
	elseif self.inputType = Table.InputType_ComboBox then
		inputTypeDescr := 'ComboBox';
	elseif self.inputType = Table.InputType_TextNumeric then
		inputTypeDescr := 'TextNumeric';
		inputTypeClass := EntTableTextNumeric; 
	elseif self.inputType = Table.InputType_SignedNumeric then
		inputTypeDescr := 'SignedNumeric';
		inputTypeClass := EntTableSignedNumeric;
	else
		inputTypeDescr := 'Unknown';
	endif;

end;</source>
        <Parameter name="inputTypeDescr" type="String" usage="output"/>
        <Parameter name="inputTypeClass" type="Class" usage="output"/>
    </JadeMethod>
