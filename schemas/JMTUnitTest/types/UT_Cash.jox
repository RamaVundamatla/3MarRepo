				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
				self.assertTrueMsg(cashPay.cashValue = 57.6, idx.String &amp; " cash payment value &lt;&gt; 230.4 AAAZ");
			elseif idx.isOneOf(3) then //  ROAD RELEASE
				self.assertTrueMsg(cashPay.myProformaDetail &lt;&gt; null, idx.String &amp; " Cash Pay has no proforma detail");
				self.assertTrueMsg(cashPay.myProformaDetail.myInvoiceLineType = invLineType2 ,  idx.String &amp; " line type sbe invLineType2");
				self.assertTrueMsg(cashPay.cashValue = 57.6,  idx.String &amp; " cash payment value &lt;&gt; 230.4 CCCCZ");
			elseif idx.isOneOf(2) then // TO DO TASK
