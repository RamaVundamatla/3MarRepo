    <JadeMethod name="isCoveredByOOTL" id="2f30eec6-52e2-40de-a009-7411c64481bf">
        <source>isCoveredByOOTL(_type : Integer) : Boolean;
/*
Purpose:		29178	
Date				Who			Reason
MARCH 2012		CNWAB1		Initial creation
*/


vars
	coveringItem : CM_DeckItemLayout;
begin
	coveringItem := self.allCoveringPolygons[_type];
	
	if coveringItem = null then
		return false;
	endif;
	
	if coveringItem.myDeckItem = null then
		return false;
	endif;
	
	return coveringItem.myDeckItem.isOOTL();
	
epilog

