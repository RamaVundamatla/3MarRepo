    <JadeMethod name="acceptMove" id="9adfa025-047a-48b9-bab2-049cb95a97ec">
        <updating/>
        <source>acceptMove(_task :CM_RTQueueTask; _target: String) updating;
// ---------------------------------------------------------------------------
// Created:     01 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Record an Accept in the machine history
// Parameters:  _task 		- task being accepted
//				_target		- target location id
//				_machine	- machine doing accept
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForAccept(_task, _target);
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_target" type="String"/>
    </JadeMethod>
    <JadeMethod name="amendForMachine" id="8db1da2e-9892-48db-8ec2-e9be608612aa">
        <updating/>
        <source>amendForMachine( _machine : CM_Machine) updating, protected;
/*
Purpose:		Move history from 1 IMV to another after an IMV switch		
Parameters:		_machine 	- IMV to move history TO	
Return Value:		

Date			Who		Reason
28 April 2010	cnwrd1	Initial creation
//cnwrd1 par 23997 28.4.2010
22/11/2010		cnwcs5	par 23714/ccms 1132 - handle accepts as well
*/
vars

begin
	if self.type = CM_MachineHistory.Type_PickUp then	// 22/11/2010 cnwcs5 par 23714/ccms 1132	
		self.targetLocation := _machine.id;
	endif;												// 22/11/2010 cnwcs5 par 23714/ccms 1132	
	
	self.machine 		:= _machine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="amendMove" id="f574ffc0-5984-48b7-8397-ee9eaed27a78">
        <updating/>
        <source>amendMove(_sourceLocationId, _targetLocationId : String; _ti : CM_TrackedItem; _userCode: String; _mach: CM_Machine) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwrd1	Initial creation
//cnwrd1 par 23997 28.4.2010
*/

vars

begin

	self.setForAmendment( 	_sourceLocationId, 
							_targetLocationId,
							_ti,
							_userCode,
							_mach);


epilog

end;</source>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="amendMoveHistoryForIMVSwitch" id="f15ca72f-2658-4127-9dbf-10d779f373d8">
        <updating/>
        <source>amendMoveHistoryForIMVSwitch(_machine :CM_Machine) updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Adjust machine history after IMV switch
// Parameters:  _machine	- IMV the move is being switched TO
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	moveHistory, lastHistory, startOfLift,
	startOfMove				: CM_MachineMoveHistory;
	thisHistory				: CM_MachineHistory;
	oldColl, newColl		: CM_MachineHistoryByDateTime;	
	notComplete				: Boolean;
	type, count				: Integer;
	iter					: Iterator;
begin	
	// ----------------------------------------------------------------------------------------
	// populate oldColl with all history entries for the lift our task is part of
	// ----------------------------------------------------------------------------------------
	create oldColl transient;
	create newColl transient;
		
	self.getAllLiftEntries (oldColl);
	// ----------------------------------
	// move history over to new machine
	// ----------------------------------
	moveHistory := self;

	while moveHistory &lt;&gt; null do					
		// move to other machine
		moveHistory.amendForMachine(_machine);
		// we want oldColl to only contain history for the old machine
		oldColl.removeIfPresent (moveHistory);
		// history for the new machine goes into newColl
		newColl.add (moveHistory);
		// clear out lift linkages - these will be set later on the target machine
		moveHistory.myPriorLiftHistory 	:= null;
		moveHistory.myNextLiftHistory 	:= null;
		moveHistory.isStartOfLift		:= false;
		setMyLastWorkingHistory (null);
		// make sure we get accept as well
		moveHistory := moveHistory.myPriorHistory.CM_MachineMoveHistory;	
	endwhile;		
	
	startOfMove := newColl.first.CM_MachineMoveHistory;

	// --------------------------------------
	// sort out lift linkages for old machine
	// --------------------------------------
	foreach thisHistory in oldColl do
		moveHistory := thisHistory.CM_MachineMoveHistory;
		type 		:= thisHistory.type;

		if type = CM_MachineMoveHistory.Type_AcceptMove or type = CM_MachineMoveHistory.Type_PickUp then
			if moveHistory.getEndOfMoveTS = null then
				// an incomplete move
				notComplete := true;
			elseif type = CM_MachineMoveHistory.Type_AcceptMove then
				// increment number of incomplete moves in this lift
				count := count + 1;
			endif;
		elseif type = CM_MachineMoveHistory.Type_SetDown then
			// decrement number of incompete moves in this lift
			count := count - 1;
		endif;
		
		if type = CM_MachineMoveHistory.Type_SetDown and notComplete = false and count = 0 then
			// by doing the IMV switch, we now have a completed lift where before we did not.
			// we now need to set end of lift properties
			moveHistory.isEndOfLift 		:= true;
			moveHistory.myNextLiftHistory 	:= null;	// inverse maintenance		
			lastHistory 					:= null;	// so next iteration will be start of lift
			continue;
		endif;
		
		if lastHistory &lt;&gt; null then
			moveHistory.myPriorLiftHistory 	:= lastHistory;
			moveHistory.isStartOfLift		:= false;
			moveHistory.isEndOfLift			:= false;
		else
			// first history for lift - set start of lift properties
			moveHistory.myPriorLiftHistory := null;
			moveHistory.setLastWorkingHistory (null, moveHistory.machine);	// will set isStartOfLift if necessary
		endif;
					
		lastHistory := thisHistory.CM_MachineMoveHistory;
	endforeach;
	// work out whether the last lift is complete or not
	if lastHistory &lt;&gt; null then	
		if notComplete then
			// lift is not complete
			lastHistory.isEndOfLift := false;
		else
			// lift is complete
			lastHistory.isEndOfLift := true;
		endif;
	endif;
	// -------------------------------------
	// now sort out linkages for new machine
	// -------------------------------------	

	// find the most recent start of lift  - the move being switched
	// will become part of that lift which will now be incomplete
	// any subsequent lifts will also be linked and 'uncompleted'
	iter := _machine.history.createIterator;
	
	iter.startAtObject (startOfMove);
	
	while iter.back (thisHistory) do
		if not thisHistory.isMoveHistory then
			continue;
		endif;
		
		moveHistory := thisHistory.CM_MachineMoveHistory;
		type 		:= moveHistory.type;
		
		if type &lt;&gt; CM_MachineHistory.Type_AcceptMove and
			type &lt;&gt; CM_MachineHistory.Type_PickUp and
			type &lt;&gt; CM_MachineHistory.Type_SetDown then
			continue;
		endif;
		
		if moveHistory.isEndOfLift then
			// the task being switched will be the start of the lift
			break;
		endif;
		
		if moveHistory.isStartOfLift then
			// we have found the start of the lift to which the move will be added
			startOfLift := moveHistory;
			break;
		endif;
	endwhile;
	
	if startOfLift = null then
		startOfLift := startOfMove;
	endif;
	// ------------------------------------------------------------------------------------
	// we have added an incomplete move so now everything after it will be part of the same lift
	// ------------------------------------------------------------------------------------
		
	iter.reset;
	iter.startAtObject (startOfLift);
	
	lastHistory := null;
	
	while iter.next (thisHistory) do
		// going through the lift entries in date time order
		if not thisHistory.isMoveHistory then
			continue;
		endif;
		
		moveHistory := thisHistory.CM_MachineMoveHistory;
		type 		:= moveHistory.type;
		
		if type &lt;&gt; CM_MachineHistory.Type_AcceptMove and
			type &lt;&gt; CM_MachineHistory.Type_PickUp and
			type &lt;&gt; CM_MachineHistory.Type_SetDown then
			continue;
		endif;
		// we have added an incomplete move to this machine so the lift cannot be complete
		moveHistory.isEndOfLift 		:= false;
		moveHistory.myNextLiftHistory	:= null;
		
		if moveHistory &lt;&gt; startOfLift then 
			// not start of lift
			moveHistory.myPriorLiftHistory 	:= lastHistory;
			moveHistory.isStartOfLift		:= false;
			moveHistory.setMyLastWorkingHistory (null);
		else
			// start of lift
			moveHistory.myPriorLiftHistory := null; 
			moveHistory.setLastWorkingHistory (null, _machine);	// will set isStartOfLift if necessary
		endif;
		
		lastHistory := moveHistory;
	endwhile;
epilog
	delete oldColl;
	delete newColl;
	delete iter;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeString" id="25b17f4d-c3db-40ef-8147-654474c6e2f8">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoTypeString(set: Boolean; value: String io) mapping;

vars
	tmpCargoType : CM_CargoType;
begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if tiId.trimBlanks = null then	//If no id, then cargoType is blank too!
		return;
	endif;
	tmpCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if tmpCargoType &lt;&gt; null then
		value := tmpCargoType.description.trimBlanks;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="completedMove" id="24ceb372-c9fd-418c-9868-4d24c9f53869">
        <updating/>
        <source>completedMove(_sourceLocationId, _targetLocationId : String; _ti : CM_TrackedItem; _userCode: String; _mach: CM_Machine) updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Refactored methods
25 Aug 2010	cnwcs5	Par 25313 - IMV always has pickup/setdown
02/11/2010	cnwcs5	par 23714/ccms 1132 - machine productivity reporting
*/

vars
	source, target	:String;
	type			:Integer;
begin 
	
	source 	:= _sourceLocationId;
	target	:= _targetLocationId;
	type 	:= self.Type_Move;
	
	if _mach.isIMV then
		// task will be IMV move task
		if _sourceLocationId = _mach.id then
			// convert move from IMV to setDown by IMV
			type	:= self.Type_SetDown;
		elseif _targetLocationId = _mach.id then
			// convert move to IMV to pickup by IMV
			type	:= self.Type_PickUp;
		endif;
	endif;
	
	self.setForCompletion(type, source, target, _ti, _userCode, _mach, null);	// 02/11/2010 cnwcs5 par 23714/ccms 1132
end;</source>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="completedPickup" id="7097beb3-b869-477d-9892-871f73cfccf9">
        <updating/>
        <source>completedPickup(_sourceLocationId : String; _ti : CM_TrackedItem; _userCode: String; _machine: CM_Machine) updating;
/*
Date		Who		Reason
16 October 2012	cnwcs5	Initial creation - par 30382
*/
vars

begin
	self.setForCompletion(self.Type_PickUp, _sourceLocationId, _machine.myMachineController.id, _ti, _userCode, _machine, null);
epilog

end;</source>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="completedSetdown" id="0a3810a2-1c9e-415d-9ac4-cb096e683222">
        <updating/>
        <source>completedSetdown(_targetLocationId : String; _ti : CM_TrackedItem; _userCode: String; _machine: CM_Machine) updating;
/*
Date		Who		Reason
16 October 2012	cnwcs5	Initial creation - par 30382
*/
vars

begin
	self.setForCompletion(self.Type_SetDown, _machine.myMachineController.id, _targetLocationId, _ti, _userCode, _machine, null);
epilog

end;</source>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="completedTask" id="4f834dc8-8c2e-4fb0-b9d5-faf3bf9105de">
        <updating/>
        <source>completedTask(_task: CM_RTQueueTask; _userCode: String; _mach: CM_Machine) updating;

/*

Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Refactored methods
19 Aug 2010	cnwcs5	par 25313 - RTG setodwn is IMV pickup and vice versa.  use IMV move to get source/target locations
03/09/2010	cnwcs5	par 25313 - new method to get source and target locations
02/11/2010	cnwcs5	par 23714/ccms 1132 - machine productivity reporting
*/
vars
	typeLocal		: Integer;
	isOtherMachine	: Boolean;
	source, target	: String;
	imvMoveTask	:CM_RTQueueTask;
begin 
	// _task may be for a machine other than _mach in the case of an IMV. _task could be a setDown onto an IMV 
	// or a pickup from the IMV by another machine.  if this is the case then we record the setDown as a pickup
	// and the pickup as a setDown because history is from the IMV's perspective
	isOtherMachine := _mach &lt;&gt; null and _mach.isIMV and _task.myEntry &lt;&gt; null and _task.myEntry.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV;
	
	source 	:= _task.getSourceLocationIdForHistory (false);				// 03/09/2010 cnwcs5 par 25313
	target	:= _task.getTargetLocationIdForHistory;						// 03/09/2010 cnwcs5 par 25313
	
	if _task.taskType = TASK_PICKUP then 
		if isOtherMachine then											// 19 Aug 2010	cnwcs5	par 25313
			// another machines pickup is a setdown on the IMV
			typeLocal 	:= Type_SetDown; 								// 19 Aug 2010	cnwcs5	par 25313
			// let's try and get the source/target for the IMV move
			imvMoveTask	:= _task.myEntry.getPreviousEntryFirstMoveTask;		// 25.11.2010 cnsrd1 par 25681	
			if imvMoveTask &lt;&gt; null and 									// 19 Aug 2010	cnwcs5	par 25313
				imvMoveTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then	// 19 Aug 2010	cnwcs5	par 25313
				target	:= imvMoveTask.getTargetLocationIdForHistory;	// 03 Sep 2010	cnwcs5	par 25313
			endif;														// 19 Aug 2010	cnwcs5	par 25313
		else															// 19 Aug 2010	cnwcs5	par 25313
			typeLocal := Type_PickUp; 
		endif;															// 19 Aug 2010	cnwcs5	par 25313
	elseif _task.taskType = TASK_SETDOWN then
		if isOtherMachine then											// 19 Aug 2010	cnwcs5	par 25313
			// another machines setdown is a pickup on the IMV
			typeLocal := Type_PickUp; 							// 19 Aug 2010	cnwcs5	par 25313
			// let's try and get the source/target for the IMV move
			imvMoveTask	:= _task.myEntry.getNextEntryFirstMoveTask;		// 25.11.2010 cnwrd1 multi machine director moves first task could now be a director. par 25681
			
			if imvMoveTask &lt;&gt; null and 									// 19 Aug 2010	cnwcs5	par 25313
				imvMoveTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then	// 19 Aug 2010	cnwcs5	par 25313
				source 	:= imvMoveTask.getSourceLocationIdForHistory (false);	// 03 Sep 2010	cnwcs5	par 25313
			endif;														// 19 Aug 2010	cnwcs5	par 25313   
		else													// 19 Aug 2010	cnwcs5	par 25313	
			typeLocal := Type_SetDown; 		
		endif;													// 19 Aug 2010	cnwcs5	par 25313
	elseif  _task.taskType = TASK_MOVE then
		typeLocal := self.Type_Move;

		if _task.ti &lt;&gt; null and ( _task.ti.isOnShip or _task.sourceLocation.isKindOf(CM_CraneLaneController) )then			// 26 Aug 2010	cnwcs5	par 25313  //cnwrd1 19.5.2011 par 25795
			// we are coming off a ship and _mach is the target
			if _mach &lt;&gt; null and _mach.isIMV then				// 26 Aug 2010	cnwcs5	par 25313
				// we always have pickup/setDown so convert Move to
				// pickup from ship
				typeLocal	:= self.Type_PickUp;				// 26 Aug 2010	cnwcs5	par 25313
				
				if _mach &lt;&gt; null then //cnwrd1 par 29970
					target := _mach.id;
				endif;
			endif;												// 26 Aug 2010	cnwcs5	par 25313
		endif;													// 26 Aug 2010	cnwcs5	par 25313
		
		//cnwrd1 par 25624 3.7.2012 if we are going to a shop and from an IMV and we are the last task this is a setdown ( in reality a move from crane to ship)
		if _task.ti &lt;&gt; null 
		 and (_task.targetLocation.isKindOf(CM_VoyageController) or _task.targetLocation.isKindOf(CM_CraneLaneController) ) //13 July 2012	NDL Par 30039
		 and _task.myEntry.getNextRelatedEntry() =  null then  //epr par 35702 17/2/15
			if _mach &lt;&gt; null and _mach.isIMV then	
				typeLocal	:= self.Type_SetDown;
								
				if _mach &lt;&gt; null then //cnwrd1 par 29970
					source := _mach.id;
				endif;
				
			endif;
		endif;
	else
		typeLocal := Type_Unknown;
	endif;
	
	self.setForCompletion(typeLocal,
						  source,
						  target,
						  _task.ti,
						  _userCode,
						  _mach,
						  _task);
end;
</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="findLastWorkingHistory" id="c0762b5f-8180-4aea-88d1-3f592dc3ed3d">
        <source>findLastWorkingHistory(_machine :CM_Machine):CM_MachineMoveHistory protected;
/*
Date		Who		Reason
16 Oct 2012	cnwcs5	Initial creation - par 30382
*/
constants
	MAGIC_NUMBER = 1000;
vars
	history		:CM_MachineHistory;
	moveHistory	:CM_MachineMoveHistory;
	historyType,
	count		:Integer;
	iter		:Iterator;
begin
	iter := _machine.history.createIterator;
	
	// we are looking for the most recet activity prior to the receiver
	if _machine.history.includes (self) then
		iter.startAtObject (self);
	endif;
		
	while iter.back (history) do
		if not history.canBeUsedInKPIReporting then
			break;
		endif;
		
		if history = self then
			continue;
		endif;
		
		historyType := history.type;
		// hopefully we find a set-down or move
		if historyType = CM_MachineHistory.Type_AcceptMove or	// incomplete lift
			historyType = CM_MachineHistory.Type_PickUp or		// incomplete lift
			historyType = CM_MachineHistory.Type_SetDown or
			historyType = CM_MachineHistory.Type_Move then

			moveHistory := history.CM_MachineMoveHistory;
			
			return moveHistory;
		endif;
		
		// we need to stop B4 we troll through the entire history - probably won't happen as we would find a move somewhere
		count := count + 1;
		
		if count &gt;= MAGIC_NUMBER then
			// we're not going to find it - sooooooo unlikely that there would be no work for this machine AND 1000 items in the history
			break;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="getAcceptMoveTS" id="b7a3632f-1a37-4218-bd3c-68bb542033a2">
        <source>getAcceptMoveTS():TimeStamp;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/10/2012	cnwcs5	par 30382 - is no accept use  pickup
// ---------------------------------------------------------------------------
vars
	type			:Integer;
	ts				:TimeStamp;
	priorHistory	:CM_MachineMoveHistory;
begin 
	type 			:= self.type;
	ts				:= null;
	priorHistory	:= self.myPriorHistory.CM_MachineMoveHistory;
	
	if type = self.Type_AcceptMove then
		ts := self.dateTime;
		
	elseif type = self.Type_PickUp or
		type = self.Type_Amendment or 
		type = self.Type_SetDown then
		
		if priorHistory &lt;&gt; null then
			ts := priorHistory.getAcceptMoveTS;
		
		elseif type = self.Type_PickUp then										// par 30382
			// there is no  Accept for this Pickup so use the Pickup date/time
			ts := self.dateTime;												// par 30382
		endif;																	// par 30382
		
	elseif type = self.Type_Move then
		// instant move
		ts := self.dateTime;
	endif;
	
	return ts;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAcceptMoveTSLocalTZ" id="29272036-aa6b-4fa1-a20e-38dc72ba90d7">
        <source>getAcceptMoveTSLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.getAcceptMoveTS());
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAllLiftEntries" id="ff6496d4-1f76-4b50-8987-e1660709f5ed">
        <source>getAllLiftEntries(_coll :CM_MachineHistoryByDateTime input);
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Populate _coll with all move histories for the current lift
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	history	:CM_MachineHistory;
begin
	_coll.add (self);
	
	history := self.myPriorLiftHistory;
	
	while history &lt;&gt; null do
		_coll.add (history);
		
		history := history.CM_MachineMoveHistory.myPriorLiftHistory;
	endwhile;
	
	// look for stuff after the receiver
	history := self.myNextLiftHistory;
	
	while history &lt;&gt; null do
		_coll.add (history);
		
		history := history.CM_MachineMoveHistory.myNextLiftHistory;
	endwhile;
epilog

end;</source>
        <Parameter name="_coll" type="CM_MachineHistoryByDateTime" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllMoveEntries" id="f168c584-b402-483f-a049-25eda2777803">
        <source>getAllMoveEntries(_coll :CM_MachineHistoryByDateTime input);
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	history	:CM_MachineHistory;
begin
	if self.type &lt;&gt; self.Type_SetDown or not self.isEndOfMove &lt;&gt; null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'method called for item that is not end of lift');
	endif;
	// should only be called for a setDown	
	
	_coll.add (self);
	
	history := self.myPriorHistory;
	
	while history &lt;&gt; null do
		_coll.add (history);
		
		history := history.myPriorHistory;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_coll" type="CM_MachineHistoryByDateTime" usage="input"/>
    </JadeMethod>
