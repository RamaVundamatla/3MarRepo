        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="1fbd14f6-f0ef-40b6-82a0-147d2b031cec">
        <updating/>
        <source>jssSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's caption with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.caption &lt;&gt; pValue then
		self.caption	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssString" id="b8a3fe81-afd2-4ded-ae97-422db275b11a">
        <source>jssString():String;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the (trimmed) text value of the receiver's caption.
//
// Parameters:	None
//
// Returns:		String - the trimmed caption value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssTime" id="91f3db6e-733b-4252-a0b7-64a7f8d0b93c">
