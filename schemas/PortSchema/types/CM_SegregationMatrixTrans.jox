    <JadeMethod name="importMyReferencesXML" id="5187e8f2-d307-4303-850e-8ce36b6540eb">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	segCondCode,
	hazardCode1,
	hazardCode2		: String;
	hazardClass1,
	hazardClass2			: CM_HazardClass;
	segregationRule			: CM_SegregationRule;
	segCondition			: CM_SegregationCondition;
begin
	hazardCode1 			:= _referencesBlock.cnEcGetTagValueOfName('myHazardClass1');
	hazardCode2 			:= _referencesBlock.cnEcGetTagValueOfName('myHazardClass2');
	segCondCode				:= _referencesBlock.cnEcGetTagValueOfName('segregationCondition');
	
	hazardClass1 := app.myRoot.allHazardClasses[hazardCode1];
	if hazardClass1 = null then
		app.raiseCMException1(Error_hazar_class_with_code_ne,hazardCode1,null, null);
	endif;
	
	hazardClass2 := app.myRoot.allHazardClasses[hazardCode2];
	if hazardClass2 = null then
		app.raiseCMException1(Error_hazar_class_with_code_ne,hazardCode2,null, null);
	endif;
	
	self.myEntity1 			:= hazardClass1;
	self.myEntity2 			:= hazardClass2;
		
	if segCondCode &lt;&gt; null then
		segCondition := app.myPassport.myTerminal.allSegregationConditions[self.mySegregationMatrixAgent.ruleType, segCondCode];
		if segCondition = null then
			app.raiseCMException1(Error_segre_condi_with_code_ne,segCondCode, null, null);
		endif;
		
		
		create segregationRule transient;
		segregationRule.setProxy(myEntity1, myEntity2, segCondition, app.myPassport.myTerminal);
		self.myPxySegregationRule 	:= segregationRule;
	endif;
	
end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
</Class>
