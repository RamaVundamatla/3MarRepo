    <JadeMethod name="selectLocationBlock" id="738c5bea-db30-4a54-9876-eea7180419b7">
        <updating/>
        <source>selectLocationBlock(_toLocation: CM_IrregularBlockController) updating, protected;
/*
Purpose:			 // PAR 32308
Date		Who		Reason
02 September 2013	cnwab1	Initial creation
*/

vars
	fromLocation : CM_IrregularBlockController;
	location: CM_LocationsController;
	region: PointArray;
	topLeft, bottomRight: Point;
	x1, y1, x2, y2 : Integer;

begin
	fromLocation := self.allSelectedObjects.last().CM_IrregularBlockController;
	if fromLocation = null then
		return;
	endif;
	topLeft := cellToPixel(fromLocation.region.first);
	bottomRight := cellToPixel(_toLocation.region.last.add(1, 1));

	x1 := topLeft.x+2;
	y1 := topLeft.y+2;
	
	x2 := bottomRight.x-2;
	y2 := bottomRight.y-2;

	self.selectBlockOfObjectsFromXYs(CM_IrregularBlockController, x1, y1, x2, y2);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_toLocation" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="selectRegion" id="09be5d1c-0ad1-4d47-9acf-6034bb3631f3">
        <source>selectRegion(region: PointArray; selectMode: Boolean) protected;
// select or deselected all the cells in a region depending on select mode setting
vars
	topLeft, bottomRight: Point;
	x, y: Integer;
begin
	topLeft := region.first;
	bottomRight := region.last;
	
	foreach x in topLeft.x to bottomRight.x do
		foreach y in topLeft.y to bottomRight.y do
			self.getCell(x, y).setIsSelected(selectMode);
		endforeach;
	endforeach;
	self.drawRegion(region);
end;
</source>
        <access>protected</access>
        <Parameter name="region" type="PointArray"/>
        <Parameter name="selectMode" type="Boolean"/>
    </JadeMethod>
