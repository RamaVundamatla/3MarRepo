    <JadeMethod name="jlgTimeTest" id="44b6e4f4-51ab-42dc-ac0c-beb8f9c599b6">
        <source>jlgTimeTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2018	jlgsh3	Initial creation

*/

vars
	int : Integer;
	dec : Decimal[6,2];
	tsStart,
	tsEnd	: TimeStamp;
	minDiff	: Integer;
	timeBlock : Decimal[10,1];
	isIntegerNull : Boolean;
	
begin
	tsEnd := tsEnd;
	//write tsEnd;
	tsStart := tsEnd.changeByXXMinutes(-1350);// changeByXXHours(-5);
	//tsStart := tsStart.changeByXXHours(-5);
	//minDiff := tsEnd.getDifferenceInMinutes(tsStart);
	//write minDiff.String &amp; ' minDiff';
	
//write tsEnd;
//return;

	int := tsEnd.getDifferenceInMinutes(tsStart);
	write int.String &amp; ' minutes difference';
	//int := 31;
	
	dec := int/60;
/*	int := 
	write dec.String &amp; ' before eval';
	
	if dec &gt; 0 then
		//if dec &lt; 1 then
		//	dec := 1.0;
		if dec &gt; 0 and dec &lt; 0.5 then
			dec := 0.5;
		elseif dec &gt; 0.5 and dec &lt; 1 then
			dec := 1;
		endif;
	endif;
	write dec.String &amp; ' after eval' &amp; CrLf;
	
	dec := differenceMins/60;// - int;
*/	
	int := dec.abs().Integer;
	dec := dec - int;
	
	
	if int = 0 then
		isIntegerNull := true;
	else 
		timeBlock := int.Decimal;
	endif;
	
	
	if dec &gt; 0 then
		if dec &lt; 1 and isIntegerNull then
			dec := 1.0;
		elseif dec &gt; 0 and dec &lt; 0.5 then
			dec := 0.5;
		elseif dec &gt; 0.5 and dec &lt; 1 then
			dec := 1;
		endif;
	endif;

	
	if isIntegerNull then
		timeBlock := dec;
	else
		timeBlock := timeBlock + dec;
	endif;
	write timeBlock;
epilog

end;</source>
    </JadeMethod>
