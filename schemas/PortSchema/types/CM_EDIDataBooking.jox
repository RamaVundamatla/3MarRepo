    <JadeMethod name="isValidForEDIMode" id="ac65d342-f85d-4fe1-a8df-e729e5accdc1">
        <source>isValidForEDIMode(_realBookingRef : CM_BookingRef; _ediBookingHeaderTI : CM_EDIBookingHeaderTI; _ediMode : String; _extraInfo : String output ) : Boolean protected;
//
// Par21718 cnwrs1 dec 2009
//
vars
	ediIsOlder	: Boolean;
	tmpEdiMode	: String;
begin

	//checking whether EDI file is not old
	if _realBookingRef = null then	// EDI date time is always valid - there is no date time at all
		ediIsOlder := false;
		
	elseif _realBookingRef.ediFileIssueDateTime = null then	//// EDI date time is always valid - there is no date time at all
		ediIsOlder := false;
	
	elseif _ediBookingHeaderTI.ediFileIssueDateTime = null then	//assume that _ediBookingRefTI &lt;&gt; null always. 
		ediIsOlder := false;
	else	//when both dates &lt;&gt; null
		ediIsOlder := _realBookingRef.ediFileIssueDateTime &gt; _ediBookingHeaderTI.ediFileIssueDateTime;
	endif;
	
	if _ediMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		tmpEdiMode := app.getErrorString(EDIData_ModeADD);
	elseif _ediMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		tmpEdiMode := app.getErrorString(EDIData_ModeUPDATE);
	else
		tmpEdiMode := app.getErrorString(EDIData_ModeDELETE);
	endif;

	// prepare extraInfo for audit information (CM_AuditObjectInformation)
	if ediIsOlder then		// cannot load EDI file - it is older than current _realBookingRef.ediFileIssueDateTime

		_extraInfo := app.getErrorString1(EDIModeIgnored, tmpEdiMode) &amp;" "
					&amp; app.getErrorString3(EDIFileIsOlderThanCurrent, _ediBookingHeaderTI.myEDIData.fileName, _ediBookingHeaderTI.ediFileIssueDateTime.asStringJMT(), _realBookingRef.ediFileIssueDateTime.asStringJMT() );
	else // can load EDI file - it is fresh or there are issue dates = null
	
		_extraInfo := app.getErrorString(EDIMode) &amp;" "&amp; tmpEdiMode &amp; ". "
					&amp; app.getErrorString2(EDIFileNameCreatedDateTime, _ediBookingHeaderTI.myEDIData.fileName, _ediBookingHeaderTI.ediFileIssueDateTime.asStringJMT() );
	endif;
	return not ediIsOlder;	// when ediIsOlder - cannot load EDI
end;</source>
        <access>protected</access>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_ediMode" type="String"/>
        <Parameter name="_extraInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="8ea4e4b4-ae74-4f34-9e38-af23281ff414">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
// par21718 cnwrs1 Nov 2009
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Dec 2017	jlgrs1	TFS 8281 - SNO - EDI New Coaprn Issues
//
vars
//	errorSet : CM_ErrorSet;
	allMatchedBRItems : CM_BookingRefItemDict;
	cmifEDIBooking : CMIF_EDIBooking;
	tmpStatus : Integer;
begin
	on Exception do validationExceptionHandler(exception, _passport);
//	create errorSet transient;
	create cmifEDIBooking transient;
	create allMatchedBRItems transient;
	cmifEDIBooking.status := self.status;
	cmifEDIBooking.myOperator := self.myOperator;
	cmifEDIBooking.processEDITIs(self.allEDITrackedItems, false, _passport, allMatchedBRItems); //cnwrs1 par 26223 10 nov 2010
//	_passport.moveErrorsToSet(errorSet);
//	_passport.addErrorsFromSet(errorSet);
	tmpStatus := self.getStatusFromEDITrackedItems(false);
	
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
	endif;
epilog
	delete allMatchedBRItems;
	delete cmifEDIBooking;
//	delete errorSet;
end;
</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="matchBookingItemsToBooking" id="d0e863d7-8fa2-49fc-9770-c2a30c8bb8b9">
        <source>matchBookingItemsToBooking(_allPrxyBookings	: CM_ObjectArray input;	_allPrxyBookingItems : CM_ObjectArray input ) protected;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	isFound				: Boolean;
	bookingItemElement		: Object;
	bookingElement		: Object;
	ediTI				: CM_EDITrackedItem;
	ediBookingItem			: CM_EDIBookingItemTI;
	prxyBookingItem			: CM_BookingRefItem;
	prxyBooking			: CM_BookingRef;
	
begin
	// This is not nice, but we need to set the proxy Booking for each BookingItem.
	foreach bookingItemElement in _allPrxyBookingItems do : bookingItem_loop
		prxyBookingItem	:=	bookingItemElement.CM_BookingRefItem;
		prxyBooking	:=	null;
		isFound		:=	false;
		
		foreach ediTI in self.allEDITrackedItems do : edi_loop
			if not ediTI.isKindOf( CM_EDIBookingItemTI ) then
				continue edi_loop;
			endif;
			
			ediBookingItem	:=	ediTI.CM_EDIBookingItemTI;
			
			if ediBookingItem.id &lt;&gt; prxyBookingItem.id then
				continue edi_loop;
			endif;
			
			// for release 7.7.3 there is only 1 Booking tracked item
			foreach bookingElement in _allPrxyBookings do : booking_loop
				prxyBooking	:=	bookingElement.CM_BookingRef;
				if prxyBooking.bookingReference = ediBookingItem.id then
					isFound	:=	true;
					break edi_loop;
				endif;
			endforeach booking_loop;
		endforeach edi_loop;
		
		if isFound then
			prxyBookingItem.setMyBookingRef(prxyBooking);
		endif;
	endforeach bookingItem_loop;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_allPrxyBookings" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_allPrxyBookingItems" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="14023d83-7be8-4d96-b67d-228777c7fd9e">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataBooking::currentBookingCode.name or
	   propName = CM_EDIDataBooking::currentBookingItemCode.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="storePersistentErrors" id="47a52156-5b23-4a7e-8d14-5b86d79d1a8f">
        <source>storePersistentErrors(): Boolean;
/*
Date		Who		Reason
22 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars

begin
