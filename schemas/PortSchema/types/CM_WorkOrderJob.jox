vars

begin
	if self.myWODtl &lt;&gt; null then
		if self.myWODtl.isKindOf(CM_WodReceive) and self.myWODtl.CM_WodReceive.myTrain &lt;&gt; null then
			return self.myWODtl.CM_WodReceive.myTrain.code;
		elseif self.myWODtl.isKindOf(CM_WodRelease) and self.myWODtl.CM_WodRelease.myTrain &lt;&gt; null then
			return self.myWODtl.CM_WodRelease.myTrain.code;
