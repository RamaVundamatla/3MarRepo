    <JadeMethod name="setMeterMarks" id="b09d0929-f384-4999-a5e2-0f76e80cf850">
        <updating/>
        <source>setMeterMarks(_textBox : TextBox) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	berth, berthForMarks : HMS_Berth;
	loa : Decimal [6,2];
	bridgeToBow, bowMark, sternMark, bridgeMark : Decimal [12,2];
	sideTo : Integer;

begin
	berth := self.cmbToBerth.listObject.HMS_Berth;
	if berth = null then
		return;
	endif;

	if self.myCurrentMovement &lt;&gt; null then	//22 Jun 2018	NDL	TFS 39248
		loa := self.myCurrentMovement.myHMSVoyageData.dim_LengthOverall;
		bridgeToBow := self.myCurrentMovement.myHMSVoyageData.dist_BridgeToBow;
	endif;
	
	sideTo := OrientStarboardSideTo;
		
	if _textBox = null then
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, null, berthForMarks,true);
	elseif _textBox = self.txtBowMarkTo then
		bowMark := _textBox.text.asDecimalJMT();
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
	elseif _textBox = self.txtSternMarkTo then
		sternMark := _textBox.text.asDecimalJMT();
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_SternMark), berthForMarks,true);	
	else
		return;
	endif;

	self.txtBowMarkTo.text	:= bowMark.asStringJMT();
	self.txtSternMarkTo.text:= sternMark.asStringJMT();
	
	if berthForMarks &lt;&gt; null and berthForMarks &lt;&gt; berth then
		self.cmbToBerth.listIndex := self.cmbToBerth.findObject(berthForMarks);
	endif;
epilog

end;</source>
        <Parameter name="_textBox" type="TextBox"/>
    </JadeMethod>
    <JadeMethod name="setPermitTotalDays" id="9bd383c3-24e6-4dbc-b649-6eae00076bfd">
        <source>setPermitTotalDays(_alwaysUpdate : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlger1	Initial creation 41645

*/

vars
	realObject : CM_WodPermitRequest;
	rowIndex : Integer;
	wodCargoRequest : CM_VoyageHoldJob;
	holdId : String;
	index : Integer;
	longestDays : Decimal[6,2];
	totDays : Decimal[6,2];
	daysToComplete : Decimal[6,2];
	holdValueArray : DecimalArray;
	holdIdArray : StringArray;
	incrementForCargo : Decimal[5,2];
	roundedTotal : Decimal[6,2];
begin
	if not self.myCurrentProxyTask.isKindOf(CM_WodPermitRequest) then
		return;
	endif;
	
	realObject:=self.myCurrentProxyTask.pxyGetRealObject.CM_WodPermitRequest;
	if not _alwaysUpdate and realObject &lt;&gt; null and realObject.myParent.CM_WorkOrderVoyage.lengthOfTime &lt;&gt; null  then
		return;
	endif;
	
	create holdValueArray transient;
	create holdIdArray transient;

	foreach rowIndex in 1 to self.tblOOWConfirm.rows do
		if rowIndex &lt;= self.tblOOWConfirm.fixedRows then
			continue;
		endif;
		wodCargoRequest := self.tblOOWConfirm.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
		if wodCargoRequest = null then
			//Hold summary line, round up then reset the sub total
			roundedTotal := self.myTerminal.applyRoundingToValue( holdValueArray[ index ] );
			holdValueArray[ index ] := roundedTotal;
			self.tblOOWConfirm.setCellText( rowIndex, HoldTotalCol, roundedTotal.asStringJMT );
			continue;
		endif;
		holdId := wodCargoRequest.getHoldId();
			
		if holdIdArray.includes( holdId ) then
			index := holdIdArray.indexOf( holdId );
		else
			holdValueArray.add(0.00);
			holdIdArray.add(holdId);
			index := holdIdArray.size;
		endif;
		
		daysToComplete := self.tblOOWConfirm.accessCell( rowIndex, DaysToCompleteCol ).text.asDecimalJMT;
		
		holdValueArray[ index ] := holdValueArray[ index ] + daysToComplete;
		
	endforeach;
	
	if not holdValueArray.isEmpty then
		foreach index in 1 to holdValueArray.size do
			daysToComplete := holdValueArray[ index ];
			if daysToComplete &gt; 0 then	
				if longestDays &lt; daysToComplete then
					longestDays :=daysToComplete;// self.myTerminal.applyRoundingToValue(daysToComplete); 
				endif;
				totDays := totDays + daysToComplete;
			endif;
		endforeach;

		longestDays := longestDays + incrementForCargo; 
	endif;

	self.txtPermitTotalDays.text := longestDays.asStringJMT;
	
	
epilog

end;</source>
        <Parameter name="_alwaysUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderSource" id="f8365cbe-27d7-4a7a-98f6-c34ae7733bca">
        <source>setProxyWorkOrderSource(_task : CM_WodPack) : CM_WorkOrderTISource protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwmd1	Initial creation

*/

vars
	realWOSource : CM_WorkOrderTISource;
	realTask : CM_WodPack;
begin
	if _task &lt;&gt; null then
		realTask := _task.pxyGetRealObject();
		realWOSource := realTask.mySource;
	endif;

	/*return self.myAssistant.setProxyWorkOrderSource(
				realWOSource, 
				_task, 
				self.cmbPackCargoType.listObject.CM_CargoType, 
				null, 
				self.mode = Mode_Update);*/
	return _task.myParent.setProxyWorkOrderSource(
				realWOSource, 
				_task, 
				self.cmbPackCargoType.listObject.CM_CargoType, 
				null, 
				self.mode = Mode_Update);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_WodPack"/>
        <ReturnType type="CM_WorkOrderTISource"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1979d80a-8020-46bc-8acc-d2f2cd6431d2">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/08/2009	cnwrd1	Initial creation
06/06/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	tmpTask 	: CM_WorkOrderDtl;
	terminal    : CM_Terminal;
begin

	self.minimumHeight := 600;					//17 Aug 2018	NDL	TFS 40127
	self.minimumWidth  := 900;					//29.09.2021 navma1 #51925		
	terminal           := self.myTerminal;		//10.09.2021 navma1 #51002
	inheritMethod();
	
	if app.getMyUser().myOrganisation.isExternal  or 
		not terminal.isUseYardJobsForCargoWo then      //10.09.2021 navma1 #51002
		self.chkAutoQueue.visible   := false;
		self.chkMoveAutoRTQ.visible := false;
		self.lReqBy.visible         := false;          //29.09.2021 navma1 #51925
		self.dtReqBy.visible        := false;          //29.09.2021 navma1 #51925
		self.tmReqBy.visible        := false;          //29.09.2021 navma1 #51925
	endif;
	
	self.shtBlank.showMySheet();
	
	if self.myProxyWorkOrder.id &lt;&gt; null then
		self.setCaption(app.getErrorString(Tasks_work_order) &amp; self.myProxyWorkOrder.id );
	else
		self.setCaption(app.getErrorString(Tasks_New_work_order));
	endif;
		
	if app.myRoot.canDo(Mod_Queuing) then
		self.chkMoveAutoRTQ.visible := true;
	endif;
		
	self.modalResult := IDCANCEL;
	self.fldDetails.tabsHeight := -1;
	self.refreshToolbar();
		
	//set the current task to null so that a save with no values is not done. 
	//The current task will only contain a value if run from the task enquiry view in the work unit enquiry form.
	tmpTask := self.myCurrentProxyTask;
	self.myCurrentProxyTask := null;
	
	self.buildCombos();        
	self.initDetailTable();
	
	self.displayTasks(tmpTask);
	
	//29.09.2021 navma1 #51925 Pending 
	//self.setActiveTab();
	//29.09.2021 navma1 #51925 pending 
	if tmpTask &lt;&gt; null and self.myCurrentProxyTask = null then	//17 Jul 2018	NDL	TFS 39742 - displayTasks can set this sucker to one of the children don't overwrite it...
		self.myCurrentProxyTask := tmpTask;
	endif;
	
	self.tbPackCargo.selectionType := self.tbPackCargo.SelectionType_Row;
	
	self.setControlsForViewMode();
	
	if self.myMainForm &lt;&gt; null then
		self.myMainForm.enabled := false;
	endif;
	
	// TFS 54298 jlizm1 31/08/2022
	if terminal.getDefaultVoyageProcess &lt;&gt; null and terminal.getDefaultVoyageProcess.isEUPDefaultProcess then
		self.chkHasCargoVR.visible := false;
	endif;
	
	self.lblWTransferType.visible := false;	//16 Jul 2018	NDL	TFS 39740
	self.cmbWTransferType.visible := false;	//16 Jul 2018	NDL	TFS 39740
	
	self.beginClassNotification(CM_WorkOrderDtl, false, Any_System_Event, Response_Continuous, null); //cnwrd1 
	
	//14 Dec 2018	NDL	TFS 42541
	if not app.getMyUser.canDo( terminal, self.permissionMaint ) then   //10.09.2021 navma1 #51002
		self.butOK.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupOOWConfirmTable" id="f76eb4d8-6533-40ef-a59e-e42cace31c52">
        <source>setupOOWConfirmTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlger1	Initial creation

*/

vars
	headingStr : String;
	voyTfrType : CM_VoyageJobTransferType;

begin
	self.tblOOWConfirm.visible:=true;
	self.tblOOWConfirm.clear();
	self.tblOOWConfirm.rows := 1;
	self.tblOOWConfirm.fixedRows := 1;
	self.tblOOWConfirm.columns := self.HoldTotalCol;
	self.tblOOWConfirm.fixedColumns := 0;
	
	headingStr := 	app.getErrorString(Hold) &amp; Tab
				&amp;	app.getErrorString(Workpoint) &amp; Tab
				&amp;	app.getErrorString(CM_Type) &amp; Tab
				&amp;	app.getErrorString(Operator_GC) &amp; Tab
				&amp;	app.getErrorString(Consignee) &amp; Tab
				&amp;	app.getErrorString(CM_Commodity_GC) &amp; Tab
				&amp;	app.getErrorString(Move_amount) &amp; Tab
				&amp;	app.getErrorString(Transfer_type) &amp; Tab
				&amp;	app.getErrorString(Gangs) &amp; Tab
				&amp;	app.getErrorString(HoursPerDay) &amp; Tab
				&amp;	app.getErrorString(Hourly_target_rate) &amp; Tab
				&amp;	app.getErrorString(Days_complete) &amp; Tab
				&amp;	app.getErrorString(Hold_sub_total);
	
	self.tblOOWConfirm.setCellText(1,1,headingStr);
	self.tblOOWConfirm.tabKey := J_key_Tab;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="6ef075eb-f4dd-42c0-b7b2-f6e83f075988">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27/01/2010	cnwrd1	Initial creation
29/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
08/06/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
02/10/2019  cnwma1	Bug 46853: PEL1 - (TOP URGENT) Pindah| Caught exception:
*/

vars
	realWorkOrder, 
	dtlWorkOrder    : CM_WorkOrder;
	expectedEdition : Integer;
	invalidPxy,
	invalidObj      : Boolean;
	edition 		: Integer;
begin

	on Exception  do app.handleDeletedObject(exception,theObject,invalidObj);
	on Exception  do app.handleDeletedObject(exception,self.myProxyWorkOrder,invalidPxy);
	
	dtlWorkOrder := theObject.CM_WorkOrderDtl.myParent;			// TFS 38560
	edition      := theObject.edition;
	
	if not invalidObj then
		if self.myProxyWorkOrder &lt;&gt; null then
			self.myProxyWorkOrder.pxyGetRealObjectAndEdition(realWorkOrder, expectedEdition);
		endif;	
	else
		app.msgBox('Another user has deleted the a Task on the Work order you are currently editing. The editing must now be cancelled','Work Order Task deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		unloadForm;
		return;
	endif;
	
	if invalidPxy then
		app.msgBox('Another user has deleted the a Task on the Work order you are currently editing. The editing must now be cancelled','Work Order Task deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		unloadForm;
		return;
	endif;
	
	if eventType = Object_Update_Event and dtlWorkOrder &lt;&gt; null and dtlWorkOrder = realWorkOrder then  // only for edits
		app.msgBox('Another user has updated the Work Order you currently have selected.' &amp; CrLf &amp;
				'The Work Order must now be re-loaded.', 'Work Order updated', MsgBox_Exclamation_Mark_Icon);
		delete self.myProxyWorkOrder;
		if realWorkOrder &lt;&gt; null then  //02.10.2019 cnwma1 #46853
			self.myProxyWorkOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrder;
			self.doRefresh();
		endif;

	elseif eventType = Object_Delete_Event and dtlWorkOrder = realWorkOrder then
		app.msgBox('Another user has deleted the a Task on the Work order you are currently editing. The editing must now be cancelled','Work Order Task deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			delete self.myProxyWorkOrder; 
			if realWorkOrder &lt;&gt; null then   //02.10.2019 cnwma1 #46853
			self.myProxyWorkOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrder;
			self.doRefresh();
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tbPackCargo_dblClick" id="db7a3ef8-5b03-4f62-8f47-8fbbe37d96ed">
