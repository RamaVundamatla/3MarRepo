    <JadeMethod name="countTransactionsOfType" id="ceca7264-bc63-4a40-bc5a-70593886e88c">
        <source>countTransactionsOfType(_cargo : CM_TrackedItem; _tranType : Integer) : Integer;

vars
	count	: Integer;
	tran	: CM_TITransaction;
begin
	foreach tran in _cargo.allTransactions do
		if tran.type = _tranType then
			count := count + 1;
		endif;
	endforeach;
	
	return count;
end;
</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_tranType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createAvailabilityGrade" id="a61fb150-8b2c-43e2-b5b4-b54a305c434e">
        <source>createAvailabilityGrade( _code : String ):CM_MTGrade;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	proxyAvailGrade : CM_MTGrade;
	availGrade : CM_MTGrade;
	index : Integer;
	
begin

	term := self.getTerminal;
	
	index := 100;
	while true do
		if app.myRoot.allAvailabilityGrades.getAtKey(index) = null then
			break;
		endif;
		index := index + 1;
	endwhile;
	
	create proxyAvailGrade transient;
	proxyAvailGrade.setProxy(	index,
								_code,
								false,
								false,
								0,
								null,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
								term.allSubTerminals	//CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
								);
								
	app.myTrxCA.trxCreateAvailabilityGrade(proxyAvailGrade, availGrade,app.myPassport);

	return availGrade;
	
epilog

	delete proxyAvailGrade;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="createAvailabilityGradeAndDesc" id="3fb306de-afda-4930-8dbe-4a1f674b1f69">
        <source>createAvailabilityGradeAndDesc(_code :Integer; _desc :String):CM_MTGrade;
/*
Date		Who		Reason
02 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

	terminal 	: CM_Terminal;
	proxy 		: CM_MTGrade;
	mtGrade 	: CM_MTGrade;	
begin
	terminal := self.getTerminal;
	
	create proxy transient;
	
	proxy.setProxy(_code, _desc,
								false,
								false,
								0,
								null,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
								terminal.allSubTerminals	//CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
								);
								
	app.myTrxCA.trxCreateAvailabilityGrade(proxy, mtGrade,app.myPassport);

	return mtGrade;
	
epilog

	delete proxy;

end;</source>
        <Parameter name="_code" type="Integer"/>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="createBGPManagerRunTask" id="fddceaba-c2f0-4ef7-95b8-eaee95aabb8f">
        <source>createBGPManagerRunTask(_autoSchedule : CM_AutoSchedule);

/*

Purpose:		Create the BPGManager and autoschedule and run the required task

Date			Who		Reason
11/02/2016		cnwmh5	Initial creation

*/

vars

	bgpManager					: BGP_Manager;
	bgpGeneric 					: BGP_GenericController;

begin

	// create the BGPManager
	self.opts.purge();
	self.opts.addAssoc("IsServer", true);
	bgpManager := self.addBGPManager(_autoSchedule.description);
	self.assertNotNull(bgpManager);

	// create Process Wash
	bgpGeneric := bgpManager.allBGPControllers.first.BGP_GenericController;
	self.updateBGPGenericControllerProc(bgpGeneric);
	
	// run the task
	_autoSchedule.runTasks(null, null);
	
	// start the bgp process
	//bgpManager.startBackGroundApp(bgpGeneric, false);
	
	// need to sleep for a minute to make sure that the process gets run
	//process.sleep(60000);

epilog

	if bgpManager &lt;&gt; null then	
		bgpManager.terminateProcessing(app.myPassport.userCode);
	endif;

end;</source>
        <Parameter name="_autoSchedule" type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="createCalendar" id="f7c888c6-5948-4f3a-8af5-60d966f0a054">
        <source>createCalendar(	_code : String; _description : String; _hasEndTime : Boolean; _hasTime : Boolean; _dayCode : String) : CM_Calendar;
// CCMS 1295 free storage days
vars
	proxy		: CM_Calendar;
	realCalendar	: CM_Calendar;
	proxyDayType	: CM_DayType;
	dayType		: CM_DayType;
	terminal	: CM_Terminal;
	allTerminals : CM_TerminalByCodeDict;
begin
	terminal := self.getTerminal();
	create allTerminals transient;
	allTerminals.add(terminal);
	create proxyDayType transient;
	proxyDayType.setProxy(_dayCode, _dayCode);
	app.myTrxCA.trxCreateDayType(proxyDayType, dayType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	create proxy transient;
	proxy.setProxy(	_code, _description, _hasEndTime, _hasTime, dayType, null, null, allTerminals);

	app.myTrxCA.trxCreateCalendar(proxy, realCalendar, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
 	
	return realCalendar;
epilog
	delete proxy;
	delete proxyDayType;
	delete allTerminals;
end;


</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hasEndTime" type="Boolean"/>
        <Parameter name="_hasTime" type="Boolean"/>
        <Parameter name="_dayCode" type="String"/>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="createCargo" id="600a5fb4-a10d-4b3c-acf2-9b7bcf3d51a5">
        <source>createCargo(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _asTransient : Boolean; _ct : Integer) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	remarks 		: String;
	
begin
	root := CM_Root.firstInstance;
	
//	cargoType := root.allCargoTypesById[TI_CargoType_Container];	// cnwrl1 28/04/2010 PAR 23854 - what it was
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cargoTypeInt	:= self.opts.intDef( ETRow_CargoType, _ct );
	cargoType		:= root.allCargoTypesById[ cargoTypeInt ];
	// cnwrl1 28/04/2010 PAR 23854 - end of coding
	
	if _asTransient then
		pxyTI := self.getTerminal.createTI(cargoType, _asTransient);
		
		//14 May 2015	NDL	- Needed to allow subTerminal default to make the correct decision.
		if self.opts.includesKey(UTTI_IMEX) then						
			pxyTI.zSetPxyImexStatus(self.opts.int(UTTI_IMEX));
		endif;
		
//		pxyTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		pxyTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
		pxyTI.setISOType(_isoType);
		//pxyTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		pxyTI.setTotalWeight(4000, null, null);					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			pxyTI.setTemperature(4);
		endif;
		global.setExtraData(pxyTI.allExtraData, pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		return pxyTI;
	else
		beginTransaction;
		realTI := self.getTerminal.createTI(cargoType, _asTransient);
//		realTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		realTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
		realTI.setISOType(_isoType);
		//realTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			realTI.setTemperature(4);
		endif;
		global.setExtraData(realTI.allExtraData, realTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		// 13/07/015 cnwmh5
		remarks := realTI.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realTI.setRemarks(remarks &amp; self.createdByUnitTest(remarks), false);
		commitTransaction;
		return realTI;
	endif;

epilog

	if not _asTransient then
		delete pxyTI;
	endif;
	
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_asTransient" type="Boolean"/>
        <Parameter name="_ct" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createCashCredit" id="6fa1c93d-e778-41d3-822e-411594803ad5">
        <source>createCashCredit(_cashReceipt  : CM_CashReceipt; 
				 _creditAmount : Decimal;
				 _comments 	   : String;
				 _firstPaymentInv,
				 _firstPaymentProfrma  : Decimal) : CM_CashCredit;

/*

Purpose:			Create a cash credit from an existing cash receipt, based on INV_CashCredit::doSave, keep in sync with this

Parameters:			

Return Value:		


Date		Who		Reason
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars
	index				: Integer;
	cashOnPayment,
	cashOnPaymentTax	: Decimal[23, 6];	
	terminal			: CM_Terminal;
	pxyCashCredit	    : CM_CashCredit;
	pxyCreditDetail,
	pxyTaxCreditDetail  : CM_CashCreditDetail;
	cashCredit			: CM_CashCredit;
	drTerm 				: CM_DebtorTerminal;
	now 				: TimeStamp;
	user 				: CM_User;
	invoiceLine			: CM_InvoiceLine;
	bank				: CM_Bank;
	allPxyCashDetails 	: ObjectArray;
	obj			    	: Object;
	ti				    : CM_TrackedItem;
	cashPayment,
	cashPaymentTax 		: CM_CashPayment;
	invUpdated,
	profrmaUpdated   : Boolean;
begin

	now 		:= app.actualTimeServer;
	user 		:= app.getMyUser;
	terminal 	:= self.getTerminal();
	drTerm 		:= _cashReceipt.myDebtorTerminal;
	bank 		:= _cashReceipt.myBank;
	
	// don't create a credit if no value
	if _creditAmount = 0 then
		return null;
	endif;

	create pxyCashCredit transient;
	pxyCashCredit.setProxy(	_creditAmount,
							now,
							_comments,
							bank,
							drTerm,
							_cashReceipt,
							user
							);

	create allPxyCashDetails transient;

	
	foreach obj in _cashReceipt.allCashPayments do
		
		
		cashPayment   :=  obj.CM_CashPayment;
		ti			  := cashPayment.myTrackedItem;
		index 		  := 0;
		cashOnPayment := cashPayment.getUncreditedAmount;
		
		if invUpdated and profrmaUpdated then
			continue;
		endif;
		
		if not invUpdated then
			if cashPayment.myInvoice &lt;&gt; null then
				cashOnPayment := _firstPaymentInv ;
				invUpdated    := true;
			endif;
		endif;
		
		if not profrmaUpdated then
			if cashPayment.myProformaDetail &lt;&gt; null  then
				cashOnPayment := _firstPaymentProfrma ;
				profrmaUpdated    := true;
			endif;
		endif;
		
	
		if cashOnPayment &gt; 0 then
			
			create pxyCreditDetail transient;
			pxyCreditDetail.setDerivedProxy(null, 
											cashPayment,
											ti,
											cashOnPayment,
											now);
			allPxyCashDetails.add(pxyCreditDetail);
			
			if cashPayment.hasTax &lt;&gt; null then			
				cashPaymentTax   := cashPayment.myCashPaymentForTax;
				cashOnPaymentTax := cashPaymentTax.getUncreditedAmount;
				
				if cashOnPaymentTax &gt; 0 then
					create pxyTaxCreditDetail transient;
					pxyTaxCreditDetail.setDerivedProxy(null,
														cashPaymentTax,
														ti,
														cashOnPaymentTax,
														now);
														
					allPxyCashDetails.add(pxyTaxCreditDetail);
				endif;
			endif;
		endif;
	endforeach;
	
	
	app.myTrxCA.trxCreateCashCredit (pxyCashCredit, cashCredit, allPxyCashDetails, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Create Cash Credit failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	return cashCredit;	

epilog

	if allPxyCashDetails &lt;&gt; null and not allPxyCashDetails.isEmpty then
		allPxyCashDetails.purge();
	endif;
	delete pxyCashCredit;
	delete allPxyCashDetails;
	
end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_creditAmount" type="Decimal"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_firstPaymentInv" type="Decimal"/>
        <Parameter name="_firstPaymentProfrma" type="Decimal"/>
        <ReturnType type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="createContainer" id="b40368d4-82df-435f-bc4b-1bebccfbeb41">
        <source>createContainer(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _asTransient : Boolean) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	imexInt 		: Integer;
	remarks			: String;
	
begin
	root := CM_Root.firstInstance;
	
//	cargoType := root.allCargoTypesById[TI_CargoType_Container];	// cnwrl1 28/04/2010 PAR 23854 - what it was
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cargoTypeInt	:= self.opts.intDef( ETRow_CargoType, TI_CargoType_Container );
	cargoType		:= root.allCargoTypesById[ cargoTypeInt ];
	// cnwrl1 28/04/2010 PAR 23854 - end of coding

	
	
	if _asTransient then
		pxyTI := self.getTerminal.createTI(cargoType, _asTransient);
		
		//14 May 2015	NDL	- Needed to allow subTerminal default to make the correct decision.
		if self.opts.includesKey(UTTI_IMEX) then						
			pxyTI.zSetPxyImexStatus(self.opts.int(UTTI_IMEX));
		endif;
		
//		pxyTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		pxyTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
		pxyTI.setISOType(_isoType);
		//pxyTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		pxyTI.setTotalWeight(4000, null, null);					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			pxyTI.setTemperature(4);
		endif;
		global.setExtraData(pxyTI.allExtraData, pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));					// 10/09/2015 cnwmh5
		return pxyTI;
	else
		beginTransaction;
		realTI := self.getTerminal.createTI(cargoType, _asTransient);
//		realTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		realTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
		realTI.setISOType(_isoType);
		//realTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			realTI.setTemperature(4);
		endif;
		global.setExtraData(realTI.allExtraData, realTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		// 13/07/015 cnwmh5
		remarks := realTI.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realTI.setRemarks(remarks &amp; self.createdByUnitTest(null), false);
		commitTransaction;
		return realTI;
	endif;

epilog

	abortTransaction;  // in case if falls over during the begin commit above...
	if not _asTransient then
		delete pxyTI;
	endif;
	
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_asTransient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createContainerFromVoyage" id="122d06a7-6b99-4b88-9b8b-87b7c1f685d7">
        <source>createContainerFromVoyage(_voyage : CM_Voyage; _id : String; _toLocation : Any; _isoType : String; _operator : CM_Operator; _commodity : String; 
							_destPort : String; _dischargePort : String; _tareWeight : Decimal; _cargoWeight : Decimal) : CM_TrackedItem;
// Create an onship container for the given attributes and then move it onsite to the given location
// This creates an onsite container with the required ship receive etc transactions for invoicing
vars
	intFaceArray		: CMIF_TIObjectArray;
	newTI				: CM_TrackedItem;
	intFaceObj			: CMIF_PreNote;
	preNote				: CMIF_PreNote;

begin
	
	create intFaceArray transient;
	create intFaceObj as CMIF_OnshipCargo transient;	
	
	intFaceObj.myTerminal		:= self.getTerminal;
	//intFaceObj.setUserDetails(self);
	intFaceObj.setMyInOutCommon(null);

	// Main Details
	intFaceObj.cargoType		:= TI_CargoType_Container;
	intFaceObj.commodity 		:= _commodity;
	intFaceObj.id				:= _id;
	intFaceObj.isoType			:= _isoType;
	
	intFaceObj.weightTotal			:= _cargoWeight + _tareWeight;
	intFaceObj.weightCargo			:= _cargoWeight;
	intFaceObj.weightTare			:= _tareWeight;
	
	intFaceObj.weightDeclared 	:= intFaceObj.weightTotal;

	intFaceObj.numberOfItems := 1;
	
	// Voyage Details
	intFaceObj.imExStatus := self.getRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	intFaceObj.voyageCode		:= _voyage.code;
	intFaceObj.operatorCode		:= _operator.code;
	intFaceObj.destinationPort	:= _destPort;
	intFaceObj.dischargePort	:= _dischargePort;

	intFaceObj.setCarbonDioxide( NULL_INTEGER );
	intFaceObj.setOxygen( NULL_OXYGEN );
	intFaceObj.setHumidity( NULL_HUMIDITY );
	intFaceObj.ventilation 		:= NULL_VENTILATION;
	intFaceObj.transportMode 	:= BR_TYPE_SHIP_STR;
	intFaceObj.receiptTransportMode := app.transModeToCode(intFaceObj.transportMode);
	if _commodity = "REEF" then
		intFaceObj.carriageTempC := 4;
	endif;
	
	intFaceArray.add(intFaceObj);
	preNote := intFaceObj;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreatePreNotes(intFaceArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	newTI := intFaceObj.myPersistentTrackedItem;

	// now optionally move it
	if _toLocation &lt;&gt; null then
		if not self.opts.includesKey("isForcedMove") then
			self.opts.addAssoc("isForcedMove", true);
		endif;
		self.move(newTI, _toLocation);
		self.opts.removeAssoc("isForcedMove");
	endif;

	return newTI;
epilog
	delete intFaceObj;
	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_toLocation" type="Any"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_destPort" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createContainerRange" id="9fe65be7-9d79-4129-82a6-951ad6404b98">
        <source>createContainerRange(_start, _end :String):CM_ContRange;
// ---------------------------------------------------------------------------
// Created:     24 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	range	:CM_ContRange;
	proxy	:CM_ContRange;
begin
	create proxy transient;
	
	proxy.setProxy (_start, _end, '2200', null, null, null, null, null, null, null, 45000, 2354, null, null, null);
	
	app.myTrxCA.trxCreateContRange (proxy, range, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();

	return range;
epilog
	delete proxy;
end;</source>
        <Parameter name="_start" type="String"/>
        <Parameter name="_end" type="String"/>
        <ReturnType type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="createDatedChargedTransaction" id="b2200ab3-4947-449e-80ef-9cadd1ec3a23">
        <source>createDatedChargedTransaction(_realTI : CM_TrackedItem input; _dateTime : TimeStamp; _type : Integer; _charged  :Boolean) : CM_TITransaction;
// cnwjre1
vars
	transParams: CMIF_TITransactionController;
	transObj : CM_TITransaction;
begin
	if _type = TRANS_TYPE_STORAGE then
		create transParams as CMIF_StorageTransController transient;
	else
		create transParams transient;
	endif;
	transParams.type := _type;
	transParams.noCharge := not _charged;
	transParams.userId := app.getMyUserCode();
	transParams.dateTime := _dateTime;
	
	beginTransaction;
	transObj := _realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	return transObj;
epilog
	delete transParams;
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_charged" type="Boolean"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
