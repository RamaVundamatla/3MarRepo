    <JadeMethod name="getNextTranNumForFlexiGate" id="8716acbd-c8d4-4174-ad9a-597473e5d241">
        <source>getNextTranNumForFlexiGate() : String;
/* ---------------------------------------------------------------------------
Created:     01 October 2008 by cnwrs2

Purpose:     GatePass is a tran number generated from a Terminal key series.
				For each entity for this visit we take that same tran num and add a suffix A, B C etc on the end.
        
Change Date	Who		Reason
cnwas3	05/08/2009	SFW 1035 - changes to how the vehicle visit number "works"
------------------------------------------------------------------------------*/
vars
	
	suffix,suffixOverflow : String;
	num,secondLetter,firstLetter : Integer;
	dynaDict : DynaDictionary;
	unique : Boolean;
	tranNumber : String;
	
begin
	
	create dynaDict transient;
	dynaDict.setMembership(CMGTE_Entity);
	dynaDict.addMemberKey(CMGTE_Entity::tranNumber.name, false, true);
	dynaDict.endKeys(true);
	self.allGateEntities.copy(dynaDict);
	num := self.allGateEntities.size()+1;
	
	unique := false;
	
	while not unique do
		suffix := self.myTerminal.getNextSuffix(num);
		tranNumber := self.visitNumber &amp; '-' &amp; suffix;
		unique := dynaDict.getAtKey(tranNumber) = null;
		num := num + 1;
	endwhile;
	//process.debugAdi();
	//num := (self.allGateEntities.size() + 1); 
//////////////////////////////////////////////////////////////////////////////////////////////////////cnwas3 begin
	//suffix := self.myTerminal.getNextSuffix(num);
///////////////////////////////////////////////////////////////////////////////////////////////////////cnwas3 end	
	//suffix := (num + 64).Character &amp; suffixOverflow; // Make into A, B, C etc //cnwas3 commented out	
	//return self.gatePass &amp; '-' &amp; suffix; 	
	return tranNumber;
epilog
	delete dynaDict;					//+cnwml2 MSL CCMS 1012
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVVRDtlJobAction" id="e5abc1a7-8db8-439c-8c74-f7ac822c9761">
        <source>getNextVVRDtlJobAction(_ts : TimeStamp; _type : Integer) : CM_VehicleVisitRecordDetail;
/*

Purpose:	This method returns the next Job Action VVR Details Type

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2024	navkc1 CR 62694 Task 62901: UI - WO Ops Start Stop Details

*/

vars
	vvrDtl		: CM_VehicleVisitRecordDetail;
	
begin
	
	foreach vvrDtl in self.allVehicleVisitRecordDetails discreteLock where vvrDtl.recordType = _type do
		if vvrDtl.timeStart &lt; _ts then
			continue;
		endif;
		return vvrDtl;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
    <JadeMethod name="getNumTIByType" id="12d2231b-2c68-4cd5-8816-5d3b3ba117f5">
        <source>getNumTIByType(_receival : Boolean; _isFull : Boolean; _isChassis : Boolean) : Integer;
/*
Purpose:	FOR OPSVIEW DATA EXTRACT		

Date		Who		Reason
01 December 2021	navab1	TFS 51853
*/

vars
	ti : CM_TrackedItem;
	num : Integer;
	col : Collection;
begin
	if _receival then
		col := self.allReceivedTrackedItems;
	else
		col := self.allReleasedTrackedItems;
	endif;
	
	foreach ti in col  as CM_TrackedItem discreteLock do
		if _isChassis then
			if _isFull then
				if ti.isChassis() then
					if ti.CM_TILC.hasAssociatedTIs() then
						num := num + 1;
					endif;
				endif;
			else
				if ti.isChassis() then
					if not ti.CM_TILC.hasAssociatedTIs() then
						num := num + 1;
					endif;
				endif;
			endif;
		else
			if _isFull then
				if not ti.isChassis() then
					if ti.isFull() then
						num := num + 1;
					endif;
				endif;
			else
				if not ti.isChassis() then
					if not ti.isFull() then
						num := num + 1;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return num;
epilog

end;</source>
        <Parameter name="_receival" type="Boolean"/>
        <Parameter name="_isFull" type="Boolean"/>
        <Parameter name="_isChassis" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
