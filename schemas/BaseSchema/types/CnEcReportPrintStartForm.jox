    </JadeMethod>
    <JadeMethod name="doFormLoad" id="76cb0506-af0e-461e-8af7-9e4eef5f51d6">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 July 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportPriority	: Integer;

begin
	centreWindow();
	inheritMethod();
	lblMessage.visible	:=	null;

	foreach reportPriority in 3 to 1 step -1 do
		cmbPriority.addItem(reportPriority.String);
	endforeach;

	if self.aIsPreview then
		self.caption		:=	$CNEC_PRINT_PREVIEW;
		optLocal.value		:=	true;
		optLocal.enabled	:=	false;
		optServer.enabled	:=	false;
		txtDate.readOnly	:=	true;
		txtTime.readOnly	:=	true;
	endif;

	txtDate.readOnly	:=	true;
	txtTime.readOnly	:=	true;

	self.setTableProperties(tblParameters);
	self.doLoadDetails();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="66589037-1638-4040-9ba7-582625178f16">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 July 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportForm			: CnEcReport;
	isError				: Boolean;
	errorMessage		: String;
	isRunLocal			: Boolean;
	rowIndex			: Integer;
	rowCount			: Integer;
	table				: Table;
	cellObject			: Object;

	timeStamp			: TimeStamp;
	priority			: Integer;
	copies				: Integer;
	destination			: String;
	isPrintToFile		: Boolean;
	printStatus			: Integer;
	printerName			: String;
	reportDefinition	: CnEcReportDefinition;
	queueEntry			: CnEcReportQueueEntry;
	parameterValueArray	: CnEcReportParameterValueArray;
	objectValue			: Object;
	stringValue			: String;

begin
	queueEntry			:=	self.aMyReportQueueEntry;
	isRunLocal			:=	optLocal.value;

	reportDefinition	:=	self.aMyReport;
	timeStamp.setDate(txtDate.text.trimBlanks.Date);
	timeStamp.setTime(txtTime.text.trimBlanks.Time);
	priority			:=	cmbPriority.text.trimBlanks.Integer;
	copies				:=	txtCopies.text.trimBlanks.Integer;
	destination			:=	txtDestination.text.trimBlanks;
	isPrintToFile		:=	chkPrintToFile.value;
	printerName			:=	cmbPrinter.text.trimBlanks;

	if isRunLocal then
		printStatus	:=	CNEC_REPORT_PRINTING;
	else
		if self.aIsPreview then
			printStatus	:=	CNEC_REPORT_PREVIEW;
		else
			printStatus	:=	CNEC_REPORT_PENDING;
		endif;
	endif;

	// Get the parameters.

	create parameterValueArray transient;
	table		:=	tblParameters;
	rowCount	:=	table.rows;

	foreach rowIndex in 2 to rowCount do
		cellObject	:=	table.cnEcGetItemObject(rowIndex, 1);
		objectValue	:=	table.cnEcGetItemObject(rowIndex, 4);

		if objectValue = null then
			stringValue	:=	table.getCellText(rowIndex, 4);
		else
			stringValue	:=	null;
		endif;

		if cellObject.isKindOf(CnEcReportParameter) then
			parameterValueArray.createParameterValue(null, cellObject.CnEcReportParameter, objectValue, stringValue);
		else
            parameterValueArray.createParameterValue(null, cellObject.CnEcReportParameterValue.myReportParameter, objectValue, stringValue);
		endif;
	endforeach;

	// Call the transaction...

	if queueEntry = null then
		self.aError	:=	self.aMyTA.trxReportQueueEntryCreate(	app.myBaseRoot,
																		timeStamp,
																		priority,
																		copies,
																		destination,
																		isPrintToFile,
																		printStatus,
																		printerName,
																		reportDefinition,
																		parameterValueArray,
																		self.aMyReportQueueEntry);
	else
		endNotification(self.aMyReportQueueEntry, Any_System_Event);

		self.aError	:=	self.aMyTA.trxReportQueueEntryUpdate(	self.aMyReportQueueEntry,
																		self.aObjectEdition,
																		app.myBaseRoot,
																		timeStamp,
																		priority,
																		copies,
																		destination,
																		isPrintToFile,
																		printStatus,
																		printerName,
																		reportDefinition,
																		parameterValueArray);
	endif;

	// Now run the report (if required)...

	if self.aError = null and isRunLocal then
		lblMessage.caption	:=	"The report is now running...";
		self.beginTimer(1000, Timer_Continuous, 0);

		if currentSchema.findName(self.aMyReport.formName) &lt;&gt; null then
			create reportForm as currentSchema.getClass(self.aMyReport.formName);
			printStatus			:=	reportForm.printReport(self.aMyReportQueueEntry, self.aIsPreview, errorMessage);
			isError				:=	(printStatus = CNEC_REPORT_ERROR);
			self.aError	:=	errorMessage;
		endif;

		if isError then
			errorMessage	:=	self.aMyTA.trxReportQueueEntrySetStatus(self.aMyReportQueueEntry, 0, CNEC_REPORT_ERROR, errorMessage);
		else
			errorMessage	:=	self.aMyTA.trxReportQueueEntryDelete(self.aMyReportQueueEntry);
		endif;

		if errorMessage &lt;&gt; null then
			app.msgBox(errorMessage, $CNEC_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;

		self.endTimer(0);
	endif;
epilog
	delete parameterValueArray;
	delete reportForm;

	return self.doShowError();
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGetPrintFile" id="5872c0ea-7e76-4c13-ab28-eb536f1ac5ad">
        <source>doGetPrintFile() protected;

vars
	printFileName	: String;

begin
	printFileName	:=	global.cnEcFileGet(false, null);

	if printFileName.trimBlanks.length &lt;&gt; 0 then
		txtDestination.text	:=	printFileName;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadDetails" id="56b2939c-7f01-4e55-934a-d79f0840e04f">
        <updating/>
        <source>doLoadDetails() updating, protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	reportParameter	: CnEcReportParameter;
	parameterValue	: CnEcReportParameterValue;
	reportForm		: CnEcReport;
	theTimeStamp	: TimeStamp;
	defaultValue	: String;
	printerArray	: StringArray;
	parameterIndex	: Integer;
	theClass		: Class;

begin
	if self.aMyReport &lt;&gt; null then
		txtDescription.text	:=	self.aMyReport.reportDescription;
	endif;

	tblParameters.rows	:=	1;

	// If adding a new entry into report queue/schedule ...

	if self.aMyReportQueueEntry = null then
		txtDate.text			:=	theTimeStamp.date.String;
		txtTime.text			:=	theTimeStamp.time.String;
		cmbPriority.listIndex	:=	1;
		txtCopies.text			:=	self.aMyReport.copies.String;

		if self.aMyReport.isLocalAllowed then
			if optLocal.enabled then
				optLocal.value	:=	true;
			endif;
		else
			optServer.value		:=	true;
			optServer.enabled	:=	false;
			optLocal.enabled	:=	false;
		endif;

		// ...and populate parameters table with report parameter references

        theClass := currentSchema.getClass(self.aMyReport.formName);

        if theClass = null then
        	app.msgBox("Report not found in the current schema!", "Report parameters not displayed", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
        	return;
        endif;

		create reportForm as theClass;

		foreach reportParameter in self.aMyReport.allReportParameters do
			if	reportParameter.sequence = 0			and
				reportParameter.parameterName = null	and
				reportParameter.parameterType = null	then
				
				continue;
			endif;

			parameterIndex	:=	tblParameters.addItem(reportParameter.displayTab());
			tblParameters.cnEcSetItemObject(parameterIndex, 1, reportParameter);
			defaultValue	:=	reportForm.getDefaultParameterValue(reportParameter, self.aAllReportParameterValues);
			tblParameters.setCellText(parameterIndex, 4, defaultValue);

			if reportForm.isParameterRequired(reportParameter.parameterName) then
				tblParameters.setCellText(parameterIndex, 2, "*");
			endif;
		endforeach;
		
		tblParameters.accessMode	:=	Table.AccessMode_Row;
	// ...otherwise ...
	else
		// ...load existing report schedule entry details ...
		txtDate.text			:=	self.aMyReportQueueEntry.timeStamp.date.shortFormat;
		txtTime.text			:=	self.aMyReportQueueEntry.timeStamp.time.String;
		cmbPriority.listIndex	:=	cmbPriority.findStringExact(1, self.aMyReportQueueEntry.priority.String);
		txtCopies.text			:=	self.aMyReportQueueEntry.copies.String;
		chkPrintToFile.value	:=	self.aMyReportQueueEntry.isPrintToFile;
		txtDestination.text		:=	self.aMyReportQueueEntry.destination;

		theClass	:=	currentSchema.getClass(self.aMyReport.formName);

        if theClass = null then
        	app.msgBox(	"Report not found in the current schema!",
        				"Report parameters not displayed",
        				MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
        	return;
        endif;

		create reportForm as theClass;

		foreach parameterValue in self.aMyReportQueueEntry.allReportParameterValues do

			if parameterValue.myReportParameter.sequence = 0			and
			   parameterValue.myReportParameter.parameterName = null	and
			   parameterValue.myReportParameter.parameterType = null	then
				continue;
			endif;

			tblParameters.row	:=	tblParameters.addItem(parameterValue.displayTab());
			tblParameters.cnEcSetItemObject(tblParameters.row, 1, parameterValue);
			tblParameters.cnEcSetItemObject(tblParameters.row, 4, parameterValue.myObjectValue);

			if reportForm.isParameterRequired(parameterValue.myReportParameter.parameterName) then
			    tblParameters.setCellText(tblParameters.row, 2, "*");
			endif;
		endforeach;
	endif;

	tblParameters.sortColumn[1]	:=	5;							// cnwdad1 30/09/2000.
	tblParameters.sortType[1]	:=	Table.SortType_Numeric;		// cnwdad1 30/09/2000.
	tblParameters.resort();										// cnwdad1 30/09/2000.

	create printerArray transient; 

	if optServer.value then
		global.cnEcGetAllServerPrinters(printerArray);
	else
		app.printer.getAllPrinters(printerArray);
	endif;					

	cmbPrinter.listCollection(printerArray, false, 0);
	self.doSetPrinterListToDefault();

	if self.aMyReportQueueEntry &lt;&gt; null then
		cmbPrinter.listIndex	:=	cmbPrinter.findStringExact(1, self.aMyReportQueueEntry.printerName);
	endif;

	if chkPrintToFile.value then
		btnPrintFile.enabled	:=	true;
		cmbPrinter.enabled		:=	false;
	else
		btnPrintFile.enabled	:=	false;
		txtDestination.text		:=	null;
		cmbPrinter.enabled		:=	true;
	endif;

	self.registerNotifications();
epilog
	delete printerArray;
	delete reportForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetPrinterListToDefault" id="c91ebfe2-2e93-404e-af13-a242f4eb2075">
        <source>doSetPrinterListToDefault() protected;

vars
	defaultPrinter		: String;
	setPrinterResult	: Integer;

begin
	defaultPrinter		:=	"";
	setPrinterResult	:=	app.printer.setPrinter(defaultPrinter);

	if setPrinterResult = Print_Successful then
		cmbPrinter.listIndex	:=	cmbPrinter.findString(1, defaultPrinter);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="optLocal_click" id="11c3a08d-e311-4fc0-9558-4085a0167b6f">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optLocal_click(optionbutton: OptionButton input) updating;

vars
	printerNameArray	: StringArray;
	theTimeStamp		: TimeStamp;

begin
	app.mousePointer	:=	Busy;

	create printerNameArray transient;

	if optionbutton.value then
		txtDate.readOnly	:=	true;
		txtTime.readOnly	:=	true;
		app.printer.getAllPrinters(printerNameArray);
		txtDate.text		:=	theTimeStamp.date.String;
		txtTime.text		:=	theTimeStamp.time.String;
	endif;

	cmbPrinter.listCollection(printerNameArray, false, 0);
	self.doSetPrinterListToDefault();
epilog
	delete printerNameArray;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optServer_click" id="839759aa-ad79-476a-804a-00fc9a089a12">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optServer_click(optionbutton: OptionButton input) updating;

vars
	printerNameArray	: StringArray;

begin
	app.mousePointer	:=	Busy;

	create printerNameArray transient;

	if optionbutton.value then
		txtDate.readOnly	:=	false;
		txtTime.readOnly	:=	false;
		global.cnEcGetAllServerPrinters(printerNameArray);
	endif;

	cmbPrinter.listCollection(printerNameArray, false, 0);
	self.doSetPrinterListToDefault();
epilog
	delete printerNameArray;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFormParameters" id="eea3bb38-6bea-419c-8ce4-be6a3b170aee">
        <source>setFormParameters(param: CnEcReportParameter; paramForm:CnEcReportParameterValueSuper input);

begin
	paramForm.setReportParameter(param);

	if param.isPrimitiveType() then
		// ...as primitive type
		paramForm.setStringValue(tblParameters.getCellText(tblParameters.row, 4));	
	else
		// ...as object reference
		paramForm.setObjectValue(tblParameters.cnEcGetItemObject(tblParameters.row, 4));
	endif;
end;</source>
        <Parameter name="param" type="CnEcReportParameter"/>
        <Parameter name="paramForm" type="CnEcReportParameterValueSuper" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblParameters_click" id="6c8ecbdd-d417-4c96-ad70-6514c6b28b16">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParameters_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		29 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnableButtons();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblParameters_dblClick" id="13d7bc73-0bca-489b-afe6-b16481f300da">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParameters_dblClick(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		29 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (tblParameters.cnEcIsRowSelected(tblParameters.row)) then
		btnValue.click(btnValue);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblParameters_mouseDown" id="843de327-0635-4441-b5e0-c166dd2a8816">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParameters_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	table.cnEcSelectRow();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="c25db55b-4f7b-4e12-8e9b-ad583def9ee9">
        <updating/>
        <source>timerEvent(eventTag : Integer) updating;

begin
	lblMessage.visible	:=	(not lblMessage.visible);
	lblMessage.refreshNow();
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
