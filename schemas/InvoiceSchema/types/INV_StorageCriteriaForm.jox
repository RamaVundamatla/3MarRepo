    <JadeMethod name="btnViewAudit_click" id="bb6f9c6f-86a2-497f-a289-0fbb10d76757">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewAudit_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits

*/

vars
	storageDetail		: CM_StorageDetail;
begin
	
	storageDetail := self.myStorageDetail;
	
	if storageDetail = null then
		return;
	endif;
	
	app.viewAuditForm(storageDetail, self.myAssistant.class, self.myTerminal);
	
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbFutureStoChrgPeriod_click" id="8a9729a9-bd1a-4c6d-b17e-8911ef279023">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFutureStoChrgPeriod_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage

*/

vars
	chargeType : Integer;
begin
	if combobox.listIndex &gt; 0 then
		// Release storage combo should be the same as Future storage combo
		// Except in Edit mode, if future release storage combo is ALL MONTH, set the release storage combo to ALL DAY
		chargeType := combobox.itemData[combobox.listIndex];
		
		// This is edit mode
		if self.myStorageDetail &lt;&gt; null then
			if chargeType = CM_StorageDetail.Calendar_Months then
				chargeType := CM_StorageDetail.Calendar_Days;
			endif;
		endif;
		
		self.setComboIndex(self.cmbRelStoChrgPeriod, chargeType);
		
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbRelStoChrgPeriod_click" id="1438185d-c6cc-4840-a1b8-8541c2254700">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRelStoChrgPeriod_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage

*/

vars
	chargeType : Integer;
begin
	if combobox.listIndex &gt; 0 then
		// Future storage combo should be the same as Release storage combo
		chargeType := combobox.itemData[combobox.listIndex];
		
		self.setComboIndex(self.cmbFutureStoChrgPeriod, chargeType);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
