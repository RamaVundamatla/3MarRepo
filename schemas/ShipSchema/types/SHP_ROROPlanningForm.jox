    <JadeMethod name="setModeViewActual" id="3b9c555a-5f22-461d-a7b7-f63fda51b9b4">
        <updating/>
        <source>setModeViewActual() updating;
/*
Purpose:			
Date			Who		Reason
23 August 2011	cnwab1	Initial creation
25 Jul 2012		cnwcs5	par 29124 - roro edi stowage advice remarks
*/

vars

begin
	self.btnViewActual.value := true;


	self.switchWorkingMode(self.WorkMode_None);

	self.btnAutoDischCC.enabled := false;
	self.btnCCModeDLR.enabled := false;
	self.btnCCModeDisch.enabled := false;
	self.btnCCModeErase.enabled := false;
	self.btnCCModeLoad.enabled := false;
	self.btnCCModeSOB.enabled := false;
	self.btnCCPalette.enabled := false;
	self.btnDrawAlignBot.enabled := false;
	self.btnDrawAlignLeft.enabled := false;
	self.btnDrawAlignRght.enabled := false;
	self.btnDrawAlignTop.enabled := false;
	self.btnJobDelete.enabled := false;
	self.btnJobEdit.enabled := false;
	self.btnJobSave.enabled := false;
	self.btnSummarise.enabled := true;
	self.btnTranship.enabled := true;
	self.btnWorkJob.enabled := false;
	self.btnWorkPlan.enabled := false;
	self.btnWorkSeq.enabled := false;
	self.btnCapacity.enabled := true;
	self.cmbWPJob.enabled := false;
	self.cmbWorkPoint.enabled := false;
	self.btnDrawRemarks.enabled	:= false;	// par 29124 July 2012
	self.btnDrawRemarks.value	:= false;	// par 29124 July 2012
	self.chkOutOfSequence.enabled := false;//cnwrd1 par 30626 ccms 2209 23.10.12

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnTranship.enabled:= false;
	endif;
	
	self.doResize(); // PAR 31073 we are hiding the Exports Show button and need this to close the toolbar gap.
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setModeViewCCDischarge" id="1c2dda4d-b463-4c81-a7b8-66b049472bff">
        <source>setModeViewCCDischarge();
/*
Purpose:			
Date			Who		Reason
23 August 2011	cnwab1	Initial creation
25 Jul 2012		cnwcs5	par 29124 - roro edi stowage advice remarks
*/

vars

begin
	self.btnViewDischarge.value := true;
	self.btnViewExport.visible := true; // PAR 31073

	self.btnAutoDischCC.enabled := true;
	self.btnCCModeDLR.enabled := true;
	self.btnCCModeDisch.enabled := true;
	self.btnCCModeErase.enabled := true;
