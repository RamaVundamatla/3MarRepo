    <JadeMethod name="getMoveDescription" id="9ea00461-1297-45a2-a5b8-505f6b08bad4">
        <source>getMoveDescription():String;
// ---------------------------------------------------------------------------
// Created:     15 October 2008 by concms1
// Purpose:     ccms 1035 - Gate ticket printing (APM)
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
begin
	if self.myYardRequest = null then
		return null;
	endif;
	
	wle := self.myYardRequest.getWLEForTI(self.getTI());
		
	if wle = null then
		return null;
	endif;
	
	return wle.getMoveDescription;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
