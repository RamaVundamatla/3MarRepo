    <JadeMethod name="setForCreate" id="754f3d3b-cdee-4ca5-ab3b-d0104c828245">
        <updating/>
        <source>setForCreate(_proxyShippingLine:CM_ShippingLine) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
