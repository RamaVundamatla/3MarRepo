    <JadeMethod name="createProxysForUpdate" id="ee97f34a-4bba-4ec0-8e15-a7768d6c6efd">
        <source>createProxysForUpdate() : CMGTE_EntityArray;
// ---------------------------------------------------------------------------
// Created:     26 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyInOuts : CMGTE_EntityArray;
	pxyGateEntity, realGateEntity : CMGTE_Entity;
begin

	if self.myVehicleVisit = null then
		return null;
	endif;
	
	foreach realGateEntity in self.myVehicleVisit.allGateEntities discreteLock do
		pxyGateEntity := app.createUpdateProxy(realGateEntity).CMGTE_Entity;
		pxyInOuts.add(pxyGateEntity);
	endforeach;
	
	create pxyInOuts transient;
	
	
	return pxyInOuts;
epilog

end;</source>
        <ReturnType type="CMGTE_EntityArray"/>
    </JadeMethod>
    <JadeMethod name="displayTransaction" id="e62bbf00-43b1-423f-817b-3ad933f45aa3">
        <updating/>
        <source>displayTransaction(_tranNum : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	table : CM_DataTable;
	tmpChassis, tmpType : String;
	err : CM_ErrorPersistent;
	len, row : Integer;
begin
	self.hideForViewOnly();
	
	
	table := self.tblData;
	self.btnReprocess.enabled := true;
	self.btnReprocess.bubbleHelp := "Reprocess Road Job";
	
	table.rows := table.fixedRows;
	
	if self.myVehicleVisit = null then
		return;
	endif;
	
	if self.myVehicleVisit.status &lt;&gt; CM_VehicleVisitRecord.Status_Trouble then
		self.btnReprocess.enabled := false;
		self.btnReprocess.bubbleHelp := "Road Job is not in Trouble, cannot Reprocess";
	endif;
	
	self.txtTrans.text := _tranNum;
	
	len := _tranNum.length();
	
	// need to check this call to see if really required and what should do here
	//tmpChassis := self.myVehicleVisit.getChassisID(self.tranNum);
	
	self.txtChassis.caption := tmpChassis;
	//self.txtContainerID.caption := self.myVehicleVisit.getContainerID(_tranNum);
	self.txtDate.caption := self.myVehicleVisit.createdTime.asStringJMT();
	
	
	foreach err in self.myVehicleVisit.allErrorsWarningsByTranNum discreteLock where err.transactionNum[1:len] = _tranNum do
		if err.isStatement() and not self.showStatements then
			continue;
		endif;
		
		row := table.addItemObject(err,     "" &amp; Tab &amp; err.errorCode.String &amp; Tab &amp; err.getErrorText() &amp; Tab &amp; err.getTypeString() &amp; Tab &amp; err.getStatusString());
		if err.type = CM_ErrorPersistent.Type_Error then
			table.accessRow(row).foreColor := Red;
		elseif err.type = CM_ErrorPersistent.Type_Warning then
			table.accessRow(row).foreColor := Blue;
			table.accessCell(row, self.Column_Ignore).inputType := Table.InputType_CheckBox;
		else
			table.accessRow(row).foreColor := Green;
		endif;
		
		if err.status = CM_ErrorPersistent.Status_Closed then
			table.accessRow(row).foreColor := DarkGray;
			table.accessRow(row).backColor := LightGray;
		endif;
		
		if not err.isStatement() then
			table.accessCell(row, self.Column_Update).inputType := Table.InputType_CheckBox;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_tranNum" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayTransactions" id="cf592a9b-4f3c-4eca-8877-d0b2e5cc7555">
        <source>displayTransactions(_trans : CMGTE_EntitySet);
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gate : CMGTE_Entity;
	table : CM_DataTable;
	tmpChassis, tmpType : String;
	err : CM_ErrorPersistent;
	row : Integer;
begin
	table := self.tblTrans;
	table.selectMode := Table.SelectMode_CurrentRow;
	
	table.rows := table.fixedRows;
	table.visible := false;
	
	if _trans.isEmpty() then
		return;
	endif;
	
	foreach gate in _trans reversed, discreteLock do
	
		self.txtTrans.text := gate.tranNumber;
		
		row := table.addItemObject(gate, gate.tranNumber &amp; Tab &amp; gate.date.asStringJMT());
		
	endforeach;
	table.visible := true;

epilog

end;</source>
        <Parameter name="_trans" type="CMGTE_EntitySet"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="60a0abcf-f952-4bd7-be71-819d82242dc6">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gate : CMGTE_Entity;
	tranNum : String; 
	trans : CMGTE_EntitySet; 
begin
	create trans transient;
	tranNum := self.txtTrans.text;
	self.doReset();
	if tranNum &lt;&gt; null then
		self.txtTrans.text := tranNum.String;
		self.myTerminal.getVehicleVisitGateItemsByTran(tranNum, trans, true);
		
		if trans.isEmpty() then
			app.msgBox("No transactions for '" &amp; tranNum.String &amp; "' at terminal '" &amp; self.myTerminal.code &amp; "'.", "Transaction Problem", MsgBox_OK_Only);
			return;
		endif;
	else
		return;
	endif;
	
	if trans.size &gt; 1 then
		self.displayTransactions(trans);
	endif;
	
	gate := trans.last;
	self.myVehicleVisit := gate.myVehicleVisitRecord;
	
	self.displayTransaction(tranNum);
epilog
	delete trans;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="98e8e5f4-2382-4916-82f8-478e1beb0c0e">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.displayTransaction(self.tranNum);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReset" id="8696c5cb-d03f-4788-8c45-e5912b7a1754">
        <source>doReset();
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblData.rows := self.tblData.fixedRows;
	
	self.txtChassis.caption := "";
	self.txtContainerID.caption := "";
	self.txtTrans.text := "";
	self.txtDate.caption := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateGateEntity" id="c47f5c44-73e8-43a3-9755-0c35791e4762">
        <updating/>
        <source>doUpdateGateEntity() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	result : Integer;
	pxyInOuts : CMGTE_EntityArray;
begin
	pxyInOuts := self.createProxysForUpdate();
	if pxyInOuts = null then
		return false;
	endif;
	
	if pxyInOuts.isEmpty then
		return false;
	endif;
	
	self.setErrorsToIgnore(app.myPassport);
	
	app.myPassport.setWarningsIgnored(true);
	
	while true do
		
		// trxUpdateInOutFlexiGateEntity() no longer takes a collection.  Could create a new method:
		// trxUpdateInOutFlexiGateEntities() which takes the collection and pushes each entity through the normal channels once 
		// in transaction state?
		
		// Some Errors can be ignored, some cannot! See self.setErrorsToIgnore
		if not app.myPassport.noErrorsIgnored() then
			result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			self.setAllErrorWarnings(app.myPassport);	
			return false;
		endif;
	
		if not app.myPassport.hasErrorsOrWarnings() then
			app.msgBox("Transaction Created.", "Terminal Gate", MsgBox_Information_Icon);
			self.setAllErrorWarnings(app.myPassport);	
			return true;
		endif;
		
		app.msgBox("Transaction has Trouble.", "Terminal Gate", MsgBox_Exclamation_Mark_Icon);
		self.setAllErrorWarnings(app.myPassport);	
		return true;
	endwhile;

	return true;
epilog


	app.myPassport.clearErrorsToIgnore(); // PAR 17703 AKB2008SEP


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideForViewOnly" id="69ec849a-dc03-45a7-9aab-405ab3ee1eed">
        <updating/>
        <source>hideForViewOnly() updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if not self.viewMode then
		return;
	endif;
	
	self.grpTop.visible := false;
	self.btnReprocess.visible := false;
	self.grpTable.top := self.grpTop.top;

	self.grpTable.height := self.btnClose.top - 5 - self.grpTable.top;
	
	self.tblData.accessColumn(self.Column_Update).visible := false;
	self.tblData.accessColumn(self.Column_Ignore).visible := false;
	
	self.caption := "Trouble for transaction " &amp; self.myVehicleVisit.visitNumber &amp; ", vehicle " &amp; self.myVehicleVisit.regNumber;
	
	self.width := 400;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="e2819935-468f-454e-aeff-0ab8c0bfe652">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	IGNORE = 5;  
vars
	row : Integer;
	table : CM_DataTable;
begin
	table := self.tblData;
	
	table.columns := 6;
	table.rows := 0;
	table.addItem("Updated" &amp; Tab &amp; "Number" &amp; Tab &amp; "Description" &amp; Tab &amp; "Type" &amp; Tab &amp; "Status" &amp; Tab &amp; "Ignore" );
	table.fixedRows := 1;

	self.txtChassis.caption := "";
	self.txtContainerID.caption := "";
	self.txtTrans.text := "";
epilog

end;</source>
