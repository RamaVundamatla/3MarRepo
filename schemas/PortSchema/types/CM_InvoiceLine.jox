    <JadeMethod name="transientCopy" id="9b2c277f-fe6e-44c4-bc8e-21c952586cd2">
        <source>transientCopy(): SelfType;
// for proforma invoices, copy as transient before aborting the transaction creation
vars
	pxyMe : SelfType;
	transChg,
	charge	: CM_Charge;
begin
	pxyMe := self.cloneSelf(true);
	
	pxyMe.invoiceLineDesc := self.invoiceLineDesc;
	pxyMe.bank := self.bank;
	pxyMe.invoice := self.invoice;
	pxyMe.debtor  := self.debtor;
	
	// ### CARGO
	pxyMe.trackedItem := self.trackedItem;	// 31602 add this for the cash receipt printing
	if self.myTransactionTI &lt;&gt; null then
		pxyMe.remarks := self.myTransactionTI.typeString;
		pxyMe.quantityNoMinMax := self.myTransactionTI.type;	// 36544 save this off for the CM_ProformaDetails transactionType for the cash receipt report.
	endif;
	
	
	// ### VOYAGE
	// TFS 37454
	pxyMe.myTransactionHMS := self.myTransactionHMS;
	pxyMe.myTransactionEvent := self.myTransactionEvent;
	pxyMe.myTransactionWO := self.myTransactionWO; // TFS 41281
	pxyMe.myTransactionBOL := self.myTransactionBOL;	//31 Oct 2019	NDL	TFS 47100
	
	// TFS 39507
	if self.myTransactionWO &lt;&gt; null then
		pxyMe.remarks := self.myTransactionWO.getTranTypeString();
		pxyMe.quantityNoMinMax := self.myTransactionWO.type;	// save this off for the CM_ProformaDetails transactionType for the cash receipt report.
	endif;
	if self.myTransactionHMS &lt;&gt; null then
		pxyMe.remarks := self.myTransactionHMS.typeString;
		pxyMe.quantityNoMinMax := self.myTransactionHMS.type;	// save this off for the CM_ProformaDetails transactionType for the cash receipt report.
	endif;
	
	
	foreach charge in self.charges do
		transChg := charge.cloneSelf(true);
		// link to new invoice line, keep bank null (not needed) but keep service for tax
		transChg.setForCreate(null, pxyMe, transChg.sequenceNum, charge.service);
	endforeach;
epilog	
	return pxyMe;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="updateDebtorWithAudits" id="fb828a6d-4713-4639-af18-81d235c480a8">
        <updating/>
        <source>updateDebtorWithAudits(_newDebtor : CM_Debtor) updating;
/*
Purpose:			

Date		Who		Reason
22 June 2023	navab1	BUG 58791
*/

vars

	audit : CM_UpdateTransactionAuditAgent;
begin

	if self.debtor = _newDebtor then
		return;
	endif;
	
	create audit transient;
	audit.audUpdateGeneric(self, true);
	self.debtor := _newDebtor;
	audit.audUpdateGeneric(self, false);
epilog
	delete audit;

end;</source>
        <Parameter name="_newDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="updateFromSnapshotResync" id="c976948d-0914-431d-8ff5-dbc292b10175">
        <updating/>
        <source>updateFromSnapshotResync(_debtor : CM_Debtor; _qtyRangeMap : CM_QuantityRangeMap; _quantity : Integer) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
// 19/06/2019 jlgsl4	TFS 44796 - add audits to resyncing
vars
	invType : CM_InvoiceDesc;
	newInvoice	: CM_Invoice;
begin
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true); // TFS 44796
	self.setForUpdateQuantity(_quantity);
	self.setFromQuantityRangeMap(_qtyRangeMap);
	if _debtor &lt;&gt; self.debtor then
		invType := self.invoiceLineDesc.getInvoiceType(_debtor);
		newInvoice := self.bank.getAutoInvoiceSnapshot(invType, _debtor, self.chargeTime, false, self.invoiceLineDesc);
		if newInvoice &lt;&gt; self.invoice then
			self.moveLineToInvoice(newInvoice);
		endif;
	endif;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false); // TFS 44796
end;

</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_qtyRangeMap" type="CM_QuantityRangeMap"/>
        <Parameter name="_quantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFromTransactionResync" id="1d388c0e-95ac-407d-891b-262494615399">
        <updating/>
        <source>updateFromTransactionResync(_tran : CM_TITransaction) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		19 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 01/05/2014 cnwjre1	33885 testing, add the return status for voided/posted line so these resync correctly
// 19/06/2019 jlgsl4	TFS 44796 - add audits to resyncing
// 05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Jan 2022	navvt20		TFS CR 55625 Task 55658: Jade - Contract Id TRX
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	value				: Real;
	str					: String; // 18 Jan 2022 navvt20 TFS 55658
	tmpDebtor  			: CM_Debtor;
	invLineNarration	: String;
	invLineSeq			: String;
	invSeq				: String;
	invLineTotal		: String;
	canLogExtra			: Boolean;
begin
	if _tran = null then
		return false;
	endif;
	
	if self.invoiceLineDesc &lt;&gt; null then						//05.10.2022 navma1 #52967
		invLineNarration := self.invoiceLineDesc.narration;
	endif;
	
	invLineSeq 		:= self.sequenceNum.String;						//05.10.2022 navma1 #52967
	invSeq	   		:= self.invoice.sequenceNum.String;				//05.10.2022 navma1 #52967
	invLineTotal	:= self.lineTotal.String;						//05.10.2022 navma1 #52967
	canLogExtra     := app.canLogExtraDetail();						//05.10.2022 navma1 #52967
	
	// 37707 handle lines from posted invoices separately
	// this returns true so that a new invoice line can be created when the existing one has been voided
	if self.status = CM_InvoiceLine.STATUS_VOIDED or self.invoice.isVoided then
		if canLogExtra then													//05.10.2022 navma1 #52967
			app.invLog(invLineNarration &amp; " - existing invoice line " &amp; invLineSeq &amp; " " &amp; invLineTotal &amp; " of invoice " &amp; invSeq &amp; " is VOIDED", LogTRACE.String); //05.10.2022 navma1 #52967
		endif;
		return true;
	endif;
	// 37707 is posted, do nothing and return false so no new invoice line gets created
	//if self.invoice.status = CM_Invoice.INVOICE_POSTED then
	if self.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
		if canLogExtra then													//05.10.2022 navma1 #52967
			app.invLog(invLineNarration &amp; " - existing invoice line " &amp; invLineSeq &amp; " " &amp; invLineTotal &amp; " of invoice " &amp; invSeq &amp; " is POSTED", LogTRACE.String);	//05.10.2022 navma1 #52967
		endif;
		return false;
	endif;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true); // TFS 44796
	// 35992 can lose weight etc if transaction does not have it set (such as Unpack)
	// TFS 1990 don't need to for split lines, keep their values
	if not self.manual then
		value := _tran.getChargeQuantity();
		if value &lt;&gt; 0 then
			self.trackedItemQuantity := value;
		endif;
		value := _tran.getChargeVolume();
		if value &lt;&gt; 0 then
			self.trackedItemVolume := value;
		endif;
		value := _tran.getChargeWeight();
		if value &lt;&gt; 0 then
			self.trackedItemWeight := value;
		endif;
		value := _tran.totalLength; // PAR 31615
		if value &lt;&gt; 0 then
			self.trackedItemLength := value;
		endif;
		// Start 18 Jan 2022 navvt20 TFS 55658
		//navra1 - 13th March 2024 - BUG 62681 - start
		/*str := _tran.contractId;
		if str &lt;&gt; null then 
			self.setContractId(str); // ### TFS CR 55648 TASK 56818 15MAR2023 NAVAB1
		endif;*/
		//navra1 - 13th March 2024 - BUG 62681 - end
		// End 18 Jan 2022 navvt20 TFS 55658
	endif;

	tmpDebtor := _tran.getDebtorForInvoiceLine(self.invoiceLineDesc); // TFS 42221
	if canLogExtra then													//05.10.2022 navma1 #52967
		app.invLog(invLineNarration &amp; " - existing invoice line " &amp; invLineSeq &amp; " " &amp; invLineTotal &amp; " of invoice " &amp; invSeq, LogTRACE.String);		//05.10.2022 navma1 #52967
	endif;

	if tmpDebtor &lt;&gt; self.debtor then
		self.reevaluate();
	endif;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false); // TFS 44796
	return false;
end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFromVBContractResync" id="4acc5bb6-4204-430f-9171-7678ab4cd0dd">
        <source>updateFromVBContractResync();
/*
Purpose:	Update charges that have been created form a volume based contract.		

Date		Who		Reason
20 Jun 2023	navab1	CR 55653 TASK 55669 
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	charge 			: CM_Charge;
	contract 		: CM_InvoiceContract;
	detail 			: CM_InvoiceContractDetails;
	rate 			: CM_InvoiceContractRate;
	entry 			: CM_InvoiceContractRateEntry;
	uomType 		: Integer;
	rangeAmount, 
	rateAmount 		: Decimal [23,4];
	canLogExtraInfo : Boolean;
begin
	canLogExtraInfo := app.canLogExtraDetail();							//28.05.2024 navma1 #64224
	
	if canLogExtraInfo then												//28.05.2024 navma1 #64224
		app.invLog("CONT RESYNC VB " &amp; self.invoiceLineDesc.narration, LogINFO.String);
	endif;
	
	contract := self.bank.allInvoiceContractsById[self.contractId,self.debtor];
	
	if contract = null then
		if canLogExtraInfo then											//28.05.2024 navma1 #64224
			app.invLog("CONT RESYNC contract " &amp; self.contractId &amp; " for debtor " &amp; self.debtor.name &amp; " not found, no changes to rates", LogINFO.String);
		endif;
		return;
	endif;
	
	detail := contract.getContractDetail(self.trackedItem,self.invoiceLineDesc,self.chargeTime);
	
	if detail = null then
		if canLogExtraInfo then											//28.05.2024 navma1 #64224
			app.invLog("CONT RESYNC no matching detail found, no changes to rates", LogINFO.String);
		endif;
		return;
	endif;
	
	if detail.contractType &lt;&gt; INV_CONTRACT_TYPE_VOLUME_BASED then
		if canLogExtraInfo then											//28.05.2024 navma1 #64224
			app.invLog("CONT RESYNC detail found but not volume based, no changes to rates", LogINFO.String);
		endif;
		return;
	endif;
	if detail.myUnitOfMeasure &lt;&gt; null then
		uomType := detail.myUnitOfMeasure.type;
	endif;
	
	foreach charge in self.charges discreteLock do : outerloop
		if not charge.isVolumeBased() then
			continue outerloop;
		endif;
		
		rate := detail.allInvContractRatesByService[charge.service];
		if rate = null then
			continue outerloop;
		endif;
		
		// ### GET RANGE AMOUNT TO GET RATE
		if uomType = Invoice_UOM_Type_Weight then
			rangeAmount := charge.contractVBAccumulatedWeight;
		elseif uomType = Invoice_UOM_Type_Volume then
			rangeAmount := charge.contractVBAccumulatedVolume;
		elseif uomType = Invoice_UOM_Type_TEU then
			rangeAmount := charge.contractVBAccumulatedTEU;
		elseif uomType = Invoice_UOM_Type_Quantity then 
			rangeAmount := charge.contractVBAccumulatedQuantity;
		else
			continue outerloop; // ignore
		endif;
		
		if canLogExtraInfo then											//28.05.2024 navma1 #64224
			app.invLog("CONT RESYNC  deriving rate for charge " &amp; charge.sequenceNum.String &amp; " range amolunt " &amp; rangeAmount.String, LogINFO.String);
		endif;
		
		foreach entry in rate.allInvoiceContractRateEntries discreteLock do : innerloop
			if rangeAmount &gt;= entry.fromAmount
			and rangeAmount &lt;= entry.toAmount then
				rateAmount := entry.costPerUnit;
				if canLogExtraInfo then											//28.05.2024 navma1 #64224
					app.invLog("CONT RESYNC  rate found for range " &amp; entry.fromAmount.String &amp; " to " &amp; entry.toAmount.String, LogINFO.String);
				endif;
				
				charge.setRateForContractResync(rateAmount);
				
				continue outerloop;
			endif;
		endforeach;
		
		if canLogExtraInfo then											//28.05.2024 navma1 #64224
			app.invLog("CONT RESYNC  no rate found for charge " &amp; charge.sequenceNum.String, LogINFO.String);
		endif;
		
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="usesGLCode" id="01f6e74a-82e2-44b7-80e8-4e90cc90e701">
        <source>usesGLCode( _str : String ):Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2017	jlgndl1	Initial creation	22 Aug 2017
26/09/2017	jlgdap1	TFS 7146 SNO Prevent 1090 when no GL codes in use
*/

vars

	iter : Iterator;
	charge : CM_Charge;
	service : CM_Service; 
	glCode : CM_GLCode;

begin

	iter := self.charges.createIterator;
	while iter.next( charge ) do
		service := charge.service;
		if service = null then
			continue;
		endif;
		glCode := service.genLCode;
		//if glCode.code &lt;&gt; _str then						// TFS 7146
		if glCode = null or glCode.code &lt;&gt; _str then		// TFS 7146
			continue;
		endif;
		return true;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateWebInvoiceLine" id="9ed660c1-d8c9-496f-b565-24de9c5cf08d">
        <source>validateWebInvoiceLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes
11/02/2025	navcs2	MTN-33895 GPHA - POST /invoice error 90275 

*/

vars

begin
	
	if self.externalRef1 = null then
		app.raiseCMException1(Err_Is_Null, "External Reference1", "Web Invoice Line number", null);				// 11/02/2025	navcs2	MTN-33895
	endif;
	
	if self.externalRef2 = null then
		app.raiseCMException1(Err_Is_Null, "External Reference2", "Web Invoice Line File Number", null);		// 11/02/2025	navcs2	MTN-33895
	endif;
	
epilog

end;</source>
    </JadeMethod>
