    <JadeMethod name="doContextMenuReportTree" id="fa6c553e-3b15-45e9-9c1a-c9960c366ae0">
        <updating/>
        <source>doContextMenuReportTree(cntrl: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, y1				: Real;
	menuEntity			: CM_MenuEntity;
	idx					: Integer;
	user				: CM_User;
begin
	
	menuEntity := self.lbReportTree.listObject.CM_MenuEntity;
	idx := cntrl.getListIndex(x,y);
	if idx &lt; 0 then
		return false;
	endif;
	//check we are clicking the right object
	menuEntity := cntrl.itemObject[idx].CM_MenuEntity;
	
	self.lbReportTree.listObject := menuEntity;	

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop(cntrl.listIndex);
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	//disable all the context menu options, and re enable depending on what appropriate
	//for the select object type
	self.mnuRepResetFromJMT.enabled 	:= false;
	self.mnuRepResetAllMenus.enabled 	:= false;
	self.mnuRepSaveAsSys.enabled 		:= false;
	
	user := app.getMyUser;
	
	if app.isSpecial() then
		self.mnuRepSaveAsJMT.visible := true;
	else
		self.mnuRepSaveAsJMT.visible := false;
	endif;
	if app.isAllowedToInspect() then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;
	endif;
	
	if user.canDo(self.myTerminal, PmAdmAdminMenuAccess) then
		self.mnuRepSaveAsSys.visible := true;
		self.mnuRepResetAllMenus.visible := true;
		self.mnuRepResetFromJMT.visible := true;

		self.mnuRepSaveAsSys.enabled := true;
		self.mnuRepResetAllMenus.enabled := true;
		self.mnuRepResetFromJMT.enabled := true;
	else
		self.mnuRepSaveAsSys.visible := false;
		self.mnuRepResetAllMenus.visible := false;
		self.mnuRepResetFromJMT.visible := false;
	endif;
	
	if CM_MenuUserReport.hasInstance(menuEntity) and 
	   (menuEntity.CM_MenuUserReport.myEmailTemplate &lt;&gt; null) then
		self.mnuSep3.visible := true;
		self.mnuEditEmailData.visible := true;
	else
		self.mnuSep3.visible := false;
		self.mnuEditEmailData.visible := false;
	endif;
	
	self.popupMenu(self.mnuContextHeader, x1.Integer, y1.Integer);
	
	return false;

end;</source>
        <Parameter name="cntrl" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuTblReports" id="1d91a9ab-03c0-4918-8ffa-b9b52343c9ab">
        <updating/>
        <source>doContextMenuTblReports(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	column,
	row,
	idx					: Integer;

begin
	
	cntrl.CM_DataTable.getCellFromPosition(x, y, row, column);
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form	
	
	self.popupMenu(self.mnuBGRContext, x1.Integer, y1.Integer);
	return false;                  // cancel further processing

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplayEmailForm" id="801d33b6-3396-42ab-bef0-8773282430c7">
        <source>doDisplayEmailForm(_csvFileName : String; _email : CM_EmailTemplate input; _showExtra : Boolean) : Boolean protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	attachFrm 		: CMUI_EmailSetupForm;
	sender			: String;
	
begin

/* -- par 19494  13.8.09
	if not app.myRoot.canDo(PmPDFBackground) then //par 19494 cnwrd1 9.6.09
		return false;
	endif;
	*/
	
	app.mousePointer := MousePointer_Default;
				
	//attachFrm := app.loadForm(CMUI_EmailSetupForm, self.myAssistant.class, false, false, false, self.myTerminal, null).CMUI_EmailSetupForm; //par 19494 cnwrd1 9.6.09
				

	create attachFrm; //par 19494 cnwrd1 9.6.09
	attachFrm.myTerminal := self.myTerminal;
	attachFrm.createMyAssistant(CMUI_Assistant);
	
	
	if attachFrm = null then
		return false;
	endif;
	
	if _csvFileName &lt;&gt; null then
		_email.attachFile(_csvFileName);
	endif;
	attachFrm.centreWindow;
	attachFrm.initEmailObject(_email, _showExtra);
	
	if attachFrm.showModal = MsgBox_Return_OK then
		return true;
	endif;
	return false;
epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_csvFileName" type="String"/>
        <Parameter name="_email" type="CM_EmailTemplate" usage="input"/>
        <Parameter name="_showExtra" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEditEmailData" id="ee22991e-8daa-4f04-aff1-cc364b549b11">
        <source>doEditEmailData() protected;
// ---------------------------------------------------------------------------
// Created:     17 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj						: Object;
	pxyEmailTemplate,
	emailTemplate			: CM_EmailTemplate;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	obj := self.lbReportTree.listObject;
	if (not CM_MenuUserReport.hasInstance(obj)) or
	   (obj.CM_MenuUserReport.myEmailTemplate = null) then
		return;
	endif;
	
	emailTemplate := obj.CM_MenuUserReport.myEmailTemplate;
	pxyEmailTemplate := app.createUpdateProxy(emailTemplate).CM_EmailTemplate;
		
	if (not self.doDisplayEmailForm(null, pxyEmailTemplate, true)) then
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMenuUserReportEmail(pxyEmailTemplate, obj.CM_MenuUserReport, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(	app.getString( User_Report_Email_Update ), app.myPassport, ErrWarnMode_Add );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete pxyEmailTemplate;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLbReportTreeSearch" id="c927e5b6-de26-4be7-9bbf-4478d40a5ed4">
        <updating/>
        <source>doLbReportTreeSearch() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 27 June 2011
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
//----------------------------------------------------------------------

vars
	str 	: String;
	idx		: Integer;
	found	: Boolean;
	i	 	: Integer;
	level	: Integer;
	total	: Integer;
	obj : Object;
	menuUserDetail : CM_MenuUserDtl;
	report : CM_QryReport;
	extraString : String;
begin
	//self.btnCancel.default := false;
	//self.btnPrint.default := false;
	str := self.txtSearchReport.text.trimBlanks;

	total := self.lbReportTree.listCount;

	if searchIndex &gt; lbReportTree.listIndex  then
		searchIndex := lbReportTree.listIndex;
	endif;
	
	if searchIndex &lt; 1 or searchIndex &gt;= total then
		searchIndex := 1;
	endif;

	if str.trimBlanks = null then
		return;
	endif;

	foreach idx in searchIndex + 1 to total do
		if lbReportTree.itemText[idx].toUpper.pos(str.toUpper,1) &lt;&gt; null then
			found := true;
			break;
		endif;
		//01 Sep 2015	NDL	Par 36846
		obj := lbReportTree.itemObject[idx];
		if obj &lt;&gt; null and obj.isKindOf(CM_MenuUserDtl) then
			menuUserDetail :=  obj.CM_MenuUserDtl;
			if menuUserDetail.myMenuDtl &lt;&gt; null and menuUserDetail.myMenuDtl.isKindOf(CM_QryReport) then
				report := menuUserDetail.myMenuDtl.CM_QryReport;
				extraString := report.reportDescription;
				if extraString &lt;&gt; null then
					if extraString.toUpper.pos(str.toUpper,1) &lt;&gt; null then
						found := true;
						break;
					endif;
				endif;
			endif;
		endif;
		
	endforeach;

	if found = false then
		return;
	endif;
	lbReportTree.listIndex := idx;

	// step backwards, opening any higher levels
	level := lbReportTree.itemLevel[idx]; 
	foreach i in 1 to idx reversed do
		if lbReportTree.itemLevel[i] &lt; level then
			 lbReportTree.itemExpanded[i] := true;
			 level := level - 1;
		endif;
		if level = 0 then
			break;
		endif;
	endforeach;

	searchIndex := idx;
	
	self.lbReportTree.click( self.lbReportTree );	//02 Sep 2015	NDL	Par 36846
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadDefaultDatesTimes" id="367a7df2-7a61-4586-a93f-b89e3bd46e8e">
        <updating/>
        <source>doLoadDefaultDatesTimes() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	aTime		: Time;
	yesterday	: Date;
	now			: TimeStamp;
begin
	//SET DATES///////////////////////
	//get the first day of the month
	//app.getDatesLastMonth(openDate, closeDate);
	now := self.systemToLocalTime(app.actualTimeServer());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
	yesterday := now.date - 1;
	//set the cnec Date text boxes
//rs	self.txtOpenDate.setDate(yesterday);
//rs	self.txtCloseDate.setDate(yesterday);
//rs	self.txtMatchStart.setDate(yesterday);
//rs	self.txtMatchEnd.setDate(yesterday);
//rs	self.txtBaseDate.setDate(yesterday);

	self.docketStartDate := yesterday;
	self.docketEndDate := yesterday;
	self.matchStartDate := yesterday;
	self.matchEndDate := yesterday;
	self.ageBaseDate := yesterday;
	
	self.tblParameter.setValueByName(ETRow_StartDate, self.docketStartDate);
	self.tblParameter.setValueByName(ETRow_EndDate, self.docketEndDate);
	self.tblParameter.setValueByName(ETRow_MatchDateStart, self.matchStartDate);
	self.tblParameter.setValueByName(ETRow_MatchDateEnd, self.matchEndDate);
	self.tblParameter.setValueByName(ETRow_BaseDate, self.ageBaseDate);

	//SET TIMES//////////////////////
	aTime.setTime(0, 0, 0, 0);
	self.tblParameter.setValueByName(ETRow_MatchTimeStart, aTime);
	aTime.setTime(23, 59, 59, 0);
	self.tblParameter.setValueByName(ETRow_MatchTimeEnd, aTime);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPicParamPicDblClick" id="3ad9f481-f2d3-4e53-bb3f-8520ee034852">
        <source>doPicParamPicDblClick() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  -------------------------------------------------
vars
	tbl				: CM_EntryTable;
	openDialog		: CMDFileOpen;
	pic				: Binary;
begin
	tbl := self.tblParameter;
	create openDialog transient;
	
	openDialog.filter := '*.jpg; *.jpeg; *.bmp';
	openDialog.filterIndex := 1;
	openDialog.hideReadOnly := true;
	
	if openDialog.open = 0 then
		pic := app.loadPicture(openDialog.fileName);
	    self.picParamPic.picture := pic;
	    self.tblParameter.accessCell(self.tblParameter.row, CM_EntryTable.ColumnValue).picture := pic;
	endif;
	
epilog
	delete openDialog;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReport" id="71fed5ff-b2b0-4a64-aaba-13815905fe06">
        <updating/>
        <source>doReport() protected, updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/02/2018	jlgdap1		TFS 37030 SSL Demurrage Report
// 08/07/2022	jlizm1		TFS 53544 Show warning when trying to print pdf in foreground
vars
	formatOption			: Integer;
	profileName,
	errorStr,
	processOption			: String;
	filterObject,
	filterObjectTemplate	: CMQF_FilterReports;
	proformaFilter : CMQF_InvoiceProforma;
	extraDetail				: CM_ExtraDetail;
	skipValidation			: Boolean;
	enqController : CM_EnqControllerTI;
begin
	on Exception do self.reportExceptionHandler(exception, app.myPassport);
	
	app.isReportWriter := true;// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//	statusLine.caption := "Please wait whilst report is running";	// cnwrl1 11/11/2009 PAR 19951 - what it was
//	statusLine.caption := app.getString( Please_Wait_While_Running );	// cnwrl1 16/06/2010 - what it was
	if self.myReportAgent.myQryReport &lt;&gt; null then
		statusLine.caption := app.getString( Please_Wait_While_Running, self.myReportAgent.myQryReport.reportName );
	elseif self.myReportAgent.myJRWReport &lt;&gt; null then
		statusLine.caption := app.getString( Please_Wait_While_Running, self.myReportAgent.myJRWReport.name );
	else
		statusLine.caption := app.getString( Please_Wait_While_Running );
	endif;
	statusLine.refreshNow();
	
	//If we are browsing the current, saved any sub folder, then just run the BGP report - already processed
	if self.myMenuEntity &lt;&gt; null and self.myMenuEntity.isKindOf(CM_MenuRootUserBackgroundReps) or
		(self.myMenuEntity.isKindOf(CM_MenuUserHdr) and self.myMenuEntity.CM_MenuUserHdr.isBGPReportHeader) then
		self.printBGPReport();
		return;
	endif;
	processOption := self.tblPrintOptions.getValueByName(ETRow_ProcessOption).String;
	
	//validate criteria?
	skipValidation := (processOption = self.PROCESS_TEMPLATE) or (self.myReportAgent.state = CMUI_ReportAgent.STATE_TEMPLATE_EDIT);
	if (not self.requiredFieldsOK(skipValidation = false)) then
		return;
	endif;
	
	if (not self.warningFieldsOK()) then
		return;
	endif;
	
	self.getParametersForReport(self.myReportAgent.myQryReport);
	
	// TFS 37030 populate the Cargo id row in the parameter table with all the cargo items that match any 
	// selector query we may have configured
	enqController := self.runSelectorQueryForCargoIDs(self.myReportAgent.myQryReport); // ### TFS CR 65817 TASK 65819 27AUG2024 NAVAB1

	if self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_VIEW then //we've clicked on a template and want to run it
//		if app.msgBox('Running a template manually will result in the output only being sent to ' &amp; app.getMyUserCode, "Report",  MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_OK then	// cnwrl1 11/11/2009 PAR 19951 - what it was
		if app.msgBox(	app.getString( Running_Template_Manually, app.getMyUserCode ),
						app.getString( Report ),
						MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon ) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
		
		//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
		//mapped method.  Now using getBGPReportRequest method
		//filterObjectTemplate := self.myMenuEntity.CM_MenuUserReport.myReportRequest.myFilter;
		filterObjectTemplate := self.myMenuEntity.CM_MenuUserReport.getBGPReportRequest().myFilter;
		filterObject := filterObjectTemplate.cloneSelf(true);
		filterObject.cloneReferences(filterObjectTemplate, true);
		filterObject.setDatesForTemplateRun(self.systemToLocalTime(app.actualTimeServer()).date);	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
	else	
		filterObject := self.myReportAgent.myQryReport.createFilter();
		if filterObject &lt;&gt; null then
			filterObject.initialize();
			filterObject.allQueryReportParams.clear();
			
			// ### TFS CR 65817 TASK 65819 27AUG2024 NAVAB1
			if filterObject.isKindOf(CMQF_InvoiceProforma) then
				proformaFilter := filterObject.CMQF_InvoiceProforma;
				if proformaFilter &lt;&gt; null
				and enqController&lt;&gt; null then
					enqController.allObjects.copy(proformaFilter.allTrackedItems);
				endif;
			endif;
			
			
			self.allQueryReportParams.copy(filterObject.allQueryReportParams);
			filterObject.allQueryReportParams.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
			if self.myReportAgent.myQryReport.mySelectorQuery &lt;&gt; null then
				self.myReportAgent.setSelectorQueryFromTable(filterObject);
				filterObject.selectorMode := self.myReportAgent.myQryReport.mySelectorQuery.queryMode;
			else
				filterObject.setFromAgent(self.myReportAgent);
			endif;
		endif;
	endif;
	
	if self.tblParameter.isRowVisible(ETRow_ReportProfile) then
		profileName := self.tblParameter.getValueByName(ETRow_ReportProfile).String;
	endif;
	
	if self.cmbFormat.listIndex &gt; 0 then	//06 Jul 2021	NDL	TFS 51405
		formatOption := self.cmbFormat.itemData[self.cmbFormat.listIndex];
	else
		app.msgBox(	app.getString( Input_required_field_format ), app.getString( Error ), MsgBox_OK_Only );
		return;
	endif;
	
	if formatOption = CM_QryReport.PDF_Format and processOption = self.PROCESS_FOREGROUND then	// TFS 53544
		app.msgBox( app.getErrorString(Print_pdf_foreground),
					app.getString(Report_Runner), 
					MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.myReportAgent.myQryReport.menuId = self.myReportAgent.myQryReport.getIdPrefix &amp; CM_RepShipLogList.String then
		if self.myReportController &lt;&gt; null then
			self.myReportController.run(true);
		endif;
	endif;
	
	if self.cmbFormat.text = Rich_Text_Format and self.myReportAgent.myQryReport.jrwReportName.size &gt; 1 then //nice and ugly
		app.msgBox(	app.getString( Ability_CompileRTF_NotPossible ),
					app.getString( Multidesign_RTF_Not_Available ),
					MsgBox_Exclamation_Mark_Icon );
	endif;
	
	if self.myReportController &lt;&gt; null then
		self.myReportController.doPrint();//saves input to report controller's extra detail
		extraDetail := self.myReportController.getExtraDetails(filterObject, errorStr);
		if errorStr &lt;&gt; null then
			app.msgBox( errorStr, app.getString( Report ), MsgBox_Information_Icon );
			return;
		endif;
	endif;
	
	if formatOption &lt;&gt; JadeReportWriterReport.PRINTER then
		if self.myReportAgent.state = myReportAgent.STATE_TEMPLATE_EDIT then
			self.updateTemplateFileType(filterObject, extraDetail, profileName);
		elseif processOption = self.PROCESS_FOREGROUND then
			self.runForegroundFileType(filterObject, extraDetail, profileName);	
		elseif processOption = self.PROCESS_BACKGROUND then
			self.runBackgroundFileType(filterObject, extraDetail, profileName);
		elseif processOption = self.PROCESS_TEMPLATE then
			self.createTemplateFileType(filterObject, extraDetail, profileName);
		endif;
	else
		if self.myReportAgent.state = myReportAgent.STATE_TEMPLATE_EDIT then
			self.updateTemplateStandard(filterObject, extraDetail, profileName);	
		elseif processOption = self.PROCESS_FOREGROUND then
			self.runForegroundStandard(filterObject, extraDetail, profileName);	
		elseif processOption = self.PROCESS_BACKGROUND then
			self.runBackgroundStandard(filterObject, extraDetail, profileName);
		elseif processOption = self.PROCESS_TEMPLATE then
			self.createTemplateStandard(filterObject, extraDetail, profileName);
		endif;
	endif;
	
epilog
	if global.isValidObject(filterObject) and filterObject.isTransient then
		delete filterObject;
	endif;
	app.isReportWriter := false;// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReportSearch" id="c8b54ab3-e584-46c9-bc30-befe6096b244">
        <updating/>
        <source>doReportSearch() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 27 June 2011
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	toolbar : CMUI_Toolbar;
begin
	toolbar := self.frmToolbarSearch;
	toolbar.showCaptions := false;
	
	if toolbar.visible = false then
		toolbar.addButton(self.btnFindTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnCloseTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.positionToolbarControls();
		
	endif;

	if self.frmFind.visible = true then	
		self.doLbReportTreeSearch();
	else
		self.frmFind.left := 2;
		self.frmFind.width := self.frmFind.parent.width - 4;
		self.frmFind.top := 15;
		self.frmFind.visible := true;
		self.txtSearchReport.left := 90;  // ### TFS 50421 15DEC2021 NAVAB1 was 60;
		self.txtSearchReport.top := 10;  // ### TFS 50421 15DEC2021 NAVAB1
		self.txtSearchReport.width := self.txtSearchReport.parent.width - 65;
		
		self.lbReportTree.top := self.frmFind.top + self.frmFind.height + 2;
		toolbar.visible := true;
		self.txtSearchReport.setFocus();
		self.btnCancel.default := false;
	endif;
	
	self.doResize(); //03 Dec 2015	NDL	Par 36846
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doReportSearchClose" id="51130d61-344c-494c-8c6d-6afba7a34355">
        <source>doReportSearchClose();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 28 June 2011
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	self.lbReportTree.height := self.lbReportTree.height + self.frmToolbarSearch.height;
	self.lbReportTree.top := self.lbReportTree.top - self.frmToolbarSearch.height;
	
	self.frmFind.visible := false;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="78c79311-d1fa-4d59-9bd4-9e9828a6c1c9">
        <updating/>
        <source>doResize() updating;
// -----------------------------------------------------------------------------
// Created:		14 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	HorzGap = 5;
begin

	inheritMethod();


	self.grpTerminals.top := 0;
	self.grpTerminals.left := 0;
	self.grpTerminals.height := 80;
	
	self.tblTerminals.left := HorzGap;
	self.tblTerminals.width := self.tblTerminals.parent.width - HorzGap * 2;
	self.tblTerminals.top := HorzGap * 3;
	self.tblTerminals.height := self.tblTerminals.parent.height - HorzGap * 4;
	
	self.grpReports.top := self.grpTerminals.height + HorzGap;
	self.grpReports.left := 0;
	self.grpReports.height := self.grpReports.parent.height - (self.grpTerminals.height + HorzGap);
	
//	self.grpRight.top := 0;
//	self.grpRight.height := self.grpRight.parent.height;// - HorzGap;

	self.lbReportTree.left := self.lbReportTree.parent.left + HorzGap;

	self.lbReportTree.top := HorzGap * 3;
	if self.frmFind.visible then
		self.lbReportTree.top := self.lbReportTree.top + self.frmFind.height + 2;
		self.frmFind.width := self.frmFind.parent.width - 4;
		self.txtSearchReport.width := self.txtSearchReport.parent.width - self.txtSearchReport.left - 10;
	endif;
	self.lbReportTree.width :=  self.lbReportTree.parent.width - (HorzGap * 2);
	self.lbReportTree.height := self.lbReportTree.parent.height - (HorzGap * 2) - self.lbReportTree.top;//25 Nov 2015	NDL	Par 36846
	
//	self.lblRepName.width := grpRight.width - 20;
	
	self.tblParameter.top := self.lblRepName.top + self.lblRepName.height + 5;
	self.tblParameter.repositionAfterResize();
	self.setTblParameterHeight();
	self.lblRepName.width := self.tblParameter.width;		// 35958 report description width
	
	self.tblBGPReports.top := 45;
	self.tblBGPReports.repositionAfterResize();

	self.tblBGPEnt.top := 45;
	self.tblBGPReports.repositionAfterResize();	

// cnwdad1 12/04/2006 - The "Output Options" title was partly hidden.
//	self.tblPrintOptions.top := 3* HorzGap;
	self.tblPrintOptions.top := 3* HorzGap + 5;
	self.tblPrintOptions.left := HorzGap;
	
	self.tblPrintOptions.width := self.tblPrintOptions.parent.width - 15;
	self.tblPrintOptions.accessColumn(CM_EntryTable.ColumnValue).width := (self.tblPrintOptions.width - 100).Integer;
	
	self.multiGrpOutput.cnEcResizeContents();
	self.multiGrpEdit.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="doStopsListDisplay" id="9cf53485-37d6-429e-94b4-ccc979b6d398">
        <source>doStopsListDisplay(_table : CM_EntryTable io; _row :Integer; _attribName : String);
// ---------------------------------------------------------------------------
// Created:		07 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	str : String;
begin
	str := self.lstTblStop.getSelectedString(_attribName);
	
	_table.setValue(_row, str);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_attribName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTblBGPReportsSort" id="2fa46461-2e35-4709-9b5d-f1bc332802cd">
        <updating/>
        <source>
doTblBGPReportsSort() protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_DataTable;
begin
	tbl := self.tblBGPReports;
	self.sortColumn :=tbl.column;

	tbl.accessColumn(self.sortColumn).sortOrder := 1;
	tbl.accessColumn(tbl.column).sortAsc := self.sortAscending;
	
	
	tbl.accessedColumn.sortType := Table.SortType_Alpha;
	
	tbl.resort;
	self.sortAscending := (not self.sortAscending);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblStopsCloseUp" id="e2d3f0ea-f850-4d91-89bd-9a6b3a2b54c9">
        <source>doTblStopsCloseUp(_theTable : Table) ;
// ---------------------------------------------------------------------------
// Created:		06 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars

	aStopTable		:	CM_StopsTable;
	theObject		:	Object;
	theString		:	String;
	theNumSelected	:	Integer;
	
begin
	if _theTable.isKindOf(CMUI_ListTable) then
		theNumSelected :=  _theTable.CMUI_ListTable.allSelectedObjects.size;
		if theNumSelected = 0 then
//			theString := "None Selected";	// cnwrl1 11/11/2009 PAR 19951 - what it was
			theString := app.getString( NoneSelected );
		else
			if theNumSelected = 1 then
//				theString := "1 Item Selected";	// cnwrl1 11/11/2009 PAR 19951 - what it was
				theString := app.getString( One_Item_selected );
			else
//				theString := theNumSelected.String &amp; " Items Selected";	// cnwrl1 11/11/2009 PAR 19951 - what it was
				theString := app.getString( Items_Selected, theNumSelected.display );
			endif;
			foreach theObject in _theTable.CMUI_ListTable.allSelectedObjects do
				if theObject.isKindOf(CM_StopsTable) then
					aStopTable := theObject.CM_StopsTable;
					if aStopTable &lt;&gt; null then
//						theString := theString &amp; ", " &amp; aStopTable.code.trimBlanks;
						theString := theString &amp; CNEC_COMMA &amp; Space &amp; aStopTable.code.trimBlanks;
					endif;
				endif;

			endforeach;
		endif;
	else
//		theString := "None Selected";	// cnwrl1 11/11/2009 PAR 19951 - what it was
		theString := app.getString( NoneSelected );
	endif;
	
	self.tblParameter.setValueByControlName(_theTable.name,theString);
end;</source>
        <Parameter name="_theTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doTemplateDateComboGotFocus" id="66477b61-5e17-4f67-ae90-32572050e7f3">
        <source>doTemplateDateComboGotFocus(_combo : ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:     11 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	entRow			: EntTableRowTransient;
	theRow			: Integer;
	jCell			: JadeTableCell;
//	dateBoxName		: String;
begin
//	dateBoxName := self.myReportAgent.getTemplateDateAlternateCntrl(_combo.name);
	/*replaced by above cleverness
	if _combo = self.cmbOpenDate then
		dateBoxName := self.txtOpenDate.name;
	elseif _combo = self.cmbCloseDate then
		dateBoxName := self.txtCloseDate.name;
	elseif _combo = self.cmbMatchStart then
		dateBoxName := self.txtMatchStart.name;
	elseif _combo = self.cmbMatchEnd then
		dateBoxName := self.txtMatchEnd.name;
	elseif _combo = self.cmbBaseDate then
		dateBoxName := self.txtBaseDate.name;
	elseif _combo = self.cmbConnDate then
		dateBoxName := self.txtConnDate.name;
	elseif _combo = self.cmbOnDate then
		dateBoxName := self.txtOnDate.name;
	endif;
	*/
	entRow := self.tblParameter.getEntTableRowByControlName(_combo.name);
	theRow := self.tblParameter.getRowByName(entRow.name);
	jCell := self.tblParameter.accessCell(theRow, CM_EntryTable.ColumnValue);
	
	if self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_EDIT then
		if jCell.text &lt;&gt; null then
			_combo.text := jCell.text;
		endif;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTreeClick" id="ed1f1c9f-bb40-4d89-837c-8824583f07ad">
        <updating/>
        <source>doTreeClick() updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
04 Dec 2015	cnwkpd1	PAR #36903 - Invoice Report Template editing issue
	
*/

vars
	entTableDef		: EntTableDef;
	menuEntity		: CM_MenuEntity;
	tmpReportAgent	: CMUI_ReportAgentStd;
	enableSubTerminal : Boolean;
	terminal		: CM_Terminal;
begin
	app.mousePointer := Busy;
	
	tmpReportAgent := self.myReportAgent;
	tmpReportAgent.initQryReportForRunner(null);
	//tmpReportAgent.allCriteriaLineHolders.purge();
	//tmpReportAgent.myQryReport := null;
	self.myOperator := null;		//set when an operator is selected from cmbOperator
	self.myOperatorGroup := null;	//set when an operator group is selected from cmbOperatorGroup

	self.cmbProcess.text := self.PROCESS_FOREGROUND;
	self.tblPrintOptions.setValueByName(ETRow_ProcessOption, self.PROCESS_FOREGROUND);
	
	menuEntity := self.lbReportTree.listObject.CM_MenuEntity;
	self.myMenuEntity := menuEntity;
	
	if menuEntity = null or not app.isValidObject(menuEntity) then//par 16802
		self.myReportAgent.setState(tmpReportAgent.STATE_NULL);
		return;
	endif;
	
	//self.tblBGPReports.allSelectedObjects.clear;
	self.setNavigatorHeading(menuEntity.getHeading());
	
	if menuEntity.isKindOf(CM_MenuUserHdr) and
	   menuEntity.CM_MenuUserHdr.isBGPReportHeader then
		self.showBGPReportsOffHeader(menuEntity.CM_MenuUserHdr);
		
	elseif menuEntity.isKindOf(CM_MenuUserReport) then 
		//we have clicked on a template
		tmpReportAgent.initQryReportForRunner(menuEntity);
		// PAR #36903 - swapped order to ensure Terminals collection is set up before Company combo is loaded
		// cnwmc5 - 11 March 2016 - PAR 37496 - swapped back and moved terminals collection population to 'showTableForReport'
		self.showTableForReport(menuEntity, true);
		self.showTableForTemplate(menuEntity.CM_MenuUserReport);
		self.myReportAgent.setState(tmpReportAgent.STATE_TEMPLATE_VIEW);
		self.showTemplateUserMaint();
	
	elseif menuEntity.isKindOf(CM_MenuUserDtl) then
		// We have clicked on a report.
		tmpReportAgent.initQryReportForRunner(menuEntity);
		self.showTableForReport(menuEntity, true);
		
	elseif menuEntity.isKindOf(CM_MenuRootUserBackgroundReps) then	
		// We have clicked on current or saved folder.
		self.showBGPReportsOffRoot(menuEntity.CM_MenuRootUserBackgroundReps);
		if app.activeForm = self then
			self.tblBGPReports.setFocus();
		endif;
	else
		// Other stuff headings etc.
		self.myReportAgent.setState(tmpReportAgent.STATE_NULL);
	endif;

	//9/11/2009 cnwdz2 par21400  start
	enableSubTerminal := false;
	foreach terminal in self.myReportAgent.allTerminals do
		if app.isSubTerminalsOn(terminal) then
			enableSubTerminal := true;
			break;	
		endif;
	endforeach;
	if enableSubTerminal and
	   CM_QryReportUser.hasInstance(tmpReportAgent.myQryReport) then //PAR25589 cnwsh3 21/09/2010 - Check if the sub terminal is included in allvisible rows.
		if tmpReportAgent.myQryReport.CM_QryReportUser.allVisibleRows.includes(ETRow_MySubTerminal) then
			self.tblParameter.showRowByName(ETRow_MySubTerminal, false);
		else
			self.tblParameter.hideRowByName(ETRow_MySubTerminal, false);
		endif;
	endif;  //9/11/2009 cnwdz2 par21400  stop
	
	
	self.setPrintOptionsView();

	self.doResize();

epilog
	app.mousePointer := Idle;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="exHandlerReport" id="0b750e97-9a3a-47e5-a818-abf79f668d18">
        <updating/>
        <source>exHandlerReport(exObj : Exception) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     12 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	errStr		: String;
	error		: CM_Error;
	isJSSException	: Boolean;
	
begin
	
	abortTransaction;
	// Get specific information.
	app.writeLog('INFO &gt;&gt; Report Writer exception generated (' &amp; exObj.errorCode.String &amp; ')' , LogINFO);
	errStr := 'Background Error (' &amp; exObj.errorCode.String &amp; '). ';
   	
	isJSSException := app.isJSSException(exObj);

	if (not isJSSException) then
		if exObj.isFatalThinClientError then
			return Ex_Pass_Back; // Pass back processing.
		else
			return Ex_Resume_Next;
		endif;
	endif;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCSVFilePath" id="9e222682-d01a-44e6-8cc6-0f4fea19b5a4">
        <source>getCSVFilePath();
// ---------------------------------------------------------------------------
// Created:     04 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	fileCSV		 		: CMDFileSave;
	fileString			: String;

begin

	create fileCSV;
	if fileCSV.open = 0 then
		fileString := fileCSV.fileName;
	endif;

	//self.tblPrintOptions.setValueByName(ETRow_CsvFileName, fileString);
	if fileString &lt;&gt; '' then	// 11/05/2012 cnwar2 #18486
		self.tblPrintOptions.setValueByName(ETRow_CsvFileName, fileString);
	endif;
	
epilog
	delete fileCSV;	
end;</source>
    </JadeMethod>
    <JadeMethod name="getCellInputTypeForParamType" id="c770add0-f080-4613-8089-cec7feb9cefa">
        <source>getCellInputTypeForParamType(_qryParam : CM_QueryReportParam) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003	cnwth2
//
// Purpose:     Pass in a cell optionally if it needs to be initialized in some way (ie.max length etc.)
//				Returns inputType table constant for the query parameter's primative type
//				This logic is not 'up' on CM_QueryReportParam because PortSchema does not know
//				about the various extra input type constants in CM_EntryTable
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _qryParam = null then
		return null;
	endif;
	
	if _qryParam.type = Binary.number then
		return CM_EntryTable.InputType_Picture;

	elseif _qryParam.type = Boolean.number then
		return CM_EntryTable.InputType_CheckBox;
				
	elseif _qryParam.type = Decimal.number or
	   _qryParam.type = Integer.number then
		return CM_EntryTable.InputType_TextNumeric;
	
	else
		return CM_EntryTable.InputType_TextBox;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_qryParam" type="CM_QueryReportParam"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="f9f8d06a-aecd-491c-a9b6-be940a07534a">
        <source>getExtraPermissions(permArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     18 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(permArray);

	permArray.add(PmRptTemplateMaint);
	permArray.add(PmRptRunBGPrint);
	
end;</source>
        <Parameter name="permArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOutputType" id="aa498381-3afa-4740-bca7-d57c49bfbd12">
        <source>getOutputType() : Integer protected;

// cnwdvb1 24 April 2003 

vars
	destinationOption		: String;
begin
	destinationOption := self.tblPrintOptions.getValueByName(ETRow_DestinationOption).String;
	if destinationOption = self.DESTINATION_PRINT then
		return BGP_ReportRequest.Print;
	elseif destinationOption = self.DESTINATION_PRINTANDSAVE then
		return BGP_ReportRequest.SaveAndPrint;
    elseif destinationOption = self.DESTINATION_SFTP then   //MTN-36668
        return BGP_ReportRequest.FTP_SFTP;                      //MTN-36668
	endif;
	// Always save by default.
	return BGP_ReportRequest.Save;

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getParametersForReport" id="f639c218-ea0a-4649-b143-9c6e0a6d5662">
        <source>getParametersForReport(_qryReport : CM_QryReport) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003	cnwth2
//
// Purpose:     Creates transient qry param objects with values from tblParameter
// 30 Oct 2025 navah1 MTN-36162: NSWP | Handle Existing Date Parameters Stored and Ensure Legacy Report Support	 
// ----------   ----------  --------------------------------------------------
vars
	row,
	numRows				: Integer;
	tbl					: CM_EntryTable;
	obj					: Object;
	transQryParam,
	qryParam			: CM_QueryReportParam;
	entRowTransient		: EntTableRowTransient;
	paramValue			: Any; 
	cellObj				: JadeTableCell;
begin
	self.allQueryReportParams.purge();
	// cnwjre1 May 2014 from testing, skip all this if no parameters
	if _qryReport.allQueryReportParams.isEmpty() then
		return;
	endif;
	
	tbl := self.tblParameter;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		obj := tbl.accessRow(row).itemObject;
		if (not EntTableRowTransient.hasInstance(obj)) then
			continue;
		endif;
		entRowTransient := obj.EntTableRowTransient;
		
		qryParam := _qryReport.allQueryReportParams[entRowTransient.name];
		if qryParam = null then
			continue;
		endif;
		
		transQryParam := qryParam.cloneSelf(true);
		
		//30.10.2025 navah1 #36162 Start
		// paramValue := tbl.getValueByName(entRowTransient.name);
		if qryParam.type = Date.number then   
			cellObj :=	tbl.accessCell(row, tbl.ColumnValue);  
			paramValue := cellObj.text.trimBlanks(); 
		else
			paramValue := tbl.getValueByName(entRowTransient.name);
		endif;
		//30.10.2025 navah1 #36162 End
		
		transQryParam.setDefaultValue(paramValue);
		self.allQueryReportParams.tryAdd(transQryParam);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_qryReport" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e5c518ef-abaf-4a2c-90c0-740ee4d10949">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//----------------------------------------------------------------
//	Created:	24 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theXML : String;
begin

	theXML := inheritMethod();

	theXML := self.tblBGPReports.getXmlStrForColumns(true);
	theXML := theXML &amp; global.formatAsXML(XML_PrintPreview, self.tblPrintOptions.getValueByName(ETRow_PrintPreview).Integer.String);
//	theXML := theXML &amp; global.formatAsXML(XML_ShowFind, self.frmFind.visible.String);
	return theXML;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="0cfc76be-54fe-43aa-8b92-5b0cef689ead">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
//----------------------------------------------------------------
//	Created:	24 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	printPrev		: Boolean;
	value, theXML	: String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

	// #### Print Preview
 	value := theXML.cnEcGetTagValueOfName(XML_PrintPreview);

 	if value = "" then
 		printPrev := true;
 	else
 		printPrev := value.Integer.Boolean;
 	endif;

	//Set them
	self.tblPrintOptions.setValueByName(ETRow_PrintPreview, printPrev);
	
/*	value := theXML.cnEcGetTagValueOfName(XML_ShowFind);
	
	if value.Boolean then
		self.doReportSearch();
	endif; */
	//
	
	self.doReportSearch();	//27 Nov 2015	NDL	Par 36846

end;</source>
    </JadeMethod>
    <JadeMethod name="handleBGPDelete" id="21fe2809-2215-4a20-b6bd-2640f8e5fb3e">
        <source>handleBGPDelete(_userInfo : Any) protected;

vars
	numRows,
	row				: Integer;
	tbl				: CM_DataTable;
begin
	tbl := self.tblBGPReports;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		if tbl.accessRow(row).itemObject = _userInfo.Object then
			tbl.removeItem(row);
			return;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleBGPUpdate" id="7db9a327-be9f-4790-b5c0-6d4c12c85daf">
        <updating/>
        <source>handleBGPUpdate(_menuUserReport : CM_MenuUserReport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     13 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entDef				: EntTableDef;
	entRow				: EntTableRow;
	table				: CM_DataTable;
	lineColour,
	currentRow,
	numRows,
	row					: Integer;
	menuUserReport		: CM_MenuUserReport;
	str					: String;
	
begin

	if self.myReportAgent.state &lt;&gt; self.myReportAgent.STATE_BGR_RUN or _menuUserReport = null then
		return;
	endif;
	
	if _menuUserReport.isReportTemplate() then
		return;
	endif;
	
	entDef := app.myController.getEntTableDef(ETDef_BGPReportInfo);
	if entDef = null then 
		return;
	endif;
	//get the line to add/insert into the table
		//foreach entRow in entDef.allEntTableRows do
	foreach entRow in self.tblBGPReports.allTblDataEntRows do
		str := str &amp; _menuUserReport.getDisplayStringForAttribute(entRow.name, true) &amp; Tab;
	endforeach;
	
	lineColour := _menuUserReport.getLineColour;
	if lineColour = null then
		lineColour := self.tblBGPReports.backColor;
	endif;
	
	table := self.tblBGPReports;
	currentRow := table.row;
	numRows := table.rows;
	//first loop through and see if we already have this report listed in the table	
	foreach row in table.fixedRows + 1 to numRows do
		menuUserReport := table.accessRow(row).itemObject.CM_MenuUserReport;	
		if menuUserReport = _menuUserReport then //already listed - we've got an updated status so redisplay row
			table.removeItem(row);
			table.addItemAt(str, row);
			table.accessRow(row).itemObject := _menuUserReport;
			table.accessedRow.backColor := lineColour;
			return;
		endif;
	endforeach;
	
	//if we get here, it's a new BGP report so addLine
	table.accessRow(table.addItem(str)).itemObject := _menuUserReport;
epilog

	if table &lt;&gt; null then
		table.resort();
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_menuUserReport" type="CM_MenuUserReport"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="aebf3efe-4f21-40bf-a91e-00fb81061bb1">
        <updating/>
        <source>handleNotification(_eventType : Integer; 
					_object : Object; 
					_tag : Integer;
					_userInfo : Any) protected, updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2002		cnwth2	
//
// Purpose:     Normally re-displays the report menu, and re-selects what the user has selected
//				Except if BGP note.
//			 	
//			
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	listBox				: CMUI_NavigatorListBox2;
	idx,
	listCount			: Integer;
	menuEntity			: CM_MenuEntity;
	rep					: CM_QryReport;
	report				: CM_MenuUserReport;
	
begin
	menuEntity := self.myMenuEntity;
	listBox := self.lbReportTree;
	
	if (CM_MenuRootUserBackgroundReps.hasInstance(menuEntity)) or 
	   (CM_MenuUserHdr.hasInstance(menuEntity) and menuEntity.CM_MenuUserHdr.isBGPReportHeader) then
		if _eventType = CM_User.BGP_REPORT_DELETED then
			self.handleBGPDelete(_userInfo);
			return;	
		endif;
		if (global.isValidObject(_userInfo.Object)) and
		   (CM_MenuUserReport.hasInstance(_userInfo.Object)) then 
		   //global.isValidObject(_userInfo.Object) and 
			//only redisplay if we are actually viewing BGP reports!
			report := _userInfo.CM_MenuUserReport;
			self.handleBGPUpdate(report);
//			return;
		endif;
	endif;
	
	if (_eventType = EVENT_QRYREPORTUSER_CREATE or
	   _eventType = EVENT_QRYREPORTUSER_UPDATE or
	   _eventType = EVENT_QRYREPORTUSER_DELETE) then
	
		menuEntity := listBox.listObject.CM_MenuEntity;
		
		listBox.displayTree(true, null);
		//re-select the report selected - if no longer there permission must have changed, or deleted
		if global.isValidObject(menuEntity) then
			listCount := listBox.listCount;
			foreach idx in 1 to listCount do
				if listBox.itemObject[idx].CM_MenuEntity = menuEntity then
					listBox.listIndex := idx;
					listBox.click(listBox);
					return;
				endif;
			endforeach;
		else
//			app.msgBox('The report you currently have selected in the Report Runner has been deleted.' &amp; CrLf &amp;
//						'Your menu has been refreshed.', 'User report deleted...', MsgBox_Exclamation_Mark_Icon);
			app.msgBox(	app.getString( Report_Selected_HasBeenDeleted ),
						app.getString( User_Report_Deleted ),
						MsgBox_Exclamation_Mark_Icon );
			listBox.click(listBox);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_tag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handlePrintBackgroundOptions" id="ba60a521-7841-4193-8c12-e0b64d7faf56">
        <source>handlePrintBackgroundOptions();
// ---------------------------------------------------------------------------
// Created:     20 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not self.canPrintBackground) then
		self.tblPrintOptions.hideRowByName(ETRow_DestinationOption, false);
		self.tblPrintOptions.hideRowByName(ETRow_ChoosePrinter, false);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="bc2c3120-c8e1-4420-98ca-02bca7f08cb3">
        <updating/>
        <source>initForm() updating;
// -----------------------------------------------------------------------------
// Created:		13 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

begin

	if self.myReportAgent = null then
		create self.myReportAgent transient;
	endif;

	self.myReportAgent.init(self);
	
	self.sptMain.backColor := Grey;
	
	self.initTblBGPReports();
	self.initTblBGPEnt();
	self.initTblPrintOptions();
	self.loadReportOptionCombos(null,null);
	
	self.getXMLSettingsForSetup();
	
	//self.tblTerminals.backColor := 16771302;		// TFS 51086 navmd1 29/04/2021 JADE2020 Skin Fixes

//	self.txtStartTime.alignment := TextBox.Alignment_Left;
//	self.txtEndTime.alignment 	:= TextBox.Alignment_Left;
	self.picParamPic.automaticCellControl := true;

	self.armNotifications();
	self.loadReportTree();
	self.doTreeClick();

//	self.statusLine.caption := "Please select a report";	// cnwrl1 11/11/2009 PAR 19951 - what it was
	self.statusLine.caption := app.getString( Please_Select_A, app.getString( Report ) );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblBGPEnt" id="be38effa-1337-4df0-aa63-8bfbb2356670">
        <source>initTblBGPEnt();
// ---------------------------------------------------------------------------
// Created:     17 December 2002		cnwth2	
