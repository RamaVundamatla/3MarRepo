    <JadeMethod name="start" id="c0f5a67f-c2ba-4512-98f0-219fbf508aa5">
        <updating/>
        <source>start() updating;

/*

Purpose:			Start method for Interface Controllers

Parameters:			None

Return Value:		None


Date		Who		Reason
03 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
11 Jun 2010	cnwkpd1	PAR #24010 - Make the app a "background app" to prevent 1215 exceptions
					following a lock exception

*/

vars

begin
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);		// PAR #24010

	
epilog

end;</source>
    </JadeMethod>
