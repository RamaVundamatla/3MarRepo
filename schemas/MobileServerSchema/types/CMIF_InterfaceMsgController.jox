    <JadeMethod name="setupProxyInterfaceHistory" id="aba1459e-8b26-4143-b0be-40726f7bbab4">
        <source>setupProxyInterfaceHistory(
	_prxInterfaceHistory	: CM_InterfaceHistory io;
	_requestStr				: String;
	_responseStr			: String ) protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	
begin
	// attributes
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::formattedRequest.name, _requestStr );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::formattedResponse.name, _responseStr );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::functionName.name, self.functionName );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::rawRequest.name, self.inputRequest );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::rawResponse.name, self.outputResponse );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::requestTimeStamp.name, self.requestTimeStamp );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::responseTimeStamp.name, self.responseTimeStamp );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::responseStatus.name, self.errorIndicator );	// ie 0,1 or 2
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::userCode.name, self.userCode );
	
	// references
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::myMachine.name, self.myMachine );
	_prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::myTCPInterfaceDefinition.name, self.myInterfaceDefinition );
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_prxInterfaceHistory" type="CM_InterfaceHistory" usage="io"/>
        <Parameter name="_requestStr" type="String"/>
        <Parameter name="_responseStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateContainers" id="d354262d-f429-4b82-9b01-f4a430ede0ee">
        <source>validateContainers();
// validateContainers(_containerId,_twinContainerId : String);// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814 - what it was

/*

Purpose:			Validate that the input container(s) match the container(s) of the current tasks

Parameters:			Input container id(s)

Return Value:		None


Date		Who		Reason
22 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
11 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
14/05/2009	cnwrl1	PAR 19668 - CCMS 1814 - container ids are now part of the message class
*/

vars
	currentTiId		: String;
	task			: CM_RTQueueTask;

begin
//	if _containerId = null then					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if self.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
	task := self.getTask;
	if task &lt;&gt; null and task.ti &lt;&gt; null then
		currentTiId := task.ti.id;
	endif;
	
//	if currentTiId &lt;&gt; _containerId then			// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if currentTiId &lt;&gt; self.containerId then
//		app.raiseCMException3(ERR_RT_CONTAINER_MISMATCH, _containerId, self.functionName, currentTiId, null, null);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		app.raiseCMException3( ERR_RT_CONTAINER_MISMATCH, self.containerId, self.functionName, currentTiId, null, null );
	endif;
	
	// And validate twin container id against twin task
	currentTiId := null;
	task := self.getTwinTask;
	if task &lt;&gt; null and task.ti &lt;&gt; null then
		currentTiId := task.ti.id;
	endif;
	
//	if currentTiId &lt;&gt; _twinContainerId then		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if currentTiId &lt;&gt; self.containerId2 then
//		app.raiseCMException3(ERR_RT_CONTAINER_MISMATCH, _twinContainerId, self.functionName, currentTiId, null, null);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		app.raiseCMException3( ERR_RT_CONTAINER_MISMATCH, self.containerId2, self.functionName, currentTiId, null, null );
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMachine" id="4fc02dba-482b-4eca-ba2a-76c5b1388926">
        <updating/>
        <source>validateMachine() updating;

/*

Purpose:			Validate the Machine ID of the input request and do set up for machine.

Parameters:			None

Return Value:		Set up reference myMachine


Date		Who		Reason
24 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	machineId		: String;
	terminal		: CM_Terminal;
	rtDevice		: CM_RTDeviceVehicleMount;
	
begin
	// Terminal is set for the interface
	terminal := app.getMyTerminalDO_NOT_USE();

	// Machine Id is always the first parameter
	machineId := self.allInputFields[1];
	
	// Validate incoming machine Id
	self.myMachine := terminal.machines[machineId];
	if self.myMachine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND, machineId, terminal.code, null, null);
		return;
	endif;

	// Check machine is RT enabled
	rtDevice := self.myMachine.myRTDevice;
	if rtDevice = null then
		app.raiseCMException1(ERR_MACH_NO_RT, machineId, null, null);
		return;
	endif;
	
	// Check device id is numeric - required to use mediator framework
	if not rtDevice.id.isInteger then
		app.raiseCMException1(ERR_MACH_NON_NUM_RT, machineId, null, null);
		return;
	endif;

	// Set up twin lift capable flag
	self.machineIsTwinLift := self.myMachine.isTwinLift();		// PAR #18743
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMachineAndMediator" id="494ab4c3-8f1f-4c84-9825-98e713c5831e">
        <updating/>
        <source>validateMachineAndMediator() updating;

/*

Purpose:			Validate the machine and mediator.

Parameters:			None

Return Value:		Set up references myMachine and myMediator.
					Set user in passport from machine.


Date		Who		Reason
11 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
27 Nov 2008	conjk3	PAR #18478 - Supress errors when logging off if already logged off

*/

vars
	mediator		: CM_RTConnectMediator;
	terminal		: CM_Terminal;
	timeout			: Integer;
	
begin
	// Terminal is set for the interface
	terminal := app.getMyTerminalDO_NOT_USE();
	
	// Validate machine id first, and set up myMachine reference
	self.validateMachine();
	
	// Check machine is logged on
	// cnwjk3 PAR 18478 27/11/08
	//if self.myMachine.user = null or not self.myMachine.loggedOn then
	if self.functionName &lt;&gt; TCP_FUNCTION_LOGOFF then
		if self.myMachine.user = null or not self.myMachine.loggedOn then
			app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
			return;
		endif;
	endif;
	
	// Set user from machine
	app.myPassport.setMyUser(self.myMachine.user);
	self.setUserCode( app.getMyUserCode );			// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814
	
	// Validate and set mediator
	mediator := terminal.allActiveMediators[self.myMachine.myRTDevice.id.Integer];
	// cnwjk3 PAR 18478 27/11/08
	if self.functionName &lt;&gt; TCP_FUNCTION_LOGOFF then
		if mediator = null or not mediator.isKindOf(CM_RadioTelemetryMediator) then
			app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
			return;
		endif;
	endif;

	// cnwjk3 PAR 18478 27/11/08
	if mediator &lt;&gt; null then 
		self.myMediator := mediator.CM_RadioTelemetryMediator;
	endif;
	
	// Fault questions must be answer before operator uses machine
	// cnwjk3 PAR 18478 27/11/08
	if 	self.functionName &lt;&gt; TCP_FUNCTION_SENDFAULTRESPONSE
		and self.functionName &lt;&gt; TCP_FUNCTION_LOGON
		and self.functionName &lt;&gt; TCP_FUNCTION_LOGOFF then
		if self.myMediator.isFaultQuestionOutstanding then
			app.raiseCMException1(ERR_MACH_FAULTS_OUT, self.myMachine.id, null, null);
		endif;
	endif;
	
	// Check for session timeout
	if self.functionName &lt;&gt; TCP_FUNCTION_LOGOFF then
		timeout := self.myInterfaceDefinition.sessionTimeout;
		if timeout &lt;&gt; null then
			if self.myMediator.lastUpdateTs.addMinutes(timeout) &lt; app.actualTimeServer then
				app.raiseCMException(ERR_MS_SESSION_TIMEOUT, null, null);
				return;
			endif;	
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMachineIsTwinLift" id="7ac187d0-3fb2-4819-9169-d3faedf4ee04">
        <source>validateMachineIsTwinLift();

/*

Purpose:			Check that the machine for this message is a Twin Lift machine

Parameters:			None

Return Value:		None, exception raised if the machine is not a Twin Lift


Date		Who		Reason
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	machineId		: String;
	terminal		: CM_Terminal;
	rtDevice		: CM_RTDeviceVehicleMount;
	
begin
	if not self.machineIsTwinLift then
		app.raiseCMException1(ERR_MACH_NOT_TWIN, self.myMachine.id, null, null);
		return;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateNumberOfParameters" id="fa4303fc-37b8-4d7b-a0f5-5cf13b51186e">
        <source>validateNumberOfParameters(_expected : Integer);

/*

Purpose:			Validate the receiver allInputFields to check it has the expected
					number of parameters

Parameters:			Expected number of parameters

Return Value:		None, exception raised if the number is incorrect


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	numFields		: Integer;
	
begin
	numFields := self.allInputFields.size;
	
	if numFields &lt;&gt; _expected then
		app.raiseCMException2(ERR_TCP_INVALID_NUMPARAMS, numFields.asStringJMT, _expected.asStringJMT, null, null);
		return;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_expected" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateRequestFormat" id="a2768650-a0af-4456-9748-e572858bc775">
        <updating/>
        <source>validateRequestFormat() updating;

/*

Purpose:			Validate the format of the input request, and set up receiver
					function name and input fields from it

Parameters:			None

Return Value:		None


Date		Who		Reason
11 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

constants
	LeftParen		= "(";
	RightParen		= ")";
	
vars
	pos,
	len				: Integer;
	parameters		: String;
	
begin
	// Check input is non blank
	if self.inputRequest = null then
		app.raiseCMException(ERR_TCP_INVALID_FORMAT, null, null);
		return;
	endif;
	
	// Check last character is a ")"
	len := self.inputRequest.length();
	if self.inputRequest[len] &lt;&gt; RightParen then
		app.raiseCMException(ERR_TCP_INVALID_FORMAT, null, null);
		return;
	endif;
	
	// Get function name from start of message
	pos := 1;
	self.functionName := self.inputRequest.scanUntil(LeftParen, pos).trimBlanks().toLower();
	
	if pos = 0							// there is no LeftParen
	or self.functionName = null			// or there is no function
	then
		app.raiseCMException(ERR_TCP_INVALID_FORMAT, null, null);
		return;
	endif;
	
	// Get the parameter string from between the parentheses
	pos := pos + 1;
	parameters := self.inputRequest[pos:len - pos];
	
	// And parse them into the inputFields array
	self.allInputFields.clear();
	parameters.csvToStringArray(self.allInputFields, ",");		// cnwdad1 25/11/2009  PAR #21720 Added delimiter parameter.
end;</source>
    </JadeMethod>
    <JadeMethod name="validateTasks" id="7874a33d-6327-4291-9c6d-f7cb9e9cfafb">
        <source>validateTasks(_expectedTaskType : Integer);

/*

Purpose:			Validate the state(s) of the current task(s)

Parameters:			Expected type of current task(s)

Return Value:		None, exception raised if there are any issues


Date		Who		Reason
22 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
03 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	task,
	twinTask		: CM_RTQueueTask;
	tasks			: CM_RTQueueTaskArray;
	
begin
	create tasks transient;
	tasks.add(self.getTask());
	
	// Need to perform the same validation on both tasks, if there is a twin task
	twinTask := self.getTwinTask();
	if twinTask &lt;&gt; null then
		tasks.add(twinTask);
	endif;
	
	foreach task in tasks do
	
		if task = null then
			if _expectedTaskType &lt;&gt; TASK_UNKNOWN then
				app.raiseCMException1(ERR_RT_PHASE_STARTUP, self.functionName , null, null);
			endif;
		elseif task.machine &lt;&gt; self.myMachine then
			if _expectedTaskType &lt;&gt; TASK_UNKNOWN then
				app.raiseCMException(TaskAllocated, null, null);
			endif;
		elseif task.taskType &lt;&gt; _expectedTaskType then
			if task.status = TASK_OFFERED or task.status = TASK_ACCEPTED or task.status = TASK_WORKING then
				if task.taskType = TASK_DIRECTOR then
					app.raiseCMException1(ERR_RT_PHASE_DIRECTEDMOVE, self.functionName , null, null);
				elseif task.taskType = TASK_PICKUP then
					app.raiseCMException1(ERR_RT_PHASE_QUEUEDMOVE, self.functionName , null, null);
				elseif task.taskType = TASK_SETDOWN then
					app.raiseCMException1(ERR_RT_PHASE_SETDOWN, self.functionName , null, null);
				endif;
			else
				if _expectedTaskType &lt;&gt; TASK_UNKNOWN then
					app.raiseCMException1(ERR_RT_PHASE_STARTUP, self.functionName , null, null);
				endif;
			endif;
		endif;

	endforeach;
	
	
epilog
	delete tasks;
	
end;</source>
        <Parameter name="_expectedTaskType" type="Integer"/>
    </JadeMethod>
</Class>
