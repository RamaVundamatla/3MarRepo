    <JadeMethod name="getTSForNextScheduledRun" id="bab5ad99-8e68-44e0-aa10-01d35b7bac90">
        <source>getTSForNextScheduledRun(_currentTimeStamp : TimeStamp; _runDayOfWeekArray, _runTimesArray : StringArray) : TimeStamp;

/*

Purpose:		Get the next scheduled run date and time	

Date			Who		Reason
01 April 2011	cnwmh5	Initial creation

*/
constants
	
	DEFAULT_TIME = "05:00:00".Time;
	
vars

	dayOfWeekIndex	: Integer;
	currentTS		: TimeStamp;
	runTime			: String;

begin

	currentTS := _currentTimeStamp;

	// get the date for the next day of the week
	dayOfWeekIndex := self.getNextRunDate(currentTS, _runDayOfWeekArray, _runTimesArray);
	
	// get the time to run
	if _runTimesArray.isEmpty() then
		currentTS.setTime(DEFAULT_TIME);
	else
		if dayOfWeekIndex &gt; _runTimesArray.size then
			runTime := _runTimesArray[1];
		else
			runTime := _runTimesArray[dayOfWeekIndex];
		endif;
		if runTime = null or not runTime.Time.isValid() then
			currentTS.setTime(DEFAULT_TIME);
		else
			currentTS.setTime(runTime.Time);
		endif;
		if _currentTimeStamp.date = currentTS.date and _currentTimeStamp.time &gt; currentTS.time then
			currentTS := currentTS.addDays(1);
			self.getNextRunDate(currentTS, _runDayOfWeekArray, _runTimesArray);
		endif;
	endif;
	
	return currentTS;	

epilog

end;</source>
        <Parameter name="_currentTimeStamp" type="TimeStamp"/>
        <Parameter name="_runDayOfWeekArray" type="StringArray"/>
        <Parameter name="_runTimesArray" type="StringArray"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getThinClientCommandLine" id="3c7016cc-240f-41aa-811e-5f17cececf57">
        <source>getThinClientCommandLine(): String;
constants
	UserDelimiter	: String	= 'endJade';
	
vars
	commandLine,
	userData	: String;
	userStart,
	pos			: Integer;

begin
	commandLine := process.getCommandLine();	
    pos := 1;
    pos := commandLine.pos(UserDelimiter, pos);
	if pos = 0 then												// Allow for managed environments where endJade is all lower case
		pos := 1;
		pos := commandLine.pos(UserDelimiter.toLower, pos);
	endif;
    if pos &gt; 0 then
    	userStart	:= pos + UserDelimiter.length + 1;
    	if commandLine.length &gt;= userStart then
	    	userData := commandLine[userStart : end];
	    endif;
	endif;
	return userData;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
