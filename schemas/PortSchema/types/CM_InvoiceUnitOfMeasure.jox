    <JadeMethod name="validateForDelete" id="6514b4fb-5c5c-434c-9c6f-01c8d03bb305">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 December 2022	navvt20	TFS CR 55621 Task 55693: Jade - UOM TRX

*/

vars

begin
	if self.allInvoiceContractDetails.isNotEmpty then
        app.raiseCMException1(Invoice_uom_already_exists,self.code,null,null);
    endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2a49cf86-6ce5-4ad2-90e1-3717c87f8eaa">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 December 2022	navvt20	TFS CR 55621 Task 55693: Jade - UOM TRX

*/

vars
	existingInvoiceUnitOfMeasure,
	realInvoiceUnitOfMeasure      : CM_InvoiceUnitOfMeasure;
begin
	if self.code = null then
        app.raiseCMException(Input_required_field_code, ETRow_Code, self);
    endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description ,self);
	endif;
	
	if self.myRoot = null then
        app.raiseCMException(Input_required_field_root, null, null); 
    endif;

	existingInvoiceUnitOfMeasure	:= self.myRoot.allInvoiceUnitOfMeasure[self.code];
	realInvoiceUnitOfMeasure		:= self.pxyGetRealObject();
	
	if existingInvoiceUnitOfMeasure &lt;&gt; null and
	   (realInvoiceUnitOfMeasure = null or //in which case we are trying add a new one that is duplicate
	   existingInvoiceUnitOfMeasure &lt;&gt; realInvoiceUnitOfMeasure) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(Invoice_uom_already_exists, self.code, null, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
