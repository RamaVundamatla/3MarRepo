    <JadeMethod name="jtdAddEpilogProfile" id="06c4a434-73ba-465e-97ee-f58098a85c2f">
        <source>jtdAddEpilogProfile(mp : JtdMethodProfile; pos : Integer);

begin
	if mp &lt;&gt; null then
		if pos &gt; 0 and pos &lt;= self.jtdAllEpilogProfiles.size then
			self.jtdAllEpilogProfiles.insert(pos, mp);
		else
			self.jtdAllEpilogProfiles.add(mp);
		endif;
	endif;
end;</source>
        <Parameter name="mp" type="JtdMethodProfile"/>
        <Parameter name="pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdAddMethodProfile" id="2f129fa7-9fed-4bfe-b402-3d2e477ef73c">
        <source>jtdAddMethodProfile(mp : JtdMethodProfile; pos : Integer);

begin
	if mp &lt;&gt; null then
		if pos &gt; 0 and pos &lt;= self.jtdAllMethodProfiles.size then
			self.jtdAllMethodProfiles.insert(pos, mp);
		else
			self.jtdAllMethodProfiles.add(mp);
		endif;
	endif;
end;</source>
        <Parameter name="mp" type="JtdMethodProfile"/>
        <Parameter name="pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdAddPrologProfile" id="8d941ab6-b55a-4eb2-ba0f-c36550e27753">
        <source>jtdAddPrologProfile(mp : JtdMethodProfile; pos : Integer);

begin
	if mp &lt;&gt; null then
		if pos &gt; 0 and pos &lt;= self.jtdAllPrologProfiles.size then
			self.jtdAllPrologProfiles.insert(pos, mp);
		else
			self.jtdAllPrologProfiles.add(mp);
		endif;
	endif;
end;</source>
        <Parameter name="mp" type="JtdMethodProfile"/>
        <Parameter name="pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdAsString" id="43cdfb45-e4bb-479f-a53e-dde995745997">
        <source>jtdAsString() : String;

vars
	s, sMain, sProlog, sEpilog : String;
	mp : JtdMethodProfile;
	
begin
	sProlog := null;
	sMain := null;
	sEpilog := null;

	foreach mp in self.jtdAllPrologProfiles do
		sProlog := sProlog &amp; Tab &amp; Tab &amp; self.JtdTagMethod &amp; ' ' &amp; mp.jtdAsString &amp; CrLf;
	endforeach;
		
	foreach mp in self.jtdAllMethodProfiles do
		sMain := sMain &amp; Tab &amp; self.JtdTagMethod &amp; ' ' &amp; mp.jtdAsString &amp; CrLf;
	endforeach;
	
	foreach mp in self.jtdAllEpilogProfiles do
		sEpilog := sEpilog &amp; Tab &amp; Tab &amp; self.JtdTagMethod &amp; ' ' &amp; mp.jtdAsString &amp; CrLf;
	endforeach;

	if sProlog &lt;&gt; null then
		sProlog := Tab &amp; self.JtdTagBeginProlog &amp; CrLf &amp; sProlog &amp; Tab &amp; self.JtdTagEndProlog &amp; CrLf;
	endif;
	
	if sEpilog &lt;&gt; null then
		sEpilog := Tab &amp; self.JtdTagBeginEpilog &amp; CrLf &amp; sEpilog &amp; Tab &amp; self.JtdTagEndEpilog &amp; CrLf;
	endif;

	s := self.JtdTagBeginProfile &amp; ' ' &amp; self.jtdName &amp; CrLf &amp; Tab &amp;
		self.JtdTagRandomSelection &amp; ' ' &amp; self.jtdRandomSelection.String &amp; CrLf &amp;
		Tab &amp; self.JtdTagDefaultThinkSecs &amp; ' ' &amp; self.jtdDefaultThinkSecs.String &amp;
		CrLf &amp; Tab &amp; self.JtdTagStopWhenAllRun &amp; ' ' &amp; self.jtdStopWhenAllRun.String &amp;
		CrLf &amp; sProlog &amp; sEpilog &amp; sMain &amp; self.JtdTagEndProfile;
	
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdDelMthProfilesWithNoMthDesc" id="13e7b2e9-c517-4d9b-a662-8c7268fa25e2">
        <source>jtdDelMthProfilesWithNoMthDesc();

vars
	mp : JtdMethodProfile;
	oa : ObjectArray;
	
begin
	create oa transient;
	
	foreach mp in self.jtdAllPrologProfiles do
		if mp.jtdMyTrxGenMethodDesc = null then
			oa.add(mp);
		endif;
	endforeach;

	foreach mp in self.jtdAllMethodProfiles do
		if mp.jtdMyTrxGenMethodDesc = null then
			oa.add(mp);
		endif;
	endforeach;

	foreach mp in self.jtdAllEpilogProfiles do
		if mp.jtdMyTrxGenMethodDesc = null then
			oa.add(mp);
		endif;
	endforeach;

	// delete method profiles via a temporary array as arrays cannot
	// be updated during iteration (deleting mp in above foreach
	// loop would cause an automatic update to jtdAllMethodProfiles,
	// jtdAllPrologProfiles and/or jtdAllEpilogProfiles via automatic
	// inverse maintenance)
	oa.purge;

epilog
	delete oa;		
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdDeleteUnresolvedMthProfiles" id="51b6a813-2ca4-432f-9568-d8baf9bf4df7">
        <source>jtdDeleteUnresolvedMthProfiles(prologMethods, mainMethods, epilogMethods : Boolean);

vars
	mp : JtdMethodProfile;
	oa : ObjectArray;
	
begin
	create oa transient;

	if prologMethods then	
		foreach mp in self.jtdAllPrologProfiles do
			if not mp.jtdClassAndMethodExist then
				oa.add(mp);
			endif;
		endforeach;
	endif;

	if mainMethods then	
		foreach mp in self.jtdAllMethodProfiles do
			if not mp.jtdClassAndMethodExist then
				oa.add(mp);
			endif;
		endforeach;
	endif;

	if epilogMethods then	
		foreach mp in self.jtdAllEpilogProfiles do
			if not mp.jtdClassAndMethodExist then
				oa.add(mp);
			endif;
		endforeach;
	endif;

	// delete method profiles via a temporary array as arrays cannot
	// be updated during iteration (deleting mp in above foreach
	// loop would cause an automatic update to jtdAllMethodProfiles,
	// jtdAllPrologProfiles and/or jtdAllEpilogProfiles via automatic
	// inverse maintenance)
	oa.purge;

epilog
	delete oa;		
end;</source>
        <Parameter name="prologMethods" type="Boolean"/>
        <Parameter name="mainMethods" type="Boolean"/>
        <Parameter name="epilogMethods" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdGetTotalMethods" id="63227cb6-d8b8-4e3c-865c-6fdc46ae5dae">
        <source>jtdGetTotalMethods() : Integer;

begin
	return self.jtdAllPrologProfiles.size +
		   self.jtdAllMethodProfiles.size +
		   self.jtdAllEpilogProfiles.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdHasEpilog" id="86b3e839-1052-465d-87c9-235d637e26b2">
        <source>jtdHasEpilog() : Boolean;

begin
	return self.jtdAllEpilogProfiles.size &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdHasMain" id="e126aeda-68ed-40e7-95d2-977d36fc3274">
        <source>jtdHasMain() : Boolean;

begin
	return self.jtdAllMethodProfiles.size &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdHasProlog" id="858a4534-6be4-425e-8dd3-763a62bf6422">
        <source>jtdHasProlog() : Boolean;

begin
	return self.jtdAllPrologProfiles.size &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdInitialize" id="680c609b-1e83-4dab-a3ea-731fc56e7918">
        <updating/>
        <source>jtdInitialize() updating;

begin
	self.jtdName := null;
	self.jtdAllPrologProfiles.purge;
	self.jtdAllMethodProfiles.purge;
	self.jtdAllEpilogProfiles.purge;
	self.jtdRandomSelection := false;
	self.jtdDefaultThinkSecs := 0;
	self.jtdStopWhenAllRun := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdLoadMthProfilesFromString" id="ce989ca9-96d3-40a7-b184-309ba8bf04d9">
        <source>jtdLoadMthProfilesFromString(valueString : String; initialStartPos, endPos : Integer;
	includeMthsWithZeroCalls, loadProlog, loadMain, loadEpilog : Boolean) protected;

vars
	n, len, startPos, crlfPos : Integer;
	mp : JtdMethodProfile;
	s : String;
	
begin
	if (not loadProlog) and (not loadMain) and (not loadEpilog) then
		// nothing to do!
		return;
	endif;
	
	len := valueString.length;
	
	if len &lt; 1 then
		return;
	endif;

	// work through a local variable so initialStartPos can remain constant
	startPos := initialStartPos;
		
	if startPos &lt; 1 or startPos &gt; len or (endPos &gt; 0 and endPos &lt; startPos) then
		return;
	endif;
	
	while true do
		n := valueString.pos(self.JtdTagMethod, startPos);

		// We only check for the end tag being beyond the end position. If the
		// end tag is within the end position, but some of the profile text goes
		// beyond the end position, we still process that profile entry.
		if n &lt; startPos or (endPos &gt; 0 and n &gt;= endPos) then
			break;
		endif;
		
		n := n + self.JtdTagMethod.length;

		if n &gt;= len then
			break;
		endif;
				
		crlfPos := valueString.pos(CrLf, n);
		
		if crlfPos &lt;= n then
			break;
		endif;
		
		startPos := crlfPos;

		s := valueString[n : crlfPos - n];
		
		if loadProlog then		
			create mp transient;
			mp.jtdSetFromString(s);
		
			if mp.jtdNumCalls &gt; 0 or includeMthsWithZeroCalls then
				self.jtdAllPrologProfiles.add(mp);
			else
				delete mp;
			endif;
		endif;

		if loadMain then
			create mp transient;
			mp.jtdSetFromString(s);
		
			if mp.jtdNumCalls &gt; 0 or includeMthsWithZeroCalls then
				self.jtdAllMethodProfiles.add(mp);
			else
				delete mp;
			endif;
		endif;

		if loadEpilog then
			create mp transient;
			mp.jtdSetFromString(s);
		
			if mp.jtdNumCalls &gt; 0 or includeMthsWithZeroCalls then
				self.jtdAllEpilogProfiles.add(mp);
			else
				delete mp;
			endif;
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="valueString" type="String"/>
        <Parameter name="initialStartPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <Parameter name="includeMthsWithZeroCalls" type="Boolean"/>
        <Parameter name="loadProlog" type="Boolean"/>
        <Parameter name="loadMain" type="Boolean"/>
        <Parameter name="loadEpilog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdRemoveEpilogProfile" id="180281b9-8cdf-4c64-80c9-9f226dfba9f1">
        <source>jtdRemoveEpilogProfile(mp : JtdMethodProfile);

begin
	if mp &lt;&gt; null then
		self.jtdAllEpilogProfiles.remove(mp);
	endif;
end;</source>
        <Parameter name="mp" type="JtdMethodProfile"/>
    </JadeMethod>
    <JadeMethod name="jtdRemoveMethodProfile" id="654b1099-af53-426f-92cf-6ea5b2d305d4">
        <source>jtdRemoveMethodProfile(mp : JtdMethodProfile);

begin
	if mp &lt;&gt; null then
		self.jtdAllMethodProfiles.remove(mp);
	endif;
end;</source>
        <Parameter name="mp" type="JtdMethodProfile"/>
    </JadeMethod>
    <JadeMethod name="jtdRemovePrologProfile" id="d8f1f030-549c-4cd3-8538-b3d0c24aca64">
        <source>jtdRemovePrologProfile(mp : JtdMethodProfile);

begin
	if mp &lt;&gt; null then
		self.jtdAllPrologProfiles.remove(mp);
	endif;
end;</source>
        <Parameter name="mp" type="JtdMethodProfile"/>
    </JadeMethod>
    <JadeMethod name="jtdSetDefaultThinkSecs" id="5c801b6e-1f70-4f1b-a0cd-acfba97da69b">
        <updating/>
        <source>jtdSetDefaultThinkSecs(secs : Integer) updating;

begin
	if secs &lt; 1 then
		self.jtdDefaultThinkSecs := 0;
	elseif secs &gt; JtdMaxThinkSeconds then
		self.jtdDefaultThinkSecs := JtdMaxThinkSeconds;
	else
		self.jtdDefaultThinkSecs := secs;
	endif;
end;</source>
        <Parameter name="secs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSetFromString" id="aa0412c3-0f44-4a43-bbec-189cbfe93eec">
        <updating/>
        <source>jtdSetFromString(valueString : String; includeMethodsWithZeroCalls : Boolean) updating;

vars
	n, len, endPos, endPrologPos, endEpilogPos, crlfPos : Integer;
	
begin
	self.jtdInitialize;

	len := valueString.length;

	if len &lt; 1 then
		return;
	endif;

	// look for profile begin
		
	n := valueString.pos(self.JtdTagBeginProfile, 1);
	
	if n &lt; 1 then
		return;
	endif;
	
	n := n + self.JtdTagBeginProfile.length;
	
	if n &gt;= len then
		return;
	endif;

	crlfPos := valueString.pos(CrLf, n);
	
	if crlfPos &lt;= n then
		return;
	endif;
	
	self.jtdName := valueString[n : crlfPos - n].trimBlanks;

	endPos := valueString.pos(self.JtdTagEndProfile, crlfPos);

	// look for random selection setting
			
	n := valueString.pos(self.JtdTagRandomSelection, crlfPos);
	
	if n &gt; crlfPos and (endPos &lt; 1 or n &lt; endPos) then
		n := n + self.JtdTagRandomSelection.length;
	
		if n &gt;= len then
			return;
		endif;

		crlfPos := valueString.pos(CrLf, n);
	
		if crlfPos &lt;= n then
			return;
		endif;
	
		self.jtdRandomSelection := valueString[n : crlfPos - n].trimBlanks.Boolean;
	endif;

	// look for default think seconds
	
	n := valueString.pos(self.JtdTagDefaultThinkSecs, crlfPos);
	
	if n &gt; crlfPos and (endPos &lt; 1 or n &lt; endPos) then
		n := n + self.JtdTagDefaultThinkSecs.length;
	
		if n &gt;= len then
			return;
		endif;

		crlfPos := valueString.pos(CrLf, n);
	
		if crlfPos &lt;= n then
			return;
		endif;
	
		self.jtdSetDefaultThinkSecs(valueString[n : crlfPos - n].trimBlanks.Integer);
	endif;

	// look for stop when all entries run setting
	
	n := valueString.pos(self.JtdTagStopWhenAllRun, crlfPos);
	
	if n &gt; crlfPos and (endPos &lt; 1 or n &lt; endPos) then
		n := n + self.JtdTagStopWhenAllRun.length;
	
		if n &gt;= len then
			return;
		endif;

		crlfPos := valueString.pos(CrLf, n);
	
		if crlfPos &lt;= n then
			return;
		endif;
	
		self.jtdStopWhenAllRun := valueString[n : crlfPos - n].trimBlanks.Boolean;
	endif;

	// look for prolog methods
	
	n := valueString.pos(self.JtdTagBeginProlog, crlfPos);
	
	if n &gt; crlfPos and (endPos &lt; 1 or n &lt; endPos) then
		n := n + self.JtdTagBeginProlog.length;
	
		if n &gt;= len then
			return;
		endif;

		crlfPos := valueString.pos(CrLf, n);
	
		if crlfPos &lt; n then // not &lt;= because nothing follows this tag, so = is ok
			return;
		endif;

		endPrologPos := valueString.pos(self.JtdTagEndProlog, crlfPos);
		
		if endPrologPos &gt; crlfPos then
			// load prolog profile entries
			self.jtdLoadMthProfilesFromString(valueString, crlfPos, endPrologPos,
				includeMethodsWithZeroCalls, true, false, false);

			crlfPos := valueString.pos(CrLf, endPrologPos);
	
			if crlfPos &lt;= endPrologPos then
				return;
			endif;
		endif;
	endif;

	// look for epilog methods
	
	n := valueString.pos(self.JtdTagBeginEpilog, crlfPos);
	
	if n &gt; crlfPos and (endPos &lt; 1 or n &lt; endPos) then
		n := n + self.JtdTagBeginEpilog.length;
	
		if n &gt;= len then
			return;
		endif;

		crlfPos := valueString.pos(CrLf, n);
	
		if crlfPos &lt; n then // not &lt;= because nothing follows this tag, so = is ok
			return;
		endif;

		endEpilogPos := valueString.pos(self.JtdTagEndEpilog, crlfPos);
		
		if endEpilogPos &gt; crlfPos then
			// load epilog profile entries
			self.jtdLoadMthProfilesFromString(valueString, crlfPos, endEpilogPos,
				includeMethodsWithZeroCalls, false, false, true);

			crlfPos := valueString.pos(CrLf, endEpilogPos);
	
			if crlfPos &lt;= endEpilogPos then
				return;
			endif;
		endif;
	endif;

	// load method profile entries
	
	self.jtdLoadMthProfilesFromString(valueString, crlfPos, endPos,
		includeMethodsWithZeroCalls, false, true, false);
end;</source>
        <Parameter name="valueString" type="String"/>
        <Parameter name="includeMethodsWithZeroCalls" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdSetName" id="791f1cf2-26db-4607-8a00-205201c18d61">
        <updating/>
        <source>jtdSetName(s : String) updating;

begin
	if self.jtdName &lt;&gt; s then
		self.jtdName := s;
	endif;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetRandomSelection" id="6af9477e-d8e7-4bd4-b9d6-29bfe6ee3b9b">
