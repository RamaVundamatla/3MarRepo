    <JadeMethod name="addDamageWithDate" id="5eb07fad-660b-41bd-9244-a04a3c1ce69e">
        <source>addDamageWithDate(_ti :CM_TrackedItem; _code :String; _pos :String; _severity :CM_DamageSeverity; _qty :Integer; _remarks :String; _damageDate : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2023	navra1	Initial creation for TFS - 55859

*/

vars
	pxyTI		:CM_TrackedItem;
	pxyDamage	:CM_DamageInstance;
	code		:CM_DamageDefinitionCode;
	pos			:CM_DamagePosition;
	party 		:CM_DamageParty;
	reason 		:CM_DamageReason;
	place		:CM_DamagePlace;
	terminal	:CM_Terminal;
	severity	:CM_DamageSeverity;	//11.07.2022 navak20 TFS 53862
	damStatus : Integer;
begin
	damStatus := DamageStatusDamaged; // ### TFS 55314 07NOV2022 NAVAB1
	if self.opts.includesKey("DamageStatus") then	 // ### TFS 55314 07NOV2022 NAVAB1
		damStatus := self.opts.int( "DamageStatus" ); // ### TFS 55314 07NOV2022 NAVAB1
	endif;

	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	self.assertNotNullMsg(pxyTI, "Error creating TI Proxy");
	
	code 	:= app.myRoot.allDamageDefinitionCodes[_code];
	self.assertNotNullMsg (code, ' invalid damage code');
	
	pos		:= app.myRoot.allDamagePositionsByCode [_pos];
	self.assertNotNullMsg (pos, ' invalid damage position');
	
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		party := terminal.allDamageParties.first;
		reason := terminal.allDamageReasons.first;		
		place := terminal.allDamagePlaces.first;
		severity := _severity;	//11.07.2022 navak20 TFS 53862
		if severity = null then	//11.07.2022 navak20 TFS 53862
			severity := terminal.allDamageSeverities.first;	//11.07.2022 navak20 TFS 53862
		endif;	//11.07.2022 navak20 TFS 53862
	endif;
	
	create pxyDamage transient;
	pxyDamage.setProxy (pxyTI, null, code, pos, _remarks, true, _qty, severity, null,
							place, party, reason, null, null, _damageDate , damStatus, null, null	//July 1, 2022 navak20 TFS 53862   // ### TFS 55314 07NOV2022 NAVAB1 added damStatus
							);
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, _remarks, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyDamage;
	delete pxyTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_pos" type="String"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_damageDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="addDamageWithRepair" id="813156e5-4111-49b8-beb8-916b9b9f1cfc">
        <source>addDamageWithRepair(_ti :CM_TrackedItem; _code :String; _pos :String; _severity :CM_DamageSeverity; _qty :Integer; _remarks :String; _damageDateTime : TimeStamp; _repairReason:CM_RepairReason; _repairRemarks:String; _repairedDateTime : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2023	navra1	Initial creation for TFS - 55859

*/

vars
	pxyTI		:CM_TrackedItem;
	pxyDamage	:CM_DamageInstance;
	code		:CM_DamageDefinitionCode;
	pos			:CM_DamagePosition;
	party 		:CM_DamageParty;
	reason 		:CM_DamageReason;
	place		:CM_DamagePlace;
	terminal	:CM_Terminal;
	severity	:CM_DamageSeverity;	
	damStatus : Integer;
begin
	damStatus := DamageStatusRepaired;
	if self.opts.includesKey("DamageStatus") then	 
		damStatus := self.opts.int( "DamageStatus" );
	endif;

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy;
	endLoad;
	
	code 	:= app.myRoot.allDamageDefinitionCodes[_code];
	self.assertNotNullMsg (code, ' invalid damage code');
	
	pos		:= app.myRoot.allDamagePositionsByCode [_pos];
	self.assertNotNullMsg (pos, ' invalid damage position');
	
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		party := terminal.allDamageParties.first;
		reason := terminal.allDamageReasons.first;
		place := terminal.allDamagePlaces.first;
		severity := _severity;	
		if severity = null then	
			severity := terminal.allDamageSeverities.first;	
		endif;	
	endif;
	
	create pxyDamage transient;
	pxyDamage.setProxy (pxyTI, null, code, pos, _remarks, true, _qty, severity, null,
							place, party, reason, _repairReason , null, _damageDateTime, damStatus, _repairRemarks, _repairedDateTime);
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, _remarks, TI_UPDMODE_NORMAL, null, app.myPassport);

	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	endLoad;	
	delete pxyTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_pos" type="String"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_damageDateTime" type="TimeStamp"/>
        <Parameter name="_repairReason" type="CM_RepairReason"/>
