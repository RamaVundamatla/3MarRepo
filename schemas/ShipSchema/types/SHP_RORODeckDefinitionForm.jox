    <JadeMethod name="doChangeDeck" id="3cd7f56a-7987-4a68-8d4a-5dadf0968e6f">
        <updating/>
        <source>doChangeDeck(_deck : CM_Deck) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	pxyDeckLayer : CM_DeckLayerLayout;
	pxyDeckItemLayout	: CM_DeckItemLayout;
	invaldDeck : Boolean;
	deckEdition : Integer;
begin
		
	if  self.myCurrentDeck = _deck then
		return;
	endif;
	
	on Exception do  app.handleDeletedObject(exception,self.myCurrentDeck,invaldDeck);
	
	if self.myCurrentDeck &lt;&gt; null then
		deckEdition:=self.myCurrentDeck.edition;
	endif;
	//if the current deck is for a differnt vessel  that the current vessel all the notes 
	// will of been ended already and not started
	// ending them again results in an exception that is not passed back to user method just returns
	if invaldDeck or (self.myCurrentDeck &lt;&gt; null  and self.myCurrentDeck.getROROStructure = self.getROROStructure )then
		
		self.endDeckItemNotes();
		self.endDeckNotes();
		
		if self.myCurrentProxyDeck &lt;&gt; null then
			foreach pxyDeckLayer in self.myCurrentProxyDeck.myDeckLayout.allDeckLayerLayouts discreteLock do
				self.endLayerNotes(pxyDeckLayer);
				foreach pxyDeckItemLayout in pxyDeckLayer.allDeckItemLayouts discreteLock do
					self.endLayerItemNotes(pxyDeckItemLayout);
				endforeach;
			endforeach;
		endif;
	endif;

	self.myCurrentDeck:=_deck;
	
	self.loadDeckDetails();
	
	if self.myCurrentDeck = null then
		return;
	endif;
	self.drawDeckLayouts(CMUI_PointDrawingFrame.Mode_DisplayOnly, true); // PAR 27821 pass in mode PAR 28058
	
	self.startDeckItemNotes();
	
	self.startDeckNotes();
	
epilog
	self.setCaption(null);
end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="doChangeMode" id="825b5ed2-4ab1-44fb-902d-ae8bc1c1d591">
        <updating/>
        <source>doChangeMode(	_mode : Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	parentDeck : CM_Deck;
	tpSheet : CMUI_Sheet;
	tmpLayer : CM_DeckLayerLayout;
begin
	//doing this first because i don't want to change the enabled controls until after the proxy is created because if there is an exception it aborts and 
	// i don't get an opportunity to change the enabled controls and mode back
	
	// PAR 27528 
	tpSheet := self.fldDefinition.topSheet.CMUI_Sheet;
	
	if _mode = self.Mode_Edit then
		// create the proxy from real object
		self.createProxyUpdate();
		
		self.drawDeckLayouts(CMUI_PointDrawingFrame.Mode_DisplayOnly, true); // PAR 27821 pass in mode, PAR 28058
		
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter;
	endif;
	
	self.mode:=_mode;
	self.enableControls();
	
	self.loadDeckDetails();
	
	if self.mode = self.Mode_View then
		
		//if there is a proxy object then delect the proxy
		if self.myCurrentProxyDeck &lt;&gt; null then
			// will be the same for a copy
			if self.myCurrentDeck = self.myCurrentProxyDeck then
				self.myCurrentDeck:=null;
			endif;
		
			//delete self.myCurrentProxyDeck;			// 12/03/2012 cnwmh5 #29100 - Now cleaned up in doClearDeckGraphics
		endif;
		// PAR 27595 clear out graphic
		self.doClearDeckGraphics();
		
		
		self.btnDrawTBCross.value := false;
		///self.btnShowText.value := false;		// 28845 if 'Show Labels' is pressed, keep it down until the user toggles it, like 'Remarks'
		self.btnMultiSelect.value := false;
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
		self.frameLabelLineH.clearGraphics();
		self.frameLabelLineV.clearGraphics();
		
	endif;
	if self.mode = self.Mode_New then
		self.txtCode.setFocus;


		// PAR 27595 clear out graphic
		self.doClearDeckGraphics();
	
		//create the proxy
		self.createProxyNew();
	
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
	endif;
	
	if  self.mode = self.Mode_New or self.mode = self.Mode_Edit then
		self.txtCode.setFocus;
		if self.mode = self.Mode_Edit then
			self.fldDefinition.topSheet := tpSheet;
		endif;
	endif;
epilog
	
	self.setCaption(null);

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
