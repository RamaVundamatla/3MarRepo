    <JadeMethod name="getLengthOfTIInPixels" id="df5c5098-374a-4f53-89b1-544af4435b8c">
        <source>getLengthOfTIInPixels(_ti : CM_TrackedItem) : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if _ti = null then 
		return 0;
	endif;
	if _ti.isKindOf(CM_Container) then
		return self.getSizeInPixels(_ti.getActualLength());
	else
		// Assume 20 footer
		return self.getSizeInPixels(20);
	endif;
