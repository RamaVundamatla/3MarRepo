    <JadeMethod name="tblDisplayRowAysnc" id="152ea014-c3b3-45eb-ba04-361f4c086c97">
        <source>tblDisplayRowAysnc(objArrayIn:Collection;breakout:Boolean io):Integer;
/*
 
Purpose:                
 
Parameters:             
 
Return Value:           
 
Date        Who         Reason
04 April 2024   annamth     CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process
 
*/
 
vars	
	//mtdCtxArray:ObjectArray;
	resultArray:StringArray;
	tmpStr : String;
	objecInt,obj:Object;
	firstTime:Boolean;
	idx,index:Integer;
	dynObj:JadeDynamicObject;
	dynArray:JadeDynamicObjectArray;
	count,ctxCount:Integer;
	objOutArray:ObjectArray;
	aswMgr:ASW_Manager;	  
begin

	firstTime:=true;
	ctxCount :=10;
	breakout :=false;
	idx:=0;
	index:=0;

	beginTransientTransaction;
	create resultArray sharedTransient;
	//create objArray transient;
	//create mtdCtxArray transient;
	create objOutArray sharedTransient;
	create aswMgr transient;
	create dynArray sharedTransient;
	/*Main ENT row information to be used for displaying the string
	Add the properties to the jade dynamic object array and pass them to the handletblDisplayRowAsync*/
	foreach objecInt in self.tblData.allTblDataEntRows do
	  create dynObj sharedTransient;
	  dynObj.addProperty("attrName",String);
	  dynObj.setPropertyValue("attrName",objecInt.EntTableRow.name);
	  dynObj.addProperty("inputType",Integer);
	  dynObj.setPropertyValue("inputType",objecInt.EntTableRow.inputType);
	  dynObj.addProperty("sortFieldName",String);
	  dynObj.setPropertyValue("sortFieldName",objecInt.EntTableRow.sortFieldName);
	  dynArray.add(dynObj);
	endforeach;	  
	commitTransientTransaction;

	//index:=aswMgr.handletblDisplayRowAsync(objArrayIn,breakout,dynArray,objOutArray,resultArray);
	if index &lt;&gt; 0 then
		count:=1;
	foreach obj in objOutArray do
		tmpStr:=resultArray.at(count);
			if obj &lt;&gt; null and obj = self.myPlaceHolderObject and self.myPlaceHolderObject &lt;&gt; null then
				idx := tblData.addItemObject(obj, '....');
			else
				idx:=tblData.addItemObject(obj,tmpStr);
			endif;
			if idx=0 then
				breakout:=true;
				break;
			endif;
			if obj &lt;&gt; null and (not obj.isTransient) then
				self.armNotesForObject(obj);
			endif;
			self.doPostAddItem(idx, obj);

			if self.frmModalDialog.visible then
				if count mod 1000 = 0 then
					self.zTblDataShowDataUpdateProgress(idx, count, breakout);
				endif;
			endif;

		count:=count+1;
	endforeach;
	return count-1;
	else
		return index;
	endif;
 
epilog
    //delete objArray;
	//delete mtdCtxArray;
	beginTransientTransaction;
	if objOutArray &lt;&gt; null then
		delete objOutArray;
	endif;
	
	//delete objOutArray;
	if resultArray &lt;&gt; null then
		delete resultArray;
	endif;
	commitTransientTransaction;
	delete aswMgr;  
end;</source>
        <Parameter name="objArrayIn" type="Collection"/>
        <Parameter name="breakout" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
