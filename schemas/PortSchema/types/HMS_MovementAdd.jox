<Class name="HMS_MovementAdd" id="63b5d100-f1b2-405e-ac24-5e42f4345146">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <Constant name="TypeStr" id="c62ea282-c529-4dc1-bd3f-3986a780a5d7">
        <source>"Add Movement.."</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="createPropertyChanges" id="79432751-d581-46c3-a56b-20143c2caf36">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	workingMovement : CMIF_HMS_WorkingMovement;
 	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);
	workingMovement := _cmifTrans.myWorkingMovement;
	if workingMovement &lt;&gt; null then
		self.myMovement.createPropertyChanges(self, workingMovement);
	else
		create propertyChange;
		propertyChange.set(self, "Movement Added", null, null);		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="f62d2bf5-bfbf-4220-a4f1-3f9abfe98eb8">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
 	// Set type and typeString
	type:=TRANS_TYPE_AddMovement;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="28f48e93-798f-439e-96ff-ad48dabcfab7">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;	

	return rtnValue;				
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
