    </JadeMethod>
    <JadeMethod name="doSelectAll" id="f08a4b6f-6081-4e95-a398-4a36b788a91b">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
	allSel : Boolean;
begin
	numRows := self.tblData.rows;
	
	allSel := ((numRows - self.tblData.fixedRows) &lt;&gt; self.tblData.allSelectedObjects.size);	
	self.tblData.allSelectedObjects.clear();

//	if self.btnSelectAll.caption = app.getErrorString(SelectAll) then
	if allSel then
		foreach rowIdx in self.tblData.fixedRows to numRows do
			jRow := self.tblData.accessRow(rowIdx);
			jRow.selected := true;
			if jRow.itemObject &lt;&gt; null then
				self.tblData.allSelectedObjects.add(jRow.itemObject);
			endif;
		endforeach;
	else
		foreach rowIdx in self.tblData.fixedRows to numRows do
			jRow := self.tblData.accessRow(rowIdx);
			jRow.selected := false;
		endforeach;
	
	endif;	
	inheritMethod();

end;</source>
    </JadeMethod>
