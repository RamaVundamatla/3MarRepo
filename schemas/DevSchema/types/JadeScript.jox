    <JadeMethod name="sdlCreateYACriteria" id="4e59c0e2-23c9-41f2-a983-f2f968e34fd8">
        <updating/>
        <source>sdlCreateYACriteria() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Apr 2019	jlgsl4	TFS 43798 - AAT - IsChild cargo invoice allocation

*/

vars
	proxyObj : CM_YACriteriaType;
