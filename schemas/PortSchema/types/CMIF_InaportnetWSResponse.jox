    <JadeMethod name="isSuccess" id="d46949a5-1fb8-4166-b88c-3b5a96af9dba">
        <source>isSuccess() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlger1	Initial creation

*/

vars
	statusCode,
	statusMessage : String;
begin
	self.getStatus(statusCode,statusMessage);
	
	return statusCode ="01" and statusMessage = "Success";
	
epilog

end;</source>
