    <JadeMethod name="mpdGetProcessInfo" id="f52e7842-d53e-48a0-88f1-b2b2896281ba">
        <source>mpdGetProcessInfo();
/*

Purpose:			Remind me how to grab a remote nodes proc

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2019	jlgmd1	Initial creation

*/

constants
	NODE_NAME : String = "CNWCHCS101332";
	//PROC_USER : String = "cnwDmast_fa90";
vars
	n : Node;
	p : Process;
	proc_user : String;
begin
	proc_user := "Process Username ? [navDmast_fa90]";
	read proc_user;

	if proc_user = null then
		return;
	endif;
	
	n := system.nodes[NODE_NAME];	// keyed by 'name', rather than id
	p := n.processes[proc_user];	// 'usercode' ascending case-sensitive (the f*ck !?)
	
	write p.edition.String;
	write p.type.Integer.String;
	write p.signOnUserCode;
	
	beginTransaction;
	p.changeUserCode("FL1");
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mpdHandleAllExceptions" id="6b697029-be82-4129-ad28-e2d4c91bdc80">
        <source>mpdHandleAllExceptions(ex: Exception; invalid: Boolean io; writeLog : Boolean) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgmd1	Initial creation

*/

vars
	r : Integer;
begin
	if writeLog then
		write method.qualifiedName &amp; Tab &amp; ex.errorCode.String &amp; Tab &amp; ex.String;
	endif;

	// Try and continue
	if ex.continuable then
		r := Ex_Continue;
	// Unless we've been interrupted
	elseif ex.errorCode = 4035 then
		r := Ex_Abort_Action;
	else
		r := Ex_Resume_Next;
	endif;
	
	// As you were...
	invalid := true;
	return r;
epilog

end;</source>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="invalid" type="Boolean" usage="io"/>
        <Parameter name="writeLog" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mpdJWTTests" id="d21a46d4-ce5f-4cb7-a5dc-8ef7a7783913">
        <source>mpdJWTTests();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
22 December 2023		navmd1	Initial creation

*/

constants
	OAuthConfigURL : String = "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration";
	OAuthClientCredentialsFlowUrl : String = "https://login.microsoftonline.com/14acb383-2d3a-4541-a2db-1768bb5bc005/oauth2/v2.0/token";	// mtn.navis.com tenant
	OAuthClientCredentailsClientId : String = "a3c7daa0-355d-4f51-a7f2-0879f7362038";
	OAuthClientCredentailsClientSecret : String = "Kgk8Q~TIEyllG61AXsp6tq_a5hsXW~FlgyqdhbMF";
	OAuthClientCredentialsScope : String = "a3c7daa0-355d-4f51-a7f2-0879f7362038/.default";
	OAuthClientCredentialCert : String = "";
	OAuthClientCredentialKey : String = "";
vars
	conn			: JadeHTTPConnection;
	timeoutMS		: Integer;
	sendSuccess		: Boolean;
	resultCode		: Integer;
	jsonParser		: JadeJson;
	response		: String;
	jwksUrl			: String;
	pos				: Integer;
	jwks			: String;
	cert			: String;
	token			: String;
	kid				: String;
begin
	app.initialize();
	
	create conn transient;
	timeoutMS := 10 * 1000;
	conn.connectTimeout := timeoutMS;
	conn.sendTimeout := timeoutMS;
	conn.receiveTimeout := timeoutMS;
	conn.url := OAuthConfigURL;
	
	sendSuccess := conn.sendRequest(JadeHTTPConnection.Verb_GET, null, null);
	resultCode := conn.queryStatusCode();
	if sendSuccess then
		conn.readBody(0);
		write "Status Code: " &amp; resultCode.String;
		response := conn.responseBody.StringUtf8.String;
		write response;
		if resultCode &gt;= 300 then
			return;
		endif;
	else
		write "sendRequest failed. Check firewall or timeout settings.";
		return;
	endif;
	
	// TODO: Parse the response into a config object and just return the jwks_uri
	// For now, I'm just going to parse it directly
	pos := 1;
	pos := response.pos("jwks_uri", pos);
	response.scanUntil(":", pos);
	pos += 1;
	response.scanUntil('"', pos);
	pos += 1;
	jwksUrl := response.scanUntil('"', pos);
	
	if jwksUrl = null or pos = 0 then
		write "Error finding JWKS Url";
		return;
	else
		write "JWKS Url: " &amp; jwksUrl;
	endif;
	
	jwks := JadeJsonWebKeySetReader@getJWKSFromURL(jwksUrl);
	
	if jwks = null then
		write "Error generating JWKS";
		return;
	else
		write jwks;
	endif;
	
	conn.url := OAuthClientCredentialsFlowUrl;
	sendSuccess := conn.sendRequest(JadeHTTPConnection.Verb_POST, null, "client_id=" &amp; OAuthClientCredentailsClientId &amp; "&amp;client_secret=" &amp; OAuthClientCredentailsClientSecret &amp; "&amp;scope=" &amp; OAuthClientCredentialsScope &amp; "&amp;grant_type=client_credentials");
	resultCode := conn.queryStatusCode();
	if sendSuccess then
		conn.readBody(0);
		write "Status Code: " &amp; resultCode.String;
		response := conn.responseBody.StringUtf8.String;
		write response;
		if resultCode &gt;= 300 then
			return;
		endif;
	else
		write "sendRequest failed. Check firewall or timeout settings.";
		return;
	endif;
	
	pos := 1;
	pos := response.pos("access_token", pos);
	response.scanUntil(":", pos);
	pos += 1;
	response.scanUntil('"', pos);
	pos += 1;
	token := response.scanUntil('"', pos);
	
	if token = null or pos = 0 then
		write "Error finding Access Token";
		return;
	else
		write "Access Token: " &amp; token;
		kid := JadeJWTParser@getKeyId(token);
		write "kid: " &amp; kid;
	endif;
	
	cert := JadeJsonWebKeySetReader@getKeyFromJWKS(jwks, kid);
	if cert = null then
		write "Error getting Cert from Token";
		return;
	else
		write cert;
	endif;
	
epilog
	delete conn;
	delete jsonParser;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdLocationControlStats" id="da31015b-bc57-415e-ba23-aa73bc89394d">
        <source>mpdLocationControlStats();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 August 2024		navmd1	Initial creation

*/

vars
	lc						: CM_LocationsController;
	oa						: ObjectArray;
	dict					: CM_AssociationDict;
	val						: CM_Association;
	term					: CM_Terminal;
	iter					: Iterator;
	termCode				: String;
	count,
	badVoyageControllers	: Integer;
	oaSizeStr				: String;
	invalid,
	invalidLc				: Boolean;
	invalidTermCol,
	invalidTermColVoy		: CM_LCArray;
	bayVoyage				: CM_BayVoyage;
	voyageStructure			: CM_VoyageStructure;
begin
	app.initialize();
	create dict transient;
	create invalidTermCol transient;
	create invalidTermColVoy transient;
	
	create oa transient;
	CM_LocationsController.allInstances(oa, 0, true);
	oaSizeStr := oa.size.asStringJMTWithOptionalCommas(true, false);
	write "CM_LocationsController size: " &amp; oaSizeStr;
	
	on Exception do app.handleDeletedObject(exception, term, invalid);
	on Exception do app.handleDeletedObject(exception, lc, invalidLc);
	
	write app.actualTime();
	foreach lc in oa as CM_LocationsController do
		term := lc.myTerminal;
		termCode := null;
		
		if invalidLc then
			// Because it takes so long to get through these, the ones at the end might be deleted by the time we get to them
			invalidLc := false;
			continue;
		endif;
		
		if invalid then
			write lc.getOidAsString() &amp; " Error 4 referencing myTerminal";
			invalid := false;
		endif;
		
		if term &lt;&gt; null then
			termCode := term.code;
		else
			if lc.isSlotController then
				bayVoyage := lc.CM_SlotController.myBayVoyage;
				if bayVoyage &lt;&gt; null then
					voyageStructure := bayVoyage.myCellularVoyageStructure;
					if voyageStructure &lt;&gt; null then
						if voyageStructure.myVoyage &lt;&gt; null then
							term := voyageStructure.myVoyage.getMyTerminal();
							if term &lt;&gt; null then
								termCode := term.code;
							endif;
						endif;
					endif;
				endif;
			endif;
			
			if termCode = null then
				termCode := "*INVALID*";
				if not lc.isVoyageController() then
					invalidTermCol.add(lc);
				else
					invalidTermColVoy.add(lc);
					badVoyageControllers += 1;
				endif;
			endif;
		endif;
		
		val := dict[termCode];
		if val = null then
			dict.addAssoc(termCode, 0);
			val := dict[termCode];
		endif;
		val.setValue(val.asInteger + 1);
		count += 1;
		if count mod 10000 = 0 then
			write count.asStringJMTWithOptionalCommas(true, false) &amp; " / " &amp; oaSizeStr;
		endif;
	endforeach;
	write app.actualTime();
	
	iter := dict.createIterator();
	while iter.next(val) do
		iter.getCurrentKeys(termCode);
		write termCode &amp; Tab &amp; val.asInteger.String;
	endwhile;
	
	invalidTermCol.inspectModal;
	write badVoyageControllers;
	invalidTermColVoy.inspectModal;

epilog
	delete dict;
	delete oa;
	delete iter;
	delete invalidTermCol;
	delete invalidTermColVoy;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdMapFileAnalysis" id="bde16100-7bb5-42ea-8de9-4851eab58871">
        <source>mpdMapFileAnalysis();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 March 2025		navmd1	Initial creation

*/

constants
	COUNT_INSTANCES		= false;
vars
	dbfile		: DbFile;
	classMaps	: UserDbClassMapSet;
	classMap	: DbClassMap;
	className	: String;
	cls			: Class;
	scm			: Schema;
	str			: String;
begin	
	foreach dbfile in DbFile.instances do
		if dbfile.name.isOneOf("containr", "") then
			write dbfile.name &amp; Tab &amp; (dbfile.getFileLength() / 1024 / 1024).numberFormat() &amp; " MB";
			classMaps := dbfile.getPropertyValue("classMapRefs").UserDbClassMapSet;
			foreach classMap in classMaps do
				scm := classMap.sendMsg("_getSchema").Schema;
				className := classMap.getName().getTokens()[1];
				cls := scm.getClass(className);
				str := cls.name;
				
				if COUNT_INSTANCES then
					str &amp;= Tab &amp; cls.instances.size64.String;
				endif;
				
				write str;
			endforeach;
		endif;
	endforeach;
	
	write "done";
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdReadEmailsEA" id="675354a3-0102-4a9f-b623-370bd3c14776">
        <executionLocation>server</executionLocation>
        <source>mpdReadEmailsEA() serverExecution;
/*

Purpose:			Non-Oauth email tests

Parameters:			

Return Value:		

Date			Who		Reason
06 July 2022	navmd1	Initial creation

*/

constants
	USE_NTLM_AUTH 	: Integer = 0;			// AutoUseInwardSecurePassword
	
	USE_IMAP		: Boolean = false;		// AutoUseImap	
	IMAP_FLAGS		: Integer = 1;			// LOGOUT_WITHOUT_EXPUNGE (1) // MSL
	
	SERVER_ADDR		: String = "outlook.office365.com";	// MSL
	SERVER_PORT		: Integer = 993;		// AutoImapPort 993 = ssl/tls		// Server Port is only ever used if IMAP is selected. Otherwise, its hard coded to use 110 (POP3) or 143 (IMAP) in the EA ocx.
	SERVER_SSL		: Integer = BGP_EmailSendRequest.SSL_STARTTLS;		// AutoInwardSSLUsage

	USER			: String =  "edifact@imterminal.it";
	PASS			: String = "CXjac00xTEtMLjECAAvXAqs=";
	
	TIMEOUT			: Integer = 30;			// AutoEmailTimeout
vars
	oPop3				: POPMAIN;
	pop3Password		: String;
	nRet,
	nCount				: Integer;
begin
	app.initialize();
	
	// Create transient
	create oPop3 transient;
	oPop3.nTLMAuth := USE_NTLM_AUTH;
	
	if USE_IMAP then
		oPop3.iMAP4Connection := 1;
		oPop3.iMAP4Flags := IMAP_FLAGS;
		oPop3.serverPort := SERVER_PORT;
	endif;
	
	// Get logon information.
	//pop3Password := app.pwDeCode(null, PASS);
	pop3Password := "Ed1fact2";
	
	// If we are using ssl then set up necessary attributes.
	if SERVER_SSL &lt;&gt; BGP_EmailSendRequest.SSL_NONE then		
		oPop3.sSL_stls := SERVER_SSL;
		
		if oPop3.sSL_init() &lt;&gt; 0 then
			app.writeLog("initialize ansslplus failed", LogERROR);
			return;
		endif;
	endif;
	
	oPop3.timeout := TIMEOUT;
	
	// Try and connect to server.
	nRet := oPop3.connect(SERVER_ADDR, USER, pop3Password);
	if nRet &lt;&gt; 0 then
		app.writeLog("Error connecting to Email server: '" &amp; nRet.String &amp; "'", LogERROR);	//25 Nov 2019	NDL	TFS 47053
		app.writeLog("Error with connecting server ERROR RETURNED: " &amp; nRet.String &amp; ". SERVER&gt;&gt;"&amp; SERVER_ADDR &amp; "&lt;&lt; USER&gt;&gt;" &amp; USER &amp; "&lt;&lt; PW&gt;&gt;" &amp; '******'&amp; "&lt;&lt; PORT &gt;&gt;" &amp; oPop3.serverPort.String &amp; "&lt;&lt;", LogERROR);
		return;
    endif;
	
	// How many emails are there
	nCount := oPop3.getTotalOfMails();
	app.writeLog("Emails Received: " &amp; nCount.String, LogINFO);
	
epilog
	oPop3.close();
	delete oPop3;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdReadJournal" id="27ab6026-c1dc-431f-bdc4-db2a4a167fc8">
        <source>mpdReadJournal();

/*

Purpose:													******************************************************
															**** NOTE: This will only run on the server       ****
															**** So all journal files need to be copied there ****
															**** If reading journals not currently on disk    ****
															******************************************************

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2009	cnwkpd1	Otago Support - read journal files

*/

vars
	file: File;
	lyne: String;
	jDir: String;
	jaa: JadeAuditAccess;
	journalNum: Integer;
	offset: Integer;
	type: Integer;
	objType: Integer;
	startTs,
	ts: TimeStamp;
	serial: Decimal[12, 0];
	tranId: Decimal[12, 0];
	strOid: String;
	classNum: Integer;
	editn: Integer;
	userSlot: Integer;
	userName: String;
	byUserSlot: Integer;
	byUserName: String;
	justOne : Boolean;
	reportDir : String;
	
	jdo					: JadeDynamicObject;
	dict				: DynaDictionary;
	logClassNum			: Integer;
	startJournalNum		: Integer;
	
begin
	jDir:= "D:\navDmast\server\c_misc\mpd\PENJournals";				// Server Directory
	startJournalNum:= 1789840;										//db0001789840
	justOne := false;
	reportDir := "C:\Temp\DOMTN294";								// Client Directory
	
	while true do
	
		create file transient;
		
		// Check journal exists
		file.usePresentationFileSystem := false;
		file.fileName := jDir &amp; "\db" &amp; startJournalNum.stringWithLeadingZeros(10) &amp; ".log";
		file.mode := File.Mode_Input;
		file.kind := File.Kind_ANSI;
		if not file.isAvailable then
			write "Journal " &amp; startJournalNum.String &amp; " not found, exiting";
			break;
		endif;
		
		file.close();
		file.usePresentationFileSystem := true;
		file.openOutput(reportDir &amp; "\jaa_journal_dump_" &amp; startJournalNum.String &amp; ".txt");		// Client Directory
		
		if file.isAvailable then
		
			create dict transient;
			dict.setMembership(JadeDynamicObject);
			dict.addExternalKey(Decimal, 20, false, true);
			dict.endKeys(false);
			
			logClassNum := CM_MovementLog.number;
		
			journalNum := startJournalNum;
					
			create jaa;

			jaa.getJournal(jDir, journalNum, offset);
				
			while jaa.getNextRecord(type, objType, offset, ts, serial, tranId, strOid, classNum, editn) do
				lyne:= ts.dataDumpFormat &amp; ' ' &amp; serial.String &amp; ' (' &amp;
					journalNum.String &amp; ', ' &amp; offset.String &amp; ') ';
				if tranId &lt;&gt; null then
					lyne := lyne &amp; tranId.String &amp; ' ';
				endif;
				
				if type = jaa.Jaa_Type_BeginTransaction then
					lyne:= lyne &amp; 'beginTransaction';
					create jdo transient;
					jdo.addProperty("tranId", Decimal);
					jdo.setPropertyValue("tranId", tranId);
					jdo.addProperty("tranStart", TimeStamp);
					jdo.setPropertyValue("tranStart", ts);
					
					jdo.addProperty("createsLog", Boolean);
					
					dict.putAtKey(tranId, jdo);
					
				elseif type = jaa.Jaa_Type_CommitTransaction then
					lyne:= lyne &amp; 'commitTransaction';
					
					jdo := dict.getAtKey(tranId).JadeDynamicObject;
					if jdo = null then
						write "beginTransaction; not found for commitTransaction; - tranId " &amp; tranId.String;
					else
						if jdo.getPropertyValue("createsLog").Boolean then
							startTs := jdo.getPropertyValue("tranStart").TimeStamp;
							write lyne &amp; " creates logs, elapsed time = " &amp; (ts - startTs).String;
						endif;
					endif;						
						
				elseif type = jaa.Jaa_Type_AbortTransaction then
					lyne:= lyne &amp; 'abortTransaction';
				elseif type = jaa.Jaa_Type_UserSignOn then
					lyne:= lyne &amp; 'signOn';
					jaa.getUserData(userName, userSlot);
					lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp; ', name=' &amp; userName;
				elseif type = jaa.Jaa_Type_UserSignOff then
					lyne:= lyne &amp; 'signOff';
					jaa.getUserData(userName, userSlot);
					lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp; ', name=' &amp; userName;
				elseif type = jaa.Jaa_Type_ChangeUser then
					lyne:= lyne &amp; 'changeUser';
					jaa.getChangeUserData(userName, userSlot, byUserName,byUserSlot);
					lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp;
						', name=' &amp; userName &amp;
						', by index=' &amp; byUserSlot.String &amp;
						', name=' &amp; byUserName;
				elseif type = jaa.Jaa_Type_DatabaseOpen then
					lyne:= lyne &amp; 'dbOpen';
				elseif type = jaa.Jaa_Type_DatabaseClose then
					lyne:= lyne &amp; 'dbClose';
				elseif type = jaa.Jaa_Type_NoAuditDiscontinuity then
					lyne:= lyne &amp; 'disc-noAudit';
				elseif type = jaa.Jaa_Type_ReorgDiscontinuity then
					lyne:= lyne &amp; 'disc-reorg';
				elseif type = jaa.Jaa_Type_AuditSwitch then
					lyne:= lyne &amp; 'disc-switch';
				elseif type = jaa.Jaa_Type_Create then
					lyne:= lyne &amp; 'create';
					if objType = jaa.Jaa_Object_Object then
						lyne:= lyne &amp; ' object';					
					elseif objType = jaa.Jaa_Object_Blob then
						lyne:= lyne &amp; ' blob';
					elseif objType = jaa.Jaa_Object_Collection then
						lyne:= lyne &amp; ' collection';
					endif;
					lyne := lyne &amp; ' ' &amp; strOid;
				elseif type = jaa.Jaa_Type_Delete then
					lyne:= lyne &amp; 'delete';
					if objType = jaa.Jaa_Object_Object then
						lyne:= lyne &amp; ' object';
					elseif objType = jaa.Jaa_Object_Blob then
						lyne:= lyne &amp; ' blob';
					elseif objType = jaa.Jaa_Object_Collection then
						lyne:= lyne &amp; ' collection';
					endif;
					lyne := lyne &amp; ' ' &amp; strOid;
				elseif type = jaa.Jaa_Type_Update then
					lyne:= lyne &amp; 'update';
					if objType = jaa.Jaa_Object_Object then
						lyne:= lyne &amp; ' object';
					elseif objType = jaa.Jaa_Object_Blob then
						lyne:= lyne &amp; ' blob';
					elseif objType = jaa.Jaa_Object_Collection then
						lyne:= lyne &amp; ' collection';
					endif;
					lyne := lyne &amp; ' ' &amp; strOid;
				endif;
				file.writeLine(lyne);
	//			write lyne;
			endwhile;
		endif;

		// EOF
		startJournalNum += 1;
		offset := 0;
		
		file.close();
		delete file;
		dict.purge();
		delete dict;
		
		if justOne then
			break;
		endif;
	endwhile;
	
epilog
	delete jaa;
	delete file;
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	
end;
	</source>
    </JadeMethod>
    <JadeMethod name="mpdReadTransLog" id="398a90f5-1a47-418d-8993-3e39ceb6c0e4">
        <source>mpdReadTransLog();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 March 2020	jlgmd1	Initial creation

*/

constants
	FILELOC : String = "C:\Temp\MES\cn_tranlog_20200229.csv";
vars
	file		: File;
	headers,
	line,
	delim,
	tranId		: String;
	pos,
	col,
	count		: Integer;
	
	totals		: CM_AssociationDict;
	kvVal		: CM_Association;
	iter		: Iterator;
	
	prof		: JadeProfiler;
begin
	prof := process.profiler;
	prof.methodCount := 200;
	prof.fileName := method.name &amp; "_prof";
	prof.start();	
	
	create totals transient;

	create file transient;
	file.usePresentationFileSystem := true;
	file.kind := File.Kind_ANSI;
	file.mode := File.Mode_Input;
	file.fileName := FILELOC;
	
	// Read the header line
	headers := file.readLine();		// This is quite slow, should be redone to read all as text, or buffered input of some description
	
	while true do
		line := file.readLine().trimBlanks();
		
		// Skip blank lines
		if line.length = 0 then
			continue;
		endif;
		
		pos := 1;
		col := 1;
		
		// Read the 'Tran Id' column (col H, #8)
		while col &lt; 8 do
			
			if line[pos:1] = '"' then
				delim := '"';
			else
				delim := ',';
			endif;
			
			line.scanUntil(delim, pos);
			
			if pos = 0 then
				// die ?
			endif;
			
			col := col + 1;
			pos := pos + 1;
			
		endwhile;
		
		delim := line[pos:1];
		pos := pos + 1;
		tranId := line.scanUntil(delim, pos);
		
		kvVal := totals[tranId.toUpper()];
		if kvVal = null then
			totals.addAssoc(tranId, 1);
		else
			kvVal.setValue(kvVal.asInteger() + 1);
		endif;
		
		count := count + 1;
		
		if count &gt;= 1000 then
			break;
		endif;
		
		// How do I get out of here... !?
	endwhile;
	
	// Summary
	iter := totals.createIterator();
	while iter.next(kvVal) do
		totals.getIteratorKeys(tranId, iter);
		write tranId &amp; Tab &amp; kvVal.asInteger.String;
	endwhile;
	
	if prof = null then
		totals.inspectModal();
	endif;

epilog
	delete file;
	delete totals;
	delete iter;
	
	if prof &lt;&gt; null then
		prof.report();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdRecompileAllSchemas" id="fa061de0-ca27-4c89-af1f-61e2d01becae">
        <source>mpdRecompileAllSchemas();
/*

Purpose:			Recompile all schemas/methods.
					We cheat slightly, and just use the Release/Extract agent to launch an external JADE process ;)

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2021	navmd1	Initial creation

*/

vars
	agent : DEV_ReleaseExtractAgent;
	ret : Boolean;
begin
	app.initialize();
	
	create agent transient;
	
	write "Recompiling All Methods...";
	if not agent.runExtractCommand("RootSchema", "JadeRecompileAllMethods", "") then
		write "Check JadeRecompileAllMethods.log on the server for more details";
	else
		write "All Done";
	endif;
epilog
	delete agent;
end;</source>
    </JadeMethod>
