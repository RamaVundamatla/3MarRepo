    <JadeMethod name="validate" id="b6787a5f-92d4-4b71-ba42-a1370dc150ba">
        <source>validate(_userObject: Object);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------

vars
	tmpTI 			: CM_TrackedItem;
	realBulkRelease	: CM_BulkRelease;
	expectedEdition : Integer;
	brCode			: String;
	allTis			: CM_TISet; 
begin
	inheritMethod(_userObject);

	create allTis transient;//23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//if self.allTrackedItems.isEmpty() and self.allTrackedItemsReleased.isEmpty then
	if allTis.isEmpty() and self.allTrackedItemsReleased.isEmpty then //23/06/2023	navkc1	CR 58406 Task 58408
		app.raiseCMException1(ErrorOnStore_NullTIForRequest, self.String, null, _userObject);
		return;
	endif;
	
	if self.myReserveHeader &lt;&gt; null then
		self.myReserveHeader.pxyGetRealObjectAndEdition(realBulkRelease, expectedEdition);
		if realBulkRelease &lt;&gt; null then
			brCode := realBulkRelease.code;
		else
			brCode := self.myReserveHeader.code;
		endif;
	
		//foreach tmpTI in self.allTrackedItems do
		foreach tmpTI in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			//tmpTI.validateForBulkRelease(self.myReserveHeader.code);
			tmpTI.validateForBulkRelease(brCode);	// 02/02/2012 cnwar2 #28113 - need to check original code in case it has been changed
		endforeach;
	endif;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_userObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateWeightAndQuantity" id="9ba55441-0b1b-4740-a414-66feb4c7755c">
        <source>validateWeightAndQuantity(_moveControl: CMIF_MoveController input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2015	cnwndl1	Initial creation	Par 37092

*/

vars

	outstanding : Decimal[14,4];
	isForBulkMulti : Boolean;
	desc : String;

begin

	inheritMethod(_moveControl);
	
	if _moveControl.weight = 0 and _moveControl.quantity &lt; 0 then
		return;
	endif;
	
	self.validateWeightQuantityAdd(	_moveControl.quantity, _moveControl.weight, true );
	
	

epilog

end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWeightQuantityAdd" id="cda603b3-56ad-44ae-ae54-695c36e28e85">
        <source>validateWeightQuantityAdd(_moveQuantity: Integer; _moveWeight: Decimal; _raiseError: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2015	cnwndl1	Initial creation	Par 37092

*/

vars

	outstanding : Decimal[14,4];
	isForBulkMulti : Boolean;
	desc : String;
	ti : CM_TrackedItem;

begin
	
	if _moveWeight = 0 and _moveQuantity &lt; 0 then
		return null;
	endif;
	
	if self.weightRequested = 0 and self.totalRequested = 0 then
		// Must be a the original style release by ID of cargo that is NOT bulk of any sort.
		// No checking required for weight or Quantity.
		return null;
	endif;
	
	//outstanding = requested - released
	ti := self.getTI;
	if ti = null then
		return null;
	endif;
	
	isForBulkMulti:=self.isBulkMulti;
	if isForBulkMulti then
		outstanding := self.getWeightOutstanding();
	else
		outstanding := self.getTotalOutstanding();
	endif;
	
	if outstanding &lt;= 0 then
		if _raiseError then
			app.raiseCMException1(Reserve_detail_outstan_balance, outstanding.asStringJMT, null, self );
			return null;
		else
			return app.getErrorString1(Reserve_detail_outstan_balance, outstanding.asStringJMT );
		endif;
	endif;
	
	if isForBulkMulti then
		outstanding := outstanding - _moveWeight;
	else
		outstanding := outstanding - _moveQuantity;
	endif;
	
	if outstanding &lt; 0 then
		desc := self.getTotalRequestedDisplay() &amp; ' x ' &amp; self.getProductISOTypeDescr();
		if _raiseError then
			app.raiseCMException1(Quant_weigh_relea_will_excee_r, desc, null, self );
			return null;
		else
			return app.getErrorString1(Quant_weigh_relea_will_excee_r, desc );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_raiseError" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
