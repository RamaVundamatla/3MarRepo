    <JadeMethod name="getDisplayStringForAttribute" id="098ca174-e0a7-4c22-9975-9f9f529e7722">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 16 January 2007

vars

begin

	if _attrName = ETRow_MyType or
		_attrName = ETRow_Type  then 
		if not self.isKindOf(CM_BreakBulkGeneric) then
			//epr par 34310 22/7/14
			if self.myProduct &lt;&gt; null then
				return self.myProduct.getDisplayStringForAttribute(ETRow_MyType,_short);
			else
				//epr par 34778 25/8/14 
				if self.myCargoType.mySystemProductType = null then
					return null;
				endif;
				return self.myCargoType.mySystemProductType.getDisplayStringForAttribute(ETRow_MyType,	_short);
			endif;
			return null;
		endif;	
	elseif _attrName = ETRow_OverHeight or
		_attrName = ETRow_OverLengthBack or
		_attrName = ETRow_OverLengthFront or
		_attrName = ETRow_OverWidthLeft or
		_attrName = ETRow_OverWidthRight then
		return null;
	elseif _attrName = ETRow_FirstConnectedDTSort  or _attrName = ETRow_LastConnectedDTSort or _attrName = ETRow_LastDisconnDTSort then //04/08/2016 cnwma1 TFS #2430
	
		return null.String;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFutureLocationsOfTypeString" id="69d128e6-d0b1-4efc-8cbb-7f1cb712bf26">
        <source>getFutureLocationsOfTypeString(_moveMode: Integer): String;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		This looks the same as the one on TrackedItem, but it looks at a different method on the future move
// ---------------------------------------------------------------------------
vars
	theLocations : String;
	theMoves : CM_FutureMoveArray;
	aMove : CM_FutureMove;
	splitable : Boolean;
begin

	splitable := self.myCargoType.isBreakBulkMulti or self.myCargoType.isBulkMulti;		//04 Oct 2013 - Break bulk

	create theMoves transient;
	if _moveMode = PLANNING_MODE then
		self.getFutureMovesOfType(_moveMode, TI_FutureMovePlanned,theMoves );
		foreach aMove in theMoves do
			if splitable and aMove.myWorkListEntry &lt;&gt; null then	//04 Oct 2013 - Break bulk
				theLocations := theLocations &amp; aMove.getAllLocationsString &amp; "(" &amp; aMove.myWorkListEntry.getMoveAmountDisplay(true) &amp; "), ";
			else
				theLocations := theLocations &amp; aMove.getAllLocationsString &amp; ", ";
			endif;
		endforeach;
		self.getFutureMovesOfType(_moveMode, TI_FutureMoveDLRDischarge,theMoves );
		foreach aMove in theMoves do
			theLocations := theLocations &amp; aMove.getAllLocationsString &amp; " (D), ";
		endforeach;
		self.getFutureMovesOfType(_moveMode, TI_FutureMoveDLRLoad,theMoves );
		foreach aMove in theMoves do
			theLocations := theLocations &amp; aMove.getAllLocationsString &amp; " (L), ";
		endforeach;
	endif;
	if _moveMode = QUEUE_MODE then
		self.getFutureMovesOfType(_moveMode, TI_FutureMoveQueued,theMoves );
		foreach aMove in theMoves do
			if splitable and aMove.myWorkListEntry &lt;&gt; null then		//04 Oct 2013 - Break bulk
				theLocations := theLocations &amp; aMove.getAllLocationsString &amp; "(" &amp; aMove.myWorkListEntry.getMoveAmountDisplay(true) &amp; "), ";
			else
				theLocations := theLocations &amp; aMove.getAllLocationsString &amp; ", ";
			endif;
		endforeach;
	endif;
	
	if theLocations &lt;&gt; null then
		theLocations := theLocations[1 :theLocations.length - 2];
	endif;
	return theLocations;
epilog
	delete theMoves;

end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="e2b409cc-86f7-470f-8fd6-037de6071208">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/03/2013	cnwdap1	Initial creation PAR #31155 SFW 1321 Imperial Measurements
*/
vars

begin
	if _attrName.isOneOf(ETRow_OverHeight, ETRow_OverLengthBack, ETRow_OverLengthFront, ETRow_OverWidthLeft, ETRow_OverWidthRight) then
		return null;
	elseif _attrName = ETRow_MyLength then
		return app.convertMeasurementForDisplay(_measureType, self.length);
	elseif _attrName = ETRow_MyHeight then
		return app.convertMeasurementForDisplay(_measureType, self.height);
	elseif _attrName = ETRow_MyWidth then
		return app.convertMeasurementForDisplay(_measureType, self.width);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMySplitFromParent" id="50b3f623-47dc-4bd3-8c7e-bd231ae68dc0">
        <source>getMySplitFromParent():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2016	cnwndl1	Initial creation	TFS 1904

*/

vars

	splitTrx : CM_TITransaction;
	parentSplitTrx : CM_TITransaction;
	parentTi : CM_TrackedItem;

begin

	splitTrx := self.allTransactions.getFirstTransOfType(TRANS_TYPE_SPLIT);
	if splitTrx &lt;&gt; null and splitTrx.CM_Split.action = 101 then
		parentSplitTrx := splitTrx.CM_Split.myParentSplit;
		if parentSplitTrx &lt;&gt; null then
			parentTi := parentSplitTrx.myTrackedItem;
		endif;
	endif;
	
	return parentTi;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRawMeasurementValue" id="c3106647-1c43-4941-95c5-d7f062329658">
        <source>getRawMeasurementValue(_rowName: String): Decimal;
/*
