    <JadeMethod name="updateLocation" id="5d452214-86c1-48d7-8d5d-6edb7d407835">
        <updating/>
        <source>updateLocation(_lc : CM_LocationsController) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars
	gridLocation : CMIF_RDTGridLocation;
begin
	self.myTargetLocation := _lc; //epr par 31927 1/7/13 set target location before getting the target loc height
	if self.myTargetTI &lt;&gt; null then 
		self.setTargetLocationHeightFromTI(self.myTargetTI);
	endif;
	
	if _lc.isKindOf(CM_GridController) and self.isLocationInGriddedArea(_lc) then
		// The display builder will not have been executed yet, so we get the 
		// information we need from the gridded area itself.
		self.myGridArea :=  _lc.CM_GridController.getMyGridArea();
		if self.isLandscape then
			if self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END then
				if self.targetLocationHeight &gt; 0 then
					if self.targetLocationHeight &gt; self.myGridArea.getHeightOfStack() then
						self.targetLocationHeight := 1;
					endif;
					self.rowLC := self.gridRowToStackHeight(self.targetLocationHeight, self.myGridArea);
					if self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
						self.colLC := self.myTargetLocation.CM_GridController.column;
					else
						self.colLC := self.myTargetLocation.CM_GridController.row;
					endif;
				else
					if self.myTargetTI = null then
					
						// No height was specified in the location string and we are looking at the side (or face) view
						// of a gridded row.  We need to work out the first height available in the stack so that we center 
						// on that.
						self.rowLC := self.myGridArea.getHeightOfStack - self.myTargetLocation.allTrackedItems.size();
						if self.rowLC &lt; 1 then
							self.rowLC := 1;
						endif;
						self.targetLocationHeight := self.gridRowToStackHeight(self.rowLC, self.myGridArea);
					else
						// No height specified in the location string, but we have a target TI that has been set explicitly,
						// so we can get the height from that
						self.setTargetLocationHeightFromTI(self.myTargetTI);
						self.rowLC := self.gridRowToStackHeight(self.targetLocationHeight, self.myGridArea);
					endif;
	
					if self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
						self.colLC := self.myTargetLocation.CM_GridController.column;
					else
						self.colLC := self.myTargetLocation.CM_GridController.row;					
					endif;
				endif;
			else
				self.rowLC := self.myTargetLocation.CM_GridController.row;
				self.colLC := self.myTargetLocation.CM_GridController.column;	
			endif;
		else
			self.rowLC := self.myTargetLocation.CM_GridController.column;
			self.colLC := self.myTargetLocation.CM_GridController.row;
		endif;
	else
		// The display builder will have been executed befor we get here.  This allows us
		// to ge the information we need from the display builder for non-gridded areas
		self.myGridArea :=  null;
		gridLocation := self.myDisplayBuilder.getGridLocation(_lc);
		if gridLocation &lt;&gt; null then
			self.rowLC := gridLocation.row;
			self.colLC := gridLocation.col;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="vScrollAmount" id="8570f339-724a-4f89-a6db-210b0e1ccace">
        <methodInvocation>mapping</methodInvocation>
        <source>vScrollAmount(set: Boolean; _value: Real io) protected, mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Apr 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	PAR 24901 - Rail Rakes locations are in 10ft slots so make scrolling bigger
							  - also at smalled scalefactor can afford to make bigger scoll changes
*/

vars
	theGridHeight : Real;
begin

	theGridHeight :=self.getGridHeight();
	
	if self.myDisplayBuilder &lt;&gt; null and 
		self.myDisplayBuilder.isKindOf(CMIF_RDTRailDisplayBuilder) then
		theGridHeight:=theGridHeight * 2;
	endif;
	
	if self.scaleFactor &lt;= 0.5 then
		theGridHeight:=theGridHeight * 2;
	endif;
	
	if set then
		// set code here
	else
		// get code here
		_value := self.vScrollFactor * theGridHeight;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zoomIn" id="3398c19b-3d17-4292-bee6-7c97a388bdbb">
        <updating/>
        <source>zoomIn(_reCenterLocation : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.scaleFactor &gt;= MAX_SCALE then
		return;
	endif;

	//self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	//self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );	


	//self.scaleFactor := self.scaleFactor * 2;
	self.scaleFactor := self.scaleFactor + SCALE_INCREMENT;
	
	if _reCenterLocation then
		self.gotoLocationByID(self.myTargetLocation, self.myTargetTI, self.drawMode, false);
		return;
	endif;
	
	
	self.resetScrollOffsets();
	self.resizeDrawingFrames();

	
	// Zoom relative to the current top row and left column 
	self.rowLC := self.topGridRow;
	self.colLC := self.leftGridCol;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	//self.calcViewRowsColsFromLC();
	self.calcDrawRows();
	self.calcDrawCols();
	self.drawEverything();

	//self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
	//self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );	


epilog

end;</source>
        <Parameter name="_reCenterLocation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zoomOut" id="dbbcb1ec-56ae-4eb6-93eb-99a0940fec2b">
        <updating/>
        <source>zoomOut(_reCenterLocation : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	
	if self.scaleFactor &lt;= MIN_SCALE then
		return;
	endif;


	//self.scaleFactor := self.scaleFactor / 2;
	self.scaleFactor := self.scaleFactor - SCALE_INCREMENT;
	
	if _reCenterLocation then
		self.gotoLocationByID(self.myTargetLocation, self.myTargetTI, self.drawMode, false);
		return;
	endif;
	
	
	self.resetScrollOffsets();
	self.resizeDrawingFrames();

	//self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	//self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );	
	
	// Zoom relative to the current top row and left column 
	self.rowLC := self.topGridRow;
	self.colLC := self.leftGridCol;

	self.calcViewSizes();
	self.reCalcRowsCols();

	//self.calcViewRowsColsFromLC();
	self.calcDrawRows();
	self.calcDrawCols();
	self.drawEverything();

	//self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
	//self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );	
		
epilog

end;</source>
        <Parameter name="_reCenterLocation" type="Boolean"/>
    </JadeMethod>
</Class>
