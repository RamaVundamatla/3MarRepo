    <JadeMethod name="segregationTypeEnumToString" id="9041ca49-b8f7-4012-96f1-9844cd353439">
        <source>segregationTypeEnumToString(_segregationType : Integer) : String;
/*
----------   ----------  --------------------------------------------------
Created:	23 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _segregationType = Segregation_Type_Road then
		return Segregation_Type_Road_Str;
	elseif _segregationType = Segregation_Type_Rail then
		return Segregation_Type_Rail_Str;
	elseif _segregationType = Segregation_Type_Ship then
		return Segregation_Type_Ship_Str;
	elseif _segregationType = Segregation_Type_Yard then
		return Segregation_Type_Yard_Str;
	elseif _segregationType = Segregation_Type_Warehouse then	//28 Jul 2015	NDL	Par 36660
		return Segregation_Type_Warehouse_Str;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name,'Unhandled Segregation type(' &amp; _segregationType.String &amp; ')');
	return null;
end;


</source>
        <Parameter name="_segregationType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
