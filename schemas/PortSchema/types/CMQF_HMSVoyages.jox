    <JadeMethod name="addVoyage" id="6bc3a632-c1aa-4022-9397-5d5c06fae067">
        <source>addVoyage(_collection: Collection input; _voyage : CM_Voyage ; _passport: CM_Passport) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwrd1	Initial creation

*/

vars

begin

	// PAR 24475
	if self.getMyVessel &lt;&gt; null then
		// if have a vessel then filter by that
		if _voyage.vesselCode &lt;&gt; self.getMyVessel.code then
			return;
		endif;
	endif;

	if self.includeCancelled then
		_collection.add(_voyage);
	else
		if _voyage.isCancelled then  //jlier1 TFS51963 5/10/21
			//do nothing for now
		else
			_collection.add(_voyage);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterArrivalDates" id="7d12bd88-2439-48ce-aa6c-81ebbf15ee47">
        <source>filterArrivalDates(_collection: Collection input; _passport: CM_Passport) protected;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
vars

	terminal	: CM_Terminal;
	iter,
	iterVoy		: Iterator;
	startTs,
	endTs		: TimeStamp;
	voyage		: CM_Voyage;

begin

	iter := self.allTerminals.createIterator();
	// Go through all selected terminals
	while iter.next(terminal) do
	
		// Set up starting point in arrivals dict.
		delete iterVoy;
		iterVoy := terminal.allVoyagesByArrivalDTCode.createIterator();
		startTs.setDate(self.arriveDateFrom);
		startTs.setTime(self.arriveTFrom.Time);	
		endTs.setDate(self.arriveDateTo);
		endTs.setTime(self.arriveTTo);
		terminal.allVoyagesByArrivalDTCode.startKeyGeq(startTs, null, iterVoy);

		while (iterVoy.next(voyage)) do
			if voyage.arrivedDT &gt; endTs then
				break;
			endif;
			
			//if voyage.myHMSVoyageData = null or voyage.myHMSVoyageData.excludeReport then
			if voyage.myHMSVoyageData &lt;&gt; null and voyage.myHMSVoyageData.excludeReport then		// 10/06/2008 cnwar2 #16751
				continue;
			endif;
			
			//_collection.add(voyage); 
			self.addVoyage( _collection , voyage , _passport); // cnwrd1 par 23993 25.5.2010 ++
		endwhile;
	endwhile;	

epilog	
	delete iterVoy;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterDepartureDates" id="3ca2e3cd-3e68-4641-9852-351c7fae11b8">
        <source>filterDepartureDates(_collection: Collection input; _passport: CM_Passport) protected;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Expected Arrival and Departure dates
vars
	
	startTs,
	endTs		: TimeStamp;

begin

	startTs.setDate(self.departDateFrom);
	startTs.setTime(self.departTFrom);
	
	endTs.setDate(self.departDateTo);
	endTs.setTime(self.departTTo);
	
	//self.searchForVoyages(startTs, endTs, _collection, false, _passport);					// PAR #35826
	self.searchForVoyages(startTs, endTs, _collection, false, false, false, _passport);		// PAR #35826

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterExpectedArrivalDates" id="5f304fff-0a9e-4428-8a3e-78c84acc6db5">
        <source>filterExpectedArrivalDates(_collection: Collection input; _passport: CM_Passport) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/03/2015	cnwdap1		Initial creation PAR #35826 CCMS SFW 1410
//
vars
	startTs,
	endTs		: TimeStamp;

begin
	startTs.setDate(self.estimatedArrivalDateFrom);
	startTs.setTime(self.estimatedArrivalTimeFrom);
	
	endTs.setDate(self.estimatedArrivalDateTo);
	endTs.setTime(self.estimatedArrivalTimeTo);
	
	self.searchForVoyages(startTs, endTs, _collection, false, true, false, _passport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterExpectedDepartureDates" id="e3607710-4d13-4195-97da-ddff2ba1bf6a">
        <source>filterExpectedDepartureDates(_collection: Collection input; _passport: CM_Passport) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/03/2015	cnwdap1		Initial creation PAR #35826 CCMS SFW 1410
//
vars
	startTs,
	endTs		: TimeStamp;

begin
	startTs.setDate(self.estimatedDepartDateFrom);
	startTs.setTime(self.estimatedDepartTimeFrom);
	
	endTs.setDate(self.estimatedDepartDateTo);
	endTs.setTime(self.estimatedDepartTimeTo);
	
	self.searchForVoyages(startTs, endTs, _collection, false, false, true, _passport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterInPortDates" id="52c05041-edbd-4200-bbe2-df2c0c72af7d">
        <source>filterInPortDates(_collection: Collection input; _passport: CM_Passport) protected;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Expected Arrival and Departure dates
vars
	
	startTs,
	endTs		: TimeStamp;
	

begin

	startTs.setDate(self.inPortDateFrom);
	startTs.setTime(self.inPortTFrom);
	
	endTs.setDate(self.inPortDateTo);
	endTs.setTime(self.inPortTTo);
	
	//self.searchForVoyages(startTs, endTs, _collection, true, _passport);				// PAR #35826
	self.searchForVoyages(startTs, endTs, _collection, true, false, false, _passport);	// PAR #35826

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="d50b04c3-dad7-4c48-b90d-665e921eba8b">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ==========	========	=================================================
// 29/08/2012	cnwdap1		PAR #30142 Allow open-ended "to" dates
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Added expected arrival/departure dates
vars
	hasFilteredByDate	: Boolean;
begin

	inheritMethod(_collection, _passport);
	
	if self.getMyVoyage &lt;&gt; null then
		_collection.add(self.getMyVoyage);
		return;
	endif;
	
	// PAR 24475
	if (not self.allVoyages.isEmpty) then
		self.allVoyages.copy(_collection);
		return;
	endif;
	
	if self.arriveDateFrom.isValid() and self.arriveDateTo.isValid() then
		hasFilteredByDate := true;
		self.filterArrivalDates(_collection, _passport);
	endif;
	
	if self.departDateFrom.isValid() and self.departDateTo.isValid() then
		hasFilteredByDate := true;
		self.filterDepartureDates(_collection, _passport);
	endif;
	
	if self.inPortDateFrom.isValid() and self.inPortDateTo.isValid() then
		hasFilteredByDate := true;
		self.filterInPortDates(_collection, _passport);
	endif;
	
	if self.estimatedArrivalDateFrom.isValid and self.estimatedArrivalDateTo.isValid then		// PAR #35826
		hasFilteredByDate := true;															// PAR #35826
		self.filterExpectedArrivalDates(_collection, _passport);							// PAR #35826
	endif;																					// PAR #35826
	if self.estimatedDepartDateFrom.isValid and self.estimatedDepartDateTo.isValid then		// PAR #35826
		hasFilteredByDate := true;															// PAR #35826
		self.filterExpectedDepartureDates(_collection, _passport);							// PAR #35826
	endif;																					// PAR #35826
	
	// PAR 24475
	if (not hasFilteredByDate) then
		// need to filter by vessel if one has been selected
	endif;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="be66ae67-3557-46a8-823e-bba621c0cd98">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

	runDate	: Date;
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
	/*
	runDate := app.actualTimeServer().date;

	// Arrival
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateFromType, self.arriveDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateToType, self.arriveDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsTimeFrom then
		return self.arriveTFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_ArrivalsTimeTo then	
		return self.arriveTTo.shortFormatJMT();
//		Par 10238
//		return self.arriveTFrom.format('HH:mm');
	endif;
	
	// Depart
	if _attrName = ETRow_DepartedDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.departDateFromType, self.departDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.departDateFromType, self.departDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_DepartedDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.departDateToType, self.departDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.departDateToType, self.departDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_DepartedTimeFrom then
		return self.departTFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_DepartedTimeTo then
		return self.departTTo.shortFormatJMT();
	endif;
	
	// In Port
	if _attrName = ETRow_InPortDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.inPortDateFromType, self.inPortDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.inPortDateFromType, self.inPortDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_InPortDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.inPortDateToType, self.inPortDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.inPortDateToType, self.inPortDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_InPortTimeFrom then
		return self.inPortTFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_InPortTimeTo then
		return self.inPortTTo.shortFormatJMT();
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);

*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVessel" id="bfc67104-7027-4868-9adf-822bc5fa276c">
        <source>getMyVessel():CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	vessel : CM_Vessel;
	edition : Integer;
	invalidObj : Boolean;

begin

	vessel := self.myVessel;

	if vessel = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, vessel, invalidObj );
	edition := vessel.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return vessel;

epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="1e50cf28-0ab7-4a0b-8db4-6f6289b93f4d">
