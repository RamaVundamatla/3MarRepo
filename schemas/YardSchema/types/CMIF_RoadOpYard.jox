    <JadeMethod name="addVehicleToDataTable" id="abd85e0e-5b52-44f3-a4c7-044e7d50f350">
        <source>addVehicleToDataTable(_vehicle: CM_Vehicle input);
/*
Date		Who		Reason
22 Aug 2006	cnwer1	Initial creation - PAR#xxxx
23 Oct 2012	cnwcs5	par 29653 - hide completed jobs
*/
vars
	wle 		: CM_WorkListEntry;
	vehicleWLEs, 
 	wleColl	: CM_WLEArray;
begin
	if self.myRoadOpController.hideCompletedJobs then
		// par 29653 - don't want to add vehicle if it only has completed jobs
		if not _vehicle.hasIncompleteRoadJobs then
			return;
		endif;
	endif;
	
	inheritMethod(_vehicle);
	
	create vehicleWLEs transient;
	
	_vehicle.getAllWLEs(vehicleWLEs);
	
	wleColl := self.allWLEs;
	
	foreach wle in vehicleWLEs do
		if not wleColl.includes(wle) then 
			// not one we are already showing
			if self.addDataTableObject(wle) then	
				// added to table
				wleColl.add(wle);
			endif;									
		endif;
	endforeach;

epilog
	delete vehicleWLEs;
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
