    <JadeMethod name="fixWoJobReqDate" id="7b6fdb40-fb66-4974-b87a-88a6580ed7fb">
        <source>fixWoJobReqDate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023		navma1	Initial creation

*/

vars
	obj    : Object;
	woJob  : CM_WorkOrderJob;
	oArray : ObjectArray; 
	reqDate: TimeStamp;
begin

	create oArray transient;
	CM_WorkOrderJob.allInstances(oArray,0,true);
	
	foreach obj in oArray do
		woJob :=  obj.CM_WorkOrderJob;
		
		if woJob.requiredByDT.isValid then
			continue;
		endif;
		if woJob.myWODtl &lt;&gt; null and  woJob.myWODtl.requiredByDT.isValid then
			reqDate:= woJob.myWODtl.requiredByDT;
		elseif woJob.myWorkOrderDtlToDo &lt;&gt; null and  woJob.myWorkOrderDtlToDo.requiredByDT.isValid then
			reqDate:= woJob.myWorkOrderDtlToDo.requiredByDT;
		else
			reqDate := woJob.createdTime;
		endif;
		
		if reqDate.isValid then
			woJob.setRequiredByDT(reqDate);
		endif;
		
	endforeach;
epilog
		delete oArray;
end;</source>
    </JadeMethod>
