    <JadeMethod name="setForCreate" id="bb5371e9-1e65-4a48-be22-fded0fae1f17">
        <updating/>
        <source>setForCreate(pProxyConsigneeConsignor:CM_ConsigneeConsignor; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDAC	: CM_DataAccessController;

begin
	self.code := pProxyConsigneeConsignor.code.trimBlanks;		// Cannot be updated, only set on create
	self.setForUpdate(pProxyConsigneeConsignor);

	tmpDAC := _passport.allDataAccessControllers[CM_ConsigneeConsignor.name];
	if tmpDAC &lt;&gt; null then
		tmpDAC.addObject(self);
	endif;

	self.myRoot := app.myRoot;
	if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then
		self.myRootByDesc := app.myRoot;
	else 
		self.myRootByDesc := null;
	endif;

end;</source>
        <Parameter name="pProxyConsigneeConsignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4d839d88-9d8d-42a5-9778-03281291d3be">
        <updating/>
        <source>setForUpdate(_proxy:CM_ConsigneeConsignor) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
// 25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 added isUsedForPacking attribute
// 03 Aug 2017	cnwma1	TFS #5209:PEN - Release Request Stop
// ---------------------------------------------------------------------------
vars
	proxyAddress	: CM_Address;
begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
	endif;

	self.code 					:= _proxy.code.trimBlanks;
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	self.description 			:= _proxy.description.trimBlanks;
	self.colour 				:= _proxy.colour;

	if _proxy.debtor &lt;&gt; self.debtor then
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE, false, self.debtor);
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE, false, _proxy.debtor);
	endif;


	self.debtor 				:= _proxy.debtor;
	self.myConsignGroup 		:= _proxy.myConsignGroup;
	self.order 					:= _proxy.order;
	self.derogationNumber 		:= _proxy.derogationNumber;
	self.emailAddress 			:= _proxy.emailAddress;
	self.secureExportPartner 	:= _proxy.secureExportPartner;
	self.showOOWRemarks			:= _proxy.showOOWRemarks;
	
	self.allPINNotifyEmailAddresses.clear();
	_proxy.allPINNotifyEmailAddresses.copy(self.allPINNotifyEmailAddresses);
	
	//par#12903 3/11/2006
	self.isConsignor 	:= _proxy.isConsignor;
	self.isConsignee 	:= _proxy.isConsignee;
	self.isFreightFwdr  := _proxy.isFreightFwdr;
	
	//cnwmc5 - 20/12/2012 - HAT 2198
	self.license 			:= _proxy.license;
	self.licenseExpiryDate 	:= _proxy.licenseExpiryDate;
	
	self.isUsedForPacking	:= _proxy.isUsedForPacking;			// PAR #35895
	self.isRestricted			:= _proxy.isRestricted; // 2.8.2017 cnwma1 TFS #5209
	self.isInternal			:= _proxy.isInternal; //jlier1 TFS 57087 27/6/23
	// 31448 maintain address
	if _proxy.myAddress = null then
		if self.myAddress &lt;&gt; null then
			delete self.myAddress;		// sets to null
		// else if both null, no nothing
		endif;
	else
		if self.myAddress = null then
			create self.myAddress persistent;
		endif;
		proxyAddress := _proxy.myAddress;
		self.myAddress.update(proxyAddress.addr1, proxyAddress.addr2, proxyAddress.addr3, proxyAddress.postCode, proxyAddress.region, proxyAddress.countryCode);
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
