<CollClass name="CM_InvTypeGrpMinChargeByMove" id="83d43a35-f818-4d9c-8c74-aed6baaced31">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_InvTypeGroupingMinCharge"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_InvTypeGroupingMinCharge::moveType"/>
    </MemberKey>
    <JadeMethod name="getGroupingFor" id="7e920c2a-00a9-4409-ba78-bb945e1d1320">
        <source>getGroupingFor( _invLineType : CM_InvoiceLineDesc; _movement : HMS_VoyageMovement; _moveType : String ):CM_InvTypeGroupingMinCharge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	item : CM_InvTypeGroupingMinCharge;
	iter : Iterator;
	moveType : String;

begin

	if _invLineType = null then
		return null;
	endif;
	
	if _moveType &lt;&gt; null then
		moveType := _moveType;
		
	elseif _movement &lt;&gt; null then
		if _movement.isArrival or _movement.isMoveTypeArrCancelled then
			moveType := app.getMoveTypeDescription(HMSMovementTypeArrival);
		elseif _movement.isMovementTypeShift or _movement.isMoveTypeShiftCancelled then
			moveType := app.getMoveTypeDescription(HMSMovementTypeShift);
		elseif _movement.isMovementTypeDeparture or _movement.isMoveTypeDepCancelled then
			moveType := app.getMoveTypeDescription(HMSMovementTypeDeparture);
		endif;
	endif;

	iter := self.createIterator;	
	while iter.next( item ) do
		if item.allLineTypesForMinimumCharge.includes( _invLineType ) then
			if item.moveType = null //All move types
			or item.moveType = moveType // Is for this specififc move type
			then
				return item;
			endif;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_moveType" type="String"/>
        <ReturnType type="CM_InvTypeGroupingMinCharge"/>
    </JadeMethod>
    <JadeMethod name="getOverlapping" id="b8a0e4f5-c552-426b-97fa-d684d261ffe4">
        <source>getOverlapping(  itemToCheck : CM_InvTypeGroupingMinCharge; matchingLineType : CM_InvoiceLineDesc output ):CM_InvTypeGroupingMinCharge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	item : CM_InvTypeGroupingMinCharge;
	iter : Iterator;
	invLineType : CM_InvoiceLineDesc;

begin

	if itemToCheck = null then
		return null;
	endif;

	iter := self.createIterator;
	if itemToCheck.groupLinesBy = CM_InvTypeGroupingMinCharge.GroupTypeInvoice then
		//has no move type
		while iter.next( item ) do
			if itemToCheck = item then
				continue;
			endif;
			//Any item using the same invoice line type
			foreach invLineType in itemToCheck.allLineTypesForMinimumCharge do
				if item.allLineTypesForMinimumCharge.includes( invLineType ) then
					matchingLineType := invLineType;
					return item; 
				endif;
			endforeach;
		endwhile;
	
	elseif itemToCheck.groupLinesBy = CM_InvTypeGroupingMinCharge.GroupTypeMovement then 
		//has a move type
		while iter.next( item ) do
			if itemToCheck = item then
				continue;
			endif;
			//Any item using the same invoice line type with NO move type
			//Or any item using the same invoice line type with the same move type
			if item.moveType = null or item.moveType = itemToCheck.moveType then
				foreach invLineType in itemToCheck.allLineTypesForMinimumCharge do
					if item.allLineTypesForMinimumCharge.includes( invLineType ) then
						matchingLineType := invLineType;
						return item; 
					endif;
				endforeach;
			endif;
		endwhile;
	
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="itemToCheck" type="CM_InvTypeGroupingMinCharge"/>
        <Parameter name="matchingLineType" type="CM_InvoiceLineDesc" usage="output"/>
        <ReturnType type="CM_InvTypeGroupingMinCharge"/>
    </JadeMethod>
</CollClass>
