    <JadeMethod name="validateForUpdate" id="7b3b0388-8b43-4967-9755-6a02265248ce">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	real : CM_InvoiceSignoffUser;
	match : CM_InvoiceSignoffUser;

begin

	if self.effectiveDT = null or not self.effectiveDT.date.isValid then
		app.raiseCMException(Must_enter_valid_effec_date_ti, null, null);
		return;
	endif;
	
	if self.myBusinessUnit = null then
		app.raiseCMException(Select_business_unit, null, null);
		return;
	endif;
	
	if self.myUser = null then
		app.raiseCMException(Must_select_user, null, null);
		return;
	endif;
	
	if self.isTransient then
		real := self.pxyGetRealObject;
	else
		real := self;
	endif;
	
	match := self.myBusinessUnit.allInvoiveSignoffUsers.getAtKey( effectiveDT );
	
	if match &lt;&gt; null and match &lt;&gt; real then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Invoice_signoff_user), app.getErrorString(DateAndTime), effectiveDT.asStringJMT, null, null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
