    <JadeMethod name="setupCriteria" id="39d797d2-efd1-4f1f-b18c-085df08f9289">
        <updating/>
        <source>setupCriteria() updating;
/*

Date		Who		Reason
24 January 2014	cnwer1	Initial creation PAR

*/
constants
	MAX_CRITERIA = 8;
vars
	i: Integer;
	criteriaFrame: CMUI_YACriteriaCntl;
	tabIndex: Integer;
	criteriaType 		: CM_YACriteriaType;
	obj				: Object;
begin
	self.frmCriteria.visible:=false;
	self.picCriteria.transparent:=true;
	self.allClonedFrames.purge;

	tabIndex := self.frmCriteria.tabIndex;	
	while i &lt; MAX_CRITERIA do
		i := i + 1;
		criteriaFrame := self.addCriteriaFrame(i,  tabIndex);
		//default 1st to cargo type
		if i = 1 then
			criteriaType:=app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType];
			criteriaFrame.setCriteriaType(criteriaType);
			criteriaFrame.txtCriteriaValue.text :="CONT";
		endif;
		//default 2nd  to IMEX
		if i = 2 then
			criteriaType:=app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus];
			criteriaFrame.setCriteriaType(criteriaType);
		endif;		
	endwhile;
	
	//not sure why but first one cloned had -5 and meant when the container frame for the cloned controls was resized the first one was out - weird jade bug
	foreach obj in self.allClonedFrames do
		 obj.Control.parentRightOffset:=10;
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cc3b1872-ddf3-46df-ba11-78a7c24884c8">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
24 January 2014	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod();

	
	self.frmCriteria.txtCriteriaValue.parentAspect:=Control.ParentAspect_StretchRight;
	self.frmCriteria.btnValuePicker.parentAspect:=Control.ParentAspect_AnchorRight;
	
	self.setupCriteria();
	
	self.tblResults.clear();
	self.tblResults.fixedRows := 1;
	self.tblResults.rows := self.tblResults.fixedRows;
	self.tblResults.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblResults.multiSelect := CM_BaseTable.MultiSelect_None;
	self.tblResults.setForm (self);
	
	self.tblResults.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_WhatIfPlan));

	self.tblResults.accessColumn(self.tblResults.columns).visible:=false;
	self.tblResults.sortColumn[1]:=self.tblResults.columns;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblResults_click" id="34c48436-215f-462f-830c-42591f3f99ed">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_click(table: Table input) updating;
/*

Date		Who		Reason
27 January 2014	cnwer1	Initial creation PAR

*/

vars
	result : CM_TestAutoPlanResult;
begin
	if self.tblResults.accessedRow = null then
		return;
	endif;
	
	result := self.tblResults.accessedRow.itemObject.CM_TestAutoPlanResult;
	if result &lt;&gt; null then
		self.loadResults(result);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f25eaa69-e830-4950-b864-c489139ffb5c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019429, locale);
	btnDoWhatIf.translateCaption(Xlat_0019430, locale);
	btnReset.translateCaption(Xlat_0019431, locale);
end;</source>
    </JadeMethod>
</GUIClass>
