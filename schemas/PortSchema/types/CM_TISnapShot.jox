    <JadeMethod name="getCandHDebtor" id="b144b564-92c4-474c-816c-ecce528cb5ae">
        <source>getCandHDebtor(_useOriginal : Boolean) : CM_DebtorNode;
// ---------------------------------------------------------------------------
// Created:     10 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	tmpVoyage		: CM_Voyage;
	tmpDebtor		: CM_DebtorNode;
	tmpOperator		: CM_Operator;
	
begin
	
	if self.imExStatus = TI_IMEX_STATUS_IMPORT or
	   self.imExStatus = TI_IMEX_STATUS_EXPORT or
	   self.imExStatus = TI_IMEX_STATUS_TRANSHIP or		// PAR #23645 CCMS 1116
	   self.imExStatus = TI_IMEX_STATUS_STORAGE then
	
		tmpOperator := self.getCandHOperator(_useOriginal);
		if tmpOperator &lt;&gt; null then
			tmpDebtor := tmpOperator.debtor;
		endif;

	elseif self.transitStatus = TI_TransitStatusSOB or
	   self.transitStatus = TI_TransitStatusDLR then

		tmpVoyage := self.getVoyage();
		if tmpVoyage &lt;&gt; null and 
		   tmpVoyage.myDefaultLineGroupDebtor &lt;&gt; null then //par 16703 cnwrs1 May 2008
			tmpDebtor := tmpVoyage.myDefaultLineGroupDebtor.debtor;
		endif;
	endif;
	return tmpDebtor;
end;</source>
        <Parameter name="_useOriginal" type="Boolean"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
