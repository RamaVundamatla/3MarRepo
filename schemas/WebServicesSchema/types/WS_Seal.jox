<Class name="WS_Seal" id="15ed5167-8772-4bd7-b1d3-f1b394418a07">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="description" id="bccfec58-d620-462d-ad9e-c9e2f2f10e26">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sealType" id="5eafdd75-cc51-49bd-9177-43d6f67a1243">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="value" id="d3e1c5f3-0ba2-4789-860e-f2340cf9a5f7">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getSealTypeObj" id="b2a6855e-f4e6-427b-91f8-23cea9cad354">
        <source>getSealTypeObj() : CM_SealType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 May 2023			jlizm1	Initial creation TFS 56558 EUP Seal Numbers on Trucks - Web

*/

vars

begin
	return app.myRoot.allTruckSealTypes[self.sealType];
	
epilog

end;</source>
        <ReturnType type="CM_SealType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="5415d443-fcc7-47bf-988a-aa9159ceaa93">
        <updating/>
        <source>setProxyFromObject(_object: CM_SealObject) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation

*/

vars
	sealType : CM_SealType;
begin
	inheritMethod(_object);
	self.sealType:=_object.sealType;
			
	sealType:=_object.getMySealTypeObj; 
	if sealType &lt;&gt; null then
		self.description:=_object.getMySealTypeObj.description;
		if sealType.showSealOnCheck then
			self.value:=_object.getSealValueAsString;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_SealObject"/>
    </JadeMethod>
</Class>
