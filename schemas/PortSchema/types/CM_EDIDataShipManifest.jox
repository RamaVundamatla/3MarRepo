    <JadeMethod name="getVoyageCode" id="34c20849-6ad5-4530-a9f5-d569c56e2064">
        <source>getVoyageCode(): String;
//
//24 Apr 2012	cnwrs1	Par 29476 - When a Voyage is not defined "Will Be Planned" and "Will Be Planned" the RORO Deck Plan nor the RORO Stowage Advice will fail verification.
//30 Nov 2022   navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
//21/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
//
vars
	ediTI : CM_EDITrackedItem;
begin
	
	//if self.allEDITrackedItems.size &gt; 0 then									//30.11.2022 navma1 #52499
	if self.allEDITrackedItems.isNotEmpty then									//21/11/2023	navcs2	ChangeRequest 60866
        foreach ediTI in self.allEDITrackedItems do								//21/11/2023	navcs2	ChangeRequest 60866
			if self.isTransportManifestRelated then								//21/11/2023	navcs2	ChangeRequest 60866
				return ediTI.getVoyageCode();									//21/11/2023	navcs2	ChangeRequest 60866
			elseif ediTI.isEDIBOLHdrTI then										//21/11/2023	navcs2	ChangeRequest 60866
                return ediTI.getVoyageCode();									//21/11/2023	navcs2	ChangeRequest 60866
			elseif ediTI.isEDICargo() then // ### TFS CR 64617 TASK 64637 16JUL2024 NAVAB1
				return ediTI.getVoyageCode(); // ### TFS CR 64617 TASK 64637 16JUL2024 NAVAB1
			endif;																//21/11/2023	navcs2	ChangeRequest 60866
        endforeach;																//21/11/2023	navcs2	ChangeRequest 60866
    endif;																		//21/11/2023	navcs2	ChangeRequest 60866
    return inheritMethod();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
