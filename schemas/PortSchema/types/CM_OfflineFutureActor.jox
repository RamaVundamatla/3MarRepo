    <JadeMethod name="wakeupOfflineFutureActorApp" id="cb349167-1760-484a-8d49-f5c24815a4ad">
        <source>wakeupOfflineFutureActorApp() protected;

/*

Purpose: Send the notification to the CM_OfflineFutureActor app to wake up, if the receiver needs to be processed within the standard wakeup timeframe


Return Value:		


Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/

vars
	nextWakeupTime	: TimeStamp;
	root		    : CM_Root;
begin
	// Only need to do this if myRoot reference has previously been sent, otherwise
	// receiver wont be in the queue yet
	
	root := self.myRoot;				//28.05.2024 navma1 #64224
	
	if root &lt;&gt; null then
		nextWakeupTime := app.actualTimeAppServer + CM_OfflineFutureActorHandler.Standard_Timer_Delay.Time;	//19.11.2025 navhl20 #36492
		
		// Only send the note if we need to be processed before the next calculated 
		// wakeup time for the app
		if self.actionTimeStamp &lt; nextWakeupTime then
			root.causeEvent(EVENT_OFFLINEFUTURE_PROCESS, false, null);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
