    <JadeMethod name="initLayout" id="9adf49a0-86cd-41b5-b1d2-9a00fdd1cb96">
        <source>initLayout();

vars
	lX, lY: CM_IntegerArray;
	proxyLayout, realLayout: CM_LayoutGraphic;
	pointsPolygon : PointArray;
begin

	create pointsPolygon transient;
	create proxyLayout transient;
	proxyLayout.setDefaultOutline4(0,0, DEFAULT_YARD_X, DEFAULT_YARD_Y,pointsPolygon);
	proxyLayout.setProxy(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"Terminal " &amp; self.code,self);
	
