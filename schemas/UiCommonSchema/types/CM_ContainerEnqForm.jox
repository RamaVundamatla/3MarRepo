    <JadeMethod name="doMnuInterModalClick" id="74f8152b-1830-4fef-9621-34e9cd3afcd3">
        <source>doMnuInterModalClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53084 GPHA revceival/release of tranship cargo

*/

vars
	pxyTI, ti	: CM_TrackedItem;
	tiSet		: CM_TISet;
	theReturn 	: Integer;
	newStatus	: Integer;
	
begin
	// get all selected cargo items 
	create tiSet transient;
	
	if self.tblData.allSelectedObjects.isEmpty() then
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		tiSet.add(ti);
	else
		self.tblData.allSelectedObjects.copy(tiSet);		
	endif;
	
	
	if tiSet.isEmpty then
		return;
	endif;
	
	foreach ti in tiSet do
		delete pxyTI;
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		
		if ti.getTransitStatus = TI_TransitStatusNull then
			newStatus := TI_TransitStatusInterModal;
		elseif ti.getTransitStatus = TI_TransitStatusInterModal then
			newStatus := TI_TransitStatusNull;
		else
			continue;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateTITransitStatus(pxyTI,newStatus,app.myPassport);
			if not app.myPassport.trxCompletedOK then
				theReturn := app.showErrorWarningDialog("Transit Status Change", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endforeach;
	
epilog
	delete pxyTI;

end;</source>
    </JadeMethod>
