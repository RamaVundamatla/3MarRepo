    <JadeMethod name="showCurrent" id="31ec4f9a-4347-44dd-8cf6-574657128fdf">
        <source>showCurrent();
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
constants
	SelectColour : Integer = #FFDDDD;
vars
	tmpRowFrame	: CMUI_RowFrame;
	totHeight,
	nextTop		: Real;
begin


	foreach tmpRowFrame in self.allRowFrames do
		tmpRowFrame.ignoreSkin := true;
		tmpRowFrame.frmInput.ignoreSkin := true;
		tmpRowFrame.frmText.ignoreSkin := true;

		if tmpRowFrame = self.myCurrentRowFrame then
			tmpRowFrame.frmInput.backColor := SelectColour;
			tmpRowFrame.frmText.backColor := SelectColour;
		//elseif tmpRowFrame.isDisabled then
			//tmpRowFrame.frmInput.backColor := Gray;
			//tmpRowFrame.frmText.backColor := Gray;
		else
			tmpRowFrame.frmInput.backColor := self.backColor;
			tmpRowFrame.frmText.backColor := self.backColor;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="unuseCurrentRow" id="cede55d4-7358-484c-899d-6e13bc0d26e6">
        <updating/>
        <source>unuseCurrentRow( idx_frame : Integer) updating;
//-----------------------------------------------------------------------
//	Created:	12 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	idx,
	newIdx		: Integer;
	removeFrame	: CMUI_RowFrame;
begin

	if self.rowCount &gt; 1 then
		removeFrame := self.allRowFrames[idx_frame];
		idx := self.allRowFrames.indexOf(removeFrame);
		self.allRowFrames.remove (removeFrame);
		self.allUnusedRowFrames.add (removeFrame);
		
		if self.allRowFrames.size &lt; idx then
			newIdx := self.allRowFrames.size;
		else
			newIdx := idx;
		endif;
		self.setCurrentRowFrame (self.allRowFrames[newIdx]);
		self.resizeRow(myCurrentRowFrame, myCurrentRowFrame.height);
		self.rowCount := self.rowCount - 1;
	elseif self.rowCount = 1 then
		//delete last row? - just clear out and leave it there
		self.clearRow(1);
	//else
		//row count must be 0
	endif;

end;</source>
        <Parameter name="idx_frame" type="Integer"/>
    </JadeMethod>
