    <JadeMethod name="getConfig" id="9cfd029f-3923-4e99-afa4-e1d6c673d929">
        <source>getConfig(pCode : String) : Any;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	stateObj := self.myStateObject;
	
	if stateObj = null then
		return null;
	endif;
	
	return stateObj.getStateData(pCode);

end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getDisplayName" id="b4cfe6b5-b4e2-4b4b-a9b0-d485a031aa3d">
        <source>getDisplayName(_includeTAType : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwer1	Initial creation

*/

vars

begin
	if _includeTAType then
		return self.getNiceName &amp; " - " &amp; self.typeString;
	endif;
	
	return self.getNiceName;
epilog

end;</source>
