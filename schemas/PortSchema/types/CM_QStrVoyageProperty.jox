    <JadeMethod name="getValueForObject" id="a457f538-ef8f-4b1d-812e-4d623dd6cd90">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2017	jlgndl1	Initial creation	TFS 7654

*/

vars

	voyageOid : String;
	voyage : CM_Voyage;
	propValue : String; 
begin
	//epr TFS 47132 18/12/19
	if self.propertyClassName = CM_BOL.name and  self.propertyName = CM_BOL::getVoyageCode.name then
		propValue := _obj.sendMsg(self.propertyName).String;
	
		if self.needToUpperCase then
			propValue := propValue.toUpper;
		endif;
		return propValue;
	else
	
		voyageOid := inheritMethod(_obj, _op).String;
		
		if voyageOid &lt;&gt; null and voyageOid.length &lt;&gt; 10 and voyageOid[1:10] = "CM_Voyage/" then
			voyage := voyageOid[11:end].asOid.CM_Voyage;
			if voyage &lt;&gt; null then
				return voyage.code;
			endif;
		endif;
		
		return voyageOid;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="50766733-df9d-4cf7-a378-a8173f0b9139">
        <source>getWebDataRowName(): String;
//
// Purpose:			
//
// Parameters:			
//
