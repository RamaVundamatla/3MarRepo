end;</source>
    </JadeMethod>
    <JadeMethod name="initVoyageAllocationSheet" id="8b096aa5-435e-4c5b-92a1-f70e997a3725">
        <updating/>
        <source>initVoyageAllocationSheet(_lastVisitVoyage : Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// 12/10/2011	cnwmh5	#28309 - If 1st voyage for the terminal then there won't be a voyage to get the vessel so use the vessel on the form
//
vars
	ct 			: CM_YACriteriaType;
	yaConfig 	: CM_YAConfig;
	o 			: Object;
	s 			: String;
	voyage 		: CM_Voyage;
	//voyageConfig : CM_YAVoyageConfig;
	myText 		: String;
	vessel 		: CM_Vessel;			//cnwas3 par 1035
begin
	voyage := self.myCurrentVoyage;	
	self.myVoyageAlloc := null;
	self.myVoyageConfig := null;
	self.allCriteriaTypesForVoyage.clear();
	self.allAvailable.clear();
	self.allSelected.clear();
	self.lstAvailable.clear();
	self.lstSelected.clear();
	
	if voyage &lt;&gt; null then
		vessel := voyage.getMyVessel();
		if not _lastVisitVoyage and voyage.allVoyageAllocationConfigs.size &gt; 0 then
			self.myVoyageAlloc := voyage.allVoyageAllocationConfigs[TI_IMEX_STATUS_EXPORT].CM_VoyageAllocationConfig;
		//else
		//	self.myVoyageAlloc := self.myTerminal.myYAConfig.allYAVoyageConfigs[TI_IMEX_STATUS_EXPORT].CM_YAVoyageConfig;
		endif;
		
		//enable later when things work
		self.shtVoyageAlloc.enabled := voyage.useVoyageAllocations;
	else																		// 12/10/2011 cnwmh5 #28309
		vessel := self.myCurrentVessel;
	endif;
	
	//this is to set up the available ones for voyage allocations ONLY!
	foreach o in app.myRoot.allYACriteriaTypes do
		if o.isKindOf(CM_YACriteriaType) then
			ct := o.CM_YACriteriaType;
			if ct.isVoyageAllocationCT then
				self.allCriteriaTypesForVoyage.add(ct);
			endif;
		endif;
	endforeach;
	
	//voyage has been setup, don't use defaults!
	if self.myVoyageAlloc &lt;&gt; null then
		foreach o in self.allCriteriaTypesForVoyage do
			if o.isKindOf(CM_YACriteriaType) then	
				ct := o.CM_YACriteriaType;
				if not self.myVoyageAlloc.allOpCriteria.includes(ct) then
					self.allAvailable.add(ct.description);
				endif;
			endif;
		endforeach;
		
		foreach ct in self.myVoyageAlloc.allOpCriteria do
			self.allSelected.add(ct.description);
		endforeach;
	elseif vessel &lt;&gt; null and vessel.myVoyageAllocationConfig &lt;&gt; null then			//cnwas3 ccms 1035 begin
		
		//create self.myVoyageAlloc persistent;
		self.myVoyageAlloc := vessel.myVoyageAllocationConfig;
				
		foreach o in self.allCriteriaTypesForVoyage do
			if o.isKindOf(CM_YACriteriaType) then	
				ct := o.CM_YACriteriaType;
				if not self.myVoyageAlloc.allOpCriteria.includes(ct) then
					self.allAvailable.add(ct.description);
				endif;
			endif;
		endforeach;
		
		foreach ct in self.myVoyageAlloc.allOpCriteria do
			self.allSelected.add(ct.description);
		endforeach;
		
	elseif vessel &lt;&gt; null then																		//cnwas3 ccms 1035 end
	//no voyage allocations, use terminal defaults
		yaConfig := self.myTerminal.myYAConfig;//cnwas3 ccms 1028 begin
		
		if yaConfig = null then
			yaConfig := self.createYAConfig();
		endif;			//cnwas3 ccms 1028 end
		
		self.myVoyageConfig := yaConfig.allYAVoyageConfigs[TI_IMEX_STATUS_EXPORT].CM_YAVoyageConfig;
		
		// par 22718 - check if self.myVoyageConfig is null and create it if we need to
		// Note: - this should not really ever happen :-(
		// Remove this code after 7.8.1 release - it is a stopgap
		// if self.myVoyageConfig = null then
		//	self.myVoyageConfig := self.createYAVoyageConfig (yaConfig);
		// endif;
		// par 22718 - end
		foreach o in self.allCriteriaTypesForVoyage do
			if o.isKindOf(CM_YACriteriaType) then	
				ct := o.CM_YACriteriaType;
				if not self.myVoyageConfig.allOpCriteria.includes(ct) then
					self.allAvailable.add(ct.description);
				endif;
			endif;
		endforeach;
		
		foreach ct in self.myVoyageConfig.allOpCriteria do
			self.allSelected.add(ct.description);
		endforeach;
	endif;
	
	foreach s in self.allAvailable do
		self.lstAvailable.addItem(s);
	endforeach;
	
	foreach s in self.allSelected do
		self.lstSelected.addItem(s);
	endforeach;	
	
	self.setVADefaultColourCombo(true);
end;</source>
        <Parameter name="_lastVisitVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="46506c06-479a-453a-836b-b10196883bd4">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theActiveControl	: Control;

begin

	if self.fldMain.topSheet = self.shtVesselDetails then

		if keyCode = J_key_Tab then
			theActiveControl := app.activeControl;
			//epr CCMS 1116 15/6/2011
			if theActiveControl = self.tblNewDimensions or theActiveControl.parent = self.tblNewDimensions then
				if self.tblNewDimensions.userInputEnabled then
					self.tblNewDimensions.tabKey := J_key_Tab;
				else
					self.tblNewDimensions.tabKey := 0;
				endif;
	
			elseif shift = 0 and theActiveControl = self.ckbHasRamps then
				// moving forward into table
				self.tblNewDimensions.row 	  := self.tblNewDimensions.fixedRows + 1;
				self.tblNewDimensions.tabKey := J_key_Tab;
			elseif shift = 1 and theActiveControl = self.fldMain then
				// moving back into table
				self.tblNewDimensions.row 	:= self.tblNewDimensions.rows;
				self.tblNewDimensions.tabKey := J_key_Tab;
			endif;
		else
			inheritMethod(keyCode, shift);
		endif;
		
	elseif self.fldMain.topSheet = self.shtCutoffs then
		if keyCode = J_key_Tab then
			theActiveControl := app.activeControl;
			/* // ### JIRA 34233 06MAR 2025 NAVAB1
			if theActiveControl = self.tblRecCutoffs or theActiveControl.parent = self.tblRecCutoffs then
				if self.tblRecCutoffs.userInputEnabled then
					self.tblRecCutoffs.tabKey := J_key_Tab;
				else
					self.tblRecCutoffs.tabKey := 0;
				endif;
			
			elseif shift = 0 
			and ((self.btnAddOperator.enabled and theActiveControl = self.btnAddOperator) or (not self.btnAddOperator.enabled and theActiveControl = self.ckbOverrideDef)) then
				// moving forward into table
				self.tblRecCutoffs.column 	:= TblRecCutoffsCol_EarliestHrs + (self.hasOperatorColumn.Integer);
				self.tblRecCutoffs.row 		:= self.tblRecCutoffs.fixedRows + 1;
	
			elseif shift = 1 
			and ((self.cmbVoyage.enabled and theActiveControl = self.cmbVoyage) or (not self.cmbVoyage.enabled and theActiveControl = self.fldMain)) then
				// moving back into table
				self.tblRecCutoffs.column 	:= TblRecCutoffsCol_CutoffTime + (self.hasOperatorColumn.Integer);
				self.tblRecCutoffs.row := self.tblRecCutoffs.rows;
			endif;
			*/
		else
			inheritMethod(keyCode, shift);
		endif;

		
	else
		inheritMethod(keyCode, shift);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="c79994e6-ab92-4820-9a14-2b7a12b0e33c">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod;
	self.beginClassNotification(CM_FileData,false,Object_Create_Event,Response_Continuous,null);
	self.beginClassNotification(CM_FileData,false,Object_Delete_Event,Response_Continuous,null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadBerthPreferences" id="ef38aeaa-6485-432e-89bc-06fee6cf965d">
        <source>loadBerthPreferences(_berthPrefArray : HMS_BerthPrefArray);
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
vars
	berthPref:	HMS_BerthPreference;
	tmpTable : CM_DataTable;
begin

 	// This method loads berthPref objs into the table tblBerthPref

	tmpTable := self.tblBerthPref;
	tmpTable.rows := tmpTable.fixedRows;
	 	
	if _berthPrefArray = null then
		self.cmbBerthPref.clear();
		self.optBerthPref.value := false;
		self.optBerth.value := true;

	else
	
		self.cmbBerthPref.listCollection(_berthPrefArray, true, 0);
		
		foreach berthPref in _berthPrefArray do
			tmpTable.addItemObject(berthPref, berthPref.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));
		endforeach; 
		
		tmpTable.colourRows(self.colorRow1, self.colorRow2);
		
	endif;					
	 		
end;</source>
        <Parameter name="_berthPrefArray" type="HMS_BerthPrefArray"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="bcb96f32-2fbf-46c5-8e13-af77739e3b53">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	//ccms 1058 setup operators multi select group box
	self.mulOperators.setupControl(app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionPlural, 'Operators'),app.myRoot.allOperators,SHP_VoyageDefinitionForm::displayEntryOperator.name);
	
	self.initComboBoxes();	
	
	if self.myCurrentVoyage &lt;&gt; null then
		if self.cmbVoyage.findObject(self.myCurrentVoyage) &gt; 0 then
			self.cmbVoyage.setObject(self.myCurrentVoyage);
		endif;
		self.setMyCurrentVoyage(self.myCurrentVoyage);		
	endif;

	if (not self.viewModeOnly) then
		// user has update rights
		if self.myCurrentVoyage &lt;&gt; null then
			if self.mode = self.Mode_Update then
				if (not self.doBtnEdit()) then
					self.setToViewMode(); 
					self.cmbVoyage.setFocus();
					if self.myCurrentVoyage.archived then
						self.btnEditTV.enabled := false;
					endif;
				endif;
			else
				self.setToViewMode(); 
				self.cmbVoyage.setFocus();
				if self.myCurrentVoyage.archived then
					self.btnEditTV.enabled := false;
				endif;
								
			endif;
		elseif self.mode = self.Mode_Add then
			self.doBtnNew();
		else
			self.setToViewMode();
			self.cmbVoyage.setFocus();				
		endif;
	
	else
		// user is read only user
		self.setToViewMode();
		self.setNavigatorHeading(self.caption); 
		self.cmbVoyage.setFocus();
	endif;
	
	// CCMS 1009
	if self.initCopyAsNewVoyage
	and self.btnCopyVoyage.enabled then
		self.doCopyAsNewVoyage();
	endif;
	
	self.doResize();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDimensionsTbl" id="36bfabd8-cd6b-4393-a9e8-b1b34caa89ed">
        <source>loadDimensionsTbl(_hmsVoyage : CM_Voyage; _hmsVessel : CM_Vessel);
//-----------------------------------------
// Created: August 2005 By: cnwgd1
// CCMS 1020 Remove unnessesary decimal points (i.e. if .00) with cnEcStripDecimalZeros
//-----------------------------------------
vars
	
	row 		: Integer;
	entRow		: EntTableRow;
	dataObject	: CM_Object;
begin
	
	// Set enteries for values column
	if _hmsVoyage &lt;&gt; null then
		dataObject:=_hmsVoyage;
	elseif _hmsVessel &lt;&gt; null then
		dataObject:=_hmsVessel;
	endif;
	
	if  dataObject &lt;&gt; null then
		row:=2;
		while row &lt;= self.tblNewDimensions.rows do
			entRow:= self.tblNewDimensions.accessRow(row).itemObject.EntTableRow;
			if entRow = null then
				return;
			endif;
			self.tblNewDimensions.accessCell(row,2).text:=dataObject.getDisplayStringForAttribute(entRow.name,false);
			row:=row+1;
		endwhile;
	endif;
end;</source>
        <Parameter name="_hmsVoyage" type="CM_Voyage"/>
        <Parameter name="_hmsVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="loadExternalRampTable" id="03e7f700-2e64-4564-9639-30194247b661">
        <source>loadExternalRampTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116
13/10/2011		cnwmh5	#28444 - Rewrite so that creation of the vessel's first voyage in the terminal
								 has the vessels ramp details displayed
*/

vars
	iter : Iterator;
	rampVoyage 	: CM_RORORampExternalVoyage;
	rampVessel	: CM_RORORampExternalVessel;
	str	 : String;
begin
	self.tblExtRamps.clearAllData;
	
	// 13/10/2011 cnwmh5 #28444
	if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myStructuralElements &lt;&gt; null then
		iter := self.myCurrentVoyage.myStructuralElements.allRamps.createIterator;
		while iter.next(rampVoyage) do
			str := rampVoyage.getAttributeStringForDefArray(self.tblExtRamps.allTblDataEntRows);
			self.tblExtRamps.addItemObject(rampVoyage,str);
		endwhile;
		return;
	endif;
		
	if self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myStructuralElements &lt;&gt; null then
		iter := self.myCurrentVessel.myStructuralElements.allRamps.createIterator;
		while iter.next(rampVessel) do
			str := rampVessel.getAttributeStringForDefArray(self.tblExtRamps.allTblDataEntRows);
			self.tblExtRamps.addItemObject(rampVessel,str);
		endwhile;
		return;
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadRecCutoffsRow" id="ab7990cf-023c-4942-a127-f8fd0c23c59e">
        <source>loadRecCutoffsRow(_proxyCutoff : CM_ReceivalCutoffVoyage; _row : Integer);
/*
Purpose:	

Date		Who		Reason
12 March 2025	navab1	JIRA 34233
*/

vars
	table				: CM_DataTable;
	earliestTS, earliestTSPN, cutoffTS, cutoffTSPN : TimeStamp;
	earlyTSStr, earlyTSStrPN, cutoffTSStr, cutoffTSStrPN, earlyHours, earlyHoursPN, cutoffHours, cutoffHoursPN,opCode : String;
	columnEarliestHrs, columnCutoffHrs : Integer;
begin
	table := self.tblVoyageCutoffs;
	columnEarliestHrs 	:= 2 + (self.hasOperatorColumn.Integer);
	columnCutoffHrs 	:= 4 + (self.hasOperatorColumn.Integer);
	
	opCode := "";
	if self.hasOperatorColumn then
		if _proxyCutoff.myOperator &lt;&gt; null then
			opCode := _proxyCutoff.myOperator.code &amp; Tab;
		else
			opCode := Tab;
		endif;
	endif;

	if _proxyCutoff.hoursEarly &lt;&gt; 0 then
		earlyHours := _proxyCutoff.hoursEarly.String;
	endif;

	if _proxyCutoff.hoursEarlyPN &lt;&gt; 0 then
		earlyHoursPN := _proxyCutoff.hoursEarlyPN.String;
	endif;

	if _proxyCutoff.hoursCutoff &lt;&gt; 0 then
		cutoffHours := _proxyCutoff.hoursCutoff.String;
	endif;
	if _proxyCutoff.hoursCutoffPN &lt;&gt; 0 then
		cutoffHoursPN := _proxyCutoff.hoursCutoffPN.String;
	endif;
	
	if _proxyCutoff.earliestDateTime.isValid then

		earliestTS 		:= self.systemToLocalTime( _proxyCutoff.earliestDateTime);  // ### JIRA 36847 16DEC2025 NAVAB1
	else	
		earliestTS := null;
	endif;

	if earliestTS.isValid then
		earlyTSStr :=  earliestTS.time.shortFormatJMT() &amp; " " &amp;earliestTS.date.shortFormatJMT();
	else
		earliestTS := null;

	endif;
	
	if _proxyCutoff.earliestDateTimePN.isValid then
		earliestTSPN 		:= self.systemToLocalTime(_proxyCutoff.earliestDateTimePN);  // ### JIRA 36847 16DEC2025 NAVAB1
	else
		earliestTSPN := null;
	endif;

	if earliestTSPN.isValid then
		earlyTSStrPN :=  earliestTSPN.time.shortFormatJMT() &amp; " " &amp; earliestTSPN.date.shortFormatJMT();
	endif;

	if earlyTSStrPN &lt;&gt; null then
		earlyTSStr := earlyTSStr &amp; " (" &amp; earlyTSStrPN &amp; ")";
	endif;
	
	if _proxyCutoff.cutoffDateTime.isValid then
		cutoffTS 		:= self.systemToLocalTime(_proxyCutoff.cutoffDateTime);  // ### JIRA 36847 16DEC2025 NAVAB1
	else
		cutoffTS := null;
	endif;

	if cutoffTS.isValid then
		cutoffTSStr :=  cutoffTS.time.shortFormatJMT() &amp; " " &amp; cutoffTS.date.shortFormatJMT();
	endif;
	
	if _proxyCutoff.cutoffDateTimePN.isValid then
		cutoffTSPN 		:= self.systemToLocalTime(_proxyCutoff.cutoffDateTimePN);  // ### JIRA 36847 16DEC2025 NAVAB1
	else
		cutoffTSPN := null;
	endif;

	if cutoffTSPN.isValid then
		cutoffTSStrPN :=  cutoffTSPN.time.shortFormatJMT() &amp; " " &amp; cutoffTSPN.date.shortFormatJMT();
	endif;

	if cutoffTSStr &lt;&gt; null then
		cutoffTSStr := cutoffTSStr &amp; " (" &amp; cutoffTSStrPN &amp; ")";
	endif;
	
	if earlyHours &lt;&gt; null then
		earlyHours := earlyHours &amp; " (" &amp; earlyHoursPN.asStringJMT() &amp; ")";
	endif;
	
	if cutoffHours &lt;&gt; null then
		cutoffHours := cutoffHours &amp; " (" &amp; cutoffHoursPN.asStringJMT() &amp; ")";
	endif;
	
	table.accessCell(_row, 1).text := _proxyCutoff.code  &amp; Tab &amp; opCode &amp; earlyHours &amp; Tab &amp; earlyTSStr &amp; Tab &amp; 
												cutoffHours &amp; Tab &amp; cutoffTSStr;
												
	if _proxyCutoff.hoursCutoff &lt; 0 then
		table.accessCell(_row, columnCutoffHrs).foreColor := Red;
	else
		table.accessCell(_row, columnCutoffHrs).foreColor := Black;
	endif;
	if _proxyCutoff.hoursEarly &lt; 0 then
		table.accessCell(_row, columnEarliestHrs).foreColor := Red;
	else
		table.accessCell(_row, columnEarliestHrs).foreColor := Black;
	endif;

epilog

end;</source>
        <Parameter name="_proxyCutoff" type="CM_ReceivalCutoffVoyage"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadRecCutoffsToTable" id="d41d0667-fcf5-4bd1-acab-8ee794b41a10">
        <source>loadRecCutoffsToTable(_proxyCutoff : CM_ReceivalCutoffVoyage);
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2025
ADO - JIRA 34524
*/

vars
	table				: CM_DataTable;
	earliestTS, earliestTSPN, cutoffTS, cutoffTSPN : TimeStamp;
	earlyTSStr, earlyTSStrPN, cutoffTSStr, cutoffTSStrPN, earlyHours, earlyHoursPN, cutoffHours, cutoffHoursPN,opCode : String;
	row : Integer;
	columnEarliestHrs, columnCutoffHrs : Integer;
begin
	columnEarliestHrs 	:= 2 + (self.hasOperatorColumn.Integer);
	columnCutoffHrs 	:= 4 + (self.hasOperatorColumn.Integer);

	table := self.tblVoyageCutoffs;

	opCode := "";
	if self.hasOperatorColumn then
		if _proxyCutoff.myOperator &lt;&gt; null then
			opCode := _proxyCutoff.myOperator.code &amp; Tab;
		else
			opCode := Tab;
		endif;
	endif;

	if _proxyCutoff.hoursEarly &lt;&gt; 0 then
		earlyHours := _proxyCutoff.hoursEarly.String;
	endif;

	if _proxyCutoff.hoursEarlyPN &lt;&gt; 0 then
		earlyHoursPN := _proxyCutoff.hoursEarlyPN.String;
	endif;

	if _proxyCutoff.hoursCutoff &lt;&gt; 0 then
		cutoffHours := _proxyCutoff.hoursCutoff.String;
	endif;
	if _proxyCutoff.hoursCutoffPN &lt;&gt; 0 then
		cutoffHoursPN := _proxyCutoff.hoursCutoffPN.String;
	endif;
	
	if _proxyCutoff.earliestDateTime.isValid then
		earliestTS 		:= self.systemToLocalTime(_proxyCutoff.earliestDateTime);
	else	
		earliestTS := null;
	endif;

	if earliestTS.isValid then
		earlyTSStr :=  earliestTS.time.shortFormatJMT() &amp; " " &amp;earliestTS.date.shortFormatJMT();
	else
		earliestTS := null;

	endif;
	
	if _proxyCutoff.earliestDateTimePN.isValid then
		earliestTSPN 		:= self.systemToLocalTime(_proxyCutoff.earliestDateTimePN);
	else
		earliestTSPN := null;
	endif;

	if earliestTSPN.isValid then
		earlyTSStrPN :=  earliestTSPN.time.shortFormatJMT() &amp; " " &amp; earliestTSPN.date.shortFormatJMT();
	endif;

	if earlyTSStrPN &lt;&gt; null then
		earlyTSStr := earlyTSStr &amp; " (" &amp; earlyTSStrPN &amp; ")";
	endif;
	
	if _proxyCutoff.cutoffDateTime.isValid then
		cutoffTS 		:= self.systemToLocalTime(_proxyCutoff.cutoffDateTime);
	else
		cutoffTS := null;
	endif;

	if cutoffTS.isValid then
		cutoffTSStr :=  cutoffTS.time.shortFormatJMT() &amp; " " &amp; cutoffTS.date.shortFormatJMT();
	endif;
	
	if _proxyCutoff.cutoffDateTimePN.isValid then
		cutoffTSPN 		:= self.systemToLocalTime(_proxyCutoff.cutoffDateTimePN);
	else
		cutoffTSPN := null;
	endif;

	if cutoffTSPN.isValid then
		cutoffTSStrPN :=  cutoffTSPN.time.shortFormatJMT() &amp; " " &amp; cutoffTSPN.date.shortFormatJMT();
	endif;

	if cutoffTSStr &lt;&gt; null then
		cutoffTSStr := cutoffTSStr &amp; " (" &amp; cutoffTSStrPN &amp; ")";
	endif;
	
	if earlyHours &lt;&gt; null then
		earlyHours := earlyHours &amp; " (" &amp; earlyHoursPN.asStringJMT() &amp; ")";
	endif;
	
	if cutoffHours &lt;&gt; null then
		cutoffHours := cutoffHours &amp; " (" &amp; cutoffHoursPN.asStringJMT() &amp; ")";
	endif;
	
	
	row := table.addItemObject(_proxyCutoff, _proxyCutoff.code  &amp; Tab &amp; opCode &amp; earlyHours &amp; Tab &amp; earlyTSStr &amp; Tab &amp; 
												cutoffHours &amp; Tab &amp; cutoffTSStr);
	if _proxyCutoff.hoursCutoff &lt; 0 then
		table.accessCell(row, columnCutoffHrs).foreColor := Red;
	else
		table.accessCell(row, columnCutoffHrs).foreColor := Black;
	endif;
	if _proxyCutoff.hoursEarly &lt; 0 then
		table.accessCell(row, columnEarliestHrs).foreColor := Red;
	else
		table.accessCell(row, columnEarliestHrs).foreColor := Black;
	endif;
												
epilog

end;</source>
        <Parameter name="_proxyCutoff" type="CM_ReceivalCutoffVoyage"/>
    </JadeMethod>
    <JadeMethod name="loadSectionsTable" id="bec4faa3-277e-4b10-a65a-d23c79f6fbfe">
        <source>loadSectionsTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116
13/10/2011		cnwmh5	#28444 - Change so that the creation of vessel's first voyage for the terminal
								 has the vessel's section details displayed
*/

vars

	iter : Iterator;
	section : CM_VesselSection;
	str	 : String;
	aVoyageStructure : CM_VoyageStructuralElements;
	aVesselStructure : CM_VesselStructuralElements;
begin
	self.tblSections.clearAllData;
	
	// 13/10/2011 cnwmh5 #28444
	
	/*if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null then
		iter := self.myCurrentVoyage.myCellularVoyageStructure.allSections.createIterator;
	endif;*/
	
	//cnwrd1 31874
	if self.myCurrentVoyage &lt;&gt; null then
		aVoyageStructure := self.myCurrentVoyage.getMyPrimayVoyageStructure;
		
		if aVoyageStructure &lt;&gt; null then
			iter := aVoyageStructure.allSections.createIterator;
		endif;
	endif;
	
	/*if iter = null and self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null then
		iter := self.myCurrentVessel.myCellularVesselStructure.allSections.createIterator;
	endif;*/
	
	
	if iter = null and self.myCurrentVessel &lt;&gt; null then
		aVesselStructure := self.myCurrentVessel.getMyPrimaryVesselStructure;
		
		if aVesselStructure &lt;&gt; null then
			iter := aVesselStructure.allSections.createIterator;
		endif;
	endif;
	
	
	if iter = null then
		return;
	endif;	
	
	while iter.next(section) do
		str := section.getAttributeStringForDefArray(self.tblSections.allTblDataEntRows);
		self.tblSections.addItemObject(section,str);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTankTable" id="e7f5a611-e669-43b6-b0b7-3788a0cb18f8">
        <source>loadTankTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116
13/10/2011		cnwmh5	#28444 - Change so that the creation of vessel's first voyage for the terminal
								 has the vessel's tank details displayed
*/

vars

	iter : Iterator;
	tank : CM_VesselTank;
	str  : String;	
	aVoyageStructure : CM_VoyageStructuralElements;
	aVesselStructure : CM_VesselStructuralElements;	
begin

	self.tblTanks.clearAllData;
	
	// 13/10/2011 cnwmh5 #28444
	/*if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null then
		iter := self.myCurrentVoyage.myCellularVoyageStructure.allTanks.createIterator;
	endif;
	if iter = null and self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null then
		iter := self.myCurrentVessel.myCellularVesselStructure.allTanks.createIterator;
	endif;
	if iter = null then
		return;
	endif;*/

	//cnwrd1 31874
	if self.myCurrentVoyage &lt;&gt; null then
		aVoyageStructure := self.myCurrentVoyage.getMyPrimayVoyageStructure;
		
		if aVoyageStructure &lt;&gt; null then
			iter := aVoyageStructure.allTanks.createIterator;
		endif;
	endif;
	
	
	if iter = null and self.myCurrentVessel &lt;&gt; null then
		aVesselStructure := self.myCurrentVessel.getMyPrimaryVesselStructure;
		
		if aVesselStructure &lt;&gt; null then
			iter := aVesselStructure.allTanks.createIterator;
		endif;
	endif;
	
	if iter = null then
		return;
	endif;
	
	while iter.next(tank) do
		str := tank.getAttributeStringForDefArray(self.tblTanks.allTblDataEntRows);
		self.tblTanks.addItemObject(tank,str);
	endwhile;
	
	
epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblWPOpHrs" id="af6964c4-0978-4d95-b0c4-97516ae64286">
        <source>loadTblWPOpHrs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	obj : Object;	
	dynaDict : DynaDictionary;

begin

	self.tblWPOpHrs.rows := 1;

	if self.myCurrentVoyage = null or self.myCurrentVoyage.allWorkPointOperatingHours.isEmpty then
		return;
	endif;
	
	create dynaDict transient;
	dynaDict.setMembership( CM_WorkPointOperatingHours );
	dynaDict.addMemberKey( CM_WorkPointOperatingHours::craneWorkPointId.name, false, true );
	dynaDict.addMemberKey( CM_WorkPointOperatingHours::exchangeStart.name, false, true );
	dynaDict.endKeys(true);	

	self.myCurrentVoyage.allWorkPointOperatingHours.copy(dynaDict);
	iter := dynaDict.createIterator;
	
	while iter.next( obj ) do
		opHr := obj.CM_WorkPointOperatingHours;
		self.tblWPOpHrs.addItemObject(opHr, opHr.getAttributeStringForDefArray(self.tblWPOpHrs.allTblDataEntRows));
	endwhile;
	
epilog

	delete iter;
	delete dynaDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTidalClassTbl" id="b04f78e0-b3e7-442c-b4c3-304721b204b7">
        <source>loadTidalClassTbl();

vars
	tmpTable	: CM_DataTable;
 	count		: Integer;
 	tidalClass	: HMS_TidalClass;
begin

	// Arrival tidal class	
	tmpTable := self.tblCurrentsArriv;
	// Set entries in "Values" column
	tmpTable.column := 2;
	tidalClass := self.cmbTidalClassAr.listObject.HMS_TidalClass;
	count := 1;
	while count &lt;= 4 do
		tmpTable.row := count+1;
		if tidalClass &lt;&gt; null then
			tmpTable.text := tidalClass.allMaximumCurrents[count].asStringJMT;
		else
			tmpTable.text := null;
		endif;
		count := count+1;
	endwhile;
	
	// Departure tidal class
	tmpTable := self.tblCurrentsDepar;
	// Set entries in "Values" column
	tmpTable.column := 2;
	tidalClass := self.cmbTidalClassDpt.listObject.HMS_TidalClass;
	count := 1;
	while count &lt;= 4 do
		tmpTable.row := count+1;
		if tidalClass &lt;&gt; null then			
			tmpTable.text := tidalClass.allMaximumCurrents[count].asStringJMT;
		else
			tmpTable.text := null;
		endif;
		count := count+1;
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadVoyageCutoffsToTable" id="bad04139-ca5e-4a95-b5d6-961c525155ed">
        <updating/>
        <source>loadVoyageCutoffsToTable(_voyage : CM_Voyage) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2025
ADO - JIRA 34524
*/

vars
	recCutoff	 		: CM_ReceivalCutoffVoyage;
	recCutoffDef		: CM_ReceivalCutoffTermDef;
	sortedList			: CM_ReceivalCutoffBySortCode;
	table				: CM_DataTable;
	sortKey : Integer;
	codeKey : String;
	iter : Iterator;
begin


	table := self.tblVoyageCutoffs;
	table.rows := table.fixedRows;
	table.visible := true;
	
	// insert operator column if required and not already added
	if not self.hasOperatorColumn and _voyage &lt;&gt; null then
		foreach recCutoff in _voyage.allReceivalCutoffs do
			if recCutoff.myOperator &lt;&gt; null then
				self.hasOperatorColumn := true;
				table.insertColumn(TblRecCutoffsCol_EarliestHrs);
				table.accessCell(2,2).text := app.getErrorString(Operator);
				table.inputType 	:= table.InputType_None;
				break;
			endif;
		endforeach;
	endif;
	

	create sortedList transient;
		
	foreach recCutoff in self.allProxyCutoffs do 
		recCutoffDef := recCutoff.myReceivalCutoffTermDef;
		sortKey := 0;
		
		if recCutoffDef &lt;&gt; null then
			sortKey := recCutoffDef.sortKey;
		endif;
		
		codeKey := recCutoff.code;
		
		sortedList.putAtKey(sortKey,codeKey,recCutoff);
	
	endforeach;
	
	iter := sortedList.createIterator();
	
	while iter.next(recCutoff) do
		self.loadRecCutoffsToTable(recCutoff);
	endwhile;
		
	
epilog
	delete sortedList;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="loadVoyageCutoffsToTableOp" id="1bd035a9-3169-47a1-bfe0-a359263cff59">
        <updating/>
        <source>loadVoyageCutoffsToTableOp(_operator : CM_Operator) updating;
/*
Purpose:	

Date		Who		Reason
09 April 2025	navab1	JIRA 34524
*/

vars
	recCutoff : CM_ReceivalCutoffVoyage;
	table				: CM_DataTable;
begin
	// check if already done for this operator
	foreach recCutoff in self.allProxyCutoffs do
		if recCutoff.myOperator &lt;&gt; null then
			if recCutoff.myOperator = _operator then
				return;
			endif;
		endif;
	endforeach;
	
	table := self.tblVoyageCutoffs;

	self.createProxyCutoffsForOperator(self.myCurrentVoyage, _operator);
	
	if not self.hasOperatorColumn then
		self.hasOperatorColumn := true;
		table.insertColumn(TblRecCutoffsCol_EarliestHrs);
		table.inputType 	:= table.InputType_None;
		table.accessCell(2,2).text := app.getErrorString(Operator);
	endif;
	
	self.loadVoyageCutoffsToTable(self.myCurrentVoyage);
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
