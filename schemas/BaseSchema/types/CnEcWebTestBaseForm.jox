// --------------------------------------------------------------------------------
begin
	self.doMoveControls();
end;</source>
    </JadeMethod>
    <JadeMethod name="statusMsg" id="10673638-f04f-4a76-8989-966c28f9e8ce">
        <source>statusMsg(pMessage: String) protected;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Purpose:		Displays a message on the status bar, and sets/resets the cursor (Busy/Idle).
//
// Parameters:	String - The message to be displayed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pMessage.trimBlanks = null) then
		picBusy.visible			:=	false;
		picReady.visible		:=	true;
		staStatusLine.caption	:=	"Ready.";
		app.mousePointer		:=	Idle;
	else
		app.mousePointer		:=	Busy;
		picReady.visible		:=	false;
		picBusy.visible			:=	true;
		staStatusLine.caption	:=	pMessage;
		picBusy.refreshNow();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="4fbc4ae7-4de1-498c-b630-363b602699ab">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		15 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doLoadRemoteClientList();
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="872faae3-e807-47dc-a751-2e4fda4cff8c">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars
	date	: Date;
	time	: Time;

begin
	lblCurrentTime.caption	:=	" " &amp; date.format("dd/MM/yyyy") &amp; ",  " &amp; time.format("hh:mm:ss");
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
