    <JadeMethod name="validateMe" id="73492a79-ff4f-49c9-b811-3e1ffdcbef44">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 june 2022 navtnr20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	if self.myVehicleBookingSlotType = null then
		app.raiseCMException(Vehicle_booking_termina_refere, null, null);
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTransient" id="a30a256e-a6b7-4078-9647-91d9931bb2e5">
        <source>validateTransient():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navhl20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	if self.allCriteria.isEmpty then
		return app.getErrorString(No_Criteria_values_selected);
	endif;
	
	if self.myVehicleBookingSlotType = null then
		return app.getErrorString(Vehiclebooking_ref_not);
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
