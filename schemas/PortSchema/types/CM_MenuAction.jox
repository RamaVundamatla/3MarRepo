    <JadeMethod name="setFromMenuDtl" id="69a3250c-c6e1-41c0-b31c-ac90c447ebc2">
        <updating/>
        <source>setFromMenuDtl(_userDtl : CM_MenuUserDtl; _menuDtl : CM_MenuDtlNav) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.attr1			:= _menuDtl.attr1;
	self.extraTableDef	:= _menuDtl.extraTableDef;
	self.level			:= _userDtl.level + 1;
	self.mainTableDef	:= _menuDtl.mainTableDef;
	self.myMenuDtl		:= _menuDtl;
	self.myMenuUserDtl	:= _userDtl;
	self.myParent		:= _userDtl;
	self.myTerminal		:= _userDtl.getMyTerminal();
	self.param1			:= _menuDtl.param1;

end;</source>
        <Parameter name="_userDtl" type="CM_MenuUserDtl"/>
        <Parameter name="_menuDtl" type="CM_MenuDtlNav"/>
    </JadeMethod>
    <JadeMethod name="setFromSubSchema" id="442c43e3-a4e9-4990-96e9-71ff57f6a37f">
        <updating/>
        <source>setFromSubSchema(_parent : CM_MenuEntity; _mainTableDef, _extraTableDef : String) updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.extraTableDef	:= _extraTableDef;
	self.level			:= _parent.getLevel() + 1;
	self.mainTableDef	:= _mainTableDef;
//	self.myMenuDtl		:= _menuDtl;
//	self.myMenuUserDtl	:= _userDtl;
	self.myParent		:= _parent;
	self.myTerminal		:= _parent.getMyTerminal();

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_mainTableDef" type="String"/>
        <Parameter name="_extraTableDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHeading" id="1c8c444c-6370-4360-8a02-df746fcbf2ad">
        <updating/>
        <source>setHeading(_heading : String) updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.heading := _heading[1:60]; // TFS 3009 increased to 60

end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
