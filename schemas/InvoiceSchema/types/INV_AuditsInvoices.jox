    <JadeMethod name="doNotableClear" id="bb278034-403f-4754-bc9e-ad57fdce150a">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="bbe6f3c8-a564-4ab2-b0ea-b86b1859f6e6">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	finIO : CM_ExtFinanceIO;
begin
	if self.myCurrentInvoice &lt;&gt; null or self.myCurrentInvoiceLine &lt;&gt; null then
		if app.isDevelopmentSystem then
//			if app.msgBox("Click 'Yes' to print POE, 'No' for WLG else 'Cancel' for Default.","Choose Invoice",MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then	// cnwrl1 06/05/2009 PAR 19320 - what it was
			if app.msgBox(	app.getErrorString( Print_POE_WLG_Or_Cancel ),
							app.getErrorString( Choose_Invoice ),
							MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon ) = MsgBox_Return_Yes then
				finIO := CM_NAVPOE.firstInstance;
			else
				finIO := CM_Greentree.firstInstance;
			endif;		
		else
			finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		endif;
		if  finIO.class = CM_NAVPOE then
			self.doPrintPOE();
		elseif finIO.class = CM_Greentree then
			self.doPrintWLG();
		else
			self.doPrintDefault();
		endif;
	else
		self.doPrintOutTable(self.tblData,self.caption, true, false, false,false);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintDefault" id="a74912c3-e37b-4f30-abab-619b8af1fc54">
        <source>doPrintDefault();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	Invoice_Label_Width = 250;
	Before_Description_Spacing = 15;
	After_Description_Spacing = 8;
vars
	ar:    INV_PlainAuditReport; 
	pd:    CMS_Progress;
	date:  Date;
	audit: CM_Audit;
	now:   TimeStamp;
	i:     Integer;
	tmpJadeReport  : JadeReport;
	theInvoice : CM_Invoice; 
begin

	app.mousePointer := MP_HOURGLASS;
	theInvoice := self.myCurrentInvoice;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	if theInvoice = null then
		theInvoice := self.myCurrentInvoiceLine.invoice;
	endif;
	
	if theInvoice = null then
		return;
	endif;
	
	
	create tmpJadeReport transient;
	tmpJadeReport.description := app.getErrorString(INV_Audit_Review_Invoice) &amp; theInvoice.sequenceNum.String;
	app.printer.setReport(tmpJadeReport);
	app.printer.setMargins(Print_Portrait,10,10,10,10);
	app.printer.suppressDialog := true;

	create ar;
	ar.picLogoCompany.picture := app.getPicLogoPort();
	ar.picLogoJMT.picture := app.getPicLogoProduct();
	// setup header information
	ar.lblDebtor.caption := theInvoice.debtor.name;

	if theInvoice.toDT.isValid then
		// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		ar.lblInvoiceDate.caption := self.systemToLocalTime(theInvoice.toDT).date.shortFormatJMT();
	else
		ar.lblInvoiceDate.caption := app.getErrorString(INV_Date_To_Be_Given);
	endif;

	ar.lblInvoice.caption := app.getErrorString(INV_Invoice_No) &amp; theInvoice.sequenceNum.String &amp; "  " &amp; theInvoice.invoiceType.getInvoiceString(theInvoice) &amp; ".";
	ar.lblInvoice.width := Invoice_Label_Width;

	// set header
	app.printer.setHeader(ar.frHeader);

	// AKB PAR 1477 added, from here 
	// Setup Footer
	ar.lblTheDatePrinted.caption :=  now.String;
	ar.lblTheUser.caption := app.getMyUser.userName;
	//Set Footer
	app.printer.setFooter(ar.frFooter);
	// AKB PAR 1477 to here
	
	ar.lblTheUser.caption := app.getMyUserCode;
	app.printer.setFooter(ar.frFooter);

	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction(app.getErrorString(INV_Printing_Audit_Report));


	if theInvoice.unqualifiedAudits.size &gt; 0 then
		ar.lblDescription.caption := app.getErrorString(INV_Unqualified_Audits);
		ar.frSubHeader.height := ar.lblDescription.height + After_Description_Spacing;

		app.printer.print(ar.frSubHeader);

		pd.progress.partsInJob := theInvoice.unqualifiedAudits.size;
		pd.setAction(app.getErrorString(INV_Printing_Unqualified));

		i := 0;
		foreach audit in theInvoice.unqualifiedAudits do
			ar.printAudit(audit, false);
			i := i + 1;
			pd.progress.partsDone := i;
			pd.doWindowEvents(0);
			if pd.aborted then
				app.printer.abort;
				return;
			endif;
		endforeach;
	endif;

	if theInvoice.qualifiedAudits.size &gt; 0 then
		ar.lblDescription.caption := app.getErrorString(INV_Qualified_Audits);
		if theInvoice.unqualifiedAudits.size &gt; 0 then
			ar.lblDescription.top := After_Description_Spacing;
			ar.frSubHeader.height := After_Description_Spacing +
									 ar.lblDescription.height +
									 After_Description_Spacing;
		else
			ar.frSubHeader.height := ar.lblDescription.height + After_Description_Spacing;
		endif;

		app.printer.print(ar.frSubHeader);

		pd.setAction(app.getErrorString(INV_Printing_Qualified_Audits));
		pd.progress.partsInJob := theInvoice.qualifiedAudits.size;

		i := 0;
		foreach audit in theInvoice.qualifiedAudits do
			ar.printAudit(audit, true);
			i := i + 1;
			pd.progress.partsDone := i;
			pd.doWindowEvents(0);
			if pd.aborted then
				app.printer.abort;
				return;
			endif;
		endforeach;
	endif;

	app.printPreview(tmpJadeReport, true);

epilog
	app.printer.close;
	delete ar;
	delete pd;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintPOE" id="f078c176-e2e5-43f0-89f8-90ea9ff3f9a5">
        <source>doPrintPOE();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ar : INV_AuditReport;
	pd : CMS_Progress;
	date : Date;
	audit : CM_Audit;
	now : TimeStamp;
	index : Integer;
	tmpJadeReport  : JadeReport;
	theInvoice : CM_Invoice; 
begin

	app.mousePointer := MP_HOURGLASS;
	theInvoice := self.myCurrentInvoice;
	
	if theInvoice = null then
		theInvoice := self.myCurrentInvoiceLine.invoice;
	endif;
	
	if theInvoice = null then
		return;
	endif;
	
	create tmpJadeReport transient;
	tmpJadeReport.description := app.getErrorString(INV_Audit_Review_Invoice) &amp; theInvoice.sequenceNum.String;
	app.printer.setReport(tmpJadeReport);


	app.printer.setMargins(Print_Portrait,10,10,10,10);
	app.printer.suppressDialog := true;

	create ar;

	ar.picLogoCompany.picture := app.getPicLogoPort();
	ar.picLogoJMT.picture := app.getPicLogoProduct();

	if theInvoice.unqualifiedAudits.isEmpty and theInvoice.qualifiedAudits.isEmpty then
		ar.txtHeaderLeft.text := app.getErrorString(INV_Audit_Report);
	elseif not theInvoice.unqualifiedAudits.isEmpty then
		ar.txtHeaderLeft.text := app.getErrorString(INV_Unqualified_Audit_Report);
	elseif not theInvoice.qualifiedAudits.isEmpty then
		ar.txtHeaderLeft.text := app.getErrorString(INV_Qualified_Audit_Report);
	endif;

	app.printer.setHeader(ar.fHeader);
	
	now := self.systemToLocalTime(app.actualTimeServer);// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	ar.txtFooterLeft.text := app.getErrorString(INV_Print_Time) &amp; now.String;
	app.printer.setFooter(ar.fFooter);

	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction(app.getErrorString(INV_Printing_Audit_Report));
	ar.label2.caption := ar.txtHeaderLeft.text;
	ar.txtUserCode.text := app.getMyUser.userName;
	date := self.systemToLocalTime(app.actualTimeServer).date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	ar.txtReportDate.text := date.String;

	app.printer.print(ar.fTitleSep);
	app.printer.print(ar.fTitle);
	app.printer.print(ar.fTitleSep);

	ar.txtHeading1.text := app.getErrorString(INV_Invoice_No) &amp; theInvoice.sequenceNum.String;
	app.printer.print(ar.fHeading1);

	ar.txtAttribute.text := app.getErrorString(INV_Debtor);
	ar.lblValue.caption := theInvoice.debtor.name;
	app.printer.print(ar.fAttribute);

	ar.txtAttribute.text := app.getErrorString(SequenceNumber);
	ar.lblValue.caption := theInvoice.sequenceNum.String;
	app.printer.print(ar.fAttribute);

	ar.txtAttribute.text := app.getErrorString(Status);
	if theInvoice.isPosted then
		ar.lblValue.caption := app.getInvoiceStatusString(theInvoice.getMyInvoiceProcess, CM_Invoice.INVOICE_POSTED); //app.getErrorString(Posted); // TFS 39618
	elseif theInvoice.status = CM_Invoice.INVOICE_PENDING then
		ar.lblValue.caption := app.getInvoiceStatusString(theInvoice.getMyInvoiceProcess, CM_Invoice.INVOICE_PENDING); //app.getErrorString(Pending); // TFS 39618
	elseif theInvoice.status = CM_Invoice.INVOICE_OPEN then
		ar.lblValue.caption := app.getInvoiceStatusString(theInvoice.getMyInvoiceProcess, CM_Invoice.INVOICE_OPEN); //app.getErrorString(Open_GC); // TFS 39618
	elseif theInvoice.isVoided then
		ar.lblValue.caption := app.getInvoiceStatusString(theInvoice.getMyInvoiceProcess, CM_Invoice.INVOICE_VOID); //app.getErrorString(Void); // TFS 39618
	else	//04 Sep 2017	NDL	TFS 6759
		ar.lblValue.caption := app.getInvoiceStatusString(theInvoice.getMyInvoiceProcess, theInvoice.status); // TFS 39618
	endif;

	app.printer.print(ar.fAttribute);

	ar.txtAttribute.text := app.getErrorString(INV_Opened_On);
	ar.lblValue.caption := theInvoice.fromDT.String;
	app.printer.print(ar.fAttribute);

	ar.txtAttribute.text := app.getErrorString(NumberOfItems);
	ar.lblValue.caption := theInvoice.invoiceLines.size.String;
	app.printer.print(ar.fAttribute);

	app.printer.print(ar.fAttributeSep);

	pd.progress.partsInJob := theInvoice.unqualifiedAudits.size;

	ar.txtHeading2.text := app.getErrorString(INV_Unqualified_Audits);
	app.printer.print(ar.fHeading2);
	app.printer.print(ar.fAttributeSep);

	pd.setAction(app.getErrorString(INV_Printing_Unqualified));
	index := 0;
	foreach audit in theInvoice.unqualifiedAudits do
		if audit.isKindOf(CM_AuditTIEdit) then
			ar.printAuditTIEdit(audit.CM_AuditTIEdit);
		endif;
		index := index + 1;
		pd.progress.partsDone := index;
		pd.doWindowEvents(0);
		if pd.aborted then
			app.printer.abort;
			return;
		endif;
	endforeach;

	pd.setAction(app.getErrorString(INV_Printing_Qualified_Audits));
	ar.txtHeading2.text := app.getErrorString(INV_Qualified_Audits);
	app.printer.print(ar.fHeading2);
	app.printer.print(ar.fAttributeSep);

	pd.progress.partsInJob := theInvoice.qualifiedAudits.size;
	index := 0;
	foreach audit in theInvoice.qualifiedAudits do
		if audit.isKindOf(CM_AuditTIEdit) then
			ar.printAuditTIEdit(audit.CM_AuditTIEdit);
		endif;
		index := index + 1;
		pd.progress.partsDone := index;
		pd.doWindowEvents(0);
		if pd.aborted then
			app.printer.abort;
			return;
		endif;
	endforeach;

	app.printPreview(tmpJadeReport, true);

epilog
	app.printer.close;
	delete ar;
	delete pd;
	app.mousePointer := MP_DEFAULT;


end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintWLG" id="65df4c8c-a47f-4edb-879b-41fb871841c8">
        <source>doPrintWLG();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants


	Invoice_Label_Width = 250;
	Before_Description_Spacing = 15;
	After_Description_Spacing = 8;
vars
	ar:    INV_PlainAuditReport;
	pd:    CMS_Progress;
	date:  Date;
	audit: CM_Audit;
	now:   TimeStamp;
	i:     Integer;
	tmpJadeReport  : JadeReport;
	theInvoice : CM_Invoice; 
begin

	app.mousePointer := MP_HOURGLASS;
	theInvoice := self.myCurrentInvoice;
	
	if theInvoice = null then
		theInvoice := self.myCurrentInvoiceLine.invoice;
	endif;
	
	if theInvoice = null then
		return;
	endif;
	
	create tmpJadeReport transient;

	tmpJadeReport.description := app.getErrorString(INV_Audit_Review_Invoice) &amp; theInvoice.sequenceNum.String;
	app.printer.setReport(tmpJadeReport);

	app.printer.setMargins(Print_Portrait,10,10,10,10);
	app.printer.suppressDialog := true;

	create ar;
	ar.picLogoCompany.picture := app.getPicLogoPort();
	ar.picLogoJMT.picture := app.getPicLogoProduct();
	// setup header information
	ar.lblDebtor.caption := theInvoice.debtor.name;

	if theInvoice.toDT.isValid then
		ar.lblInvoiceDate.caption := theInvoice.toDT.date.shortFormatJMT();
	else
		ar.lblInvoiceDate.caption := app.getErrorString(INV_Date_To_Be_Given);
	endif;

	ar.lblInvoice.caption := app.getErrorString(INV_Invoice_No) &amp; theInvoice.sequenceNum.String &amp; "  " &amp; theInvoice.invoiceType.getInvoiceString(theInvoice) &amp; ".";
	ar.lblInvoice.width := Invoice_Label_Width;

	// set header
	app.printer.setHeader(ar.frHeader);

	// AKB PAR 1477 added, from here 
	// Setup Footer
	now := self.systemToLocalTime(app.actualTimeServer);// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	ar.lblTheDatePrinted.caption := now.String;
	// AKB PAR 1477 to here

	ar.lblTheUser.caption := app.getMyUserCode;
	app.printer.setFooter(ar.frFooter);

	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction(app.getErrorString(INV_Printing_Audit_Report) );


	if theInvoice.unqualifiedAudits.size &gt; 0 then
		ar.lblDescription.caption := app.getErrorString(INV_Unqualified_Audits);
		ar.frSubHeader.height := ar.lblDescription.height + After_Description_Spacing;

		app.printer.print(ar.frSubHeader);

		pd.progress.partsInJob := theInvoice.unqualifiedAudits.size;
		pd.setAction(app.getErrorString(INV_Printing_Unqualified));

		i := 0;
		foreach audit in theInvoice.unqualifiedAudits do
			ar.printAudit(audit, false);
			i := i + 1;
			pd.progress.partsDone := i;
			pd.doWindowEvents(0);
			if pd.aborted then
				app.printer.abort;
				return;
			endif;
		endforeach;
	endif;

	if theInvoice.qualifiedAudits.size &gt; 0 then
		ar.lblDescription.caption := app.getErrorString(INV_Qualified_Audits);
		if theInvoice.unqualifiedAudits.size &gt; 0 then
			ar.lblDescription.top := After_Description_Spacing;
			ar.frSubHeader.height := After_Description_Spacing +
									 ar.lblDescription.height +
									 After_Description_Spacing;
		else
			ar.frSubHeader.height := ar.lblDescription.height + After_Description_Spacing;
		endif;

		app.printer.print(ar.frSubHeader);

		pd.setAction(app.getErrorString(INV_Printing_Qualified_Audits));
		pd.progress.partsInJob := theInvoice.qualifiedAudits.size;

		i := 0;
		foreach audit in theInvoice.qualifiedAudits do
			ar.printAudit(audit, true);
			i := i + 1;
			pd.progress.partsDone := i;
			pd.doWindowEvents(0);
			if pd.aborted then
				app.printer.abort;
				return;
			endif;
		endforeach;
	endif;

	app.printPreview(tmpJadeReport, true);

epilog
	app.printer.close;
	delete ar;
	delete pd;
	app.mousePointer := MP_DEFAULT;


end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="d0558ce9-9130-4d0e-ad78-2a876a1bd50c">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable 				: CM_DataTable;
	theAudits :	CM_AuditBySeqNumDict;
	audit:  CM_Audit;
	row:    Integer;
	rate : CM_Rate;
	theCaption : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblInfo.rows := 0;
	theTable := self.tblData;
	theTable.rows := theTable.fixedRows;
	self.myCurrentAudit := null;
	
	create theAudits transient;

	self.btnPrint.visible := true;
	
	if self.myCurrentRate &lt;&gt; null then
//		self.btnPrint.visible := false;
		if self.mode = Mode_Unqualified then
			foreach audit in self.myCurrentRate.unqualifiedAudits discreteLock, reversed do
				theAudits.add(audit);
			endforeach;
		else
			foreach audit in self.myCurrentRate.qualifiedAudits discreteLock, reversed do
				theAudits.add(audit);
			endforeach;
		endif;
	elseif self.myCurrentRateEntry &lt;&gt; null then
		if self.mode = Mode_Unqualified then
			foreach audit in self.myCurrentRateEntry.unqualifiedAudits discreteLock, reversed do
				theAudits.add(audit);
			endforeach;
		else
			foreach audit in self.myCurrentRateEntry.qualifiedAudits discreteLock, reversed do
				theAudits.add(audit);
			endforeach;
		endif;
	elseif self.myCurrentService &lt;&gt; null then
//		self.btnPrint.visible := false;
		foreach rate in self.myCurrentService.debtorNodeRates discreteLock, reversed do
			if theCaption = null then
				self.serviceCaption := rate.getCode();
			endif;
			if self.mode = Mode_Unqualified then
				foreach audit in rate.unqualifiedAudits discreteLock, reversed do
					theAudits.add(audit);
				endforeach;
			else
				foreach audit in rate.qualifiedAudits discreteLock, reversed do
					theAudits.add(audit);
				endforeach;
			endif;
		endforeach;
	elseif self.myCurrentInvoice &lt;&gt; null then
		if self.mode = Mode_Unqualified then
			foreach audit in self.myCurrentInvoice.unqualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		else
			foreach audit in self.myCurrentInvoice.qualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		endif;
	elseif self.myCurrentInvoiceLine &lt;&gt; null then
		if self.mode = Mode_Unqualified then
			foreach audit in self.myCurrentInvoiceLine.unqualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		else
			foreach audit in self.myCurrentInvoiceLine.qualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		endif;
	elseif self.myCurrentCashPayment &lt;&gt; null then
		if self.mode = Mode_Unqualified then
			foreach audit in self.myCurrentCashPayment.unqualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		else
			foreach audit in self.myCurrentCashPayment.qualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		endif;
	elseif self.myCurrentCashReceipt &lt;&gt; null then		// 34227 cash receipt audit
		if self.mode = Mode_Unqualified then
			foreach audit in self.myCurrentCashReceipt.unqualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		else
			foreach audit in self.myCurrentCashReceipt.qualifiedAudits discreteLock do
				theAudits.add(audit);
			endforeach;
		endif;
	endif;

	foreach audit in theAudits discreteLock do
		self.doQueryAddItem(audit);
	endforeach;
	self.setMyCaption();
//	inheritMethod(); do not need. This will show the Searcher frame if no audits.

epilog
	delete theAudits;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="2b4b0c90-f495-4a3b-9d48-a3589dc2f755">
        <updating/>
        <source>doQueryAddItem(_theAudit : CM_Audit) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theDataLine : String;
	idx : Integer;
begin
		
	theDataLine := _theAudit.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

	idx := self.tblData.addItem(theDataLine);
	self.tblData.accessRow(idx).itemObject := _theAudit;
	// setup note for this item
//	self.doNotableAdd(_theAudit);

end;</source>
        <Parameter name="_theAudit" type="CM_Audit"/>
    </JadeMethod>
    <JadeMethod name="doSaveQualify" id="09e7aad1-d47b-4684-be93-252c0db3674f">
        <updating/>
        <source>doSaveQualify() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theAQC : CMIF_AuditQualifyController;
	anAudit, proxyAudit : CM_Audit;
	anObject : Object;
	idx, rowStart, rowEnd,theReturn : Integer;
begin
	create theAQC transient;
	theAQC.clearingRemarks := self.txtQualifyRemark.text;
	theAQC.myFinancialObject := self.myCurrentInvoice;
	
	
	if self.myCurrentAudit &lt;&gt; null then
		proxyAudit := app.createUpdateProxy(self.myCurrentAudit).CM_Audit;
		proxyAudit.clearingRemarks := self.txtQualifyRemark.text[1:60];
		theAQC.allAuditsToQualify.add(proxyAudit);
	else
		rowStart := self.tblData.fixedRows + 1;
		rowEnd := self.tblData.rows;
		foreach idx in rowStart to rowEnd do
			anAudit := self.tblData.accessRow(idx).itemObject.CM_Audit;
			proxyAudit := app.createUpdateProxy(anAudit).CM_Audit;
			proxyAudit.clearingRemarks := self.txtQualifyRemark.text[1:60];
			theAQC.allAuditsToQualify.add(proxyAudit);
		endforeach;
		
		if rowEnd = 1 then
			app.msgBox("No Audits to Qualify.","Qualify Audits",MsgBox_OK_Only);
			self.frmQualify.visible := false;
			return;
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateAuditQualify(theAQC,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.doQuery();
			global.beep;
			self.frmQualify.visible := false;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	foreach proxyAudit in theAQC.allAuditsToQualify do
		delete proxyAudit;
	endforeach;
	delete theAQC;
end;</source>
    </JadeMethod>
