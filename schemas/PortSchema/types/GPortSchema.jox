    <JadeMethod name="getAllServerPrinters" id="727578a5-6397-493b-920c-a574568c19e3">
        <executionLocation>server</executionLocation>
        <source>getAllServerPrinters(_printerArray : CnStringArray io) serverExecution;
// copy of cnEcGetAllServerPrinters using CnStringArray for longer printer names
// for 32305 Aug 2013
begin
	if (not _printerArray = null) then
		app.printer.getAllPrinters(_printerArray);
