    <JadeMethod name="hasNZCSClearance" id="1cda73b8-7d7e-488a-bd4c-9d9afa83c8fd">
        <source>hasNZCSClearance() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 August 2018	jlgsl4	TFS 39133 - Trade Single Window
31 October 2018	jlgsl4	TFS 39133 - new response codes; C07 is export only
*/

vars

begin
	return self.responseStatus = NZCS_Clearance_1 or self.responseStatus = NZCS_Clearance_2 or self.responseStatus = NZCS_Clearance_3
		or self.responseStatus = NZCS_Clearance_4 or self.responseStatus = NZCS_Clearance_5 or self.responseStatus = NZCS_QualifiedClearance_1
		or (self.responseStatus = NZCS_Clearance_6 and isValidTSWMessage()) or (self.responseStatus = NZCS_Clearance_7 and self.isTSWExport); // TFS 39133 - 16/08/18 - 31/10/18
epilog

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
