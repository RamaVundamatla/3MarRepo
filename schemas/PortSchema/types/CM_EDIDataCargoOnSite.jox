    <JadeMethod name="isTransportManifestRelated" id="d2a3e909-9d34-4b72-8c77-aab2c38ee607">
        <source>isTransportManifestRelated(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint

*/

vars

begin
	if self.myTransportManifest &lt;&gt; null then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
