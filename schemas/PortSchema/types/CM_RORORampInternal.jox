<Class name="CM_RORORampInternal" id="1ab47fcb-fae4-48f9-ad21-52c637fbb97d">
    <superclass name="CM_RORORamp"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <JadeMethod name="cloneMySelf" id="916120cf-02c7-4f8f-85bd-88fe63b02c58">
        <source>cloneMySelf(_newDeck : CM_Deck; _copy : Boolean) : CM_RORORampInternal;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : SelfType;
begin
	newMe := self.cloneSelf(_copy);


	newMe.myDeck := _newDeck;
	
	if self.myLayout &lt;&gt; null then
		newMe.myLayout := self.myLayout.cloneMySelf(newMe, newMe.getLayer(), _copy);
	endif;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newDeck" type="CM_Deck"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_RORORampInternal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="94cd4c05-d791-45ea-94c4-ccef04747817">
        <updating/>
        <source>setForUpdate(_proxyRORORamp: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	beforeAuditText,afterAuditText : String;
	
begin
	if self.myDeck &lt;&gt; null then
		beforeAuditText:=self.myDeck.getAuditText();
	endif;
	
	inheritMethod(_proxyRORORamp, _passport);

	if self.myDeck &lt;&gt; null then
	//CCMS 1116 added auditing - attached audits to vesssel
		afterAuditText:=self.myDeck.getAuditText;
		app.myAA.auditUpdateTrx(self.myDeck,beforeAuditText, afterAuditText);
	endif;
epilog

end;</source>
        <Parameter name="_proxyRORORamp" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
