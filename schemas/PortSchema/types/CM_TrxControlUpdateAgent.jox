    <JadeMethod name="trxUpdateTIHazards" id="7d56ad66-12e4-45bd-9171-8509e2e6db5c">
        <updating/>
        <source>trxUpdateTIHazards(	_realTI: CM_TrackedItem input;
					_tiHazDict : CM_HazardByCodeDict input;
					_passport : CM_Passport input ) updating;
//
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _realTI = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'BOL In', null, null);
		return;
	endif;

	// Start the transaction
	beginTransaction;

	app.myUtilityUA.utlUpdateTIHazards(_realTI, _tiHazDict, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tiHazDict" type="CM_HazardByCodeDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
