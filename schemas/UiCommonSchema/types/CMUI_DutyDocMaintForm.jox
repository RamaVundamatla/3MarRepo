    <JadeMethod name="btnDeleteCargo_click" id="8f25eea2-f4ce-4000-b152-5fe854578f3e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteCargo_click(btn: Button input) updating;
// Remove (not delete) this duty item from the duty doc. TO delete need to go to Duty Item Maintenance
// 04/08/2014 cnwma1  cnwma1 PAR 34408 Credit Customer current charges
//07 Jun 2016	cnwrs1	TFS2107 round all values to this field
vars

	dutyDocItem, pxyDutyDocItem : CM_DutyDocItem;
	row : Integer;
	theReturn : Integer;
	invoiceLine : CM_InvoiceLine; 			
	invoiceStatus	: CMIF_InvoiceStatus;   
	pxyInvoiceLine	: CM_InvoiceLine; 		
	release : CM_BulkRelease;
	tiSet			: CM_TISet;
	ti: CM_TrackedItem;
	docItem :CM_DutyDocItem;
	docItemSet : CM_DutyDocItemSet;
	txnSet : CM_TITransactionSet;
	txn : CM_TITransaction;
	invoiceLineSet : CM_InvoiceLineSet;
	ls: Boolean;
begin

	row := self.tblDutyDocItems.row;
	if row &gt; self.tblDutyDocItems.fixedRows and row &lt;= self.tblDutyDocItems.rows then
		dutyDocItem := self.tblDutyDocItems.accessRow(row).itemObject.CM_DutyDocItem;
	endif;

	if dutyDocItem = null then
		return;
	endif;
	
	ti:= dutyDocItem.getMyTrackedItem;
	while true do
		app.cmsBeginLoad(ls);
			pxyDutyDocItem := dutyDocItem.pxyCreateUpdateProxy().CM_DutyDocItem;
		app.cmsEndLoad(ls);
		//Void Invoice Line
		if self.myDutyDoc.dutyDeposit = 0 then			// cnwma1 31/07/2014 PAR 34408
			create txnSet transient;
			create invoiceLineSet transient;
			txnSet := dutyDocItem.getMyTrackedItem.getTransOfType(TRANS_TYPE_DUTY_CHARGE);
			foreach txn in txnSet do
				if txn.myInvoiceLine &lt;&gt; null then
					if  txn.myInvoiceLine.getRate.roundedTo(4) = pxyDutyDocItem.duty and txn.myInvoiceLine.trackedItem = ti and txn.myInvoiceLine.voided=false then
							invoiceLineSet.addNoDuplicates(txn.myInvoiceLine,false);
					endif;
				endif;
			endforeach;
			invoiceLine := invoiceLineSet.first;
			if invoiceLine &lt;&gt; null then
				create invoiceStatus transient;
				app.cmsBeginLoad(ls);
				pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
				app.cmsEndLoad(ls);
				invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
				invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
				app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
				else
					theReturn := app.showErrorWarningDialog("Invoice Line", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and theReturn = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
			endif;
		endif;
		pxyDutyDocItem.setProxyDutyDoc(null);
		pxyDutyDocItem.setDutyItemValue();
		// Delete Release Request Item from the Release Request			// cnwma1 31/07/2014 PAR 34408
		release :=pxyDutyDocItem.getMyTrackedItem.allBulkReleasesAssigned.last;
		if release &lt;&gt; null then
			create tiSet transient;
			create docItemSet transient;
				foreach  docItem in myDutyDoc.allDutyDocItems  do
					if docItem.cargoId = ti.id  then
						docItemSet.add(docItem);
					 endif;
				endforeach;
			tiSet.add(pxyDutyDocItem.getMyTrackedItem);
			if docItemSet.size &lt; 2 then
				app.myTrxUA.trxUpdateUnassignRelease(tiSet, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
				else
					theReturn := app.showErrorWarningDialog("Bulk Release assignment update", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and theReturn = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
			endif;
		endif;		
		app.myTrxUA.trxUpdateDutyDocItem( pxyDutyDocItem, app.myPassport );      // cnwma1 31/07/2014 PAR 34408
		delete pxyDutyDocItem;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
		else
			theReturn := app.showErrorWarningDialog("Bulk Release assignment update", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		self.loadDutyDocItems();
		break;
	endwhile;

epilog
	app.cmsEndLoad(ls);
	delete pxyDutyDocItem;
	if invoiceStatus &lt;&gt; null then
		invoiceStatus.allInvoiceLines.purge;
	endif;
	delete invoiceStatus;
	delete tiSet;
	delete docItemSet;
	delete invoiceLineSet;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="d770c582-0b5b-4879-9593-372e9fd26a16">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	msgStr			: String;
begin
	if self.myDutyDoc = null then
		return;
	endif;
	
	msgStr := app.getErrorString2(ConfirmDelete, '', self.myDutyDoc.id);
	if app.msgBox(msgStr, 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		if self.doDelete then
			self.unloadForm();
		endif;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEditCargo_click" id="253de04f-db60-4bef-8d95-ff0b752072b4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditCargo_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	dutyItemForm : CMUI_DutyDocItemMaintForm;
	dutyDocItem : CM_DutyDocItem;
	row : Integer;
	allDutyDocItems : CM_DutyDocItemSet;
begin
	
	
	
	if not btn.enabled then
		return;
	endif;
	
	self.doSave(false);
	
	
	//inheritMethod();
	if self.tblDutyDocItems.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create allDutyDocItems transient;
	self.tblDutyDocItems.allSelectedObjects.copy(allDutyDocItems);
	
	dutyDocItem := allDutyDocItems.first; 

	dutyItemForm := app.loadForm(CMUI_DutyDocItemMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DutyDocItemMaintForm;
	dutyItemForm.setBaseData( self.myDutyDoc, dutyDocItem,allDutyDocItems, self );
	dutyItemForm.showModal();
	
	self.setPrintCarVisibility();
	


epilog
	delete allDutyDocItems;
end;</source>
