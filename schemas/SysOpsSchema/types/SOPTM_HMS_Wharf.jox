    <JadeMethod name="setControlsForAddEdit" id="fde7734f-2d49-4184-960a-0a386437e4a6">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	maintFormObj	: SOP_HMS_TableMaintForm;
	
begin
	inheritMethod();
	
	maintFormObj	:=	self.myForm.SOP_HMS_TableMaintForm;
	maintFormObj.tblInput1.userInputEnabled	:=	true;
	
	if maintFormObj.mode = maintFormObj.Mode_Add then
		if maintFormObj.mulSelect1.visible then
			maintFormObj.mulSelect1.setSelected(null);
		endif;
		
		if maintFormObj.mulSelect2.visible then
			maintFormObj.mulSelect2.setSelected(null);
		endif;
		
		maintFormObj.tblInput1.setValueByName(ETRow_DisplayLeftToRight, true);
		maintFormObj.tblInput1.setFocus;
		maintFormObj.tblInput1.moveFirst();
		maintFormObj.tblData1.userInputEnabled	:=	true;
		maintFormObj.fldInput.initSheetBackColors();
	else
		if maintFormObj.mulSelect1.visible then
			maintFormObj.mulSelect1.setSelected(maintFormObj.myProxyObject.HMS_Wharf.allBerths);
		endif;
		
		if maintFormObj.mulSelect2.visible then
			maintFormObj.mulSelect2.setSelected(maintFormObj.myProxyObject.HMS_Wharf.allTerminals);
		endif;
		
		maintFormObj.tblData1.userInputEnabled	:=	true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="cbd0c7f4-b28c-46eb-bf43-a721eb4a86f7">
        <source>setObjectFromTableSpecial(_propName, _strValue : String; _obj : HMS_Wharf input; _table : CM_EntryTable input) : Boolean;
//--------------------------------------------------
// Created:	28 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _propName = ETRow_IsLogicalWharf then
		if _strValue = app.getErrorString(SOP_Logical_Wharf) then
			_obj.setPropertyValue(HMS_Wharf::isLogicalWharf.name, true);		
		else
			_obj.setPropertyValue(HMS_Wharf::isLogicalWharf.name, false);		
		endif;
		return true;
	elseif _propName = ETRow_WaterOnLeft then
		if _strValue = app.getErrorString(SOP_Water_On_Left) then
			_obj.setPropertyValue(HMS_Wharf::waterOnLeft.name, true);		
		else
			_obj.setPropertyValue(HMS_Wharf::waterOnLeft.name, false);		
		endif;
		return true;		
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="HMS_Wharf" usage="input"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="29138461-281b-4fa8-97dc-913ad77dacf1">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2024	navhn30	Initial creation  ChangeRequest 65521: NSW | OnePort Integration - Setting voyage process by wharf

*/

vars
	wharf: HMS_Wharf;
	cmbProcess : CMUI_ComboBox;
begin

	wharf := _obj.HMS_Wharf;
	if _attrName = ETRow_MyDefaultVoyageProcess then
		if wharf.myDefaultVoyageProcess &lt;&gt; null then
			cmbProcess := _tbl.form.SOP_HMS_TableMaintForm.cmbVoyageProcess;
			_tbl.setValue( _row, wharf.myDefaultVoyageProcess.description);
			cmbProcess.listIndex := cmbProcess.findStringExact(1, wharf.myDefaultVoyageProcess.description);
			cmbProcess.lostFocus(cmbProcess);
		endif;
		return true;
	endif;
	return inheritMethod(_tbl, _attrName, _row, _obj);

epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTblData1Rows" id="86581fa0-80f8-473a-bef6-948082ea24cf">
        <source>setTblData1Rows(pObj: HMS_Wharf);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm 			: SOP_HMS_TableMaintForm;
	harbour				: HMS_Harbour;
	arrResource,
	depResource,
	shiftResource		: HMS_Resource;
	resourceForWharf	: HMS_ResourceForWharf;
	tmpDataTable		: CM_DataTable;
	int, idx			: Integer;	
	wharf				: HMS_Wharf;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	
	harbour := theForm.cmbFiltHarbour.listObject.HMS_Harbour;	
	
	tmpDataTable := theForm.tblData1;
	tmpDataTable.userInputEnabled := false;

	tmpDataTable.rows := 1;
	//now add the user terminal security roles	
	
	theForm.allClonedControls.purge();
//	theForm.newIndex := 0;
	
	foreach int in 1 to 2 do
		
		if pObj &lt;&gt; null then 
			
				if pObj.isTransient then  // if transient has all details set to null so table is blank when editing exsisting tug resources. 
				wharf := pObj.pxyGetRealObject();
				else
				wharf := pObj;
				endif;
				
				resourceForWharf := wharf.allResourcesForWharf[harbour,wharf,int];
			
				if resourceForWharf &lt;&gt; null then 
					arrResource := 	resourceForWharf.myArrivalResource;
					depResource := resourceForWharf.myDepartResource;
					shiftResource := resourceForWharf.myShiftResource;
				endif;
		else
				arrResource := 	null;
				depResource := null;
				shiftResource := null;
		endif;

		
		idx := tmpDataTable.addItemObject(harbour,'Resource ' &amp; int.String);

	
		tmpDataTable.accessCell(idx, 2).itemObject := arrResource;
		if arrResource &lt;&gt; null then
			tmpDataTable.accessedCell.text := arrResource.description;
		endif;
			
		tmpDataTable.accessCell(idx, 3).itemObject := depResource;
		if depResource &lt;&gt; null then
			tmpDataTable.accessedCell.text := depResource.description;
		endif;
			
		tmpDataTable.accessCell(idx, 4).itemObject := shiftResource;
		if shiftResource &lt;&gt; null then	
			tmpDataTable.accessedCell.text := shiftResource.description;
		endif;
		
		self.addResourceCombosToTblData1(idx, harbour,arrResource,depResource,shiftResource);

//		tmpDataTable.accessCell(idx, 2).cellControl := theForm.cmbResourceArr;
//		tmpDataTable.accessCell(idx, 3).cellControl := theForm.cmbResourceDep;
//		tmpDataTable.accessCell(idx, 4).cellControl := theForm.cmbResourceShift;
		
	endforeach;
end;</source>
        <Parameter name="pObj" type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="c8c63f00-f532-4d96-a2c4-ffe38638d213">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
// 26.08.24		navhn30		ChangeRequest 65521: NSW | OnePort Integration - Setting voyage process by wharf
//--------------------------------------------------------------
vars
	tableObj		: CM_EntryTable;
	maintFormObj	: SOP_HMS_TableMaintForm;
	comboEntry		: String;
	processHarbours : CM_ProcessHarbourDict;
	processHarbour  : CM_ProcessHarbour;
	voyageProcess   : CM_VoyageProcess;
	voyageProcesses : CM_VoyageProcessByCode;
	
begin
	maintFormObj	:=	self.myForm.SOP_HMS_TableMaintForm;

	inheritMethod();
	maintFormObj.setTblDataEntRows(ETDef_HMSWharf);		//cnwdb2 - 17 April 2014 - PAR 33977

	
	//setup table comboboxes
	tableObj	:=	maintFormObj.tblInput1;	
	comboEntry	:=	app.getErrorString(SOP_Water_On_Left) &amp; Tab &amp; app.getErrorString(SOP_Water_On_Right);

	tableObj.setComboValues(tableObj.getRow(ETRow_WaterOnLeft), comboEntry);

	comboEntry	:=	app.getErrorString(SOP_Physical_Wharf) &amp; Tab &amp; app.getErrorString(SOP_Logical_Wharf);	
	tableObj.setComboValues(tableObj.getRow(ETRow_IsLogicalWharf), comboEntry);	
	
	//26.08.24	 navhn30	TFS 65521 start
	maintFormObj.cmbVoyageProcess.clear();
	maintFormObj.cmbVoyageProcess.addItem(" ");
	processHarbours :=  maintFormObj.myHarbour.allProcessHarbours;
	
	foreach processHarbour in processHarbours do
		if maintFormObj.cmbVoyageProcess.findObject(processHarbour.myVoyageProcess) = -1 then
			maintFormObj.cmbVoyageProcess.addItemObject(processHarbour.myVoyageProcess.description, processHarbour.myVoyageProcess);
		endif;
	endforeach;
	
	voyageProcesses := app.myRoot.allVoyageProcesses;
	if processHarbours.isEmpty then
		foreach voyageProcess in voyageProcesses do
		
			// ### JIRA 33001 03OCT2024 NAVAB1
			if voyageProcess.isAutomaticProcess
			and not app.myRoot.canDo(Mod_VoyageAutoClosure) then
				continue;
			endif;
				
			if maintFormObj.cmbVoyageProcess.findObject(voyageProcess) = -1 then
				maintFormObj.cmbVoyageProcess.addItemObject(voyageProcess.description,voyageProcess);	
			endif;
		endforeach;
	endif;
	//26.08.24	 navhn30	TFS 65521 end

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="88e11c1b-f1d6-4242-9f3a-1b2737474aca">
        <updating/>
        <source>showThumbnail(pObj: HMS_Wharf) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 26/09/2011	cnwcs5	CCMS RIO 2130/Par 28261 - Minimum Residence Time
// 10/11/2011	cnwdap1	PAR #28675 Don't disable the hook code row, this prevents double-click from working
// 26.08.24		navhn30		ChangeRequest 65521: NSW | OnePort Integration - Setting voyage process by wharf
vars
	berthColl	: CM_ObjectSet;
	form		: SOP_HMS_TableMaintForm;
	table		: CM_EntryTable;
	row			: Integer;
begin
    form	:=	self.myForm.SOP_HMS_TableMaintForm;
	table	:=	form.tblInput1;
	
	table.clearValues;
	table.setTableFromObject(pObj, 'setTableFromObjectSpecial'); // 26.08.24	navhn30		TFS #65521
	
	if pObj.waterOnLeft then
		table.accessCell(table.getRow(ETRow_WaterOnLeft), table.ColumnValue).comboIndex := 1;
	else
		table.accessCell(table.getRow(ETRow_WaterOnLeft), table.ColumnValue).comboIndex := 2;
	endif;
	
	if pObj.isLogicalWharf then
		table.accessCell(table.getRow(ETRow_IsLogicalWharf), table.ColumnValue).comboIndex := 2;
	else
		table.accessCell(table.getRow(ETRow_IsLogicalWharf), table.ColumnValue).comboIndex := 1;
	endif;
	
	row := table.showRowByName(ETRow_HookCodeMinResidenceTime, false);
	
	//table.disableRow(row);		// PAR #28675
	
	if form.mode = form.Mode_View then
		table.setValue(row, app.getErrorString (XLAT_DBLCLICK_VIEW));
	else
		table.setValue(row, app.getErrorString (XLAT_DBLCLICK_EDIT));
	endif;
	
	self.jadeCode := pObj.getJadeCode;
	
	if form.mulSelect1.visible then
		create berthColl transient;
		pObj.allBerths.copy(berthColl);
		pObj.getHarbourReal.getBerthsUnassignedToWharf(berthColl);
		form.mulSelect1.setAvailable(berthColl, true);
		form.mulSelect1.setSelected(pObj.allBerths);
	endif;
	
	if form.mulSelect2.visible then
		form.mulSelect2.setAvailable(pObj.getHarbourReal.allTerminalsByCode, true);	
		form.mulSelect2.setSelected(pObj.allTerminals);	
	endif;
	
	self.setTblData1Rows(pObj);
epilog
	delete berthColl;
end;</source>
        <Parameter name="pObj" type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="89bb1eda-a386-4e3f-b684-4b4bed0971d8">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	03 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpWharf : HMS_Wharf;
	cell     :JadeTableCell;
begin

	tmpWharf := _obj.HMS_Wharf;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := tmpWharf.colour;
		endif;
	endif;
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
