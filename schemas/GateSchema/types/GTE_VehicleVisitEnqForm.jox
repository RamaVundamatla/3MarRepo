    <JadeMethod name="addObjectsToTable" id="26403014-b60b-46f1-b013-716c1d12977c">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
11 Apr 2025  navma1  	 MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
----------   ----------  --------------------------------------------------
*/
vars
	savePointer				: Integer;
	carrier					: CM_Carrier;
	vehicle					: CM_Vehicle;
begin
	
	if not self.isFirstActivateComplete then
		return;
	endif;
	
	savePointer 		:= app.mousePointer;
	app.mousePointer 	:= Window.MousePointer_HourGlass;
	
	self.btnModalOpt1.width := self.btnModalOpt1.width + 20;	// 27/03/2008 cnwar2 #16318
	self.btnModalOpt1.left	:= self.btnModalOpt1.left  - 20;	// Adjust size of button to fit caption 'Return Data'
	
	self.progressStart(null, app.getErrorString(Cancel), app.getErrorString(ReturnData), null,app.getErrorString(LoadingDataIntoView));
	self.frmModalDialog.refreshNow;
	
	//epr 21/1/15 CCMS 1409 par 35553 
	if self.filterEIR &lt;&gt; null and  self.myTerminal.getConfig(UseReceiveReleaseEIR).Boolean then  //11.04.2025 navma1 #MTN-34621
		self.addObjectsToTableEIR(_numItems);
		return;
	endif;
	//go through the optimum starting point
	//epr par 35090 20/11/14
	if self.filterCarrier &lt;&gt; null and not self.filterTimeIn.isValid  then
		
		carrier := app.myRoot.allCarriers[self.filterCarrier];
		
		if carrier = null then
			return;
		endif;
		
		foreach vehicle in carrier.vehicles discreteLock do			//22.04.2025 navma1 #MTN-34621
			self.addObjectsToTableVehicle(vehicle, _numItems);
		endforeach;
	
		return;
	endif;	
	
	self.addObjectsToTableTerminal(_numItems);	
epilog
	progressFinish;
	app.mousePointer := savePointer;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTableEIR" id="bae09726-ccb1-4559-bcca-c89f6587791b">
        <updating/>
        <source>addObjectsToTableEIR(_numItems: Integer io) protected, updating;
/*

Date		Who		Reason
22 January 2015	cnwer1	Initial creation PAR 35553

*/

vars
	iter			: Iterator;
	visit			: CM_VehicleVisitRecord;
	breakOut		: Boolean;
	eirNumber		: CM_EIRNumber;
begin

	iter:=self.myTerminal.allEIRNumbers.createIterator;
	self.myTerminal.allEIRNumbers.startKeyGeq(self.filterEIR,iter);
	
	while iter.next(eirNumber) do
		if eirNumber.eirNumber &lt;&gt; self.filterEIR then
			break;
		endif;
		visit:= eirNumber.myVVR;
		if visit = null then
			return;
		endif;
		if self.includeObject(visit, app.myPassport) then
			self.addObjectToTable(visit, _numItems, breakOut);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTableTerminal" id="b2e2065b-c716-4108-8eb8-315c4ebff69c">
        <updating/>
        <source>addObjectsToTableTerminal(_numItems: Integer io) updating,  protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2006 By cnwth2

Changed On   Changed By  Reason
19/02/2015	 cnwma1      PAR # 35701 Vehicle Visit Enquiry not returning correct data
17 Jan 2025	 navhl20 	 CR MTN-33055: MTN - Improve Performance of Vehicle Visit Enquiry
24 Jul 2025	 navhl20 	 Story MTN-35312: MTN | Pagination - Vehicle Visit Enquiry
----------   ----------  --------------------------------------------------
*/
vars
//	dict			: Dictionary;
	iter					: Iterator;
	visit					: CM_VehicleVisitRecord;
	breakOut				: Boolean;
	passport				: CM_Passport;
	defaultTS 				: TimeStamp;
	startObject 			: CM_VehicleVisitRecord;
	breakOnVvrNumChange 	: Boolean;	//16 Oct 2020	NDL TFS 49189
	breakWhenInGtrThanOut 	: Boolean;	//16 Oct 2020	NDL TFS 49189
	count 					: Integer;
	form					: CM_BaseForm;
	vvrSet					: CM_VehicleVisitRecordSet;
begin
	passport 	:= app.myPassport;
	
	/*if self.filterGatePass &lt;&gt; null then							// 19/02/2015 cnwma1 PAR #35701 
		//dict:=self.myTerminal.allVehicleVisitsByNumDT;	
	//else
		dict := self.myTerminal.allVehicleVisits;		
	endif;*/

/*	if self.filterTimeIn.isValid or self.filterTimeOut.isValid then  // 19/02/2015 cnwma1 PAR #35701 
		dict := self.myTerminal.allVehicleVisits;	
		iter := dict.createIterator;
		dict.startKeyGeq(self.filterTimeIn, iter);
	else
		dict:=self.myTerminal.allVehicleVisitsByNumDT;	
		iter := dict.createIterator;
		if self.filterTimeOut.isValid then
			defaultTS := self.filterTimeOut;
		endif;
		dict.startKeyGeq(self.filterGatePass, defaultTS,iter);
	endif; */
	
	//iter := dict.createIterator;											// 19/02/2015 cnwma1 PAR #35701 
	/*if  self.filterGatePass = null and self.filterTimeIn.isValid() then
		dict.startKeyGeq(self.filterTimeIn, iter);
	elseif self.filterGatePass &lt;&gt; null then
		dict.startKeyGeq(self.filterTimeIn,iter);
	endif;*/
	
	
	
	//14 Oct 2020	NDL	TFS 49189
	if self.filterStevedore &lt;&gt; null then
		iter := self.filterStevedore.allVVRS.createIterator; 
	elseif self.filterGatePass &lt;&gt; null then
		iter := self.myTerminal.allVehicleVisitsByNumDT.createIterator;
		startObject := self.myTerminal.allVehicleVisitsByNumDT.getAtKeyLeq( self.filterGatePass, null );
		breakOnVvrNumChange := true;
		if startObject &lt;&gt; null and startObject.visitNumber = self.filterGatePass then
			iter.startAtObject( startObject );
		else
			return;
		endif;
	elseif self.filterTimeIn.isValid then
		iter := self.myTerminal.allVehicleVisits.createIterator;
		startObject := self.myTerminal.allVehicleVisits.getAtKeyGeq( self.filterTimeIn );
		if self.filterTimeOut.isValid then
			breakWhenInGtrThanOut := true;
		endif;
		if startObject &lt;&gt; null then
			iter.startAtObject( startObject );
		else
			return;
		endif;
	else
		iter := self.myTerminal.allVehicleVisits.createIterator;
		if self.filterTimeOut.isValid then
			breakWhenInGtrThanOut := true;
		endif;
	endif;
	
	create vvrSet transient;										//17.01.2025 navhl20 #33055
	
	while iter.next(visit) do
	
		if breakOnVvrNumChange then	//16 Oct 2020	NDL TFS 49189
			if visit.visitNumber &lt;&gt; self.filterGatePass then
				break;
			endif;
		elseif breakWhenInGtrThanOut then	//16 Oct 2020	NDL TFS 49189
			if visit.timeIn &gt; self.filterTimeOut then
				break;
			endif;
		endif;
	
		if self.includeObject(visit, passport) then
			vvrSet.tryAdd(visit);									//17.01.2025 navhl20 #33055
		endif;
		
		if breakOut then
			break;
		endif;
		
	endwhile;
	
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, vvrSet, true);	//24.07.2025 navhl20 #35312
	_numItems := vvrSet.size();																		//24.07.2025 navhl20 #35312
epilog
	delete iter;
end;</source>
        <access>protected</access>
