    <JadeMethod name="initTable" id="bae72141-fde8-442b-a096-7edcd6640ef1">
        <source>initTable() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 

*/

vars
	heading		: String;
	tableObj	: Table;

begin
	tableObj				  :=	self.tblDetails;
	tableObj.defaultRowHeight := 20;
	tableObj.fixedRows		  :=	1;
	tableObj.fixedColumns	  :=	0;
		
	tableObj.rows			  :=	1;
	tableObj.columns		  :=	2;
	tableObj.setCellText(1, 1, app.getErrorString(RTQMachineTableLegendColHeader) &amp; Tab &amp; app.getErrorString(RTQMachineTableLegendDetailCol));
	
	tableObj.wordWrap		  :=	true;
	tableObj.selectMode		  :=	Table.SelectMode_CurrentRow;
	tableObj.scrollBars		  :=	Table.ScrollBars_Both;
	tableObj.partialTextIndication	:=	true;
	tableObj.accessRow(1).backColor	:=	self.colorHeadingColumn;
end;</source>
        <access>protected</access>
    </JadeMethod>
