/*

Purpose:			


Return Value:		


Date		Who		Reason
19 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if textbox.text.length &lt;= 10 then
		return;
	endif;

	self.doGetValidContainer();
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtVehicle_change" id="7408aa10-8d92-45f9-ba26-b483aa58c21b">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtVehicle_change(textbox: TextBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vehicleID		: String;
begin
	vehicleID := textbox.text.trimBlanks();
	if vehicleID.length &gt;= 3 and vehicleID &lt;&gt; self.previousVehicleID then
		self.clearAllInfo();
		self.doGetVehicleDetails(vehicleID);
		self.previousVehicleID := vehicleID;
	endif;
	
end;


</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="3cf3109b-4af7-4361-af99-3a118fbbb979">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	self.allClonedControls.purge();
	
	if self.allContainerInfo &lt;&gt; null then
		self.allContainerInfo.purge();
	endif;
	
	delete self.allContainerInfo;
	
end;


</source>
    </JadeMethod>
</GUIClass>
