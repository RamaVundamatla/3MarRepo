    <JadeMethod name="setForUpdate" id="38e01883-d6d3-4229-b363-6128b2683f5e">
        <updating/>
        <source>setForUpdate(_pxyProcess : SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 Voyage Status Enhancements
//
vars

begin

	self.code := _pxyProcess.code;
	self.description := _pxyProcess.description;
	
	//10 May 2018	NDL	TFS 38517
	self.setReportNames(	_pxyProcess.ediPrenoteFormat,	//_ediPrenoteFormat : String;
							_pxyProcess.reportInvoiceEstimate,	//_reportInvoiceEstimate : String;
							_pxyProcess.reportInvoicePreinvoice,	//_reportInvoicePreinvoice : String;
							_pxyProcess.reportInvoiceTaxinvoice,	//_reportInvoiceTaxinvoice : String;
							_pxyProcess.workOrderReceivalReport,	//_workOrderReceivalReport : String;	//11 Jun 2018	NDL	TFS 38795
							_pxyProcess.workOrderReleaseReport	//_workOrderReleaseReport : String	//11 Jun 2018	NDL	TFS 38795
							);
							
	
epilog

end;</source>
        <Parameter name="_pxyProcess" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="80d30e9c-211b-44f0-a9fc-95690237a06e">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_ediPrenoteFormat : String;
			_reportInvoiceEstimate : String;
			_reportInvoicePreinvoice : String;
			_reportInvoiceTaxinvoice : String;
			_workOrderReceivalReport : String;
			_workOrderReleaseReport : String
			) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 3427 PEL1 Voyge Status Enhancements
//
vars

begin
	self.code := _code;
	self.description := _description;
	
	//10 May 2018	NDL	TFS 38517
	self.setReportNames(	_ediPrenoteFormat,	//_ediPrenoteFormat : String;
							_reportInvoiceEstimate,	//_reportInvoiceEstimate : String;
							_reportInvoicePreinvoice,	//_reportInvoicePreinvoice : String;
							_reportInvoiceTaxinvoice,	//_reportInvoiceTaxinvoice : String
							_workOrderReceivalReport,	//_workOrderReceivalReport : String;	//11 Jun 2018	NDL	TFS 38795
							_workOrderReleaseReport	//_workOrderReleaseReport : String	//11 Jun 2018	NDL	TFS 38795
							);
	
	self.myRoot := app.myRoot;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_ediPrenoteFormat" type="String"/>
        <Parameter name="_reportInvoiceEstimate" type="String"/>
        <Parameter name="_reportInvoicePreinvoice" type="String"/>
        <Parameter name="_reportInvoiceTaxinvoice" type="String"/>
        <Parameter name="_workOrderReceivalReport" type="String"/>
        <Parameter name="_workOrderReleaseReport" type="String"/>
