    <JadeMethod name="setSearcherTblDef" id="f53eba10-1cbf-4c7e-bb60-13203fd6f29d">
        <source>setSearcherTblDef() : Boolean;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	entTableDef	: EntTableDef;
begin
	entTableDef := app.myController.getEntTableDef(ETDef_EDIViewerFind);
	if entTableDef &lt;&gt; null then
		self.tblSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; ETDef_EDIViewerFind &amp; ') not found');
		return false;
	endif;
	self.tblSearch.enabled := true;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ded0e902-497e-478e-ad65-6ef1e9666ffa">
        <updating/>
        <source>setupForm() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 August 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	errMsg : XLAT_Translation;
begin
	inheritMethod();
	
	self.addToolbarControls();
	
	self.frmMode := self.Query_Mode;	
	
	self.setCaption(app.getErrorString(WebServiceViewer));
	errMsg := app.zGetUntranslatedText(XLAT_Exceptions, WebServiceViewer);
	if errMsg &lt;&gt; null then
		self.helpKeyword := HelpFile_SearchString &amp; errMsg.text;
	endif;
	
	self.initTableData(ETDef_EDIViewer);
	self.setSearcherTblDef();

	self.minimumWidth := 920;
	self.minimumHeight := 410;
	
	self.setNavigatorHeading (self.caption);
	
	self.tblSearch.setValueByName(ETRow_FilterFromDate, app.actualTimeServer().Date);
	self.tblSearch.setValueByName(ETRow_FilterToDate, app.actualTimeServer().Date);
	
	self.tblLogInformation.hideColumnByColName(ETRow_Process);
	
	self.doShowSearcher();
	
	self.registerNotifications();
	
	self.btnSearch.setFocus();	//05 Dec 2019	NDL	TFS 47715
	self.btnSearch.zOrder(1);	//05 Dec 2019	NDL	TFS 47715
end;</source>
    </JadeMethod>
