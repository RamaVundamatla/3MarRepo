	self.initSearch();
	self.initTblData();
	self.doMnuHideClick (self.mnuContextHide);
	self.setButtonState;
	
	self.beginClassNotification(CM_InterTerminalMove, false, Any_System_Event, Response_Continuous, null);	

epilog

end;</source>
