<Class name="CM_TrailerDischarge" id="af33ab93-a295-42d9-92ab-fc902de47988">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="otherTrackedItemID" id="7183fa06-7767-483d-9262-e18166e85bf4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="trailerTypeCode" id="ff671d83-ca58-46e0-bbdb-dda41644422b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayString" id="8157bd00-c82a-4844-b75a-54a647f6efc5">
        <source>getDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2020	jlgndl1	Initial creation	TFS 50422
09 Feb 2024	jlika1	TFS 62215 CUX | Transactions when loading/unloading a MAFI
*/
vars
	str : String;
begin	
	if self.type = TRANS_TYPE_TRAILER_DIS then
		str := app.getErrorString2(Unloaded_from_trailer, self.id, self.otherTrackedItemID);
	elseif self.type = TRANS_TYPE_TRAILER_CARGO_DIS then
		str := app.getErrorString2(Unloaded_from_trailer, self.otherTrackedItemID, self.id);
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d3d84c48-0fe6-4ecc-bd08-b7971cce6585">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2020	jlgndl1	Initial creation	TFS 50422
09 Feb 2024	jlika1	TFS 62215 CUX | Transactions when loading/unloading a MAFI
*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_TrailerType then
		return self.getTrailerType();	
	elseif _attrName = ETRow_Details  then
		lDetail := self.getDisplayString();	
		return lDetail;	
	else
		return inheritMethod(_attrName, _short);
	
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="8420d0be-bc39-4816-8c95-0bde7a2b6ca0">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2020	jlgndl1	Initial creation	TFS 50422

*/

vars
	str : String;

begin
	
	str := inheritMethod();
	str := str &amp; self.getDisplayString();
	return str;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrailerType" id="eb977eb6-84b8-4761-9dc8-143575a16df2">
        <source>getTrailerType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2020	jlgndl1	Initial creation	TFS 50422

*/

vars

begin

	return self.trailerTypeCode;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasOtherTrackedItem" id="04a5c4b9-6c4b-4daa-b9dd-8b86c659af33">
