    <JadeMethod name="tRTMoveTwinDirectorToShip" id="2b1f4498-975f-4c09-ad0d-7f244fa9df03">
        <updating/>
        <source>tRTMoveTwinDirectorToShip()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2020	jlgndl1	Initial creation	TFS 49174/48549

*/

constants

	LoadBox1 = 'TWIN4854901';
	LoadBox2 = 'TWIN4854902';
	BlockStack	= 'BSTL';
	Ship = "UTRDSHIP";
	Voyage1 = "UTBAVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId = "CRR1";
	ShipRelReq = 'TWINREL';
	QueueName = "UT_QUEUE";
	ReachStacker = "RCH1";
	IMV = "IM1";
	YardAlloc = 'TWIN';
	
vars
	
	passport : CM_Passport;
	operator : CM_Operator;
	wles : CM_WLEArray;
	bs : CM_BlockStack;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	cta : CM_CraneTransferArea;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	tas : StringArray;
	crane : CM_Machine;
	voyageQueue : CM_VoyageQueue;
	craneQueue : CM_VoyageCraneQueue;
	loadPort : CM_Port;
	dischargePort : CM_Port;
	queue : CM_SubQueue;
	shipRelease : CM_BulkRelease;
	voyAlloc : CM_VoyageAllocation;
	slots : CM_SlotControllerArray;
	voyageJob : CM_VoyageJob;
	editions : CM_ObjectByOidEditionDict;
	tmpLoadCC : CMIF_LoadColorCode;
	loadTi1 : CM_TrackedItem;
	loadTi2 : CM_TrackedItem;
	reachStacker : CM_Machine;
	imv : CM_Machine;
	request : CM_Request;
	wle : CM_WorkListEntry;
	rtQEntry1 : CM_RTQueueEntry;
	rtQEntry2 : CM_RTQueueEntry;
	rtqtask1 : CM_RTQueueTask;
	rtqtask2 : CM_RTQueueTask;
	multiRule : Boolean;
	agent : CMIF_MobileGenericAgent;
	today : Date;
	
begin

	today := app.actualTimeAppServer.date;
	multiRule := today.dayOfWeek.isOdd;  // Note different test depending on this setting.  Runs with 'false' on tuesday thursday saturday, and 'true' the other days.

	passport := app.myPassport;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).display);
	
	self.disableAllYA(true);

	// delete the data
	self.deleteContainer(LoadBox1);
	self.deleteContainer(LoadBox2);
	self.deleteTerminalArea(BlockStack);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine (ReachStacker);
	self.deleteMachine (IMV);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	self.deleteReleaseRequest(ShipRelReq);
	self.deleteYA(YardAlloc);
	
		
//	=========== CREATES =============================================================================	

	create wles transient;

	self.disableAllYA(true);
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bs := self.addBlockStack(BlockStack, 0, null);
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	
	// create the crane transfer area
	self.opts.purge;
	self.opts.addAssoc("SetCraneLaneCages", true);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship,operator);
	self.opts.purge;
	self.opts.addAssoc("UseAllocations", true);
	self.opts.addAssoc("CopyVoyageVAConfig", false);
	
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	
	//add crane queues
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);

	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	if multiRule then 
		// add machine rule between 2 areas - will get deleted if one area deleted
		self.addMachineRule (bs, cta, RTMoveMethod_1);
	endif;
	
	// create queue
	queue := self.addQueueToTA (QueueName, BlockStack);
	assertNotNull (queue);
	
	//create ship release request
	self.opts.purge();
	self.opts.addAssoc("Voyage",voyage);
	self.opts.addAssoc("Number",2.Integer);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("DischargePort",dischargePort);
	shipRelease := self.addReleaseByTypeRequest(ShipRelReq, BR_TYPE_SHIP, TI_CargoType_Container, "2200");
	self.assertTrueMsg( shipRelease &lt;&gt; null, "Bulkrelease " &amp; ShipRelReq &amp; " not created - " &amp; app.myPassport.getErrorsAndWarningsAsString);

	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,null,self.getTerminal.getDefaultEmptyCommodity(),1,false,false);		// 05/04/2013 cnwmh5
	
	//create load jobs for onsite TIs
	create slots transient;
	self.getJobSlotControllers(voyage.code, '01', DeckOnDeck, 1, 2, 1, slots);
	self.getJobSlotControllers(voyage.code, '03', DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 2);
	
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	self.opts.purge();
	self.opts.addAssoc("OutOfOrder", true);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");	
	
	//Assign release to the slots
	create editions transient;
	slots.copyNoDuplicates(editions);
	create tmpLoadCC transient;
	tmpLoadCC.myBulkReleaseReserveDetail := shipRelease.allReserveDetails.first;
	tmpLoadCC.myVoyageAllocation := slots.first.CM_SlotController.mySlotRequestLoad.getFirstAllocation;
	app.myTrxUA.trxUpdateSlotRequestAttribute(slots, null, true, editions, CM_SlotRequest.Attribute_AssignRelease, tmpLoadCC, app.myPassport);
	assertTrueMsg(app.myPassport.noErrors, "Assigning Release to slots failed with " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	
	//create the cargo in block stack ready to be associated with the director tasks
	loadTi1 := self.addContainerForExport(LoadBox1, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi1, bs.getLocationsController);
	self.assertEqual(loadTi1.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi1);
	self.deleteStops(loadTi1);	

	loadTi2 := self.addContainerForExport(LoadBox2, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi2, bs.getLocationsController);
	self.assertEqual(loadTi2.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi2);
	self.deleteStops(loadTi2);
	
	self.loadAllJobsToOps(voyage, true);
	
	// Queue Wles
	foreach request in voyageJob.allRequests do
		foreach wle in request.allWorkListEntries do
			wles.add(wle);
			self.autoplanWLE(wle);
		endforeach;
	endforeach;
	
	rtQEntry1 := wles[1].allRTQueueEntries[1];
	rtQEntry2 := wles[2].allRTQueueEntries[1];
	
	create tas transient;
	tas.add(bs.id);
	tas.add(cta.id);
	
	// create the IMV
	self.opts.purge();
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	imv := self.addMachine(MACHINETYPE_IMV, IMV, 97, tas, rtQEntry1.myQueue.id);
	self.machineLogon (imv);
	
	self.machineAssignToQueue( imv, rtQEntry1.myQueue );
	
	// create the Reach Stacker
	self.opts.purge();
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.opts.addAssoc("AccessMaxHeightDiff","4".Integer);
	self.opts.addAssoc("AccessMaxLocationReach","3".Integer);
	self.opts.addAssoc("AccessMaxOverstowHeight","4".Integer);
	reachStacker := self.addForkLift (ReachStacker, 91, tas, craneQueue.id);
	assertNotNull(reachStacker);
	self.machineAssignToQueue( reachStacker, rtQEntry1.myQueue );
	
	//Place in debug here if running manually to use the web apps.
	
	self.machineLogon (reachStacker);
	
	//Accept the director tasks
	self.machineAcceptSpecifiedTwinTask( reachStacker, rtQEntry1, rtQEntry2 );
	
	// do the pick-ups
	self.machineDirectorTwin ( reachStacker, loadTi1.id, loadTi2.id );
	
	if multiRule then
		// do the set-downs
		rtqtask1 := rtQEntry1.allTasks.last;
		rtqtask2 := rtQEntry2.allTasks.last;
		self.machineSetdownTwinTask ( reachStacker, rtqtask1, rtqtask2, imv.id ); 
		
	else
		// do the set-downs
		rtqtask1 := rtQEntry1.getFirstUncompletedTask;
		rtqtask2 := rtQEntry2.getFirstUncompletedTask;
		self.machineSetdownTwinTask ( reachStacker, rtqtask1, rtqtask2, cta.getFirstAvailableLoadLane.getFullId );
		
	endif;
	
	//Now use the Hand Held Lander to actually load them from the crane lane to the ship.
	app.isRTApp:=true; 
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	agent.doLanderLoad(loadTi1, wles[1].getTargetLocation, wles[1], null, null);
	agent.doLanderLoad(loadTi2, wles[2].getTargetLocation, wles[2], null, null);
		
	self.machineLogOff (reachStacker);
	if multiRule then
		self.machineLogOff (imv);
	endif;
	
	self.assertTrueMsg( loadTi1.myPrimaryActualLocation.isVoyageController, "First container failed to be loaded to ship");
	self.assertTrueMsg( loadTi2.myPrimaryActualLocation.isVoyageController, "Second container failed to be loaded to ship");
	
	// delete the data
	self.deleteContainer(LoadBox1);
	self.deleteContainer(LoadBox2);
	self.deleteTerminalArea(BlockStack);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine (ReachStacker);
	self.deleteMachine (IMV);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	self.deleteReleaseRequest(ShipRelReq);
	self.deleteYA(YardAlloc);
	
epilog
	app.isRTApp := false;
	delete agent;
	delete tas;
	delete locations;
	delete slots;
	delete wles;
	self.disableAllYA(false);
	delete tmpLoadCC;
	delete editions;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRTQStraddleOvestowHeldSeq" id="7a7ab7f9-24ff-4be3-bade-e5f8a69f490e">
        <source>tRTQStraddleOvestowHeldSeq();
// cnwer1
// cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2011	cnwrd1	Initial creation

*/


constants
	Straddle1Id		= "UTS2";
	Straddle2Id		= "UTS3";
	QueueId			= "UTQ1";
	
vars
	q1				: CM_RadioTelemetryQueue;
	straddle1,
	straddle2		: CM_Machine;
	tas				: StringArray;
	task1,
	task2,
	task2Org			: CM_RTQueueTask;
	ya: CM_YardAllocation;
	straddleStack: CM_StraddleStack;
	container1, container2: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	locations : CM_LCArray;	
begin
	deleteTerminalArea("UTSTRD");
	straddleStack := addStraddleStack("UTSTRD", 4, 4, 3);
	assertNotNullMsg(straddleStack, "straddleStack");
	
	//have to set YAconfig t
	
	// create a container and move to location
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  straddleStack.allGridControllersByRowColumn[1, 1]);

	self.deleteContainer("TEST0000002");
	container2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container2,  straddleStack.allGridControllersByRowColumn[1, 1]);
	
	
	// Create RT Queue for Blockstack
	q1 := self.addQueue(QueueId, straddleStack, null, false);

	
	self.moveQueued(container1,  straddleStack.allGridControllersByRowColumn[4, 1]);
	self.moveQueued(container2,  straddleStack.allGridControllersByRowColumn[3, 1]);

	// Get the Pickup tasks for the two containers
	task1 := container1.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; container1.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; container1.id &amp; " is not a Pickup");
	
	task2Org := container2.getQueueTask();
	self.assertNotNullMsg(task2Org, "Queue task for " &amp; container2.id);
	self.assertEqualMsg(task2Org.taskType, TASK_PICKUP, "Task for " &amp; container2.id &amp; " is not a Pickup");

	
	// Create 2 twin lift straddle to do the work
	create tas transient;
	tas.add(straddleStack.id);
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	
	straddle1 := self.addStraddleTwin(Straddle1Id, 92, tas, q1.id);
	straddle2 := self.addStraddleTwin(Straddle2Id, 93, tas, q1.id);
	
	//opts.clear;
	self.opts.purge;
	self.opts.addAssoc("OverstowMoveMode", CM_RTVehicleConfig.OSTOW_AUTOPLAN);
	self.machineConfig(straddle1);
	self.machineConfig(straddle2);
	
	app.isRTApp:=true;  
	self.machineLogon(straddle1);
	self.machineLogon(straddle2);
	
	// Put machines into queue
	self.machineAssignToQueue(straddle1, q1);
	self.machineAssignToQueue(straddle2, q1);

	// Try get a task for machine 1 - this should get the first (overstowed) task.
	task1 := self.machineTaskRequest(straddle1);
	self.assertNotNull(task1);
	self.assertEqual(task1.ti.id ,'TEST0000002'); //this should be container 2, the overstow!
	
	//now try and get the second task which should now be held
	self.expectTrxError(No_Tasks); 
	task2 := self.machineTaskRequest(straddle2);
	self.assertNull(task2);	
	self.assertEqual(task2Org.status , TASK_SYS_HELD); //make sure its held

	self.expectedTrxErrors.clear();
	//move the overstow task for machine1	
	self.machineAcceptTask(straddle1, task1);
	self.machinePickup(straddle1);
	self.machineSetdownTask(straddle1, straddle1.allCurrentWorkingQueueTasks.first ,  straddle1.allCurrentWorkingQueueTasks.first.targetLocationId);
	
	//machine 2 should be able to now get the task for container 2
	task2 := self.machineTaskRequest(straddle2);

	self.assertNotNull(task2);	
	self.assertEqual(task2.ti.id ,'TEST0000002'); //this should be container 2
	self.machineAcceptTask(straddle2, task2);
	
	// Tray again to get a task
	task1 := straddle1.allCurrentWorkingQueueTasks.first; //should automatically be working the real mvoe now
	self.assertNotNull(task1);
	self.assertEqual(task1.ti.id ,'TEST0000001'); //this should be container 1, the overstowed move
	self.machineAcceptTask(straddle1, task1);
	
	self.machinePickup(straddle1);
	self.machineSetdownTask(straddle1, straddle1.allCurrentWorkingQueueTasks.first  ,  straddle1.allCurrentWorkingQueueTasks.first.targetLocationId);
	
	self.machinePickup(straddle2);
	self.machineSetdownTask(straddle2, straddle2.allCurrentWorkingQueueTasks.first  ,  straddle2.allCurrentWorkingQueueTasks.first.targetLocationId);

	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);

	assertEqual(container1.getPrimaryLocation(REAL_MODE), straddleStack.allGridControllersByRowColumn[4, 1]);
	assertEqual(container2.getPrimaryLocation(REAL_MODE), straddleStack.allGridControllersByRowColumn[3, 1]);

	
epilog
	app.isRTApp:=false;
	delete tas;
	self.opts.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTQueuingBiDir" id="993f9afd-ca9e-49c7-87db-5595ed678cbc">
        <source>tRTQueuingBiDir();
// cnwer1
// 23/8/10	cnwdw1	
// 
constants
	Container = "UT100";
	StraddleStack1 = "UT_ST1";
	StraddleStack2 = "UT_ST2";
	Queue = "UT_Q";
	BI_DIRECTION = false;
	UNI_DIRECTION = true;
vars
	ti1, ti2: CM_TrackedItem;
	st1, st2: CM_GridArea;
	q1, q2: CM_RadioTelemetryQueue;
	task: CM_RTQueueTask;
begin
	self.deleteContainer(Container&amp;"1");
	self.deleteContainer(Container&amp;"2");
	self.deleteQueue(q1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	ti1 := self.addContainer(Container&amp;"1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	ti2 := self.addContainer(Container&amp;"2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, st2.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti2.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

	// Test 1
	// queue From: ST1 To: anywhere
	q1 := self.addQueue(Queue, st1, null, BI_DIRECTION);
	assertNotNull(q1);
	
	// queue move TI1 from ST1 to ST2
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti1.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);
	
	// queue move TI2 from ST2 to ST1
	self.moveQueued(ti2, st1.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti2.isQueuedToYard);
	assertEqual(q1.allEntries.size, 2);

	self.unqueueTI(ti1);
	self.unqueueTI(ti2);
	assertEqual(q1.allEntries.size, 0);
	self.deleteQueue(q1);
	
	// Test 2
	// queue From: anywhere To: ST2
	q1 := self.addQueue(Queue, null, st2, BI_DIRECTION);
	assertNotNull(q1);

	// queue move TI1 from ST1 to ST2
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti1.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);
	
	// queue move TI2 from ST2 to ST1
	self.moveQueued(ti2, st1.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti2.isQueuedToYard);
	assertEqual(q1.allEntries.size, 2);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tRTQueuingInOut" id="90324c44-d8d3-4949-8283-d43135790bd8">
        <source>tRTQueuingInOut();
// cnwer1
// 23/8/10	cnwdw1	
// 
constants
	Container = "UT100";
	StraddleStack1 = "UT_ST1";
	StraddleStack2 = "UT_ST2";
	Queue = "UT_Q";
	BI_DIRECTION = false;
	UNI_DIRECTION = true;
vars
	ti1, ti2: CM_TrackedItem;
	st1, st2: CM_GridArea;
	q1, q2: CM_RadioTelemetryQueue;
	task: CM_RTQueueTask;
begin
	self.deleteContainer(Container&amp;"1");
	self.deleteContainer(Container&amp;"2");
	self.deleteQueue(q1);
	self.deleteQueue(q2);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	ti1 := self.addContainer(Container&amp;"1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	ti2 := self.addContainer(Container&amp;"2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, st2.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti2.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

	// Test 1
	// queue From: ST1 To: anywhere
	q1 := self.addQueue(Queue&amp;"OUT", st1, null, UNI_DIRECTION);
	assertNotNull(q1);
	// queue From: anywhere to ST1
	q2 := self.addQueue(Queue&amp;"IN", null, st1, UNI_DIRECTION);
	assertNotNull(q2);
	
	// queue move TI1 from ST1 to ST2
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti1.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);
	
	// queue move TI2 from ST2 to ST1
	self.moveQueued(ti2, st1.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti2.isQueuedToYard);
	assertEqual(q2.allEntries.size, 1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tRTQueuingUniDir" id="4692a0a6-03ba-4d01-97de-80637bf7f986">
        <source>tRTQueuingUniDir();
// cnwer1
// 23/8/10	cnwdw1	
// 
constants
	Container = "UT100";
	StraddleStack1 = "UT_ST1";
	StraddleStack2 = "UT_ST2";
	Queue = "UT_Q";
	BI_DIRECTION = false;
	UNI_DIRECTION = true;
vars
	ti1, ti2: CM_TrackedItem;
	st1, st2: CM_GridArea;
	q1, q2: CM_RadioTelemetryQueue;
	task: CM_RTQueueTask;
begin
	self.deleteContainer(Container&amp;"1");
	self.deleteContainer(Container&amp;"2");
	self.deleteQueue(q1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	ti1 := self.addContainer(Container&amp;"1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	ti2 := self.addContainer(Container&amp;"2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, st2.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti2.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

	// Test 1
	// queue From: ST1 To: anywhere
	q1 := self.addQueue(Queue, st1, null, UNI_DIRECTION);
	assertNotNull(q1);
	
	// queue move TI1 from ST1 to ST2
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti1.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);
	
	// queue move TI2 from ST2 to ST1
	self.moveQueued(ti2, st1.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti2.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);

	self.unqueueTI(ti1);
	assertEqual(q1.allEntries.size, 0);
	self.deleteQueue(q1);
	
	// Test 2
	// queue From: anywhere To: ST2
	q1 := self.addQueue(Queue, null, st2, UNI_DIRECTION);
	assertNotNull(q1);

	// queue move TI1 from ST1 to ST2
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti1.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);
	
	// queue move TI2 from ST2 to ST1
	self.moveQueued(ti2, st1.allGridControllersByRowColumn[1, 1]);
	assertTrue(ti2.isQueuedToYard);
	assertEqual(q1.allEntries.size, 1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tSetdownSwapChangeTINotJob1" id="11d0982c-2f62-4cb1-bac1-2dbad5b7e680">
        <source>tSetdownSwapChangeTINotJob1();
/*

Purpose:			This unit test checks the Tandem lift swap only swap the cargo between truck, release request, vvr
					Vehicle App Config
						Allow Tandem lift to differenct location is true
						Swap Cargo not Job is true
						
					Scenario
						Truck 1 gated in with Release request 1
						Truck 2 gated in with Release request 2
						
						Cargo 1 is assigned to release 1
						Cargo 2 is assigned to release 2
						
						Do a swap and set down
						
						Cargo 1 should be set down to Truck 2
						Cargo 2 should be set down to Truck 1
						
						Release 1 should have Cargo 2;
						Release 2 should have Cargo 1;
						
						Truck 1 should linked to Release 1;
						Truck 2 should linked to Release 2

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2025	navkc1 JIRA 36189 PNL | Vehicle App Swap behaviour with Release Requests - Unit test

*/
constants
	UTISO1		= "SCJ1";
	UTTI1		= "UT36189-1";
	UTTI2		= "UT36189-2";
	UTTRUCK1	= "T36189-1";
	UTTRUCK2	= "T36189-2";
	UTTRUCK1ROAD= UTTRUCK1 &amp; " Road";
	UTTRUCK2ROAD= UTTRUCK2 &amp; " Road";
	UTREL1		= "UTRELSCJ1";
	UTREL2		= "UTRELSCJ2";
	UTMACHINE	= "MSCJ";
	UTTA		= "UTTA36189";
	UTYARDALLOC = "UTYASCJ";
vars
	operator		: CM_Operator;
	term			: CM_Terminal;
	iso1			: CM_ISOType;
	cont1,
	cont2			: CM_Container;
	cargoType		: CM_CargoType;
	rel1,
	rel2			: CM_BulkRelease;
	vvr1,
	vvr2			: CM_VehicleVisitRecord;
	gate			: CM_Gate;
	machine			: CM_Machine;
	ta				: CM_TerminalArea;
	vehAppConfig	: CM_RTVehicleConfig;
	ya				: CM_YardAllocation;
	locations		: CM_LCArray;
	sa				: StringArray;
	job1,
	job2			: CM_Job;
	wle1,
	wle2			: CM_WorkListEntry;
	rtq1,
	rtq2			: CM_RTQueueEntry;
	pxyRtqTask,
	rtqTask1,
	rtqTask2		: CM_RTQueueTask;
begin
	// Get Terminal
		term := self.getMyTerminal();
	
	// Get Operator
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Container Cargo Type
		cargoType := self.getCargoType("CONT");
		self.assertNotNullMsg(cargoType, "Failed to get ISO CONT cargo type");
	
	// Get Gate
		gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
		self.assertNotNullMsg(gate, "Failed to get gate");
	
	// Get ISO 1
		iso1 := self.addISOType(UTISO1, UTISO1, cargoType, true, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, false, 1000);
		
	// Create Containers
		cont1 := self.addContainer(UTTI1, operator, UTISO1, "MT", TI_IMEX_STATUS_IMPORT).CM_Container;
		cont2 := self.addContainer(UTTI2, operator, UTISO1, "MT", TI_IMEX_STATUS_IMPORT).CM_Container;
	
	// Get Terminal Area
		self.deleteTerminalArea(UTTA);
		ta := self.addBlockStack(UTTA, 10, null);
	
	// Move containers to TA
		self.moveCargo(cont1, null, ta.allLocationsControllers.first, app.myPassport);
		self.moveCargo(cont2, null, ta.allLocationsControllers.first, app.myPassport);
	
	// Get YA Allocation
		create locations transient;
		locations.add(ta.allLocationsControllers.first());
		
		ya := self.addYA(UTYARDALLOC, YACriteriaType_CargoType, cargoType, YACriteriaType_ISO, iso1, null, null, locations, null);
		self.assertNotNullMsg(ya, "Failed to create Yard allocation");
		beginTransaction;
			ya.setPriorityValue(999999);
		commitTransaction;
	
	// Get Terminal Area for machine
		create sa transient;
		// Container 1
		ta := cont1.myPrimaryActualLocation.myTerminalArea;
		sa.tryAdd(ta.id);
		self.assertNotNullMsg(ta, "Failed to get terminal area of container 1");
		
		// Container 2
		ta := cont2.myPrimaryActualLocation.myTerminalArea;
		self.assertNotNullMsg(ta, "Failed to get terminal area of container 2");
		sa.tryAdd(ta.id);
		
	// Get machine
		self.opts.purge();
		self.opts.addAssoc("MachineLiftType", 2);
		self.deleteMachine(UTMACHINE);		
		machine := self.addForkLift(UTMACHINE, 36189, sa, null);
		
		vehAppConfig := machine.myRTVehicleConfig;
		self.assertNotNullMsg(vehAppConfig, "Failed to get the RT Vehicle App Config for machine");
		
		beginTransaction;
			vehAppConfig.setPropertyValue("allowTandemToDiffTargets", true);
			vehAppConfig.setPropertyValue("doSwapChangeCargo", true);
		commitTransaction;
		
	// Get Release request
		self.deleteReleaseRequest(UTREL1);
		self.deleteReleaseRequest(UTREL2);
		self.deleteVehicle(UTTRUCK1);
		self.deleteVehicle(UTTRUCK2);
		
		rel1 := self.addReleaseByTypeRequest(UTREL1, BR_TYPE_ROAD, cargoType.id, UTISO1);
		self.releaseAssignCargo(rel1, null, cont1);
		rel2 := self.addReleaseByTypeRequest(UTREL2, BR_TYPE_ROAD, cargoType.id, UTISO1);
		self.releaseAssignCargo(rel2, null, cont2);
		
		self.opts.purge();
		self.opts.addAssoc("release", rel1);
		vvr1 := self.gateOutContainer(UTTRUCK1, null, UTTRUCK1, null, true, gate, null);
		self.opts.purge();
		self.opts.addAssoc("release", rel2);
		vvr2 := self.gateOutContainer(UTTRUCK2, null, UTTRUCK2, null, true, gate, null);
		
	// Get job
		job1 := vvr1.myRoadJob;
		job2 := vvr2.myRoadJob;
		self.assertNotNullMsg(job1, "Failed to get Job1");
		self.assertNotNullMsg(job2, "Failed to get Job2");
		
	// Get WLE
		wle1 := job1.workListEntries.last();
		wle2 := job2.workListEntries.last();
		self.assertNotNullMsg(wle1, "Failed to get Wle1");
		self.assertNotNullMsg(wle2, "Failed to get Wle2");
		
	// Get RTQ
		rtq1 := wle1.allRTQueueEntries.last();
		rtq2 := wle2.allRTQueueEntries.last();
		self.assertNotNullMsg(rtq1, "Failed to get Rtq1");
		self.assertNotNullMsg(rtq2, "Failed to get Rtq2");
		
	// Get RT Task
		rtqTask1 := rtq1.allTasks.last();
		rtqTask2 := rtq2.allTasks.last();
		self.assertNotNullMsg(rtqTask1, "Failed to get RtqTask1");
		self.assertNotNullMsg(rtqTask2, "Failed to get RtqTask2");
	
	// Allocate machine to task 1
		pxyRtqTask := app.createUpdateProxy(rtqTask1).CM_RTQueueTask;
		
		pxyRtqTask.setProxyAllocMachine(machine, rtqTask1.myEntry, rtqTask1.sourceLocation, rtqTask1.targetLocation, cont1);
		app.myTrxUA.trxUpdateTaskAllocateMachine(pxyRtqTask,false,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyRtqTask;
		
	// Allocation machine to task 2
		pxyRtqTask := app.createUpdateProxy(rtqTask2).CM_RTQueueTask;
		
		pxyRtqTask.setProxyAllocMachine(machine, rtqTask2.myEntry, rtqTask2.sourceLocation, rtqTask2.targetLocation, cont2);
		app.myTrxUA.trxUpdateTaskAllocateMachine(pxyRtqTask,false,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyRtqTask;
	
	// Login to vehicle
		beginTransaction;
			machine.executeLogon(app.myPassport.myUser);
		commitTransaction;
		
	// Accept tasks
		self.machineAcceptSpecifiedTwinTask(machine, rtq1, rtq2);
		self.assertNoTrxErrorsOrWarnings();
		
	// Pickup cargo
		app.myTrxUA.trxMachineDirectorTask(machine, cont1, cont2, true, null, null,  app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertTrueMsg(rel1.allTrackedItemsAssigned.includes(cont1), "Cont 1 should have been assigned to release 1 in the pickup process");
		self.assertTrueMsg(rel2.allTrackedItemsAssigned.includes(cont2), "Cont 2 should have been assigned to release 2 in the pickup process");
		
	// Swap and Setdown;
		// Setdown location to Truck 2,
		// Twin Setdown location to Truck 1
		// isSwap = true
		app.myTrxUA.trxMachineSetdownTask(machine, rtqTask1, rtqTask2, UTTRUCK2ROAD, UTTRUCK1ROAD, false, true, null, null, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertTrueMsg(cont1.myPrimaryActualLocation.CM_VehicleController.getID().pos(UTTRUCK2ROAD, 1) &gt; 0, "Cont 1 set down to a wrong location");
		self.assertTrueMsg(cont2.myPrimaryActualLocation.CM_VehicleController.getID().pos(UTTRUCK1ROAD, 1) &gt; 0, "Cont 2 set down to a wrong location");
	
	// Road exit 
		self.roadExit(vvr1);
		self.roadExit(vvr2);
		
	// Check 
		// Container is linked to correct release request
		// Cont 1 to Release 2
		// Cont 2 to Release 1
		self.assertTrueMsg(cont1.deliveryRelease = UTREL2, "Cont1 is linked to incorrect release request");
		self.assertTrueMsg(cont2.deliveryRelease = UTREL1, "Cont2 is linked to incorrect release request");
		
		// Release request should have correct container
		// Release 1 has Cont 2;
		// Release 2 has Cont 1;
		self.assertTrueMsg(rel1.allTrackedItemsReleased.includes(cont2), "Release 1 does not have cont 2 released");
		self.assertTrueMsg(rel2.allTrackedItemsReleased.includes(cont1), "Release 2 does not have cont 1 released");
		
		// VVR should have correct container
		// VVR1 has Cont 2;
		// VVR2 has Cont 1;
		self.assertTrueMsg(vvr1.allReleasedTrackedItems.includes(cont2), "VVR 1 does not have cont 2 released");
		self.assertTrueMsg(vvr2.allReleasedTrackedItems.includes(cont1), "VVR 2 does not have cont 1 released");
		
		// VVR should linked to correct truck
		// VVR1 to Truck 1
		// VVR2 to Truck 2
		self.assertTrueMsg(vvr1.vehicle.regNumber = UTTRUCK1, "VVR 1 is linked to incorrect truck");
		self.assertTrueMsg(vvr2.vehicle.regNumber = UTTRUCK2, "VVR 2 is linked to incorrect truck");
epilog
	self.deleteTrackedItem(cont1, true);
	self.deleteTrackedItem(cont2, true);
	self.deleteISOType(UTISO1);
	self.deleteYA(UTYARDALLOC);
	delete sa;
	delete locations;
	delete pxyRtqTask;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSetdownSwapChangeTINotJob2" id="59f2b89f-3775-4703-a40d-c3480ede299d">
        <updating/>
        <source>tSetdownSwapChangeTINotJob2() updating;
/*

Purpose:			This unit test checks the Tandem lift swap validate the cargo against the release request to be swapped to
					
					Vehicle App Config
						Allow Tandem lift to differenct location is true
						Swap Cargo not Job is true
						
					Scenario
						Truck 1 gated in with Release request 1 for ISO Type 1
						Truck 2 gated in with Release request 2 for ISO Type 2
						
						Cargo 1 ISO Type 1 is assigned to release 1
						Cargo 2 ISO Type 2 is assigned to release 2
						
						Do a swap and set down
						
						Should get an error as the ISO Type does not match

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2025	navkc1 JIRA 36189 PNL | Vehicle App Swap behaviour with Release Requests - Unit test

*/
constants
	UTISO1		= "SCJ1";
	UTISO2		= "SCJ2";
	UTTI1		= "UT36189-1";
	UTTI2		= "UT36189-2";
	UTTRUCK1	= "T36189-1";
	UTTRUCK2	= "T36189-2";
	UTTRUCK1ROAD= UTTRUCK1 &amp; " Road";
	UTTRUCK2ROAD= UTTRUCK2 &amp; " Road";
	UTREL1		= "UTRELSCJ1";
	UTREL2		= "UTRELSCJ2";
	UTMACHINE	= "MSCJ";
	UTTA		= "UTTA36189";
	UTYARDALLOC = "UTYASCJ";
vars
	operator		: CM_Operator;
	term			: CM_Terminal;
	iso1,
	iso2			: CM_ISOType;
	cont1,
	cont2			: CM_Container;
	cargoType		: CM_CargoType;
	rel1,
	rel2			: CM_BulkRelease;
	vvr1,
	vvr2			: CM_VehicleVisitRecord;
	gate			: CM_Gate;
	machine			: CM_Machine;
	ta				: CM_TerminalArea;
	vehAppConfig	: CM_RTVehicleConfig;
	ya				: CM_YardAllocation;
	locations,
	locations2		: CM_LCArray;
	sa				: StringArray;
	job1,
	job2			: CM_Job;
	wle1,
	wle2			: CM_WorkListEntry;
	rtq1,
	rtq2			: CM_RTQueueEntry;
	pxyRtqTask,
	rtqTask1,
	rtqTask2		: CM_RTQueueTask;
	sideAccess		: Integer;
begin
	// Get Terminal
		term := self.getMyTerminal();
	
	// Get Operator
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Container Cargo Type
		cargoType := self.getCargoType("CONT");
		self.assertNotNullMsg(cargoType, "Failed to get ISO CONT cargo type");
	
	// Get Gate
		gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
		self.assertNotNullMsg(gate, "Failed to get gate");
	
	// Get ISO 1
		iso1 := self.addISOType(UTISO1, UTISO1, cargoType, true, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, false, 1000);
		
	// Get ISO 2
		iso2 := self.addISOType(UTISO2, UTISO2, cargoType, true, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, false, 1000);
	
	// Create Containers
		cont1 := self.addContainer(UTTI1, operator, UTISO1, "MT", TI_IMEX_STATUS_IMPORT).CM_Container;
		cont2 := self.addContainer(UTTI2, operator, UTISO2, "MT", TI_IMEX_STATUS_IMPORT).CM_Container;
	
	// Get Terminal Area
		self.deleteTerminalArea(UTTA);
		ta := self.addBlockStack(UTTA, 10, null);
	
	// Move containers to TA
		self.moveCargo(cont1, null, ta.allLocationsControllers.first, app.myPassport);
		self.moveCargo(cont2, null, ta.allLocationsControllers.first, app.myPassport);
	
	// Get YA Allocation for ISO 1
		create locations transient;
		locations.add(ta.allLocationsControllers.first());
		
		ya := self.addYA(UTYARDALLOC, YACriteriaType_CargoType, cargoType, YACriteriaType_ISO, iso1, null, null, locations, null);
		self.assertNotNullMsg(ya, "Failed to create Yard allocation");
		beginTransaction;
			ya.setPriorityValue(999999);
		commitTransaction;
	
	// Get YA Allocation for ISO 2
		create locations2 transient;
		locations2.add(ta.allLocationsControllers.first());
		
		ya := self.addYA(UTYARDALLOC, YACriteriaType_CargoType, cargoType, YACriteriaType_ISO, iso2, null, null, locations2, null);
		self.assertNotNullMsg(ya, "Failed to create Yard allocation");
		beginTransaction;
			ya.setPriorityValue(999999);
		commitTransaction;
	
	// Get Terminal Area for machine
		create sa transient;
		// Container 1
		ta := cont1.myPrimaryActualLocation.myTerminalArea;
		sa.tryAdd(ta.id);
		self.assertNotNullMsg(ta, "Failed to get terminal area of container 1");
		
		// Container 2
		ta := cont2.myPrimaryActualLocation.myTerminalArea;
		self.assertNotNullMsg(ta, "Failed to get terminal area of container 2");
		sa.tryAdd(ta.id);
		
	// Get machine
		self.opts.purge();
		self.opts.addAssoc("MachineLiftType", 2);
		self.deleteMachine(UTMACHINE);		
		machine := self.addForkLift(UTMACHINE, 36189, sa, null);
		
		vehAppConfig := machine.myRTVehicleConfig;
		self.assertNotNullMsg(vehAppConfig, "Failed to get the RT Vehicle App Config for machine");
		
		beginTransaction;
			vehAppConfig.setPropertyValue("allowTandemToDiffTargets", true);
			vehAppConfig.setPropertyValue("doSwapChangeCargo", true);
		commitTransaction;
		
	// Get Release request
		self.deleteReleaseRequest(UTREL1);
		self.deleteReleaseRequest(UTREL2);
		self.deleteVehicle(UTTRUCK1);
		self.deleteVehicle(UTTRUCK2);
		
		rel1 := self.addReleaseByTypeRequest(UTREL1, BR_TYPE_ROAD, cargoType.id, UTISO1);
		self.releaseAssignCargo(rel1, null, cont1);
		rel2 := self.addReleaseByTypeRequest(UTREL2, BR_TYPE_ROAD, cargoType.id, UTISO2);
		self.releaseAssignCargo(rel2, null, cont2);
		
		self.opts.purge();
		self.opts.addAssoc("release", rel1);
		vvr1 := self.gateOutContainer(UTTRUCK1, null, UTTRUCK1, null, true, gate, null);
		self.opts.purge();
		self.opts.addAssoc("release", rel2);
		vvr2 := self.gateOutContainer(UTTRUCK2, null, UTTRUCK2, null, true, gate, null);
		
	// Get job
		job1 := vvr1.myRoadJob;
		job2 := vvr2.myRoadJob;
		self.assertNotNullMsg(job1, "Failed to get Job1");
		self.assertNotNullMsg(job2, "Failed to get Job2");
		
	// Get WLE
		wle1 := job1.workListEntries.last();
		wle2 := job2.workListEntries.last();
		self.assertNotNullMsg(wle1, "Failed to get Wle1");
		self.assertNotNullMsg(wle2, "Failed to get Wle2");
		
	// Get RTQ
		rtq1 := wle1.allRTQueueEntries.last();
		rtq2 := wle2.allRTQueueEntries.last();
		self.assertNotNullMsg(rtq1, "Failed to get Rtq1");
		self.assertNotNullMsg(rtq2, "Failed to get Rtq2");
		
	// Get RT Task
		rtqTask1 := rtq1.allTasks.last();
		rtqTask2 := rtq2.allTasks.last();
		self.assertNotNullMsg(rtqTask1, "Failed to get RtqTask1");
		self.assertNotNullMsg(rtqTask2, "Failed to get RtqTask2");
	
	// Allocate machine to task 1
		pxyRtqTask := app.createUpdateProxy(rtqTask1).CM_RTQueueTask;
		
		pxyRtqTask.setProxyAllocMachine(machine, rtqTask1.myEntry, rtqTask1.sourceLocation, rtqTask1.targetLocation, cont1);
		app.myTrxUA.trxUpdateTaskAllocateMachine(pxyRtqTask,false,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyRtqTask;
		
	// Allocation machine to task 2
		pxyRtqTask := app.createUpdateProxy(rtqTask2).CM_RTQueueTask;
		
		pxyRtqTask.setProxyAllocMachine(machine, rtqTask2.myEntry, rtqTask2.sourceLocation, rtqTask2.targetLocation, cont2);
		app.myTrxUA.trxUpdateTaskAllocateMachine(pxyRtqTask,false,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyRtqTask;
	
	// Login to vehicle
		beginTransaction;
			machine.executeLogon(app.myPassport.myUser);
		commitTransaction;
		
	// Accept tasks
		self.machineAcceptSpecifiedTwinTask(machine, rtq1, rtq2);
		self.assertNoTrxErrorsOrWarnings();
		
	// Pickup cargo
		app.myTrxUA.trxMachineDirectorTask(machine, cont1, cont2, true, null, null,  app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertTrueMsg(rel1.allTrackedItemsAssigned.includes(cont1), "Cont 1 should have been assigned to release 1 in the pickup process");
		self.assertTrueMsg(rel2.allTrackedItemsAssigned.includes(cont2), "Cont 2 should have been assigned to release 2 in the pickup process");
		
	// Swap and Setdown;
		// Setdown location to Truck 2,
		// Twin Setdown location to Truck 1
		// isSwap = true
		self.expectedTrxErrors.clear();
		self.expectedTrxErrors.add(Warn_Request_Line_Match);
		app.myTrxUA.trxMachineSetdownTask(machine, rtqTask1, rtqTask2, UTTRUCK2ROAD, UTTRUCK1ROAD, false, true, null, null, app.myPassport);
		self.assertTrxErrorMsg(Warn_Request_Line_Match, "Error not raised for swapping cargo to a release request that does not match.");
epilog
	self.deleteTrackedItem(cont1, true);
	self.deleteTrackedItem(cont2, true);
	self.deleteISOType(UTISO1);
	self.deleteISOType(UTISO2);
	self.deleteYA(UTYARDALLOC);
	delete sa;
	delete locations;
	delete locations2;
	delete pxyRtqTask;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTaskStatusHeldTests" id="ecd71144-7982-4501-ac20-cddfb8b58395">
        <source>tTaskStatusHeldTests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2015	cnwndl1	Initial creation	Par 36014

*/

constants

	BlockStack1			: String = "HOLD1";
	BlockStack2			: String = "HOLD2";
	Container1			: String = "HOLD000001";
	Container2			: String = "HOLD000002";
	LabourRestrict		: String = "HOLD";
	RTQStop				: Integer = 970;
	YardMoveStop		: Integer = 971;
	MoveRequestId		: String = "HOLDMOVE";

vars

	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	tiReef : CM_Container;
	tiMT : CM_Container;
	lob : CM_LabourRestriction;
	selectedTypes : CM_CargoBOLTypeSet;
	preventActions : IntegerArray;
	opts : CM_AssociationDict;
	rtqStopTable : CM_StopsTable;
	ymStopTable : CM_StopsTable;
	wle : CM_WorkListEntry;
	entry : CM_RTQueueEntry;
	queue : CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	
	moveRequest : CM_YardDeliveryRequest;
	configMTStrategy: Integer;

begin

	//cleanup old data
	self.deleteContainer(Container1);
	self.deleteContainer(Container2);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(BlockStack2);
	self.deleteStopsTable(RTQStop);
	self.deleteStopsTable(YardMoveStop);
	
	create selectedTypes transient;
	create preventActions transient;
	create opts transient;
	
	//create a prevent RTQ stop
	selectedTypes.clear();
	preventActions.clear();
	opts.purge;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	preventActions.add(StopPreventRTQueuing);
	opts.addAssoc(ETRow_CheckStopAreas, preventActions);
	rtqStopTable := self.addStopsTable(RTQStop, "UTRTQ", StopPreventRTQueuingStr, selectedTypes, opts);
	
	//create a prevent Yard move stop.
	selectedTypes.clear();
	preventActions.clear();
	opts.purge;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	preventActions.add(StopPreventYardMove);
	opts.addAssoc(ETRow_CheckStopAreas, preventActions);
	ymStopTable := self.addStopsTable(YardMoveStop, "UTYM", StopPreventYardMoveStr, selectedTypes, opts);
	
	//create two block stacks, add a reefer container to the first one, queue to the second block stack.
	bs1 := addBlockStack(BlockStack1, 10, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, "Failed to create Block Stack " &amp; BlockStack1 );
	bs2 := addBlockStack(BlockStack2, 10, null);
	self.assertTrueMsg(bs2 &lt;&gt; null, "Failed to create Block Stack " &amp; BlockStack2 );
	tiReef := self.addContainerAtLocation(Container1,null,"2231","REEF",TI_IMEX_STATUS_EXPORT,bs1);
	self.assertTrueMsg(tiReef &lt;&gt; null, "Failed to create Reefer container " &amp; Container1 );
	self.moveQueued( tiReef, bs2 );
	self.assertTrueMsg( not tiReef.allWorklistEntries.isEmpty, "Failed to create queued move" );
	wle := tiReef.allWorklistEntries.first;
	self.assertTrueMsg( wle &lt;&gt; null, "Failed to find WLE" );
	self.assertTrueMsg( not wle.allRTQueueEntries.isEmpty, "WLE has no RTQ Entries" );
	entry := wle.allRTQueueEntries.first;
	self.assertTrueMsg( entry &lt;&gt; null, "Failed to find RTQ Entry" );
	queue := entry.myQueue;
	self.assertTrueMsg( queue &lt;&gt; null, "Failed to find Queue" );
	self.assertTrueMsg( not entry.allTasks.isEmpty, "RTQ Entry has no tasks" );
	task := entry.allTasks.first;
	self.assertTrueMsg( task &lt;&gt; null, "Failed to find Task" );
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 1" );
	
	//Set a LOB on block on the source BS check that the task is system held
	lob := self.addLabourRestriction(LabourRestrict, bs1, true);
	self.assertTrueMsg(lob &lt;&gt; null, "Failed to create Labour On Block - test 2 " &amp; LabourRestrict );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 3" );
	
	//Delete the LOB, check that the task status is now unactioned
	self.deleteLabourRestriction(lob);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 4" );
	
	//Set the task status to manually held and check it happened.
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_USER_HELD, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 5" );
	self.assertTrueMsg(task.status = TASK_USER_HELD, "Failed to set Task status - Test 6" );
	
	//Set the task status back to unactioned and check it happened.
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_UNACTIONED, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 7" );
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 8" );
	
	//Set the task status to manually held, then add an LOB to the target location, check that the status is still manually held
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_USER_HELD, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 9" );
	lob := self.addLabourRestriction(LabourRestrict, bs2, true);
	self.assertTrueMsg(lob &lt;&gt; null, "Failed to create Labour On Block - test 10 " &amp; LabourRestrict );
	self.assertTrueMsg(task.status = TASK_USER_HELD, "Failed to set Task status - Test 11" );
	
	//Set the task status to unacationed, check that it is now system held because the LOB is still in play.
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_UNACTIONED, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 12" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 13" );
	
	//Delete the LOB, check that the task status is now unactioned
	self.deleteLabourRestriction(lob);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 14" );
	
	//Add an RTQ Stop to the cargo, check that the status is system held.
	self.addStop(tiReef, rtqStopTable);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 15" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 15" );
	
	//Add a Yard Move stop to the cargo, check that the status is system held.
	self.addStop(tiReef, ymStopTable);
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 16" );
	
	
	//Remove the RTQ stop, check that still system held (by the Yard Move stop)
	self.deleteStop(tiReef, rtqStopTable);
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 17" );
	
	//Remove the Yard Move stop, check that the task is now unactioned
	self.deleteStop(tiReef, ymStopTable);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 18" );
	
	//Unqueue the container then connect to power, reQueue and check the task is system held.
	self.unqueueTI( tiReef );
	self.assertTrueMsg(tiReef.myPrimaryQueuedLocation = null, "TI not unqueued - Test 19");
	
	app.myMobileAgent.updateTIConnection( tiReef, true, true, null );
	self.assertTrueMsg(tiReef.isConnected = true, "TI not connected - Test 19a");
	
	self.moveQueued( tiReef, bs2 );
	self.assertTrueMsg( not tiReef.allWorklistEntries.isEmpty, "Failed to create queued move - Test 19b" );
	wle := tiReef.allWorklistEntries.first;
	self.assertTrueMsg( wle &lt;&gt; null, "Failed to find WLE - Test 19c" );
	self.assertTrueMsg( not wle.allRTQueueEntries.isEmpty, "WLE has no RTQ Entries - Test 19d" );
	entry := wle.allRTQueueEntries.first;
	self.assertTrueMsg( entry &lt;&gt; null, "Failed to find RTQ Entry - Test 19e" );
	queue := entry.myQueue;
	self.assertTrueMsg( queue &lt;&gt; null, "Failed to find Queue - Test 19f" );
	self.assertTrueMsg( not entry.allTasks.isEmpty, "RTQ Entry has no tasks - Test 19g" );
	task := entry.allTasks.first;
	self.assertTrueMsg( task &lt;&gt; null, "Failed to find Task - Test 19h" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 20" );
	
	//Disconnect the power and check that unactioned again
	app.myMobileAgent.updateTIConnection( tiReef, true, false, null );
	self.assertTrueMsg(tiReef.isConnected = false, "TI still connected - Test 21");
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 22" );
	
	//Suspend the Queue, check that the task is system held.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_HELD,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 23" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 24" );
	
	//Resume the Queue, check that the task is unactioned again.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_RUNNING,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 25" );
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 26" );
	
	//Suspend the Queue, and add a LOB on source, check that the task is system held.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_HELD,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 27" );
	lob := self.addLabourRestriction(LabourRestrict, bs1, true);
	self.assertTrueMsg(lob &lt;&gt; null, "Failed to create Labour On Block - test 28 " &amp; LabourRestrict );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 29" );
	
	//Resume the Queue, check that the task is still system held by the LOB.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_RUNNING,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 30" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 31" );
	
	//remove the LOB, check that the task is unactione again.
	self.deleteLabourRestriction(lob);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 32" );
	
	self.unqueueTI( tiReef );
	
	//Now repeat the subset that are appropriate for a director task
	
	tiMT := self.addContainerAtLocation(Container1,null,"2200","MT",TI_IMEX_STATUS_STORAGE,bs1);
	self.assertTrueMsg(tiMT &lt;&gt; null, "Failed to create MT container " &amp; Container2 );
	
	self.setTerminalConfig(UseBestPickDirector, true);
	self.setTerminalConfig(DoNotCreateBulkRelease, true);
	configMTStrategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal).Integer;

	moveRequest := self.moveDirector(MoveRequestId, 1, tiMT.operatorCode, "2200", bs1, null, bs2); 
	entry := moveRequest.allWorkListEntries.first.allRTQueueEntries.first;
	self.assertTrueMsg( entry &lt;&gt; null, "Failed to find RTQ Entry for Director task" );
	queue := entry.myQueue;
	self.assertTrueMsg( queue &lt;&gt; null, "Failed to find Queue for Director task" );
	self.assertTrueMsg( not entry.allTasks.isEmpty, "RTQ Entry  for Director task has no tasks" );
	task := entry.allTasks.first;
	self.assertTrueMsg( task &lt;&gt; null, "Failed to find Director task" );
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 41" );
	
	//Set a LOB on block on the source BS check that the task is system held
	lob := self.addLabourRestriction(LabourRestrict, bs1, true);
	self.assertTrueMsg(lob &lt;&gt; null, "Failed to create Labour On Block - test 42 " &amp; LabourRestrict );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 43" );
	
	//Delete the LOB, check that the task status is now unactioned
	self.deleteLabourRestriction(lob);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 44" );
	
	//Set the task status to manually held and check it happened.
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_USER_HELD, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 45" );
	self.assertTrueMsg(task.status = TASK_USER_HELD, "Failed to set Task status - Test 46" );
	
	//Set the task status back to unactioned and check it happened.
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_UNACTIONED, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 47" );
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 48" );
	
	//Set the task status to manually held, then add an LOB to the target location, check that the status is still manually held
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_USER_HELD, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 49" );
	lob := self.addLabourRestriction(LabourRestrict, bs2, true);
	self.assertTrueMsg(lob &lt;&gt; null, "Failed to create Labour On Block - test 50 " &amp; LabourRestrict );
	self.assertTrueMsg(task.status = TASK_USER_HELD, "Failed to set Task status - Test 51" );
	
	//Set the task status to unacationed, check that it is now system held because the LOB is still in play.
	app.myTrxUA.trxUpdateQueueTaskStatus(task, TASK_UNACTIONED, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 52" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 53" );
	
	//Delete the LOB, check that the task status is now unactioned
	self.deleteLabourRestriction(lob);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 54" );
	
	//Suspend the Queue, check that the task is system held.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_HELD,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 55" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 56" );
	
	//Resume the Queue, check that the task is unactioned again.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_RUNNING,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 57" );
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 58" );
	
	//Suspend the Queue, and add a LOB on source, check that the task is system held.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_HELD,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 59" );
	lob := self.addLabourRestriction(LabourRestrict, bs1, true);
	self.assertTrueMsg(lob &lt;&gt; null, "Failed to create Labour On Block - test 60 " &amp; LabourRestrict );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 61" );
	
	//Resume the Queue, check that the task is still system held by the LOB.
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_RUNNING,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK , app.myPassport.getErrorsAndWarningsAsString &amp; " - Test 62" );
	self.assertTrueMsg(task.status = TASK_SYS_HELD, "Failed to set Task status - Test 63" );
	
	//remove the LOB, check that the task is unactione again.
	self.deleteLabourRestriction(lob);
	self.assertTrueMsg(task.status = TASK_UNACTIONED, "Failed to set Task status - Test 64" );
	

epilog

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, configMTStrategy);

	self.deleteYardJob(MoveRequestId);
	self.deleteLabourRestriction(lob);
	self.deleteContainer(Container1);
	self.deleteContainer(Container2);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(BlockStack2);
	self.deleteStopsTable(RTQStop);
	self.deleteStopsTable(YardMoveStop);
	
	delete selectedTypes;
	delete preventActions;
	if opts &lt;&gt; null then
		opts.purge;
	endif;
	delete opts;

end;</source>
    </JadeMethod>
    <JadeMethod name="tTestLocToForRMGRTGCorrect" id="03c90194-0c2f-474b-ae2b-89cdfad9286e">
        <source>tTestLocToForRMGRTGCorrect();

/*

Purpose:			Check that the Queued Location To is correct for RMG / RTG Areas for 20ft / 40ft containers.  
					e.g. MHRT1000201 1 (no sapce between area and bay)

Date				Who		Reason
15 November 2011	cnwmh5	Initial creation

*/
constants

	RMGArea40Id				: String = "UTMHRM4";
	RTGArea40Id				: String = "UTMHRT4";
	BlockStack2Id			: String = "UTMHBS2";
	Container401Id			: String = "UTMHZZ00401";
	Container402Id			: String = "UTMHZZ00402";
	YardAllocation40ft		: String = "UTYA40ft";
	YardAllocation40ftA		: String = "UTYA40ftA";
	VehicleId				: String = "UTMHV1";
	Vehicle2Id				: String = "UTMHV2";
	
vars

	rmgArea40, rtgArea40	: CM_RTGArea;
	operator				: CM_Operator;
	blockStack				: CM_BlockStack;
	container				: CM_Container;
	ya40ft,
	ya40ftA					: CM_YardAllocation;
	vvr						: CM_VehicleVisitRecord;
	qLC						: CM_LocationsController;
	subBlock 				: CM_SubBlockStack;
	
	locations				: CM_LCArray;
	
	spaceCount				: Integer;
	str						: String;
	idx						: Integer;
	
begin

	self.disableAllYA(true);
	
	// setup any default values
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	
	self.deleteVehicle(VehicleId);
	self.deleteVehicle(Vehicle2Id);
	
	self.deleteContainer(Container401Id);
	self.deleteContainer(Container402Id);
	
	self.opts.purge();
	self.opts.addAssoc("use40ftIds", true);
	self.deleteTerminalArea(RMGArea40Id);
	rmgArea40 := self.addRMGArea(RMGArea40Id, 4, 4, 4);
	self.assertNotNull(rmgArea40);
	
	self.deleteTerminalArea(RTGArea40Id);
	rtgArea40 := self.addRTGArea(RTGArea40Id, 4, 4, 4);
	self.assertNotNull(rtgArea40);
	
	self.deleteTerminalArea(BlockStack2Id);
	blockStack := self.addBlockStack(BlockStack2Id, 10, null);
	self.assertNotNull(blockStack);
	
	create locations transient;
	
	// 07/04/2014 cnwmh5 - add / update a sub blcok stack 
	locations.add(rmgArea40.allGridControllersByRowColumn[1, 4]);
	locations.add(rmgArea40.allGridControllersByRowColumn[2, 4]);
	locations.add(rmgArea40.allGridControllersByRowColumn[3, 4]);
	locations.add(rmgArea40.allGridControllersByRowColumn[4, 4]);
	subBlock := self.addSubBlockStack(rtgArea40, locations); 
	self.assertNotNull(subBlock);
	
	// update subBLockStack
	locations.add(rmgArea40.allGridControllersByRowColumn[4, 3]);
	self.opts.purge();
	self.opts.addAssoc("SubBlockColour", 16711808);
	self.updateSubBlockStack(locations, subBlock);
	
	// delete subBlockStack
	self.deleteTerminalArea(subBlock.id);
	self.assertEqual(rtgArea40.allSubBlockStacks.size, 0);
	
	self.deleteTerminalArea(BlockStack2Id);
	blockStack := self.addBlockStack(BlockStack2Id, 10, null);
	self.assertNotNull(blockStack);
	
	// create yard allocations
	locations.clear();
	locations.add(rmgArea40.allGridControllersByRowColumn[1, 1]);
	locations.add(rmgArea40.allGridControllersByRowColumn[1, 4]);
	self.deleteYA(YardAllocation40ft);
	ya40ft := self.addYA(YardAllocation40ft, 
		YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		YACriteriaType_ISO, 4010,
		YACriteriaType_IsForty, CM_YADataBoolean.VALUE_TRUE,
		locations, null);
	self.assertNotNull(ya40ft);
	
	vvr := self.gateInContainer(VehicleId, Container401Id, "4010", operator.code, "GENL", self.getProfileSetting(UT_Profile.P_DGATE).asString());
	self.assertNotNull(vvr);
	
	container := self.getTrackedItem(Container401Id).CM_Container;
	self.assertNotNull(container);
	
	spaceCount := 0;
	str	:= container.getFullName(QUEUE_MODE);
	idx := str.length;
	while idx &gt; 0 do
		if str[idx] = " " then
			spaceCount := spaceCount + 1;
		endif;
		idx := idx - 1;
	endwhile;
	self.assertEqual(spaceCount, 1);
	
	// create yard allocations
	locations.clear();
	locations.add(rtgArea40.allGridControllersByRowColumn[1, 1]);
	locations.add(rtgArea40.allGridControllersByRowColumn[1, 4]);
	self.deleteYA(YardAllocation40ftA);
	ya40ftA := self.addYA(YardAllocation40ftA, 
		YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		YACriteriaType_ISO, 4010,
		YACriteriaType_IsForty, CM_YADataBoolean.VALUE_TRUE,
		locations, null);
	self.assertNotNull(ya40ftA);
	
	vvr := self.gateInContainer(Vehicle2Id, Container402Id, "4010", operator.code, "GENL", self.getProfileSetting(UT_Profile.P_DGATE).asString());
	self.assertNotNull(vvr);
	
	container := self.getTrackedItem(Container402Id).CM_Container;
	self.assertNotNull(container);
	
	spaceCount := 0;
	qLC := container.getPrimaryLocation(QUEUE_MODE);
	self.assertNotNull(qLC);
	str	:= qLC.getFullIdForTI(true);
	idx := str.length;
	while idx &gt; 0 do
		if str[idx] = " " then
			spaceCount := spaceCount + 1;
		endif;
		idx := idx - 1;
	endwhile;
	self.assertEqual(spaceCount, 1);
	
		
epilog

	self.disableAllYA(false);
	
	self.deleteYA(YardAllocation40ft);
	self.deleteYA(YardAllocation40ftA);

	delete locations;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTwinLift" id="5b286b18-173c-4bcc-aff2-c4892580bde4">
        <updating/>
        <source>tTwinLift() updating;
// cnwer1
//01 March 2011	cnwdw1	
//
vars
	bs1, bs2, bs3 : CM_BlockStack;
	q1: CM_RadioTelemetryQueue;
	ti1, ti2: CM_TrackedItem;
	straddle: CM_Machine;
	tas: StringArray;
begin
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"1", 100, null);
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2", 100, null);
	bs3 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"3", 100, null);

	ti1 := self.addContainerOpts("TEST1000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts("TEST1000002", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.move(ti1, bs1);
	self.move(ti2, bs1);
	
	q1 := self.addQueue("UT_Q", bs2, null, false);

	self.moveQueued(ti1, bs2);
	self.moveQueued(ti2, bs2);
	
	create tas transient;
	tas.add(bs1.id); tas.add(bs2.id);  tas.add(bs3.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	self.addStraddleTwin("UTS1", 91, tas, q1.id);
	
	straddle := self.getMachine("UTS1");
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	
	// Test that cannot twin lift 20ft with 40ft
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(straddle, 
										ti1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,
										ti2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.clearExpectedTrxErrors();
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("TareWeight", 2000);
	self.updateTI(ti2);
	self.assertEqual(ti2.getISOType, "2200");
	
	// Test that cannot move containers in different terminal areas
	self.move(ti2, bs3);
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(straddle, 
										ti1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,
										ti2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.clearExpectedTrxErrors();
	self.move(ti2, bs1);
	
	// Test weight difference
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", (ti1.totalWeight + 501).Integer);
	self.updateTI(ti2);
	self.expectTrxError(ERR_MACH_MAX_TWIN_WEIGHT); 
	self.machineAcceptSpecifiedTwinTask(straddle, 
										ti1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,
										ti2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.clearExpectedTrxErrors();

	// Test max weight 
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", straddle.maxLiftWeight.Integer);
	self.updateTI(ti2);
	self.expectTrxError(MACH_MAX_LIFT_WEIGHT_TWIN);
	self.machineAcceptSpecifiedTwinTask(straddle, 
										ti1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,
										ti2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.clearExpectedTrxErrors();
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", ti1.totalWeight.Integer);
	self.updateTI(ti2);
	
	// Do pickup and setup
	self.machineAcceptSpecifiedTwinTask(straddle, 
										ti1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,
										ti2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.machinePickup(straddle);
	self.machineSetdownTwinTask(straddle, ti1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first.allTasks.last,
										ti2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first.allTasks.last, bs2.id);
	self.machineLogOff(straddle);
	assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs2.getLocationsController);
	assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs2.getLocationsController);
	
epilog
	app.isRTApp:=false;  
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTwinLiftAllocatedHeld" id="76e2afd0-1a6a-4709-902e-540ff0cc0c63">
        <source>tTwinLiftAllocatedHeld();
// jlgmd1
// cnwkpd1
/*

Purpose:			Test the ability to allocate Held twin task to a machine and have them assigned
					via a Get Next Task

Date		Who		Reason
20 Oct 2011	cnwkpd1	PAR #28383 - CCMS 2030 - Allow allocation of Held twin tasks

*/

constants
	StraddleId		= "UTS2";
	QueueId			= "UTQ1";
	
vars
	bs1, 
	bs2, 
	bs3 			: CM_BlockStack;
	q1				: CM_RadioTelemetryQueue;
	ti1, 
	ti2				: CM_TrackedItem;
	straddle		: CM_Machine;
	tas				: StringArray;
	task1,
	task2,
	task			: CM_RTQueueTask;
	
begin
	// Create new bloackstacks
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"X", 100, null);
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"Y", 100, null);

	// Set up machine rule between them to be Straddle
	self.addMachineRule(bs1, bs2, RTMoveMethod_23);
	
	// Create new containers
	ti1 := self.addContainerOpts("UKPD1000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts("UKPD1000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// Move them to the first blockstack
	self.move(ti1, bs1);
	self.move(ti2, bs1);
	
	// Create RT Queue for Blockstack
	q1 := self.addQueue(QueueId, bs2, null, false);

	self.moveQueued(ti1, bs2);
	self.moveQueued(ti2, bs2);

	// Get the Pickup tasks for the two containers
	task1 := ti1.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti1.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti1.id &amp; " is not a Pickup");
	
	task2 := ti2.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti2.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti2.id &amp; " is not a Pickup");

	// Mark both tasks as held
	self.setTaskStatus(TASK_USER_HELD, task1);
	self.setTaskStatus(TASK_USER_HELD, task2);
	
	// Create twin lift straddle to do the work
	create tas transient;
	tas.add(bs1.id);
	tas.add(bs2.id);
	
	opts.addAssoc("WeightDifference", 500);
	opts.addAssoc("WeightMaxLift", 20000);
	straddle := self.addStraddleTwin(StraddleId, 92, tas, q1.id);
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	
	// Put machine into queue
	self.machineAssignToQueue(straddle, q1);

	// Try to get a task for the machine - should be none, because they are both held
	self.expectTrxError(No_Tasks); 
	task := self.machineTaskRequestTwin(straddle);
	self.assertNull(task);
	
	// Now allocate the first task to the machine
	self.machineAllocateTask(straddle, task1);
	self.assertEqual(straddle.allAllocatedQueueTasks.first, task1);

	// Tray again to get a task
	task := self.machineTaskRequestTwin(straddle);
	self.assertEqual(task, task1);
	self.assertEqual(straddle.allCurrentQueueTasks.size, 2);
	
	self.machinePickup(straddle);
	self.machineSetdownTwinTask(straddle, ti1.getQueueTask(), ti2.getQueueTask(), bs2.id);

	self.machineLogOff(straddle);

	assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs2.getLocationsController);
	assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs2.getLocationsController);

	
epilog
	app.isRTApp:=false;
	delete tas;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTwinLiftFlag" id="9881861a-7676-4fd4-ad8c-340b17085c67">
        <source>tTwinLiftFlag();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2025	navbs1	Initial creation Bug MTN-35345: MTN - Avoid Running Twin Lift Flag Logic for Non Container Cargo Items

*/
constants
	Cargo_Type			: String = "UTREBAR";
	QueueId			= "UTQ35345";
vars
	
	bs1, 
	bs2, 
	bs3 			: CM_BlockStack;
	q1				: CM_RadioTelemetryQueue;
	ti1, 
	ti2,
	ti3,
	ti4,
	ti5			: CM_TrackedItem;
	task1,
	task2,
	task3			: CM_RTQueueTask;
	cargoType 		: CM_CargoType;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	lc				: CM_LocationsController;
begin
	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	cargoType	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	foreach lc in voyage.allVoyageLocations do
		if lc.isKindOf(CM_GeneralCargoController) then
			break;
		endif;
	endforeach;
	
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"1", 100, null);
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2", 100, null);
	bs3 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"3", 100, null);

	ti1 := self.addContainerOpts("TEST1000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts("TEST1000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti3 := self.addContainerOpts("TEST1000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti4 :=  self.addCargoBreakBulkAtLocation("TEST1000004", cargoType, 1, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	ti5 :=  self.addCargoBreakBulkAtLocation("TEST1000005", cargoType, 1, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	
	self.move(ti1, bs1);
	self.move(ti2, bs1);
	self.move(ti3, bs1);
	self.moveBreakBulk(ti4, bs1, 1);
	self.moveBreakBulk(ti5, bs1, 1);
	
	// Create RT Queue for Blockstack
	q1 := self.addQueue(QueueId, bs2, null, false);
	self.addQueueToTA(QueueId,bs3);
	
	//CONTAINER-TWIN LIFT  FLAG - BOTH 
	self.moveQueued(ti1, bs2);
	self.moveQueued(ti2, bs2);
	self.moveQueued(ti3, bs2);

	task1 := ti1.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti1.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti1.id &amp; " is not a Pickup");
	
	task2 := ti2.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti2.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti2.id &amp; " is not a Pickup");
	
	task3 := ti3.getQueueTask();
	self.assertNotNullMsg(task3, "Queue task for " &amp; ti3.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti3.id &amp; " is not a Pickup");
	
	assertEqual(CM_RTQueueEntry.TWIN_BOTH, task2.myEntry.getTwinCarryFlag);
	
	self.unqueueTI(ti1);
	assertNull(ti1.getQueueTask());
	self.unqueueTI(ti2);
	assertNull(ti2.getQueueTask());
	self.unqueueTI(ti3);
	assertNull(ti3.getQueueTask());
	
	//CONTAINER-TWIN LIFT  FLAG - NEXT 
	self.moveQueued(ti1, bs3);
	self.moveQueued(ti2, bs2);
	self.moveQueued(ti3, bs2);
	
	task1 := ti1.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti1.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti1.id &amp; " is not a Pickup");
	
	task2 := ti2.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti2.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti2.id &amp; " is not a Pickup");
	
	task3 := ti3.getQueueTask();
	self.assertNotNullMsg(task3, "Queue task for " &amp; ti3.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti3.id &amp; " is not a Pickup");
	
	assertEqual(CM_RTQueueEntry.TWIN_NEXT, task2.myEntry.getTwinCarryFlag);
	
	
	self.unqueueTI(ti1);
	assertNull(ti1.getQueueTask());
	self.unqueueTI(ti2);
	assertNull(ti2.getQueueTask());
	self.unqueueTI(ti3);
	assertNull(ti3.getQueueTask());
	
	//CONTAINER-TWIN LIFT  FLAG - PREV 
	self.moveQueued(ti1, bs2);
	self.moveQueued(ti2, bs2);
	self.moveQueued(ti3, bs3);
	
	task1 := ti1.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti1.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti1.id &amp; " is not a Pickup");
	
	task2 := ti2.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti2.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti2.id &amp; " is not a Pickup");
	
	task3 := ti3.getQueueTask();
	self.assertNotNullMsg(task3, "Queue task for " &amp; ti3.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti3.id &amp; " is not a Pickup");
	
	assertEqual(CM_RTQueueEntry.TWIN_PREV, task2.myEntry.getTwinCarryFlag);
	
	
	//NON CONTAINER-TWIN LIFT  FLAG - NONE  
	self.moveQueued(ti5, bs2);
	task1 := ti5.getQueueTask();
	self.assertNotNullMsg(task1, "Queue task for " &amp; ti1.id);
	self.assertEqualMsg(task1.taskType, TASK_PICKUP, "Task for " &amp; ti1.id &amp; " is not a Pickup");

	assertEqual(CM_RTQueueEntry.TWIN_NONE, task1.myEntry.getTwinCarryFlag);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateQueueStatus" id="61656dc4-dae5-4b85-9052-2e3048e79d8e">
        <source>tUpdateQueueStatus();
/*

Purpose:	Update Queue Status			

Date		Who		Reason
14/04/2014	cnwma1	Initial creation

*/
constants
	QName = "QRTGArea";
	BS	  = "BS111";
	
vars
	queue	: CM_RadioTelemetryQueue;
	bs 		: CM_BlockStack;
begin
	
	deleteQueue(QName);
	
	deleteTerminalArea(BS);
	bs:=self.addBlockStack(BS,200,null);
	self.assertNotNull(bs);
	
	queue := self.addQueue(QName,bs, null, false);
	
	app.myTrxUA.trxUpdateQueueStatus(queue,QSTATUS_HELD,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(queue.status,1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateSourceLocation" id="9dd94c31-88c3-43f0-a30e-bd1566fbc8b7">
        <source>tUpdateSourceLocation();
/*

Purpose:			

Date		Who		Reason
08/05/2014 cnwma1	Initial creation

*/

constants
		BS1 ="MABS1";
		BS2 ="MABS2";
		YAId	: String  = "BSAPL20";


vars

	bs1,bs2  : CM_BlockStack;
	ya					: CM_YardAllocation;
	locations : CM_LCArray;
	vvr: CM_VehicleVisitRecord;
	releaseRequest: CM_BulkRelease;
	gate  : CM_Gate;
	rtTask : CM_RTQueueTask;
	operator    : CM_Operator;
	ti          : CM_TrackedItem;
		entry : CM_RTQueueEntry;
	q1 : CM_RTQTaskByTypeStatus;



begin

	self.disableAllYA(true);

	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	operator := self.getOperator("APL");
	
	deleteContainer("MTAD111");
	self.deleteTerminalArea(BS1);
	self.deleteTerminalArea(BS2);

	
	bs1 := self.addBlockStack(BS1,80,null);
	self.assertNotNull(bs1);
	
	bs2 := self.addBlockStack(BS2,80,null);
	self.assertNotNull(bs2);	

	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	locations.add(bs2.allLocationsControllers.first.CM_YardController);
	
	ti :=self.addContainerAtLocation("MTAD111",operator,"2200","MT",TI_IMEX_STATUS_STORAGE,bs1.myLocationsController);
	self.assertNotNull(ti);

	ya := self.addYA(YAId, YACriteriaType_OperatorItem, self.getOperator("APL"), 
						   YACriteriaType_ISO, 2200,
						   null, CM_YADataBoolean.VALUE_TRUE,
						   locations, null);	
	
	// Update Rt Task source Direction Location 
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Operator",operator);
	self.deleteVehicle("TKM50");
	releaseRequest := addReleaseByTypeRequestOpts("TKM50", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);

	self.opts.addAssoc('release', releaseRequest);
	vvr := self.gateOutContainer("TKM50", "", "MA", null, true, gate, null);
	self.assertNotNull(vvr);

	rtTask :=bs1.allRTQueueTasks[TASK_DIRECTOR, TASK_PICKUP];
	assertNotNull(rtTask);
	
	self.assertEqual(rtTask.mySourceTerminalArea.id,"MABS1");
	app.myTrxUA.trxUpdateRTTaskDirectoLocation( bs2.myLocationsController,rtTask,true,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(rtTask.mySourceTerminalArea.id,"MABS2");
	app.myTrxUA.trxUpdateVVRCancel(vvr,"Wrong Transaction",app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(vvr.status,99);

epilog

	self.disableAllYA(false);

	delete locations ;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tUserDelete" id="053c3245-7fd8-4c30-a2a3-6e347e0f4b2a">
        <updating/>
        <source>tUserDelete() updating;
// cnwns1
// cnwjre1 29211 can't delete user logged onto machine
constants
	UserName = "UTXYZ";
	MachineName = "UTZY";
	QueueName	= "UT_QXYZ";
vars
	bsName	: String;
	currentUser,
	user	: CM_User;
	machine	: CM_Machine;
	queue 	: CM_SubQueue;
	bs		: CM_BlockStack;
	tas 	: StringArray;
begin
	currentUser := app.myPassport.myUser;

	machine := self.getMachine(MachineName);
	// turn off the 'loggedOn' property so can delete it with an invalid user
	if machine &lt;&gt; null and
	   machine.loggedOn then
		beginTransaction;
		machine.setPropertyValue('loggedOn', false);
		commitTransaction;
	endif;
	self.deleteMachine(MachineName);
	self.deleteUser(UserName);
	user := self.addUser(UserName, UserName);
	
	self.deleteQueue(QueueName);
	bsName := self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString;
	bs := self.getTerminal.allTerminalAreas[bsName].CM_BlockStack;
	if bs = null then
		bs := self.addBlockStack(bsName, 1000, null);
	endif;
	queue := self.addQueueToTA (QueueName, bsName);
	assertNotNull (queue);

	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);
	self.deleteRTDevice("81");
	
	create tas transient;
	tas.add(bs.id);
	machine := self.addForkLift (MachineName, 81, tas, queue.id);
	assertNotNull(machine);
	
	// set app.myPassport.myUser to new user
	app.myPassport.setMyUser(user);
	self.machineLogon(machine);
	
	app.myTrxDA.trxDeleteUser(user, app.myPassport);
	// should get an error
	self.assertTrxErrorMsg(User_logged_machin_cannot_dele, "No 'User logged onto machine' error");
	
	// log off and try again
	self.machineLogOff(machine);
	app.myTrxDA.trxDeleteUser(user, app.myPassport);
	// should get no error
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete tas;
	// reset app.myPassport.myUser to regular user
	app.myPassport.setMyUser(currentUser);
end;
</source>
    </JadeMethod>
    <JadeMethod name="testRTGReAutoPlanOnRTMachines" id="c4de079f-6bf0-4105-83a9-868d6b900207">
        <updating/>
        <source>testRTGReAutoPlanOnRTMachines(_container : CM_Container; _isoType : String; 
						      _rmgArea : CM_RTGArea;  _taAccess: StringArray; 
							  _rmgAreaQueue : CM_RadioTelemetryQueue input)protected, updating;

/*
Purpose:		Test that for a RMG Area that validates over height correctly	

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2011	cnwdz2	Initial creation par27008

*/
constants
	RMGId				: String  = "RMG1";
	MachineId			: Integer = 91;
	YAId				: String  = "UTDZYA1";
vars
	ya					: CM_YardAllocation;
	locations			: CM_LCArray;
	rmg1				: CM_Machine;
	task1				: CM_RTQueueTask;
	locFullId,
	locFullIdWithHeight : String;
	lc					: CM_LocationsController;
begin
	rmg1 := self.addRMG(RMGId, MachineId, _taAccess, _rmgAreaQueue.id);
	assertNotNull(getTerminal.getRTVehicleConfigForObject(rmg1));
	assertTrue(getTerminal.getRTVehicleConfigForObject(rmg1).autoResequenceJobs);
	
	//assign the machine to the queue
	self.machineAssignToQueue(rmg1, _rmgAreaQueue);
	self.machineLogon(rmg1);
	
	task1 := self.machineTaskRequest(rmg1);
	self.machineAcceptTask(rmg1, task1);

	//epr par 31576 27/6/13 now without an YA it still finds a location on resequence
	locFullId:=rmg1.allCurrentWorkingQueueTasks.first.ultimateTargetLocationId;
	self.assertEqual(locFullId,"UTDZRMGA1000103");
	// create a yard allocation for queuing of container3
	create locations transient;
	locations.add(_rmgArea.allGridControllersByRowColumn[1, 1]);
	locations.add(_rmgArea.allGridControllersByRowColumn[4, 1]);
	ya := self.addYA(YAId, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
						   YACriteriaType_ISO, _isoType,
						   YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE,
						   locations, null);	
	
	//test the new funcationality - reautoplan of the container
	locFullId := _rmgArea.allGridControllersByRowColumn[3, 1].getFullId();
	locFullIdWithHeight := locFullId &amp; " 1"; //full id and height
	//epr par 31576 27/6/13 on pickup will resequence again this time using the YA allocation just created 
	self.testMachinePickupTaskWithLoc(rmg1, task1, locFullId);
	self.testMachineSetdownTaskWithLoc(rmg1, _container, locFullId, _rmgArea.allGridControllersByRowColumn[3, 1]);
	
	
	//test the existing funcationality - queue and move a container to a valid target location
	lc := _rmgArea.getLC("040001");
	self.moveQueued(_container, lc);
	task1 := self.machineTaskRequest(rmg1);
	locFullId := _rmgArea.allGridControllersByRowColumn[4, 1].getFullId();
	locFullIdWithHeight := locFullId &amp; " 1"; //full id and height
	self.testMachineAcceptTaskWithLoc(rmg1, task1, locFullId);
	self.testMachinePickupTaskWithLoc(rmg1, task1, locFullId);
	self.testMachineSetdownTaskWithLoc(rmg1, _container, locFullId, _rmgArea.allGridControllersByRowColumn[4, 1]);
	
	self.machineLogOff(rmg1);
	
epilog
	self.deleteYA(YAId);
	
	delete locations;
end;</source>
        <access>protected</access>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_rmgArea" type="CM_RTGArea"/>
        <Parameter name="_taAccess" type="StringArray"/>
        <Parameter name="_rmgAreaQueue" type="CM_RadioTelemetryQueue" usage="input"/>
    </JadeMethod>
