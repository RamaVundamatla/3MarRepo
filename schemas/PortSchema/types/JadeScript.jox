    <JadeMethod name="rel821_par32604" id="6ec7406c-91db-4e20-b0ba-2356df9a66d5">
        <source>rel821_par32604();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2013	cnwndl1	Initial creation	Par 32604

*/

vars

	nullTrain : CM_NullTrain;
	desc : String;

begin

	desc := app.getErrorString(Default_train);
	foreach nullTrain in CM_NullTrain.instances do
		if nullTrain.description.pos( UnknownMessage, 1 ) &gt; 1 then
			beginTransaction;
			nullTrain.setPropertyValue( CM_NullTrain::description.name, desc );	
			commitTransaction;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rel821_par32796" id="47cc04b2-3456-49de-b2e7-ebdf98a8399d">
        <source>rel821_par32796();
//
// 16 Oct 2013	cnwrs1	Par32792 
//
vars
	xlationTable : CM_XlationTable;
	pxyXlationTable : CM_XlationTable;
	xlationOut : CM_Xlation;
	xlationIn : CM_Xlation;
	pxyXlationIn : CM_Xlation_In;
	loadState : Boolean;
	found : Boolean;
	objUpgraderXlation : CM_ObjectUpgraderXlation821;
begin
	app.initialize;
	foreach xlationTable in CM_XlationTable.instances do 
		if xlationTable.type = XLATION_TYPE_VOYAGETERMINAL then
			app.writeLog("Operator Terminal="&amp;xlationTable.myOperatorTerminal.displayCode, 0);
			foreach xlationOut in xlationTable.allOutwardTranslations do
				found := false;
				foreach xlationIn in xlationTable.allInwardTranslations where xlationIn.foreignCode = xlationOut.foreignCode do
					if xlationIn.getMySystemObject.CM_Voyage.vesselCode = xlationOut.getMySystemObject.CM_Voyage.vesselCode then
						found := true;
					endif;
				endforeach;
				if not found then
					app.writeLog('XlationOut='&amp;xlationOut.String&amp;' xlationIn='&amp;xlationIn.String&amp;' op='&amp;xlationTable.getMyOperator.code&amp;' foreignCode='&amp;xlationOut.foreignCode&amp;' systemCode='&amp;xlationOut.systemCode, 0);
					app.cmsBeginLoad(loadState);
					pxyXlationTable := xlationTable.pxyCreateUpdateProxy;
					create pxyXlationIn transient;
					pxyXlationIn.setProxy(xlationOut.systemCode, xlationOut.foreignCode, pxyXlationTable);
					pxyXlationIn.setXlationTable(pxyXlationTable);
					app.myTrxUA.trxUpdateXlation(pxyXlationTable, app.myPassport);
					app.myProxyManager.deleteProxyLink(pxyXlationTable);
				endif;
			endforeach;
		endif;
	endforeach;
	beginTransaction;
	create objUpgraderXlation;
	objUpgraderXlation.makeComplete;
	commitTransaction;
epilog
	app.cmsEndLoad(loadState);	
end;

</source>
    </JadeMethod>
    <JadeMethod name="rel821_par32796_CleanUp" id="682a1271-1855-4a17-b918-dc9ffbd580e4">
        <source>rel821_par32796_CleanUp();
//
// 20 Mar 2014	cnwrs1	cleanup need for some demo databases for Par 32796 to be installed
// Par 33062 in some databases there is stray data that causing 32796 to fail, sometimes it can cause 821 upgrade stricpt to fail.
// this has only occured in development and demo databases
vars
	xlationTable : CM_XlationTable;
begin
	app.initialize;
	foreach xlationTable in CM_XlationTable.instances do 
		if xlationTable.type = XLATION_TYPE_VOYAGETERMINAL then
			if xlationTable.myOperatorTerminal	 = null then
				beginTransaction;
				xlationTable.erase(NORMAL_ERASE);
				commitTransaction;
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rel821_par32851" id="a1691206-738e-45b5-8c5d-d49be5ca547d">
        <source>rel821_par32851();
// Cash III stuff to take back, cash module config rows, new errors
vars

	etAgent	: EntTableAgent;
	transAgent 	: CM_TranslationAgent;
	array : StringArray;
begin
	app.initialize();
	
	create etAgent transient;
	create array transient;
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	array.add ("ETRow_CashSecPayDivConvert");
	array.add ("ETRow_CashCollectOverpay");
	array.add ("ETRow_CashCollectUnderpay");
	array.add ("ETRow_CashDebtorType");
	array.add ("ETRow_CashInvoiceType");
	array.add ("ETRow_IsPOS");
	array.add ("ETDef_TermCashOps");
	array.add ("ETDef_PaymentMethod");
	etAgent.trxUpdateFromConstant(array);
	
	array.clear();
	array.add('Cannot_pay_more_cash');
	create transAgent transient;
	transAgent.trxLoadSpecificErrors(array);
	return;
	
	write ETRow_CashSecPayDivConvert;
	write ETRow_CashCollectOverpay;
	write ETRow_CashCollectUnderpay;
	write ETRow_CashDebtorType;
	write ETRow_CashInvoiceType;
	write ETRow_IsPOS;
	write ETDef_TermCashOps;
	write ETDef_PaymentMethod;
	
//	write CashSecPayDivConvertRate;
	write CashCollectAllowOverPay;
	write CashInvoiceType;
	write CashDebtorType;
	write CashCollectAllowUnderpay;
	
	write Cannot_pay_more_cash;

epilog
	delete array;
	delete etAgent;
	delete transAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel821_par33019" id="f5320387-d3c9-4d4a-bf4e-9b0435557571">
        <source>rel821_par33019();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2013	cnwdap1		Initial creation PAR #33019 CCMS DPH 2285
//
vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;

begin
	app.initialize;
	
	// load ent table things
	create etAgent transient;
	create array transient;
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	array.add ("ETRow_ClientRef1");
	array.add ("ETRow_ClientRef2");
	array.add ("ETRow_SalesOrderNbr");
	array.add ("ETDef_BOLEnqGeneralCargo");
	array.add ("ETDef_EDITIBOLHdr");
	array.add ("ETDef_EDITICargo");
	array.add ("ETDef_BOLEnqGeneralThumbnail");
	etAgent.trxUpdateFromConstant(array);
	
	// load translatable string
	create transAgent transient;
	create tmpArray transient;
	tmpArray.add('ERR_FIELD_SALESORDERNBR');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	// update query definitions
	app.myRoot.createQueryDefinitionObjects();
	beginTransaction;
	app.myRoot.myQueryMenuRoot.resetUserSelectorColumns(true);
	commitTransaction;
	
	return;
	
	write ETRow_ClientRef1;
	write ETRow_ClientRef2;
	write ETRow_SalesOrderNbr;
	write ETDef_BOLEnqGeneralCargo;
	write ETDef_EDITIBOLHdr;
	write ETDef_EDITICargo;
	write ETDef_BOLEnqGeneralThumbnail;
	write ERR_FIELD_SALESORDERNBR;
epilog
	delete etAgent;
	delete array;
	delete transAgent;
	delete tmpArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel821_par33661" id="d49136bc-f421-4723-9bdd-844249d5c5f5">
        <source>rel821_par33661();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/03/2014	cnwdap1		Initial creation PAR #33661 Rebuild myMeasurementType references on CM_ProdAttrDecimal and CM_ProdAttrInteger
//
vars
	weightType, linearType, volumeType, densityType : CM_MeasurementType;
	decAttr	: CM_ProdAttrDecimal;
	intAttr	: CM_ProdAttrInteger;
	
begin
	app.initialize();
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	linearType := app.getDefaultMeasurementForType(Type_Linear);
	volumeType := app.getDefaultMeasurementForType(Type_Volume);
	densityType := app.getDefaultMeasurementForType(Type_Density);

	beginTransaction;
	foreach decAttr in CM_ProdAttrDecimal.instances where decAttr.myMeasurementType = null do 
		if decAttr.name.isOneOf("myWidth", "myHeight", "myLength") then
			decAttr.setMyMeasurementType(linearType);
		elseif decAttr.name = "myVolume" then
			decAttr.setMyMeasurementType(volumeType);
		elseif decAttr.name = "myWeight" then
			decAttr.setMyMeasurementType(weightType);
		endif;
	endforeach;
	foreach intAttr in CM_ProdAttrInteger.instances where intAttr.myMeasurementType = null do
		if intAttr.name = "myDensity" then
			intAttr.setMyMeasurementType(densityType);
		endif;
	endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
