    <JadeMethod name="trxCreateFinanceOneActivity" id="f025422d-af09-4c16-858b-477a2114e7d5">
        <updating/>
        <source>trxCreateFinanceOneActivity(_invoice : CM_Invoice input;
							_financeOneDef : CM_FinanceOneSeviceDef;
							_request : String; 
							_errorResponse : String; 
							_exceptionResponse : String; 
							_successResponse : String;
							_realActivityHistory : CM_ExternalWebServiceActivity output;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 March 2023		jlier1	Initial creation 56856
23 September 2024	navmd1	TFS 66210 Added _realActivityHistory output and moved status setting to its own method

*/

vars
	pxyActivity : CM_EWSActivityFinanceOne;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;	
	
	
	create pxyActivity transient;
	pxyActivity.initialiseFromInvoiceAndDef(_invoice, _financeOneDef);
	pxyActivity.setProxyRequestDetails(_request,_errorResponse &amp; _exceptionResponse &amp; _successResponse,null);
	pxyActivity.setStatus(_errorResponse &lt;&gt; null, _exceptionResponse  &lt;&gt; null, _successResponse &lt;&gt; null);
	
	_realActivityHistory := app.myUtilityCA.utlCreateEWSActivityHistory(pxyActivity, _passport);
	
	_invoice.setExternalInterfaceStatus(pxyActivity.status);
	
epilog
	delete pxyActivity;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_financeOneDef" type="CM_FinanceOneSeviceDef"/>
        <Parameter name="_request" type="String"/>
        <Parameter name="_errorResponse" type="String"/>
        <Parameter name="_exceptionResponse" type="String"/>
        <Parameter name="_successResponse" type="String"/>
        <Parameter name="_realActivityHistory" type="CM_ExternalWebServiceActivity" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
