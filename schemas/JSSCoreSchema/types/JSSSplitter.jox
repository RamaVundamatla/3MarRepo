        <source>leftToRightRatio(set: Boolean; _value: Integer io) mapping, protected;

/*
Purpose:


Return Value:



Date		Who		Reason
22 Feb 00	KPD		Initial creation


*/

vars

begin
    if set then
    	if _value &lt; 0 or _value &gt; 100 then
    		_value := 50;
    	endif;
    endif;


epilog	


end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="5fe5424c-bb2c-4850-b2eb-e19015bf753e">
        <updating/>
        <source>mouseUp(cntrl: BaseControl input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		25 June 2002 by cnwdad1
//
// Purpose:		Called by the splitter bar when the user mouse action is complete.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.jssfmMouseUp(self, button, shift, x, y);
	
	inheritMethod(cntrl, button, shift, x, y);
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
