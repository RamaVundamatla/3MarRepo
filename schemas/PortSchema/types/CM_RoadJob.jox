    <JadeMethod name="getFirstTrackedItem" id="ee081c7a-887f-42d3-8952-4c0bc971e877">
        <source>getFirstTrackedItem(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023	navlw1	Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 		: CM_TrackedItem;
	wle		: CM_WorkListEntry;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid); 
	
	foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if not wle.isChassis then
			invalid := false;
			ti := wle.myTrackedItem;
	
			if ti &lt;&gt; null then
				ti.edition;
				if invalid then
					return null;
				else
					return ti;
				endif;
			endif;
		endif;
	endforeach;
	return null;
epilog

end;
</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstWle" id="b77dd026-75ed-49dd-bd4e-b24045228936">
        <source>getFirstWle(): CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2024	navhl20	ChangeRequest 63511: FR | 53891 - Mobile App changes for Delivery Dispatch - Remedial
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle		: CM_WorkListEntry;
begin
	
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		if not wle.isChassis then
			return wle;
		endif;
	endforeach;
	return null;
epilog
	
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
