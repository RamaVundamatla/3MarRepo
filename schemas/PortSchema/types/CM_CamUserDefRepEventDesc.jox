    <JadeMethod name="outputFile" id="9b91e8c6-0631-4128-87cd-6b0fd7b28357">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
/* 
---------------------------------------------------------------------------
 Created:     P Bremmers               

 Purpose:     MES1008

 Parameters:  None

 Returns:     Nothing

 Changed On   	Changed By  Reason
 ----------   	----------  --------------------------------------------------
 10/02/2011		cnwcs5		CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input 
 18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
 30 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
 09 Jan 2020	jlgdap1		TFS 48016 SNO Deletion CODECO - new _transactions parameter
---------------------------------------------------------------------------
*/

vars

begin
	_camTaskHistory.setFileName(_camFile.CM_CamFileJRW.jrwFilename.getFileNameAndExtension);

	_camTaskHistory.updateFileDataFromCamFileJRW(_camFile.CM_CamFileJRW);	// Copies huge string array and the file storage header
end;
</source>
