    <JadeMethod name="copyToRealWSObject" id="4ab68b76-048f-480d-af8b-79ab0a573b72">
        <source>copyToRealWSObject(_realRequest: SAP19_DataKinerja_OB_DT input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	item			: CMIF_SAPDataKinerjaItem;
	realItem		: SAP19_DataKinerja_OB_DT_item;
	
begin
	inheritMethod(_realRequest, _createdObjects);
	create _realRequest.t_Kinerja transient;
	_createdObjects.add(_realRequest.t_Kinerja);
	// manual population of item required
	foreach item in self.allItem do
		create realItem transient;
		_createdObjects.add(realItem);
		item.copyToRealWSObject(realItem, _createdObjects);
		//epr TFS 44229 8/4/19
		
		_realRequest.t_Kinerja.item.add(realItem);
	endforeach;

epilog

end;</source>
        <Parameter name="_realRequest" type="SAP19_DataKinerja_OB_DT" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyToSAPDataKinerjaReq" id="ad7f52c2-e11c-4f5a-a181-21a16c6f5e9c">
        <source>copyToSAPDataKinerjaReq(_obj : Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Aug 2018 cnwma1ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
*/

vars
	item 	 	: CMIF_SAPDataKinerjaItem;
	term 	 	: CM_Terminal;
	wharf    	: HMS_Wharf;
	berth    	: HMS_Berth;
	obj      	: Object;
	hmsMove  	: HMS_Movement;
	hmsVoyage	: HMS_VoyageData;
	hmsMoveArr 	: HMS_MovementArray;
	iter		: Iterator;
	moveDict	: HMS_MovementByDateDict;
	startCalFrom: TimeStamp;
	kinerjaArr	: CMIF_KinerjaArray;
	kinerja 	: CMIF_Kinerja;
	invoice     : CM_Invoice;
begin
	
	if _obj.isKindOf(CM_Terminal) then
		term := _obj.CM_Terminal;
		kinerjaArr := term.getTerminalKinerja();
		
	elseif _obj.isKindOf(CM_Invoice) then
		invoice := _obj.CM_Invoice;
		kinerjaArr := invoice.getKinrjaForInvoice();
	endif;
	
	if kinerjaArr &lt;&gt; null then
		if not kinerjaArr.isEmpty then
			foreach kinerja in kinerjaArr do
				create item transient;
				/*Used by Nota Kapal */
				item.pERIODE 						:= kinerja.dateTime.Date.formatAsYYYYMMDD[1:6].String;
				item.dATA_SOURCE					:= self.convertNull(kinerja.dataSource).String;
				item.bERTH_ID						:= self.convertNull(kinerja.berthID).String;
				item.bERTH_NAME						:= self.convertNull(kinerja.berthName).String;
				item.bRANCH_CODE					:= self.convertNull(kinerja.branchCode).String;
				item.wAITING_TIME_DERMAGA 			:= self.convertNull(kinerja.waitingDermagaTM).String;
				item.wAITING_TIME_PILOT   			:= self.convertNull(kinerja.waitingPilotTM).String;
				item.aPPROACH_TIME 					:= self.convertNull(kinerja.approachTM).String;
				item.bERTHING_TIME  				:= self.convertNull(kinerja.berthTM).String;
				item.bERTHING_WORKING_TIME			:= self.convertNull(kinerja.berthWorkingTM).String;
				item.bERTH_THROUGPUT				:= self.convertNull(kinerja.berthThroughPut).String;
				item.eFEKTIF_TIME					:= self.convertNull(kinerja.effectiveTM).String;
				item.eT_BT							:= self.convertNull(kinerja.etBT).String;
				item.iDLE_TIME		    			:= self.convertNull(kinerja.idleTM).String;
				item.nON_OPERATING_TIME   			:= self.convertNull(kinerja.notOperationTM).String;
				item.pOSTPONE_TIME  				:= self.convertNull(kinerja.postPoneTM).String;
				item.tURN_AROUND_TIME 				:= self.convertNull(kinerja.turnRoundTM).String;
				item.bOR							:= self.convertNull(kinerja.berthOccupancyRatio).String;				
				item.pRODUKTIVITAS  				:= self.convertNull(kinerja.productivitas).String;
				item.pROD_CONTAINER  				:= self.convertNull(kinerja.prodContainer).String;
				item.pROD_LIQUID_BULK 				:= self.convertNull(kinerja.prodLiquid).String;
				
				/*Used by Nota Jasa Penumpukan */
				item.dWELLING_TIME_BONGKAR			:= self.convertNull(kinerja.dwellTMBongkar).String;
				item.dWELLING_TIME_MUAT 			:= self.convertNull(kinerja.dwellTMMuat).String;
				item.tOTAL_DWELLING_TIME_IMPORT 	:= self.convertNull(kinerja.dwellTMImp).String;
				item.tOTAL_DWELLING_TIME_EXPORT 	:= self.convertNull(kinerja.dwellTMExp).String;
				
				/*Used By Daily BGP*/
				item.sOR 							:= self.convertNull(kinerja.shedOccupancyRatio).String;
				item.yOR 							:= self.convertNull(kinerja.yardOccupancyRatio).String;
				
				/*Not Used Items*/
				item.uOM 							:= self.convertNull(kinerja.uOM).String;
				item.rEALIZATION 					:= self.convertNull(kinerja.realization).String;
				item.dWELLING_TIME_IMPORT_PELINDO1 	:= self.convertNull(kinerja.dwellTMImpPEL).String;
				item.dWELLING_TIME_EXPORT_PELINDO1 	:= self.convertNull(kinerja.dwellTMExpPEL).String;
				
				self.allItem.add(item);
			endforeach;
		endif;
	endif;
epilog
	//02 Oct 2019	NDL	 - Transient leak, found when writing unit tests for TFS 46758
	if kinerjaArr &lt;&gt; null and not kinerjaArr.isEmpty then
		kinerjaArr.purge();
	endif;
	delete kinerjaArr;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="28064d93-c8a9-4476-8204-a8e65517251a">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.allItem.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getActivityHistoryExtraDetails" id="f12ff70e-66dc-4c20-84c1-8e5d27e27686">
        <source>getActivityHistoryExtraDetails(_activityHistory: CM_ActivityHistoryExtInterface input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	typeString : String;

begin

	typeString := "Daily";

	if _activityHistory.myInvoice &lt;&gt; null then
		if _activityHistory.myInvoice.myVoyage &lt;&gt; null then
			typeString := _activityHistory.myInvoice.myVoyage.code; 
		endif;
	endif;
		
	return typeString;

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
