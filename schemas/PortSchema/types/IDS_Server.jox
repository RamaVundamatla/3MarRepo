    <JadeMethod name="asynchObjectRegister" id="e3ab5ed0-7a74-4589-bb90-aa237e030ccd">
        <updating/>
        <source>asynchObjectRegister(asynchObject:IDispatch io; objectType:Integer io; config:Integer io; reserved:Any io) updating;
	// 

vars
	_p1 : IDispatch;

begin

	_p1 := asynchObject;


	_jadeActiveXMethodio('AsynchObjectRegister', 1, _p1, objectType, config, reserved);
	if _p1 = null then
		asynchObject := null;
	else
		asynchObject := _p1._morph(IDispatch).IDispatch;
	endif;

end;
</source>
        <Parameter name="asynchObject" type="IDispatch" usage="io"/>
        <Parameter name="objectType" type="Integer" usage="io"/>
        <Parameter name="config" type="Integer" usage="io"/>
        <Parameter name="reserved" type="Any" usage="io"/>
    </JadeMethod>
