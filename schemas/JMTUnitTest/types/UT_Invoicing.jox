        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="checkEmail" id="12d2e357-8c5d-4c0c-9352-ac9c1753cbab">
        <source>checkEmail(_emailRequest : BGP_EmailSendRequest) protected;
// CCMS 2120
vars
	count	: Integer;
	itemCount,
	sublineCount,
	topLevelCount,
	childCount	: Integer;
	bin		: Binary;
	fileName,
	str		: String;
	fdsh	: CM_FileDataStorageHeader;
	xmlDoc	: JadeXMLDocument;
	parser	: JadeXMLDocumentParser;
	element,
	rootElement,
	childElement	: JadeXMLElement;
	xmlNode,
	childNode,
	childNode2	: JadeXMLNode;
	attr		: JadeXMLAttribute;
begin
	// should only be one attached file
	foreach fdsh in _emailRequest.allAttachedFiles do
		bin := fdsh.getDataAsBinary();
		count := count + 1;
		fileName := fdsh.fileName;
		if fileName.length &gt; 4 then
			self.assertTrueMsg(fileName[fileName.length-3:end]='.xml', "Email file name suffix");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Email attached files");
	str := bin.String;

	// ####################################################
	// ####################################################
	// ####################################################
	// #### NOTE if failing here see if BUG 52509 has been fixed.
	// ####################################################
	// ####################################################
	// ####################################################
	self.assertTrueMsg(str &lt;&gt; null, "XML Attachment '" &amp; fileName &amp; "' is null (" &amp; method.qualifiedName &amp;")"); // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1
	
	create xmlDoc transient;
	create parser transient;
	parser.parseDocumentString(xmlDoc, str);
	rootElement := xmlDoc.rootElement;
	foreach xmlNode in rootElement.childNodes do
		element := xmlNode.JadeXMLElement;
		topLevelCount := topLevelCount + 1;
		// 'invoice', 'invoiceparties', 3 x 'invoiceitem', 'invoicesummary'
		foreach childNode in xmlNode.childNodes do
			childElement := childNode.JadeXMLElement;
			if childElement.localName = "itemdetails" then
				itemCount := itemCount + 1;
				sublineCount := 0;
				foreach attr in childElement.attributes do
					self.assertEqualMsg(attr.value.Integer, itemCount, "&lt;invoiceitem 'itemid' attribute value");
				endforeach;
				// test CM_DebtorInvLineType otherCode values
				childCount := 0;
				foreach childNode2 in childElement.childNodes do
					childElement := childNode2.JadeXMLElement;
					childCount := childCount + 1;
					if itemCount = 1 then
						if childCount = 1 then
							self.assertEqualMsg(childElement.textData, 'CODE01', itemCount.String &amp; " itemidentifier value");
						elseif childCount = 2 then
							self.assertEqualMsg(childElement.textData, 'UT_ILD01', itemCount.String &amp; " itemdescription value");
						endif;
					elseif itemCount = 2 then
						if childCount = 1 then
							self.assertEqualMsg(childElement.textData, 'CODE02', itemCount.String &amp; " itemidentifier value");
						elseif childCount = 2 then
							self.assertEqualMsg(childElement.textData, 'UT_ILD02', itemCount.String &amp; " itemdescription value");
						endif;
					elseif itemCount = 3 then
						if childCount = 1 then
							self.assertEqualMsg(childElement.textData, 'CODE03', itemCount.String &amp; " itemidentifier value");
						elseif childCount = 2 then
							self.assertEqualMsg(childElement.textData, 'UT_ILD03', itemCount.String &amp; " itemdescription value");
						endif;
					endif;
				endforeach;
				self.assertEqualMsg(childCount, 2, itemCount.String &amp; " itemdetails elements");
			elseif childElement.localName = "invoiceitemsubline" then
				sublineCount := sublineCount + 1;
				foreach attr in childElement.attributes do
					self.assertEqualMsg(attr.value.Integer, sublineCount, "&lt;invoiceitemsubline 'itemid' attribute value");
				endforeach;
			elseif childElement.localName = "itemcost" then
				// test summary calculations
				childCount := 0;
				foreach childNode2 in childElement.childNodes do
					childElement := childNode2.JadeXMLElement;
					childCount := childCount + 1;
					// currency
					if childElement.localName = 'currency' then
						self.assertEqualMsg(childElement.textData, 'NZD', itemCount.String &amp; " currency value");
					elseif childElement.localName = 'unitprice' then
						self.assertEqualMsg(childElement.textData.Decimal, 12.Decimal, itemCount.String &amp; " unitprice value");
					elseif childElement.localName = 'quantity' then
						self.assertEqualMsg(childElement.textData.Integer, 15, itemCount.String &amp; " quantity value");
					elseif childElement.localName = 'netamount' then
						self.assertEqualMsg(childElement.textData.Decimal, 180.Decimal, itemCount.String &amp; " netamount value");
					elseif childElement.localName = 'gst' then
						self.assertEqualMsg(childElement.textData.Decimal, 27.Decimal, itemCount.String &amp; " gst value");
					elseif childElement.localName = 'totalamount' then
						self.assertEqualMsg(childElement.textData.Decimal, 207.Decimal, itemCount.String &amp; " totalamount value");
					endif;
				endforeach;
				self.assertEqualMsg(childCount, 6, itemCount.String &amp; " itemcost elements");
				// invoice summary values
			elseif childElement.localName = "invoicequantity" then
				childCount := 0;
				foreach childNode2 in childElement.childNodes do
					childElement := childNode2.JadeXMLElement;
					childCount := childCount + 1;
					// currency
					if childElement.localName = 'invoiceqty' then
						self.assertEqualMsg(childElement.textData.Integer, 45, "invoicequantity value");
					endif;
				endforeach;
				self.assertEqualMsg(childCount, 1, "invoicequantity elements");
			elseif childElement.localName = "invoicecost" then
				// test summary totals
				childCount := 0;
				foreach childNode2 in childElement.childNodes do
					childElement := childNode2.JadeXMLElement;
					childCount := childCount + 1;
					// currency
					if childElement.localName = 'currency' then
						self.assertEqualMsg(childElement.textData, 'NZD', itemCount.String &amp; " currency value");
					elseif childElement.localName = 'netamount' then
						self.assertEqualMsg(childElement.textData.Decimal, 540.Decimal, itemCount.String &amp; " netamount value");
					elseif childElement.localName = 'gst' then
						self.assertEqualMsg(childElement.textData.Decimal, 81.Decimal, itemCount.String &amp; " gst value");
					elseif childElement.localName = 'totalamount' then
						self.assertEqualMsg(childElement.textData.Decimal, 621.Decimal, itemCount.String &amp; " totalamount value");
					endif;
				endforeach;
				self.assertEqualMsg(childCount, 4, "invoicecost elements");
			endif;
		endforeach;
	endforeach;
	self.assertEqualMsg(topLevelCount, 6, "top-level elements");
epilog
	delete xmlDoc;
	delete parser;
end;
</source>
        <access>protected</access>
        <Parameter name="_emailRequest" type="BGP_EmailSendRequest"/>
    </JadeMethod>
    <JadeMethod name="checkInvLineCopyValues" id="05d59145-3689-4b93-8c68-f17e3ddb29ab">
        <source>checkInvLineCopyValues(_ti : CM_TrackedItem; cmifInvLineCopy : CMIF_InvoiceLineCopy; selectedInvLine, realInvLine : CM_InvoiceLine);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55543: Jade - Invoice Line Copy Unit Test

*/

vars
	ti : CM_TrackedItem;
begin
	if cmifInvLineCopy.newInvoice then
		self.assertEqual(cmifInvLineCopy.myInvoice, realInvLine.invoice);
		self.assertEqual(selectedInvLine.invoice.debtor, realInvLine.debtor);
	else
		self.assertEqual(selectedInvLine.invoice, realInvLine.invoice);
		self.assertEqual(selectedInvLine.debtor, realInvLine.debtor);
	endif;
	
	if cmifInvLineCopy.differentChargeDT then
		self.assertEqual(cmifInvLineCopy.chargeDT, realInvLine.chargeTime);
	else
		self.assertEqual(selectedInvLine.chargeTime, realInvLine.chargeTime);
	endif;
	
	self.assertEqual(realInvLine.STATUS_NORMAL,realInvLine.status);
	self.assertEqual(selectedInvLine.bank, realInvLine.bank);
	self.assertEqual(selectedInvLine.invoiceLineDesc, realInvLine.invoiceLineDesc);
	self.assertEqual(selectedInvLine.paymentType, realInvLine.paymentType);
	self.assertEqual(0, realInvLine.exportedCount);
	self.assertEqual(0, realInvLine.overriddenChargeCount);
	self.assertEqual(0, realInvLine.escalatingDays);
	self.assertEqual(0, realInvLine.escalatingCount);
	// should not be referencing any transactions
	self.assertEqual(selectedInvLine.myTransactionBOL, null);
	self.assertEqual(selectedInvLine.myTransactionEvent, null);
	self.assertEqual(selectedInvLine.myTransactionHMS, null);
	self.assertEqual(selectedInvLine.myTransactionVTMIS, null);
	self.assertEqual(selectedInvLine.myTransactionWO, null);
	self.assertEqual(selectedInvLine.myTransactionTI, null);
	
	if cmifInvLineCopy.differentCargos then
		ti := _ti;
	else
		ti := selectedInvLine.trackedItem;
	endif;
	
	self.assertEqual(ti, realInvLine.trackedItem);
	
	if ti &lt;&gt; null then
		self.assertEqual(ti.id,realInvLine.trackedItemId);
		self.assertEqual(ti.getChargeQuantity(),realInvLine.getTrackedItemQuantity());
		self.assertEqual(ti.getChargeVolume(),realInvLine.getTrackedItemVolume());
		self.assertEqual(ti.length.Real,realInvLine.getTrackedItemLength());
		self.assertEqual(ti.getChargeWeight(),realInvLine.getTrackedItemWeight().Real);
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="cmifInvLineCopy" type="CMIF_InvoiceLineCopy"/>
        <Parameter name="selectedInvLine" type="CM_InvoiceLine"/>
        <Parameter name="realInvLine" type="CM_InvoiceLine"/>
    </JadeMethod>
