    </JadeMethod>
    <JadeMethod name="getAllLoadedSOHLocnsForLot" id="31987927-d02e-485e-83cd-e5829d9a05d9">
        <updating/>
        <source>getAllLoadedSOHLocnsForLot()updating;
//--------------------------------------------------------------
//Created: 07 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	lot 		: CM_LogLot;
	hatch,
	place		: Integer;
	placeStr	: String;
begin

	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	self.allSOHLocationsForLot.clear();
	self.allLogs.clear;
		
	lot := self.cmbLot.listObject.CM_LogLot;
	hatch := self.tblSelection.getValueByName(ETRow_Hatch).Integer;
	placeStr := self.tblSelection.getValueByName(ETRow_Place).String;

	if placeStr = 'DECK' then
		place := PlaceDeck;
	elseif placeStr = 'HOLD' then
		place := PlaceHold;
	endif;	
	
	
	if self.myLogVoyage = null then
		return;
	endif;
	
	self.myLogVoyage.myLogVoyageStructure.getAllLoadedSOHForLotHatchPl(self.allSOHLocationsForLot, lot, hatch, place);
	//self.myLogVoyage.getAllLoadedSOHLocnsForLot(self.allSOHLocationsForLot, lot);

	//self.showSummaries(); 
	self.showLotDetails();

end;</source>
    </JadeMethod>
    <JadeMethod name="getAvailableLocations" id="ffd9a168-87e5-4e92-ab58-803d59317d5d">
        <updating/>
        <source>getAvailableLocations() protected, updating;

vars

	location		: CM_LocationsController;
	tmpLCSearch		: CMIF_SearchTypes;
	def				: CMIF_DocketLogDef;
	row,
	numRows			: Integer;
	cell			: JadeTableCell;
	array			: CMIF_DocketLogDefByLocation;
	isFirst			: Boolean;
	prevSelection	: String;
	productLog		: CM_ProductLog;
	tmpLocs			: CM_LCByIdExtKeyDict;//cnwdz2 par 15385
	tmpLocation		: CM_LocationsController;//cnwdz2 par 15385
begin

	app.mousePointer := MousePointer_HourGlass;	
	self.allToLocations.clear;
	prevSelection := self.cmbLocation.text;
	create tmpLCSearch transient;
	create tmpLocs transient; //cnwdz2 par 15385
	
	if self.selection = DOCKET then
		isFirst := true;
		create array transient;
		self.getSelectedDefs(array);
		foreach def in array where not def.isNoNumber do
			tmpLCSearch.myOperator := def.myOperator;
			if def.getSpeciesReference &lt;&gt; null and not tmpLCSearch.allSpecies.includes(def.getSpeciesReference) then
				tmpLCSearch.allSpecies.add(def.getSpeciesReference);
			endif;
			
			if def.getGradeReference &lt;&gt; null and not tmpLCSearch.allGrades.includes(def.getGradeReference) then
				tmpLCSearch.allGrades.add(def.getGradeReference);
			endif;
			
			if def.getTypeReference &lt;&gt; null and not tmpLCSearch.allTypes.includes(def.getTypeReference) then
				tmpLCSearch.allTypes.add(def.getTypeReference);
			endif;
			
			if def.getTreatmentReference &lt;&gt; null and not tmpLCSearch.allTreatments.includes(def.getTreatmentReference) then
				tmpLCSearch.allTreatments.add(def.getTreatmentReference);		
			endif;
			
			if def.getLengthReference &lt;&gt; null and not tmpLCSearch.allLengths.includes(def.getLengthReference) then
				tmpLCSearch.allLengths.add(def.getLengthReference);
			endif;
			
		endforeach;	
		if isFirst then
			self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);
			isFirst := false;
		else
			self.myTerminal.availableLocationsForTypeSub(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);
		endif;

	elseif self.selection = TICKET then
		if self.myLog &lt;&gt; null then
			tmpLCSearch.myOperator := self.myLog.myOperator;
			tmpLCSearch.mySpecies := self.myLog.myLogSpecies;
			tmpLCSearch.myGrade := self.myLog.myLogGrade;
			tmpLCSearch.myType := self.myLog.myLogType;
			tmpLCSearch.myTreatment := self.myLog.myLogTreatment;
			tmpLCSearch.myLength := self.myLog.myLogLength;
			self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);	
		endif;
	//cnwdz2 par 15385
	elseif self.selection = LOT then
		isFirst	:= true;
		numRows 	:= self.tblSelectData.rows;
		foreach row in 2 to numRows do
			cell :=	self.tblSelectData.accessCell(row, 1);
			if cell.text.Integer.Boolean = true then
				// loop through checked rows
				self.mySOHLocation := self.tblSelectData.accessRow(row).itemObject.CM_SOHLocation;
				if self.mySOHLocation &lt;&gt; null then
					productLog := self.mySOHLocation.myProduct.CM_ProductLog;
					tmpLCSearch.myOperator := productLog.myOperator;
					tmpLCSearch.mySpecies := productLog.myLogSpecies;
					tmpLCSearch.myGrade := productLog.myLogGrade;
					tmpLCSearch.myType := productLog.myLogType;
					tmpLCSearch.myTreatment := productLog.myLogTreatment;
					tmpLCSearch.myLength := productLog.myLogLength;
					self.myTerminal.availableLocationsForType(tmpLCSearch, tmpLocs, TA_TYPE_LOGAREA);
//					self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);			
				endif;		
				
				if isFirst then
					tmpLocs.copy(self.allToLocations);
					isFirst := false;
				endif;		
				foreach tmpLocation in self.allToLocations do
					if not tmpLocs.includes(tmpLocation) then
						self.allToLocations.remove(tmpLocation);
					endif;
				endforeach;
			endif;					
		endforeach;
	endif;
	
	// Load up combobox.	
	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbLocation, self.allToLocations);
	if self.cmbLocation.findStringExact(1,prevSelection) &lt;&gt; -1 then
		self.cmbLocation.text := prevSelection;
		self.tblActionData.setValueByName(ETRow_Location, prevSelection);	
	else
		self.tblActionData.setValueByName(ETRow_Location, null);	
	endif;

epilog
	
	delete tmpLCSearch;
	delete tmpLocs;	//cnwdz2 par 15385
	delete array;
	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getPlace" id="14fdc017-72ce-4504-94dd-e2abfc60b31f">
        <source>getPlace(_place : String) : Integer protected;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars

begin

	if _place = 'DECK' then
		return PlaceDeck;
	elseif _place = 'HOLD' then
		return PlaceHold;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_place" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDefs" id="9f2777ee-8787-40aa-bc5f-046a3c9a31ec">
        <source>getSelectedDefs(_array : CMIF_DocketLogDefByLocation input) protected;

vars

	row			: Integer;
	cell		: JadeTableCell;
	tempArray	: ObjectArray;
	def			: CMIF_DocketLogDef;
	max			: Integer;

begin

	_array.clear;
	create tempArray transient;
	max	:= self.tblSelectData.rows;
	self.allDocketLogDef.copy(tempArray);
	foreach row in self.tblSelectData.fixedRows + 1 to max do
		cell :=	self.tblSelectData.accessCell(row, 1);
		if cell.text.Integer.Boolean = true then
			def := tempArray[row - 1].CMIF_DocketLogDef;
			if def &lt;&gt; null then
				_array.add(def);
			endif;
		endif;
	endforeach;
epilog
	delete tempArray;
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="CMIF_DocketLogDefByLocation" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedLogs" id="6305229d-a1e3-4cb0-abf4-6e9eb31ef667">
        <source>getSelectedLogs(_array : CM_TISet io) protected;


vars

	row			: Integer;
	cell		: JadeTableCell;
	log			: CM_Log;
	theColumn,
	max,
	fixed		: Integer;
	
begin

	// Par 9784
	_array.clear;
	max := self.tblSelectData.rows;
	fixed := self.tblSelectData.fixedRows;
	theColumn := self.tblSelectData.getColumnByRowName(ETRow_Filler);		
	foreach row in fixed + 1 to max do
		cell :=	self.tblSelectData.accessCell(row, theColumn);
		if cell.text.Integer.Boolean = true then
			log := self.allLogs[row - fixed].CM_Log;
			if log &lt;&gt; null then
				_array.add(log);
			endif;
		endif;
	endforeach;
	

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="54ed7251-db6d-4a0d-bc7c-13f2147d63ff">
        <updating/>
        <source>getXMLSettingsForSave() : String updating;


vars

	xmlStr	: String;
begin
	
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblSelectData.getXmlStrForColumns(true);

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotoStartField" id="c47beb2e-70c4-4e9f-80fe-9acad71d50fe">
        <source>gotoStartField() protected;

vars

begin

	self.tblSelection.setFocus();
	if self.selection = DOCKET then
		self.tblSelection.goToRowByName(ETRow_DocketNumber);
	elseif self.selection = TICKET then
		self.tblSelection.goToRowByName(ETRow_LogId);
	elseif self.selection = NONUMBER or
		self.selection = LOT then
		self.tblSelection.goToRowByName(ETRow_Lot);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="620ff83d-40a6-4ccb-9c02-f4d444a2b52a">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		tblSelection.handleFormTab(keyCode, shift, optNoNumber, tblSelectData);
		tblActionData.handleFormTab(keyCode, shift, tblSelectData, tblActionData);
		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;
	inheritMethod(keyCode, shift);
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="84aa629a-e64b-41e9-a36c-ca9db4fd3284">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars
	showCaptions : Boolean;
	idx		: Integer;
	gVoy	: CM_VoyageGlobal;
	gVoyDict: CM_VoyageGlobalByCodeDict;
	voy		: CM_Voyage;
begin
	self.doOptDocketClick();
	self.optDocket.value := true;
	
	gVoyDict := app.myRoot.allVoyagesGlobal;
	
	foreach gVoy in gVoyDict do
		if gVoy.isArchived then
			continue;
		endif;
		foreach voy in gVoy.allVoyages do
			if voy.myLogVoyageStructure = null then
				continue;
			endif;
			if voy.myTerminal = self.myTerminal then
				//	Sep 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, don't show completed voyages
				if voy.isClosedStatus() then
					continue;
				endif;
				// may need to add the date in here
				// PAR13445 Mohammad
				idx := self.cmbVoyageGlobal.addItem(voy.code &amp; ' ' &amp;gVoy.vesselName);
				self.cmbVoyageGlobal.itemObject[idx] := gVoy;
				break;
			endif;
		endforeach;
	endforeach;
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;	 //turn it off 
		self.toolbarShowCaptions(showCaptions);	// turn back on and get sizeDeiff in toolbarShowCaptions
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadHatchAndPlace" id="110f8107-f2af-4f7c-88b6-10e26c4f4a63">
        <source>loadHatchAndPlace() protected;

vars

	count		: Integer;

begin

	self.cmbHatch.clear;
	self.cmbPlace.clear;
	self.cmbHatch.addItem(null);
	foreach count in 1 to self.myLogVoyage.myLogVoyageStructure.numHatches do
		self.cmbHatch.addItem(count.String);
	endforeach;	

	self.cmbPlace.addItem(null);
	self.cmbPlace.addItem('DECK');
	self.cmbPlace.addItem('HOLD');

end;</source>
        <access>protected</access>
    </JadeMethod>
