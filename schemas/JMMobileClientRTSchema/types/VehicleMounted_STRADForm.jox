    <JadeMethod name="getAllSelectedQueueTasks" id="71d1a054-e692-451e-a83e-1f56a8b7c616">
        <source>getAllSelectedQueueTasks(_allSelectedEntries : CM_RTQueueTaskArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwer1	Initial creation

*/

vars
	theTable 	: Table;
	row : Integer;
begin
	theTable:=tblJobs;
	if theTable.rows = theTable.fixedRows + 1 then
		_allSelectedEntries.add( theTable.accessRow(theTable.fixedRows + 1 ).itemObject.CM_RTQueueTask);
	else
		row :=theTable.fixedRows + 1; 
		while row &lt;=  theTable.rows do
			if  theTable.accessCell(row,1).text.Integer = true.Integer then
				_allSelectedEntries.add( theTable.accessRow(row).itemObject.CM_RTQueueTask);
			endif;
			row:=row+1;
		endwhile;
	endif;
epilog

end;</source>
        <Parameter name="_allSelectedEntries" type="MobileHandHeldThin::CM_RTQueueTaskArray" usage="input"/>
    </JadeMethod>
