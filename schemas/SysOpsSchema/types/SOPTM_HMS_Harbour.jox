    <JadeMethod name="getEmailGroups" id="ac251b5d-676e-429e-800a-d71732dce3fa">
        <source>getEmailGroups();
// -------------------------------------------
// Created 11 May 2004 by cnwdvb1
// -------------------------------------------
vars

	iter 	: Iterator;
	entity	: CM_EmailEntity;

begin

	self.allEmailGroups.clear();
	iter := app.myRoot.allEmailEntities.createIterator();
	while iter.next(entity) do
		if entity.type = Email_Group then
			self.allEmailGroups.add(entity.CM_EmailGroup);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="e9192d22-83dd-4ff9-a78b-5a25a776e560">
        <source>initShtMultiSelect();
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
begin

	theForm := self.myForm;
	inheritMethod;	
	self.setupMultiSelect1('Terminals',app.myRoot.allTerminals,SOP_HMS_TableMaintForm::displayEntryAllTerminals.name);	
	self.setupMultiSelect2('Wharf View Display Order',null,SOP_HMS_TableMaintForm::displayEntryWharf.name);
	theForm.mulSelect2.mySelectedListBox.sorted := false;	

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtTblInput2" id="cab95c68-c3fc-47f4-be9c-e8725384b6aa">
        <updating/>
        <source>initShtTblInput2() updating;
//--------------------------------------------------
// Created:	08 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	row 	: Integer;
	str		: String;
	form	: SOP_TableMaintForm;
	table	: CM_EntryTable;
	tmpSheet : CMUI_Sheet;
begin
	
	inheritMethod();
	
	form := self.myForm;
	tmpSheet := form.shtTblInput2;
	tmpSheet.visible := true;
	table := form.tblInput2;

	form.initTblInput(form.tblInput2, ETDef_HMSHarbourDefaults);	
	form.initTblInput(form.tblInput3, ETDef_ServiceOrderTimes);
		
	if table.myEntTableDef &lt;&gt; null then
		tmpSheet.caption := table.myEntTableDef.description;

		row := table.getRowByName(ETRow_TidalTimeTypeArrival);
		str := app.getErrorString(PilotOnBoard) &amp; Tab &amp; app.getErrorString(PilotOffVessel);
		table.setComboValues(row, str);

		row := table.getRowByName(ETRow_TidalTimeTypeDeparture);
		str := app.getErrorString(PilotOffVessel) &amp; Tab &amp; app.getErrorString(PilotOnBoard);		
		table.setComboValues(row, str);
		
		row := table.getRowByName(ETRow_TidalTimeTypeShift);
		str := app.getErrorString(BerthDeparture); //$Berth_Arrival &amp; Tab &amp; app.getErrorString(Berth_Departure);
		table.setComboValues(row, str);	
		
		//20 Mar 2012	NDL	Par 28251
		row := table.getRowByName(ETRow_Timezone);
		str := app.timezoneEnumToString(0);
		table.setComboValues(row, str);
									
	endif;
	tmpSheet.cnEcResizeContents;	

	tmpSheet := form.shtTblInput3;
	tmpSheet.visible := true;
	table := form.tblInput3;	
	if table.myEntTableDef &lt;&gt; null then
		tmpSheet.caption := table.myEntTableDef.description;

		row := table.getRowByName(ETRow_BaseTimeArrive);
		str := app.getErrorString(Wharf) &amp; Tab &amp; app.getErrorString(Sea);
		table.setComboValues(row, str);
		row := table.getRowByName(ETRow_BaseTimeShift);
		str := app.getErrorString(BerthArrivingAt) &amp; Tab &amp; app.getErrorString(BerthLeavingFrom);
		table.setComboValues(row, str);
		row := table.getRowByName(ETRow_BaseTimeDepart);
		str := app.getErrorString(Sea) &amp; Tab &amp; app.getErrorString(Wharf);
		table.setComboValues(row, str);	
				
	endif;
	tmpSheet.cnEcResizeContents;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="91d2d15f-128a-468b-9c93-50b1c7e49c8a">
        <updating/>
        <source>setControlsForAddEdit()updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	tmpTerminals : CM_TerminalByCodeDict;
begin
	
	theForm := self.myForm.SOP_HMS_TableMaintForm;
		
	if theForm.mode = theForm.Mode_Add then
		theForm.mulSelect2.setSelected(null);
		create tmpTerminals transient;
		app.myRoot.getTerminalsUnassignedToHarbou(tmpTerminals);
		theForm.mulSelect1.setAvailable(tmpTerminals, true);			
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setAvailable(null, true);											
		theForm.tblInput2.clearValues;
		theForm.tblInput3.clearValues;
		theForm.cmbBerth.clear();
		theForm.cmbBerthDept.clear();
		theForm.cmbHarbourRegion.clear();
	else
		if theForm.mulSelect1.visible then						
			theForm.mulSelect1.setSelected(theForm.myProxyObject.HMS_Harbour.allTerminalsByCode);		
		endif;				
	endif;
//	if theForm.mode = theForm.Mode_Update and 
//	   theForm.mulSelect2.isMySheetVisible then
//		theForm.mulSelect2.setFocus;
//	endif;
	theForm.tblInput2.userInputEnabled := true;
	theForm.tblInput3.userInputEnabled := true;		
	inheritMethod();

epilog
	delete tmpTerminals;		
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="2e3f71ce-6794-452f-b59b-9b33620b0042">
        <updating/>
        <source>setCtrlsForView() updating;
//--------------------------------------------------
// Created:	08 March 2004 By: cnwgd1
//--------------------------------------------------
vars

	theForm : SOP_HMS_TableMaintForm;
	
begin
	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	self.getEmailGroups();
	theForm.cmbEmailGroup.listCollection(self.allEmailGroups, false, 0);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="b9597344-ba60-4a63-a997-88f2d6932a1d">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _harbour: HMS_Harbour input; _tbl: CM_EntryTable input): Boolean;
//--------------------------------------------------
// Created:	08 March 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------
// 27/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 21/05/2014	cnwdap1		PAR #34176 Work order report dates setting
vars
	int			: Integer;
	dec			: Decimal[3,1];							// PAR #33337
	woDates		: Boolean;								// PAR #34176
begin
	if _tbl.name = 'tblInput1' then
		return false;
	endif;
	
	if _attrName = ETRow_LinesmenOrderArrive then
		_harbour.defaultOrderTimesArrive[1] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_LinesmenOrderShift then
		_harbour.defaultOrderTimesShift[1] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_LinesmenOrderDept then
		_harbour.defaultOrderTimesDepart[1] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_PilotLaunchArrive then
		_harbour.defaultOrderTimesArrive[2] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_PilotLaunchDepart then
		_harbour.defaultOrderTimesDepart[2] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_TugsOrderArrive then
		_harbour.defaultOrderTimesArrive[3] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_TugsOrderShift then
		_harbour.defaultOrderTimesShift[2] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_TugsOrderDepart then
		_harbour.defaultOrderTimesDepart[3] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_PilotOnArrive then
		_harbour.defaultOrderTimesArrive[4] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_PilotOnDepart then
		_harbour.defaultOrderTimesDepart[4] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_PilotOffArrive then
		_harbour.defaultOrderTimesArrive[5] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_PilotOffDepart then
		_harbour.defaultOrderTimesDepart[5] := _strValue.Integer;
		return true;
	elseif _attrName = ETRow_IsDoClearanceCheck then
		_harbour.setPropertyValue(HMS_Harbour::isDoClearanceCheck.name, (_strValue = "1"));
		return true;
	elseif _attrName = ETRow_BaseTimeArrive then
		if _strValue = app.getErrorString(Sea) then
			int := AtSea;
		else
			int := AtWharf;
		endif;	
		_harbour.setPropertyValue('baseTimeArrive', int);
		return true;						
	elseif _attrName = ETRow_BaseTimeShift then
		if _strValue = app.getErrorString(BerthLeavingFrom) then
			int := AtBerthDepartingFrom;
		else
			int := AtBerthArrivingTo;
		endif;	
		_harbour.setPropertyValue('baseTimeShift',int);
		return true;
	elseif _attrName = ETRow_BaseTimeDepart then
		if _strValue = app.getErrorString(Sea) then
			int := AtSea;
		else
			int := AtWharf;
		endif;	
		_harbour.setPropertyValue('baseTimeDepart', int);
		return true;
	elseif _attrName = ETRow_TidalTimeTypeArrival then
		if _strValue = app.getErrorString(PilotOffVessel) then
			int := AtWharf;
		else
			int := AtSea;
		endif;	
		_harbour.setPropertyValue('tidalTimeTypeArrival', int);
		return true;
	elseif _attrName = ETRow_TidalTimeTypeShift then
		if _strValue = app.getErrorString(BerthArrival) then
			int := AtSea;
		else
			int := AtWharf;
		endif;	
		_harbour.setPropertyValue('tidalTimeTypeShift', int);
		return true;
	elseif _attrName = ETRow_TidalTimeTypeDeparture then
		if _strValue = app.getErrorString(PilotOffVessel) then
			int := AtSea;
		else
			int := AtWharf;
		endif;		
		_harbour.setPropertyValue('tidalTimeTypeDeparture', int);
		return true;
	elseif _attrName = ETRow_Timezone then	//20 Mar 2012	NDL	Par 28251
		int := app.timezoneStringToEnum( _strValue );
		_harbour.setTimezone(int);
		return true;	//29 Mar 2012	NDL	Par 28251
		
	elseif _attrName = ETRow_MaximumDraft then													// PAR #33337
		dec := _strValue.Decimal;																// PAR #33337
		_harbour.setPropertyValue(HMS_Harbour::maximumDraft.name, dec);							// PAR #33337
		return true;																			// PAR #33337
	elseif _attrName = ETRow_SuppressTidalWarnings then											// PAR #33337
		_harbour.setPropertyValue(HMS_Harbour::suppressTidalWarnings.name, (_strValue = "1"));	// PAR #33337
		return true;																			// PAR #33337
		
	elseif _attrName = ETRow_WoDateTime24Hrs then			// PAR #34176
		if _strValue = '1' then								// PAR #34176
			woDates := true;								// PAR #34176
		else												// PAR #34176
			woDates := false;								// PAR #34176
		endif;												// PAR #34176
		_harbour.setWoDateTimeSameAsView(woDates);			// PAR #34176
		return true;										// PAR #34176
	endif;

	return false;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="334d141d-0fed-4327-af9c-453f8c19adfa">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _harbour : HMS_Harbour): Boolean updating;
//--------------------------------------------------
// Created:	08 March 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 27/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 21/05/2014	cnwdap1		PAR #34176 Work Order Report Dates option
vars
	str : String;
begin
	inheritMethod(_tbl, _attrName, _row, _harbour);

	if _tbl.name = 'tblInput1' then
		return false;
	endif;

	if _attrName = ETRow_LinesmenOrderArrive then
		_tbl.setValue(_row, _harbour.defaultOrderTimesArrive[1]);	
		return true;
	elseif _attrName = ETRow_LinesmenOrderShift then
		_tbl.setValue(_row, _harbour.defaultOrderTimesShift[1]);
		return true;
	elseif _attrName = ETRow_LinesmenOrderDept then
		_tbl.setValue(_row, _harbour.defaultOrderTimesDepart[1]);
		return true;
	elseif _attrName = ETRow_PilotLaunchArrive then
		_tbl.setValue(_row, _harbour.defaultOrderTimesArrive[2]);
		return true;
	elseif _attrName = ETRow_PilotLaunchDepart then
		_tbl.setValue(_row, _harbour.defaultOrderTimesDepart[2]);
		return true;
	elseif _attrName = ETRow_TugsOrderArrive then
		_tbl.setValue(_row, _harbour.defaultOrderTimesArrive[3]);
		return true;
	elseif _attrName = ETRow_TugsOrderShift then
		_tbl.setValue(_row, _harbour.defaultOrderTimesShift[2]);
		return true;
	elseif _attrName = ETRow_TugsOrderDepart then
		_tbl.setValue(_row, _harbour.defaultOrderTimesDepart[3]);
		return true;
	elseif _attrName = ETRow_PilotOnArrive then
		_tbl.setValue(_row, _harbour.defaultOrderTimesArrive[4]);
		return true;
	elseif _attrName = ETRow_PilotOnDepart then
		_tbl.setValue(_row, _harbour.defaultOrderTimesDepart[4]);
		return true;
	elseif _attrName = ETRow_PilotOffArrive then
		_tbl.setValue(_row, _harbour.defaultOrderTimesArrive[5]);
		return true;
	elseif _attrName = ETRow_PilotOffDepart then
		_tbl.setValue(_row, _harbour.defaultOrderTimesDepart[5]);
		return true;
	elseif _attrName = ETRow_IsDoClearanceCheck then
		_tbl.setValue(_row, _harbour.isDoClearanceCheck.cnEcGetTableCheckBoxValue());
		return true;
	elseif _attrName = ETRow_BaseTimeArrive then
		if _harbour.baseTimeArrive = AtSea then
			str := app.getErrorString(Sea);
		else
			str := app.getErrorString(Wharf);
		endif;	
		_tbl.setValue(_row, str);
		return true;						
	elseif _attrName = ETRow_BaseTimeShift then
		if _harbour.baseTimeShift = AtBerthDepartingFrom then
			str := app.getErrorString(BerthLeavingFrom);
		else
			str := app.getErrorString(BerthArrivingAt);
		endif;	
		_tbl.setValue(_row, str);	
		return true;
	elseif _attrName = ETRow_BaseTimeDepart then
		if _harbour.baseTimeDepart = AtSea then
			str := app.getErrorString(Sea);
		else
			str := app.getErrorString(Wharf);
		endif;	
		_tbl.setValue(_row, str);
		return true;
	elseif _attrName = ETRow_TidalTimeTypeArrival then
		if _harbour.tidalTimeTypeArrival = AtWharf then
			str := app.getErrorString(PilotOffVessel);
		else
			str := app.getErrorString(PilotOnBoard);
		endif;	
		_tbl.setValue(_row, str);	
		return true;
	elseif _attrName = ETRow_TidalTimeTypeShift then
		if _harbour.tidalTimeTypeShift = AtSea then
			str := app.getErrorString(BerthArrival);
		else
			str := app.getErrorString(BerthDeparture);
		endif;	
		_tbl.setValue(_row, str);		
		return true;
	elseif _attrName = ETRow_TidalTimeTypeDeparture then
		if _harbour.tidalTimeTypeDeparture = AtSea then
			str := app.getErrorString(PilotOffVessel);
		else
			str := app.getErrorString(PilotOnBoard);
		endif;	
		_tbl.setValue(_row, str);		
		return true;		
	elseif _attrName = ETRow_EmailGroup then
		if _harbour.myEmailGroup &lt;&gt; null then
			_tbl.setValue(_row, _harbour.myEmailGroup.name);
		endif;
	elseif _attrName = ETRow_MyDefaultTerminal then
		if _harbour.myDefaultTerminal &lt;&gt; null then
			_tbl.setValue(_row, _harbour.myDefaultTerminal.name);
		endif;
	elseif _attrName = ETRow_Timezone then	//20 Mar 2012	NDL	Par 28251
		_tbl.setValue(_row, _harbour.getTimezoneDescr);
		return true;	//29 Mar 2012	NDL	Par 28251
		
	elseif _attrName = ETRow_MaximumDraft then						// PAR #33337
		_tbl.setValue(_row, _harbour.maximumDraft);					// PAR #33337
		return true;												// PAR #33337
	elseif _attrName = ETRow_SuppressTidalWarnings then				// PAR #33337
		_tbl.setValue(_row, _harbour.suppressTidalWarnings);		// PAR #33337
		return true;												// PAR #33337
		
	elseif _attrName = ETRow_WoDateTime24Hrs then					// PAR #34176
		_tbl.setValue(_row, _harbour.woDateTimeSameAsView);			// PAR #34176
		return true;												// PAR #34176
		
	endif;
	return false;

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="994d2c3e-1d61-450b-92ef-ca3664b8f4e0">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm	: SOP_HMS_TableMaintForm;
begin
	inheritMethod();
	
	self.myForm.setTblDataEntRows(ETDef_HMSHarbour);		//cnwdb2 - 17 April 2014 - PAR 33977


	if self.allEntTableDefs.isEmpty then
		app.processGlobalConstantGroup(PortSchemaName, ConfigTypeConstants, SOPTM_HMS_Harbour::setAllEntTableDefs.name, self);
	endif;	
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.myAssistant.comboBoxHMSBerth(theForm.cmbBerth, theForm.myHarbour, null, true);		
	theForm.myAssistant.comboBoxHMSBerth(theForm.cmbBerthDept, theForm.myHarbour, null, true);	
	theForm.myAssistant.comboBoxHMSRegion(theForm.cmbHarbourRegion, theForm.myHarbour, null);
	theForm.myAssistant.comboBoxHMSTimeZone(theForm.cmbTimezone, null);	//20 Mar 2012	NDL	Par 28251
	

	theForm.initShtTblInput2();
	theForm.initTblInput(theForm.tblInput2, ETDef_HMSHarbourDefaults);	
	theForm.initTblInput(theForm.tblInput3, ETDef_ServiceOrderTimes);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="749f3d11-3887-4087-88f0-8dff98777c6e">
        <updating/>
        <source>showThumbnail(pObj: HMS_Harbour) updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	assist	: CMUI_Assistant;
	tmpTerminals : CM_TerminalByCodeDict;
begin

    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput2.clearValues;
	theForm.tblInput3.clearValues;		
	theForm.tblInput1.setTableFromObject(pObj, 'setTableFromObjectSpecial');	
	theForm.tblInput2.setTableFromObject(pObj, 'setTableFromObjectSpecial');	
	theForm.tblInput3.setTableFromObject(pObj, 'setTableFromObjectSpecial');			

	create tmpTerminals transient;
	pObj.allTerminalsByCode.copy(tmpTerminals);
	app.myRoot.getTerminalsUnassignedToHarbou(tmpTerminals);
	theForm.mulSelect1.setAvailable(tmpTerminals, true);	
	theForm.mulSelect1.setSelected(pObj.allTerminalsByCode);	
	
	theForm.cmbDefTerminal.listCollection(pObj.allTerminalsByCode, false, 0);	
	
	theForm.mulSelect2.setAvailable(pObj.allWharves, true);		
	theForm.mulSelect2.setSelected(pObj.allWharfDisplayOrderArray);	

	assist := theForm.myAssistant;

	assist.comboBoxHMSBerth(theForm.cmbBerth, pObj, pObj.defaultArrvBerth, true);
	theForm.cmbBerth.lostFocus(theForm.cmbBerth);	

	assist.comboBoxHMSBerth(theForm.cmbBerthDept, pObj, pObj.defaultDepartBerth, true);
	theForm.cmbBerthDept.lostFocus(theForm.cmbBerthDept);
	
	//20 Mar 2012	NDL	Par 28251
	assist.comboBoxHMSTimeZone(theForm.cmbTimezone, pObj);
	theForm.cmbTimezone.lostFocus(theForm.cmbTimezone);
	
	//not used anywhere
	//assist.comboBoxHMSRegion(theForm.cmbHarbourRegion, pObj, pObj.myDefaultHarbourRegion);
	//theForm.cmbHarbourRegion.lostFocus(theForm.cmbHarbourRegion);
	//th2 set on checkpoints only
	//assist.comboBoxHMSTidalModelType(theForm.cmbTidalModel, pObj.tidalModelType);
	
	theForm.cmbEmailGroup.listObject := pObj.myEmailGroup;
	//th2 changed after getting Invalid property value  error here
	theForm.cmbDefTerminal.listIndex := theForm.cmbDefTerminal.findObject(pObj.myDefaultTerminal);
	theForm.cmbDefTerminal.lostFocus(theForm.cmbDefTerminal);	
	

	//Make visible here as not visible when creating a habour only viewing and editing
	theForm.shtTblInput3.visible := true;
	theForm.shtTblInput2.visible := true;	

epilog
	delete tmpTerminals;
end;</source>
        <Parameter name="pObj" type="HMS_Harbour"/>
    </JadeMethod>
</Class>
