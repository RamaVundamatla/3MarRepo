begin

	if set then
		self.allowMultiSelectEdit := _value;
		if self.allowMultiSelectEdit then
			self.multiSelect := CM_BaseTable.MultiSelect_Simple;
		else
			if (not self.allowMultiSelectDelete) then
				self.multiSelect := CM_BaseTable.MultiSelect_None;
			endif;
		endif;
	else
		_value := self.allowMultiSelectEdit;
	endif;

end;</source>
