    <JadeMethod name="isCompleteBySplit" id="21aa23a2-9655-4646-9831-01fbf639a526">
        <source>isCompleteBySplit() : Boolean;
/*
Purpose:			
		 // If the  total requested is zero it will be because part of a TI was requested, and it has been split 
		 // and the total requested has been delivered, leaving some of the ti still onsite

Date		Who		Reason
04 November 2021	navab1	TFS 52328
*/

vars
	aTI : CM_TrackedItem;
begin
	aTI := self.getTI();
	
	if aTI = null then
		return false;
	endif;
	
	//23Jun2022 navsp1 TFS#53920
	if aTI.allReserveDetails.size &gt; 1  then	
		return false;
	endif;
	
	if self.totalRequested = 0 // DO NOT CALL GetTotalRequested() because it calls this method
	and self.allTrackedItemsReleased.isEmpty() // This is empty because the new split TI is on its own reserveTI
	and aTI.myCargoType.allowDuplicates
	and aTI.allSplitChildrenTis.isNotEmpty() then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDelivered" id="aba3dbaa-bf39-4075-8623-03f0e50a3e7b">
        <source>isDelivered(): Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------------
// 24/09/2009	consw1		SFW1035 - Changed CM_ReserveTI methods to use getTI for consistency.
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
begin
	tmpTI := self.getTI();
	if tmpTI &lt;&gt; null then
		if tmpTI.site = TI_SITE_OFFSITE then
			return true;
		endif;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFullyLoaded" id="d682751e-3f9f-4d22-9b2e-3a53da5c70b1">
        <source>isFullyLoaded(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2015	cnwndl1	Initial creation	Par 37288
*/

vars
	ti 		: CM_TrackedItem;
	lc 		: CM_LocationsController;
	bulkRel : CM_BulkRelease;
begin
	
	bulkRel := self.myReserveHeader;
	
	if bulkRel  = null then
		return false;
	endif;
	
	ti := self.getTI;
	
	if ti = null then
		return true;
	endif;
	
	if not ti.isOnSite then
		return true;
	endif;
	
	if ti.isChild then
		return true;
	endif;
	
	lc := ti.myPrimaryActualLocation;
	
	if lc &lt;&gt; null then
		if bulkRel.isRoadType then
			if lc.isVehicle then
				return true;
			endif;
			if lc.isTILCController then
				return true;
			endif;
		elseif bulkRel.isRailType then
			//epr TFS 45291 23/9/19 
			if lc.isWagon then
				return true;
			endif;
		elseif bulkRel.isShipType then
			if lc.isVoyageController then
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFullySPL" id="96e30d7a-7ab0-49a5-9f5c-cd5b1c126400">
        <source>isFullySPL(): Boolean;
/*

Purpose:			 Is Fully Staged, and  Packed or Loaded

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2017	cnwndl1	Initial creation	TFS 4016

*/

vars

	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	isPack : Boolean;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;

begin

	create tiSet transient;
	if self.getTotalStaged( tiSet, firstStagingLC, null ) &gt;= 1 then
		return true;
	endif;
	
	ti := self.getTI;
	if ti = null then
		return false;
	endif;
	if self.myReserveHeader &lt;&gt; null then
		isPack :=  self.myReserveHeader.isPackingType();
		if isPack then
			if ti.isChild then
			return true;
			endif;
		endif;
	endif;
	
	lc := ti.myPrimaryActualLocation;
	if lc &lt;&gt; null then
		if lc.isKindOf( CM_YardController ) then
			// its still in the yard, can't be loaded yet
			return false;
		endif;
		if lc &lt;&gt; null then
			if lc.isVehicle then
				return true;
			endif;
			if lc.isTILCController then
				return true;
			endif;
			if lc.isWagon then	//09 Jun 2020	TFS 49537
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

	delete tiSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFullyStaged" id="c741eff7-80c3-4ee3-81ab-964abcfd72bd">
        <source>isFullyStaged(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;

begin

	create tiSet transient;
	return self.getTotalStaged( tiSet, firstStagingLC, null ) &gt;= 1;

epilog

	delete tiSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populatePxyfromPrenote" id="ef12292e-6ed5-4cdb-977f-ae9631822819">
        <updating/>
        <source>populatePxyfromPrenote(_ti	:	CM_TrackedItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/

vars

begin
	self.remarks			:=	_ti.remarks;
	self.myBookingRefItem	:=	_ti.myBookingRefItem;
	self.weightRequested	:=	_ti.weight;
	self.myBOLDtl			:=  _ti.myBOLDtl;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="59c69392-962a-462f-91f6-d4378a6195aa">
        <source>pxyCreateUpdateProxy(): SelfType;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 21 January 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description
14/10/2025		navdap1		MTN-36227	Yara New Discoveries | Cater for multiple lines in an OrderCreate / OrderChange / OrderResponse / ShipNotice
****************************************************/
vars
	proxy 			 : CM_ReserveTI;
	completedOK		 : Boolean;
begin
	proxy := inheritMethod();
	
	proxy.myBOLIn					:= self.myBOLIn;	
	proxy.anyAmtAnyIdAllowedAmount	:= self.anyAmtAnyIdAllowedAmount;
	proxy.myBOLDtl					:= self.myBOLDtl;
	
	proxy.setYaraExtraData(self.getYaraExtraData());	// MTN-36227
	app.writeLog(method.qualifiedName &amp; Tab &amp; "proxy extra data is " &amp; proxy.getYaraExtraData(), LogDEBUG);
	
	completedOK 	:= true;			
	
	return proxy;
epilog
	if not completedOK then			
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
