        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setBOLValues" id="eb523247-fdf4-489d-8e24-be418ef5eed0">
        <updating/>
        <source>setBOLValues(_cmif : CMIF_BOLIn input) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 01 October 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars

begin
	_cmif.voyageCode := self.voyageCode;
	_cmif.bolNumber := self.billOfLading;
	_cmif.numItems := self.quantityOnBill;
	_cmif.bolType := BOLType_GeneralBillOfLading;
	
epilog
end;</source>
        <Parameter name="_cmif" type="CMIF_BOLIn" usage="input"/>
    </JadeMethod>
