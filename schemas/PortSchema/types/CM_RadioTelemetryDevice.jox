    <JadeMethod name="removeFromAlerts" id="625a2cce-9710-4806-a646-6040ca5cda0c">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::removeFromAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>removeFromAlerts(alert: CM_SystemAlert) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	terminal : CM_Terminal;
begin
	if not self.allAlerts.includes(alert) then
		return;
	endif;
	allAlerts.remove(alert);

	
	terminal := self.getTerminalForAlert;
	if terminal &lt;&gt; null and alert.mySystemAlertType &lt;&gt; null and not alert.reviewed then
		terminal.causeEvent(alert.mySystemAlertType.type,false,alert);	 // #25662 24/09/2010 set to false
	endif;
end;


</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
