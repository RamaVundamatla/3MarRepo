    <JadeMethod name="create" id="a68addca-2916-4e9d-aef5-bbaff9fcd486">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.permissionView		:= PmAdmTrainEnquiryView;
	self.permissionMaint	:= PmAdmTrainEnquiryMaint;	// TFS 2198
	self.helpFileName 		:= HelpFile_Yard;
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="displayTable" id="6148bae1-8a0b-4339-b029-4156f7c10015">
        <updating/>
        <source>displayTable() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Nov 2020 	cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// ---------------------------------------------------------------------------

vars
	theDataLine 	: String;
	loadStateSet 	: Boolean;
	tbl				: CM_DataTable;
	dict 			: CM_TrainByCodeDateDict;
	train 			: CM_Train;
	idx , 
	colourCol		: Integer;
	stevedore       : CM_Stevedore;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	tbl 	 	      := self.tblData;
	tbl.rows  		  := tbl.fixedRows;
	colourCol 		  := tbl.getColumnByRowName(ETRow_Colour);

	create dict transient;
	self.myTerminal.allTrainsArrival.copyNoDuplicates(dict, false);
	
	//navsp1 24MAY2022 TFS#53619 - uncommented
	if self.chkDeparted.value then
		self.myTerminal.allTrainsDeparted.copyNoDuplicates(dict, false);
	endif;
	
	stevedore := self.cmbStevedore.listObject.CM_Stevedore;       //02.10.2020 cnwma1 TFS #50112
	if stevedore &lt;&gt; null then 									  //02.10.2020 cnwma1 TFS #50112
		stevedore.allTrainsReceive.copyNoDuplicates(dict, false);
		stevedore.allTrainsRelease.copyNoDuplicates(dict, false);
	endif;
	
	app.cmsBeginLoad(loadStateSet);
	foreach train in dict  discreteLock do
		if not self.includeObject(train) then
			continue;
		endif;
		theDataLine := train.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx 		:= tbl.addItem(theDataLine);
		tbl.accessRow(idx).itemObject := train;
		
		
		if colourCol &gt; 0 then
			tbl.accessCell(idx, colourCol).backColor := train.colour;
			tbl.accessedCell.text := null;
		endif;
		self.doNotableAdd(train);
	endforeach;
			
epilog
	delete dict;
	app.cmsEndLoad(loadStateSet);
	if (not self.timerRefreshActive) then //+ cnwmd1, CCMS 1067, Par 19710
		self.beginTimerForRefresh();
	endif;	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddReleaseRequest" id="ecf69c61-b790-4cd9-9414-613927d062a8">
        <source>doAddReleaseRequest();
// ---------------------------------------------------------------------------
// Created:     27 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
// ---------------------------------------------------------------------------

vars
	bulkRelease : CM_BulkRelease;
begin

	create bulkRelease transient;//form cleans up
	self.myAssistant.releaseRequestAdd(bulkRelease, BR_TYPE_RAIL, self.myMasterMenuAction,null);				//14.6.2023 navhl20 #58634

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCrgFcstDef" id="30522eef-1b84-405d-8037-4ecab51c45c5">
        <source>doBtnCrgFcstDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2022	navtnr20	Initial creation 	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	form : CMUI_CargoForecastForm;
begin
	if self.myCurrentTrain = null then
		return;
	endif;
	
	form := app.loadForm(CMUI_CargoForecastForm, YRD_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoForecastForm;		//13.05.2022 navsrk	53142
	if form = null then
		return;		//13.05.2022 navsrk	53142
	endif;
	if form &lt;&gt; null then
		form.setMyObject(self.myCurrentTrain);
		form.setParentForm(self);
		form.show();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboTrainStatus" id="6f71107c-bdb1-449c-982a-9a5e9be3f6aa">
        <source>doBuildComboTrainStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	navsp1	Initial creation TFS#53619

*/

vars
	status : Integer;
begin
	self.cmbStatus.clear;
	self.cmbStatus.sorted := false;
	self.cmbStatus.addItem("");
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Created),TrainStatus_Created );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Inbound),TrainStatus_Inbound );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Arrived),TrainStatus_Arrived );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Working),TrainStatus_Working );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Complete),TrainStatus_Complete );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Departed),TrainStatus_Departed );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Closed),TrainStatus_Closed );
	self.cmbStatus.addItemWithData( app.trainStatusEnumToString(TrainStatus_Cancelled),TrainStatus_Cancelled );
end;</source>
    </JadeMethod>
    <JadeMethod name="doCopyItem" id="31472189-b42f-4c1c-ada5-d7c3668cdc17">
        <updating/>
        <source>doCopyItem() updating;
// ---------------------------------------------------------------------------
// Created:     22 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	initObject		: CM_Train;
	
begin
	
	initObject := self.tblData.allSelectedObjects.first.CM_Train;
	if initObject = null then
		app.msgBox(app.getErrorString(Please_select_train_copy_first),app.getErrorString(No_Train_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.myAssistant.showTrainMaintenance(initObject, self.myMasterMenuAction, YRD_TrainForm.Mode_Copy, self);
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="c5c5cb6a-7c21-4cb9-9f34-785de3b7ea5a">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	train			: CM_Train;
	result			: Integer;
begin
	
	train  := self.tblData.allSelectedObjects.first.CM_Train;
	if train = null then
	
		app.msgBox(app.getErrorString(Must_select_train_delete_first) ,app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Sure_that_want_delete_train, train.code ),app.getErrorString(Confirm_Delete), MsgBox_OK_Cancel + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteTrain(train, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Train) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="a133049a-b0d5-4702-9a71-860633c61734">
        <updating/>
        <source>doEditItem() updating;
// ---------------------------------------------------------------------------
// Created:     22 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	initObject		: CM_Train;
	
begin
	
	initObject := self.tblData.allSelectedObjects.first.CM_Train;
	if initObject = null then
		app.msgBox(app.getErrorString(Please_select_train_edit_first),app.getErrorString(No_Train_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.myAssistant.showTrainMaintenance(initObject, self.myMasterMenuAction, YRD_TrainForm.Mode_Update, self);
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableForTrain" id="470ebdc1-6fda-440e-93e6-4bafc505b5e0">
        <source>doEnableForTrain(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
// ---------------------------------------------------------------------------

vars

begin
	self.btnNew.enabled := _enable;
	self.btnEditItem.enabled := _enable;
	self.btnDelete.enabled := _enable;
	self.btnCopyTrain.enabled := _enable;
	self.btnAddRequest.enabled := _enable;
	self.btnCargoForecast.enabled := true;	//25-Apr-2022	TFS 53142
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuAuditsForObjectClick" id="01f8a9f2-b166-463a-9c1a-7a3b70dd66a9">
        <source>doMnuAuditsForObjectClick(menuItem: MenuItem input);

/*

Purpose:		// TFS BUG 58789 26JUNE2023 NAVAB1	

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2023	navab1	Initial creation

*/

vars
	obj : Object;
	hasAudits : Boolean;
	train : CM_Train;

begin

	obj := self.tblData.accessedRow.itemObject;
	if obj &lt;&gt; null and CM_Train.hasInstance(obj) then
		train := obj.CM_Train;
		hasAudits := train.hasAudits;
	endif;
	
	if not hasAudits then
		return;
	endif;
		
	app.viewAuditForm(train, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="190f4b58-e26e-45af-a70d-6b32cfa233a9">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	cnwmd1	Initial creation

*/

vars
	anObject 	: Object;
	train		: CM_Train;
begin


	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	//if CM_Train.hasInstance(anObject) then
	if CM_Train.hasInstance(anObject) and not anObject.CM_Train.isNullTrain then	//06 Oct 2013	NDL	Par 32604
		//train := anObject.CM_Train;
		self.mnuContextTrainRemarks.userObject := anObject;
		self.doMnuContextModifyCaptions();
		self.doMnuContextVisibility(true);
		return true;
	else
		self.doMnuContextVisibility(false);
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
