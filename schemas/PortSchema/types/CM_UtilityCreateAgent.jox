    <JadeMethod name="utlCreateUpdateProducts" id="c59c9c27-2070-45aa-a1b2-05ca1893150c">
        <source>utlCreateUpdateProducts(_proxyProducts :CM_ObjectSet; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     11 April 2008 anwaer1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave 		: Boolean;
	product,
	pxyRealObj			: CM_Product;
	operator		: CM_Operator;
	newCode,
	typeCode		: CM_ProductAttributeCode;
	proxyProduct,
	newProduct  	: Object;
	todo, done		: Integer;
	cargoType 		: CM_CargoType;
	realProduct		: CM_Product;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();
	
	todo := _proxyProducts.size;
	
	foreach proxyProduct in _proxyProducts do 
		done := done + 1;
		if proxyProduct.isKindOf(CM_Product) then
			proxyProduct.CM_Product.pxyGetRealObjectAndEdition(realProduct, expectedEdition);
			
			if (_passport.myCMIFMonitor &lt;&gt; null) then
				_passport.myCMIFMonitor.updateProgress(app.getErrorString(Processing_cargo_subtype), todo, done);
			endif;

			if realProduct &lt;&gt; null then
				app.myUtilityUA.utlUpdateProduct(proxyProduct.CM_Product, _passport);
			else
				app.myUtilityCA.utlCreateProduct(proxyProduct.CM_Product, product, _passport);
			endif;
			
			if not self.checkValidationWithPassport(_passport) then
				return;
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a product (' &amp; proxyProduct.String &amp; ')');
		endif;
	endforeach;
	return;
end;</source>
        <Parameter name="_proxyProducts" type="CM_ObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateUser" id="149c4a89-dc54-4ba1-b0dd-5b9ce8c50572">
        <source>utlCreateUser(pProxyUser : CM_User; _password : String; pNewUser : CM_User output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05 Nov 2025	navlw1	JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users
// ---------------------------------------------------------------------------
vars
	userTerminal : CM_UserTerminal;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valUser(pProxyUser, _passport);

	if _password = null and not pProxyUser.status = PendingUser then // navlw1 05/11/2025 JIRA-MTN-36369
	//	app.raiseCMException1(REQUIRED_FIELD, 'password', null, null);
		app.raiseCMException(Input_required_field_password, null, null); // cnwdb2	PAR 35364
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create pNewUser as pProxyUser.class persistent;
	pNewUser.setForCreate(pProxyUser);
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewUser);
	endif;	
	if _passport.noErrors then
		// navlw1 05/11/2025 JIRA-MTN-36369
		// added an if statement as do not want to update the password for pending users
		if not pProxyUser.status = PendingUser then
			app.myUtilityUA.utlUpdatePassword(pNewUser, pNewUser.edition, _password, _passport);
		endif;
	endif;

end;</source>
        <Parameter name="pProxyUser" type="CM_User"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="pNewUser" type="CM_User" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateUserTISnapShot" id="c57613f0-58ab-4608-bda3-e757bd4934b5">
        <source>utlCreateUserTISnapShot(_tiSnap: CM_TISnapShot; _changeReason: CM_MessageUser;_passport: CM_Passport input): CM_UserTISnapShot;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	userSnap			: CM_UserTISnapShot;
	realChangeReason	: CM_MessageUser;
begin


	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	//validation??
	
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	app.setContinueCMExceptions(false);

	create userSnap persistent;
	userSnap.setFromTISnapShot(_tiSnap);

	if _passport.noErrors
	and _changeReason &lt;&gt; null then
		create realChangeReason persistent;
		realChangeReason.setForCreateFromProxy(_changeReason);
		userSnap.addChangeNote(realChangeReason);
	endif;

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(userSnap);
	endif;

epilog
	return userSnap;
end;</source>
        <Parameter name="_tiSnap" type="CM_TISnapShot"/>
        <Parameter name="_changeReason" type="CM_MessageUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_UserTISnapShot"/>
    </JadeMethod>
