    <JadeMethod name="keyDown" id="57a92e18-0875-4398-8d43-d316f35d3d3a">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode:Integer io; shift:Integer) updating;

begin
	//write "keyCode="&amp;keyCode.String&amp;" shift="&amp;shift.String;
	if keyCode = 116 or keyCode = 27 then  // F5
		showCreatorCreators;
		loadSessions;

	elseif keyCode=65 and shift=2 then  // Ctrl+A
		txtResults.setFocus;
		txtResults.selStart:=0;
		txtResults.selLength:=-1;
		keyCode:=0;

	elseif keyCode=82 and shift=3 then  // Shift+Ctrl+R
		app.startApplication("TestResultsSchema", "TestResults");
		keyCode:=0;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="a763c5fa-5283-48ff-ac5d-ad8ce3e1e5c5">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	on Exception do app.jtdGlobalExceptionHandler(exception) global;
	beginNotification(global, Bmk_Result, Response_Continuous, 0);
	beginClassNotification(BmkControlSession, false, Object_Update_Event, Response_Continuous, 0);
	computerName:=app.computerName.toLower;
	setCaption;
	if app.getEnvid &lt;&gt; "jblpcre" then
		txtResults.backColor:=11053271;
	endif;
	loadSessions;
	loadActions;
	if process.getUserCode = 'cnwjhp1' then
		top:=top+100;
		//left:=left+100;
	endif;
	cmbSession.setFocus;
	resize;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadActions" id="c3ebd29d-0f56-4a2a-97dc-34ca9bc35a17">
        <updating/>
        <source>loadActions() updating;

begin
	cmbAction.addItem(Fix_Envid);
	cmbAction.addItem(Show_CreatorCreators);
	cmbAction.addItem(Start_Creators);
	cmbAction.addItem(Show_Jade_Version);
	cmbAction.addItem(Start_Rap);
	//if process.getUserCode = 'cnwjhp1' then cmbAction.addItem(Start_SingleUser_AppServer); endif;
	cmbAction.addItem(Sync_Master_Thinbin);
	cmbAction.addItem(Sync_Client_Thinbins);
	cmbAction.addItem(Start_JadeDev);
	cmbAction.addItem(Start_AppServers);
	cmbAction.addItem(Start_ODT);
	cmbAction.addItem(Start_ControllerApp);
	cmbAction.addItem(Start_Creators);
	//cmbAction.addItem(Start_Background_Monitor);
	cmbAction.addItem(Start_PerfMon_Logs);
	cmbAction.addItem(Start_Driver_Apps);
	cmbAction.addItem(Stop_PerfMon_Logs);
	cmbAction.addItem(Save_Log_Files);
	//cmbAction.addItem(Post_Process_Log_Files);
	cmbAction.addItem(Stop_Creators);
	cmbAction.addItem(Start_UserApp);
	cmbAction.addItem(Start_JadeMonV2);
	cmbAction.addItem(Start_JadeMon);
	cmbAction.addItem(Start_DriverApp);
	cmbAction.addItem(Start_SingleUser);
	cmbAction.addItem(Start_SingleUser_JdbUtil);
	cmbAction.addItem(Start_SingleUser_AppServer);
	cmbAction.addItem(Start_Fat_Client);
	cmbAction.addItem(Start_KillerFat);
	cmbAction.addItem(Start_KillerAll);
	cmbAction.addItem(Stop_All_Child_Processes);
	cmbAction.addItem(Stop_All_Mine);
	cmbAction.addItem(Stop_CreatorCreators);
	cmbAction.listIndex:=1;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSessions" id="3926f199-ea0f-4446-9543-e1213b7e5abd">
        <updating/>
        <source>loadSessions() updating;

vars
	selIndex:Integer;
	bc:BmkControlSession;
begin
	// ensure 200 sessions are available
	foreach session in 1 to 200 do
		if global.allBmkControls.size &lt; session then
			beginTransaction;
			create global.allBmkControls[session];
			global.allBmkControls[session].session:=session;
			commitTransaction;
		endif;
	endforeach;

	cmbSession.clear;	
	session:=0;
	selIndex:=1;
	foreach bc in global.allBmkControls do
		cmbSession.addItem(bc.session.padLeadingWith("0",2)&amp;"  "&amp;bc.owner&amp;"  "&amp;bc.envid&amp;"  "&amp;bc.rapHost.asAbbrevHost);
		cmbSession.itemObject[cmbSession.newIndex]:=bc;
//		if session = 0 and bc.owner = process.getUserCode then
		if bc = myBmkControl then
			selIndex:=cmbSession.newIndex;
			session:=selIndex;
		endif;
	endforeach;
	
	cmbSession.listIndex:=selIndex;
	cmbSession_click(null);
end;</source>
    </JadeMethod>
