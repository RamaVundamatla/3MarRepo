//----------------------------------------------------------------
vars

begin
	


end;</source>
    </JadeMethod>
    <JadeMethod name="utilityName" id="83d67b84-dd69-4b79-9662-2e2e33ee451b">
        <methodInvocation>mapping</methodInvocation>
        <source>utilityName(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	27 October 2004	by Jason Chapman  (cnwjc2)
//  26 Sep 2017 cnwma1 TFS #6988 DQM : Upload EDI Error
//----------------------------------------------------------------
vars

begin

	//_value := "_xl8conv.exe"; 			26.9.2017 cnwma1 TFS #6988
	_value := "JMTExcelConverter.exe";    //26.9.2017 cnwma1 TFS #6988
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
