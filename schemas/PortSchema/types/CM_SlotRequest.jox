// ---------------------------------------------------------------------------
// Created:     30 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myDischargePort := _port;
	if _port &lt;&gt; null then
		self.dischargePort := _port.code;
	else
		self.dischargePort := null;
