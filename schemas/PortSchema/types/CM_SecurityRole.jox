Parameters:			

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation

*/

vars
	
begin

	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllChildMaintRoles" id="b1d5a64b-b7c2-49ff-8d8f-7da62458441d">
        <source>getAllChildMaintRoles( _set : CM_SecurityRoleSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

	childRole : CM_SecurityRole;
	invalidObj : Boolean;
	edition : Integer;

begin

	on Exception do app.handleDeletedObject( exception, childRole, invalidObj );
	foreach childRole in self.allChildMaintenanceRoles do
		invalidObj := false;
		edition := childRole.edition;
		if not invalidObj then
			if childRole = self then
				continue;
			endif;
			_set.add( childRole );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_set" type="CM_SecurityRoleSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllUsers" id="94383df5-77b3-46b5-be86-61443471e2f1">
        <source>getAllUsers(_userSet : CM_UserSet input);
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	theUser : CM_User;
	userTerm : CM_UserTerminal;
begin
	if _userSet = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null set passed to method');
		return;
	endif;
	
	foreach userTerm in self.allUserTerminals do
		theUser := userTerm.myUser;
		if (not _userSet.includes(theUser)) then
			_userSet.add(theUser);
		endif;
	endforeach;
end;</source>
        <Parameter name="_userSet" type="CM_UserSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="0f597656-4c15-436f-bf04-74fc1d4d8889">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
03 Apr 2009	cnwkpd1	PAR #19375 - Prevent 1310 exceptions in auditing when long
					To Do Task descriptions are used.  Maximum property name
					for auditing is 60 characters, and maximum for To Do task
					descriptions is 40, so preamble needs to be less than
					20 characters

*/

vars
	txt,
	s				: String;
	sa				: StringArray;
	i,
	permSize		: Integer;
	toDoDesc		: CM_ToDoTaskDesc;
	qryReport		: CM_QryReport;
	stopTable		: CM_StopsTable;
	trans 			: CM_TransactionType;
	eventType 		: CM_EventType;

begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	if self.mySecurityRoleVisibility &lt;&gt; null then
		txt := txt &amp; self.mySecurityRoleVisibility.getAuditText;
	endif;

	permSize := self.permissions.size;
		
	create sa transient;
	app.getPermissionNames(sa);

	i := 0;	
	foreach s in sa do
		i := i + 1;
		if s &lt;&gt; null then
			if i &lt;= permSize and self.permissions[i] then
				txt := txt &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
			else
				txt := txt &amp; s &amp; AuditStringSeparator &amp; "5" &amp; AuditStringSeparator &amp; "false" &amp; AuditStringSeparator;
			endif;
		endif;
	endforeach;

	foreach toDoDesc in self.allToDoTasksAddRemove discreteLock do
		s := toDoDesc.description;
		if s &lt;&gt; null then
			txt := txt &amp; 'Todo Task Add/Rem:  ' &amp; 			// PAR #19375
				   s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;

	foreach toDoDesc in self.allToDoTasksComplete discreteLock do
		s := toDoDesc.description;
		if s &lt;&gt; null then
			txt := txt &amp; 'Todo Task Comp:  ' &amp; 				// PAR #19375
				   s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;

	foreach qryReport in self.allQryReports discreteLock do
		s := qryReport.reportName;
		if s &lt;&gt; null then
			txt := txt &amp; 'Report:  ' &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	foreach stopTable in self.allStopsMaint discreteLock do
		s := stopTable.heading;
		if s &lt;&gt; null then
			txt := txt &amp; 'Stops Table Maint:  ' &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;
	
// cnwdad1 03/06/2010 - CCMS 1129.
	foreach stopTable in self.allStopsCancel discreteLock do
		s := stopTable.heading;
		if s &lt;&gt; null then
			txt := txt &amp; 'Stops Table Delete:  ' &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	foreach stopTable in self.allStopsView discreteLock do
		s := stopTable.heading;
		if s &lt;&gt; null then
			txt := txt &amp; 'Stops Table View:  ' &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	foreach trans in self.allTransactionTypesForEvents discreteLock do
		s := trans.description;
		if s &lt;&gt; null then
			txt := txt &amp; 'Transaction Access:  ' &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	foreach eventType in self.allEventTypes discreteLock do
		s := eventType.description;
		if s &lt;&gt; null then
			txt := txt &amp; 'Event Types:  ' &amp; s &amp; AuditStringSeparator &amp; "4" &amp; AuditStringSeparator &amp; "true" &amp; AuditStringSeparator;
		endif;
	endforeach;
	
	return txt;	
epilog
	delete sa;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChildHeirAlphaOrder" id="9a332dd0-4880-454d-bc29-52675ca41c83">
        <source>getChildHeirAlphaOrder( _objArray : ObjectArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

	orderedRoles : CM_SecurityRoleDict;
	role : CM_SecurityRole;

begin

	create orderedRoles transient;
	
	self.allChildRoles.copy( orderedRoles );
	foreach role in orderedRoles where role.myParentRole = self do
		_objArray.add( role );
		role.getChildHeirAlphaOrder( _objArray );
	endforeach;

epilog

	delete orderedRoles;
	
end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
