    <JadeMethod name="getTotalActionedRBT" id="5461b9ae-7bfe-46c3-9d2c-82522dbaa1c0">
        <source>getTotalActionedRBT() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars
	aRBT		: CM_WorkOrderRequestByType;
	result 		: Integer;
begin

	result := 0;
	
	foreach aRBT in self.allWORequestByType do
		result := result + aRBT.totalActioned;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalCargoCount" id="89d8a13d-513f-4773-ab44-80cdbbb9aa1f">
        <source>getTotalCargoCount():  Integer;

/*

Purpose:			
Calculate how many cargo items we have selected in total

Parameters:			

Return Value:		


Date		Who		Reason
19/08/2009	cnwrd1	Initial creation
11/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
*/

vars
	result : Integer;
	tiArray : HugeStringArray;
	aBooking : CM_BookingRef;
	aBulkRel : CM_BulkRelease;
	aWorkOrder 	: CM_WorkOrder;
	invalidWO : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, aWorkOrder, invalidWO); 

	result := 0;
	
	//need to step through all my source items and add up !
	
	//1st titextlist:
	create tiArray transient;
	self.getTIsAsStringArray(tiArray);
	
	result := result + tiArray.size;
	
	// TFS 38501 If we're a PEL booking or release source, 			// TFS 38501
	// the numebr of TIs is the only count							// TFS 38501
	if self.myParent.CM_WorkOrder.hasBookingOrReleaseTask then		// TFS 38501
		return result;												// TFS 38501
	endif;															// TFS 38501

	// now each booking:
	foreach aBooking in self.allBookings do	
		result := result + aBooking.getTotalQuantity();
	endforeach;
	
	// now bulk releases
	foreach aBulkRel in self.allBulkReleases do
		result := result + aBulkRel.getTotalRequested();
	endforeach;
	
	foreach aWorkOrder in self.allSourceWorkOrders do
		result := result + aWorkOrder.CM_WorkOrderTI.getTotalRequired();
	endforeach;
	
	// from request by type
	result := result + self.getTotalFromRBT();

	return result;
	
epilog
	delete tiArray;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalFromRBT" id="203ef926-cae2-4773-b88c-8bdd7fe1d61f">
