    <JadeMethod name="areWLEsAllStatus" id="817ae4bb-2581-4409-8ec6-65554277fbff">
        <source>areWLEsAllStatus(wleStat: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue

*/

vars

begin
	if not app.myPassport.isVASEnabled then
		inheritMethod(wleStat);
	endif;
	
	if self.getTotalQuantity() &lt;&gt; self.getRemainingQuantity().Integer then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="wleStat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
