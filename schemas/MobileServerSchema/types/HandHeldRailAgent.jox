    <JadeMethod name="getValidContainerInwards" id="b07dbd66-a876-4783-9efc-1c1166507023">
        <source>getValidContainerInwards(_wagonPos : DTO_WagonPosition);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	realTI : CM_TrackedItem;
	containerInfo : DTO_ContainerInfo;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict : CM_DamageInstanceByLocDict;
	damageDict : CM_DamageInstanceByDmgePos;
	oldPxy 		: CM_TrackedItem;
	cargoMustBePrenoted : Boolean;
	oldPxyID	: String;
begin
	containerInfo:=_wagonPos.myDTOContainer;
	if containerInfo &lt;&gt; null then
		if containerInfo.myRealTrackedItem &lt;&gt; null and containerInfo.myRealTrackedItem.id = containerInfo.containerId then
			return;
		endif;
	endif;
	
	if containerInfo.containerId = null then
		return;
	endif;
	
	cargoMustBePrenoted:=self.myTerminal.getConfig(RailHHCargoMustPrenote).Boolean;
	
	realTI := self.myTerminal.lookupTrackedItem(containerInfo.containerId, TI_CargoType_Container, TI_STATE_NORMAL, null, false); //PAR 18971 cnwgb1 21.5.09
	
	
	if realTI = null then
		realTI := self.myTerminal.lookupTrackedItem(containerInfo.containerId, TI_CargoType_Container, TI_STATE_NOTIFIED, null, false); //PAR 18971 cnwgb1 21.5.09
	endif;
	
	
	
	
	if realTI = null and cargoMustBePrenoted then
		containerInfo.setMyRealTrackedItem(null);
		return;
	endif;
	//realTI will most likely still be null - fine, we'll create a new one.
	
	
	
	
	if realTI = null then
		if containerInfo.myPxyTrackedItem &lt;&gt; null  then
			if containerInfo.myRealTrackedItem &lt;&gt; null then
				containerInfo.setMyRealTrackedItem(null);
				create containerInfo.myPxyTrackedItem as CM_Container transient;
			endif;
		else
			create containerInfo.myPxyTrackedItem as CM_Container transient;
		endif;
	else
		containerInfo.setMyRealTrackedItem( realTI);
		
	endif;
	
	if realTI &lt;&gt; null then
		// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		//damageDict:=	realTI.allDamageInstances;
		damageDict:=	realTI.allDamageInstancesByPos;
	endif;
	containerInfo.myPxyTrackedItem.setPxyForRailHandHeld(containerInfo.containerId,
								containerInfo.isoTypeCode,
								containerInfo.customsSeal,
								containerInfo.operatorSeal,
								containerInfo.shipperSeal,
							damageDict);
		

	

epilog

end;</source>
        <Parameter name="_wagonPos" type="DTO_WagonPosition"/>
    </JadeMethod>
    <JadeMethod name="getValidContainerOutwards" id="7a45ad6c-257a-4d58-97a8-412e787fa802">
        <source>getValidContainerOutwards(_dtoWagon 	: DTO_Wagon;
						_wagonPos	: DTO_WagonPosition input;
						_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2007	cnwer1	Initial creation - PAR#15038

*/
vars
	loopTI,
	realTI		: CM_TrackedItem;
	realWagon	: CM_Wagon;
	tiArray		: CM_TIArray;
	containerInfo : DTO_ContainerInfo;
begin

	

// PAR 19710	realWagon := self.myTerminal.allWagons[_dtoWagon.wagonID];
	realWagon := _dtoWagon.myTrain.allWagonsByIdOutward[_dtoWagon.wagonID];
	
	containerInfo.setMyRealTrackedItem(null);
	
	if realWagon = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Wagon with id "' &amp; _dtoWagon.wagonID &amp; '" does not exist.');
	endif;
	containerInfo:=_wagonPos.myDTOContainer;
	
	if containerInfo.myRealTrackedItem &lt;&gt; null and containerInfo.myRealTrackedItem.id = containerInfo.containerId then
		return;
	endif;
	
	create tiArray transient;
	realWagon.getTIs(tiArray, REAL_MODE);
	
	foreach loopTI in tiArray do
		if loopTI.id = containerInfo.containerId then
			realTI := loopTI;
			break;
		endif;
	endforeach;

	
	
	if realTI = null then
		self.addError(Err_ID_No_Match, app.getErrorString1(Err_ID_No_Match, containerInfo.idx.String), _errorMsgs);
		return ;
	endif;
	
	containerInfo.setMyRealTrackedItem( realTI);
	

	//create containerInfo.myPxyTrackedItem as containerInfo.myRealTrackedItem.class transient;
	
	containerInfo.myPxyTrackedItem.setPxyForRailHandHeld(containerInfo.containerId,
									containerInfo.isoTypeCode,
									containerInfo.customsSeal,
									containerInfo.operatorSeal,
									containerInfo.shipperSeal,
									// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
									//containerInfo.myRealTrackedItem.allDamageInstances);
									containerInfo.myRealTrackedItem.allDamageInstancesByPos);
	//app.myProxyManager.createProxyLink(containerInfo.myRealTrackedItem,containerInfo.myPxyTrackedItem);
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_wagonPos" type="DTO_WagonPosition" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isRTDeviceValid" id="3a26c3ae-5b52-4971-a55a-76337e57bb31">
        <source>isRTDeviceValid(_device: CM_RadioTelemetryDevice input; _computerName : String; _checkAlt: Boolean io): CM_RadioTelemetryDevice;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	index : Integer;
begin
	//return inheritMethod(_device, _computer, _checkAlt);
	_checkAlt:=false;
	if not _device.isKindOf(CM_RTDeviceHandHeld) then
		return null;
	endif;
	
	if _device.computerName.toUpper = _computerName.toUpper  then
		return _device;

	else
		if  app.isDevelopmentSystem then
			_checkAlt:=true;	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_device" type="CM_RadioTelemetryDevice" usage="input"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_checkAlt" type="Boolean" usage="io"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="validateTermDefaultSettings" id="58b1181b-80d0-4a11-8a12-5672dca8405f">
        <source>validateTermDefaultSettings(_pxyTI : CM_TrackedItem; _errorMsgs : DTO_HandHeldGateErrorDict input);
// --------------------------------------------------------------------------------
// Created:		09 July 2010 by cnwjo3
//
// Purpose:		When a TI is confirmed/created on a wagon there are only 4 fields the user can access.
//				The remaining required fields are retrieved from Terminal Config 'Default'.  This method
//				checks that these fields have been set so errors aren't raised in the Trx layer. par 24921
//
vars

begin
	if _pxyTI.operatorCode = null and self.myTerminal.getConfig(DefOperator) = null then
		self.addError(ERR_TERM_CONFIG_OP_NOT_SET, app.getErrorString(ERR_TERM_CONFIG_OP_NOT_SET), _errorMsgs);
	endif;
	
	if _pxyTI.voyageCode = null and self.myTerminal.getConfig(DefVoyage) = null then
		self.addError(ERR_TERM_CONFIG_VOY_NOT_SET, app.getErrorString(ERR_TERM_CONFIG_VOY_NOT_SET), _errorMsgs);
	endif;
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWagonForInwards" id="cd6263ac-bfa0-49e1-8b3e-e3a9823a5903">
        <source>validateWagonForInwards(_dtoWagon : DTO_Wagon;
				_errorMsgs 	: DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _dtoWagon.wagonID = null then
	//	self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Wagon ID'), _errorMsgs);
		self.addError(Input_required_field_WgnId, app.getErrorString(Input_required_field_WgnId), _errorMsgs); // cnwdb2	PAR 35364


		
		return;
	endif;
	
	if _dtoWagon.myRailLine = null then
	//	self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Rail Line'), _errorMsgs);
		self.addError(Input_required_field_railLine, app.getErrorString(Input_required_field_railLine), _errorMsgs); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _dtoWagon.position = null then
	//	self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Wagon Position'), _errorMsgs);
		self.addError(Input_required_field_WgnFld, app.getErrorString(Input_required_field_WgnFld), _errorMsgs); // cnwdb2	PAR 35364
		return;
	endif;
	

end;


</source>
        <access>protected</access>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
</Class>
