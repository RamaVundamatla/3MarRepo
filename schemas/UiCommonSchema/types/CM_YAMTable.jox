    <JadeMethod name="isSpecifiedYAExpanded" id="a2027402-ddba-424a-8ffe-e2f0cc21d597">
        <updating/>
        <source>isSpecifiedYAExpanded( _ya : CM_YardAllocation ) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2009	cnwjk3	SFW1030

*/

vars
	row, column : Integer;
begin
	if self.findObjectInRow(_ya, row) then
		column := self.getColumnByRowName(ETRow_HideShow);
		if self.accessCell(row, column).picture = app.myRoot.getConfig(PicYAMCollapse).Binary then
			return true;
		endif;
	endif;	
	return false;
epilog

end;</source>
