    <JadeMethod name="frmGridArea_contextMenu" id="dfd24222-e0b4-4570-b24e-d491ed3d9a14">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	gridPoint	: CMUI_GridPoint;
	lTI : CM_TrackedItem;
	theLogController : CM_LogController;
	aSub : CM_BlockStack;
	aRestriction : CM_Restriction;
begin
	gridPoint := cntrl.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y); //self.frmGridArea

	if gridPoint &lt;&gt; null then
		if gridPoint.isKindOf(YRD_PadPoint) and (not gridPoint.YRD_PadPoint.isGap) then	//no restrictions on gaps
			self.doBuildMenuHeights();
			self.mnuHeights.visible := true;
			self.mnuHeights.enabled := true;
			
			return self.showContextMenu(mnuHeights, cntrl, conwin, mouse, x, y);
		endif;
	endif;	
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAreaMode" id="55836c3e-e58f-487e-b257-efd77aee567c">
        <source>getAreaMode() : Integer;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	areaMode : Integer;
begin
	if self.lstRestrictions.listIndex &lt; 0 then
		areaMode := YRD_PadArea.AreaMode_Height;
	else
		areaMode :=  self.lstRestrictions.itemData[self.lstRestrictions.listIndex];
	endif;
	return areaMode;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getListIndexForAdd" id="bb3cb7b3-f8af-4e52-93c1-11fc58a3c1f6">
        <source>getListIndexForAdd() : Integer;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx,theIndex : Integer;
	areaMode : Integer;
begin
	areaMode :=  self.theAreaMode;

	foreach idx in 1 to self.lstRestrictions.listCount do
		if self.lstRestrictions.itemObject[idx] = self.myCurrentTerminalArea 
		and self.lstRestrictions.itemData[idx] = areaMode then
			theIndex := idx + 1;
			break;
		endif;
	endforeach;
	
	return theIndex;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSpecialDataForDef" id="13c75741-4bbc-4f28-ae31-b9d6c1767385">
        <source>getSpecialDataForDef(_theTable : CM_EntryTable input; _theProperty : String; _theIndex : Integer; _theObject : Object);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
