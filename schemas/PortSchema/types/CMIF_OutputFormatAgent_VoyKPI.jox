    <JadeMethod name="displayRow" id="f9a2772a-ed41-4c77-9903-48f45628533d">
        <source>displayRow(_table :Table input; _array :ObjectArray; _asInteger :Boolean; _row, _startCol, _totalRow :Integer; _attribute :Attribute; _grandTotalColl :Collection input; _obj : Object):Decimal protected;
/*
Return Value:		

Date		Who		Reason
22/08/2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
29/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation
*/
vars
	value, total, colSubTotal, rowSubTotal	:Decimal [12, 2];
	subTotalColl	:Collection;
	obj				:Object;
	offset_SubTotal	:Integer;
	offset_Discharge	: Integer;			// PAR #35397
	offset_DischargeTS	: Integer;			// PAR #35397
	offset_Load			: Integer;			// PAR #35397
	offset_LoadTS		: Integer;			// PAR #35397
	offset_DLR			: Integer;			// PAR #35397
	offset_SOB			: Integer;			// PAR #35397
	offset_ROB			: Integer;			// PAR #35397
	isOnSite			: Boolean;			// PAR #35397
	isOffSite			: Boolean;			// PAR #35397
	isPrenotes			: Boolean;			// PAR #35397
begin
	offset_SubTotal	:= self.getOffsetSubTotal;
	offset_Discharge 	:= self.Offset_Discharge;								// PAR #35397
	offset_DischargeTS 	:= self.Offset_DischargeTS;								// PAR #35397
	offset_Load			:= self.Offset_Load;									// PAR #35397
	offset_LoadTS		:= self.Offset_LoadTS;									// PAR #35397
	offset_DLR			:= self.Offset_DLR;										// PAR #35397
	offset_SOB			:= self.Offset_SOB;										// PAR #35397
	offset_ROB			:= CMIF_OutputFormatAgent_Counter.Offset_ROB;			// PAR #35397
	
	// Onsite - doesn't have SOB or ROB											// PAR #35397
	if _obj.isKindOf(CM_Voyage) then											// PAR #35397
		offset_SubTotal := offset_SubTotal - 2;									// PAR #35397
		isOnSite := true;														// PAR #35397
	// Offsite - doesn't have LOAD, LOAD T/S, DLR, SOB or ROB					// PAR #35397
	elseif _obj.isKindOf(CM_Terminal) then										// PAR #35397
		offset_SubTotal := offset_SubTotal - 5;									// PAR #35397
		isOffSite := true;														// PAR #35397
	// Prenotes don't have LOAD T/S, DISCHARGE, DISCHARGE T/S, DLR, SOB or ROB	// PAR #35397
	elseif _obj.isKindOf(CM_Vessel) then										// PAR #35397
		offset_Load := offset_Load - 2;											// PAR #35397
		offset_LoadTS := offset_LoadTS - 2;										// PAR #35397
		offset_SubTotal := offset_SubTotal - 6;									// PAR #35397
		isPrenotes := true;														// PAR #35397
	endif;																		// PAR #35397
	
	create subTotalColl as self.getCollClass transient;
	
	if not isPrenotes then
		// Discharges (non-tranship)
		//self.displayRowItem (_table, _array, _attribute, self.Index_Discharge, _row, _startCol + self.Offset_Discharge, _totalRow, rowSubTotal, _asInteger, subTotalColl);		// PAR #35397
		self.displayRowItem (_table, _array, _attribute, self.Index_Discharge, _row, _startCol + offset_Discharge, _totalRow, rowSubTotal, _asInteger, subTotalColl);				// PAR #35397
			
		// Discharge (tranship)
		//self.displayRowItem (_table, _array, _attribute, self.Index_DischargeTS, _row, _startCol + self.Offset_DischargeTS, _totalRow, rowSubTotal, _asInteger, subTotalColl);	// PAR #35397
		self.displayRowItem (_table, _array, _attribute, self.Index_DischargeTS, _row, _startCol + offset_DischargeTS, _totalRow, rowSubTotal, _asInteger, subTotalColl);			// PAR #35397
	endif;
	
	if not isOffSite then
		// Loads (non-tranship)
		//self.displayRowItem (_table, _array, _attribute, self.Index_Load, _row, _startCol + self.Offset_Load, _totalRow, rowSubTotal, _asInteger, subTotalColl);					// PAR #35397
		self.displayRowItem (_table, _array, _attribute, self.Index_Load, _row, _startCol + offset_Load, _totalRow, rowSubTotal, _asInteger, subTotalColl);							// PAR #35397
	endif;
		
	if not isOffSite and not isPrenotes then
		// Load (tranship)
		//self.displayRowItem (_table, _array, _attribute, self.Index_LoadTS, _row, _startCol + self.Offset_LoadTS, _totalRow, rowSubTotal, _asInteger, subTotalColl);				// PAR #35397
		self.displayRowItem (_table, _array, _attribute, self.Index_LoadTS, _row, _startCol + offset_LoadTS, _totalRow, rowSubTotal, _asInteger, subTotalColl);						// PAR #35397
	
		// DLR
		//self.displayRowItem (_table, _array, _attribute, self.Index_DLR, _row, _startCol + self.Offset_DLR, _totalRow, rowSubTotal, _asInteger, subTotalColl);					// PAR #35397
		self.displayRowItem (_table, _array, _attribute, self.Index_DLR, _row, _startCol + offset_DLR, _totalRow, rowSubTotal, _asInteger, subTotalColl);							// PAR #35397
	endif;
	
	if not isOnSite and not isOffSite and not isPrenotes then
		// SOB
		//self.displayRowItem (_table, _array, _attribute, self.Index_SOB, _row, _startCol + self.Offset_SOB, _totalRow, rowSubTotal, _asInteger, subTotalColl);					// PAR #35397
		self.displayRowItem (_table, _array, _attribute, self.Index_SOB, _row, _startCol + offset_SOB, _totalRow, rowSubTotal, _asInteger, subTotalColl);							// PAR #35397
	
		// ROB
		if self.mode = self.Mode_CapacityTable then
			//self.displayRowItem (_table, _array, _attribute, CMIF_OutputFormatAgent_Counter.Index_ROB, _row, _startCol + CMIF_OutputFormatAgent_Counter.Offset_ROB, _totalRow, rowSubTotal, _asInteger, subTotalColl);	// PAR #35397
			self.displayRowItem (_table, _array, _attribute, CMIF_OutputFormatAgent_Counter.Index_ROB, _row, _startCol + offset_ROB, _totalRow, rowSubTotal, _asInteger, subTotalColl);										// PAR #35397
		endif;
	endif;
	
	// update subtotal for  workpoint/deck
	_table.accessCell (_row, _startCol + offset_SubTotal).text := self.formatNumber (rowSubTotal, _asInteger);
	
	self.updateCellCollection (_table, subTotalColl);
	
	// now update the total of all rowSubTotals
	total := _table.accessCell (_totalRow, _startCol + offset_SubTotal).text.asDecimalJMT;
	total := total + rowSubTotal;
	
	_table.accessedCell.text := self.formatNumber (total, _asInteger); 
	
	self.updateCellCollection (_table, subTotalColl);

	if self.mode = self.Mode_CapacityTable then
		// in theory should be no dup[licates but in testing we have some data problems
		subTotalColl.CM_TISet.copyNoDuplicates (_grandTotalColl.CM_TISet, false);
	else
		subTotalColl.copy (_grandTotalColl);
	endif;
	
	return rowSubTotal;
epilog
	delete subTotalColl;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_asInteger" type="Boolean"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_startCol" type="Integer"/>
        <Parameter name="_totalRow" type="Integer"/>
        <Parameter name="_attribute" type="Attribute"/>
        <Parameter name="_grandTotalColl" type="Collection" usage="input"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="displayRowItem" id="5408169b-3ef2-4609-85bb-b113328945f2">
        <source>displayRowItem(_table :Table input; _array :ObjectArray; _attribute :Attribute; _index,  _row, _col, _totalRow :Integer; _rowSubTotal :Decimal io; _asInteger :Boolean; _subTotalColl :Collection input)protected;
/*

Date		Who		Reason
01 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	coll	:Collection;
	value, colSubTotal	:Decimal [12,2];
	obj		:Object;
begin

	coll		:= _array [_index].Collection;
	
	if coll = null or coll.size = 0 then
		return;
	endif;
	
	value 		:= self.getTotalForAtttribute (coll, _attribute);

	_table.accessCell (_row, _col).text		:= self.formatNumber (value, _asInteger);
	_table.accessedCell.itemObject 			:= coll; 
	
	// update column subtotal
	colSubTotal 	:= _table.accessCell (_totalRow, _col).text.asDecimalJMT;
	colSubTotal		:= colSubTotal + value;
	
	
	_table.accessCell (_totalRow, _col).text	:= self.formatNumber (colSubTotal, _asInteger);
	
	self.updateCellCollection (_table, coll);
	
	coll.copy (_subTotalColl);
	
	_rowSubTotal	:= _rowSubTotal + value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_attribute" type="Attribute"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_totalRow" type="Integer"/>
        <Parameter name="_rowSubTotal" type="Decimal" usage="io"/>
        <Parameter name="_asInteger" type="Boolean"/>
        <Parameter name="_subTotalColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayRow_Container" id="b5edfd5c-6511-43e7-b884-ed120b3e488f">
        <source>displayRow_Container(_table :Table input; _row, _totalRow :Integer; _length :Integer; _attribute :Attribute; _keyRow :Integer; _displayGrandTotals :Boolean) protected;
/*
Date			Who		Reason
09/08/2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
29/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation
*/
vars
	rowSubTotal	: Decimal [12, 2];
	startCol	:Integer;
	coll		:DynaDictionary;
	iter		:Iterator;
	array		:ObjectArray;
	obj			:Object;
	asInteger	:Boolean;
	grandTotalColl		:Collection;
begin
	asInteger := true;
	
	// go through all the kpi's and get counts for the container length
	coll 	:= self.allData_Containers;
	
	if coll.isEmpty then
		return;
	endif;
	
	iter	:= coll.createIterator;
	
	if self.mode = self.Mode_CapacityTable then
		coll.startKeyGeq (_length, null, iter);
	else
		coll.startKeyGeq (_length, null, null, null, iter);
	endif;
	
	create grandTotalColl as self.getCollClass transient;
	
	while iter.next (array) do
		if array = null then
			continue;
		endif;
		
		if (iter.getCurrentKey (1)).Integer &lt;&gt; _length then
			break;
		endif;
		
		if self.mode = self.Mode_DecksTable or self.mode = self.Mode_RRMovesTable then
			obj := iter.getCurrentKey (4).Object; 
		elseif self.mode = self.Mode_CapacityTable then
			obj := iter.getCurrentKey (2).Object; 
		endif;
		
		// find the column to start displaying data - this is based on the item object property
		startCol := self.findColumnForObject (_table, _keyRow, obj);
		
		if startCol = null then
			continue;	//27 Mar 2018	NDL	TFS 37595
		//	app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unable to find KPI in table');
		endif;
		
		//rowSubTotal := rowSubTotal + self.displayRow (_table, array, asInteger, _row, startCol, _totalRow, _attribute,  grandTotalColl);		// PAR #35397
		rowSubTotal := rowSubTotal + self.displayRow (_table, array, asInteger, _row, startCol, _totalRow, _attribute,  grandTotalColl, obj);	// PAR #35397
	endwhile;
	
	if _displayGrandTotals then
		self.displayTotals (_table, asInteger, _row, startCol, _totalRow, _table.columns, rowSubTotal, grandTotalColl);
	endif;
epilog
	delete iter;
	delete grandTotalColl;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_totalRow" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_attribute" type="Attribute"/>
        <Parameter name="_keyRow" type="Integer"/>
        <Parameter name="_displayGrandTotals" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayRow_GC" id="18e4c125-aeb6-47a5-a7e6-81b450d21aec">
        <source>displayRow_GC(_table :Table input; _row, _totalRow :Integer; _cargoType :CM_CargoType; _attribute :Attribute; _keyRow :Integer; _displayGrandTotals :Boolean) protected;
/*
Date		Who		Reason
11/08/2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
29/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation
*/
vars
	rowSubTotal	: Decimal [12, 2];
	startCol	:Integer;
	coll		:DynaDictionary;
	iter		:Iterator;
	array		:ObjectArray;
	obj			:Object;
	asInteger	:Boolean;
	grandTotalColl	:Collection;
	
begin
	
	asInteger := not ((_attribute = CM_KPIVoyageMoveDtl_GC::area) or (_attribute = CM_KPIVoyageMoveDtl_GC::linearMetres));
	// go through all the kpi's and get counts for the container length
	coll 	:= self.allData_GeneralCargo;
	
	if coll.isEmpty then
		return;
	endif;
	
	iter	:= coll.createIterator;
	
	if self.mode = self.Mode_CapacityTable then
		coll.startKeyGeq (_cargoType, null, iter);
	else
		coll.startKeyGeq (_cargoType, null, null, null, iter);
	endif;
	
	create grandTotalColl as self.getCollClass transient;
	
	while iter.next (array) do
		if array = null then
			continue;
		endif;
		
		if (iter.getCurrentKey (1)).CM_CargoType &lt;&gt; _cargoType then
			break;
		endif;
		
		if self.mode = self.Mode_DecksTable or
			self.mode = self.Mode_RRMovesTable then
			obj := iter.getCurrentKey (4).Object; 
		elseif self.mode = self.Mode_CapacityTable then
			obj := iter.getCurrentKey (2).Object; 
		endif;
		
		// find the column to start displaying data - this is based on the item object property
		startCol := self.findColumnForObject (_table, _keyRow, obj);
		
		if startCol = null then
			continue;	//27 Mar 2018	NDL	TFS 37595
		//	app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unable to find KPI in table');
		endif;
		
		rowSubTotal := rowSubTotal + self.displayRow (_table, array, asInteger, _row, startCol, _totalRow, _attribute,  grandTotalColl, obj);
	endwhile;
	
	if _displayGrandTotals then
		self.displayTotals (_table, asInteger, _row, startCol, _totalRow, _table.columns, rowSubTotal, grandTotalColl);
	endif;
epilog
	delete iter;
	delete grandTotalColl;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_totalRow" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_attribute" type="Attribute"/>
        <Parameter name="_keyRow" type="Integer"/>
        <Parameter name="_displayGrandTotals" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayTotals" id="053095b4-cd97-473b-8977-d06b5c5d51bc">
        <source>displayTotals(_table :Table input; _asInteger :Boolean; _row, _startCol, _totalRow, _totalCol :Integer; _value :Decimal; _grandTotalColl :Collection) protected;
/*
Date		Who		Reason
22 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	total	:Decimal [12, 2];
begin
	// grand total for row
	total := _table.accessCell (_row, _totalCol).text.asDecimalJMT; 
	total := total + _value;		
	
	_table.accessedCell.text := self.formatNumber (total, _asInteger); 
	
	self.updateCellCollection (_table, _grandTotalColl);
	
	// update grand total for every thing
	total	:= _table.accessCell (_totalRow, _totalCol).text.asDecimalJMT;
	total	:= total + _value;
	
	_table.accessedCell.text 	:= self.formatNumber (total, _asInteger); 	
	
	self.updateCellCollection (_table, _grandTotalColl);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_asInteger" type="Boolean"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_startCol" type="Integer"/>
        <Parameter name="_totalRow" type="Integer"/>
        <Parameter name="_totalCol" type="Integer"/>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_grandTotalColl" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="findColumnForObject" id="8c07cfdf-f672-4397-80b4-954014a7ad9a">
        <source>findColumnForObject(_table :Table input; _row :Integer; _obj :Object):Integer protected;
/*
Date		Who		Reason
09 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	col, result	:Integer;
begin
	while col &lt; _table.columns do
		col := col + 1;
		
		if _table.accessCell (_row, col).itemObject = _obj then
			result := col;
			break;
		endif;
	endwhile;
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatNumber" id="5dfb5102-1359-4b64-8100-abb53c999e92">
        <source>formatNumber(_value :Decimal; _asInteger :Boolean):String protected;
/*
Purpose:			
Date		Who		Reason
24 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	
begin
	if _value = null then
		return null;
	endif;
	
	if _asInteger then
		return _value.rounded.asStringJMT;
	endif;
	
	return _value.asStringJMT;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_asInteger" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
