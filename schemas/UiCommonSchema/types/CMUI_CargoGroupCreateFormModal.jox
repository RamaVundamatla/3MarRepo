        <embedded/>
        <type name="CM_Operator"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="passedVoyage" id="c1538758-3c86-4292-834e-b84644964658">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="setCargoGroupId" id="750a23c3-cac4-43e8-b63d-7d2e37f4a515">
        <updating/>
        <source>setCargoGroupId( _passedId : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation

*/

vars

begin

	self.passedID := _passedId;

epilog

end;</source>
        <Parameter name="_passedId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d9a26992-7694-459d-a848-e115520c8d5d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation
30 Aug 2023	navrv30	ChangeRequest 59418: EUP - Cargo Group Creation -  Operator
*/

vars

begin

	inheritMethod();
	
	self.txtCGId.text := passedID;
	
	// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	if self.passedVoyage &lt;&gt; null then
		self.cmbGCOper.resetCollectionForVoyage(self.passedVoyage);
	
	endif;
	if self.passedOperator &lt;&gt; null then    //30.8.2023	navrv30	#59418
		self.cmbGCOper.listObject := passedOperator;  //30.8.2023	navrv30	#59418
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="eb5fa91b-9efd-4ab2-bb1a-2210db30cdac">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 June 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020708, locale);
end;</source>
    </JadeMethod>
</GUIClass>
