        <source>copyToRealWSObject(_realRequest: SAP13_AutocollInvoiceRequest_DT_T_Services_Item input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

