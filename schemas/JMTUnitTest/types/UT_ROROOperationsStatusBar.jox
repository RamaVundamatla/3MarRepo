	locn								: String;
	index								: Integer;
	completedDate						: TimeStamp;

begin

	app.writeLog("STEP A9", LogINFO);
	app.writeLog("Load the cargo to the voyage.  Please wait...", LogINFO);
	
	// load the rest of the items
	self.locationArray.clear();
	self.locationArray.add("D40421");
	self.locationArray.add("D40422");
	self.locationArray.add("D40423");
	self.locationArray.add("D40424");
	self.locationArray.add("D40425");
	self.locationArray.add("D40431");
	self.locationArray.add("D40441");
	
	self.loadAllJobsToOps(self.myVoyage, true);
	
	index := 1;
	create strs transient;
	foreach locn in locationArray do
		strs.clear();
		strs.add(locn);
		self.myVoyage.findLocation(strs, false, theSlot, idx);
		self.assertNotNull(theSlot);
		self.move(self.tisToPlanArray[index], theSlot);
		self.assertNoTrxErrorsOrWarnings();
		index := index + 1;
	endforeach;
	
	foreach job in self.myVoyage.allVoyageJobs do
		app.myTrxUA.trxUpdateJobStatus(job, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;


	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogINFO);
	
	// check that the details of the status bar is correct - Hide Exports
