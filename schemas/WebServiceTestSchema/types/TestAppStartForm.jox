    <JadeMethod name="load" id="cc804874-3299-48b3-bdee-ea352ccb3b3c">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars
	control			: TestAppControl;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	myControl := TestAppControl.firstInstance;
	beginNotification(myControl, Object_Update_Event, Response_Continuous, null);
	
	logMessage("Registered for updates to " &amp; myControl.String);
	
	setCaption;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logMessage" id="a27d09f7-74ef-4498-8ff6-1ad087741a79">
        <source>logMessage(msg : String);

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars
	
begin
	if runningSilent then
		return;
	endif;
	
	inheritMethod(msg);
	
	listBox1.addItemAt(app.actualTimeAppServer.time.displayWithMilliseconds &amp; " " &amp; msg.truncateWithEllipsis(100), 1);
	listBox1.topIndex := 1;
	self.doWindowEvents(0);
	

epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="256bb55e-bf50-485f-ac96-d34f0e304e19">
        <updating/>
        <source>setCaption() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
03 Nov 2004	cnwkpd1	PAR #4801 - Web Service application
02 Oct 2005	KPD		Change to display executable PID rather than App Server port

*/

vars
	pid, 
	result			: Integer;
	
begin
	caption := "Web Service Test";
		
	result := app.myCnKarmaCntrl.getProcessId(pid);
	if result = 0 then
		caption := caption &amp; " - PID " &amp; pid.String;
	endif;
	refreshNow;	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMyXMLSession" id="f3c14bf5-79ed-4031-a895-b5ca2a077ed1">
        <updating/>
        <source>setupMyXMLSession() : Boolean updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars
	xmlScript		: XMLSessionScript;
	xmlMessage,
	sessionID,
	result			: String;
		
begin
	// Handle errors - relinquish control of current session script
	if myXMLSessionScript &lt;&gt; null then
		unlock(myXMLSessionScript);
		myXMLSessionScript := null;
	endif;
	
	foreach xmlScript in myControl.allXMLSessionScripts discreteLock do
		if tryLock(xmlScript, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
			myXMLSessionScript := xmlScript;
			logMessage("Processing script " &amp; myXMLSessionScript.String);
			break;
		endif;
	endforeach;
	
	if myXMLSessionScript = null then
		logMessage("No script found");
		return false;
	endif;
	
	return true;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="4daa90e1-6ddb-4702-ba66-31d25b768aca">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars

begin
	if eventType = Object_Update_Event and theObject = myControl then
		self.doProcessUpdateNote();
	endif;
	
epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
