    <JadeMethod name="getDateTimeLocalTZ" id="f5f5a475-dd2c-49d6-a556-e87c1833b4a0">
        <source>getDateTimeLocalTZ():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2017	cnwma1	Initial creation
05 May 2017		cnwma1	  TFS #4346:Activity Report Timezone Issues
*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
