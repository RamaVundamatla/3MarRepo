<ExceptionClass name="HF_Exception" id="6aee1190-b018-4f27-9bb5-16081f1e7f27">
    <superclass name="NormalException"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ImplicitInverseRef name="myUserObject" id="26ad36f2-2c4f-4fb2-84a7-02df00fabea3">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="userString" id="f78b6ed3-7092-41c6-aeff-a6ae0fc0cf58">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="3d528e8d-1652-41c8-afe2-9939740f781c">
        <updating/>
        <source>set(pCode : Integer; pText : String; pWarning : Boolean; pUserString : String; pUserObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     17 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin

	self.errorCode := pCode;
	if pWarning then
		str := app.name &amp; " warning " &amp; pCode.String;	
	else
		str := app.name &amp; " error " &amp; pCode.String;
	endif;
	self.errorItem 		:= str;
	if app.useShortErrorMsg then
		self.extendedErrorText := pText;
	else
		self.extendedErrorText := 'Code :' &amp; pCode.String &amp; '. ' &amp; pText;
	endif;
	
	self.userString 	:= pUserString;
	self.myUserObject 	:= pUserObject;

end;</source>
        <Parameter name="pCode" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pWarning" type="Boolean"/>
        <Parameter name="pUserString" type="String"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
</ExceptionClass>
