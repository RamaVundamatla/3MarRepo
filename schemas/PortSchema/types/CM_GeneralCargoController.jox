    <JadeMethod name="validate" id="857e8650-5258-4a84-b668-21bc1e5228ef">
        <source>validate(_passport: CM_Passport input) protected;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if self.hatch = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'hatch', ETRow_Hatch, null);
		app.raiseCMException(Input_required_field_hatch, ETRow_Hatch, null); // cnwdb2	PAR 35364


	endif;
	if self.place = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Place', ETRow_Place, null);
		app.raiseCMException(Input_required_field_place, ETRow_Place, null); // cnwdb2	PAR 35364
	endif;
	if self.place &gt; Max_GC_HoldLocations then		// TFS 2229 - was missing, done for vessel but not voyage
		app.raiseCMException1(Voyage_GC_LocID_max, Max_GC_HoldLocations.String, self.place.String, self);
	endif;

	if self.myGCVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', ETRow_Voyage, null);
		app.raiseCMException(Input_required_field_voyage, ETRow_Voyage, null); // cnwdb2	PAR 35364


	endif;	
	self.validateSpecial();	//10 July 2013	NDL	Par 31965
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="a7070372-e72e-4a56-b5f8-211cb5088cf0">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

begin

	if not self.allTrackedItems.isEmpty
	or not self.allPlannedFutureMoves.isEmpty
	or not self.allQueuedFutureMoves.isEmpty
	then
		app.raiseCMException(HasCargoNoDelete, null, self);
	endif;

	

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateHoldName" id="96779439-b59c-495e-b49b-786f987040f1">
        <source>validateHoldName(_voyCode : String ): Boolean ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2015	cnwma1	Initial creation PAR #35519 1035 Error String Too Long

*/

vars
	totalLength : Integer;
	returnStr	: String;
	
	rawString : String;
	rawLength : Integer;
	maxVoyCodeLength : Integer;
begin
//	returnStr := _voyCode &amp; ' ' &amp; self.hatch.padLeadingWith('0',2) &amp; self.place.padLeadingWith('0',2);
//	if self.name.trimBlanks &lt;&gt; null then
//		returnStr := returnStr &amp; ' ' &amp; self.name;
//	endif;
	
	rawString := ' ' &amp; self.hatch.padLeadingWith('0',2) &amp; self.place.padLeadingWith('0',2);
	if self.name.trimBlanks &lt;&gt; null then
		rawString := rawString &amp; ' ' &amp; self.name;
	endif;
	rawLength := rawString.length;
	returnStr := _voyCode &amp; rawString;
	
	
	if self.name &lt;&gt; null then
		totalLength :=returnStr.length;
		if totalLength &gt; 30 then
			app.raiseCMException1(ERR_VOY_HOLDS_LENGTH,self.getFullId,null, null);
			return false;
		endif;
	endif;
	
	//10 Sep 2015	NDL	Par 36812
	//locations controller id max length = 30
	//voyage code max length = 20
//	if rawLength &gt; 10 then
//		maxVoyCodeLength := 30 - rawLength;
//		app.raiseCMWarning2(Lengt_hold_name_used_maxim_len,self.name,maxVoyCodeLength.String,null, null,null);
//	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_voyCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="aab96ee4-2427-412c-a9a7-03143c63966e">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/02/2017	cnwndl1	Initial creation	TFS 3216 / 3047
22/05/2017	cnwdap1	TFS 4179 LNX Hold Enquiry - Max Weight
02/12/2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
*/
vars
	ti : CM_TrackedItem;
	cargoHeightCms : Decimal[12,2];
	maxHeightString : String;
	weightAlreadyIn, weightToCompare : Decimal [12,2];	// TFS 4179
	futureMove : CM_FutureMove;							// TFS 4179
	mode : String;										// TFS 4179
	measure : String;									// TFS 4179
	weightDisplay, maxWeightDisplay : String;			// TFS 4179

begin
	inheritMethod(_control);
	
	ti := _control.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	if self.maxHeight &gt; 0 then
		maxHeightString := self.maxHeight.String &amp; app.getErrorString(Metres);
		cargoHeightCms := ti.getActualHeightRaw();
		if cargoHeightCms &gt; 0 then
			//maxHeight is in metres, so multiple by 100 to cms.
			if cargoHeightCms &gt;= ( self.maxHeight * 100 ) then
				//app.raiseCMException3( Locat_height_access_restr_max, ti.id, self.getFullId, maxHeightString, null, null ); 		// TFS 4179
				app.raiseCMWarning3( Locat_height_access_restr_max, ti.id, self.getFullId, maxHeightString, null, null, null ); 	// TFS 4179
			endif;
		endif;
	endif;
	
	if self.maxWeight &gt; 0 then																										// TFS 4179
		// in planning mode, check how much is planned																				// TFS 4179
		if _control.moveMode = PLANNING_MODE then																					// TFS 4179
			mode := app.getErrorString(Planned_Move);																				// TFS 4179
			foreach futureMove in self.allPlannedFutureMoves discreteLock where futureMove.isKindOf(CM_FutureMovePlanned) do		// TFS 4179
				if futureMove.myWorkListEntry = null then										// TFS 52360
					ti := futureMove.CM_FutureMovePlanned.myTrackedItem;						// TFS 52360
				else																			// TFS 52360
					ti := futureMove.myWorkListEntry.myTrackedItem;								// TFS 52360
				endif;																			// TFS 52360
				//if futureMove.myWorkListEntry.myTrackedItem.isBulkByQuantity then				// TFS 52360						// TFS 4179
				//	ti := futureMove.myWorkListEntry.myTrackedItem;								// TFS 52360						// TFS 4179
				if ti.isBulkByQuantity then														// TFS 52360						// TFS 4179
					weightAlreadyIn := weightAlreadyIn + (ti.totalWeight / ti.totalQuantity * _control.quantity);					// TFS 4179
				else																												// TFS 4179
					//weightAlreadyIn := weightAlreadyIn + futureMove.myWorkListEntry.weight;	// TFS 52360						// TFS 4179
					weightAlreadyIn := weightAlreadyIn + _control.weight;						// TFS 52360						// TFS 4179
				endif;																												// TFS 4179
			endforeach;																												// TFS 4179
		endif;																														// TFS 4179
		// in planned and real mode, check also check how much is already in there													// TFS 4179
		if _control.moveMode = PLANNING_MODE or _control.moveMode = REAL_MODE then													// TFS 4179
			if _control.moveMode = REAL_MODE then																					// TFS 4179
				mode := app.getErrorString(Actual_move);																			// TFS 4179
			endif;																													// TFS 4179
			weightAlreadyIn := weightAlreadyIn + self.totalWeight;																	// TFS 4179
		endif;																														// TFS 4179
																																	// TFS 4179
		if _control.myTrackedItem.isBulkByQuantity then																				// TFS 4179
			ti := _control.myTrackedItem;																							// TFS 4179
			weightToCompare := (ti.totalWeight / ti.totalQuantity * _control.quantity);												// TFS 4179
		else																														// TFS 4179
			weightToCompare := _control.weight;																						// TFS 4179
		endif;																														// TFS 4179
		if weightAlreadyIn + weightToCompare &gt; (self.maxWeight * 1000) then															// TFS 4179
			maxWeightDisplay := self.maxWeight.asStringJMT &amp; " tonnes";																// TFS 4179
			measure := _control.myTrackedItem.getDefaultMeasurementForType(Type_Weight).shortName;									// TFS 4179
			weightDisplay := app.convertMeasurementForDisplay(measure, weightToCompare) &amp; Space &amp; measure;							// TFS 4179
			app.raiseCMWarning5(Weight_location_exceed_max, mode, _control.myTrackedItem.id, weightDisplay, self.getFullId, maxWeightDisplay, null, null, null);	// TFS 4179
		endif;																														// TFS 4179
	endif;																															// TFS 4179

epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateSpecial" id="3039bdcb-afd8-4e57-bf9b-25f67d75e2ff">
        <source>validateSpecial();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwndl1	Initial creation	Par 31965
22 Jan  2015    cnwma1  PAR #35519 1035 Error String Too Long
*/

vars

	existing : CM_GeneralCargoController;
	real : CM_GeneralCargoController;

begin

	if self.myGCVoyage &lt;&gt; null then
		existing := self.myGCVoyage.allLocationsByHatchPlace.getAtKey( self.hatch, self.place );
		if existing &lt;&gt; null then
			if self.isTransient then
				real := self.pxyGetRealObject();
				if real &lt;&gt; existing then
					app.raiseCMException2(Loactio_already_defined_hold, self.place.String, self.hatch.String, null, self);
				endif;
			else
				if existing &lt;&gt; self then
					app.raiseCMException2(Loactio_already_defined_hold, self.place.String, self.hatch.String, null, self);
				endif;
			endif;
		endif;
	endif;
	
	if self.myVoyage &lt;&gt; null then   // 22/01/2015  cnwma1 PAR #35519
		self.validateHoldName(self.myVoyage.code);
	endif;
	if self.place &gt; Max_GC_HoldLocations then		// TFS 2302 done in 2229 for add but not for update
		app.raiseCMException1(Voyage_GC_LocID_max, Max_GC_HoldLocations.String, self.place.String, self);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
