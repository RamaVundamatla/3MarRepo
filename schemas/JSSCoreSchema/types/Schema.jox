<Class name="Schema">
    <JadeMethod name="jssGetLocalConstantCategories" id="9b30e2c2-2eaf-40c1-bc3f-f5a678573f11">
        <source>jssGetLocalConstantCategories():ConstCategoryNDict;
// --------------------------------------------------------------------------------
// Created:		27 March 2002 by cnwdad1
//
// Purpose:		Returns the schema's (subschema-hidden) collection of Constant Categories.
//
// Parameters:	None
//
// Returns:		The collecton of constant categories.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.constantCategories;
end;</source>
        <ReturnType type="ConstCategoryNDict"/>
    </JadeMethod>
    <JadeMethod name="jssIsSubschemaOf" id="13c51767-2e7a-4cdd-a355-7b25d18b43b3">
        <source>jssIsSubschemaOf(pSchemaObj:Schema):Boolean;
// --------------------------------------------------------------------------------
// Created:		22 March 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver inherits
//				from the specified schema (parameter).
//
// Parameters:	pSchemaObj - A reference to the schema in question.
//
// Returns:		True if the receiver inherits from the specified schema, otherwise
//				false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSubSchemasObj	: SchemaColl;
	
begin
	create allSubSchemasObj transient;
	pSchemaObj.allSubschemas(allSubSchemasObj);
	
	if allSubSchemasObj.includes(self) then
		return true;
	endif;
	
	return false;
epilog
	delete allSubSchemasObj;
end;</source>
        <Parameter name="pSchemaObj" type="Schema"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
