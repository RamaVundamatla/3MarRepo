    <JadeMethod name="getExtVoyageCode" id="e9d0b0aa-c9ac-4b78-aa76-89a2df518408">
        <source>getExtVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2019	jlger1	Initial creation

*/

vars
	detailPPK : WS_DetailPPK;
begin
	detailPPK:=self.allDetailPPK.first;
	if detailPPK &lt;&gt; null then
		return detailPPK.nomorPkk;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtensionStatuses" id="bdb3e12b-c185-48a6-a9f6-71cfad7fe14e">
        <source>getExtensionStatuses(_statuses : IntegerArray input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2018	jlger1	Initial creation

*/

vars
	pelindo1VoyProcess : CM_VoyageProcess;
	voyStatus,
	endStatus,
	startStatus : CM_VoyageStatus;
	iter : Iterator;
begin

	//Any with Priority less than the Priority of Voyage_Status_IVoyageArrived 
	endStatus 	:= app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IExtPendIPN  );
	startStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IExtReqIPN );
	if startStatus &lt;&gt; null then
		pelindo1VoyProcess := startStatus.myProcess;
		iter:=pelindo1VoyProcess.allStatuses.createIterator;
		pelindo1VoyProcess.allStatuses.startKeyGeq(startStatus.priority,iter);
		while iter.next(voyStatus) do
			_statuses.add(voyStatus.id);
			if voyStatus = endStatus then
				break;
			endif;
			
		endwhile;
		
	endif;

epilog
	delete iter;

end;</source>
        <Parameter name="_statuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOutgoingVoyageStatus" id="231db100-d393-472f-a525-5a9debc06d31">
        <source>getOutgoingVoyageStatus(_voyage: CM_Voyage): CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/05/2018	jlgndl1	Initial creation	TFS 38135
11/07/2018	jlgdap1	TFS 38135 PEL1 Inaportnet Integration
*/

vars

	currentStatus : Integer;
	voyStatus : CM_VoyageStatus;
	extensionStatuses : IntegerArray;
begin

	if _voyage &lt;&gt; null then
		currentStatus := _voyage.status;
	endif;

	create extensionStatuses transient;
	self.getExtensionStatuses(extensionStatuses);
	if currentStatus = Voyage_Status_IInitSerIPNPend then
		//if self.status.Integer = 2 then
			voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IInitSerIPNAppr );
		//endif;
	elseif currentStatus = Voyage_Status_IShiftRPendIPN then
		//voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IShiftAppIPN );		// TFS 38135
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IShiftRAppIPN );		// TFS 38135
	elseif extensionStatuses.includes(Voyage_Status_IExtPendIPN) then
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IExtAppIPN );
	elseif currentStatus = Voyage_Status_IDepRPendIPN then
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IDepRAppIPN );
	endif;

	return voyStatus;

epilog
	delete extensionStatuses;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getValidCurrentStatuses" id="8c339d42-1c13-4c4a-ad33-ae4ff40178a5">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin
	_validStatuses.add( Voyage_Status_IInitSerIPNPend );
	_validStatuses.add( Voyage_Status_IShiftRPendIPN );
	self.getExtensionStatuses(_validStatuses);
	_validStatuses.add( Voyage_Status_IDepRPendIPN );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="d40dbfce-f1f0-4753-9cc0-57268bc4b00c">
        <source>processMessage(  _voyage : CM_Voyage input );
/*

Purpose:			

Parameters:		
"	This is the INAPORTNET Web Service equivalent functionality to creating a Marine Services Request.
"	Voyage must be able to be identified by PKK number.
"	Voyage must be at the "Initial Marine Services Pending" or "Departure Marine Services Pending" status, otherwise
	the request will be rejected.
"	Update should mirror that in the current JMTUserInterfaceService::updateHMSResourcesUsed message if everything is OK.
	

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	detailPPK : WS_DetailPPK;
	berth : HMS_Berth;
begin

	foreach detailPPK in self.allDetailPPK do	
		detailPPK.processMessage(  _voyage ,self);		
	endforeach;	
	
	self.doUpdateVoyageStatus(_voyage);
	//epr tfs 39306 26/6/18
	//proforma is now created after the trxUpdateHMSResourceUsed is complete in the CM_TrxControlPostUpdateAgent
	// also does it off the work orders that are created 
	
epilog
	

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDataFormatsForProxy" id="4e1fc889-e514-43a8-8951-e41050062d71">
        <source>validateDataFormatsForProxy( _voyage : CM_Voyage io ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	term : CM_Terminal;
	date : Date;
	time : Time;
	detailPPK : WS_DetailPPK;
	berth : HMS_Berth;

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	term := app.myPassport.myTerminal;
	
	//6. Plan Date, Mandatory
	date:=self.tanggalRencana.asDateFromInaportnet;
	if not date.isValid then
		app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryPPKRequest::tanggalRencana.name, null, null); 
	endif;
	
	//7. Plan Time, Mandatory
	//epr TFS 40629 7/9/18
	time:=self.jamRencana.asTimeFromInaportnet;
	if not time.isValid then
		app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryPPKRequest::jamRencana.name, null, null); 
	endif;
	
	//Items 10. thru 27. (Multiple iterations of)
	foreach detailPPK in self.allDetailPPK do
		detailPPK.validateForVoyageUpdate( self, _voyage );
	endforeach;
	
	berth := self.getBerth( self.kodeDermaga );
	if berth = null then
		//The value '%1' in the field '%2' did not resolve to a '%3' in JMT.
		app.raiseCMException3(Value_field_not_resolve, self.kodeDermaga, WS_EntryPPKRequest::kodeDermaga.name, app.getErrorString(Berth), null, null);
	endif;
	
epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="417abaec-9e58-4b11-abb6-d3c127041fa6">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage io ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	detailPPK : WS_DetailPPK;

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.

	foreach detailPPK in self.allDetailPPK do
	
		detailPPK.validateForVoyageUpdate( self, _voyage );
	
	endforeach;
	
	if _voyage &lt;&gt; null then
		self.validateVoyageStatusForMsg( _voyage );
	endif;
	

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="877a8ae1-4d25-401f-aad1-ebdf8a885021">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	detailPPK : WS_DetailPPK;

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	
	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. Number of RPKRO, Mandatory
	if self.nomorRpkRo = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPPKRequest::nomorRpkRo.name, null, null);
	endif;
	
	//4. Number of PPK, Mandatory
	if self.nomorPpk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPPKRequest::nomorPpk.name, null, null);
	endif;
	
	//5. Quay Code, Mandatory
	if self.kodeDermaga = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPPKRequest::kodeDermaga.name, null, null);
	endif;
	
	//6. Plan Date, Mandatory
	if self.tanggalRencana = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPPKRequest::tanggalRencana.name, null, null);
	endif;
	
	//7. Plan Time, Mandatory
	if self.jamRencana = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPPKRequest::jamRencana.name, null, null);
	endif;
	
	//8 Port Code - Checked in superClass ::validareCredentials
	
	foreach detailPPK in self.allDetailPPK do
	
		detailPPK.validateMandFieldsPresent( self );
	
	endforeach;

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
