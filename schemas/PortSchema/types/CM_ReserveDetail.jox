begin
	ct:= self.getCargoType;
	if ct &lt;&gt; null and ct.isBulkMulti then
		return ct.getBulkTrackByDisplayForWeight(self.getWeightReleased(),self.getDensity,true); 
	elseif ct &lt;&gt; null and self.byTypeByWeight then													// 6/12/2023 navcs2 ChangeRequest 57537
		return ct.getConvertedWeightDisplay(self.getWeightReleased(), true);						// 6/12/2023 navcs2 ChangeRequest 57537
