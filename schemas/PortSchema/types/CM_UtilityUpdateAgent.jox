    <JadeMethod name="utlUpdateJob" id="cc112cd8-e27f-4e25-8a4b-f0d33b669486">
        <updating/>
        <source>utlUpdateJob(pProxyJob : CM_Job input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 navma1  		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	realJob:CM_Job;
	expectedEdition:Integer;

begin

	self.initialiseActivity();


	app.setContinueCMExceptions(true);
	app.myValUA.valJob(pProxyJob);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	pProxyJob.pxyGetRealObjectAndEdition(realJob, expectedEdition);
	
	if realJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Job.name, null, null);
		return;
	endif;

	exclusiveLock(realJob);

	if _passport.noErrors and realJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Job', null, null);
		return;
	endif;
		
	if _passport.noErrors then
		realJob.setForUpdate(pProxyJob, _passport.myTerminal);
	endif;

end;</source>
        <Parameter name="pProxyJob" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobAction" id="2ec72731-2dab-4fd0-84f7-3cc9e9016ec3">
        <source>utlUpdateJobAction(_job : CM_Job; _action : Integer; _actionTS : TimeStamp; _obj : CM_Object; _passport : CM_Passport input);		//23.09.2024  navbs1  #12445
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
*/

vars

begin
	
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateJobAction(_job, _action);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	_job.createStopStartTransaction( _action, _actionTS, _obj);		//23.09.2024  navbs1  #12445	//30.10.2024 navhl20 #33232
	
	if _passport.noErrors() then
		_job.updateObjectEdition(_job); //28/03/2024	navkc1 CR63258  Task 63259
	endif;
	
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_actionTS" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobAddRequest" id="99f4bca5-d471-4f08-bab0-13e4f325b645">
        <updating/>
        <source>utlUpdateJobAddRequest(_realJob : CM_RoadJob input; _cmifRequest : CMIF_ReleaseById input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 November 2005 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyRequest,
	newRequest : CM_Request;
	tmpTI : CM_TrackedItem;
	tmpConsignee : CM_ConsigneeConsignor;
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_realJob, 'Job');
	self.raiseExceptionIfNull(_cmifRequest, 'CMIF_Request');	
	
	app.setContinueCMExceptions(true);
	
	if _realJob.status = JOB_COMPLETE then
		app.raiseCMException1(ERR_JOB_COMPLETE, _realJob.getTreeDescription(), null, null);
	endif;

	_cmifRequest.validateForCreate(_passport);
		
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(_realJob);
	_cmifRequest.updateTICreateRequest(_realJob, _passport);

	if _passport.noErrors then
		_realJob.causeTerminalEvent(_realJob.Event_Mode_Create);
	endif;

end;</source>
        <Parameter name="_realJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_cmifRequest" type="CMIF_ReleaseById" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobDoMove" id="98e9ef71-aa1c-4264-80d4-7b429104c448">
        <updating/>
        <source>utlUpdateJobDoMove(_job : CM_Job input; 
				   _mode : Integer; 
				   _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 31/05/2022	jlier1		TFS 53650 - refactored schedule packages now called from vvr.departureProcess
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
vars
	roadJob		: CM_RoadJob;
	term		: CM_Terminal;
begin

	self.initialiseActivity();
	
	app.myValUA.valJobDoMove(_job, _mode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	term := _passport.myTerminal;											//22.04.2025 navma1 #MTN-34387
	
	exclusiveLock(_job);
	//th2 23/01/07 deadlock on CM_Terminal::allVehicleVisitRecords
	exclusiveLock(term.allVehicleVisits);
	//th2 added 24/01/07 - dealock 1081 @ CM_RoadJob::vehicleStillOnSite
	exclusiveLock(term.myRoadJobSheet.allJobsByOrder);
	
	if _passport.noErrors then
		_job.doMove(_mode, _passport);
	endif;
	
	if _passport.noErrors and _job.status = JOB_COMPLETE then
		if _job.isRoadJob then
			roadJob := _job.CM_RoadJob;
		
			if roadJob.jobType = BOLType_Log then
				roadJob.departureProcess(_passport);
			elseif roadJob.autoComplete then
				roadJob.departureProcess(_passport);
			endif;
		endif;
	endif;

epilog
end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobPriority" id="dfb265d8-f09f-4e7b-85e5-ec050c906a43">
        <updating/>
        <source>utlUpdateJobPriority(_realJobArray : CM_JobArray input; _priority : Integer input; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		24 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	realJob : CM_Job;
	
begin
	self.initialiseActivity();
	self.raiseExceptionIfNull(_realJobArray, 'Job Array');
	
	foreach realJob in _realJobArray where realJob.priority &lt;&gt; _priority do
		exclusiveLock(realJob);
	endforeach;

	foreach realJob in _realJobArray where realJob.priority &lt;&gt; _priority do
		realJob.setPriority(_priority);
	endforeach;

epilog

end;</source>
        <Parameter name="_realJobArray" type="CM_JobArray" usage="input"/>
        <Parameter name="_priority" type="Integer" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobRailOps" id="9a454696-a83e-49b4-9149-374f9ee6fb64">
        <updating/>
        <source>utlUpdateJobRailOps(pRealJob : CM_RailJob input; pIORake : CM_RailJSInOutRake; pDoAutoPlan : Boolean; pType : Integer;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		Note pDoAutoPlan reflects the drag drop windows autoplan state	
//
// Parameters:	None
//
// Returns:		Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	request : CM_Request;
	release : CM_BulkRelease;
	invalid : Boolean;
	
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(pRealJob, 'Rail Job');
	self.raiseExceptionIfNull(pIORake, 'Rail Rake');	


	if pType = Rail_JSIO_Type_Build then
		pRealJob.validateForReturnJob();
	endif;
	
	pRealJob.validateRakeTransfer(pIORake, _passport);		
	
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	exclusiveLock(pRealJob);
	
	if _passport.noErrors then
		
		request := pRealJob.allRequests.first;
		if request.myOriginatingBulkRelease = null then
			release := request.bulkRelease;					// Request initially uses 'bulkRelease' reference,
		else												// changed to use 'myOriginatingBulkRelease' in the method loadToOperations, when assign to outward rail.
			release := request.myOriginatingBulkRelease;	// Only 'bulkRelease' will be valid after the request is created but before it is loaded to ops.
		endif;
		/*
		31.03.2025 navma1 #MTN-34387
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, true);	// 04/02/2008 cnwar2 #15255
		endif;
		*/
	endif;
	
	// The type is the target
	if pType = Rail_JSIO_Type_Build then
		pRealJob.returnJobToBuildPriority(pIORake, _passport);
		//09 Mar 2017	NDl	TFS 3685
		if release &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, release, invalid);
			self.updateObjectEdition(release);
			on Exception do null;
		endif;
	elseif pType = Rail_JSIO_Type_In then
		pRealJob.moveToTransitReturn(pIORake);
	elseif pType = Rail_JSIO_Type_Out then
		pRealJob.loadToOperations(pIORake, ( pDoAutoPlan and app.isTerminalAutoPlanningEnabled()));   //SFW1030 04/08/2008   //31.03.2025 navma1 #MTN-34387
	elseif pType = Rail_JSIO_Type_Transit then
		pRealJob.moveToTransit(pIORake);
	endif;

	if _passport.noErrors then
		if pRealJob &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, pRealJob, invalid);
			invalid := false;
			pRealJob.causeTerminalEvent(pRealJob.Event_Mode_Update);
			on Exception do null;
		endif;
		/*
		31.03.2025 navma1 #MTN-34387
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, false);	// 04/02/2008 cnwar2 #15255
		endif;
		*/
	endif;
end;</source>
        <Parameter name="pRealJob" type="CM_RailJob" usage="input"/>
        <Parameter name="pIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="pDoAutoPlan" type="Boolean"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobRetroDT" id="51a49276-1ef4-4a6d-810a-bbfe80b83840">
        <updating/>
        <source>utlUpdateJobRetroDT(_job : CM_Job input; _retroDT : TimeStamp; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
20 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars

begin
	self.initialiseActivity();
	self.raiseExceptionIfNull(_job, 'Job');
	
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		_job.setRetrospectiveDT(_retroDT);
	endif;
	
	if _passport.noErrors then
		_job.causeTerminalEvent(_job.Event_Mode_Update);				//20.03.2024 navhl20 #62863
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_retroDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobRoadComplete" id="fc7f94a3-1b88-455b-8bc4-5f119a95ace4">
        <updating/>
        <source>utlUpdateJobRoadComplete(_roadJob : CM_RoadJob input;  _cmifRequest : CMIF_ReleaseById input; _cmifWleArray : CM_ObjectArray input; _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 June 2007
//
//----------------------------------------------------------------------
// 31/05/2022	jlier1		TFS 53650 - refactored schedule packages now called from vvr.departureProcess
vars
	obj : Object;
begin
	self.raiseExceptionIfNull(_roadJob, 'Job');
		
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	//MAKE WE HAVE THE CORRECT STATUS BEFORE WE START
	exclusiveLock(_roadJob);
	_roadJob.rebuildStatus();
	
	app.setContinueCMExceptions(true);
	
	//ADD A NEW REQUEST WITH A CHASSIS IF REQUIRED
	if _cmifRequest &lt;&gt; null then
		//self.initialiseActivity();
		if _roadJob.status = JOB_COMPLETE then
			app.raiseCMException1(ERR_JOB_COMPLETE, _roadJob.getTreeDescription(), null, null);
		endif;

		if _cmifRequest.validateForCreate(_passport)then 
			//exclusiveLock(_roadJob);
			_cmifRequest.updateTIChassis(_roadJob, _passport);
		endif;
	endif;
	
	//MOVE OUTSTANDING WORK ENTRIES - the rebuild in the roadjob.departureprocess should do the rest shouldn't it?
	//use CMIF_WorkListEntries to marry each location up to each ti
	foreach obj in _cmifWleArray do
		obj.CMIF_WorkEntry.processWorkEntry(_roadJob, _passport);
	endforeach;
	
	//PROCESS THE ROAD EXIT NOW
	//Prevent deadlocks by locking the job sheet.
	exclusiveLock(_passport.myTerminal.myRoadJobSheet.allJobsByOrder);
	if _passport.noErrors() and 
	not _passport.hasWarnings() or 
	_passport.warningsAcknowledged then
	
		//CHECK IF THERE IS ANYTHING TO PRINT BEFORE WE GET RID OF THE JOB
		_roadJob.departureProcess(_passport);
				
	endif;
	
	if _passport.noErrors then
		// rebuild these as in some cases the TI is deleted above which can result in invalid objects in the deferred dicts
		_passport.rebuildDeferredDicts();
		_passport.doDeferredUpdates();
	endif;
	
	app.setContinueCMExceptions(true);
	
epilog
	
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_cmifRequest" type="CMIF_ReleaseById" usage="input"/>
        <Parameter name="_cmifWleArray" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobStatus" id="8cf4239a-b3b5-4f07-9e86-b5d3d975ea37">
        <updating/>
        <source>utlUpdateJobStatus(pJob : CM_Job input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(pJob, 'Job');
	
	app.setContinueCMExceptions(false);


	if _passport.noErrors then
		pJob.rebuildStatus();
	endif;

end;</source>
        <Parameter name="pJob" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobStatusOnly" id="15b9d6c7-5fbe-4843-a295-89bdece0561b">
        <updating/>
        <source>utlUpdateJobStatusOnly(pJob : CM_Job input; _passport : CM_Passport input) updating;
// 31890 move update from GTE_RoadExitForm::doPrint (was in-line)
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(pJob, 'Job');
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		pJob.updateStatus();
	endif;

end;</source>
        <Parameter name="pJob" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobTrains" id="51d036a7-69bb-45c6-b66a-29797fe4b925">
        <updating/>
        <source>utlUpdateJobTrains(_realJob : CM_RailJob input; _train : CM_Train input; _doAutoPlan : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	request  : CM_Request;
	theBR,
	release  : CM_BulkRelease;
	yrequest : CM_YardRequest;
	invalid  : Boolean;
	
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_realJob, 'Rail Job');
	self.raiseExceptionIfNull(_train, 'Train');	

	exclusiveLock(_realJob);

	foreach request in _realJob.allRequests  discreteLock do

 		yrequest := request.CM_YardRequest;
		// ### AKB2004NOV CCMS 1282. Make the requests from the new screen actioned.
		theBR := yrequest.bulkRelease;
		if theBR &lt;&gt; null then
			if theBR.isReserveHeader() then
				yrequest.setBulkRelease(null);
				yrequest.setMyOriginatingBulkRelease(theBR);
			endif;
		endif;
	endforeach;
	
	if _passport.noErrors then

		request := _realJob.allRequests.first;
		if request.myOriginatingBulkRelease = null then
			release := request.bulkRelease;					// Request initially uses 'bulkRelease' reference,
		else												// changed to use 'myOriginatingBulkRelease' in the method loadToOperations, when assign to outward rail.
			release := request.myOriginatingBulkRelease;	// Only 'bulkRelease' will be valid after the request is created but before it is loaded to ops.
		endif;
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, true);
		endif;
	endif;
	
	// ############################
	// ############################
	// ############################
	// ############################
	_train.addJobToSheet(_realJob);
	
	if _passport.noErrors then
		if _realJob &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, _realJob, invalid);
			_realJob.causeTerminalEvent(_realJob.Event_Mode_Update);
			on Exception do null;
		endif;
		if release &lt;&gt; null then
			self.myUpdateAuditAgent.audUpdateGeneric(release, false);
		endif;
	endif;
end;</source>
        <Parameter name="_realJob" type="CM_RailJob" usage="input"/>
        <Parameter name="_train" type="CM_Train" usage="input"/>
        <Parameter name="_doAutoPlan" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobTransOnJobSheet" id="6fb2e943-76ed-4187-a816-6ab5a833fee1">
        <updating/>
        <source>utlUpdateJobTransOnJobSheet(_alljobs 		  : Boolean; 
							_theJob			  : CM_VoyageJob input;
							_jobSheetTransTo  : CM_VoyageJobSheet; 
							_newJob 		  : CM_VoyageJob output;
							_mode 			  : Integer; 
							_selectedRequests : CM_RequestSet; 
							_selectedWLES 	  : CM_WLESet; 
							_newJobNum 		  : String; 
							_moveJob 		  : Boolean; 
							_targetJob 		  : CM_VoyageJob;
							_passport 		  : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 2/9/2010		cnwjo3		CCMS 1178 PAR 23366 need to deal with select requests
// 10/10/2018	jlgrh7 		TFS #40668  POL - Transferring Work Between Cranes
// 21 Sep 2020  cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------

vars
	newJob 		: CM_VoyageJob;
	oldJS, 
	jobSheet 	: CM_VoyageJobSheet;
	term		: CM_Terminal;
	requests	: CM_RequestSet;
begin
	self.initialiseActivity();
	self.raiseExceptionIfNull(_jobSheetTransTo, app.getErrorString(Job_Sheet));
	self.raiseExceptionIfNull(_theJob, app.getErrorString(Job));	

	if _passport.hasErrors then				
		return;
	endif;

	create requests transient;

	if _selectedRequests &lt;&gt; null and not _selectedRequests.isEmpty then	//10 May 2012	NDL	Par 29528
		_selectedRequests.copy(requests);
	else
		_theJob.allRequests.copy(requests);
	endif;	

	_theJob.validateForSplit(requests);
	if _targetJob &lt;&gt; null then
	
		// TFS 8157 if the job ids are the same and the source job is part complete then this is a split which is OK
		// TFS 8157 if the job ids are the same and the source job is unactioned then this is a merge which we do not do
		if _targetJob.jobNum = _newJobNum 
		and _theJob.status = JOB_UNACTIONED   												 // TFS 8157 _theJob is the source job. 
		and _moveJob then  																	 // TFS 8157 
			jobSheet:= _targetJob.myJobSheet.CM_VoyageJobSheet;  							 // TFS 8157
			app.raiseCMException1(Numbe_alrea_exist_pleas_creat_,  _newJobNum, null, null);  // TFS 8157
		endif;  																			 // TFS 8157
		
	elseif not _alljobs and _theJob.status = JOB_UNACTIONED then
		_theJob.validateUniqueJobNum(_newJobNum);											 //epr par 32250 23/10/13
	endif;
	
	if _theJob.myVoyage &lt;&gt; _jobSheetTransTo.myVoyage then
		app.raiseCMException(Cannot_transf_crane_differ_voy, null, null);
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	term := _theJob.getMyTerminal();
	
	if term = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, app.getErrorString(ERROR_NULL_Terminal), null, null);
		return;
	endif;
	
	exclusiveLock(_theJob);
	exclusiveLock(_jobSheetTransTo);
	
	oldJS := _theJob.myVoyageJobSheet;
	
	if _theJob.isVoyageHoldJob() then // TFS 3646
	
		_theJob.splitSelectedWLEs(newJob,_selectedWLES,_newJobNum,_jobSheetTransTo.crane, _targetJob);
		
		if _passport.hasErrors then				
			return;
		endif;			
	
	elseif _moveJob = false
	and (_mode = UNPLAN_MODE or _mode = PLANNING_MODE or _mode = QUEUE_MODE or _mode = REAL_MODE) and _theJob.allRequests.size &gt; 1 then
		_theJob.splitAllRequests(newJob,requests,_newJobNum,_jobSheetTransTo,_jobSheetTransTo.crane,_targetJob);  //+TFS40668 will set isTwinLift Here in New Job
		if _passport.hasErrors then				
			return;
		endif;			
		
	//Check to see if a split was needed
	elseif _theJob.status = JOB_PART_COMPLETE and (_theJob.allRequests.size &gt; 1 or _theJob.isVoyageHoldJob()) then
		_theJob.splitUnactionedRequests(newJob,requests,_newJobNum,_jobSheetTransTo,_jobSheetTransTo.crane,_targetJob);			//+TFS40668 will set isTwinLift Here in New Job
		if _passport.hasErrors then				
			return;
		endif;			
	
	
	elseif _theJob.status = JOB_UNACTIONED and _moveJob = true then
		//epr TFS 830 13/4/17 let them change number when moving
		if not _alljobs and _newJobNum &lt;&gt; _theJob.jobNum then
			_theJob.setJobNum(_newJobNum);
		endif;
		_theJob.setCrane(null,_jobSheetTransTo.crane);
		
	elseif _theJob.isHatchLidJob then		//10 May 2012	NDL	Par 29528
		_theJob.splitAllRequests(newJob,requests,_newJobNum,_jobSheetTransTo,_jobSheetTransTo.crane,_targetJob);	//+TFS40668 will set isTwinLift Here in New Job
		if _passport.hasErrors then				
			return;
		endif;	
		
	else
		return; //silently as job is complete
	endif;

	if _passport.hasErrors then				
		return;
	endif;

	// Send event to remove job from unallocated list
	_theJob.causeTerminalEvent(CM_Job.Event_Mode_Update);
		
	if _theJob.myJobSheet &lt;&gt; null and _theJob.myJobSheet &lt;&gt; oldJS then
		// send event to update new job sheet
		_theJob.myVoyage.causeEvent(term.getTerminalEvent(JobSheet_Update_Event), false, _theJob.myJobSheet);					
	endif;
	if oldJS &lt;&gt; null then
		// Send event to update old job sheet
		_theJob.myVoyage.causeEvent(term.getTerminalEvent(JobSheet_Update_Event), false, oldJS);
	endif;	
	
	if newJob &lt;&gt; null then
		newJob.causeTerminalEvent(newJob.Event_Mode_Create);
		_newJob := newJob;
		//21/09/2020 cnwma1 TFS #49906
		if newJob.isVoyageJob() then
			app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,newJob.myTerminal,newJob);
		endif;
		//21/09/2020 cnwma1 TFS #49906
	endif;
epilog
	delete requests;
end;</source>
        <Parameter name="_alljobs" type="Boolean"/>
        <Parameter name="_theJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_jobSheetTransTo" type="CM_VoyageJobSheet"/>
        <Parameter name="_newJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_selectedWLES" type="CM_WLESet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_moveJob" type="Boolean"/>
        <Parameter name="_targetJob" type="CM_VoyageJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobTransferType" id="4961e2f8-a79c-4daa-906e-064625ff7324">
        <updating/>
        <source>utlUpdateJobTransferType(_job : CM_VoyageJob;_transferType : Integer;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	job : CM_VoyageJob;
	expectedEdition:Integer;
	oldType,newType : String;
begin

	self.initialiseActivity();
	
	_job.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_job.pxyGetRealObjectAndEdition(job, expectedEdition);
	
	if job = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;
	
	oldType := app.myRoot.allVoyageJobTransferTypes[job.transferType].CM_VoyageJobTransferType.description;
	newType := app.myRoot.allVoyageJobTransferTypes[_transferType].CM_VoyageJobTransferType.description;
	
	if not _passport.warningsAcknowledged then
		app.raiseCMWarning3(Update_JobTType_Conf,oldType,newType,job.id,null,null,_job);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(job);

	if _passport.noErrors and job.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		job.setTransferTypeManual(_transferType);
	endif;

	if _passport.noErrors then
		job.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
	endif;

epilog
	
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_transferType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobType" id="5bd883be-fe9d-43e3-b205-e397c2bf83a6">
        <source>utlUpdateJobType(pProxyJobType:CM_JobType; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	realJobType : CM_JobType;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	pProxyJobType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyJobType.pxyGetRealObjectAndEdition(realJobType, expectedEdition);
	
	if realJobType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_JobType.name, null, null);
		return;
	endif;

	app.myValUA.valJobType(realJobType, pProxyJobType);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realJobType);

	if _passport.noErrors and realJobType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'JobType', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realJobType, true);
	endif;
	
	if _passport.noErrors then
		realJobType.setForUpdate(pProxyJobType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realJobType, false);
	endif;
end;</source>
        <Parameter name="pProxyJobType" type="CM_JobType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobUnqueue" id="3b49ba7e-3dce-4f6e-a257-829a4f093341">
        <updating/>
        <source>utlUpdateJobUnqueue(_realJob : CM_Job input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: February 2002 By: cnwgd1
//-----------------------------------------
vars
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_realJob, 'Job');	

	exclusiveLock(_realJob);

	if _passport.noErrors then
		_realJob.unQueueJob(_passport);
	endif;

end;</source>
        <Parameter name="_realJob" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobWLEOrderByAddress" id="af716128-504c-4417-ba8b-0874e07e2a20">
        <updating/>
        <source>utlUpdateJobWLEOrderByAddress(_job : CM_Job; _addresses : StringArray; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 October 2023			jlizm1	Initial creation TFS 59730 Kiosk Load Sequence

*/

vars
	realJob 		: CM_Job;
	wle 			: CM_WorkListEntry;
	expectedEdition : Integer;
	wles			: CM_WLEArray;
	idx				: Integer;
	addressId		: String;
	wleAddress		: CM_Address;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_job, 'Job');
	
	if not _passport.noErrors then
		return;
	endif;
	
	create wles transient;
	_job.workListEntries.copy(wles);
	
	foreach addressId in _addresses do
		foreach wle in wles do
			if addressId = wle.getDeliveryAddressCode then
				wle.setJob(null);
				wle.setJob(_job);
			endif;
		endforeach;
	endforeach;

epilog
	delete wles;
	
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_addresses" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateJobWithWle" id="f3e57289-f2f2-4141-bf5d-3756462200f3">
        <source>utlUpdateJobWithWle(_job : CM_Job input; _jobId : String; _jobSheet : CM_WorkPointJobSheet; _wleSet : CM_WLESet; _term : CM_Terminal; _quant : Integer; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
06 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
11 Sep 2024 navbs1	Bug 65919: EUP | 53729 - WO Jobs - Remaining Quantity field is not updating correctly after splitting the partially completed unpack jobs
*/

vars
	jobParams  		: CMIF_WorkOrderJobParams;
	tiSet			: CM_TISet;
	job,
	jobParent,
	jobChild		: CM_Job;
	ti				: CM_TrackedItem;
	wodDtl			: CM_WorkOrderDtl;
	toDotaskDesc 	: CM_ToDoTaskDesc;
	wle,
	wleNew,
	wleOld			: CM_WorkListEntry;
	wleArrNew,
	wleArrOld		: CM_WLEArray;
begin
	if _term.isUseYardJobsForCargoWo then
		app.myValUA.valJobSplit(_job, _wleSet, _jobId, _jobSheet);						//12.08.2024 navhl20 #65424
		create jobParams transient;
		if _job.myWODtl &lt;&gt; null then
			wodDtl := _job.myWODtl;
		elseif _job.myWorkOrderDtlToDo &lt;&gt; null then
			wodDtl := _job.myWorkOrderDtlToDo;
		endif;
		if wodDtl.isKindOf(CM_WorkOrderTIDtl) then
			if wodDtl.isKindOf(CM_WodToDo) then
				foreach toDotaskDesc in wodDtl.CM_WodToDo.allToDoTasksDescs do
					jobParams.myToDoTaskDesc := toDotaskDesc;
					jobParams.jobId 		 := _jobId;
					jobParams.myWorkOrderDtl := wodDtl;
					jobParams.requiredByDT	 := wodDtl.requiredByDT;
					app.myUtilityCA.utlCreateInternalWorkOrderJob(wodDtl,jobParams, job, _passport );
				endforeach;
			else
				jobParams.jobId 		 := _jobId;
				jobParams.myWorkOrderDtl := wodDtl;
				jobParams.requiredByDT	 := wodDtl.requiredByDT;
				if not _job.isKindOf(CM_WOPackJob) then																//06.08.2024 navhl20 #65424
					app.myUtilityCA.utlCreateInternalWorkOrderJob(wodDtl,jobParams, job, _passport );
				else
					jobParams.isPackParentJob   := true;
					app.myUtilityCA.utlCreateInternalWorkOrderJob(wodDtl,jobParams, jobParent, _passport );
					if _passport.noErrors then
						jobParams.isPackParentJob   := false; 
						app.myUtilityCA.utlCreateInternalWorkOrderJob(wodDtl,jobParams, jobChild, _passport );
						if _job.isRetrospective then
							jobChild.setRetrospectiveDT(_job.retrospectiveDT);
						endif;
					endif;
				endif;
			endif;
		elseif wodDtl.isKindOf(CM_WorkOrderToDoDtl) then
			foreach toDotaskDesc in wodDtl.CM_WorkOrderToDoDtl.allToDoTasksDescs do
				jobParams.myToDoTaskDesc := toDotaskDesc;
				jobParams.jobId 		 := _jobId;
				jobParams.myWorkOrderDtl := wodDtl;
				jobParams.requiredByDT	 := wodDtl.requiredByDT;
				app.myUtilityCA.utlCreateInternalWorkOrderJob(wodDtl,jobParams, job, _passport );
			endforeach;
		endif;
		
		if job &lt;&gt; null and _job.isRetrospective then																//07.08.2024 navhl20 #65424
			job.setRetrospectiveDT(_job.retrospectiveDT);
		endif;
		
		if not _job.isKindOf(CM_WOPackJob) then																		//06.08.2024 navhl20 #65424
			job.setMyWorkPointJobSheet(_jobSheet);
		else
			jobChild.setMyWorkPointJobSheet(_jobSheet);
			jobParent.setMyWorkPointJobSheet(_jobSheet);
		endif;
		
		foreach wle in _wleSet do
			if not _job.isKindOf(CM_WOPackJob) then																	//06.08.2024 navhl20 #65424
				wle.setJob(job);
			else
				if wle.isKindOf(CM_WOPackChildWLE) then
					wleNew := jobChild.workListEntries.first;
					if _job.status = JOB_UNACTIONED and _quant &lt;&gt; null then
						wleNew.setQuantity(_quant);
						wleOld := _job.workListEntries.first;
						wleOld.setQuantity(wleOld.quantity - _quant);
					else
						wleNew.setQuantity(wle.quantity);
					endif;
				endif;
			endif;
			if wle.myTrackedItem &lt;&gt; null then
				_job.CM_WorkOrderJob.allTrackedItems.remove(wle.myTrackedItem);
				job.CM_WorkOrderJob.allTrackedItems.addNoDuplicates(wle.myTrackedItem,false);
			endif;
		endforeach;
		
		if not _job.isKindOf(CM_WOPackJob) then																		//06.08.2024 navhl20 #65424
			wleArrNew := job.workListEntries;
		else
			create wleArrNew transient;
			jobChild.workListEntries.tryCopy(wleArrNew);
			jobParent.workListEntries.tryCopy(wleArrNew);
			job := wodDtl.CM_WodPack.allJobs.first;
			foreach wle in _wleSet where wle.isKindOf(CM_WOPackParentWLE) do
				wleNew := jobParent.workListEntries.first;
				wleOld := job.workListEntries.first;
				wleNew.erase(NORMAL_ERASE);
				wleOld.erase(NORMAL_ERASE);
			endforeach;
		endif;
		wleArrOld := _job.workListEntries;
		
		foreach wle in _wleSet do																					//06.08.2024 navhl20 #65424
			if not wleArrNew.includes(wle) and _job.status &lt;&gt; JOB_UNACTIONED then
				wle.erase(NORMAL_ERASE);
			endif;
			if wleArrOld.includes(wle) and _job.status &lt;&gt; JOB_UNACTIONED then
				wle.erase(NORMAL_ERASE);
			endif;
		endforeach;
		
		if not _job.isKindOf(CM_WOPackJob) then																		//06.08.2024 navhl20 #65424
			job.CM_WorkOrderJob.changeStatus(JOB_UNACTIONED);
		else
			jobChild.CM_WorkOrderJob.changeStatus(JOB_UNACTIONED);
			jobParent.CM_WorkOrderJob.changeStatus(JOB_UNACTIONED);
		endif;
		
		if _job.workListEntries.isEmpty() or 
		_job.areWLEsAllDone() then																					//06.08.2024 navhl20 #65424
			if not _job.isKindOf(CM_WOPackJob) then																	//06.08.2024 navhl20 #65424
				_job.changeStatus(JOB_COMPLETE);
			else
				job := wodDtl.CM_WodPack.allJobs.first;
				_job.changeStatus(JOB_COMPLETE);
				if job.areWLEsAllDone() then																		//22.08.2024 navhl20 #65424
					job.changeStatus(JOB_COMPLETE);
				endif;
				//job.causeTerminalEvent(job.Event_Mode_Update);													//11.09.2024 navbs1 #65919
			endif;
		endif;
		//_job.causeTerminalEvent(_job.Event_Mode_Update);															//11.09.2024 navbs1 #65919
		self.updateObjectEdition(_job);																				//11.09.2024 navbs1 #65919
	endif;
epilog
	if wleArrNew &lt;&gt; null and wleArrNew.isTransient then
		delete wleArrNew;
	endif;
	delete jobParams;
end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_jobId" type="String"/>
        <Parameter name="_jobSheet" type="CM_WorkPointJobSheet"/>
        <Parameter name="_wleSet" type="CM_WLESet"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_quant" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateKiosk" id="597958b0-eb2d-4712-85be-0db4ec851188">
        <source>utlUpdateKiosk(	_pxyKiosk : CM_Kiosk input;
				_passport : CM_Passport input);

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	realKiosk 		: CM_Kiosk;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyKiosk, 'Kiosk Proxy');
	
	_pxyKiosk.pxyGetRealObjectAndEdition(realKiosk, expectedEdition);
	self.raiseExceptionIfNull(realKiosk, 'Kiosk');
	
	_pxyKiosk.validateUpdate(_passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	realKiosk.setForUpdate(_pxyKiosk);
end;</source>
        <Parameter name="_pxyKiosk" type="CM_Kiosk" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateKioskAddQuestion" id="f69d31d1-9c10-493b-a53e-4046ffcaf68a">
        <source>utlUpdateKioskAddQuestion(	_pxyQuestion 	: CM_KioskAdditionalQuestion input; 
							_allCriteria	: CMIF_Array;
							_passport 		: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	realQuestion : CM_KioskAdditionalQuestion;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyQuestion, 'Additional Question Proxy');
	
	_pxyQuestion.pxyGetRealObjectAndEdition(realQuestion, expectedEdition);
	self.raiseExceptionIfNull(realQuestion, 'Additional Question');

	app.myValUA.valKioskAdditionalQuestion(_pxyQuestion);
	
	if _passport.hasErrors then
		return;
	endif;
	
	realQuestion.setForUpdate(_pxyQuestion);
	
	if _passport.noErrors() then
		realQuestion .persistCriteria(_allCriteria, _passport);
	endif;

epilog

end;</source>
        <Parameter name="_pxyQuestion" type="CM_KioskAdditionalQuestion" usage="input"/>
        <Parameter name="_allCriteria" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateKioskPPEQuestion" id="421de175-4362-4202-b7a3-1741e7567d75">
        <source>utlUpdateKioskPPEQuestion(  _pxyPPEQuestion 	: CM_KioskPPEQuestion input; 
							_passport 			: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars
	realPPEQuestion : CM_KioskPPEQuestion;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyPPEQuestion, 'PPE Question Proxy');
	
	_pxyPPEQuestion.pxyGetRealObjectAndEdition(realPPEQuestion, expectedEdition);
	self.raiseExceptionIfNull(realPPEQuestion, 'PPE Question');

	app.myValUA.valKioskPPEQuestion(_pxyPPEQuestion);
	
	if _passport.hasErrors then
		return;
	endif;
	
	realPPEQuestion.setForUpdate(_pxyPPEQuestion);


epilog

end;</source>
        <Parameter name="_pxyPPEQuestion" type="CM_KioskPPEQuestion" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLabourWorkArea" id="e0fe8c65-6dde-4cdb-83fd-02ecbbaed36d">
        <source>utlUpdateLabourWorkArea(pProxyLabourWorkArea : CM_LabourWorkArea; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars
	cancelSave:Boolean;
	realLabourWorkArea:CM_LabourWorkArea;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyLabourWorkArea.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyLabourWorkArea.pxyGetRealObjectAndEdition(realLabourWorkArea, expectedEdition);
	
	if realLabourWorkArea = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LabourWorkArea.name, null, null);
		return;
	endif;

	app.myValUA.valLabourWorkArea(realLabourWorkArea, pProxyLabourWorkArea);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realLabourWorkArea);

	if _passport.noErrors and realLabourWorkArea.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'LabourWorkArea', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLabourWorkArea, true);
	endif;
	
	if _passport.noErrors then
		realLabourWorkArea.setForUpdate(pProxyLabourWorkArea);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLabourWorkArea, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyLabourWorkArea" type="CM_LabourWorkArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLanderDischargeGround" id="59cc40b5-d270-495d-b8b4-727eb93db84d">
        <source>utlUpdateLanderDischargeGround(_groundOption : Integer;	
							_ti : CM_TrackedItem input;
							_groundLC : CM_LocationsController input;
							_job : CM_VoyageJob;
							_wle : CM_WorkListEntry;
							_passport : CM_Passport input);
/*
Purpose:			
Date		Who		Reason
07 July 2015	cnwab1	Initial creation
*/

vars
	realObject		: CM_TrxTestObject;
	expectedEdition	: Integer;

	rtQueueEntry : CM_RTQueueEntry;
	moveController		: CMIF_MoveController;
	vWLE				: CM_VoyageWLE;
	request			: CM_Request;
	rtQueueEntryArray	: CM_RTQueueEntryArray;
	edition : Integer;
	invalidWLE : Boolean;
	form : Form;
	rtQueueTask : CM_RTQueueTask;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	///form : Form;
	voyJob : CM_VoyageJob;
	futureMoveDis : CM_FutureMove;//27 Mar 2018	NDL	TFS 37569
	fmIndex : Integer;//27 Mar 2018	NDL	TFS 37569
	futureMoveLoad : CM_FutureMove;//27 Mar 2018	NDL	TFS 37569
	invalidFM: Boolean;//27 Mar 2018	NDL	TFS 37569
begin
	if _ti = null or _ti.isSOB then
		return;
	endif;
	

	self.initialiseActivity();
	
	if app.applicationType = app.ApplicationType_GUI then	//22 Jul 2019	NDL	TFS 45758 - UE 14009 from new web lander
		form := app.getForm("MOB_HHLanderCargoMove");	// return this form if its active.
		if form = null then
			form := app.getForm("MOB_HHLanderGround");	// return this form if its active.
		endif;
	endif;
	
	_ti.receiveFromShipViaLander(form, _groundLC,  _passport); 
	
	vWLE := _wle.CM_VoyageWLE;
	if vWLE &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, vWLE, invalidWLE);
		edition := vWLE.edition;
		if invalidWLE then	//04 Jan 2019	NDL	TFS 42738
			vWLE := null;
		endif;
	endif;
	
	//10 Jul 2012 	NDL	Par 29961
	if _groundOption = GroundComplete then
	
		lc := _ti.myPrimaryPlannedLocation;	//31 Aug 2012	NDL	Par 29961
	
		//14 Jun 2012	NDL	Par 29745 - Rule change again, now we don't want to keep queued moves for grounded cargo.
		//10 Jul 2012 	NDL	Par 29961 - And now we do but conditionally on the type of grounding, GroundComplete
		//              is all over rover leave it here. GroundInTransit means ground it in the interchange at the moment
		//				and keep the queued moves in place.
		if vWLE &lt;&gt; null and  not vWLE.allRTQueueEntries.isEmpty then
			create rtQueueEntryArray transient;
			vWLE.allRTQueueEntries.copy(rtQueueEntryArray);
			foreach rtQueueEntry in rtQueueEntryArray do
				app.myUtilityDA.utlDeleteQueueEntry(rtQueueEntry, false, null, app.myPassport);
			endforeach;
		endif;
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		if _ti.isRehandle and vWLE &lt;&gt; null then
			if vWLE.myRequest &lt;&gt; null then
				if vWLE.myRequest.isKindOf(CM_SlotRequest) then
					request := vWLE.myRequest;
				elseif vWLE.myRequest.isKindOf(CM_VoyageRequest) then
					request := vWLE.myRequest;
				endif;
			endif;
		endif;
		
		if _ti.isQueued then
			create moveController transient;
			moveController.setMoveMode(QUEUE_MODE);
			moveController.setMyTrackedItem(_ti);
			moveController.setMyWorkListEntry(vWLE);
			if vWLE &lt;&gt; null and vWLE.myFutureMove = null then
				moveController.setMyWorkListEntry(null);
			endif;

			app.myUtilityUA.utlUpdateMoveTIUndo(moveController, app.myPassport);
			delete moveController;
		endif;
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		if vWLE &lt;&gt; null and not invalidWLE then
			vWLE.setNewLocationTarget( _groundLC );
			vWLE.setStatus(WLE_COMPLETED);
		endif;
		//15 Jun 2012	NDL	Par 29745 - Apparently we don't want to keep the planned location either
		if _ti.isPlanned(PLANNING_MODE) then
		
			if _ti.isRehandle then	//27 Mar 2018	NDL	TFS 37569
				//Only unplan the discharge leg, not the load leg of DLRs
				futureMoveDis := _ti.getFutureMoveOfType( PLANNING_MODE, TI_FutureMoveDLRDischarge );
				if futureMoveDis &lt;&gt; null then
					fmIndex := _ti.allPlannedFutureMoves.indexOf(futureMoveDis);
					create moveController transient;
					moveController.setMoveMode(PLANNING_MODE);
					moveController.setMyTrackedItem(_ti);
					moveController.isFullyUnplan := true;
					moveController.setMoveIndex(fmIndex);
					if request &lt;&gt; null then
						if request.isKindOf(CM_SlotRequest) then
							moveController.mySlotRequest := request.CM_SlotRequest;
						elseif request.isKindOf(CM_VoyageRequest) then
							moveController.myVoyageRequest := request.CM_VoyageRequest;
						endif;
					endif;
					
					app.myUtilityUA.utlUpdateMoveTIUndo(moveController, app.myPassport);
					delete moveController;
				
				endif;
				
				futureMoveLoad := _ti.getFutureMoveOfType( PLANNING_MODE, TI_FutureMoveDLRLoad );
				
			else
				create moveController transient;
				if request &lt;&gt; null then
					if invalidWLE then
						moveController.setForCreateUnplan(_ti,null,request,false);
					else
						moveController.setForCreateUnplan(_ti,vWLE,request,false);
					endif;
				else
					moveController.setMoveMode(PLANNING_MODE);
					moveController.setMyTrackedItem(_ti);
				endif;
				
				app.myUtilityUA.utlUpdateMoveTIUndo(moveController, app.myPassport);
				delete moveController;
				
			endif;

			
		endif;
		
		//31 Aug 2012	NDL	Par 29961
		if lc &lt;&gt; null then
			ta := lc.myTerminalArea;
			if ta &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(ta, lc.myTerminal.getTerminalEvent(EVENT_TI_MOVE), lc);
			endif;
		endif;
		
	elseif _groundOption = GroundInTransit then  //(Line 128 prior to TFS 37569 change)
		//has to remain queued.. just the source will change.
		if vWLE &lt;&gt; null and not invalidWLE then
			rtQueueEntry := vWLE.allRTQueueEntries.first;
			if rtQueueEntry &lt;&gt; null and rtQueueEntry.status &lt;&gt; ENTRY_COMPLETE then
				rtQueueTask := rtQueueEntry.allTasks.first;
				if rtQueueTask &lt;&gt; null and rtQueueTask.status = TASK_UNACTIONED then
					rtQueueTask.setSourceLocation(_groundLC);
				endif;
			endif;
			vWLE.setLocations(_groundLC.getFullId,vWLE.locationTarget);
		endif;
		
	endif;
	
	if _wle &lt;&gt; null and not invalidWLE then	//14 Jun 2012	NDL	Par 29745
		foreach rtQueueEntry in  _wle.allRTQueueEntries do
			rtQueueEntry.sendNotesForRelatedEntry();
		endforeach;
		if _wle.allRTQueueEntries.size = 1 then
			rtQueueEntry := _wle.allRTQueueEntries.first;
			rtQueueEntry.causeEvent(rtQueueEntry.getMyTerminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
		endif;
	endif;
	
	//27 Mar 2018	NDL	TFS 37569
	if _groundOption = GroundComplete and futureMoveLoad &lt;&gt; null then
		// This is a DLR, we have completed the discharge under the crane killed off the discharge WLE, now queue the load side
		if app.myPassport.hasErrors then
			return;
		endif;
		on Exception do app.handleDeletedObject( exception, futureMoveLoad, invalidFM );
		fmIndex := _ti.allPlannedFutureMoves.indexOf(futureMoveLoad);
		vWLE := futureMoveLoad.myWorkListEntry.CM_VoyageWLE;
		if vWLE &lt;&gt; null and not invalidFM then
			edition := vWLE.edition;
			if invalidWLE then
				vWLE := null;
			endif;
			if vWLE &lt;&gt; null and vWLE.allRTQueueEntries.isEmpty then
				vWLE.setLocations(_groundLC.getFullId,vWLE.locationTarget);
				create moveController transient;
				moveController.setMoveMode(QUEUE_MODE);
				moveController.setMyTrackedItem(_ti);
				moveController.setMyWorkListEntry(vWLE);
				moveController.setMyToPrimaryLocation( futureMoveLoad.getPrimaryLocation );
				moveController.setMoveIndex(fmIndex);
				
				app.myUtilityUA.utlUpdateMoveTrackedItem( moveController, app.myPassport );
				delete moveController;
				
			endif;
		endif;
	endif;
	
	
epilog
	delete moveController;
	delete rtQueueEntryArray;	
end;</source>
        <Parameter name="_groundOption" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_groundLC" type="CM_LocationsController" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLayoutGraphic" id="345b59d8-f99b-4816-9c1a-833e6579120c">
        <source>utlUpdateLayoutGraphic(pProxyLayoutGraphic : CM_LayoutGraphic input;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realLayoutGraphic : CM_LayoutGraphic;
	expectedEdition : Integer;
begin
	self.initialiseActivity();
	pProxyLayoutGraphic.raiseExceptionIfNotProxy(method);
	pProxyLayoutGraphic.pxyGetRealObjectAndEdition(realLayoutGraphic, expectedEdition);
	if realLayoutGraphic = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LayoutGraphic.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valLayoutGraphic(pProxyLayoutGraphic, realLayoutGraphic); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(realLayoutGraphic);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; realLayoutGraphic.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'LayoutGraphic Track', null, null);
			return;
		endif;
	endif;
	if _passport.noErrors then
		realLayoutGraphic.setForUpdate(pProxyLayoutGraphic);
	endif;
end;</source>
        <Parameter name="pProxyLayoutGraphic" type="CM_LayoutGraphic" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLayoutGraphicStretch" id="96e14068-5823-470f-8daa-7977bd0efeed">
        <source>utlUpdateLayoutGraphicStretch(_pxyGraphic : CM_VoyageLayoutGraphic input;	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
