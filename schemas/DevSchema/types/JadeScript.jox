    <JadeMethod name="eprConvertUTCtimetoTerminal" id="32009673-5056-4658-85d1-441191bafb94">
        <source>eprConvertUTCtimetoTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2023	jlier1	Initial creation

*/

vars
	dt,dt1  : TimeStamp;
	dtS,xmlString  : String;
	t : CM_Terminal;
	tzHelper :  CMIF_TimeZoneHelper;
	//timeZones : CMIF_TimeZoneInfoArray;
	timeZones : DynaDictionary;
	timeZone :  CMIF_TimeZoneInfo;
	 s ,e: Integer;
	 hours : Integer;
	 minutes : Integer;
begin
	
	t:="2351.39".asOid.CM_Terminal;
	write t.timeZoneID;
	dtS:="2023-03-16T01:20:00+10:00";
	//write dtS.conv;
	create tzHelper transient;
  dt :="2023-04-21T01:20:00+10:00".convertISO8601ToUTCTimeStamp;
  //write dt;
	//dt1:= tzHelper.convertTimeToUtc(dt, tzHelper.getSystemTimeZoneID);
	//write dt;
	//write dt.utcToLocalTimeUsingBias(600);
	
	
	//dt1 := tzHelper.convertTimeToUtc(dt, t.timeZoneID);
	create timeZones transient;
	timeZones.setMembership(CMIF_TimeZoneInfo);
	timeZones.addMemberKey(CMIF_TimeZoneInfo::id.name,false,false);
	timeZones.endKeys(false);
	
	 tzHelper.getSystemTimeZones(timeZones);
	
	 timeZone:= timeZones.getAtKey(t.timeZoneID).CMIF_TimeZoneInfo;
	
	write timeZone.display;
	s:= timeZone.display.pos("(UTC+", 1);
	hours:= timeZone.display[s+5:2].Integer;
	minutes :=timeZone.display[s+8:2].Integer;
	minutes:=minutes + (hours *60);
	write hours;
	write minutes;
	timeZones.purge();
	delete timeZones;
	
	delete tzHelper;

	delete tzHelper;
  write dt;
  write dt.addMinutes( minutes);

epilog
	delete tzHelper;
end;</source>
    </JadeMethod>
