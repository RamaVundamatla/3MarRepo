    <JadeMethod name="vp021_makeBayPlanActual" id="860b2227-bb42-408a-9869-d6ae0b1927f6">
        <updating/>
        <source>vp021_makeBayPlanActual() updating;

vars
	onShipTI	: CM_TrackedItem;
begin
	app.logMessage(method.qualifiedName);
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Make baplie actual');
	myEDIForm.doBayPlanMakeActual;
	app.myPassport.myActivityCapture.stopCaptureDebugMisc();

	beginTransaction;
	foreach onShipTI in self.myVoyage.allOnshipTIsByCargoTypeId do
		if onShipTI.dischargePort = app.getMyTerminalConfig(PortDestCode).String then
			onShipTI.setDestinationPort(onShipTI.dischargePort);
		endif;
	endforeach;
	commitTransaction;
	
	self.myEDIForm.unloadForm();
end;
</source>
    </JadeMethod>
