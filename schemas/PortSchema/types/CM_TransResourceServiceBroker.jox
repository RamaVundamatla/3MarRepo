    <JadeMethod name="healthCheckIsValid" id="30ac08fe-26a9-4d49-9508-4a30907be254">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date				Who			Reason
September 2017		CNWAB1		Initial creation
*/

vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
// TFS 40620	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet;// TFS 40620
	invLineDesc : CM_InvoiceLineDesc;
	paths : HugeStringArray;
	items : ObjectArray;
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;
	
	// ### CARGO  Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType) then
		resultType := CMIF_InvoiceHealthAgent.ResultType_TaskResource;
		invLineDescs := self.getAllMappedInvoiceLineTypes();
		
		foreach invLineDesc in invLineDescs do
			if  invLineDesc.myCalculationType &lt;&gt; null then
				if not invLineDesc.myCalculationType.isToDoTaskResource() then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,"Line Type: '" &amp; invLineDesc.narration &amp;  "'", CMIF_InvoiceHealthAgent.ItemType_TaskResource, self.getMyTerminal(), resultType, self);
				endif;
			endif;
		endforeach;
		return false;
	endif;
	return true;
epilog
	delete invLineDescs;
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
