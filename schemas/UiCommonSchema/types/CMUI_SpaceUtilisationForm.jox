    <JadeMethod name="positionQueryFrame" id="3c3d7c0d-cfd9-4c41-8382-d81d93a397fc">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;
	self.frmQuery.height	:=	320;
	self.frmQuery.width		:= 320;
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setQueryAgent" id="3e5f5c3c-3212-4dce-be4d-b5b580f465cf">
        <source>setQueryAgent();
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	chkIMEX, chkISO, chkCNTS, chkCT, chkOPS, chkTA, chkVOY, chkPORTS  : Boolean;
	aTA : CM_TerminalAreaMaster;
begin
	self.myQueryAgent.init();
	
	self.myQueryAgent.myTerminal := self.myTerminal;
	
	chkCT := not (self.lstCargoTypes.areAllRowsSelected(true) or self.lstCargoTypes.areAllRowsSelected(false)); // either all selected or all not selected
	chkOPS := not (self.lstOperators.areAllRowsSelected(true) or self.lstOperators.areAllRowsSelected(false)); // either all selected or all not selected
//	chkTA := not (self.lstTermArea.areAllRowsSelected(true) or self.lstTermArea.areAllRowsSelected(false)); // either all selected or all not selected
	chkTA := not self.lstTermArea.allSelectedObjects.isEmpty();
	chkVOY := not (self.lstVoyages.areAllRowsSelected(true) or self.lstVoyages.areAllRowsSelected(false)); // either all selected or all not selected
	chkPORTS := not (self.lstPorts.areAllRowsSelected(true) or self.lstPorts.areAllRowsSelected(false)); // either all selected or all not selected
	chkIMEX := not (self.lstImEx.areAllRowsSelected(true) or self.lstImEx.areAllRowsSelected(false)); // either all selected or all not selected
	chkISO := not (self.lstISO.areAllRowsSelected(true) or self.lstISO.areAllRowsSelected(false)); // either all selected or all not selected
	chkCNTS := not (self.lstContents.areAllRowsSelected(true) or self.lstContents.areAllRowsSelected(false)); // either all selected or all not selected
	
	self.myQueryAgent.setAgentsBooleans(chkCT, chkCNTS, 
				(self.chkHaz.value and self.isHazardousLicensed), 
				chkIMEX, 
				chkISO, chkOPS, chkPORTS, self.chkSpace.value, chkTA, chkVOY, self.chkYalloc.value);
	
	
	// ### ONLY COPY VALUE IF NEED TO
	// ### IF ALL SELECTED or NONE SELECTED then chkXX will be false, do not need to copy ALL
	if chkCT then 
		self.lstCargoTypes.allSelectedObjects.copy(self.myQueryAgent.allQryCargoTypes);
	endif;
	if chkCNTS then
		self.lstContents.allSelectedObjects.copy(self.myQueryAgent.allQryContents);
	endif;
	if chkISO then
		self.lstISO.allSelectedObjects.copy(self.myQueryAgent.allQryISOGroups);
	endif;
	if chkIMEX then
		self.lstImEx.allSelectedObjects.copy(self.myQueryAgent.allQryIMEX);
	endif;
	if chkOPS then
		self.lstOperators.allSelectedObjects.copy(self.myQueryAgent.allQryOperator);
	endif;
	if chkPORTS then
		self.lstPorts.allSelectedObjects.copy(self.myQueryAgent.allQryPorts);
	endif;
	if chkVOY then
		self.lstVoyages.allSelectedObjects.copy(self.myQueryAgent.allQryVoyages);
	endif;

	//22 Jun 2016	NDL	TFS 1752 - No longer register for these notes, they wont be accurate anyway because
	// they don't deal with merges and splits or descrepancies...
//	foreach aTA in self.myQueryAgent.allQryTerminalAreas discreteLock do
//		self.endNotification(aTA, self.myTerminal.getTerminalEvent(EVENT_KPIYARDMOVE));
	
//	endforeach;
	if chkTA then
		self.lstTermArea.allSelectedObjects.copy(self.myQueryAgent.allQryTerminalAreas);
	endif;
//	foreach aTA in self.myQueryAgent.allQryTerminalAreas discreteLock do
//		self.beginNotification(aTA, self.myTerminal.getTerminalEvent(EVENT_KPIYARDMOVE), Response_Continuous, null);
//	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="bc842984-7770-4bc9-8d84-c849f1d45559">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.fldMain.topSheet = self.shtYA then
		self.displayYATable();
	elseif self.fldMain.topSheet = self.shtHaz then
		self.displayHazTable();
	endif;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="051ef610-cd09-455a-87c3-13ac87a2ff47">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.isHazardousLicensed := true;

	self.usesQueryFrame := true;
	self.useTableInfo := true;
	self.useTableSorting := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmTBExtras.width := 550;
	self.cmbKPITA.width := 350;
	self.frmTBExtras.visible := true;
	
	inheritMethod();
	
	create self.myQueryAgent transient;
	create self.mySummaryLine transient;	//24 Oct 2013	NDL	Par 32079
/*	
	if self.mnuContextHide.caption = self.MNU_MACRO_HIDE then
		self.mnuContextHide.caption := "Hide";
		self.splMain.hideRightControl(true);
	endif;
	*/
	self.mnuContextHide.visible := false;
	
	if (not self.isHazardousLicensed) then
		self.shtHaz.visible := false;
		self.chkHaz.visible := false;
	endif;
	
	self.splMain.top := 0;
	self.doListBoxCargoBuild();
	self.doListBoxPortBuild();
	self.doListBoxOperatorBuild();
	self.doListBoxTermAreaBuild();
	self.doListBoxContentsBuild();
	self.doListBoxImExBuild();
	self.doListBoxISOBuild();
	self.doListBoxVoyageBuild();
	self.doComboTABuild();
	
	self.setNavigatorHeading(self.caption);
	
	self.initTableData(null);
	self.initTblSpaceDtl(null);
	self.initTiDataTable(ETDef_LlHeadings, self.tblHaz);
	self.initTiDataTable(ETDef_LlHeadings, self.tblYA);
	
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;

	self.doResetSearch();
	self.getXMLSettingsForSetup();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnSaveBase.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="a14bacff-7764-4979-b85d-60bfe1d68bb8">
