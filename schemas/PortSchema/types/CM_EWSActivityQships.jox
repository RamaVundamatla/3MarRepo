    <JadeMethod name="getDisplayStringForAttribute" id="53ee5682-7f31-40a7-b543-0b6f306db972">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


begin
	if _attrName = ETRow_ClientType then
		return self.clientType.asStringJMT;
	elseif _attrName = ETRow_DataType then 
		return self.dataType;
	elseif _attrName = ETRow_DomainName then 
		return self.domainName;
	elseif _attrName = ETRow_LastSuccessfullTS then
		return self.lastSuccessfullTS.asStringJMT;
	elseif _attrName = ETRow_ServiceVersion then 
		return self.serviceVersion;	
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseActivity" id="0c74559b-bc8e-460a-8fa6-e24e1bf6f3b6">
        <updating/>
        <source>initialiseActivity(_description: String; _interface: String; _terminal: CM_Terminal; _opsViewObject: CM_Object; _dataAction: Character; _dataType: String; _snapshot: Boolean; _oid: String) updating;
