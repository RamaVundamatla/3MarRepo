    <JadeMethod name="resetLists" id="ec57ded4-9762-4bd7-9f48-6e4438c3af5c">
        <source>resetLists(listbox : ListBox);

begin
//	write("reset lists ");
	self.setStatus(null, false);
	
	if listbox = null or listbox &lt;&gt; lstForms_change then
		lstForms_change.listCollection(aAllChangedForms, false, 0);
	endif;
	
	if listbox = null or listbox &lt;&gt; lstForms_included then
		lstForms_included.listCollection(aAllIncludedForms, false, 0);
	endif;
	
	if listbox = null or listbox &lt;&gt; lstForms_excluded then
		lstForms_excluded.listCollection(aAllExcludedForms, false, 0);
	endif;
	
	if listbox = null or listbox &lt;&gt; lstForms_new then
		lstForms_new.listCollection(aAllNewForms, false, 0);
	endif;
/*
	lbChangedForms.listIndex := CNEC_NULL_INDEX;
	lbIncluded.listIndex := CNEC_NULL_INDEX;
	lbExcluded.listIndex := CNEC_NULL_INDEX;
	lbNewForms.listIndex := CNEC_NULL_INDEX;
*/
	self.setButtons(listbox);
end;</source>
        <Parameter name="listbox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="resetStoredDetail" id="4611dfcb-8121-4189-b8ad-5d1d0ab2106f">
        <source>resetStoredDetail();

begin
	sheetMaintenance.enabled	:= true;
	sheetOptions.enabled		:= true;
	sheetProjects.enabled		:= true;
	sheetDetails.visible		:= false;
	btnGetForms.enabled			:= true;
	btnClose.enabled			:= true;
	lstForms_new.setFocus();
	self.resetLists(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveChanges" id="c1c0c973-8ed5-491a-a06f-7157ef55d1b5">
        <updating/>
        <source>saveChanges() : Boolean updating;

vars
	theObject	: Object;
	error		: String;
	ts			: TimeStamp;
	msg_return	: Integer;
	
begin
	msg_return := MsgBox_Return_No;

	if not chkTimeRecording.value and self.aMyHelp.usesTimeRecording then	// just turned off time recording
		if self.aMyHelp.allTimes.size() &gt; 0 then
			msg_return := app.msgBox(	"You have existing time records. Do you wish to delete these ?",
										"Delete Existing Times",
										MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		endif;
	endif;

	if msg_return = MsgBox_Return_Cancel then
		statusLine.caption := "Changes not saved";
		return false;
	endif;

	beginTransaction;
	self.aMyHelp.clearLists();
	self.aMyHelp.update(txtName.text,
						txtLastBuildDate.text.TimeStamp,
						lblOptions_schema.listObject.Schema,
						chkSubschemas.value,
						chkTimeRecording.value);

	if msg_return = MsgBox_Return_Yes then
		self.aMyHelp.clearTimes();
	endif;

	if chkTimeRecording.value and txtProjectName.text.trimBlanks.length &gt; 0 then
		error := self.aMyHelp.addTime(txtProjectName.text, ts, txtProjectEst.text.Real, txtProjectUsed.text.Real);
	endif;

	self.populateCnEcHelp();

	if error.length &gt; 0 then
		txtProjectName.setFocus();
	else
		foreach theObject in self.aAllIncludedForms do
			error := self.aMyHelp.addForm(theObject.Form, true);
		endforeach;
	endif;

	if error.length = 0 then
		foreach theObject in self.aAllExcludedForms do
			error := self.aMyHelp.addForm(theObject.Form, false);
		endforeach;	
	endif;

	if error.length = 0 then
		commitTransaction;
		self.populateProjects();
		statusLine.caption := "Saved";
		return true;
	else
		abortTransaction;
		app.msgBox(error, "Update Error", MsgBox_Exclamation_Mark_Icon);
		statusLine.caption := "Error";
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtons" id="dc7b469b-6b8f-4552-85a8-d22f2b884f8d">
        <source>setButtons(listbox : ListBox);

begin
	btnNewFormExclude.enabled := (listbox = lstForms_new) and (self.listboxHasSelected(listbox));
	btnNewFormInclude.enabled := (listbox = lstForms_new) and (listboxHasSelected(listbox));
	btnNewFormExclAll.enabled := (listbox = lstForms_new) and (listboxHasSelected(listbox));

	btnIncludedExclud.enabled := (listbox = lstForms_included) and (listboxHasSelected(listbox));
	btnIncludedRemove.enabled := (listbox = lstForms_included) and (listboxHasSelected(listbox));

	btnExcludedInclud.enabled := (listbox = lstForms_excluded) and (listboxHasSelected(listbox));
	btnExcludedRemove.enabled := (listbox = lstForms_excluded) and (listboxHasSelected(listbox));

	btnExtractForm.enabled := (listbox = lstForms_change or listbox = lstForms_included) and (listboxHasSelected(listbox));
	btnUpdateForm.enabled := (listbox = lstForms_change or listbox = lstForms_included) and (listboxHasSelected(listbox));

	if listbox &lt;&gt; lstForms_new then
		lstForms_new.listIndex := CNEC_NULL_INDEX;
	endif;
	
	if listbox &lt;&gt; lstForms_change then
		lstForms_change.listIndex := CNEC_NULL_INDEX;
	endif;
	
	if listbox &lt;&gt; lstForms_included then
		lstForms_included.listIndex := CNEC_NULL_INDEX;
	endif;
	
	if listbox &lt;&gt; lstForms_excluded then
		lstForms_excluded.listIndex := CNEC_NULL_INDEX;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="setCnEcHelp" id="ecd46bde-fc08-40b9-a496-fe71e19abdf3">
        <updating/>
        <source>setCnEcHelp(myCnEcHelp : CnEcHelp) updating;

vars
	dateBuilt	: String;
begin
	btnSaveChanges.enabled := false;

	btnGetForms.enabled := true;
	btnExtractForm.enabled := false;
	btnUpdateForm.enabled := false;
	sheetDetails.visible := false;
	sheetProjects.visible := false;
	txtDateModified.enabled := false;
	txtFormName.enabled := false;
	fraOutput.visible := false;

	self.aAllNewForms.clear();
	self.aAllChangedForms.clear();
	self.aAllIncludedForms.clear();
	self.aAllExcludedForms.clear();

	self.aMyHelp := myCnEcHelp;

	if aMyHelp = null then
		self.createCnEcHelp(self.aMyHelp);
	endif;

	txtName.text := self.aMyHelp.name;
	
	if aMyHelp.lastBuildDate &lt;&gt; null then
		txtLastBuildDate.text := self.aMyHelp.lastBuildDate.String;
	else
		txtLastBuildDate.text := "Not previously built";
	endif;

	if self.aMyHelp.myFormSchema &lt;&gt; null then
		lblOptions_schema.listIndex := lblOptions_schema.findObject(self.aMyHelp.myFormSchema);
	endif;
	
	chkSubschemas.value		:= self.aMyHelp.includeSubSchemas;
	chkTimeRecording.value	:= self.aMyHelp.usesTimeRecording;

	self.aMyHelp.allExcludedForms.copy(self.aAllExcludedForms);
	self.aMyHelp.allIncludedForms.copy(self.aAllIncludedForms);

	self.populateHelpLists();
	self.populateProjects();
	self.setButtons(null);
	self.setStatus("Ready", false);
end;</source>
        <Parameter name="myCnEcHelp" type="CnEcHelp"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="bc12bc95-7ca0-44ee-85df-ab2028c35a8c">
        <source>setStatus( message : String; immediate : Boolean );

begin
	statusLine.caption := message;
	
	if immediate then
		statusLine.refreshNow();
	endif;
end;</source>
        <Parameter name="message" type="String"/>
        <Parameter name="immediate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="signOn" id="82ec769e-9de2-48c5-8528-50e1b1ba59ba">
        <updating/>
        <source>signOn() updating;

begin
	fraPassword.visible	:= false;
	fraOptions.visible	:= true;
	btnGetForms.enabled	:= true;

	sheetMaintenance.visible := true;

	create aAllNewForms transient;
	create aAllChangedForms transient;

	self.populateSchemas();
	self.populateCnEcHelp();
	self.setCnEcHelp(aMyHelp);
end;</source>
    </JadeMethod>
