    <JadeMethod name="readChar" id="a3558ebd-980f-4df4-9091-28720f33d26c">
        <source>readChar(_file : File io):Character;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2020	jlgma1	Initial creation

*/

vars
	ch1,a :  Integer;
	ch2 : Integer;
	str1,
	str2 : String;
	byte1,
	byte2 : Byte;
	bin1,
	bin2	: Binary;
begin

	ch1 := _file.readBinary(1).Integer.leftBitShift(8);
	ch2 := _file.readBinary(1).Integer.leftBitShift(0);

	
	return (ch1 + ch2).Character;
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <ReturnType type="Character"/>
    </JadeMethod>
    <JadeMethod name="readFromFile" id="423ee719-1e18-490e-b1ff-fccb1e58860c">
        <updating/>
        <source>readFromFile()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2020	jlgma1	Initial creation

*/

vars
	nsdFile     : CMIF_NSDFile;
	nsdShipData : CMIF_NSDShipData;
	file        : File;
	nsd         : CMIF_NSDFile;
begin
	

	
	create file transient;
	file.kind	:=	File.Kind_Binary;
	file.openInput(self.path);
	
	self.readHeader(file);
	
	nsd := self;
	create nsdShipData transient;
	nsdShipData.readShipData(nsd,file);
epilog
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="readHeader" id="29f37045-4937-4810-9eb5-7c1ef1e81c14">
        <updating/>
        <source>readHeader(_file : File io)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2020	jlgma1	Initial creation

*/

vars

begin
	self.oldestVersion   := self.readSignedByte(_file,1).Integer;
	write "_file.currentOffset:" &amp; _file.currentOffset().String;
	self.shipFileVersion := self.readUnsignedByte(_file,1).Integer;
	write "_file.currentOffset:" &amp; _file.currentOffset().String;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="readShort" id="5e65c209-ac18-4698-b43b-239e86d719c5">
        <source>readShort(_file : File io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

