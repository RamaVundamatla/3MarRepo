	tmpSrcSubSubLocation := self.myCmbSubSubSrc.listObject.CM_SourceSubSubLocation;
	if tmpSrcSubSubLocation = null then
		return null;
	endif;
	
	return tmpSrcSubSubLocation.code;

end;</source>
