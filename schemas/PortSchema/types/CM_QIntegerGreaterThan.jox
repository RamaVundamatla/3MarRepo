    <JadeMethod name="doMatch" id="982b8301-0c21-4e00-90a3-58025ab1126a">
        <source>doMatch(_value: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return _value &gt; searchValue;

end;</source>
