    <JadeMethod name="handleNotificationRefreshView" id="4606d722-f41b-47b4-b722-c087535278d6">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin
	if self.myAssistant &lt;&gt; null then
		self.myHarbour := self.myAssistant.HMS_Assistant.myHarbour;
	else
		self.myHarbour := null;
	endif;
end;</source>
