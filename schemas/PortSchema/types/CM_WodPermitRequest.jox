    <JadeMethod name="canCreateResources" id="b0e983e0-081a-40b2-82de-6c717598943d">
        <source>canCreateResources(_voyageStatus: CM_VoyageStatus output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2018	jlger1	Initial creation 41310

*/

vars
	allTis : CM_TISet;
begin
	create allTis transient;
	self.myParent.getAllTIs(allTis);
	if allTis.size &gt; 0 then
		return false;
	endif;

	if self.myParent.taskStatus &lt; WO_STATUS_APPROVED then
		return false;
	endif;
	
	return true;

epilog

end;</source>
