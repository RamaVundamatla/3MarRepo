    <JadeMethod name="initialiseMenu" id="37312708-d2d0-4f86-a2da-f4e832397ae2">
        <updating/>
        <source>initialiseMenu(	_root : CM_Root; _menuItem : CM_MenuItem) updating;

// specialised initialise() method for XLAT_Menu, so menuNumber and menuType can get set

vars
	catName		: String;
	theHeading	: String;
	category	: XLAT_Category;
	constant	: GlobalConstant;
	constText	: String;
begin

	category := _root.allXLAT_Categories[XLAT_Menus];
	
	if _menuItem.isKindOf(CM_MenuDtl) then
		self.menuType := MenuType_Detail;
	elseif _menuItem.isKindOf(CM_MenuHdrSystem) then
		// need to determine if system or terminal
		if _menuItem.isOnNavTerminalMenu then
			self.menuType := self.MenuType_TerminalHdr;
		elseif _menuItem.isOnNavSystemMenu then
			self.menuType := self.MenuType_SystemHdr;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Menu item (' &amp; _menuItem.String &amp; ')not on sys or terminal');
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name,
				'Unhandled menuItem class (' &amp; _menuItem.String &amp; ')');
		return;
	endif;
	
	// set self.number so that call in initialise not made to getUniqueNumber
	self.number := _menuItem.getMenuTranslationNumber();
	
	initialise(category, constant, XLAT_Menus, _menuItem.heading, null);
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_menuItem" type="CM_MenuItem"/>
    </JadeMethod>
</Class>
