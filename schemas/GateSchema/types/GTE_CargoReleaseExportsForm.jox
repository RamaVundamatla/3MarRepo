    <JadeMethod name="initFilterTable" id="2a4131a0-2923-4f8b-92d5-af19f140e7f1">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	assistant		: GTE_Assistant;
	
begin

	theTable := self.tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoReleaseExportFind);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

		assistant := self.myAssistant.GTE_Assistant;
//		assistant.comboBoxOperator(cmbFiltOperator, null, null);
//		self.cmbFiltOperator.setObject(null); will initialise on got focus
		assistant.comboBoxVoyageCurrent(cmbFiltVoyage,
										app.getMyCurrentVoyage(),  //cnwjo3 par 23105 //app.myCurrentVoyage,
										true,
										false,
										true,
										true,
										true,
										true,
										true,
										false,
										false);
		assistant.comboBoxYesNoAll(theTable, ETRow_FilterCEDOSet);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef CargoReleaseExportFind not found');
	endif;

	theTable.setValueByName(ETRow_ReceivedDateFrom, null);
	theTable.setValueByName(ETRow_ReceivedDateTo, null);
	
	self.cmbFiltVoyage.lostFocus(cmbFiltVoyage);
	self.myFilterVoyage := cmbFiltVoyage.listObject.CM_Voyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="7839ed03-525a-4e06-94e9-e320863c805e">
        <updating/>
        <source>initForm() updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	parent,
	navObj	: CMUI_NavigatorObject;
	theType	: String;

begin

	self.allowAdd := false;
	self.allowDelete := false;
	self.allowPrint  	:= true;
	self.allowExportCSV	:= true;
	self.useNumRowsShown	:= true;

	self.initMainTable();

	self.setNavigatorHeading('Exports');
	
end;</source>
