    <JadeMethod name="utlCreateReeferWalkPath" id="31f3a1eb-0cdb-4550-9217-ea138c9200a4">
        <updating/>
        <source>utlCreateReeferWalkPath( 	_pxyReeferBlock : CM_ReeferBlock;
							_reeferWalkPositionArray : CM_ReeferBlockPositionArray;
							_realReeferBlock : CM_ReeferBlock output;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	ta : CM_TerminalArea;
	trxUpdAA : CM_UpdateTransactionAuditAgent;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	app.myValCA.valReeferWalkPath( _pxyReeferBlock );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	ta := _pxyReeferBlock.myTerminalArea;
	exclusiveLock(ta);
	
	create trxUpdAA transient;
	if _passport.noErrors then
		trxUpdAA.audUpdateGeneric( ta, true );
	endif;
	
	create _realReeferBlock persistent;
	_realReeferBlock.setForCreate( _pxyReeferBlock, _reeferWalkPositionArray );
	
	if _passport.noErrors then
		trxUpdAA.audUpdateGeneric( ta, false );
	endif;

epilog

	delete trxUpdAA;

end;</source>
        <Parameter name="_pxyReeferBlock" type="CM_ReeferBlock"/>
        <Parameter name="_reeferWalkPositionArray" type="CM_ReeferBlockPositionArray"/>
        <Parameter name="_realReeferBlock" type="CM_ReeferBlock" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
