    </JadeMethod>
    <JadeMethod name="doSave" id="afc110a7-203f-4d4d-aa41-9964124bfb86">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj		: CM_Error;
	idx			: Integer;
	tmpListBox	: ListBox;
	ignoreWarnings,
	rtnValue,
	isNotAvailableForEntry	: Boolean;
	isAvailableForLabourRestrict,
	isExternal	: Boolean;
	orgName		: String;
	logo		: Binary;
	daDict		: CM_DataAccessControllerSet;
	theForm : SOP_TableMaintForm;
	lDebtor : CM_Debtor;
	changeOrganisationClass : Boolean;
	lEmailAddresses : CM_EmailAddressByAddressDict;	//07 Jul 2015	NDL	Par 36588
begin
	theForm := self.myForm; 

	lDebtor := theForm.cmbDebtor.myObject.CM_Debtor;
	orgName					:= theForm.tblInput1.getValueByName(ETRow_Name).String;
	isExternal				:= theForm.tblInput1.getValueByName(ETRow_IsExternal).Boolean;
	logo					:= theForm.tblInput1.getPictureByName(ETRow_Logo);
	isNotAvailableForEntry	:= theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	isAvailableForLabourRestrict := theForm.tblInput1.getValueByName(ETRow_AvailForLabourRestrict).Boolean;
	
	create daDict transient;
	
	if theForm.cmbDACarrier.myObject &lt;&gt; null then
		daDict.add(theForm.cmbDACarrier.myObject.CM_DataAccessController);
	endif;
	if theForm.cmbDAConsignee.myObject &lt;&gt; null then
		daDict.add(theForm.cmbDAConsignee.myObject.CM_DataAccessController);
	endif;
	if theForm.cmbDAOperator.myObject &lt;&gt; null then
		daDict.add(theForm.cmbDAOperator.myObject.CM_DataAccessController);
	endif;
	if theForm.cmbDAOrg.myObject &lt;&gt; null then
		daDict.add(theForm.cmbDAOrg.myObject.CM_DataAccessController);
	endif;
	// TFS 525 04/2016 customs agent data access
	if theForm.cmbDAAgent.myObject &lt;&gt; null then
		daDict.add(theForm.cmbDAAgent.myObject.CM_DataAccessController);
	endif;
	
	//07 Jul 2015	NDL	Par 36588
	create lEmailAddresses transient;
	theForm.mulSelect2.getSelected(lEmailAddresses);

	if theForm.mode = theForm.Mode_Add then
		if isExternal then
			app.myTrxCA.trxCreateExternalOrganisation(orgName, logo, daDict, theForm.myCurrentObject, isNotAvailableForEntry,isAvailableForLabourRestrict, lEmailAddresses, app.myPassport);
		else
			app.myTrxCA.trxCreateInternalOrganisation(orgName, logo, daDict, theForm.myCurrentObject, isNotAvailableForEntry,isAvailableForLabourRestrict, lEmailAddresses, app.myPassport);
		endif;
	elseif theForm.mode = theForm.Mode_Update then
		//par 15269 currently when editing there is no way to change from internal to external
		//checking if this is changing
		changeOrganisationClass:=theForm.myCurrentObject.CM_Organisation.isExternal &lt;&gt; isExternal;
		
		//hmmmm trxUpdateExternalOrganisation and trxUpdateInternalOrganisation do exactly the same thing so merged those methods into trxUpdateOrganisation
		if not changeOrganisationClass then
			app.myTrxUA.trxUpdateOrganisation(theForm.myCurrentObject.CM_Organisation, 
												theForm.objectEdition, logo, daDict, isNotAvailableForEntry, isAvailableForLabourRestrict, lDebtor, lEmailAddresses, app.myPassport);
		else
			
			app.myTrxUA.trxUpdateOrganisationType(theForm.myCurrentObject.CM_Organisation, 
												theForm.objectEdition, logo, daDict, isNotAvailableForEntry, isAvailableForLabourRestrict, lDebtor, lEmailAddresses, app.myPassport);
		endif;
		
	endif;

epilog
	if daDict &lt;&gt; null then
		delete daDict;
	endif;
	delete lEmailAddresses;
	return app.myPassport.noErrors;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
