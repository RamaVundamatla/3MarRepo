<Class name="WS_RestIntTodoJob" id="0a09effe-0664-44db-8394-983ebd44fd1a">
    <superclass name="WS_RestIntJob"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="commodity" id="53cd7fc0-bfec-4e9d-bff2-3c787df61ab6">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="operator" id="c058df39-5f90-47d8-a99e-af26a1554af6">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="taskType" id="8820a1fd-ba34-443c-8ab1-60426575adb8">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="terminalArea" id="cab1c152-c6b2-48ad-a2d0-5d9c93a071c0">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="todoTaskCode" id="550f2322-e82f-4e65-9671-cfcd78c04a2b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="todoTaskDesc" id="0f33608e-fd8a-489f-ad19-3cceacd7db60">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="todoTaskDescUid" id="24ce1e66-b43b-4d11-89a4-6155003aa34e">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="f71fb759-fcda-4f11-9e37-46c2faa2a420">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023 navhl20 ChangeRequest 60649:[60650] EUP | Mobile DD - [53891.070] - VAS Jobs
18 Oct 2023 navma1	ChangeRequest 58762: EUP | VAS Mobile App - [53813.080] [BackEnd] VAS Remarks notification
06 Nov 2023 navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
21 Nov 2023 navma1	ChangeRequest 58761: EUP | VAS Mobile App - [53813.060] VAS Resource Groups
*/

vars
	wod 	   	: CM_WorkOrderDtl;
	remarksStr 	: String;
	toDoTask    : CM_ToDoTaskDesc;
begin
	inheritMethod(_object);
	if _object.isKindOf(CM_WOToDoTaskJob) then
		
		if _object.CM_Job.myWODtl &lt;&gt; null then										//18.10.2023 navma1 #58762
			wod 		:= _object.CM_Job.myWODtl;
		elseif _object.CM_Job.myWorkOrderDtlToDo &lt;&gt; null then
			wod 		:= _object.CM_Job.myWorkOrderDtlToDo;
		endif;
		
		if wod &lt;&gt; null then
			remarksStr := wod.getRemarks();
			self.requiredDate := wod.requiredByDT.asStringJMT;						//06.11.2023 navhl20 #58756[60740]
		endif;
		
		toDoTask := _object.CM_WOToDoTaskJob.myToDoTaskDesc;						//21.11.2023 navma1 #58761
		
		if toDoTask &lt;&gt; null then													//21.11.2023 navma1 #58761
			self.todoTaskCode		:= toDoTask.code;
			self.todoTaskDesc		:= toDoTask.description;
			self.todoTaskDescUid	:= toDoTask.getOidAsString();
		endif;
		
		self.taskType 			:= _object.CM_WOToDoTaskJob.getToDoTaskType();
		self.remarks			:= remarksStr;										//18.10.2023 navma1 #58762
		self.commodity			:= _object.CM_WOToDoTaskJob.getWSCommodity();		//10.11.2023 navhl20 #58756[60740]
		self.operator			:= _object.CM_WOToDoTaskJob.getWSOperator();		//10.11.2023 navhl20 #58756[60740]
		self.terminalArea		:= _object.CM_WOToDoTaskJob.getWSTerminalArea();	//10.11.2023 navhl20 #58756[60740]
	
	endif;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
