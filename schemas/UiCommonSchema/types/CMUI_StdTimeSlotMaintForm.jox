    <JadeMethod name="clearProxyDetails" id="236fede5-da41-4023-a29d-4b35b1575d80">
        <updating/>
        <source>clearProxyDetails(_timeSlot : CM_TimeSlotEntity io) updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if global.isValidObject(_timeSlot) then //no overhead for transient
		_timeSlot.CM_TimeSlotEntity.erase(NORMAL_ERASE);
		_timeSlot := null;
	else
		_timeSlot := null;
	endif;
end;</source>
        <Parameter name="_timeSlot" type="CM_TimeSlotEntity" usage="io"/>
    </JadeMethod>
