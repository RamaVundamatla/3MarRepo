    <JadeMethod name="isCommodity_Match" id="3b2510be-b049-4844-9b58-6f51c813d04e">
        <source>isCommodity_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/

vars

	str			: String;

begin

	str := self.myLocationEvent.commodity.trimBlanks();
	
	// Only priorities will be empty.
	if str &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isCommodity_Compare, str);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
