    <JadeMethod name="deleteConsigneeConsignor" id="0992a8d7-b825-4969-952f-e35f9c103508">
        <source>deleteConsigneeConsignor( _consignoreeStr : String );

/*
Date				Who		Reason
23 February 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
*/
	
vars
	consigneeConsignor		: CM_ConsigneeConsignor;
	camGroup				: CM_CamGroup;
	bookingRef				: CM_BookingRef;
	
begin
	consigneeConsignor	:= app.myRoot.allConsigneeConsignors[ _consignoreeStr ];
	if consigneeConsignor = null then
		return;
	endif;
	
	// 11/06/2013 cnwmh5 - Remove from CAM Group
	beginTransaction;
	foreach camGroup in consigneeConsignor.allCamGroupsForFF do
		camGroup.allFreightForwarders.remove(consigneeConsignor);	
	endforeach;	
	commitTransaction;
	
	// 11/06/2013 cnwmh5
	beginTransaction;
	foreach bookingRef in consigneeConsignor.allBookingRefsByRef do
		bookingRef.setPropertyValue("myConsignee", null);
		bookingRef.setPropertyValue("myConsignee", null);
		bookingRef.setPropertyValue("myFreightForwarder", null);
	endforeach;
	commitTransaction;
	
	app.myTrxDA.trxDeleteConsigneeConsignor( consigneeConsignor, app.myPassport );
	self.assertTrueMsg( app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString() );
	
epilog
	
end;
</source>
        <Parameter name="_consignoreeStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteContainer" id="40950214-d231-4d44-9f0d-020f44ed301e">
        <source>deleteContainer(_id: String) ;
//29 August 2008	cnwdw1	
//
vars
	ti		: CM_TrackedItem;	
begin
	while true do
		  // 13/05/2011 cnwmh5
		ti := self.getTrackedItemByCargoType(_id, 1);    
		if ti = null then
			break;
		endif;
		self.deleteTrackedItem(ti, false); // AKB added false
	endwhile;
end;
</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteContainerOnVoyage" id="d5ed7b87-7d9f-4345-b0dc-2b2345fe3757">
        <source>deleteContainerOnVoyage(_id: String; _voyageCode : String) ;
//29 August 2008	cnwdw1	
//
vars
	ti, pxyTI: CM_TrackedItem;	
	root: CM_Root;
	oid: String;
begin
	root := CM_Root.firstInstance;
	ti := self.getTerminal.lookupTrackedItem(_id, TI_CargoType_Container, TI_STATE_ONSHIP, _voyageCode, false);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false); // AKB added false
	endif;
end;
</source>
