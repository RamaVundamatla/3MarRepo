    <JadeMethod name="init" id="31748e74-e4de-465d-97a6-85b49bcb4e99">
        <updating/>
        <source>init( _tiList : CM_StringDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2010	cnwrd1	Initial creation

*/

vars

begin
	self.allTrackedItems := _tiList;
epilog

end;</source>
        <Parameter name="_tiList" type="CM_StringDict"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="d454bd9d-0580-4d14-b926-ff39ecde8e4c">
        <source>populateTable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2010	cnwrd1	Initial creation

*/

vars
	strObj 		: CM_String;
	checkResult : String;
	theTI 		: CM_TrackedItem;
	result 		: Boolean;
	thePin		: String;
begin
	
	
	foreach strObj in self.allTrackedItems do
		 //self.tbCargo.addItem( strObj.myObject.CM_TrackedItem.id &amp; Tab);
		theTI := strObj.myObject.CM_TrackedItem;
		thePin := strObj.string;
		 
		result := self.checkPin( theTI, thePin);
		if result then
			checkResult := self.pass;
		else
			checkResult := self.fail;
		endif;
			
		self.tbCargo.accessRow(self.tbCargo.addItem(strObj.myObject.CM_TrackedItem.id &amp; Tab &amp; strObj.string &amp; Tab &amp; checkResult )).itemObject := strObj;
	endforeach;
	 

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e115f99d-a316-482f-8705-3fa7a8bc0f56">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2010	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod();
	self.pass := app.getErrorString(PassString);
	self.fail := app.getErrorString(FailString);
	
	self.setupTable();
	self.populateTable();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="fd4d265e-515e-406c-b919-721554bb8223">
        <source>setupTable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2010	cnwrd1	Initial creation

*/

vars

begin

	//switch to traslatable strings
	
	//self.tbCargo.columns := 3;
	//self.tbCargo.fixedRows := 1;
	
	self.tbCargo.accessCell(1,1).text :=  app.getErrorString(Cargo_ID);
	self.tbCargo.accessCell(1,2).text :=  app.getErrorString(Pin_no);
	self.tbCargo.accessCell(1,3).text :=  app.getErrorString(CheckString);
	self.tbCargo.multiSelect := self.tbCargo.MultiSelect_None;

	self.tbCargo.userInputEnabled := true;
	
	self.tbCargo.accessColumn( 2 ).JadeTableColumn.inputType := Table.InputType_TextBox;
	self.tbCargo.accessColumn( 2 ).JadeTableColumn.maxLength := 20;
	//self.tbCargo.resizeColumn
epilog

end;</source>
    </JadeMethod>
