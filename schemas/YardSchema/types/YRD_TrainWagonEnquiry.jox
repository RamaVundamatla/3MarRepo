        <Parameter name="_menuType" type="String" usage="input"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="getPositionDataFromText" id="e6819e11-0124-4de4-aac9-cf9fb31d204f">
        <source>getPositionDataFromText(_integerArray : IntegerArray io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwndl1	Initial creation

*/
constants

	Hyphen : String = "-";
	Comma : String = ",";
	
vars

	workText : String;
	pos : Integer;
	char : Character;
	intString : String;
	hyphenStartValue : Integer;
	hyphenInUse : Boolean;
	workArray : IntegerArray;
	int : Integer;
	
begin

	workText := txtWagonRange.text.trimBlanks;
	//replace all chars that are not integers, hyphens or commas so that we end up with 
	// integer values separated by either a single comma or a single hyphen.
	foreach pos in 1 to workText.length do
		char := workText[pos];
		if char.isNumeric then
			intString := intString &amp; char;
		elseif char = Hyphen then
			if intString[intString.length] = Hyphen then
				continue;
			else
				intString := intString &amp; char;
			endif;
		else
			if intString[intString.length] = Comma then
				continue;
			else
				intString := intString &amp; Comma;
			endif;
		endif;
	endforeach;
	
	//Work through the text getting individual values and expanding out sequences of values.
	//  I.e 1,2,3,4,5,8    would give the same result as 1-5,8
	workText := intString;
	intString := null;
	create workArray transient;
	foreach pos in 1 to workText.length do
		char := workText[pos];
		if char = Comma then
			if not hyphenInUse then
				workArray.add(intString.Integer);
			else
				foreach int in hyphenStartValue + 1 to intString.Integer do
					workArray.add(int);
				endforeach;
			endif;
			hyphenInUse := false;
			hyphenStartValue := null;
			intString := null;
		elseif char = Hyphen then
			workArray.add(intString.Integer);
			hyphenStartValue := intString.Integer;
			hyphenInUse := true;
			intString := null;
		else
			intString := intString &amp; char;
			if pos = workText.length then // last value
				if not hyphenInUse then
					workArray.add(intString.Integer);
				else
					foreach int in hyphenStartValue + 1 to intString.Integer do
						workArray.add(int);
					endforeach;
				endif;
			endif;
		endif;
	endforeach;
	
	foreach int in workArray do
		if int &lt; 1 then
			continue;
		endif;
		if not _integerArray.includes(int) then
			_integerArray.add(int);
		endif;
	endforeach;
	
epilog

	delete workArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_integerArray" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getQueryCaption" id="ae9a040e-effa-487d-bb21-26480f5bb078">
        <source>getQueryCaption() : String;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	Break = " | ";
vars
	tmpCaption, tmpCode, subCaption  : String;	
	arrTS, depTS : TimeStamp;
	tmpPort : CM_Port;
	tmpTrain : CM_Train;
	wagonClass : CM_WagonClass;
begin
	// ### TRAIN
	tmpTrain := self.cmbTrain.listObject.CM_Train;
	if tmpTrain &lt;&gt; null then
		subCaption := app.getErrorString(Train) &amp; " " &amp; tmpTrain.code;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	
	// ### CODE
	tmpCode := self.txtCode.text.trimBlanks();
	if tmpCode &lt;&gt; null then
		subCaption := app.getErrorString(Code) &amp; " '" &amp; tmpCode &amp; "'";
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	// ### ORIGIN
	tmpPort := self.cmbOrigin.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		subCaption := app.getErrorString(Origin_port) &amp; " " &amp; tmpPort.code;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;

	// ### DESTINATION
	tmpPort := self.cmbDestination.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		subCaption := app.getErrorString(Destination) &amp; " " &amp; tmpPort.code;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	// ### WAGON CLASS	06 Aug 2009	NDL	
	wagonClass := self.cmbWagonClass.listObject.CM_WagonClass;
	if wagonClass &lt;&gt; null then
		subCaption := app.getErrorString(Wagon_class) &amp; " " &amp; wagonClass.code;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	return tmpCaption;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonsFromPositions" id="1004c44d-a2a1-4ff6-86d9-8a539e76fa18">
        <source>getWagonsFromPositions( _integerArray : IntegerArray; _wagonSet : CM_WagonSet io; _errString : String output ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwndl1	Initial creation

*/

vars

	train : CM_Train;
	size : Integer;
	int : Integer;
	wagon : CM_Wagon;
	
begin

	train := self.myCurrentTrain;
	if train = null then
		return;
	endif;
	
	size := train.allWagonsByOrderInward.size;
	foreach int in _integerArray do
		if int &lt;= size then 
			wagon := train.allWagonsByOrderInward[int];
		else
			wagon := null;
		endif;
		if wagon = null then
			if _errString = null then
				_errString := int.String;
			else
				_errString := _errString &amp; ", " &amp; int.String;
			endif;
		else
			if not _wagonSet.includes(wagon) then
				_wagonSet.add(wagon);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_integerArray" type="IntegerArray"/>
        <Parameter name="_wagonSet" type="CM_WagonSet" usage="io"/>
        <Parameter name="_errString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="1212ad87-02f1-4ecc-9638-622614e3a829">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------  ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
19/02/2010	cnwdad1		Changed to also handle a Train object being deleted.
01/08/2023	jlizm1		TFS 59215 Wagon maintenance notifications
*/
vars
	dataLine	: String;
	wagonObj	: CM_Wagon;
	trainObj	: CM_Train;
	isRefresh	: Boolean;
	
begin
	isRefresh	:=	false;
	
	if eventTag = self.NOTE_EVENT_TAG_WAGON then
		wagonObj := theObject.CM_Wagon;
		
		//handle getting a wagon note
		if eventType = self.myTerminal.getTerminalEvent(Wagon_Create_Event) then
			if self.includeObject(wagonObj) then
				dataLine := wagonObj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessRow(self.tblData.addItem(dataLine)).itemObject := wagonObj;
				self.doNotableAdd(wagonObj);
			endif;
		elseif eventType = Object_Update_Event  then
			if self.includeObject(wagonObj) then
				dataLine := wagonObj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.removeItemObject(wagonObj);
				self.tblData.accessRow(self.tblData.addItem(dataLine)).itemObject := wagonObj;
			endif;
		elseif eventType = Object_Delete_Event then
			self.tblData.removeItemObject(wagonObj);
			self.doNotableRemove(wagonObj);
		endif;
	elseif eventTag = self.NOTE_EVENT_TAG_TRAIN then
		if eventType = Object_Delete_Event then
			trainObj	:=	theObject.CM_Train;
			
			if cmbTrain.listObject = trainObj then
				isRefresh	:=	true;
			endif;
			
			self.cmbTrain.removeObject(trainObj);
			self.myCurrentTrain	:=	null;
			self.allWagons.clear();
			
			if isRefresh then
				self.doRefresh();
			endif;
		endif;
	endif;
epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="9808821a-0d83-4f0a-97c6-c5f04aa705dc">
        <source>includeObject(_wagon : CM_Wagon) : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//04 Nov 2020 		cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
//07 Oct 2024 		navsp1			JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens
// ---------------------------------------------------------------------------

vars
	tmpCode    : String;
	originPort : CM_Port;
	destPort   : CM_Port;
	listObj	   : CM_Port;
begin
	if self.myCurrentTrain &lt;&gt; null then
		if self.optDirIn.value then
			if self.myCurrentTrain &lt;&gt; _wagon.myTrainInwards then
				return false;
			endif;
		else
			if self.myCurrentTrain &lt;&gt; _wagon.myTrainOutwards then
				return false;
			endif;
		endif;
	endif;
	if _wagon.getTerminal() &lt;&gt; self.myTerminal then
		return false;
	endif;
	
	tmpCode := self.txtCode.text.trimBlanks().toUpper();
	self.txtCode.text := tmpCode;
	if tmpCode &lt;&gt; null then
		if _wagon.id[1:tmpCode.length()] &lt;&gt; tmpCode then
			return false;
		endif;
	endif;
	
	listObj := self.cmbOrigin.listObject.CM_Port;
	if listObj &lt;&gt; null then
		//12/08/2010 cnwdz2 25396
		originPort := _wagon.myOriginPort;
		if originPort &lt;&gt; null then
			if originPort &lt;&gt; listObj then
				return false;
			endif;
		else
			if self.optDirIn.value then
				if _wagon.myTrainInwards &lt;&gt; null and _wagon.myTrainInwards.myOriginPort &lt;&gt; listObj then
					return false;
				endif;
			else
				if _wagon.myTrainOutwards &lt;&gt; null and _wagon.myTrainOutwards.myOriginPort &lt;&gt; listObj then //13/08/2010 cnwdz2 25429 25430
					return false;
				endif;
			endif;
		endif;
	endif;
	
	listObj := self.cmbDestination.listObject.CM_Port;
	if listObj &lt;&gt; null then
		//11/08/2010 cnwdz2 25317
		destPort := _wagon.myDestinationPort;
		if destPort &lt;&gt; null then
			if destPort &lt;&gt; listObj then
				return false;
			endif;
		else
			if self.optDirIn.value then
				if _wagon.myTrainInwards &lt;&gt; null and _wagon.myTrainInwards.myDestinationPort &lt;&gt; listObj then
					return false;
				endif;
			else
				if _wagon.myTrainOutwards &lt;&gt; null and _wagon.myTrainOutwards.myDestinationPort &lt;&gt; listObj then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	//06 Aug 2009	NDL	
	if self.cmbWagonClass.listObject &lt;&gt; null then
		if _wagon.myWagonClass &lt;&gt; self.cmbWagonClass.listObject then
			return false;
		endif;
	endif;
	
	if self.cmbStevedore.listObject &lt;&gt; null then                             //02.10.2020 cnwma1 TFS #50112
		if ( _wagon.myStevedoreReceive &lt;&gt; self.cmbStevedore.listObject and
		     _wagon.myStevedoreRelease &lt;&gt; self.cmbStevedore.listObject ) then
			return false;
		endif;
	endif;
	
	if self.txtClientRef.text &lt;&gt; null then									//JIRA 20762
		if _wagon.getClientRef(self.txtClientRef.text, true) = null then	//JIRA 20762
			return false;													//JIRA 20762
		endif;																//JIRA 20762
	endif;																	//JIRA 20762
	
	return true;
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="1392f93e-bde9-41f0-8339-79bd3752933d">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 07 Oct 2024		navsp1 			JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens
constants
