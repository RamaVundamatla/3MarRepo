    <JadeMethod name="tRORODeckPlan2" id="8f82a40c-90ea-4ea6-bdbf-5b6ba8ae10e7">
        <source>tRORODeckPlan2();
// cnwrs1 
// CCMS 1009 Plans Deck Extract Par 29024
//
constants
	UserDefinedShipManifest	= 'UT DeckPlan Child';
	ShipName = "JJRORO";
	VoyageName = "UT_EDIPLANS1009C";
	TestOperator = 'MSK';
	ContainerId1 = "OOTL0002914";
	ContainerId2 = "OOTL0002915";
	ContainerId3 = "OOTL0002916";
	ContainerId4 = "OOTL0002917";
	ContainerId5 = "OOTL0002918";
	ContainerId6 = "OOTL0002919";
	ContainerId7 = "OOTL0002920";
vars
	vessel : CM_Vessel;	 
	voyage : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	voyageDeck : CM_DeckVoyage;
	startLocn : CM_ROROLocnDefn; 
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	xmlBlock : String;
	ediFileType : CM_EDIFileType;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	parentTI : CM_TrackedItem;
	childTI : CM_TrackedItem;
	tempStr : String;
begin
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;

	self.deleteVoyage(VoyageName);
	self.assertNull(self.getVoyage(VoyageName));

////	self.deleteVessel(ShipName);
////	self.assertNull(self.getVessel(ShipName));
	operator := app.myRoot.allOperators[TestOperator];

//	vessel := self.addVesselConRORO(ShipName, operator);
	vessel := self.getVessel(ShipName);
	
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, null, 0, false, true);
	
	voyageCellularStructure := voyage.myCellularVoyageStructure;
	//check cellularStructure created/
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	// create file 01 edi user defined data to load
	ediText := 
'
V,A,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
L,D1158,S
P,D1158,1,  78.74,  -5.52,
P,D1158,2,  81.19,  -5.52,
P,D1158,3,  81.19,   0.61,
P,D1158,4,  78.74,   0.61,
P,D1158,5,  78.74,  -5.52,
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1158,1.1,,,'&amp;ContainerId1&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1158,1.1 1.2,,,'&amp;ContainerId2&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1158,5.1 7,,,'&amp;ContainerId3&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName;
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
/*	ediControllerAgent.setEdiClientRef(clientRef);

	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	// now check that the correct tarckeditems have been created
	parentTI := self.getTrackedItemOnVoy(ContainerId1, VoyageName);
	self.assertNotNullMsg(parentTI, 'No trackedItem');
*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
