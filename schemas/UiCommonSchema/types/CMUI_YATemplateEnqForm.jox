    <JadeMethod name="doOpenTemplateMaintForm" id="77617c73-3e28-47eb-be8f-82780820aaae">
        <updating/>
        <source>doOpenTemplateMaintForm() protected, updating;
//08 July 2008	cnwdw1	
//
vars
	theForm : CMUI_YATemplateMaintForm;
begin
	theForm := app.loadForm(CMUI_YATemplateMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_YATemplateMaintForm;
	
	if theForm = null then
		return;
	endif;

	//self.doEnable(false);
	theForm.setParentForm(self);
	if self.mode = Mode_Update then
//		theForm.setYATemplate(tblData.accessedRow.itemObject.CM_YATemplate);
		theForm.setYATemplate(myCurrentObject.CM_YATemplate);
	endif;
	
	theForm.showModal();
	
	self.mode := Mode_View;
end;</source>
        <access>protected</access>
