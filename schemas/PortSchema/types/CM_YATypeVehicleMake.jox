    <JadeMethod name="getDisplay" id="eb14ec59-5e31-4272-a0d2-b7032b280add">
        <source>getDisplay(dataObj: Object): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	return dataObj.CM_VehicleMake.getYADisplay();

