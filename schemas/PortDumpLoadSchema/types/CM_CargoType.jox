<Class name="CM_CargoType">
    <JadeMethod name="importPLXMLReference" id="adc9eeb4-e7fe-4661-a5f5-2236ee01004a">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_CargoType::myRoot.name then
		return app.myRoot;
	elseif _name = CM_CargoType::myDrawingAttribute.name then
		return app.myRoot.allDrawingAttributes[_theCode];
	elseif _name = CM_CargoType::myClassToCreate.name then
		return currentSchema.getClass(_theCode);
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
