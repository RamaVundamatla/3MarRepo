    <JadeMethod name="doDelete" id="29463209-48da-4862-855c-b3bfa5408f53">
        <updating/>
        <source>doDelete(): Boolean updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteOverstowRule(self.myCurrentObject.CM_YAOverstowRule, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Delete Overstow Rule', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return true;
		
	endwhile;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableVoyageAttributes" id="f35a5b2e-7bb5-4d7c-8877-efde1e0acfd4">
        <source>doEnableVoyageAttributes() protected;
// -------------------------------------------
// Created 27 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin


	if not self.lstAttributes.allSelectedObjects.includes(self.myCMIFVoyageAttribute) then
//		self.cmbVoyageLater.text := null;
//		self.chkVoyageJobs.value := false;
		self.cmbVoyageLater.enabled := false;
		self.chkVoyageJobs.enabled := false;
	else
		self.cmbVoyageLater.enabled := true;
		self.chkVoyageJobs.enabled := true;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="282d7852-76f8-4afd-91a1-3f96b837f18e">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 27 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
//	if self.height &lt; 300 then
//		self.height := 300;
//	endif;

	self.frmEdit.width	:= self.frmDetailsTop.width - 10;	// 28/03/2008 cnwar2 #16316
	self.frmEdit.height	:= self.frmDetailsTop.height - 20;	// 28/03/2008 cnwar2 #16316
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f0747786-de87-417d-87ff-7dc0614e49f0">
        <updating/>
        <source>doSave(): Boolean updating;
// -------------------------------------------
// Created 22 September 2005 by cnwdvb1
// -------------------------------------------
vars

	newRule,
	pxyOverstowRule : CM_YAOverstowRule;
	code,
	description		: String;
	attributeArray	: IntegerArray;
	allImex			: CM_IMEXStatusByCodeDict;
	overstowLater	: Integer;
	doChecks		: Boolean;
	obj				: Object;
	isUpdate		: Boolean;
	result			: Integer;
	numberOfFreeTEUs : Integer;

begin

	if self.mode = Mode_Add then
		create pxyOverstowRule transient;
		self.myProxyObject := pxyOverstowRule;
	elseif self.mode = Mode_Update then
		pxyOverstowRule := self.myProxyObject.CM_YAOverstowRule;
		isUpdate := true;
	endif;
	
	create attributeArray transient;
	create allImex transient;
	
	code 			:= self.txtCode.text;
	description		:= self.txtDescr.text;
	
	foreach obj in self.lstAttributes.allSelectedObjects do
		attributeArray.add(obj.CMIF_YAOverstowAttributeType.type);
	endforeach;
	
	foreach obj in self.lstImex.allSelectedObjects do
		allImex.add(obj.CM_IMEXStatus);
	endforeach;
	
	overstowLater	:= self.cmbVoyageLater.getCurrentItemData();
	doChecks		:= self.chkVoyageJobs.value;
	numberOfFreeTEUs:= self.txtSpaces.text.Integer;

	pxyOverstowRule.setProxy(	code,
								description,
								numberOfFreeTEUs,
								attributeArray,
								allImex,
								overstowLater,
								doChecks,
								self.myTerminal);
	
	if not isUpdate then
		while true do
			app.myTrxCA.trxCreateYAOverstowRule(pxyOverstowRule, newRule, app.myPassport);
			if not app.myPassport.trxCompletedOK then	
				result := app.showErrorWarningDialog('Create Overstow Rule', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				if app.myPassport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			else
				self.clearErrorWarnings();
				self.myCurrentObject := newRule;
				return true;
			endif;
			break;
		endwhile;
		
	else
		while true do
			app.myTrxUA.trxUpdateYAOverstowRule(pxyOverstowRule, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				result := app.showErrorWarningDialog('Update Overstow Rule', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				if app.myPassport.noErrors and  result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			else
				self.clearErrorWarnings();
				return true;
			endif;
			break;
		endwhile;
	endif;
	
	return false;


epilog
	delete attributeArray;
	delete allImex;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCMIFOverstowAttribute" id="f18c889d-fba5-4300-be78-ee489e52905c">
        <source>getCMIFOverstowAttribute(_type : Integer) : Object protected;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	obj	: Object;
	attr : CMIF_YAOverstowAttributeType;

begin

	foreach obj in self.allAttributeTypes do
		if obj.CMIF_YAOverstowAttributeType.type = _type then
			return obj;
		endif;
	endforeach;


end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
