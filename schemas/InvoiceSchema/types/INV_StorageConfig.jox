    <JadeMethod name="doApply" id="76c157fd-72d7-4786-bb41-93a327644423">
        <updating/>
        <source>doApply() updating;
/*

Purpose:			Apply the storage config options to all on-site cargo,
					with confirmation and cancellable status display
Parameters:			

Return Value:		


Date		Who		Reason
05 October 2012	cnwjre1	Initial creation

*/

vars
	partsInJob,
	partsDone	: Integer;
	count		: Integer;
	monitor		: CMIF_Monitor;
	ti			: CM_TrackedItem;
begin
	if self.myTerminal.myStorageConfig = null then
		return;
	endif;
	
	// ### TFS CR 62808 TASK 62809 12MAR2024 NAVAB1
	count := self.myTerminal.allOnsiteTIsByCargoTypeId.size;
	if count &gt; 500 then
		if app.msgBox("There are " &amp; count.asStringJMT() &amp; " items on site." &amp; CrLf &amp; CrLf &amp;
							"Clicking APPLY will take a long time" &amp; CrLf &amp; 
							"Clicking APPLY will impact ALL users in your terminal" &amp; CrLf &amp; CrLf &amp;
							
							"A better option is to do a query in the cargo enquiry" &amp; CrLf &amp; 
							"and then right click to RE-EVALUATE STORAGE" &amp; CrLf &amp; CrLf &amp;
							"Are you sure you want to proceed??"	,'
							Confirm Apply',
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return; 
		endif;
	
	else
		if app.msgBox("Clicking APPLY will impact ALL users in your terminal" &amp; CrLf &amp; CrLf &amp;
							
							"A better option is to do a query in the cargo enquiry" &amp; CrLf &amp; 
							"and then right click to RE-EVALUATE STORAGE" &amp; CrLf &amp; CrLf &amp;
							"Are you sure you want to proceed??"	,'
							Confirm Apply',
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return; 
		endif;
		/*
		if app.msgBox('Do you want to do update the free storage days on all on-site cargo?' ,'Confirm Apply',
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return; 
		endif;
		*/
	endif;
	
	create monitor transient;
	monitor.myParent := self;
	app.myPassport.setMyCMIFMonitor(monitor);
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Updating Free Storage',  'Please Wait....');
	self.pbProgressBar.visible := true;

	partsInJob :=  self.myTerminal.allOnsiteTIsByCargoTypeId.size;
	monitor.partsInJob := partsInJob;
	app.myTrxUA.trxUpdateCargoFreeStorageDays(self.myTerminal, null, app.myPassport);
epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete monitor;
	self.frmModalDialog.visible := false;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doContextMenuSelectedTriggers" id="50e004ed-d36f-487b-a888-49bc0efae3e7">
        <updating/>
        <source>doContextMenuSelectedTriggers(control: ListBox input; 
							conwin: Window input;
							mouse: Boolean;
							x: Integer;
							y: Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	storageTrigger : CM_StorageTrigger;
begin
	storageTrigger := control.listObject.CM_StorageTrigger;
	if storageTrigger = null then
		return false;
	endif;
	self.mnuResetStorageDays.checked:=storageTrigger.resetFreeStorageDays;
	
	self.showContextMenu(self.mnuTriggersContext, control, conwin, mouse, x, y);
	return true;
epilog

end;</source>
        <Parameter name="control" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPopulateButtons" id="d3e2d1cf-4a86-4981-a599-99e83ba06d3a">
        <source>doPopulateButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2017	jlgrh7	Initial creation TFS7228

*/

vars
	storageConfig : CM_StorageConfig;
begin
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnApply.enabled:= false;
		self.btnRemove.enabled:= false;
		self.btnSave.enabled:= false;
		self.mulAttr.readOnly := true;
		self.mulTriggers.readOnly := true;
		self.grpMain.enabled:= false;
	else
		storageConfig := self.myTerminal.myStorageConfig;
		if storageConfig &lt;&gt; null then
			self.btnApply.enabled:= true;
			self.btnApply.visible := app.myCurrentUserCan(self.myTerminal, PmInvStorageApply);  // ### TFS CR 62808 TASK 63809 08MAR2024 NAVAB1
			self.btnRemove.enabled:= true;
			self.btnSave.enabled:= true;
			self.btnDetails.enabled := true;
			self.mulAttr.readOnly := false;
			self.mulTriggers.readOnly := false;
			self.grpMain.enabled:= true;
		else
			self.btnApply.enabled := false;
			self.btnRemove.enabled := false;
			self.btnDetails.enabled := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="a0d8d4b2-e76f-4c77-b1ca-86ada8c54168">
        <updating/>
        <source>doRemove() updating;
// added remove option 841
vars
	theReturn		: Integer;
	storageConfig	: CM_StorageConfig ;

begin
	storageConfig := self.myTerminal.myStorageConfig;
	if storageConfig = null then
		return;
	endif;
	if app.msgBox('Do you want to do remove the free storage configuration?' ,'Confirm Remove',
				MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return; 
	endif;
	
	while true do
		app.myTrxDA.trxDeleteStorageConfig(storageConfig, app.myPassport);
		 
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			self.unloadForm();	
			return ;
		else
			theReturn := app.showErrorWarningDialog("Storage Configuration Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="a0dc9e1a-a26c-4e43-a3c0-49765d85b3f9">
        <updating/>
        <source>doSave()  : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295
10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
18 Sep 2019	jlgdi1	45972 Added terminal configuration update having a right access
23 Mar 2022 jlier1	 TFS 52292
*/

vars
	pxyStorageConfig,
	newStorageConfig : CM_StorageConfig;
	theReturn : Integer;
	extraDaysCargoTypes : IntegerArray;
	allSelectedCargoTypes  : CM_CargoTypeSet;
	cargoType : CM_CargoType;
begin
	self.myStorageConfig:= self.myTerminal.myStorageConfig;						//+TFS 7228
	if self.myStorageConfig = null then
		create pxyStorageConfig transient;
	else
		beginLoad;
		pxyStorageConfig:=self.myStorageConfig.pxyCreateUpdateProxy();
		endLoad;
	endif;
	
	if self.shtCargoTypes.visible then
		create extraDaysCargoTypes transient;
		create allSelectedCargoTypes transient;
		self.mulCargoTypes.getSelected(allSelectedCargoTypes);
		foreach cargoType in allSelectedCargoTypes do
			extraDaysCargoTypes.add(cargoType.id);
		endforeach;
	endif;
	
	self.doSaveProxy(pxyStorageConfig);
	
	while true do
		if self.myStorageConfig = null then
			app.myTrxCA.trxCreateStorageConfig(pxyStorageConfig,newStorageConfig,extraDaysCargoTypes, app.myPassport );
		else
			app.myTrxUA.trxUpdateStorageConfig(pxyStorageConfig,extraDaysCargoTypes, app.myPassport );
		endif;
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	if app.myCurrentUserCan(self.myTerminal, PmAdmFinancialsystemdefauMaint) then
		beginTransaction;
		self.myTerminal.setConfig(MTsByDebtor, self.chkMTStorage.value);
		self.myTerminal.setConfig(MTsByDebtorExport, self.chkMTStorageEX.value);
		commitTransaction;
	endif;
	
	self.doPopulateButtons();	
	return true;
	
epilog
	endLoad;
	delete pxyStorageConfig;
	delete extraDaysCargoTypes;
	delete allSelectedCargoTypes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveProxy" id="453be85d-badb-4e32-a466-737ede421885">
        <source>doSaveProxy(_pxy : CM_StorageConfig input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295
26/05/2023			navkc1	CR 58009 Task 58010: UI - Storage Config - Storage Configuration Receival
*/

vars
	selectedYACriteria : CM_YACriteriaTypeArray;
	oa				: ObjectArray;
	obj				: Object;	
	selectedStorageTriggers : CM_StorageTriggerByType;
	shipReleaseType,
	shipReceivalType,
	truckReceivalType,
	wagonReceivalType,
	childReceivalType	: Integer;
begin
	
	if _pxy = null then
		return;
	endif;
	create selectedYACriteria transient;
	create selectedStorageTriggers transient;
	create oa transient;
	
	if self.cmbReceivalDates.listIndex &gt; 0 then
		shipReceivalType := self.cmbReceivalDates.itemData[self.cmbReceivalDates.listIndex];
	endif;
	if self.cmbReleaseDates.listIndex &gt; 0 then
		shipReleaseType := self.cmbReleaseDates.itemData[self.cmbReleaseDates.listIndex];
	endif;
	// 26/05/2023	navkc1	CR 58009 Task 58010
	if self.cmbTruckReceival.listIndex &gt; 0 then
		truckReceivalType := self.cmbTruckReceival.itemData[self.cmbTruckReceival.listIndex];
	endif;
	// 26/05/2023	navkc1	CR 58009 Task 58010
	if self.cmbWagonReceival.listIndex &gt; 0 then
		wagonReceivalType := self.cmbWagonReceival.itemData[self.cmbWagonReceival.listIndex];
	endif;
	// 26/05/2023	navkc1	CR 58009 Task 58010
	if self.cmbChildReceival.listIndex &gt; 0 then
		childReceivalType := self.cmbChildReceival.itemData[self.cmbChildReceival.listIndex];
	endif;
	
	self.mulAttr.getSelected(selectedYACriteria);
	// from 30731 the selected triggers are transients so that the reset FSD option can be set on them, but the storage config save deletes them
	//		if they are used directly so then subsequent access gets error 4.  Copy them again to avoid this.
	self.mulTriggers.getSelected(oa);
	foreach obj in oa do
		selectedStorageTriggers.add(obj.cloneSelf(true).CM_StorageTrigger);
	endforeach;

	_pxy.setProxy(	selectedYACriteria,
					selectedStorageTriggers,
					self.txtCutoffTime.getTime(),
					self.chkInc1stDay.value,
					self.chkIncLastDay.value,
					self.myTerminal , 
					shipReceivalType ,
					shipReleaseType ,
					self.cmbWorkingDays.listObject.CM_Calendar,
					self.cmbCompulsory.listObject.CM_Calendar,	//20 Sep 2017	NDL	TFS 7032
					truckReceivalType,	// 26/05/2023	navkc1	CR 58009 Task 58010
					wagonReceivalType,	// 26/05/2023	navkc1	CR 58009 Task 58010
					childReceivalType	// 26/05/2023	navkc1	CR 58009 Task 58010
					); 
	
epilog
	delete selectedYACriteria;
	delete selectedStorageTriggers;
	delete oa;
end;</source>
        <access>protected</access>
        <Parameter name="_pxy" type="CM_StorageConfig" usage="input"/>
    </JadeMethod>
