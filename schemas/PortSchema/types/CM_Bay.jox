    <JadeMethod name="isLastInHold" id="e5df0ed9-f730-449c-8122-bd2e66d686f9">
        <source>isLastInHold() : Boolean;
/*
------------------------------------------------------------------------
Purpose:			Returns boolean indicating if this bay is last in hold
---------------------------------------------------------------------------
*/
begin
	if self.myHold = null then
		return false;
	endif;
	return (self.myHold.allBays.last = self);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fcbeb943-210f-4df8-a56d-2ffc6045c7b2">
        <source>pxyCreateUpdateProxy(): SelfType; //serverExecution;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
// 20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
//						trying to create the proxy
// ---------------------------------------------------------------------------

vars
	theProxyMe : SelfType;
	aCell,pCell : CM_CellDefn;
	aSlot,pSlot : CM_SlotDefn;
	aTier, pTier : CM_TierDefn;
	aLid, pLid : CM_HatchLid;
	loadState : Boolean;
	completedOK		: Boolean;
begin
	theProxyMe :=  inheritMethod();

	// ############################
	// ON DECK CELLS
	foreach aCell in self.allCellsOnDeckByOrdinal do
		app.cmsBeginLoad(loadState);
		pCell := aCell.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		pCell.setMyBay(theProxyMe,true);
	endforeach;

	// ############################
	// UNDER DECK CELLS
	foreach aCell in self.allCellsUnderDeckByOrdinal do
		app.cmsBeginLoad(loadState);
		pCell := aCell.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		pCell.setMyBay(theProxyMe,false);
	endforeach;

	// ############################
	// ON DECK TIERS
	foreach aTier in self.allTiersOnDeckByLabel do
		app.cmsBeginLoad(loadState);
		pTier := aTier.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		pTier.setMyBay(theProxyMe,true);
	endforeach;

	// ############################
	// UNDER DECK TIERS
	foreach aTier in self.allTiersUnderDeckByLabel do
		app.cmsBeginLoad(loadState);
		pTier := aTier.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		pTier.setMyBay(theProxyMe,false);
	endforeach;

	// ############################
	// ON DECK SLOTS
	foreach aSlot in  self.allSlotsOnDeck do
		app.cmsBeginLoad(loadState);
		pSlot := aSlot.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);

		aTier := theProxyMe.allTiersOnDeck[pSlot.ordinalTier];
		aCell := theProxyMe.allCellsOnDeckByOrdinal[pSlot.ordinalCell];
		
		pSlot.setMyBay(theProxyMe,true);
		pSlot.setCellAndTierDefn(aCell,aTier);
	endforeach;

	// ############################
	// UNDER DECK SLOTS
	foreach aSlot in  self.allSlotsUnderDeck do
		app.cmsBeginLoad(loadState);
		pSlot := aSlot.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);

		aTier := theProxyMe.allTiersUnderDeck[pSlot.ordinalTier];
		aCell := theProxyMe.allCellsUnderDeckByOrdinal[pSlot.ordinalCell];
		
		pSlot.setMyBay(theProxyMe,false);
		pSlot.setCellAndTierDefn(aCell,aTier);
	endforeach;

	// ############################
	// HATCH LIDS
	foreach aLid in self.allHatchLids do
		// hatch lids cover many bays and so may already have been proxied
		pLid := aLid.pxyGetProxyObject();
		if pLid = null then
			app.cmsBeginLoad(loadState);
			pLid := aLid.pxyCreateUpdateProxy;
			app.cmsEndLoad(loadState);
		endif;
		pLid.allBays.add(theProxyMe);
	endforeach;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxyMe;

epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxyMe;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="reverseCellTierId" id="661aec54-7aba-42ab-8565-f5c03e67d71a">
        <source>reverseCellTierId(cellTierStr : String; tierId : String io; cellId : String io) protected;
/*
 ------------------------------------------------------------------------
Created:			06 November 2002 by cnwdwq1
Purpose:			When passed in a string that is ASSUMED to be in Cell/Tier order, we reverse
							it to be Tier/Cell order. Used in findLocation mainly.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tierLen : Integer;
	cellLen : Integer;
	tierCellStr : String;
begin
	//--------------------
	//Determine the length of the appropriate Id from the slotDefn.
	//--------------------
//	cellLen := CM_SlotDefn.cnEcGetStringPropertyLength('cellId');
	cellLen := 2;
//	tierLen := CM_SlotDefn.cnEcGetStringPropertyLength('tierId');
	tierLen := 2;
	
	if cellTierStr.length() &lt;&gt; self.getDefinedLenOfCellTierId() then
		//I have no idea what this is, invalid label!
		app.raiseCMException1(ERR_INVALID_LABEL, "(" &amp; cellTierStr &amp; ")", null, null);
		return;
	endif;	
	//tierCellStr := cellTierStr[(cellTierStr.length - (cellLen -1)):end] &amp; cellTierStr[1: tierLen];
	tierId := cellTierStr[(cellTierStr.length - (cellLen -1)):end];
	cellId := cellTierStr[1: tierLen];
	
	return;
	
	// The lengths are hardcoded above
	write CM_SlotDefn::cellId.name;
	write CM_SlotDefn::tierId.name;

end;</source>
        <access>protected</access>
        <Parameter name="cellTierStr" type="String"/>
        <Parameter name="tierId" type="String" usage="io"/>
        <Parameter name="cellId" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAftFromForward" id="b2f4b29b-fc2a-49fe-af48-bc1943c12f15">
        <updating/>
        <source>setAftFromForward(_forwardBay : CM_Bay input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		 afew attributes on the forward are always the same on the aft
//
// ---------------------------------------------------------------------------

vars

begin
	if _forwardBay.bayType = BAY_TYPE_SINGLE then
		self.bayType := _forwardBay.bayType;
		self.fortyFootBay := false;
		self.fortyFootOnly := false;
		self.fortyFiveFootBay := false;
		self.fortyFiveFootOnly := false;
		_forwardBay.fortyFootBay := false;
		_forwardBay.fortyFootOnly := false;
		_forwardBay.fortyFiveFootBay := false;
		_forwardBay.fortyFiveFootOnly := false;
		_forwardBay.idBay40 := null;
	else
		self.bayType := _forwardBay.bayType;
		self.fortyFootBay := _forwardBay.fortyFootBay;
		self.fortyFootOnly := _forwardBay.fortyFootOnly;
		self.fortyFiveFootBay := _forwardBay.fortyFiveFootBay;
		self.fortyFiveFootOnly := _forwardBay.fortyFiveFootOnly;
	endif;

end;</source>
        <Parameter name="_forwardBay" type="CM_Bay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setBaseBayDataDuringReplace" id="0739d62a-62c0-4771-903f-264d732f5c92">
        <updating/>
        <source>setBaseBayDataDuringReplace(_bayDefn : CM_BayDefn input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2013	cnwndl1	Initial creation	Par 32341

*/

vars

begin

	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	
	self.lashFromTier := _bayDefn.lashFromTier;
	self.unlashFromTier := _bayDefn.unlashFromTier;
	
	self.maxPileWeight20IB := _bayDefn.maxPileWeight20IB;
	self.maxPileWeight20OB := _bayDefn.maxPileWeight20OB;
	self.maxPileWeight40IB := _bayDefn.maxPileWeight40IB;
	self.maxPileWeight40OB := _bayDefn.maxPileWeight40OB;
	self.maxPileWeightUD := _bayDefn.maxPileWeightUD;
	
	self.isTwinLiftOD := _bayDefn.isTwinLiftOD;
	self.isTwinLiftUD := _bayDefn.isTwinLiftUD;

epilog

end;</source>
        <Parameter name="_bayDefn" type="CM_BayDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setBayType" id="3462fedf-8bfa-4b3a-8d4a-8cea1895f5d8">
        <updating/>
        <source>setBayType(_type : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _type &lt;&gt; BAY_TYPE_SINGLE and _type &lt;&gt; BAY_TYPE_TWIN and _type &lt;&gt; BAY_TYPE_TRIPLE then
		return;
	endif;
	
		
	if self.bayType &lt;&gt; _type then
		self.bayType := _type;
		
		if _type = BAY_TYPE_SINGLE then
			self.fortyFootBay := false;
			self.fortyFiveFootBay := false;
			self.idBay40 := null;
			self.fortyFootOnly := false;
		endif;
	endif;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCellAlignmentOnCreate" id="b75ee241-3cf8-4713-8e6e-ab5e1c68cfed">
        <source>setCellAlignmentOnCreate();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aCellOD,aCellUD, aCell : CM_CellDefn;
	theAlignment : Real;

begin
	if self.allCellsOnDeckByOrdinal.size = 0 then
		return;
	endif;


	aCell := self.allCellsOnDeckByOrdinal.first;

	// if the ID of the first on deck cell is not used in the under deck cells then the on deck is wider than the under deck
	if self.allCellsUnderDeck[aCell.id] = null then
		aCellUD := self.allCellsUnderDeckByOrdinal.first;
		
		// the idea is to line up the on deckand under deck cells
		// the under deck cells are not as wide so use the first UD cells ID to get the ordinal of the cell OD with the same ID
		if aCellUD &lt;&gt; null then
			aCellOD := self.allCellsOnDeck[aCellUD.id];
			if aCellOD &lt;&gt; null then
				theAlignment := aCellOD.ordinal;
			else
				theAlignment := 1;
			endif;
			foreach aCell in self.allCellsUnderDeckByOrdinal do
				aCell.setAlignment(theAlignment);

				theAlignment := theAlignment + 1;
			endforeach;
		endif;
		// the on deck cells are wider so they start at zero
		theAlignment := 1;
		foreach aCell in self.allCellsOnDeckByOrdinal do
			aCell.setAlignment(theAlignment);

			theAlignment := theAlignment + 1;
		endforeach;
	else
		aCellOD := self.allCellsOnDeckByOrdinal.first;
		
		// the idea is to line up the on deck and under deck cells
		// the on deck cells are not as wide, or are the same width,  so use the first OD cells ID to get the ordinal of the cell UD with the same ID
		if aCellOD &lt;&gt; null then
			aCellUD := self.allCellsUnderDeck[aCellOD.id];
			if aCellUD &lt;&gt; null then
				theAlignment := aCellUD.ordinal;
			else
				theAlignment := 1;
			endif;
			foreach aCell in self.allCellsOnDeckByOrdinal do
				aCell.setAlignment(theAlignment);

				theAlignment := theAlignment + 1;
			endforeach;
		endif;
		// the under deck cells are wider so they start at zero
		theAlignment := 1;
		foreach aCell in self.allCellsUnderDeckByOrdinal do
			aCell.setAlignment(theAlignment);
			theAlignment := theAlignment + 1;
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cd3ad42f-7afc-4a7d-be51-487046a1b76f">
        <updating/>
        <source>setForCreate(_proxyBay:CM_Bay; 
			_realVesselVoyage : CM_Object; 
			_passport : CM_Passport input) updating; //, serverExecution;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
	// NOTE DO NOT CREATE HATCHLIDS ON A CREATE OF A BAY.
	// HATCHLIDS ARE CREATED ON THE CREATE OF A VESEL AFTER ALL THE BAYS
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	StdHeightMetre = 2.5908;  // 8.5 feet * 12 (inches in a foot) / 39.37 (inches in a metre)
vars
	pxyCellDefn,realCellDefn:CM_CellDefn;
	pxyTierDefn,realTierDefn:CM_TierDefn;
	pxySlotDefn,realSlotDefn : CM_SlotDefn;
	defaultOnDeckMaxHeight : Decimal[5,2];	// 29 July	2010	NDL	Par 25127 / CCMS 1140
	defaultUnderDeckMaxHeight : Decimal[5,2];	// 29 July	2010	NDL	Par 25127 / CCMS 1140
begin

	_proxyBay.raiseExceptionIfNotTransient(method);
	
	self.id := _proxyBay.id;
	self.ordinalBay := _proxyBay.ordinalBay;
	self.athwartships := _proxyBay.athwartships;
	self.bayType := _proxyBay.bayType;
	self.fortyFootBay := _proxyBay.fortyFootBay;
	self.fortyFootOnly := _proxyBay.fortyFootOnly;
	self.fortyFiveFootBay := _proxyBay.fortyFiveFootBay;
	self.fortyFiveFootOnly := _proxyBay.fortyFiveFootOnly;
	self.idBay40 := _proxyBay.idBay40;
	self.lashFromTier := _proxyBay.lashFromTier;
	self.isTwinLiftOD := _proxyBay.isTwinLiftOD;
	self.isTwinLiftUD := _proxyBay.isTwinLiftUD;
//	self.ordinalHold := _proxyBay.ordinalHold;
	self.maxPileWeight20IB := _proxyBay.maxPileWeight20IB;
	self.maxPileWeight20OB := _proxyBay.maxPileWeight20OB;
	self.maxPileWeight40IB := _proxyBay.maxPileWeight40IB;
	self.maxPileWeight40OB := _proxyBay.maxPileWeight40OB;
	self.maxPileWeightUD := _proxyBay.maxPileWeightUD;
	self.numOfPlugs := _proxyBay.numOfPlugs;
	self.remarks := _proxyBay.remarks.trimBlanks;
	self.unlashFromTier := _proxyBay.unlashFromTier;
	self.useCellTierODSequencing := _proxyBay.useCellTierODSequencing;
	self.useCellTierUDSequencing := _proxyBay.useCellTierUDSequencing;
	
	self.useCellTierODSequencing40 := _proxyBay.useCellTierODSequencing40;
	self.useCellTierUDSequencing40 := _proxyBay.useCellTierUDSequencing40;
	
	defaultOnDeckMaxHeight := StdHeightMetre * _proxyBay.allTiersOnDeck.size;	// 29 July	2010	NDL	Par 25127 / CCMS 1140
	defaultUnderDeckMaxHeight := StdHeightMetre * _proxyBay.allTiersUnderDeck.size;	// 29 July	2010	NDL	Par 25127 / CCMS 1140
	
	foreach pxyCellDefn in _proxyBay.allCellsOnDeck do
	
	/* CCMS 2259 Vessel Defn do not default
		if not isImported() then // if this has come from a XML import do not default these values
			pxyCellDefn.setMaxHeight(defaultOnDeckMaxHeight);	// 29 July	2010	NDL	Par 25127 / CCMS 1140
		endif;
		*/
		app.myUtilityCA.utlCreateCellDefn(pxyCellDefn,realCellDefn,self,true, _passport);
	endforeach;

	foreach pxyCellDefn in _proxyBay.allCellsUnderDeck do
	/* CCMS 2259 Vessel Defn do not default
		if not isImported() then // if this has come from a XML import do not default these values
			pxyCellDefn.setMaxHeight(defaultUnderDeckMaxHeight);	// 29 July	2010	NDL	Par 25127 / CCMS 1140
		endif;
		*/
		app.myUtilityCA.utlCreateCellDefn(pxyCellDefn,realCellDefn,self,false, _passport);
	endforeach;
	foreach pxyTierDefn in _proxyBay.allTiersOnDeck do
		app.myUtilityCA.utlCreateTierDefn(pxyTierDefn,realTierDefn,self,true, _passport);
	endforeach;
	foreach pxyTierDefn in _proxyBay.allTiersUnderDeck do
		app.myUtilityCA.utlCreateTierDefn(pxyTierDefn,realTierDefn,self,false, _passport);
	endforeach;

	if not _proxyBay.allSlotsByOrdinal.isEmpty then // probably from an imported XML file
		foreach pxySlotDefn in _proxyBay.allSlotsByOrdinal do
			app.myUtilityCA.utlCreateSlotDefn(pxySlotDefn, realSlotDefn,self,_proxyBay.allSlotsOnDeck.includes(pxySlotDefn),_passport);
			// PAR 21790 self.setSequenceNums();
		endforeach;
		self.setSequenceNums();// PAR 21790 
	else
		self.createSlots();
	endif;

	// we have just created  a bay  and the cells, tiers and slots.
	// We must link them, the inverse is on the aft bay so we must tell our forward bay to link its slots to our slots
	if self.myForwardBay &lt;&gt; null then
		self.myForwardBay.updateSlotLinks();
	endif;
	
	// this works out the alignment for on screen drawing purposes of the cells so that the OD and UD cells line up by label
	if not self.isImported() then
		self.setCellAlignmentOnCreate();
	endif;

	//created for JATOS epr 19/8/2013
	self.setForUpdateLayouts(_proxyBay,_passport);
	// NOTE DO NOT CREATE HATCHLIDS ON A CREATE OF A BAY.
	// HATCHLIDS ARE CREATED ON THE CREATE OF A VESSEL AFTER ALL THE BAYS
end;</source>
        <Parameter name="_proxyBay" type="CM_Bay"/>
        <Parameter name="_realVesselVoyage" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="6d0f1307-ad90-41f6-b187-923d985cc7a7">
        <updating/>
        <source>setForDelete() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	// only delete transients or a real if the real has come via the TRX
	if not self.isTransient and self.pxyGetProxyObject = null then

		self.raiseExceptionIfTransient(method);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="376d2843-c2c4-44bc-b890-b1317d99256e">
        <updating/>
        <source>setForUpdate(_proxy : SelfType; _passport : CM_Passport input) updating;
/*---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
01 Sep 2014 	cnwer1 		PAR 34819 1/9/14
// ---------------------------------------------------------------------------*/
vars
	pxyCellDefn,realCellDefn:CM_CellDefn;
	pxyTierDefn,realTierDefn:CM_TierDefn;
	iCreatedCellsTeirs : Boolean;
	slotControllerToDelete : ObjectSet;
begin

	// pesistent objects can't reference transients
	self.id := _proxy.id;
	self.ordinalBay := _proxy.ordinalBay;

	self.athwartships := _proxy.athwartships;
	self.bayType := _proxy.bayType;
	self.fortyFootBay := _proxy.fortyFootBay;
	self.fortyFootOnly := _proxy.fortyFootOnly;
	self.fortyFiveFootBay := _proxy.fortyFiveFootBay;
	self.fortyFiveFootOnly := _proxy.fortyFiveFootOnly;

	self.idBay40 := _proxy.idBay40;
	self.lashFromTier := _proxy.lashFromTier;
	self.isTwinLiftOD := _proxy.isTwinLiftOD;
	self.isTwinLiftUD := _proxy.isTwinLiftUD;
	self.maxPileWeight20IB := _proxy.maxPileWeight20IB;
	self.maxPileWeight20OB := _proxy.maxPileWeight20OB;
	self.maxPileWeight40IB := _proxy.maxPileWeight40IB;
	self.maxPileWeight40OB := _proxy.maxPileWeight40OB;
	self.maxPileWeightUD := _proxy.maxPileWeightUD;
	self.numOfPlugs := _proxy.numOfPlugs;
	
	self.onShipCrane := _proxy.onShipCrane;
	self.remarks := _proxy.remarks;
	self.unlashFromTier := _proxy.unlashFromTier;
	self.useCellTierODSequencing := _proxy.useCellTierODSequencing;
	self.useCellTierUDSequencing := _proxy.useCellTierUDSequencing;
	
	self.useCellTierODSequencing40 := _proxy.useCellTierODSequencing40;
	self.useCellTierUDSequencing40 := _proxy.useCellTierUDSequencing40;
	iCreatedCellsTeirs := false;

	// ################################
	// ################################
	create slotControllerToDelete transient;

	foreach pxyCellDefn in _proxy.allCellsOnDeckByOrdinal do
		// even though this is via the UPDATE of the vessel we may be creating cells and tiers etc so check the proxy link. Proxy links only for updates
		if pxyCellDefn.pxyGetRealObject = null then
			iCreatedCellsTeirs := true;
			app.myUtilityCA.utlCreateCellDefn(pxyCellDefn, realCellDefn, self, true, _passport);
		else
			app.myUtilityUA.utlUpdateCellDefn(pxyCellDefn, _passport);
		endif;
	endforeach;
	// we have a delete - check which cells are in us, the real bay, but not in the proxy bay
	if _proxy.allCellsOnDeckByOrdinal.size &lt; self.allCellsOnDeckByOrdinal.size then
		foreach realCellDefn in self.allCellsOnDeckByOrdinal do
			if _proxy.allCellsOnDeck[realCellDefn.id] = null then
				//epr par 37142 7/1/16
				realCellDefn.getSlotControllers(slotControllerToDelete);
				slotControllerToDelete.purge;
				delete realCellDefn;
			endif;
		endforeach;
	endif;
	foreach pxyCellDefn in _proxy.allCellsUnderDeckByOrdinal do
		// even though this is via the UPDATE of the vessel we may be creating cells and tiers etc so check the proxy link. Proxy links only for updates
		if pxyCellDefn.pxyGetRealObject = null then
			iCreatedCellsTeirs := true;
			app.myUtilityCA.utlCreateCellDefn(pxyCellDefn, realCellDefn, self, false, _passport);
		else
			app.myUtilityUA.utlUpdateCellDefn(pxyCellDefn, _passport);
		endif;
	endforeach;
	// we have a delete - check which cells are in us, the real bay, but not in the proxy bay
	if _proxy.allCellsUnderDeckByOrdinal.size &lt; self.allCellsUnderDeckByOrdinal.size then
		foreach realCellDefn in self.allCellsUnderDeckByOrdinal do
			if _proxy.allCellsUnderDeck[realCellDefn.id] = null then
				//epr par 37142 7/1/16
				realCellDefn.getSlotControllers(slotControllerToDelete);
				slotControllerToDelete.purge;
				delete realCellDefn;
			endif;
		endforeach;
	endif;


	if iCreatedCellsTeirs then
		self.setCellAlignmentOnCreate();
	endif;

	foreach pxyTierDefn in _proxy.allTiersOnDeck do
		// even though this is via the UPDATE of the vessel we may be creating cells and tiers etc so check the proxy link. Proxy links only for updates
		if pxyTierDefn.pxyGetRealObject = null then
			app.myUtilityCA.utlCreateTierDefn(pxyTierDefn,realTierDefn,self,true,_passport);
			iCreatedCellsTeirs := true;
		else
			app.myUtilityUA.utlUpdateTierDefn(pxyTierDefn,_passport);
		endif;
	endforeach;
	// we have a delete - check which cells are in us, the real bay, but not in the proxy bay
	if _proxy.allTiersOnDeck.size &lt; self.allTiersOnDeck.size then
		foreach realTierDefn in self.allTiersOnDeck do
			if _proxy.allTiersOnDeckByLabel[realTierDefn.id] = null then	
				//epr par 37142 7/1/16
				realTierDefn.getSlotControllers(slotControllerToDelete);
				slotControllerToDelete.purge;
				delete realTierDefn;
			endif;
		endforeach;
	endif;


	foreach pxyTierDefn in _proxy.allTiersUnderDeck do
		// even though this is via the UPDATE of the vessel we may be creating cells and tiers etc so check the proxy link. Proxy links only for updates
		if pxyTierDefn.pxyGetRealObject = null then
			app.myUtilityCA.utlCreateTierDefn(pxyTierDefn,realTierDefn,self,false,_passport);
			iCreatedCellsTeirs := true;
		else
			app.myUtilityUA.utlUpdateTierDefn(pxyTierDefn,_passport);
		endif;
	endforeach;
	// we have a delete - check which cells are in us, the real bay, but not in the proxy bay
	if _proxy.allTiersUnderDeck.size &lt; self.allTiersUnderDeck.size then
		foreach realTierDefn in self.allTiersUnderDeck do

			if _proxy.allTiersUnderDeckByLabel[realTierDefn.id] = null then
				//epr par 37142 7/1/16
				realTierDefn.getSlotControllers(slotControllerToDelete);
				slotControllerToDelete.purge;
				delete realTierDefn;
			endif;
		endforeach;
	endif;

	
	self.setForUpdateSlots(iCreatedCellsTeirs,_proxy,_passport);	

	//created for JATOS epr 19/8/2013
	self.setForUpdateLayouts(_proxy,_passport);

epilog

	delete slotControllerToDelete;					// 14/01/2016 cnwmh5 transient leak
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateAftCellTiers" id="da1f1957-f7df-47ee-9551-e6bd1d4068a8">
        <updating/>
        <source>setForUpdateAftCellTiers(_ordinal : Integer; _cell : Boolean; _onDeck : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		June 2004 By Andrew Bishop cnwab1
//
// Purpose:		This auto removes a cell or a teir in the aft bay. It also resets the cell and tier ordinals on the slots.
//
// ---------------------------------------------------------------------------
vars
	realCellDefn:CM_CellDefn;
	realTierDefn:CM_TierDefn;
	aftBay : CM_Bay;
	pxyCell : CM_CellDefn;
	pxyTier : CM_TierDefn;
begin
	if self.isAftBay then
		return;
	endif;
	
	if not self.canHandle4045() then
		return;
	endif;
	
	if _ordinal &lt; 1 then
		return;
	endif;
	
	aftBay := self.myAftBay;
	if aftBay = null then
		return;
	endif;
	
	if aftBay &lt;&gt; null then
		if _cell then
			if _onDeck then
				realCellDefn := aftBay.allCellsOnDeckByOrdinal[_ordinal];
			else
				realCellDefn := aftBay.allCellsUnderDeckByOrdinal[_ordinal];
			endif;
			if realCellDefn &lt;&gt; null then
				pxyCell := realCellDefn.pxyGetProxyObject();
				delete realCellDefn;
				delete pxyCell;
			endif;
		else
			if _onDeck then
				realTierDefn := aftBay.allTiersOnDeck[_ordinal];
			else
				realTierDefn := aftBay.allTiersUnderDeck[_ordinal];
			endif;
			if realTierDefn &lt;&gt; null then
				pxyTier := realTierDefn.pxyGetProxyObject();
				delete realTierDefn;
				delete pxyTier;
			endif;
		endif;
	endif;
	foreach realCellDefn in aftBay.allCellsOnDeckByOrdinal do
		foreach  realTierDefn in aftBay.allTiersOnDeck do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if self.checkAndResetOrdinals(realCellDefn,realTierDefn,true)then
				break;
			endif;
		endforeach;
	endforeach;
	foreach realCellDefn in aftBay.allCellsUnderDeckByOrdinal do
		foreach  realTierDefn in aftBay.allTiersUnderDeck do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if self.checkAndResetOrdinals(realCellDefn,realTierDefn,false)then
				break;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_cell" type="Boolean"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSlots" id="3aa3ed0e-94aa-4fd7-960d-9f4cd06427b1">
        <updating/>
        <source>setForUpdateSlots(_iCreatedCellsTeirs : Boolean; _proxy : SelfType; _passport : CM_Passport input) updating;

vars
	realCellDefn:CM_CellDefn;
	realTierDefn:CM_TierDefn;
	pxySlotDefn,realSlotDefn : CM_SlotDefn;
begin
	if (not _proxy.allSlotsByOrdinal.isEmpty) then

		foreach pxySlotDefn in _proxy.allSlotsByOrdinal do
			// even though this is via the UPDATE of the vessel we may be creating cells and tiers etc so check the proxy link. Proxy links only for updates
			if pxySlotDefn.pxyGetRealObject = null then
				app.myUtilityCA.utlCreateSlotDefn(pxySlotDefn, realSlotDefn,self,_proxy.allSlotsOnDeck.includes(pxySlotDefn),_passport);
			else
				app.myUtilityUA.utlUpdateSlotDefn(pxySlotDefn, _passport);
			endif;
		endforeach;
	else
		self.createSlots();
	endif;

	//epr par 34819 1/9/14 always check this will only change if there is an issue
	foreach realCellDefn in self.allCellsOnDeckByOrdinal do
		foreach  realTierDefn in self.allTiersOnDeck do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if self.checkAndResetOrdinals(realCellDefn,realTierDefn,true)then
				break;
			endif;
		endforeach;
	endforeach;
	foreach realCellDefn in self.allCellsUnderDeckByOrdinal do
		foreach  realTierDefn in self.allTiersUnderDeck do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if self.checkAndResetOrdinals(realCellDefn,realTierDefn,false)then
				break;
			endif;
		endforeach;
	endforeach;
	
	if _iCreatedCellsTeirs then
		self.internalCreateSlots(true);
		self.internalCreateSlots(false);
	endif;

end;</source>
        <Parameter name="_iCreatedCellsTeirs" type="Boolean"/>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateWeights" id="fd9a18f7-15c0-4277-b172-65dca5296bbf">
