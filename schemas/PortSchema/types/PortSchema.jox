    <JadeMethod name="beginRFIDTagNoteWindowsPC" id="e0681aaa-7509-4b4c-852d-320edfd1509d">
        <source>beginRFIDTagNoteWindowsPC(	_event 			: Integer;
							_receiver		: Object input; 
							_terminal		: CM_Terminal) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	_readerContext passed in should be one of:
			
			Reader_Machine
			Reader_WindowsPC
			Reader_GateLane

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tagReaderDict			: CM_RFIDTagReaderByCodeDict;
	tagReader				: CM_RFIDTagReader;
	machineName				: String;
	rtnValue				: Boolean;
begin
	if _terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Num Terminal passed in');
		return false;
	endif;
	machineName := app.computerName.toUpper;
	tagReaderDict := _terminal.allRFIDTagReadersByCode;
	//th2 - need a dict by context ? but will be a max of about a dozen readers, so no biggy
	foreach tagReader in tagReaderDict do		
		if tagReader.context &lt;&gt; TagReaderContext_WindowsPC then
			continue;
		endif;
		
		// Changed this line so users can receive tag reads regardless of whether they
		// are the specified machine or not if they are coming from terminal admin screen
		if tagReader.windowsMachineName.toUpper &lt;&gt; machineName then
			continue;
		endif;
		
		rtnValue := true;
		_receiver.beginNotification(tagReader, _terminal.getTerminalEvent(_event), Response_Continuous, null);
	endforeach;
	
	return rtnValue;
	
end;


</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_receiver" type="Object" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="bolStatusEnumToString" id="b48ff9f7-1a7f-4698-9d36-59ee37c5a020">
        <source>bolStatusEnumToString(_status : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     17 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _status = BOL_STATUS_NORMAL then
		return 'Normal';
	elseif _status = BOL_STATUS_ARCHIVED then
		return 'Archived';
	else
		return 'Unknown';
	endif;

end;</source>
