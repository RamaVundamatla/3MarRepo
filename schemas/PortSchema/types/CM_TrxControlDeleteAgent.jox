    <JadeMethod name="trxDeleteYardInternalJob" id="14b63fe0-5161-4762-8ff1-99d406dac4cc">
        <updating/>
        <source>trxDeleteYardInternalJob(pYardJobSet:CM_YardJobSet; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	alertCreated	: Boolean;
	yardJob			: CM_YardJob;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	foreach yardJob in pYardJobSet do
		app.myValDA.valYardInternalJob(yardJob);
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	alertCreated := self.doDeleteYardInternalJobs(pYardJobSet, _passport);  //refactored code into here due to exception continue next out of transaction state...
	
	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Deleting of Requests', null, self);
	endif;
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pYardJobSet" type="CM_YardJobSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxEDIDeleteBulkRelease" id="aa1556f8-0877-4d9a-be44-8edd18b714ff">
        <updating/>
        <source>trxEDIDeleteBulkRelease(_release :CM_BulkRelease; _cmifRelease :CMIF_EDIReleaseRequest; _validateOnly : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2011
//
// Purpose:     CCMS POL 2122 par 28696
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants
// ---------------------------------------------------------------------------
// 20 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	ediTI		:CM_EDITrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _release = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'bulk release', null, null);
		return;
	endif;

	// Start the transaction
	beginTransaction;

	app.myUtilityDA.utlDeleteBulkRelease(_release, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors then
			// we can only update the EDI TI status if we know the trx will not be aborted
			foreach ediTI in _cmifRelease.allEDITIs do
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
			endforeach;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxEDIDeleteReserveDetail" id="47003aa7-a7cf-4b72-9f27-7c0dac4feb52">
        <updating/>
        <source>trxEDIDeleteReserveDetail(_reserveDetail :CM_ReserveDetail; _cmifRelease :CMIF_EDIReleaseRequest; _validateOnly : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
// ---------------------------------------------------------------------------
// 18 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	ediTI : CM_EDITrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _reserveDetail = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Reserve Detail', null, null);
		return;
	endif;

	// Start the transaction
	beginTransaction;

	app.myUtilityDA.utlDeleteReserveDetail(_reserveDetail, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors then
			// we can only update the EDI TI status if we know the trx will not be aborted
			foreach ediTI in _cmifRelease.allEDITIs do
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
			endforeach;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPurgeInterTerminalRailBOLs" id="2a79d4c3-5db6-4a00-8a7a-8404b1d6b13c">
        <updating/>
        <source>trxPurgeInterTerminalRailBOLs(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2017 by Emmet Ryan for TFS 4157
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//			
// ---------------------------------------------------------------------------
vars

	bolSet				: CM_BOLSet;
	iter				: Iterator;
	bolIn				: CM_BOLIn;
	count,
	completed,
	theSize				: Integer;
	setAll,
	setErrors			: CM_ObjectSetActual;
	numOfLockExceptions	: Integer;
	hadLock				: Boolean;
	errTxt				: String;
	bolExt : CM_BOLExtLogIn;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt, true);
	
	create setAll transient;
	create setErrors transient;
	create bolSet transient;

	foreach bolExt in _terminal.allLogBOLsUnmatched discreteLock do
		if bolExt.myBOL = null then
			continue;
		endif;
		
		if not bolExt.myBOL.isKindOf(CM_BOLIn) then
			continue;
		endif;
		bolIn:= bolExt.myBOL.CM_BOLIn;
		
		if not bolIn.getIsInterTermRailTransfer() then
			continue;
		endif;
					
		if bolIn.createdTime &lt; _ts then
			bolSet.add(bolIn);
		endif;	
	endforeach;
	
	if _agent.abort() then
		return;
	endif;

	theSize := bolSet.size;
	iter := bolSet.createIterator();

	while iter.next(bolIn) do
		count := count + 1;
	
		setAll.add(bolIn);
		if count mod _agent.Commit_Block_Size_Medium = 0 then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			if _agent.abort() then
				return;
			endif;
			if count mod _agent.Activity_Progress_Count_Large = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Processed)&amp;' '&amp;count.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, true);
			endif;
		endif;
		
	endwhile;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;	completed.String &amp; ' ' &amp; app.getErrorString(Empty) &amp;  ' ' &amp; app.getErrorString(Inter_termin_rail_releas_docke) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors) );
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog
	delete bolSet;
	delete iter;
	delete setAll;
	delete setErrors;
	self.finaliseActivityWithPassport(_passport);



end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPurgeMovementLog" id="7f34cfb9-71a1-4510-a99d-1e6a9b0abb1a">
        <updating/>
        <source>trxPurgeMovementLog(_movementLogArray : ObjectArray io; _passport : CM_Passport input) updating;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// Start the transaction
	beginTransaction;

	app.myUtilityUA.utlPurgeMovementLog(_movementLogArray, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_movementLogArray" type="ObjectArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxReleaseFromTransArea" id="157b1e57-c442-4d4c-baa4-bb20d15ee606">
        <updating/>
        <source>trxReleaseFromTransArea(pTISet : CM_TISet input; pOpt : Integer; pConsignee : String; 
			pDeliveryNumber : String; pReason : Integer;
			_passport : CM_Passport input)  updating;
/* NFS 3833: This code releases items from a release transfer area. The
error checking is limited to misuse checking ie that the cargo is actually
in a release transfer area at this stage. Suitability of the cargo itself
for release is performed by the move code when it got moved here

Done in one hit to avoid some of the batch going offsite and some remaining
23 Aug 2019	NDL	TFS 46020 Added pOpt and new functionality for consignee updeate
25 Nov 2025 navhl20 Bug MTN-36095: MTN | Deferred update required on trxReleaseFromTransArea
*/
constants  
	//Note: Thezse are also declared in YRD_ReleaseFromTransferArea modal form
	Replace : Integer = 0;
	RetainNonBlank : Integer = 1;
	NoUpdate : Integer = 2;
vars
	isError	: Boolean;
	isWarning : Boolean;
	isIgnore : Boolean;
	ta 		: CM_TerminalArea;
	ti 		: CM_TrackedItem;
	terminal	: CM_Terminal;
	tmpLC	: CM_LocationsController;
	error : String;
	exObj	: CM_Exception;
	allErrorMsgs : StringArray512;
	proformaLines : CM_InvoiceLineBySeqNumDict;
	consigneeForRel : String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	create allErrorMsgs transient;
	create proformaLines transient;

	app.setContinueCMExceptions(true);	
	
	if pTISet = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Tracked Item Array", null, null);
		return;
	endif;
	
	// 36361 do check for cash paid before releasing this cargo and move all of the validation outside transaction state
	//	(the cash validation must be outside trans state and can't see any good reason for the rest to be in)
	foreach ti in pTISet do
		if ti.isChild then
			//We can't release a child or an attached COU
			app.raiseCMException(ERR_MOVING_CHILD, null, null);	
			return;
		endif;
		
		terminal := ti.myTerminal;
		if terminal.isCashOnlyEnabled then
			// ### JIRA 33806 15JAN2025 NAVAB1
			if terminal.getConfig(CashOnlyInDebtOption).Integer = CashOnlyInDebtOption_NOACTION then // NO ACTION
			else
				// update the consignee now so the pro forma invoicing uses it
				if pOpt = Replace or ( pOpt = RetainNonBlank and ti.consignee = null ) then	//23 Aug 2019	NDL	TFS 46020
					if ti.consignee &lt;&gt; pConsignee then
						beginTransaction;
						ti.setConsigneeByString(pConsignee);
						commitTransaction;
					endif;
				endif;
				app.myValUA.valCashCollectionForTI(ti, false, proformaLines, false, allErrorMsgs);	
				proformaLines.purge;
			endif;
		endif;

		tmpLC := ti.getPrimaryLocation(REAL_MODE);
	
		if tmpLC = null or (not tmpLC.isKindOf(CM_YardController)) then
			app.raiseCMException1(ERR_INVALID_TA_ID, ti.locationId, null, null);
		endif;

		ta := tmpLC.CM_YardController.getParent.CM_TerminalArea;	//AA 30/10/01 replaces parent
		if ta.type &lt;&gt; TA_TYPE_RELTRANS then	
			app.raiseCMException3(VB_WRONG_TARGET_TYPE, ti.locationId, ti.id, "Release Transfer Area", null, null);
		endif;
	endforeach;
	// 36361 report any cash errors
	if terminal &lt;&gt; null then
	//	isError := terminal.getConfig(CashProcUnderpayIsError).Boolean;
		terminal.handleCashDebtorInDebt( isError, isWarning, isIgnore );	//30 May 2018	NDL	TFS 3852
	endif;
	if not isIgnore then	//30 May 2018	NDL	TFS 3852
		foreach error in allErrorMsgs do
			create exObj transient;
			//exObj.set(Cash_cargo_not_paid, error, isError, null, null, null);
			//30 May 2018	NDL	TFS 3852
			if isError then
				exObj.set(Cash_cargo_not_paid, error, false, null, null, null);
			elseif isWarning then
				exObj.set(Cash_cargo_not_paid, error, true, null, null, null);
			endif;
			raise exObj;
		endforeach;
	endif;
	// from 36361, exit here rather in releaseFromTransferArea if any errors
	if _passport.hasErrors then
		return;
	endif;	
	
	_passport.useTITransactionDeferUpdate	:= true;							//25.11.2025 navhl20 #36095
	_passport.useTIDictDeferUpdate			:= true;							//25.11.2025 navhl20 #36095

	beginTransaction;
	foreach ti in pTISet do	
		exclusiveLock(ti);		//Get latest and ensure that we have the lock for updating. Txn duration lock

		//23 Aug 2019	NDL	TFS 46020
		consigneeForRel := ti.consignee;
		if pOpt = Replace or ( pOpt = RetainNonBlank and consigneeForRel = null ) then
			consigneeForRel := pConsignee;
		endif;
		
		ti.releaseFromTransferArea(consigneeForRel, pDeliveryNumber, pReason, _passport, true); // ### TFS 51936 07SEP2021 NAVAB1
	endforeach;
	
	if _passport.noErrors then													//25.11.2025 navhl20 #36095
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	if proformaLines &lt;&gt; null then
		proformaLines.purge;
	endif;
	delete proformaLines;
	delete allErrorMsgs;
end;</source>
        <Parameter name="pTISet" type="CM_TISet" usage="input"/>
        <Parameter name="pOpt" type="Integer"/>
        <Parameter name="pConsignee" type="String"/>
        <Parameter name="pDeliveryNumber" type="String"/>
        <Parameter name="pReason" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRemoveTransfer" id="fedec5d5-46ba-4c1d-84f6-ae6736a85791">
        <updating/>
        <source>trxRemoveTransfer(_ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	app.myUtilityUA.utlRemoveTransfer(_ti, _passport);

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRoadExit" id="b6355565-8877-42d1-baba-eeab5209da0a">
        <updating/>
        <source>trxRoadExit(pRoadJob : CM_RoadJob input; _retroDT: TimeStamp; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
//15/12/2016 cnwns1 	TFS 2867:PKT - Bulk Process - WeighBridge Integration
//03/05/2017 cnwrh7		TFS2207     #1090 Error in Road Exit Form
//07/09/2017 cnwma1		TFS # 6670 PEN - RE: Ticket 5132 - Cargo IDs in a continuous loop issue continues to cause Cargo Enquiry to fail and a file lock.
//31/05/2022 jlier1		TFS 53650 - refactored schedule packages now called from vvr.departureProcess
//12/04/2023 navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
//16/02/2024 navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
//24/10/2024 navma1  	MTN-33181 SNO - Error 1081 When doing Road Exit,Truck Events not Deferred 
vars
	vvr 			: CM_VehicleVisitRecord;
	isCashEnabled   : Boolean;
begin

	if pRoadJob &lt;&gt; null then
		vvr := pRoadJob.myVehicleVisit;
	endif;

	//15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration																																				//-TFS4211
	if	vvr &lt;&gt; null and vvr.isBulkGateVVR() then																														//+TFS4211 To Avoid 1090 UE
		app.raiseCMException1(Vehicle_visit_Bulk_Only,app.getErrorString(Bulk_gate_out),"wrongGate", null);
		//err you cant process bulk gate job here
		return;
	endif;
	
	isCashEnabled := _passport.myTerminal.isCashOnlyEnabled();		//24.10.2024 navma1 #MTN-33181
	
	//shouldn't be null
	if vvr &lt;&gt; null and isCashEnabled then						//24.10.2024 navma1 #MTN-33181
		/*CCMS 1280 Cash Invoicing epr 10/8/12 
			before we release a container check that if the debtor is a cash only debtor they have paid 
			calling a validation method before this - this is odd case in that it always does a begin then abort so
			have to do it before any initalise here
		 */
		app.myValUA.valCashCollectionForVVR(vvr,false,true,null,_passport);
		
		if not app.myPassport.trxCompletedOK then
			return;
		endif;
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);	
	
	if pRoadJob = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Road Job', null, null);
		return;
	endif;

	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	_passport.useEventDeferUpdate			:= true;	//24.10.2024 navma1 #MTN-33181
	_passport.useOfflineFutureActorDeferDel := true;	//17.03.2025 navma1 #MTN-34120
	
	exclusiveLock(_passport.myTerminal.myRoadJobSheet.allJobsByOrder);	 //th2 added 24/01/07 - dealock 1081 @ CM_RoadJob::vehicleStillOnSite
	
	if pRoadJob.myGate &lt;&gt; null then // TFS 41565
		exclusiveLock(pRoadJob.myGate.allRoadJobs);						// jlgmd1 tfs 38937 18/07/2018 - deadlock 1081 @ CM_RoadJobSet
	endif;
	
	beginTransaction;
	
	vvr.setTimeOut(_retroDT);											//16.02.2024 navnk30 #62414
	pRoadJob.departureProcess(_passport);
	
	app.myUtilityUA.utlUpdateVVRRoadExit( vvr,  _passport);
	
	// ### TFS 55215 13MAR2022 NAVPW1
	CMIF_TrxActionTransport@createAction(null, null, vvr, CMIF_TrxActionTransport.ProcessTruckDeparture, _passport);	// TFS 57362
	// ### TFS 55215 13MAR2022 NAVPW1
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="pRoadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_retroDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSendEDIToConsignee" id="797026b0-b173-4bc4-a49c-f32d266b6219">
        <updating/>
        <source>trxSendEDIToConsignee(pTISet : CM_TISet; pConsignee : String; _passport : CM_Passport input) : Integer  updating;

//NFS 3833: This code creates a copino file using the passed in TIs and
//sends it as an e-mail attachment to the passed in consignee. We don't check
//the status of the TIs at all, only that the array and consignee are present
//-----------------------------------------------------------------------------------------------
//	26/01/04	CNWJC2	Updated for v7.  Now uses new email request.
//-----------------------------------------------------------------------------------------------

vars
	consignee		: CM_ConsigneeConsignor;
	ediFileType		: CM_EDIFileTypeCopino;
	copinoFileObj	: CM_EDIFile;	
	sender,
	subject,
	message,
	filePath		: String;
	now				: TimeStamp;
	lastSlash		: Integer;
	attachments		: HugeStringArray;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);	

	consignee := app.myRoot.allConsigneeConsignors[pConsignee];
	if consignee = null then
		app.raiseCMException1(ERR_INVALID_CONSIGN, pConsignee, null, null);
		return null;
	endif;

	if consignee.emailAddress = null then
		app.raiseCMException1(NoEMailAddress, 'Consignee ' &amp; pConsignee, null, null);
		return null;
	endif;
	
	if pTISet = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Tracked Item Set", null, null);
		return null;
	endif;

	create attachments transient;
	create copinoFileObj transient;
	
	//use the temp directory... this could be sent from anywhere
	filePath := app.getTempDir(); //Method is presentation client executed so this is ok (if server or app server executed, we need to use app.getTempDirFromSystemConfig

	lastSlash := filePath.reversePos("\");
	if lastSlash &lt;&gt; filePath.length then		//The path is not terminated by a slash
		filePath := filePath &amp; "\";
	endif;

	//Set email details
	copinoFileObj.fileName :=  filePath &amp; "copino" &amp; app.getMyTerminalConfigDO_NOT_USE(PortDestCode).String &amp; now.date.format("ddMM") &amp; "_" &amp; now.time.format("HHmmss") &amp; ".txt";		//To Do: Get the correct directory and create a file name
	subject := app.getErrorString(PreNote_Advice_EDI);
	message := app.getErrorString(Find_Attached_Copino) &amp; app.getMyTerminalDO_NOT_USE().name;
	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	attachments.add(copinoFileObj.fileName);
		
	ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Copino, null).CM_EDIFileTypeCopino;
	if ediFileType = null or ediFileType.type &lt;&gt; EDIFileType_Copino then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no COPINO edi file type was found');
		return null;
	endif;
	
	beginTransaction;
	//extract and write to file
	ediFileType.extractTIsAsFile(copinoFileObj, pTISet, pConsignee);
	
	if _passport.noErrors then
		//create email request
		return app.myUtilityCA.utlCreateEmailSendRequest(true, app.getErrorString(Find_Attached_Copino), consignee.emailAddress, sender, null, null, subject, message, attachments, null, null, null, EmailSource_EDI,copinoFileObj, _passport);
	endif;
	
epilog
	delete copinoFileObj;
	delete attachments;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pTISet" type="CM_TISet"/>
        <Parameter name="pConsignee" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxVehicleRoadExit" id="57a58cf6-5471-4da9-9c36-399d4fb60244">
        <updating/>
        <source>trxVehicleRoadExit(_vehicle : CM_Vehicle input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//15/12/2016	cnwns1 	TFS 2867:PKT - Bulk Process - WeighBridge Integration
//07/09/2017	cnwma1	TFS # 6670 PEN - RE: Ticket 5132 - Cargo IDs in a continuous loop issue continues to cause Cargo Enquiry to fail and a file lock.
//12/04/2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
//24/10/2024    navma1  MTN-33181 SNO - Error 1081 When doing Road Exit,Truck Events not Deferred 
//17/03/2025 	navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
vars
	obj 			: Object;
	ti 				: CM_TrackedItem;
	vvr 			: CM_VehicleVisitRecord;
	allVVRS 		: ObjectSet;
	job 			: CM_Job;
	resetStatus 	: Boolean;
	isCashEnabled   : Boolean;
begin
	
	/*CCMS 1280 Cash Invoicing epr 10/8/12 
	before we release a container check that if the debtor is a cash only debtor they have paid 
	calling a validation method before this - this is odd case in that it always does a begin then abort so
	have to do it before any initalise here
	*/

	isCashEnabled := _passport.myTerminal.isCashOnlyEnabled;		//24.10.2024 navma1 #MTN-33181
	
	create allVVRS transient;
	if _vehicle &lt;&gt; null then
		foreach job in _vehicle.allRoadJobs discreteLock do			//17.03.2025 navma1 #MTN-34120
			if job.isCompleteForExit then
			 // since this is  only doing departure for the complete jobs
				vvr:=job.CM_RoadJob.myVehicleVisit;
				if vvr = null then
					continue;
				endif;
				allVVRS.add(vvr);
			endif;
		endforeach;
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);	//01 Nov 2016	NDL TFS 2868
	
	if isCashEnabled then
		foreach obj in allVVRS do
			vvr := obj.CM_VehicleVisitRecord;
			if not _passport.warningsAcknowledged then
				app.myValUA.valCashCollectionForVVR(vvr,false,true,null,_passport);
				resetStatus := true;
			endif;
			if _passport.hasErrors() then
				return;
			endif;
		endforeach;
	endif;
	
	//15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
	if not allVVRS.isEmpty() and allVVRS.first().CM_VehicleVisitRecord.isBulkGateVVR() then
		app.raiseCMException1(Vehicle_visit_Bulk_Only,app.getErrorString(Bulk_gate_out),"wrongGate", null);
		//err you cant process bulk gate job here
		return;
	endif;
	
	//09Dec2022 navsp1 TFS 55580
	//Validation to prevent road exit if pregate OUT check is required and not done.
	if not allVVRS.isEmpty() then
		foreach obj in allVVRS discreteLock do
			vvr := obj.CM_VehicleVisitRecord;		
			if vvr.gateOutCheckStatus = vvr.InspectionPending then
					app.raiseCMException2(Vehicle_cannot_road_exit, vvr.vehicle.regNumber, vvr.InspectionPending, null, vvr.vehicle);
					return;
					
			//28.Mar.2023 navsp1 TFS 57268
			elseif vvr.gateOutCheckStatus = vvr.InspectionFailed then
				app.raiseCMException2(Vehicle_cannot_road_exit, vvr.vehicle.regNumber, vvr.InspectionFailed, null, vvr.vehicle);
				return;
			endif;		
		endforeach;
	endif;
	
	 //07 Nov 2016	NDL	TFS 2868 - to reset status
	if resetStatus and _passport.allWarnings.isEmpty then
		// validation does an abort so need to rest the status.
		// but only if there are no warnings, cos' we don't want them cleared.
		self.finaliseActivityWithPassport(_passport);
		self.initialiseActivityWithPassport(_passport, method);
	endif;
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);	
	
	if _vehicle = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, app.getErrorString (XLAT_Road_Job), null, null);
		return;
	endif;

	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	_passport.useEventDeferUpdate			:= true;	//24.10.2024 navma1 #MTN-33181
	_passport.useOfflineFutureActorDeferDel := true;	//17.03.2025 navma1 #MTN-34120
	
	beginTransaction;
	
	_vehicle.roadExitProcess(_passport);

	//epr par 21/3/2013 31268 if don't return will get the 75755 exception
	if _passport.hasErrors() then
		return;
	endif;

	// rebuild these as in some cases the TI is deleted
	// above which can result in invalid objects in the
	// deferred dicts
	_passport.rebuildDeferredDicts();
	_passport.doDeferredUpdates(); 
	
	if isCashEnabled then  //04/09/2017 cnwma1 TFS #6670
		foreach obj in allVVRS do
			vvr := obj.CM_VehicleVisitRecord;
			foreach ti in vvr.allReleasedTrackedItems discreteLock do
				app.myUtilityUA.utlUpdateCashPaymentFromTI(ti,vvr,_passport);
				if _passport.hasErrors() then
					return;
				endif;
			endforeach;		
		endforeach;
	endif;
	
	// ### TFS 55215 23Nov2022 NAVPW1
	if not _vehicle.pxyIsProxy and _passport.noErrors then
		foreach vvr in allVVRS as CM_VehicleVisitRecord do
			if not vvr.pxyIsProxy then
				CMIF_TrxActionTransport@createAction(null, null, vvr, CMIF_TrxActionTransport.ProcessTruckDeparture, _passport);	// TFS 57362
			endif;
		endforeach;
	endif;
	// ### TFS 55215 23Nov2022 NAVPW1
	
epilog
	delete allVVRS;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
