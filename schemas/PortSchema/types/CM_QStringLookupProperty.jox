<Class name="CM_QStringLookupProperty" id="030685da-317b-4d7a-b08c-71b952f7ba3e">
    <superclass name="CM_QLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Use when the field is a string, but has to be looked up from a dict</text>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="364a5349-1a4c-4741-b9d1-7026161d2e78">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QStringLookup persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QStringLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="b55b33fa-12b2-40c4-840b-9767eccf3ee5">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _op.isKindOf(CM_QStringLookup) or
	   _op.isKindOf(CM_QStringLookupNotEqual) then
		return QueryControl_ComboBox;
	elseif _op.isKindOf(CM_QStringIsOneOf) or _op.isKindOf(CM_QReferenceIsOneOf) then
		return QueryControl_MultiSelect;
	endif;
	
	return inheritMethod(_op);

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="8d102556-ba97-47a8-904d-3cbf87c8e680">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return 30;	// arbitray default
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="99833f80-f087-4d08-a3ba-7a15f1f3627a">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	queryOper : CM_QueryOperator;
	class : Class;
	className : String;

begin
	
	//first choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QStringIsOneOf then
			return class;
		endif;
	endwhile;
	delete iter;
	
	//second choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QStringLookup then
			return class;
		endif;
	endwhile;
	
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="1d4f394f-0b1c-4e92-9648-fd52b65f131a">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// ---------------------------------------------------------------------------
// Created:     30 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	propValue : String; 

begin
	propValue := inheritMethod(_obj,_op).String; // adm 180708 Par 15628 stop "invalid parameter" exceptions when null

	if self.needToUpperCase then
		propValue := propValue.toUpper;
	endif;

	return propValue;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0dfca75d-c03e-4b2b-bec9-3d3322840f32">
