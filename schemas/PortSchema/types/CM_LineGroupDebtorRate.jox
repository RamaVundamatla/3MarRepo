    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="d3f12d76-3482-4130-bf9a-730fe65cbe9e">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars

begin

	if self.auditId() &lt;&gt; null then
		return app.getErrorString(Rate) &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(Line_group_debtor) &amp; ": "&amp; self.auditId();
	else
		return app.getErrorString(Rate);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="0a9cf41f-9c5c-4d62-9d2d-e5b406f4af85">
        <source>getCode(): String;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	invalidObject : Boolean;
	edition : Integer;

begin
	
	if self.lineGroupDebtor &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.lineGroupDebtor, invalidObject );
		edition := self.lineGroupDebtor.edition;
		if invalidObject then
			return null;
		endif;
		return self.lineGroupDebtor.code;
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListName" id="34dcd50d-f612-4432-b9b4-0e2b810e7526">
        <source>getListName(): String;

vars

begin
	return self.lineGroupDebtor.code;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtorNode" id="80167752-daf2-4072-918e-93b9d81a52f1">
        <source>getMyDebtorNode(): CM_DebtorNode;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

begin
	
	if self.lineGroupDebtor &lt;&gt; null then
		return self.lineGroupDebtor.debtor;
	endif;
	
	return null;

epilog

end;</source>
