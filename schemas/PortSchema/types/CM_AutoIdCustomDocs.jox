    <JadeMethod name="newIdNotAlreadyUsed" id="6afbaf32-8695-430b-becd-1809e8a2a341">
        <source>newIdNotAlreadyUsed(_newId: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id

*/

vars
	terminal		: CM_Terminal;
	custDoc 		: CM_CustomDocument;
begin
	terminal := self.myTerminal;
	
	if terminal = null then
		return true;
	endif;
	custDoc := terminal.allCustomDocuments.getAtKey(_newId, null);
	
	return custDoc = null;

epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="dc38c5a7-8d90-47d8-aa52-2d36934a615e">
        <updating/>
        <source>setForCreate(_proxy: CM_AutoIdGenerator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars
	now : Date;
	
begin
	inheritMethod(_proxy);
	
	if not self.isTransient() and self.nextSequenceNumArray.isEmpty() then
		now := app.actualTimeAppServer().Date;
		
		self.setLastAndNextValues(null, 1, now.format("yy").Integer, now);
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c5331196-7233-4005-8816-d1b802f5fdeb">
        <updating/>
        <source>setForUpdate(_proxy: CM_AutoIdCustomDocs) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars

	now : TimeStamp;
	year : Integer;
	index : Integer;
	
begin
	
	inheritMethod(_proxy);
	
	now := app.actualTimeAppServer;
	year := now.Date.year.String[3:2].Integer;
	
	if _proxy.nextSequenceNum &gt; 0 then
		index := ( year - 1 );
		if _proxy.nextSequenceNumArray.size &gt;= index then
			if _proxy.nextSequenceNumArray[ index ] = _proxy.nextSequenceNum then
				self.nextSequenceNumArray[ index ] := _proxy.nextSequenceNumArray[ index ];
			endif;
		endif;
		index := year;
		if _proxy.nextSequenceNumArray.size &gt;= index then
			if _proxy.nextSequenceNumArray[ index ] = _proxy.nextSequenceNum then
				self.nextSequenceNumArray[ index ] := _proxy.nextSequenceNumArray[ index ];
			endif;
		endif;
		index := ( year + 1 );
		if _proxy.nextSequenceNumArray.size &gt;= index then
			if _proxy.nextSequenceNumArray[ index ] = _proxy.nextSequenceNum then
				self.nextSequenceNumArray[ index ] := _proxy.nextSequenceNumArray[ index ];
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdCustomDocs"/>
    </JadeMethod>
    <JadeMethod name="setLastAndNextValues" id="5c3e6554-2edb-4e8e-b660-3c7c56bf5b38">
        <updating/>
        <source>setLastAndNextValues(_lastIdGenerated: String; _nextSeqNum: Real; _seqYear: Integer; _lastGeneratedDate: Date) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars

begin
	
	self.lastIdGenerated := _lastIdGenerated;
	self.nextSequenceNumArray[_seqYear] := _nextSeqNum;
	self.lastGeneratedDate := _lastGeneratedDate;

epilog

end;</source>
        <Parameter name="_lastIdGenerated" type="String"/>
        <Parameter name="_nextSeqNum" type="Real"/>
        <Parameter name="_seqYear" type="Integer"/>
        <Parameter name="_lastGeneratedDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="e2b76ba6-7f3e-49b5-bb0d-8f947b32b178">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars

begin

	if _property = CM_AutoIdCustomDocs::nextSequenceNum then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
