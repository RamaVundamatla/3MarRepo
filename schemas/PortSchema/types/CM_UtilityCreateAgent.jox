vars
	remoteRequest	: BGP_RemoteProcessingRequest;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valRemoteData(_proxyRemoteHdr);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _realRemoteHdr as _proxyRemoteHdr.class persistent;
