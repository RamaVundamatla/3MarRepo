    <JadeMethod name="addToolbarControls" id="b7534e1d-d4eb-49e2-b891-8e7002817868">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars
	frm			: CMUI_Toolbar;
	canUpdate	:Boolean;
begin	
	canUpdate := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	if canUpdate then
		frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	frm.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	
	if canUpdate then
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					
	frm.addFrame(self.frmTblFilter, CMUI_Toolbar.Control_Alignment_Left); 
	self.frmTblFilter.visible := true;
	
	inheritMethod();
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="66dc6765-bf26-473e-a11e-657a3b0032e5">
        <source>addToolbarControlsQuery() protected;
/*

Purpose:			

