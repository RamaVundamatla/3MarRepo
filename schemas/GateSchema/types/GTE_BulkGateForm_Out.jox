    <JadeMethod name="enableFieldsAfterQuery" id="21cb4364-bd33-4939-8808-40f05136209b">
        <source>enableFieldsAfterQuery(_enabled : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/
vars
	control : Control;
	idx 	: Integer;
	enable 	: Boolean;
	
begin
	
	enable := _enabled and app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	
	foreach idx in 1 to self.controlCount do
		control := self.controls(idx);
		if control.isKindOf(CMUI_Label) or 
		   control.isKindOf(CMUI_TextBox) or
		   control.isKindOf(CMUI_ComboBox) or
		   control.isKindOf(CMUI_CheckBox) then
			control.enabled := enable;				
		endif;		
	endforeach;
	
	self.cmbPrinter.enabled := app.myCurrentUserCan(self.myTerminal, PmGteCanPrintFlexiGate);
	
end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoWeight" id="0d00ca87-68e4-495d-b066-912b79965541">
        <source>getCargoWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2016	cnwns1	Initial creation

*/

vars
	vvrd : CM_VehicleVisitRecordDetail;
	vvr : CM_VehicleVisitRecord;
	arrivalWeight : Decimal[16,4];
	scaleWeight : Decimal[16,4];
	cargoWeight : Decimal[16,4];
	measure : CM_MeasurementType;
	
begin

	 
	if self.tblItems.rows &lt;&gt; self.tblItems.fixedRows and self.tblItems.allSelectedObjects.size = 1 then
		vvr := self.tblItems.allSelectedObjects.first.CM_VehicleVisitRecord;
	endif;	
	
	
	if vvr &lt;&gt; null then
		vvrd := vvr.getBulkGateIn(null);		
		if vvrd &lt;&gt; null then
			scaleWeight := self.txtWeightOUT.getConvertedValue(); 	
			if scaleWeight &lt;&gt; 0 then
				arrivalWeight := vvrd.getExtraInfo_BulkGateInOrOut;
				cargoWeight :=   arrivalWeight - scaleWeight;
				if vvr.allGateEntities.first.isKindOf(CMGTE_Receival) and cargoWeight &lt; 0 then
					self.lblCargoWeight.caption := null;
				elseif vvr.allGateEntities.first.isKindOf(CMGTE_Release) and cargoWeight &gt; 0 then
					self.lblCargoWeight.caption := null;
				elseif cargoWeight = 0 then
					measure := app.getDefaultMeasurementForType(Type_Weight);
					self.lblCargoWeight.caption :=	0.String &amp; Space &amp; measure.shortName;
				else
					measure := app.getDefaultMeasurementForType(Type_Weight);
					self.lblCargoWeight.caption :=	app.convertMeasurementForDisplay(measure.shortName, cargoWeight.abs()) &amp; Space &amp; measure.shortName;
				endif;
			else
				self.lblCargoWeight.caption := null;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDefaultGate" id="78fc35b0-8c14-4f5c-9812-2bf1b63bb7cf">
        <source>getDefaultGate() : CM_Gate protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	gate : CM_Gate;
begin
	if self.cmbGate.listObject = null then				
		gate := self.myTerminal.getDefaultGate_OUT;	
	else
		gate := self.cmbGate.listObject.CM_Gate;
	endif;
	return gate;
epilog

end;</source>
