        <source>getID(): String;
//07 September 2009	cnwdw1	
//
// 01/03/2010	cnwcs5	par 22580 changed to be consistent with CM_YardICAreaLaneController
vars

begin
	if self.isDefaultLane() then
		return null;
	endif;

	return self.getLaneNumber.String;
	//	return self.getNiceName;
end;</source>
        <ReturnType type="String"/>
