    <JadeMethod name="testIsControllerAvailSubBlock" id="be1a873b-8d83-4d83-b894-71340cc93df9">
        <source>testIsControllerAvailSubBlock(pCheckLabour, pCheckLocation, pCheckSubBlock : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		This test for availability is used during convertion from grid area to a sub block stack
//				This is a different requirement from testIsControllerAvailable which is used during autoplanning and moving
//				The 2 methods ask different questions for different situations
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.numTIs &gt; 0 or self.numPlannedTIs &gt; 0 or self.numQueuedTIs &gt; 0 then
		app.raiseCMException(ERR_CONV_LC_HAS_TIS, null, null);
		return false;
	endif;
		
	return inheritMethod(pCheckLabour, pCheckLocation, pCheckSubBlock);
end;</source>
        <Parameter name="pCheckLabour" type="Boolean"/>
        <Parameter name="pCheckLocation" type="Boolean"/>
        <Parameter name="pCheckSubBlock" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerAvailable" id="45c1bbe7-67a1-45fa-86cb-782757605664">
        <source>testIsControllerAvailable(_autoMovePlan: CMIF_AutoMovePlan input);
//Is this Stack Controller available?
vars

begin
	_autoMovePlan.updateController(null);

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFull" id="64c4b5c3-9483-4ae9-8902-391091be089a">
        <source>testIsControllerFull(obj: CMIF_AutoMovePlan input);
//Set obj.targetLocation null if we are full.
vars
	topTi	:	CM_TrackedItem;
	numPlanTIs	:	Integer;
	numRealTIs	:	Integer;
	numQueueTIs	:	Integer;
	locnId	:	String;
	numControllers : Real;
	numTopControllers : Real;
	lc	: CM_LocationsController;
	msgString : String;
begin

	//----------------
	//The call checks that the height in the 1st stack, is available in the 2nd 
	//stack if we are dealing with a 40' ti.
	//----------------
	locnId	:= self.getFullId;
	self.isStackFull(obj);
	//----------------
	if obj.getController = null then
		obj.addVerboseLogEntry(app.getErrorString(Failed_stack_full), IsError, Failed_stack_full);
		return;
	endif;
	//----------------
	//If there are NO TI's here, this is fine, if
	//more than 1, we need to determine which iteration we are on.
	//If we are on iteration &gt; 1 then we need to make sure its ok to
	//go here.
	//----------------
	numRealTIs	:= self.numTIs;
	numPlanTIs	:= self.numPlannedTIs;
	numQueueTIs	:= self.numQueuedTIs;
	if obj.moveMode = REAL_MODE then
		if obj.iteration &lt;= numRealTIs then
			//There are at least as many TI's in here as the iteration.
			//(ie, this is already stacked to the row we are stacking to.)
			//Check next controller!
			obj.addVerboseLogEntry(app.getErrorString2(Positio_occupie_actual_contain,obj.iteration.String, locnId), IsForLogging, Positio_occupie_actual_contain);
			obj.updateController(null);
			return;
		endif;

	elseif obj.moveMode = PLANNING_MODE then
		//Always check for actual TI's in area 1st
		if obj.iteration &lt;= numRealTIs then
			obj.addVerboseLogEntry(app.getErrorString2(Positio_occupie_actual_contain,obj.iteration.String, locnId), IsForLogging, Positio_occupie_actual_contain);
			obj.updateController(null);
			return;
		endif;
		if obj.iteration &lt;= numPlanTIs then
			//There are at least as many TI's in here as the iteration.
			//(ie, this is already stacked to the row we are stacking to.)
			//Check next controller!
			obj.addVerboseLogEntry(app.getErrorString2(Positio_occupie_planned_contai,obj.iteration.String, locnId), IsForLogging, Positio_occupie_planned_contai);
			obj.updateController(null);
			return;
		endif;
		//Test also for Queued Containers to the stack..
		if obj.iteration &lt;= numQueueTIs then
			//There are at least as many TI's in here as the iteration.
			//(ie, this is already stacked to the row we are stacking to.)
			//Check next controller!
			obj.addVerboseLogEntry(app.getErrorString2(Positio_occupie_queued_contain,obj.iteration.String, locnId), IsForLogging, Positio_occupie_queued_contain);
			obj.updateController(null);
			return;
		endif;
  	//-----------------------
  	//If the total of planned and Queued exceeds the iteration, then forget it too.
  	//-----------------------
		if obj.iteration &lt;= (numQueueTIs + numPlanTIs + numRealTIs) then
			obj.addVerboseLogEntry(app.getErrorString4(Queue_plann_real_items_here_wi, locnId, numQueueTIs.String, numPlannedTIs.String, numRealTIs.String), IsForLogging, Queue_plann_real_items_here_wi);
			obj.updateController(null);
			return;
		endif;

	elseif obj.moveMode = QUEUE_MODE then
		// #####################################################	
		// Fork Lift Stacks are checked in CM_GridArea::testOverstowLocationsForkLift
		if not self.myTerminalArea.testIfFull(obj, self) then
			return;
		endif;

		if obj.iteration &lt;= numQueueTIs then
			//There are at least as many TI's in here as the iteration.
			//(ie, this is already stacked to the row we are stacking to.)
				obj.addVerboseLogEntry(app.getErrorString1(Another_queued_skipping,locnId), IsForLogging, Another_queued_skipping);
			obj.updateController(null);
			return;
		endif;

		if (numQueueTIs + numPlannedTIs + numRealTIs) &gt;= obj.iteration then
			//Total of all TI's here will be too big!
			obj.addVerboseLogEntry(app.getErrorString4(Queue_plann_real_items_here_wi,locnId, numQueueTIs.String, numPlannedTIs.String, numRealTIs.String), IsForLogging, Queue_plann_real_items_here_wi);
			obj.updateController(null);
			return;
		endif;		
	endif;

	//----------------
	//Test for sitting on top of a 40'. The rules are: 
	//1: If we are 40, do NOT sit on top of 20's
	//2: If we are 20, we do not sit on top of 40's
	//3: If we are a 40, we cannot overlap 2 other 40s (PAR 3245 AJA 20/11/99)
	//----------------
	//epr again isStackFull checks all this stuff by calling the ti.isOverStowable
	
	topTi := self.getTopTI(REAL_MODE);
	if topTi = null then
		obj.updateController(self);		
		return;
	endif;

	sharedLock(topTi);

	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	numTopControllers := self.calculateMoveLCs(topTi);

	if numTopControllers &gt; 1 and numControllers = 1 then
		obj.addVerboseLogEntry(app.getErrorString4(Contain_place_cannot_oversto,locnId, topTi.getActualLength().String,obj.myTrackedItem.id.trimRight,obj.myTrackedItem.getActualLength().String), IsForLogging, Contain_place_cannot_oversto);
		obj.updateController(null);
		return;
	endif;
	if numTopControllers = 1 and numControllers &gt; 1 then
		obj.addVerboseLogEntry(app.getErrorString4(Contain_place_cannot_oversto,locnId, topTi.getActualLength().String,obj.myTrackedItem.id.trimRight,obj.myTrackedItem.getActualLength().String), IsForLogging, Contain_place_cannot_oversto);
		obj.updateController(null);
		return;
	endif;
	if numControllers &gt; 1 and numTopControllers &gt; 1 then
		if topTi.getPrimaryLocation(REAL_MODE) &lt;&gt; self then		//The front end is next door, we must be over the rear end
			obj.addVerboseLogEntry(app.getErrorString2(Conta_backe_conta_conta_canno_,locnId, topTi.getActualLength().String ), IsForLogging,Conta_backe_conta_conta_canno_);
			obj.updateController(null);
			return;
		endif;
	endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFullYA" id="499c80ca-21c4-4bc4-8bc6-d392fabd17a2">
        <source>testIsControllerFullYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Set obj.targetLocation null if we are full.
vars
	topTi						: CM_TrackedItem;
	numPlanTIs,
	numRealTIs,
	accessLocn,
	totalTis,
	numQueueTIs			: Integer;
	locnId					: String;
	numTopControllers	: Real;
	accessHeight,
	heightAllowed			: Integer;
	lc							: CM_LocationsController;
	msgString				: String;
	maxStackingHeight,
	maxStackingHeightFork	: Integer;
	nextLC 					: CM_GridController;	
	theMode					: Integer;
	
begin

	// Fork Lift Stacks are checked in CM_GridArea::testOverstowLocationsForkLift
//	if not self.myTerminalArea.isKindOf(CM_SStraddleStack) then
//		return true;
//	endif;
	

	maxStackingHeight := self.getMaxStackingHeight() * 2;
	
	maxStackingHeightFork := self.myGridArea.getMaxHeightGridAreaYA(_yaAgent.myCurrentCMIFYAAutoPlan) * 2;
	
	maxStackingHeight := maxStackingHeightFork.min(maxStackingHeightFork);
	
	// Only want to call this method for first controller as
	// it handles back ends already.
	
	if not self.isAvailable(_yaAgent.iteration, null) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"No suitable position for container", true);
		return true;
	endif;
//	if self.isStackFullYA(_yaAgent, maxHeight) then
//		return true;
//	endif;

	locnId	:= self.getFullId;
	
	//----------------
	//If there are NO TI's here, this is fine, if
	//more than 1, we need to determine which iteration we are on.
	//If we are on iteration &gt; 1 then we need to make sure its ok to
	//go here.
	//----------------
	numRealTIs	:= self.numTIs;
	 //ccms 1025 26/1/09 when checking best location we will only be concerned at real cargo
	if not _yaAgent.isOnlyCheckRealCargo then
		//numPlanTIs	:= self.numPlannedTIs;
		numPlanTIs	:= self.numPlannedTIs + _yaAgent.getTestPlannedCargoCountFor(self);	//18 July 2013	NDL	Par 31899
		numQueueTIs	:= self.numQueuedTIs;
	endif;

	// DVB START HERE !!!!
	// #####################################################	
	//Always check for actual TI's in area 1st
	if _yaAgent.iteration &lt;= numRealTIs then
		// Have already checked we have enough space in isStackFullYA. Must be half heights. Just let it through.
		if  numRealTIs &lt; maxStackingHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Position " &amp; _yaAgent.iteration.String &amp; " of " &amp; locnId &amp; " is occupied.", true);
			return true;
		endif;
	endif;
	//Now, check for planned TIs
	if _yaAgent.iteration &lt;= numPlanTIs then
		if numPlanTIs &gt; 0 then	
			//Irrespective of where we are trying to go, if there is something planned
			//here. skip it.
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has a planned TI in it, skipping.", true);
			return true;
		endif;
	endif;
	
	if _yaAgent.iteration &lt;= numQueueTIs then
		//There are at least as many TI's in here as the iteration.
		//(ie, this is already stacked to the row we are stacking to.)
		//Check next controller!
		
		// Have already checked we have enough space in isStackFullYA. Must be half heights. Just let it through.
		if numQueueTIs &lt; maxStackingHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has another queued TI to it, skipping.", true);
			return true;
		endif;
	endif;

	totalTis := (numQueueTIs + numPlanTIs + numRealTIs);   // PAR 26700
	if _yaAgent.iteration &lt;= totalTis then
		//Total of all TI's here will be too big!
		//Check next controller!
		// Have already checked we have enough space in isStackFullYA. Must be half heights. Just let it through.
		if totalTis &lt; maxStackingHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has " &amp; numQueueTIs.String &amp; " Queued, " &amp; numPlanTIs.String &amp; " Planned, and " &amp; numRealTIs.String &amp; " Real items here, it will be overfull at position " &amp; 
			_yaAgent.iteration.String &amp; ", skipping.", true);
			return true;
		endif;
	endif;		
	

	//----------------
	//Test for sitting on top of a 40'. The rules are: 
	//1: If we are 40, do NOT sit on top of 20's
	//2: If we are 20, we do not sit on top of 40's
	//3: If we are a 40, we cannot overlap 2 other 40s (PAR 3245 AJA 20/11/99)
	//----------------
	
	// Par 11182
	topTi := self.getTopTI(REAL_MODE);
	if topTi = null and not _yaAgent.isOnlyCheckRealCargo then
		topTi := self.getTopTI(QUEUE_MODE);
		if topTi = null then
			topTi := self.getTopTI(PLANNING_MODE);
			if topTi = null then
				return false;
			else
				theMode :=  PLANNING_MODE;	
			endif;
		else
			theMode :=  QUEUE_MODE;
		endif;
	else
		theMode :=  REAL_MODE;
	endif;
	
	if _yaAgent.numControllers &gt; 1 then
		nextLC := self.getNextControllerOfType(self.class);
//		if self.myNextController = null or not self.myNextController.CM_StackController.isAvailable(_yaAgent.iteration) then
		if nextLC = null or not nextLC.isAvailable(_yaAgent.iteration, null) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,"No suitable next position for 40' container", true);
			return true;
		endif;
	endif;

	if topTi = null then
		return false;
	endif;
	numTopControllers := self.calculateMoveLCs(topTi);

	if numTopControllers &gt; 1 and _yaAgent.numControllers = 1 then
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has a " &amp; topTi.getActualLength().String &amp; "' container in place, cannot be overstowed by " 
										&amp; _yaAgent.myCurrentCMIFYAAutoPlan.getID() &amp; "  as is a " &amp; _yaAgent.myCMIFYAAutoPlan.getMyTrackedItem().getActualLength().String &amp; "'.", true); // PAR 17386
		return true;
	endif;
	if numTopControllers = 1 and _yaAgent.numControllers &gt; 1 then
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has a " &amp; topTi.getActualLength().String &amp; "' container in place, cannot be overstowed by " 
									&amp; _yaAgent.myCurrentCMIFYAAutoPlan.getID() &amp; "  as is a " &amp; _yaAgent.myCMIFYAAutoPlan.getMyTrackedItem().getActualLength().String &amp; "'.", true); // PAR 17386
		return true;
	endif;
	if (_yaAgent.numControllers &gt; 1 and numTopControllers &gt; 1 ) then // and theMode = REAL_MODE then
		if topTi.getPrimaryLocation(theMode) &lt;&gt; self then		//The front end is next door, we must be over the rear end
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " contains the back end of a " &amp; topTi.getActualLength().String &amp; "' container. Containers cannot overlap", true); // PAR 17386
			return true;
		endif;
	endif;
	
	// Do weight range stuff here.
	
	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerLabrRestricted" id="f66e14f4-08d9-484c-bb76-70805f0d4d93">
        <source>testIsControllerLabrRestricted(obj: CMIF_AutoMovePlan input);
//implimented in Yard controller super-class
//Returns true if this LC has a labour restriction.
//If 40' TI, we check next position as well..)
vars
	numControllers : Real;
begin
	if obj.isTestToBeDone(TI_Test_LabourRest, self) = false then
		return;
	endif;

	if obj.myTrackedItem = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI", null, null);
		return;
	endif;
	if hasRestrictions(LABOUR_RESTRICTION) then
		//There is a labour Restriction
		//obj.addVerboseLogEntry("Location has a labour restriction", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Location_labour_restrictio), IsError, Location_labour_restrictio);
		obj.updateController(null);
		return;
	endif;	
	//--------------------
	//No restriction, check next controller....
	//--------------------
	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	if numControllers &gt; 1 and not obj.checkingSecondary then
		if self.myNextController = null then // AKBJULY2002 removed not
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			obj.updateController(null);
			return;	//No next position. 40' cannot go here.
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
			if obj.isAutoPlanMove then
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386
				obj.updateController(null);		
			endif;
			return;
		endif;
		//-------------
		//Recursive call, on next controller
		//-------------
		obj.checkingSecondary := true;
		self.myNextController.testIsControllerLabrRestricted(obj);				
		obj.checkingSecondary := false;
		if 	obj.getController = null then	//There is a restriction!
			return;
		else
			// Par 7523 DVB changed 15th June
			// Set controller back to primary location.
			obj.updateController(self);
		endif;
	else
		if not obj.checkingSecondary then		//AJA 2/12/99: added to plug hole
			obj.updateController(self);
		endif;
	endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerLocnRestricted" id="793fd857-7617-459d-ad0f-57341c50dab4">
        <source>testIsControllerLocnRestricted(obj: CMIF_AutoMovePlan input);
//NOTE: ***** implimented in Yard Controller super-class
//Returns true if this LC has a labour restriction.
//If 40' TI, we check next position as well..)
vars
	numControllers : Real;
begin

	if not app.myPassport.myTerminal.isAutoPlanUserRestrictions() then		//SFW1030 31/10/2008
		return;
	endif;
	
	if not obj.isTestToBeDone(TI_Test_LocnRest, self) then
		return;
	endif;


	obj.updateController(null);

	if obj.myTrackedItem = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI", null, null);
		return;
	endif;

	sharedLock(obj.myTrackedItem);
	if self.myLocationRestriction = null then
		numControllers := self.calculateMoveLCs(obj.myTrackedItem);
		//Nothing here, check next controller....
		if numControllers &gt; 1 and not obj.checkingSecondary then
			if self.myNextController = null then // AKBJULY2002 removed not
				obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
		
				return;	//No next position. 40' cannot go here.
			endif;
			if self.myNextController.isSuitableForTI(obj) = false then
				//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
				if obj.isAutoPlanMove then
					obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386		
				endif;
				return;
			endif;
			//-------------
			//Recursive call, on next controller
			//-------------
			obj.checkingSecondary := true;
			self.myNextController.testIsControllerLocnRestricted(obj);
			obj.checkingSecondary := false;
			if 	obj.getController = null then	//There is a restriction!
				return;
			else
				// Par 7523 DVB changed 15th June
				// Set controller back to primary location.
				obj.updateController(self);
			endif;
		else
			//Nothing here, set this LC as a possible candidate.
			obj.updateController(self);
		endif;
		return;
	endif;
	//----------------
	//There is a location Restriction
	//We must now check that the TI we have can visit here...
	//----------------
	if (not obj.myTrackedItem.isCompatibleWithRestriction(self.myLocationRestriction, obj)) then
		obj.updateController(null);
		return;
	endif;

	//Candidate..
	if (not obj.checkingSecondary) then		//AJA 2/12/99: Added to plug hole
		obj.updateController(self);
	endif;
epilog
	unlock(obj.myTrackedItem);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffCmdtyGroup" id="b05b449f-e285-46b9-acc3-761ec1c322d2">
        <source>testIsDiffCmdtyGroup(obj: CMIF_AutoMovePlan input);
//In this case, we are testing 40' next LC as well as this LC.
//ASSUMPTIONS:
//That testIsControllerFull method has been called (it checks for differing heights)
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	topTI : CM_TrackedItem;
	tmpMoveMode : Integer;
	numControllers : Real;
begin

	if obj.isTestToBeDone(TI_Test_CommodityGroup, self) = false then
		return;
	endif;
	obj.updateController(null);
 	//----------------
 	//Call method to retrieve the topmost TI
 	//----------------
	topTI := getTopTI(obj.moveMode);	

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := getTopTI(tmpMoveMode);	
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;

	if not obj.myTrackedItem.hasSameUnderStowAttribute(topTI, TI_Test_CommodityGroup) then
		//obj.addVerboseLogEntry("Commodity Group of item underneath is different", IsWarning, 0); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Commod_group_item_undern_diffe), IsWarning, Commod_group_item_undern_diffe);
		return;
	endif;
	//-------------
	//Check 40'
	//-------------
	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	if numControllers &gt; 1 and not obj.checkingSecondary then
		if  self.myNextController = null then // AKBJULY2002 removed not
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			return;	//No next position. 40' cannot go here.
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
			if obj.isAutoPlanMove then
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386
			endif;
			return;
		endif;
		obj.checkingSecondary := true;
		self.myNextController.testIsDiffCmdtyGroup(obj);		
		obj.checkingSecondary := false;
		if obj.getController = null then
			//----------------
			//Next commodityGroup is incorrect
			//----------------
			return;
		endif;
	endif;
	//----------------
	//commodityGroup is same.
	//----------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
