    <JadeMethod name="mnuGridSelectAreas_click" id="bdaca29e-46a0-4254-b156-76bf6705ecf2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridSelectAreas_click(menuItem: MenuItem input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	app.mousePointer	:=	Busy;
