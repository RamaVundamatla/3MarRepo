/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2015	cnwma1	Initial creation

*/

vars
		total 	: Integer;
begin
	total := self.quantity;
	return total;
epilog

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6634308d-4c3d-40ca-b694-277fe69b0ffc">
        <source>getDisplayStringForAttribute(_attrName : String; _short : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
08 Jan 2010	cnwml2
16 Jun 2022	navdap1	 TFS 53362 EUP Master Data interface customers between TOS and ERP
28 Oct 2022	navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
28 Nov 2022	jlizm1	 TFS 55280 Harmonized System Codes
20 Apr 2023 navma1	 Defect 57662: MTN - WO - BOL summary details are missing on the Items tab
18 Dec 2024 navbs1	 Bug MTN-33650: CUX - Missing Additional Remarks pop up When Gated in Booking Item without reviewing cargo individually
*/

vars
	type 		: String;					
	str			: String;					
	measureType : CM_MeasurementType; 
	iConsign 	: CM_ConsigneeConsignor;
	root		: CM_Root;
	
begin
	if 	_attrName = ETRow_PickerRelReqRemarks1 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerRelReqRemarks2 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerCargoRemarks1 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerCargoRemarks2 then			//18.12.2024 navbs1 #33650
		return null;
		
	elseif _attrName = ETRow_BolNumber or 
	   _attrName = ETRow_Bol then
		if self.myBOL &lt;&gt; null then												
			return self.myBOL.number;
		endif;
		return null;
	
	elseif _attrName = ETRow_CargoTypeDesc or 
		   _attrName = ETRow_CargoType then
		return self.cargoTypeDescr;
	
	elseif _attrName = ETRow_Colour then
		return self.colour;
	
	elseif _attrName = ETRow_Mark or 
			_attrName = ETRow_Marks then		
		return self.markNumber;
	
	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	
	elseif _attrName = ETRow_WeightTotal or 
		   _attrName = ETRow_Weight then
		measureType := app.getDefaultMeasurementForType(Type_Weight);	
		if self.myCargoType &lt;&gt; null then	
			measureType := self.myCargoType.getMeasurementTypeFor(Type_Weight,true);
		endif;
		if self.weight &lt;= 0 then
			return null;
		elseif measureType &lt;&gt; null then
			return app.convertMeasurementForDisplay(measureType.shortName, self.weight) &amp; " " &amp; measureType.shortName;
		else
			return self.weight.asStringMeasurementJMT;
		endif;
	
	elseif _attrName = ETRow_LengthCode or 
		   _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();
	
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();
	
	elseif _attrName = ETRow_Height then
		return self.height.asStringMeasurementJMT();
	
	elseif _attrName = ETRow_NumItems or 
		   _attrName = ETRow_NumberOfItems  or 
		   _attrName = ETRow_Items then
		return self.quantity.asStringJMT();
	
	elseif _attrName = ETRow_Consignee or 
		   _attrName = ETRow_ConsigneeCode then
		
		//TFS#53362 navsp1 20Jun2022
		root := app.myRoot;
		if root.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := root.allConsigneeConsignors[self.consigneeCode];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consigneeCode;
	
	elseif _attrName = ETRow_Consignor or 
		   _attrName = ETRow_ConsignorCode then
		
		//TFS#53362 navsp1 20Jun2022
		root := app.myRoot;
		if root.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := root.allConsigneeConsignors[self.consignorCode];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consignorCode;
	
	elseif _attrName = ETRow_Remark then
		return self.remarks;
	
	elseif _attrName = ETRow_NumOnsiteTIs then
		return self.allTrackedItems.size.asStringJMT();
	
	elseif _attrName = ETRow_Reconciled then
		if self.myBOL &lt;&gt; null then													// 15/10/2010 cnwmh5 #26057
			if self.myBOL.reconciledDate &lt;&gt; null then
				return "Yes";
			else
				return "No";
			endif;
		endif;
		return null;
	
	elseif _attrName = ETRow_QuantityRemaining then
		return (self.quantity - self.getTotalCargoItems()).asStringJMT();			//cnwmc5 - 20 May 2014 - PAR 34185
	
	elseif _attrName = ETRow_VoyageCode or 
		   _attrName = ETRow_Voyage then
		if self.myBOL &lt;&gt; null and self.myBOL.CM_BOLIn.myVoyage &lt;&gt; null then			// 15/10/2010 cnwmh5 #26057
			return self.myBOL.CM_BOLIn.myVoyage.code;
		endif;
		if _attrName = ETRow_Voyage then	//15 Mar 2017	NDL	TFS 3758
			return "N/A";
		endif;
		return null;
	
	elseif _attrName = ETRow_OperatorCode or 
		   _attrName = ETRow_Operator then
		if  self.myBOL &lt;&gt; null and self.myBOL.myOperator &lt;&gt; null then				
			if _attrName = ETRow_Operator and app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return self.myBOL.myOperator.description;												// TFS 53362
			else																						// TFS 53362
				return self.myBOL.myOperator.code;
			endif;																						// TFS 53362
		endif;
		if _attrName = ETRow_Operator then	//15 Mar 2017	NDL	TFS 3758
			return "N/A";
		endif;
		return null;
	
	elseif _attrName = ETRow_StatusDesc then
		if self.myBOL &lt;&gt; null then													
			return self.myBOL.statusDescription;
		endif;
		return null;
	
	elseif _attrName = ETRow_Volume then
		measureType := app.getDefaultMeasurementForType(Type_Volume);	
		if self.myCargoType &lt;&gt; null then	
			measureType := self.myCargoType.getMeasurementTypeFor(Type_Volume,true);
		endif;
		if self.volume &lt;= 0 then
			return null;
		elseif measureType &lt;&gt; null and self.volume &gt; 0 then
			return app.convertMeasurementForDisplay(measureType.shortName, self.volume) &amp; " " &amp; measureType.shortName;
		else
			return self.volume.asStringMeasurementJMT;
		endif;
	
	elseif _attrName = ETRow_Received then
		return self.getNumReceived.asStringJMT;
	
	elseif _attrName = ETRow_Released then
		return self.getNumReleased.asStringJMT;
	
	elseif _attrName = ETRow_CargoItems then										
		return self.getTotalCargoItems().asStringJMT();								
	
	elseif _attrName = ETRow_Detail then	//15 Mar 2017	NDL	TFS 3758
		return self.getShortDisplay;
	
	elseif _attrName = ETRow_DateTime then	//15 Mar 2017	NDL	TFS 3758
		if self.myBOL &lt;&gt; null then
			return self.myBOL.dateTime.asStringJMT();
		endif;
		return null;
	
	elseif _attrName = ETRow_PickerType then	//06 Oct 2020	NDL TFS 49189
		return 'BOL Detail';
	
	elseif _attrName = ETRow_ItemId then			//06 Oct 2020	NDL TFS 49189
		if self.myBOL &lt;&gt; null then
			if self.myBOL.getMyVoyage &lt;&gt; null then
				return self.myBOL.getMyVoyage.code &amp; " " &amp; self.myBOL.number;
			else
				return self.myBOL.number;
			endif;
		endif;
		return null;
	
	elseif _attrName = ETRow_CargoId then			//06 Oct 2020	NDL TFS 49189
		return null;
	
	elseif _attrName = ETRow_PickerDescription then	//06 Oct 2020	NDL TFS 49189
		return self.getPickerDescription();
	
	elseif _attrName = ETRow_Prenoted then			//06 Oct 2020	NDL TFS 49189
		return null;
	
	elseif _attrName = ETRow_ExtraCriteriaDisp then	
		return self.getExtraCriteria();
	
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	
	elseif _attrName = ETRow_HsCode then				// TFS 55280
		return self.getHSCode();
	
	elseif _attrName = ETRow_HsCodeDescription then		// TFS 55280
		return self.getHSDescription();
	
	elseif _attrName = ETRow_DestinationPort then		//20.04.2023 navma1 #57662
		if self.myBOL &lt;&gt; null then
			return self.myBOL.destinationPort;	
		endif;
		return null;
	elseif _attrName.isMeasurementType then											
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);				
	
	else
		inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraCriteria" id="c5eef24c-1011-4188-b551-8ce8d83024a4">
        <source>getExtraCriteria():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2020	jlgndl1	Initial creation	TFS 49189 - For display on the picker

*/

vars

	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	vol : Decimal[16,4];
	wt : Decimal[16,4];
	qty : Integer;
	siteVol : Decimal[16,4];
	siteWt : Decimal[16,4];
	siteQty : Integer;
	shipVol : Decimal[16,4];
	shipWt : Decimal[16,4];
	shipQty : Integer;
	retValue : String;
	

begin

	create tiSet transient;

	if not self.allTrackedItems.isEmpty then
		self.allTrackedItems.copy( tiSet );
		
	elseif self.myBOL &lt;&gt; null and not self.myBOL.allTrackedItems.isEmpty then
		foreach ti in self.myBOL.allTrackedItems do
			if self.cargoType &lt;&gt; null and ti.cargoType &lt;&gt; self.cargoType then
				continue;
			endif;
			if self.colour &lt;&gt; null and ti.getColour &lt;&gt; self.colour then
				continue;
			endif;
			if self.commodity &lt;&gt; null and ti.commodity &lt;&gt; self.commodity then
				continue;
			endif;
			if self.markNumber &lt;&gt; null and ti.markNumber &lt;&gt; self.markNumber then
				continue;
			endif;
			tiSet.add( ti );
		endforeach;
		
	else
		return null;
		
	endif;
	
	foreach ti in tiSet do
		vol := 0;
		wt := 0;
		qty := 0;
		if ti.isBulkByVolume then
			vol := ti.totalVolume;
		elseif ti.isBulkByWeight then
			wt := ti.totalWeight;
		else
			qty := ti.totalQuantity;
		endif;
		if ti.isOnSite then
			siteVol := siteVol + vol;
			siteWt := siteWt + wt;
			siteQty := siteQty + qty;
		elseif ti.isOnShip then
			shipVol := shipVol + vol;
			shipWt := shipWt + wt;
			shipQty := shipQty + qty;
		endif;
	endforeach;
	
	
	if siteQty &gt; 0 or shipQty &gt; 0 then
		if siteQty &gt; 0 then
			retValue := app.getErrorString(INV_On_Site) &amp; " x" &amp; siteQty.String;
		endif;
		if shipQty &gt; 0 then
			if retValue &lt;&gt; null then
				retValue:= retValue &amp; ", ";
			endif;
			retValue := retValue &amp; app.getErrorString(INV_On_Ship) &amp; " x" &amp; shipQty.String;
		endif;
		
	elseif siteVol &gt; 0 or shipVol &gt; 0 then
		if siteVol &gt; 0 then
			if self.myCargoType &lt;&gt; null then
				retValue := app.getErrorString(INV_On_Site) &amp; " " &amp; self.myCargoType.getConvertedVolumeDisplay( siteVol, true );
			else
				retValue := app.getErrorString(INV_On_Site) &amp; " " &amp; siteVol.asStringMeasurementJMT &amp; "m3";
			endif;
		endif;
		if shipVol &gt; 0 then
			if retValue &lt;&gt; null then
				retValue:= retValue &amp; ", ";
			endif;
			if self.myCargoType &lt;&gt; null then
				retValue := app.getErrorString(INV_On_Ship) &amp; " " &amp; self.myCargoType.getConvertedVolumeDisplay( shipVol, true );
			else
				retValue := app.getErrorString(INV_On_Ship) &amp; " " &amp; shipVol.asStringMeasurementJMT &amp; "m3";
			endif;
		endif;
		
	elseif siteWt &gt; 0 or shipWt &gt; 0 then								
		if siteWt &gt; 0 then
			if self.myCargoType &lt;&gt; null then
				retValue := app.getErrorString(INV_On_Site) &amp; " " &amp; self.myCargoType.getConvertedWeightDisplay( siteWt, true );
			else
				retValue := app.getErrorString(INV_On_Site) &amp; " " &amp; siteWt.asStringMeasurementJMT &amp; "kg";
			endif;
		endif;
		if shipWt &gt; 0 then
			if retValue &lt;&gt; null then
				retValue:= retValue &amp; ", ";
			endif;
			if self.myCargoType &lt;&gt; null then
				retValue := app.getErrorString(INV_On_Ship) &amp; " " &amp; self.myCargoType.getConvertedWeightDisplay( shipWt, true );
			else
				retValue := app.getErrorString(INV_On_Ship) &amp; " " &amp; shipWt.asStringMeasurementJMT &amp; "kg";
			endif;
		endif;
		
	endif;
	
	return retValue;
	
epilog

	delete tiSet;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="57440907-e634-40ee-8789-1ba04a258fd9">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//25 January 2010	cnwml2


vars

	block : CM_DataContainerBlock;
	
	portStr,
	hazStr	: String;
	tmpStr : String;

begin
	inheritMethod(_dataContainer);

	if self.myBOL &lt;&gt; null then												// 15/10/2010 cnwmh5 #26057
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(BOLNumber), DC_Label, 1, null);
		block.addNewItem(self.myBOL.number, DC_Data, 1, null);
		
		if self.myBOL.myOperator &lt;&gt; null then								// 15/10/2010 cnwmh5 #26057
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Operator), DC_Label, 1, null);
			block.addNewItem(self.myBOL.myOperator.code, DC_Data, 1, null);
		endif;
		
		if self.myBOL.CM_BOLIn.myVoyage &lt;&gt; null then						// 15/10/2010 cnwmh5 #26057
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Voyage), DC_Label, 1, null);
			block.addNewItem(self.myBOL.CM_BOLIn.myVoyage.code, DC_Data, 1, null);
		endif;
		
		if self.myBOL.myNotifyParty &lt;&gt; null then							// 15/10/2010 cnwmh5 #26057
			block := _dataContainer.addNewBlock;
			block.addNewItem("Nofity Party", DC_Label, 1, null);
			block.addNewItem(self.myBOL.myNotifyParty.code, DC_Data, 1, null);
		endif;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(CargoType), DC_Label, 1, null);
	block.addNewItem(self.cargoTypeDescr, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Colour), DC_Label, 1, null);
	block.addNewItem(self.colour, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Marks), DC_Label, 1, null);
	block.addNewItem(self.markNumber, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Commodity), DC_Label, 1, null);
	block.addNewItem(self.commodity, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Weight), DC_Label, 1, null);
	block.addNewItem(self.weight.asStringMeasurementJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Volume), DC_Label, 1, null);
	block.addNewItem(self.volume.asStringMeasurementJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Length), DC_Label, 1, null);
	block.addNewItem(self.length.asStringMeasurementJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Width), DC_Label, 1, null);
	block.addNewItem(self.width.asStringMeasurementJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Height), DC_Label, 1, null);
	block.addNewItem(self.height.asStringMeasurementJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(NumberOfItems), DC_Label, 1, null);
	block.addNewItem(self.quantity.asStringJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Consignee), DC_Label, 1, null);
	block.addNewItem(self.consigneeCode, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Consignor), DC_Label, 1, null);
	block.addNewItem(self.consignorCode, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Remarks), DC_Label, 1, null);
