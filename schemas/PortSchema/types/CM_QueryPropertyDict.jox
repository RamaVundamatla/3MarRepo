<CollClass name="CM_QueryPropertyDict" id="361a995b-7c5d-4c03-be15-39eee6f9337f">
    <memberType name="CM_QueryProperty"/>
    <superclass name="CM_QueryDicts"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <MemberKey>
        <property name="CM_QueryProperty::propertyName"/>
    </MemberKey>
    <JadeMethod name="getPropByNiceName" id="750f47b7-afb1-46bb-aa13-e321b268b024">
        <source>getPropByNiceName( _niceName : String ):CM_QueryProperty;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

	iter : Iterator;
	qProp : CM_QueryProperty;
	
begin

	iter := self.createIterator;
	while iter.next( qProp ) do
		if qProp.niceName = _niceName then
			return qProp;
		endif;
	endwhile;
	
	return null;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_niceName" type="String"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
</CollClass>
