    <JadeMethod name="populateFooter" id="40ed313f-0a94-4023-a06d-ec9c8636e622">
        <source>populateFooter( _doLayoutCheck : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwndl1	Initial creation Par 36777

*/

vars

	parentWidth : Real;
	frame : CMUI_Frame;
	
	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;

begin

	frame := self.frmFooter;
	frame.left := self.frmSect1.left;
	frame.width := self.frmSect1.width;

	parentWidth := frame.width - 2;

//	if _doLayoutCheck then
//		frame.borderStyle := 1;
//		frame.caption := frame.name &amp; "@" &amp; leftMMs.String &amp; "," &amp; topMMs.String &amp; "-" &amp; rightMMs.String &amp; "," &amp; bottomMMs.String &amp; "mm";
//	else
		frame.caption := null;
		frame.borderStyle := 0;	
//	endif;
	
	self.lblChecked.top := 1;
	self.lblChecked.left := 1;
	
	self.lblDashLine.top := 10 * self.pixelsPerMM;
	self.lblDashLine.left := 1;
	self.lblDashLine.height := 4 * self.pixelsPerMM;
	
	self.lblDist.top := 14 * self.pixelsPerMM;
	self.lblDist.left := 1;
	self.lblDist.width := parentWidth;
	
	self.frmFooter.height := self.lblDist.top + self.lblDist.height + 5;
	self.frmFooter.top := self.frmMain.height - self.frmFooter.height - 1;
	
epilog

end;</source>
        <Parameter name="_doLayoutCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateSect1" id="66498f2c-705a-48fe-8af5-21bfdff067af">
        <source>populateSect1( _doLayoutCheck : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwndl1	Initial creation Par 36777

*/

vars

	parentWidth : Real;
	
	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;
	
	topPixels : Real;
	heightPixels : Real;
	
	vTop : Real;
	vLeft : Real;
	vWidth : Real;
	vHeight : Real;
	
	frame : CMUI_Frame;

begin

	frame := self.frmSect1;

	topMMs := 58;
	bottomMMs := 71;
	leftMMs := 12;
	rightMMs := 192;
	
	vTop := ( topMMs - self.frameTopOffset ) * self.pixelsPerMM;
	vLeft := ( leftMMs - self.frameLeftOffset ) * self.pixelsPerMM;
	vWidth := ( rightMMs - leftMMs ) * self.pixelsPerMM;
	vHeight := ( bottomMMs - topMMs ) * self.pixelsPerMM;

	frame.move( vLeft, vTop, vWidth, vHeight );
	
//	if _doLayoutCheck then
//		frame.borderStyle := 1;
//		frame.caption := frame.name &amp; "@" &amp; leftMMs.String &amp; "," &amp; topMMs.String &amp; "-" &amp; rightMMs.String &amp; "," &amp; bottomMMs.String &amp; "mm";
//	else
		frame.caption := null;
		frame.borderStyle := 0;	
//	endif;

//	if not _doLayoutCheck then
		self.lblWaybill.caption := self.myWaybillPrintDetail.titleStr;
		self.lbl1.caption := self.myWaybillPrintDetail.waybillNumberStr;
		self.lbl2.caption := self.myWaybillPrintDetail.waybillDateStr;
		self.lbl32.caption := self.myWaybillPrintDetail.printDateTimeStr;
		self.lblPageNo.caption := "Page 1 of " &amp; pageCount.String;
//	endif;

	parentWidth := frame.width - 1;

	self.lblCustCopy.top := 0;
	self.lblCustCopy.left := parentWidth - self.lblCustCopy.width;
	
	self.lblWaybill.top := 0;
	self.lblWaybill.left := 1;
	
	self.lblWaybillNo.top := self.lblCustCopy.top + self.lblCustCopy.height + 1;
	topPixels := self.lblWaybillNo.top;
	heightPixels := self.lblWaybillNo.height;
	leftMMs := 141;
	rightMMs := 179;
	self.moveDataLabel( self.frmSect1, self.lbl1, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	self.lblWaybillNo.left := self.lbl1.left - self.lblWaybillNo.width;
	
	self.lblWaybillDate.top := self.lblWaybillNo.top + self.lblWaybillNo.height + 1;
	topPixels := self.lblWaybillDate.top;
	heightPixels := self.lblWaybillDate.height;
	leftMMs := 141;
	rightMMs := 179;
	self.moveDataLabel( self.frmSect1, self.lbl2, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	self.lblWaybillDate.left := self.lbl2.left - self.lblWaybillDate.width;
	
	self.lblPageNo.top := self.lblWaybillDate.top + self.lblWaybillDate.height + 1;
	self.lblPageNo.left := 1;
	
	self.lblPrintDate.top := self.lblPageNo.top;
	topPixels := self.lblPrintDate.top;
	heightPixels := self.lblPrintDate.height;
	leftMMs := 141;
	rightMMs := 179;
	self.moveDataLabel( self.frmSect1, self.lbl32, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	self.lblPrintDate.left := self.lbl32.left - self.lblPrintDate.width;
	
	frame.height := lblPrintDate.top + lblPrintDate.height + 1;
	
	self.frmSect2.top := frame.top + frame.height;
	self.frmSect2.left := frame.left;
	self.frmSect2.width := frame.width;
	
epilog

end;</source>
        <Parameter name="_doLayoutCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateSect2" id="87d0f844-48d9-43a3-a8d3-d32e61ae3ce1">
        <updating/>
        <source>populateSect2( _doLayoutCheck : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwndl1	Initial creation Par 36777

*/

vars

	parentWidth : Real;
	frame : CMUI_Frame;
	
	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;
	
	topPixels : Real;
	heightPixels : Real;
	
	adjustedHeight : Real;
	commonMaxHeight : Real;

begin

	frame := self.frmSect2;
	parentWidth := frame.width - 1;

//	if _doLayoutCheck then
//		frame.borderStyle := 1;
//		frame.caption := frame.name &amp; "@" &amp; leftMMs.String &amp; "," &amp; topMMs.String &amp; "-" &amp; rightMMs.String &amp; "," &amp; bottomMMs.String &amp; "mm";
//	else
		frame.caption := null;
		frame.borderStyle := 0;	
//	endif;
	
//	if not _doLayoutCheck then
		self.lbl3.caption := myWaybillPrintDetail.consigneeStr;
		self.lbl4.caption := myWaybillPrintDetail.debtorLongNameStr;
		self.lbl5.caption := myWaybillPrintDetail.vesselStr;
		self.lbl6.caption := myWaybillPrintDetail.rotationNumberStr;
		self.lbl7.caption := myWaybillPrintDetail.releaseDateStr;
		self.lbl8.caption := myWaybillPrintDetail.billOfLadingNumberStr;
		self.lbl9.caption := myWaybillPrintDetail.vesselArrivalDateStr;
		self.lbl10.caption := myWaybillPrintDetail.deliveryOrderNumberStr;
//	endif;
	
	self.lblLine2.left := 1;
	self.lblLine2.width := parentWidth;
	self.lblLine2.top := -10;
	
	self.lblConsignee.top := 2;
	self.lblConsignee.left := 1;
	
	self.lblAgent.top := 2;
	self.lblAgent.left := 80 * self.pixelsPerMM;
	
	topPixels := self.lblConsignee.top + self.lblConsignee.height + 1;
	heightPixels := self.lblConsignee.height; // initial height
	leftMMs := 1;
	rightMMs := 79;
	self.moveDataLabel( frame, self.lbl3, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl3);
	commonMaxHeight := adjustedHeight;
	
	leftMMs := 80;
	rightMMs := 179;
	self.moveDataLabel( frame, self.lbl4, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl4);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	
	self.lblVessel.top := self.lbl3.top + commonMaxHeight + 1;
	self.lblVessel.left := 1;
	
	self.lblRotation.top := self.lblVessel.top;
	self.lblRotation.left := self.lblAgent.left;
	
	self.lblRelDate.top := self.lblVessel.top;
	self.lblRelDate.left := parentWidth - self.lblRelDate.width;
	
	topPixels := self.lblVessel.top + self.lblVessel.height + 1;
	heightPixels := self.lblVessel.height; // initial height
	leftMMs := 1;
	rightMMs := 79;
	self.moveDataLabel( frame, self.lbl5, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl5);
	commonMaxHeight := adjustedHeight;
	
	leftMMs := 80;
	rightMMs := 130;
	self.moveDataLabel( frame, self.lbl6, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl6);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	leftMMs := 131;
	rightMMs := 179;
	self.moveDataLabel( frame, self.lbl7, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Right_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl7);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	
	
	self.lblBolNum.top := self.lbl5.top + commonMaxHeight + 1;
	self.lblBolNum.left := 1;
	
	self.lblVessArrDate.top := self.lblBolNum.top;
	self.lblVessArrDate.left := self.lblAgent.left;
	
	self.lblDelNo.top := self.lblBolNum.top;
	self.lblDelNo.left := parentWidth - self.lblDelNo.width;
	
	topPixels := self.lblBolNum.top + self.lblBolNum.height + 1;
	heightPixels := self.lblBolNum.height; // initial height
	leftMMs := 1;
	rightMMs := 79;
	self.moveDataLabel( frame, self.lbl8, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl8);
	commonMaxHeight := adjustedHeight;
	
	leftMMs := 80;
	rightMMs := 130;
	self.moveDataLabel( frame, self.lbl9, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl9);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	leftMMs := 131;
	rightMMs := 179;
	self.moveDataLabel( frame, self.lbl10, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Right_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl10);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	frame.height := self.lbl8.top + commonMaxHeight + 1;
	
	self.addNewPageFrameIfRequired( frame );
	
	self.frmSect3.top := frame.top + frame.height + 1;
	self.frmSect3.left := frame.left;
	self.frmSect3.width := frame.width;
	
epilog

end;</source>
        <Parameter name="_doLayoutCheck" type="Boolean"/>
    </JadeMethod>
