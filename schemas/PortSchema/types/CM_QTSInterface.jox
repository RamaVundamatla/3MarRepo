    <JadeMethod name="doFtpFile" id="cefe77ed-ad54-4ea3-958b-4022d690b903">
        <source>doFtpFile(_file : File input ;_destName : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/
constants
	EntityCode	: String = "OracleFusionFTP";
vars
	ftp			: CnFtp;
	ftpEntity	: CM_FTPEntity;
	doFtp		: Boolean;
	dest,
	result		: String;
	resultInt	: Integer;
begin
	
	
	ftpEntity := app.myRoot.allFTPEntities[EntityCode];
	
	doFtp := true;
	if ftpEntity = null then
		app.writeLog(method.qualifiedName() &amp; " FTP entity " &amp; EntityCode &amp; " not found", LogINFO);
		doFtp := false;
	endif;
	
	if doFtp then
		create ftp transient;
		ftp.setServerName(ftpEntity.getServerNameForConnect());
		ftp.portNumber := ftpEntity.getPortNumberForConnect();
		ftp.setServerType(ftpEntity.serverType);
		ftp.setUseProxy(ftpEntity.useProxy);
		ftp.setUserId(ftpEntity.userId, ftpEntity.getPwForUse(null));
		ftp.setServerGMTBias(ftpEntity.serverGMTBias);
		ftp.passive := ftpEntity.isPassive;
		ftp.setModeAscii(ftpEntity.mode.Boolean);
		
		result := ftp.cnConnect();
		
		if result &lt;&gt; CN_OK then
			app.writeLog(method.qualifiedName() &amp; " FTP error connecting to " &amp; ftp.serverName &amp; ": " &amp; result, LogINFO);
			doFtp := false;
		else
			if ftpEntity.destinationDirectory &lt;&gt; null then
				resultInt := ftp.emFtpSetCurrentDirectory(ftp.connectionHandle, ftpEntity.destinationDirectory);
				if resultInt &lt;&gt; 0 then
					app.writeLog(method.qualifiedName() &amp; " Unable to set current directory on FTP site to " &amp; ftpEntity.destinationDirectory &amp; ". " &amp; ftp.cnGetInternetError(resultInt), LogINFO);
				endif;
			endif;
		endif;

		ftp.setServerName(ftpEntity.getServerNameForConnect());
		ftp.portNumber := ftpEntity.getPortNumberForConnect();
		ftp.setServerType(ftpEntity.serverType);
		ftp.setUseProxy(ftpEntity.useProxy);
		ftp.setUserId(ftpEntity.userId, ftpEntity.getPwForUse(null));
		ftp.setServerGMTBias(ftpEntity.serverGMTBias);
		ftp.passive := ftpEntity.isPassive;
		ftp.setModeAscii(ftpEntity.mode.Boolean);
	endif;
	
	if doFtp then
		//result := ftp.cnPutFile(_file.fileName, _file.fileName, false, false);
		result := ftp.cnPutFile(_file.fileName, _destName, false, false);
		if result = CN_OK then
			app.writeLog(method.qualifiedName() &amp; " File " &amp; _file.fileName &amp; " transferred to " &amp; ftpEntity.serverName, LogINFO);
			_file.emDeleteFile(_file.fileName);
		else
			app.writeLog(method.qualifiedName() &amp; " FTP transfer error: " &amp; result, LogINFO);
		endif;
	endif;
	

	
epilog
	if ftp &lt;&gt; null then
		ftp.cnCloseConnection();
		delete ftp;
	endif;
	
	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_destName" type="String"/>
    </JadeMethod>
    <JadeMethod name="export" id="633496c8-58a1-49d3-8c1c-a6c831e927b1">
        <updating/>
        <source>export(_invoice: CM_Invoice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	file 	    : File;
	folder  	: FileFolder;
	destName    : String;
begin
	if _invoice.debtor.isRDT() then
		return;
	endif;
	
	create folder ;
	create file   ;
	destName := self.filePrepare(_invoice,file,folder,"-1");
	self.createInvoiceLine1(file,_invoice);
	self.doFtpFile(file,destName );
	self.fileReset(file,false,folder);
	
	create folder ;
	create file   ;
	destName := self.filePrepare(_invoice,file,folder,"-2");
	self.createInvoiceLine2(file,_invoice);
	self.doFtpFile(file,destName );
	
	_invoice.incrementExportCount(false);	
epilog

	self.fileReset(file,false,folder);
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
