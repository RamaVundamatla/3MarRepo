    <JadeMethod name="getFutureMoveOfType" id="5dff2de4-a91d-419a-b900-22bfc40d963c">
        <source>getFutureMoveOfType(moveMode : Integer; moveType : Integer) : CM_FutureMove;
/*
------------------------------------------------------------------------
Created:			04 December 2002 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
*/
vars
	move : CM_FutureMove;
	coll : CM_FutureMoveArray;
begin
	if moveMode = PLANNING_MODE then
		coll := self.allPlannedFutureMoves;
	elseif moveMode = QUEUE_MODE then
		coll := self.allQueuedFutureMoves;
	endif;
	if coll = null then
		return null;
	endif;
	foreach move in coll where move.moveType = moveType do
		return move;
	endforeach;
	
	return null;

end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="moveType" type="Integer"/>
        <ReturnType type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="getFutureMoveOfTypeForTI" id="1b489a74-201c-447b-90e0-43d213a17a9f">
        <source>getFutureMoveOfTypeForTI(moveMode : Integer; moveType : Integer; _ti : CM_TrackedItem ) : CM_FutureMove;
/*
------------------------------------------------------------------------
Created:			04 December 2002 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	move : CM_FutureMove;
	coll : CM_FutureMoveArray;
begin
	if moveMode = PLANNING_MODE then
		coll := self.allPlannedFutureMoves;
	elseif moveMode = QUEUE_MODE then
		coll := self.allQueuedFutureMoves;
	endif;
	if coll = null then
		return null;
	endif;
	foreach move in coll do
		if moveType = TI_FutureMovePlannedOrDLR then
			//Special case, we check for both statuses.
			if move.moveType &lt;&gt; TI_FutureMoveDLRLoad
			and move.moveType &lt;&gt; TI_FutureMoveDLRDischarge
			and move.moveType &lt;&gt; TI_FutureMovePlanned then
				continue;
			endif;
			if move.containsTrackedItem(_ti) then
				return move;
			endif;
		else
			if	move.moveType &lt;&gt; moveType then
				continue;
			endif;
			if move.containsTrackedItem(_ti) then
				return move;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="moveType" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="getFutureMoveTIOfType" id="d237a172-1c42-4003-9067-0901b37a66ab">
        <source>getFutureMoveTIOfType(moveMode : Integer; moveType : Integer ) : CM_TrackedItem;
/*
------------------------------------------------------------------------
Created:			04 December 2002 by cnwdwq1
Purpose:			Returns the first TI for the future move mode/type passed in.
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	move : CM_FutureMove;
	coll : CM_FutureMoveArray;
begin
	if moveMode = PLANNING_MODE then
		coll := self.allPlannedFutureMoves;
	elseif moveMode = QUEUE_MODE then
		coll := self.allQueuedFutureMoves;
	endif;
	if coll = null then
		return null;
	endif;
	foreach move in coll where move.moveType = moveType do
		return move.getTrackedItem;
	endforeach;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="moveType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
