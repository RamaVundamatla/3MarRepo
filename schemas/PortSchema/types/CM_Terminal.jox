    <JadeMethod name="getAvailableCompanies" id="bd508dd9-076b-4abc-8505-026e6a31f576">
        <source>getAvailableCompanies(_companies : CM_CompanyByCodeDict input) : CM_Bank;
// 35872 add all non-suspended business units to the collection and return the default one.
//	Used to populate the list of business units on the invoice forms to replace the app current business unit.
vars
	co	: CM_Bank;
begin
	foreach co in self.companies where co.isBusinessUnit and 
			(not co.isSuspended) do
		_companies.add(co);
	endforeach;

	return self.getDefaultCompanyBank();
end;
</source>
        <Parameter name="_companies" type="CM_CompanyByCodeDict" usage="input"/>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getBOLInByNumber" id="bd00926e-7f8f-4a79-830f-a437940171d7">
        <source>getBOLInByNumber(_bolNumber : String; _bolType: Integer) :CM_BOLIn;
// ---------------------------------------------------------------------------
// Created:	01 October 2008 By Graeme Black cnwgb1
// Status: 	Unit tested by cnwsh3 
//          Added check in if statement to confirm the theBOL is not null
// Purpose:	CCMS SFW 1012  Customs AMS  Processing
// 28/02/2017 cnwma1 TFS #3599:PAR38644 C3 - CreateLogDocket WebService
// 12 Jan 2026 navhl20 Bug MTN-36816: PEN | Webportal timing out when searching by BOL
// ---------------------------------------------------------------------------
vars
	bolDict	: CM_BOLByTypeNumberDTDict;
	iter : Iterator;
	theBOL,bol: CM_BOLIn;
	checkPeriod : Integer;
	today	: Date;
begin
	if _bolNumber = null then
		return null;
	endif;
	
	bolDict := self.allBOLsReceivedByTypeNumberDT;
	//28/02/2017 cnwma1 TFS #3599
	checkPeriod := self.getConfig(BOLDuplicateCheckPeriod).Integer;
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType,_bolNumber,null,iter);
	today := app.actualTimeServer.date;											//12.01.2026 navhl20 #36816
	while iter.next(bol) do
		if checkPeriod &lt;&gt; null and bol.dateTime.date &lt; today - checkPeriod then	//12.01.2026 navhl20 #36816
			continue;
		endif;
		if bol.number &lt;&gt; _bolNumber then
			break;
		endif;
		theBOL := bol;
		break;
	endwhile;
	//28/02/2017 cnwma1 TFS #3599
	
	//theBOL := bolDict.getAtKeyGeq(_bolType, _bolNumber, null).CM_BOLIn; //28/02/2017 cnwma1 TFS #3599
	if theBOL &lt;&gt; null and _bolNumber &lt;&gt; theBOL.number then
		return null;
	else
		return theBOL;
	endif;
epilog
delete iter;
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_bolType" type="Integer"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getBOLInByNumberOperator" id="1b2f468d-2b26-466c-8909-06fe8b326695">
        <source>getBOLInByNumberOperator(_bolNumber ,_bolOperator: String; _bolType: Integer) :CM_BOLIn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2017	jlgma1	TFS # 7354 C3 - Urgent - createLogDocket and updateLogDocket webservice returning the wrong JadeOID

*/

vars
	bolDict	: CM_BOLByTypeNumberDTDict;
	iter : Iterator;
	theBOL,bol: CM_BOLIn;
	checkPeriod : Integer;
begin
	if _bolNumber  = null then
		return null;
	endif;
	
	bolDict := self.allBOLsReceivedByTypeNumberDT;
	checkPeriod := self.getConfig(BOLDuplicateCheckPeriod).Integer;
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType,_bolNumber,null,iter);
	while iter.next(bol) do
		if checkPeriod &lt;&gt; null and bol.dateTime.date &lt;app.actualTimeServer.date - checkPeriod then
			continue;
		endif;
		
		if _bolOperator &lt;&gt; null then
			if bol.getOperatorCode.toUpper &lt;&gt; _bolOperator.toUpper then
				continue;
			endif;
		endif;
		
		if bol.number &lt;&gt; _bolNumber then
			break;
		endif;
		theBOL := bol;
		break;
	endwhile;

	if theBOL &lt;&gt; null and _bolNumber &lt;&gt; theBOL.number  then
		return null;
	else
		return theBOL;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_bolOperator" type="String"/>
        <Parameter name="_bolType" type="Integer"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getBOLInByNumberPackCount" id="a3d9e104-c250-4c7a-9700-748aeb515f9a">
        <source>getBOLInByNumberPackCount(_bolNumber : String; _packCount : Integer; _valid :Integer output) : CM_BOLIn;
/*

Purpose:			Created for use in conjunction with changes for PNL TSW DTR 61364.
					Purposefully omitted check period from this method as it could cause PNL unforeseen issues as they do not have this set.

Parameters:			_bolNumber	String	The bol number to search for on the terminal
					_packCount	Integer	The pack count the bol should have

Return Value:		CM_BOLIn	The bol that was found using the parameters passed to the method

Date				Who		Reason
28 November 2023	navpw1	Initial creation TFS: 61364 (61375)
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
*/

vars
	iter						: Iterator;
	bolIn						: CM_BOLIn;
	bolsReceivedByTypeNumberDT	: CM_BOLByTypeNumberDTDict;
	
begin
	if _bolNumber = null then
		return null;
	endif;
	
	bolsReceivedByTypeNumberDT := self.allBOLsReceivedByTypeNumberDT;
	bolIn := bolsReceivedByTypeNumberDT.getAtKeyGeq(BOLType_GeneralBillOfLading, _bolNumber, null).CM_BOLIn;
	iter := bolsReceivedByTypeNumberDT.createIterator;
	bolsReceivedByTypeNumberDT.startKeyGeq(BOLType_GeneralBillOfLading, _bolNumber, null, iter);
	while iter.next(bolIn) do
		if bolIn.number &lt;&gt; _bolNumber then
			break;
		endif;
		
		if bolIn.status = BOL_STATUS_NORMAL and bolIn.allTrackedItems.size = _packCount then
			break;
		endif;
		
	endwhile;
	
	if bolIn = null then
		_valid := 0;				//navsaa30 #35121
		return null;
	endif;
	
	if bolIn.number &lt;&gt; _bolNumber or bolIn.status &lt;&gt; BOL_STATUS_NORMAL then		//navsaa30 #35121
		bolIn := null;
		_valid := 0;
	elseif bolIn.allTrackedItems.size &lt;&gt; _packCount then
		bolIn := null;
		_valid := -1;
	else
		_valid := 1;
	endif;
	
	return bolIn;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_packCount" type="Integer"/>
        <Parameter name="_valid" type="Integer" usage="output"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getBOLInsFromNumber" id="79063228-eb90-4e14-a0f7-d5e9d5165810">
        <source>getBOLInsFromNumber(_bolInSet 	: CM_BOLSet input;
					_bolType 	: Integer;
					_bolNumber 	: String;
					_forwards	: Boolean;
					_dateTime	: TimeStamp);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 August 2008
//
// Implemented version:
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
//----------------------------------------------------------------------
vars
	bolIn				: CM_BOLIn;
	iter				: Iterator;
	bolDict				: CM_BOLByTypeNumberDTDict;
	typeKey				: Integer;
	bolNumKey			: String;
	tsKey				: TimeStamp;
	// Use this only for now...... BOLType_GeneralBillOfLading
	
begin
	if _bolInSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BOLOut set passed in is null');
		return;
	endif;
	
	//bolDict := self.allBOLsReleasedByTypeStatDTNum;
	bolDict := self.allBOLsReceivedByTypeNumberDT;
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType, _bolNumber, _dateTime, iter);
	if not _forwards then
		while iter.back(bolIn) do
			iter.getCurrentKeys(typeKey,bolNumKey,tsKey); //MTN-35226 
			
			//no need to check timeSamp key because we're looping backwards
			if typeKey &lt;&gt; _bolType then 
				break;
			endif;
			
			if not bolNumKey.startsWith(_bolNumber) then
				break;
			endif;
		
			_bolInSet.add(bolIn);
		endwhile;
		
	else
		while iter.next(bolIn) do
			iter.getCurrentKeys(typeKey,bolNumKey,tsKey);  //MTN-35226 
			
			if typeKey &lt;&gt; _bolType then
				break;
			endif;
			
			if  not bolNumKey.startsWith(_bolNumber) then 
				break;
			endif;
			
			_bolInSet.add(bolIn);
		endwhile;
	endif;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_bolInSet" type="CM_BOLSet" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_forwards" type="Boolean"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBOLOutsFromNumber" id="c6bd604f-c99a-4625-912a-55fde27fa01d">
        <source>getBOLOutsFromNumber(_bolOutSet : CM_BOLSet input;
					_bolType 	: Integer;
					_bolNumber 	: String;
					_forwards	: Boolean;
					_dateTime	: TimeStamp);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 August 2008
//
// Implemented version:
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
//----------------------------------------------------------------------
vars
	bolOut				: CM_BOLOut;
	iter				: Iterator;
	bolDict				: CM_BOLByTypeNumberDTDict;
	typeKey				: Integer;
	bolNumKey			: String;
	tsKey				: TimeStamp;
	// Use this only for now...... BOLType_GeneralBillOfLading
	
begin
	if _bolOutSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BOLOut set passed in is null');
		return;
	endif;
	
	bolDict := self.allBOLsReleasedByTypeNumberDT;
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType, _bolNumber, _dateTime, iter);
	if not _forwards then
		while iter.back(bolOut) do
			iter.getCurrentKeys(typeKey,bolNumKey,tsKey);  //MTN-35226 
			
			//no need to check timeSamp key because we're looping backwards
			if typeKey &lt;&gt; _bolType then 
				break;
			endif;
			
			if not bolNumKey.startsWith(_bolNumber) then
				break;
			endif;
		
			_bolOutSet.addNoDuplicates(bolOut, false);
		endwhile;
		
	else
		while iter.next(bolOut) do
			iter.getCurrentKeys(typeKey,bolNumKey,tsKey);  //MTN-35226 
			
			if typeKey &lt;&gt; _bolType then
				break;
			endif;
			
			if  not bolNumKey.startsWith(_bolNumber) then 
				break;
			endif;
			
			_bolOutSet.addNoDuplicates(bolOut, false);
		endwhile;
	endif;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_bolOutSet" type="CM_BOLSet" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_forwards" type="Boolean"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBOLsForTypeStatusDate" id="f04e9f95-2f5b-4a1d-8d2c-79a0d1b88791">
        <source>getBOLsForTypeStatusDate(_bolOutSet 	: CM_BOLOutSet input; 
					_bolType 		: Integer;
					_archivedStatus : Integer;
					_toTimeStamp 	: TimeStamp;
					_fowards 		: Boolean;
					_bolNumber 		: String);
// ---------------------------------------------------------------------------
// Created:     02 June 2004	cnwth2
//
// Purpose:     Populates the set passed in with all the BOLOuts of the specified 
//				status (normal or archived) up to, or foward from, the specified timeStamp 
//				Currently used for general cargo module to collect outward dockets for
//				for archiving/unarchiving
//	11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys   
// ----------   ----------  --------------------------------------------------
vars
	bolOut				: CM_BOLOut;
	iter				: Iterator;
	bolDict				: CM_BOLOutByTypeStatusDTNumDict;
	typeKey,
	statusKey			: Integer;
	tsKey				: TimeStamp;
begin
	if _bolOutSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BOLOut set passed in is null');
		return;
	endif;
	
	bolDict := self.allBOLsReleasedByTypeStatDTNum;
	
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType, _archivedStatus, _toTimeStamp, _bolNumber, iter);
	if not _fowards then
		while iter.back(bolOut) do
			iter.getCurrentKeys(typeKey,statusKey,tsKey);  //MTN-35226 
			//no need to check timeSamp key because we're looping backwards
			if typeKey &lt;&gt; _bolType or
			   statusKey &lt;&gt; _archivedStatus then 
				break;
			endif;
		
			_bolOutSet.add(bolOut);
		endwhile;
		
	else
		while iter.next(bolOut) do
			iter.getCurrentKeys(typeKey, statusKey,tsKey);  //MTN-35226
			if typeKey &lt;&gt; _bolType or
			   statusKey &lt;&gt; _archivedStatus then 
				break;
			endif;
		
			_bolOutSet.add(bolOut);
		endwhile;
	endif;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_bolOutSet" type="CM_BOLOutSet" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_archivedStatus" type="Integer"/>
        <Parameter name="_toTimeStamp" type="TimeStamp"/>
        <Parameter name="_fowards" type="Boolean"/>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="getBestPickDateTypeForTI" id="acae06b8-3231-408b-9fae-7d5d8da3678d">
        <source>getBestPickDateTypeForTI(_ti : CM_TrackedItem ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2025	jlier1	Initial creation JIRA-35632

*/

vars
	iter : Iterator;
	bestPickPriority : CM_BestPickPriority;
begin
	if _ti = null then
		return CM_BestPickPriority.BestPickRecevialDT;
	endif;
	
	iter:=self.allBestPickPriorities.createIterator;
	while iter.next(bestPickPriority) do
		if bestPickPriority.doesTIMatch(_ti) then
			return bestPickPriority.bestPickDateType;
		endif;
	endwhile;
	
	//default to the receival date time
	return CM_BestPickPriority.BestPickRecevialDT;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
