    <JadeMethod name="btnSendReport_click" id="7e33126e-83e9-4cdb-a46f-0829c4252142">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSendReport_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl 		: CM_DataTable;
	objSet 		: ObjectSet;
	objSetSize 	: Integer;
begin
	tbl := self.tblData;
	create objSet transient;
	if self.tblData.rows &gt; self.tblData.fixedRows then
		tbl.getSelectedCellObjects(objSet);
		objSetSize := objSet.size;
		if objSetSize &lt; 1 then
			tbl.selectAllCells();
			tbl.getSelectedCellObjects(objSet);
		endif;
		self.sendToReport(objSet);
		self.tblData.deselectAll();
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
