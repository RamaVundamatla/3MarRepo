    <JadeMethod name="setProxy" id="c08c315b-c3f8-436a-80b3-7c71189dbf9f">
        <updating/>
        <source>setProxy(_terminal : CM_Terminal;
		_voyage : CM_Voyage; 
		_delayType : CM_DelayType;
		_startDT : TimeStamp; 
		_estEndDT : TimeStamp;
		_endDT : TimeStamp;
		_machine : CM_Machine; 
		_driver : CM_User;
		_workPoint : CM_WorkPoint;
		_remarks : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventType			: CM_EventType;
	
begin
	self.myTerminal 	:= _terminal;
	self.myVoyage 		:= _voyage;
	self.myDelayType 	:= _delayType;
	self.startDT	 	:= _startDT;
	self.estEndDT 		:= _estEndDT;
	self.endDT 			:= _endDT;
	self.myMachine 		:= _machine;
	self.myWorkPoint	:=_workPoint;
	self.myDriver 		:= _driver;
	self.remarks  		:= _remarks;
	
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_delayType" type="CM_DelayType"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_estEndDT" type="TimeStamp"/>
        <Parameter name="_endDT" type="TimeStamp"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_driver" type="CM_User"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="startDT" id="c649c0c5-c70c-4512-81bf-0f9c1a26ba2c">
