<CollClass name="CM_ReeferBlockPositionDict" id="fcf2a7fb-501a-40c0-81a3-4e9abea8c3e6">
    <loadFactor>66</loadFactor>
    <memberType name="CM_ReeferBlockPosition"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="reeferWalk"/>
    <MemberKey>
        <property name="CM_ReeferBlockPosition::position"/>
    </MemberKey>
    <JadeMethod name="findMatchingLCandTier" id="b61eda61-9233-413a-a66e-2a20655e53d4">
        <source>findMatchingLCandTier( _reeferWalkPosition : CM_ReeferBlockPosition ) : CM_ReeferBlockPosition;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	iter : Iterator;
	reeferWalkPosition : CM_ReeferBlockPosition;

begin

	iter := self.createIterator;
	while iter.next( reeferWalkPosition ) do
		if reeferWalkPosition.myLocationController &lt;&gt; _reeferWalkPosition.myLocationController then
			continue;
		endif;
		if reeferWalkPosition.tier &lt;&gt; _reeferWalkPosition.tier then
			continue;
		endif;
		return reeferWalkPosition;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_reeferWalkPosition" type="CM_ReeferBlockPosition"/>
        <ReturnType type="CM_ReeferBlockPosition"/>
    </JadeMethod>
    <JadeMethod name="getReeferWalkIncluding" id="4b9e74fb-bd6c-4708-8c6e-a80b278e38ee">
        <source>getReeferWalkIncluding( _lc : CM_LocationsController; _tier : Integer ):CM_ReeferBlockPosition;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	iter : Iterator;
	reeferWalkPosition : CM_ReeferBlockPosition;

begin

	iter := self.createIterator;
	while iter.next( reeferWalkPosition ) do
		if reeferWalkPosition.myLocationController &lt;&gt; _lc then
			continue;
		endif;
		if reeferWalkPosition.tier &lt;&gt; _tier then
			continue;
		endif;
		return reeferWalkPosition;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="CM_ReeferBlockPosition"/>
    </JadeMethod>
</CollClass>
