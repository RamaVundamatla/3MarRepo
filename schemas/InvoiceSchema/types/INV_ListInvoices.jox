    <JadeMethod name="doSendToReport" id="89fe7adb-34ff-41b4-b50c-a8286da6cedc">
        <source>doSendToReport(_objArray : ObjectArray);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	if _objArray.isEmpty() then
		app.msgBox(app.getErrorString(NoInvoicesForReport), app.getErrorString(NoInvoicesForReport), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	create pathList transient;
	pathList.add( CM_JRWInvoice::allInvoices.name );
	pathList.add( CM_JRWInvoice::allReportInvoiceSummaries.name );	// 35069
	pathList.add( CM_JRWInvoice::allCMIFInvSumF1Lines.name );	//11 Aug 2017	NDL	TFS 5799
	//Get the report we want to send our invoice items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_InvoiceView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		foreach obj in _objArray do
			if arrayCheck.includes(obj) then
				continue;
			endif;
			
			arrayCheck.add(obj);
		endforeach;
		
		app.sendItemsToReport(CM_JRWInvoice, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doSetupOracleFooter" id="d20bea7c-064d-4d51-ad43-6e6164174155">
        <source>doSetupOracleFooter(_letter : INV_LetterInvoiceOracleFinance io);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/12/2012	cnwdap1	Initial creation PAR #30860 CCMS QNS 2236
*/
vars
	businessUnit	: CM_Bank;
	str				: String;

begin
	businessUnit := self.myCurrentInvoice.bank;
	
	_letter.lblCompany.caption		:= businessUnit.mailingName;
	_letter.lblPhoneNbr.caption		:= businessUnit.phoneNumber;
	_letter.lblEmailAddr.caption	:= businessUnit.emailAddress;
	
	_letter.txtBanker.text 			:= null;
	foreach str in businessUnit.allBankDetails do
		_letter.txtBanker.text 		:= _letter.txtBanker.text &amp; str &amp; CrLf;
	endforeach;
epilog

end;</source>
        <Parameter name="_letter" type="INV_LetterInvoiceOracleFinance" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doShowReevaluateLogging" id="70f07e9e-2087-43bc-903d-bd3e7a6c69b6">
        <source>doShowReevaluateLogging(_logger : CMIF_Logger) protected;
// show the logged re-evaluation
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	captionText		: String;
	transType		: String;
	dateTime		: TimeStamp;
	lDetails		: CMUI_SystemAlertsDetails;
	dataContainer	: CM_DataContainer;
	tableAgent		: CMUI_TableAgent;
	trans			: CM_Transaction;
begin
	
	if _logger = null then
		return;
	endif;
	
	// Update the navigator
	self.setNavigatorHeading("Re-evaluation"); 
	create lDetails;
	create dataContainer transient;
	
	_logger.getLogsAsBlocks(dataContainer);
	
	lDetails.centreWindow();
	
	create tableAgent transient;
	dataContainer.headerColour	:=	self.colorHeadingColumn;
	dataContainer.valueColour	:=	self.colorValueColumn;
	dataContainer.displayMode	:=	2;
	captionText := "Re-evaluation logging ";
	captionText := captionText &amp; transType &amp; " " &amp; dateTime.asStringJMT;
	lDetails.show();
	lDetails.setCaption(captionText);
	tableAgent.addDataToTable(	dataContainer,
								lDetails.tblAlerts,
								true,
								2,
								false,
								1,
								1,
								1,
								1, 
								null,
								true);	

	lDetails.setMyTerminal(self.myTerminal);
epilog
	delete tableAgent;
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_logger" type="CMIF_Logger"/>
    </JadeMethod>
