    <JadeMethod name="comboBoxHMSOrientation" id="a5ec9a8d-f7ff-4374-b112-9b68a7042826">
        <source>comboBoxHMSOrientation(pTbl : CM_EntryTable input; pAttrName : String; _orientation : Integer);
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
