        <source>getTotalOutstandingForWeb() : Decimal;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars
	ct : CM_CargoType;
	
begin
	ct:= self.getCargoType;
	if ct &lt;&gt; null and ct.isBulkMulti then
		return ct.getBulkTrackByDisplayForWeight(self.getWeightOutstanding(), self.getDensity, false).Decimal;
	elseif ct &lt;&gt; null and self.byTypeByWeight then
