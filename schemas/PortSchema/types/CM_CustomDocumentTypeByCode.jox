<CollClass name="CM_CustomDocumentTypeByCode" id="d2976eb3-cf62-4cf1-82da-41c54b421fa9">
    <loadFactor>66</loadFactor>
    <memberType name="CM_CustomDocumentType"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_CustomDocumentType::code"/>
    </MemberKey>
    <JadeMethod name="auditIdDisplay" id="e9efa2d3-6a98-45b8-b941-605dd051a1c7">
        <source>auditIdDisplay() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 30AUG2023
ADO - CR 59942 TASK 59943 
*/

vars
	custItem	: CM_CustomDocumentType;
	rtnStr	: String;
begin

	foreach custItem in self do
		if rtnStr = null then
			rtnStr := custItem.auditId();
		else
			rtnStr := rtnStr &amp; ', ' &amp; custItem.auditId();
		endif;
	endforeach;

	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
