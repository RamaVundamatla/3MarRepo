        <updating/>
        <source>utlUpdateHMSObject(_pxyHMSObject : HMS_Object; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
//-----------------------------------------
vars
	realObject	    : HMS_Object;
	expectedEdition : Integer;
	realBerth       : HMS_Berth;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyHMSObject.raiseExceptionIfNotProxy(method);
	_pxyHMSObject.validateForUpdate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyHMSObject.pxyGetRealObjectAndEdition(realObject, expectedEdition);
	app.setContinueCMExceptions(true);

	if realObject = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyHMSObject.getName, null, null);
		return;
	endif;
	
	exclusiveLock(realObject);

	if _passport.noErrors and realObject.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'HMS Object', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;
	
	if _passport.noErrors then
		realObject.setForUpdate(_pxyHMSObject, _passport);
	endif;
	
	if _passport.noErrors then
		realObject.causeHMSEvent(realObject.EventMode_Update);
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if  realObject.isKindOf(HMS_Berth) then
		realBerth := realObject.HMS_Berth;
		if _passport.isOpsViewEnabled(null) then
			realBerth.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
									 BGP_OpsViewWSRequest.OPS_TYPE_BERTH,
									 realBerth);
		endif;
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
