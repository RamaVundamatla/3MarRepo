    <JadeMethod name="doBtnSaveClick" id="5202a6b8-f714-425f-994b-4f386d9bfdda">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	aDischargeRequest:CMIF_DischargeRequest;
	pxySR : CM_SlotRequest;
	ls : Boolean;
begin
	app.cmsBeginLoad(ls);
	pxySR := self.myCurrentRequest.pxyCreateUpdateProxy().CM_SlotRequest;
	app.cmsEndLoad(ls);
	create aDischargeRequest transient;
	aDischargeRequest.proxyRequest := pxySR;
	aDischargeRequest.realRequest := self.myCurrentRequest.CM_SlotRequest;
	self.msgCargo.getSelected(aDischargeRequest.allTrackedItems);
	
	app.myTrxUA.trxUpdateSlotRequestDischarge(aDischargeRequest,app.myPassport);
	global.beep;
	self.unloadForm();
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete aDischargeRequest;
	delete pxySR;
end;</source>
    </JadeMethod>
