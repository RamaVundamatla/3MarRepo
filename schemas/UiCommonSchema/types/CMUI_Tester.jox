    <JadeMethod name="btnSetValues_click" id="c5e5ca74-82e4-4a5f-8cca-b6987ec38d04">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetValues_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	testData	: CMUI_TestData;

begin

	foreach testData in self.allTestData do
		self.setValues(cmbForms.listObject.Form, testData);
	endforeach;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildXmlForControl" id="1e036990-7ad4-4d8e-83b5-441649471407">
        <source>buildXmlForControl(pName, pValue : String; pRef : Object; pCloseOff : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnStr	: String;
	
begin

	if pName = null then
		return null;
	endif;

	rtnStr := '&lt;CNTRL&gt;' &amp; CrLf &amp;
			  '&lt;NAME&gt;' &amp; pName &amp; CrLf;
	
	if pValue &lt;&gt; null then
		if pValue.length &gt; 7 and pValue[1:7] = '&lt;CNTRL&gt;' then
			// the pValue is madeup of XML child control values
			rtnStr := rtnStr &amp; pValue;
		else
			rtnStr := rtnStr &amp; '&lt;VALUE&gt;' &amp; pValue &amp; CrLf;
		endif;
	endif;

	if pRef &lt;&gt; null then
		rtnStr := rtnStr &amp; '&lt;REF&gt;' &amp; pRef.getOidString &amp; CrLf;
	endif;
	
	if pCloseOff then
		rtnStr := rtnStr &amp; '&lt;/CNTRL&gt;' &amp; CrLf;
	endif;
	
	return rtnStr;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <Parameter name="pRef" type="Object"/>
        <Parameter name="pCloseOff" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
