		&lt;UserHookCode&gt;
			&lt;Fonterra&gt;
				&lt;userHookType&gt;15&lt;/userHookType&gt;
				&lt;jadeCode&gt;&lt;![CDATA[setHookField(_ediPackTI : CM_EDIPackTI io; _propertyName : String; _value : Any) : Any updating;
vars
	str : String;
begin
	// do nothing.
	//return null;
	
	if _propertyName = ETRow_Consignee and 
	   _value = null then
		return 'CCS';
	elseif _propertyName = ETRow_Consignor and
	   _value = null then
		return 'DOUG';
	elseif _propertyName = ETRow_Commodity then
		if _value = null then
			return 'MIPS';
		endif;
	elseif _propertyName = ETRow_BookingRef and
	   _value &lt;&gt; null then
		str := _value.String;
		if str.length &gt; 4 then
			return str[5:str.length];
		else
			return null;
		endif;
	elseif _propertyName = ETRow_Temperature and
	   _value.Real &lt;&gt; NULL_TEMPERATURE and
	   _ediPackTI.commodity = 'MIPS' then
		_ediPackTI.commodity := 'CHEZ';
	elseif _propertyName = ETRow_Weight then
		_ediPackTI.weight := _ediPackTI.weightNet + _ediPackTI.weightTare;
	else
		return null;
	endif;
end;]]&gt;&lt;/jadeCode&gt;
			&lt;/Fonterra&gt;
		&lt;/UserHookCode&gt;
