    <JadeMethod name="setup" id="ab30073c-a76a-4f66-aeb4-649ff8a54b8c">
        <updating/>
        <source>setup(_summaryItem: CMIF_CandHSummaryItem; _voyage: CM_Voyage) updating;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.mySummaryItem := _summaryItem;
	_summaryItem.allSnapShots.copy(self.allSnapShots);
	self.myVoyage := _voyage;
	if self.mySummaryItem.size = CMIF_CandHRpt.Size_40 then
		self.is40 := true;
	else
		self.is40 := false;
	endif;
	self.summaryCode := self.mySummaryItem.itemCode;	
end;</source>
        <Parameter name="_summaryItem" type="CMIF_CandHSummaryItem"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0827bb71-94de-4798-b6f6-0ff57ce7b777">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.usesQueryFrame := false;
	self.useTableInfo := false;
	inheritMethod();
	
	self.initTable();

	self.doQuery(); // TFS 40336

	self.btnAddSnapShot.visible := not self.isFromItemSelector(); // TFS 40336
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblData.userInputEnabled := false;
		self.btnAddSnapShot.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnEditSelected.enabled:= false;
		self.mnuAddCargo.enabled:= false;
		self.mnuHideCargo.enabled:= false;
		self.mnuEditSelected.enabled:= false;
		self.mnuResetSnapShot.enabled:= false; // TFS 40336
		self.mnuUpdareFromCargo.enabled:= false; // TFS 40336
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="a3cc9df4-5c02-4581-b628-d239243227ec">
        <source>showColourLegend();
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
	colLegend.centreWindow;
	
	colLegend.addLegendItem(app.getErrorString(Original_System_Item),		Black, White,		null, false);
	colLegend.addLegendItem(app.getErrorString(UpdatedItem),				Black, PaleYellow,	null, false);
	colLegend.addLegendItem(app.getErrorString(Item_Excluded_From_Report), Black, Grey,		null, true);
	colLegend.addLegendItem(app.getErrorString(NewUserItem),				Black, PaleGreen,	null, false);
	
	colLegend.height := 200;
	colLegend.showModal;

epilog
	delete colLegend;


end;</source>
    </JadeMethod>
    <JadeMethod name="showOpPicker" id="cb479481-6df3-451b-bc8b-6e01362d74fc">
        <source>showOpPicker();
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	frm : Frame;
begin
	frm := self.frmOpPicker;
	
	self.tblData.enabled := false;
	self.btnEditSelected.enabled := false;
	
	self.cmbLGDOperators.clear;
	self.loadLGDOperatorCombo(self.mySummaryItem.getMyLGD());
		
	frm.visible := true;
	frm.centreWindow();
	frm.zOrder(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="showSnapShotCargoUpdate" id="85ee69ae-dcf0-4a52-9b46-1d27bc52a703">
        <source>showSnapShotCargoUpdate();
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	form : CMUI_SnapShotUpdateFromCargo;
begin

	if self.tblData.allSelectedObjects.isEmpty then
		//nothing selected
		app.msgBox("Select an item to update.", app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;

	form := app.loadForm(CMUI_SnapShotUpdateFromCargo, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SnapShotUpdateFromCargo;

	if form = null then
		return;
	endif;	

	self.tblData.allSelectedObjects.copy(form.allEditSnapShots);
	form.showModal();

end;</source>
    </JadeMethod>
    <JadeMethod name="showSnapShotEdit" id="4f484bb2-846c-4cde-a0f7-6c92de084255">
        <source>showSnapShotEdit();
//----------------------------------------------------------------
//	Created:	09 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	form : CMUI_SnapShotEditForm;
begin

	if self.tblData.allSelectedObjects.isEmpty then
		//nothing selected
		app.msgBox("Select an item to edit.", app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;

	form := app.loadForm(CMUI_SnapShotEditForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SnapShotEditForm;

	if form = null then
		return;
	endif;	

	self.tblData.allSelectedObjects.copy(form.allEditSnapShots);
	form.summaryCode := self.summaryCode; // TFS 40336
	form.showModal();

end;</source>
    </JadeMethod>
