    <JadeMethod name="doBtnSelectWharfShow" id="3806eb7e-db14-4d02-ba01-7a6de462d449">
        <updating/>
        <source>doBtnSelectWharfShow() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Processes the Wharf Selection.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aAllSelectedWharves.clear();
	self.msgSelectWharves.getSelected(self.aAllSelectedWharves);
	
	if self.aAllSelectedWharves.isEmpty() then
		app.msgBox(app.getString(Must_Select_At_Least, app.getString(Wharf)), app.getString(Wharf), MsgBox_OK_Only);
		return;
	endif;
	
	//epr par 16808 19/6/08 
	self.myViewController.allWharves.clear;
	self.aAllSelectedWharves.copy(self.myViewController.allWharves);
	self.showWharfSelectorEnable(false);
	self.buildMap();
	self.refreshNow();
	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnShipPositionDetails" id="97450184-6e2f-4ec6-afbf-3bb78a41b4a8">
        <updating/>
        <source>doBtnShipPositionDetails(btn: Button input) updating, protected;

vars
	pict : HMS_GraphicalDragPicture;
	tmpWharfDrawControl	: HMS_WharfDrawControl;
begin

	lblContainerFore.caption := '';
	lblContainerAft.caption	:= '';
	
	if btn.value then
		self.lblContainerFore.visible := true;
		self.lblContainerAft.visible := true;
		self.lblContFore.visible := true;
		self.lblContAft.visible := true;
		self.lblContAftTag.visible := true;
		self.lblContForeTag.visible := true;
	else
		self.lblContainerFore.visible := false;
		self.lblContainerAft.visible := false;
		self.lblContFore.visible := false;
		self.lblContAft.visible := false;
		self.lblContAftTag.visible := false;
		self.lblContForeTag.visible := false;	
	endif;		

	// Draw marks on sprite
	pict := self.myCurrentDragPicture; 
	if pict &lt;&gt; null then
		tmpWharfDrawControl := pict.myCurrentWharfDrawControl;
		tmpWharfDrawControl.showHideLabels(false, null, null);
		tmpWharfDrawControl.drawShipMetrics(pict);
		self.showTimeAndPositionForSelected(pict.myWorkingMovement);
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
