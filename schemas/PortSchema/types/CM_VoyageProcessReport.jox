    <JadeMethod name="validateForUpdate" id="e0bc2d6a-96f6-4c43-9829-ba443297d97c">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin

	if self.displayName = null then
		app.raiseCMException(Input_required_field_dispName, null, null);
	endif;	
	if self.reportName = null then
		app.raiseCMException(Report_name_maynot_blank, null, null);
	endif;
	if self.reportView = null then
		app.raiseCMException(Report_view_not_null, null, null);
	elseif not self.isInvoiceView and not self.isVoyageView then 
		app.raiseCMException3(Not_valid_selec_here_requi_rep, self.reportName, app.getErrorString(Voyage_process_report), "'CM_VoyageView' or 'CM_InvoiceView'", null, null);
	endif;
	if self.myVoyageProcess = null and not self.isTransient then
		app.raiseCMException(Voyage_process_selected, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
