    <JadeMethod name="create" id="e44fab8b-20e6-4382-900f-d60c5167588a">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2003	cnwdad1		Changed from setting background color with a global
//							constant to use the getSystemColor() method.
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
	
	self.alignment		:=	TextBox.Alignment_Center;
	self.show3D			:=	Control.Show3D_Use3D;
	self.selectionStyle	:=	TextBox.SelectionStyle_SelectAll;
//	self.backColor 		:= 	Window.Color_Window + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
	self.backColor 		:= 	self.getSystemColor(Window.Color_Window);		// cnwdad1 28/02/2003.
	self.height			:=	20;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="6f9613c5-6be8-4a2d-8823-5dd292548f85">
        <updating/>
        <source>dblClick(textbox : CnEcDateBox input) updating;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/07/2000	cnwdad1		Added check for the "readOnly" property.  If true, then
//							simply inheritMethod and return.
// 08/11/2000	cnwdad1		Changed to instantiate the new CnEcSelectCalendarForm.
// 30/11/2000	cnwdad1		Changed the setting of the date to use the parseForCurrentLocale
//							method on the Date primitive.
// --------------------------------------------------------------------------------
vars
	calendarFormObj	: CnEcCalendarSelectForm;			// cnwdad1 08/11/2000.

begin
	app.mousePointer	:=	Busy;

	if self.readOnly then
		return;
	endif;

	create calendarFormObj;

	self.date.parseForCurrentLocale(self.text);					// cnwdad1 30/11/2000.
	self.isDateValid	:=	self.date.isValid();

	if self.isDateValid then
		calendarFormObj.setStartDate(self.date);
	endif;

	self.doPositionCalendar(calendarFormObj);

	calendarFormObj.showModal();

	if calendarFormObj.modalResult = Form.CNEC_MODAL_SELECT then
		self.setDate(calendarFormObj.getDate());						// cnwdad1 08/11/200.
	endif;

	inheritMethod(textbox);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="CnEcDateBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPositionCalendar" id="ae0289d7-f791-4f50-b17f-e67155e5e794">
        <updating/>
        <source>doPositionCalendar(pCalendarFormObj:CnEcCalendarSelectForm io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Purpose:		Positions the pop-up calendar form next to the calling control.
//
// Parameters:	pCalendarFormObj - The pop-up calendar form.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj			: Control;
	parentFormObj		: Form;
	screenTop			: Real;
	screenLeft			: Real;
	screenHeight		: Real;
	screenWidth			: Real;
	posControlLeft		: Real;
	posControlTop		: Real;
	posFormLeft			: Real;
	posFormTop			: Real;
	
begin
	// Starting with self, well work up the tree of the control's parents.
	
	controlObj	:=	self;
	
	while not controlObj.parent.isKindOf(Form) do
		controlObj	:=	controlObj.parent.Control;
	endwhile;
	
	// Get the screen and date mask control dimensions.
	
	parentFormObj	:=	controlObj.parent.Form;
	parentFormObj.getDeskTopWorkArea(screenLeft, screenTop, screenWidth, screenHeight);
	self.windowToScreen(posControlLeft, posControlTop);
	
	// We'll start by placing the calendar form at the right if the date mask control.
	
	posFormLeft	:=	posControlLeft + self.width;
	posFormTop	:=	posControlTop;
	
	// Now work out where to place the calendar form.
	
	if (posFormLeft + pCalendarFormObj.width) &gt; screenWidth then
		// The right-hand edge of the form is outside the screen area, so try putting
		// the calendar form on the left-hand side of the control.
		posFormLeft	:=	posControlLeft - pCalendarFormObj.width;
		
		if posFormLeft &lt; screenLeft then
			// The left-hand edge of the form is outside the screen area, so try putting
			// the calendar form immediately beneath the control.
			posFormLeft	:=	posControlLeft;
			posFormTop	:=	posControlTop + self.height;
		endif;
	endif;
	
	if (posFormTop + pCalendarFormObj.height) &gt; screenHeight then
		// The bottom edge of the form is outside the screen area, so try putting
		// the calendar form above the control.
		posFormTop	:=	(posControlTop + self.height) - pCalendarFormObj.height;
		
		if posFormTop &lt; screenTop then
			// The top edge of the form is outside the screen area, so we'll reset the
			// calendar form positions to zero and let the form center itself when it loads.
			posFormLeft	:=	0;
			posFormTop	:=	0;
		endif;
	endif;
	
	// Set the values on the pop-up calendar form.
	
	pCalendarFormObj.setPosition(posFormLeft.Integer, posFormTop.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pCalendarFormObj" type="CnEcCalendarSelectForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNumericDateFormat" id="769fa218-6301-46cf-b80c-9c04f2e023c7">
        <source>getNumericDateFormat(pDate:Date):String protected;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 by cnwdad1
//
// Purpose:		To format a system date format with all numeric values, eg.
//				'10/July/1962' will become '10/07/1962'.
//
// Parameters:	pDate (Date) - The date whose numeric format will be returned.
//
// Returns:		The formated date with (separated) numerics.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateString	: String;
	dayNo		: String;
	monthNo		: String;
	yearNo		: String;
	separator	: String;

begin
	separator	:=	self.myDateFormat.separator;

	if pDate = null or (not pDate.isValid()) then
		dayNo	:=	'00';
		monthNo	:=	'00';
		yearNo	:=	'0000';
	else
		dayNo	:=	pDate.Date.day.String.padLeadingZeros(2);
		monthNo	:=	pDate.Date.month.String.padLeadingZeros(2);
		yearNo	:=	pDate.Date.year.String.padLeadingZeros(4);
	endif;

	if self.myDateFormat.shortFormatOrder = self.myDateFormat.MonthDayYear then
		dateString	:=	monthNo &amp; separator &amp; dayNo &amp; separator &amp; yearNo;

	elseif self.myDateFormat.shortFormatOrder = self.myDateFormat.DayMonthYear then
		dateString	:=	dayNo &amp; separator &amp; monthNo &amp; separator &amp; yearNo;

	elseif self.myDateFormat.shortFormatOrder = self.myDateFormat.YearMonthDay then
		dateString	:=	yearNo &amp; separator &amp; monthNo &amp; separator &amp; dayNo;
	endif;
epilog
	return dateString;
end;</source>
        <access>protected</access>
        <Parameter name="pDate" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="0a271205-405c-42c7-80f4-f20c361d7c88">
        <updating/>
        <source>gotFocus(textbox : CnEcDateBox input) updating;
// --------------------------------------------------------------------------------
// Created:		28 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07/04/2006	cnwdad1		Commented out the resetting of self.date if the isDateValid
//							flag is false - this means that a date has been entered
//							that is not valid, but the user should be able to correct
//							it without having to re-enter the whole date.
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;

begin
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
	
	if (not self.isInPainter()) then
		if (not self.isDateValid) then
/* cnwdad1 07/04/2006.
			if self.defaultToToday then
				self.text			:=	self.getNumericDateFormat(dateToday);
				self.date			:=	dateToday;
			else
				self.text			:=	self.getNumericDateFormat(null);
				self.date			:=	null;
			endif;
*/
		endif;

		// If we click on the year for example then we want to edit the year, not the day
		self.cursorPosition	:=	self.selStart + 1;
//		self.cursorPosition	:=	1;
//		self.selStart		:=	self.cursorPosition - 1;
	endif;

	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="CnEcDateBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isDateBlank" id="153f10e4-6e3d-43e9-b095-c83017c3941d">
        <source>isDateBlank():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Purpose:		Indicates whether or not any part of the date has been entered.  If
//				nothing has been entered, a value of true will be returned.
//
// Parameters:	None
// Returns:		Boolean - True if no part of the date has been entered, else false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	part1		: Integer;
	part2		: Integer;
	part3		: Integer;
	position1	: Integer;
	position2	: Integer;
	separator	: String;

begin
	part1		:=	0;
	part2		:=	0;
	part3		:=	0;
	separator	:=	self.myDateFormat.separator;
	position1	:=	self.text.pos(separator, 1);

	if position1 &gt; 1 then		// If the separator is the first character, then the date is rubbish anyway.
		part1	:=	self.text[1:(position1 - 1)].Integer;

		if position1 &lt; self.text.length() then	// If the separator is the last character, then the date is rubbish anyway.
			position2	:=	self.text.pos(separator, (position1 + 1));

			if position2 &gt; (position1 + 1) then	// If there's nothing between the two separators, then the date is rubbish.
				part2	:=	self.text[(position1 + 1):(position2 - 1)].Integer;

				if position2 &lt; self.text.length() then
					part3	:=	self.text[(position2 + 1):end].Integer;
				endif;
			endif;
		endif;
	endif;

	if part1 = 0 and part2 = 0 and part3 = 0 then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="df353129-2057-465b-ad35-c3b4bc5ee84b">
        <updating/>
        <source>keyDown(textbox : CnEcDateBox input; keyCode : Integer io; shift : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/07/2000	cnwdad1		Added check for the "readOnly" property.  If true, then
//							simply inheritMethod and return.
// --------------------------------------------------------------------------------
// cnwdad1 31/03/2001 - Now uses global constants instead.
//constants
//	KEY_END		=	35;
//	KEY_HOME	=	36;
//	KEY_LEFT	=	37;
//	KEY_RIGHT	=	39;

begin
	// cnwdad1 14/07/2000 - Added the following check.
	if self.readOnly then
		inheritMethod(textbox, keyCode, shift);
		return;

	elseif keyCode = CNEC_KEY_ARROWLEFT then
		if self.cursorPosition &gt; 1 then
			self.cursorPosition	:=	self.cursorPosition - 1;

			if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
				self.cursorPosition	:=	self.cursorPosition - 1;
				self.selStart	:=	self.cursorPosition;
			endif;
		endif;
		
	elseif keyCode = CNEC_KEY_ARROWRIGHT then
		if self.cursorPosition &lt; self.text.length() then
			self.cursorPosition	:=	self.cursorPosition + 1;

			if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
				if self.cursorPosition &lt; self.text.length() then
					self.cursorPosition	:=	self.cursorPosition + 1;
				endif;

				self.selStart	:=	self.cursorPosition - 2;
			endif;
		else
			self.cursorPosition	:=	self.text.length() + 1;
		endif;
		
	elseif keyCode = CNEC_KEY_HOME then
		self.cursorPosition	:=	1;
		
	elseif keyCode = CNEC_KEY_END then
		self.cursorPosition	:=	self.text.length() + 1;
		
	elseif keyCode = J_key_Back then
		if self.cursorPosition &gt; 1 then
			self.cursorPosition	:=	cursorPosition - 1;

			if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
				if self.cursorPosition &gt; 1 then
					self.cursorPosition	:=	self.cursorPosition - 1;
					self.selStart		:=	self.cursorPosition;
					self.text.cnEcReplaceCharacter('0'.Character, self.cursorPosition);
					keyCode				:=	0;
					self.selStart		:=	self.cursorPosition - 1;
				endif;
				
			else
				self.text.cnEcReplaceCharacter('0'.Character, self.cursorPosition);
				keyCode			:=	0;
				self.selStart	:=	self.cursorPosition - 1;
			endif;

		else
			keyCode	:=	0;
		endif;
		
	elseif keyCode = J_key_Stop then
		self.text.cnEcReplaceCharacter('0', self.cursorPosition);
		self.selStart	:=	self.cursorPosition - 1;
		keyCode	:=	0;
	endif;

	inheritMethod(textbox, keyCode, shift);
end;</source>
        <Parameter name="textbox" type="CnEcDateBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyPress" id="f2fcef2f-c1d4-4a23-bf19-cd8eaf700899">
        <updating/>
        <source>keyPress(textbox : CnEcDateBox input; keyCode : Integer io) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/07/2000	cnwdad1		Added check for the "readOnly" property to only process
//							this event if the control is not in "readOnly" mode.
// 23/01/2003	cnwdad1		Added a check of the isChanged flag to determine whether
//							to invoke the firstChange event method.
// --------------------------------------------------------------------------------
begin
	if	(not self.readOnly)								// cnwdad1 14/07/2000.
	and ((keyCode = J_key_0)
	or (keyCode = J_key_1)
	or (keyCode = J_key_1)
	or (keyCode = J_key_2)
	or (keyCode = J_key_3)
	or (keyCode = J_key_4)
	or (keyCode = J_key_5)
	or (keyCode = J_key_6)
	or (keyCode = J_key_7)
	or (keyCode = J_key_8)
	or (keyCode = J_key_9)
	or (keyCode = J_key_Space))
	and ((self.cursorPosition &lt;= self.text.length))
	then
		if (keyCode = J_key_Space) then
			keyCode	:=	J_key_0;
		endif;

		self.text.cnEcReplaceCharacter(keyCode.Character, self.cursorPosition);
		self.cursorPosition	:=	self.cursorPosition + 1;

		if self.cursorPosition &lt; textbox.text.length()
		and textbox.text[self.cursorPosition:1] = self.myDateFormat.separator
		then
			self.cursorPosition	:=	self.cursorPosition + 1;
		endif;

		keyCode				:=	0;
		textbox.selStart	:=	self.cursorPosition - 1;
	else
		keyCode	:=	0;
	endif;

	inheritMethod(textbox, keyCode);
	
	if (not self.isChanged) then
		self.isChanged	:=	true;
		self.firstChange(self);
	endif;
end;</source>
        <Parameter name="textbox" type="CnEcDateBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="ba5615e8-7572-45ed-acc3-7c0b3fe5c704">
        <updating/>
        <source>lostFocus(textbox : CnEcDateBox input) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/11/2000	cnwdad1		Changed the setting of the date to use the parseForCurrentLocale
//							method on the Date primitive.
//
// 14/04/2004	cnwdad1		Locale overrides (i.e. on app server) are not supported
//							by JADE.  Changes in JADE 6 to enforce this caused layout
//							problems when parsing for current locale set the date
//							property - now just using the "cnEcDate()" method.
//
// 07/04/2006	cnwdad1		Reinstated the setting of the self.date attribute from
//							the receiver's text, added a (optional) error message,
//							and commented out the reset of the receiver's text where
//							an invalid date has been entered.
//
// 08/04/2006	cnwdad1		Added an error message if the receiver is a required field
//							and no date has been entered.
// --------------------------------------------------------------------------------
vars
	userDate	: Date;
	
begin	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor	:=	self.colorNoFocus;
	endif;
	
//	self.date			:=	self.text.Date;					// cnwdad1 30/11/2000.
// cnwdad1 14/04/2004 - Locale overrides (i.e. on app server) are not supported - changes in JADE 6
// to enforce this cause layout problems when parsing for current locale.
//	self.date.parseForCurrentLocale(self.text);				// cnwdad1 30/11/2000.

// cnwdad1 07/04/2006 - reinstated the setting of self.date from the text.  Without this,
// the self.date was not being set unless the user selected a date from the date-picker.
//	self.date			:=	self.cnEcDate();
//	self.isDateValid	:=	self.date.isValid();
	userDate			:=	self.text.Date;
	self.isDateValid	:=	userDate.isValid();
	
	if self.isDateValid then
		self.date	:=	userDate;
	else
		if self.isDateBlank() then
			if self.isRequired and self.isShowErrorMsg then
				app.msgBox("Date entry is compulsory.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				self.setFocus();
			endif;
		else
			// If at least part of the date was entered, then give an audio
			// prompt to the User that it is invalid (as it must be to have
			// gotten into here).
			
			if self.isShowErrorMsg then
				app.msgBox("You must enter a valid date.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				self.setFocus();
			else
				app.beep();
			endif;
		endif;

//		self.text	:=	self.getNumericDateFormat(null);		cnwdad1 07/04/2006.
	endif;

	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="CnEcDateBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="ecd8cf16-f100-4d5a-9f6d-f2d3221d3af9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		17 January 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2003	cnwdad1		Changed from setting background color with a global
//							constant to use the getSystemColor() method.
// --------------------------------------------------------------------------------
begin
	if isTransient() = true then
		if set then
			inheritMethod(set, value);
			
			if app.getName() = "Jade" then
				if value then
//					backColor	:=	Window.Color_3DFace + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
					backColor	:=	self.getSystemColor(Window.Color_3DFace);		// cnwdad1 28/02/2003.
					tabStop		:=	false;
				else
//					backColor	:=	Window.Color_Window + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
					backColor	:=	self.getSystemColor(Window.Color_Window);		// cnwdad1 28/02/2003.
					tabStop		:=	true;
				endif;
			else
				if value then
					//backColor	:=	Gray;											// cnwdad1 02/08/2007.
					backColor	:=	self.getSystemColor(Window.Color_3DFace);		// cnwdad1 02/08/2007.
					tabStop		:=	false;
				else
					//backColor	:=	White;											// cnwdad1 02/08/2007.
					backColor	:=	self.getSystemColor(Window.Color_Window);		// cnwdad1 02/08/2007.
					tabStop		:=	true;
				endif;
			endif;

			// Make sure that a repaint is done.
			self.refresh();
		else
			inheritMethod(set, value);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="3c39a1e7-3d82-422d-89be-797225b0fbaa">
        <updating/>
        <source>setDate(pDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		05 April 1999 cnwdad1
//
// Purpose:		Sets the receiver's current date.
//
// Parameters:	pDate - The new date value.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Set the isChanged flag which is used to determine whether
//							to invoke the firstChange event method.
// --------------------------------------------------------------------------------
begin
	if pDate = null or (not pDate.isValid()) then
		self.text			:=	self.getNumericDateFormat(null);
		self.date			:=	null;
	else
		self.text			:=	self.getNumericDateFormat(pDate);
		self.date			:=	pDate;
		self.isDateValid	:=	true;
	endif;
	
	self.isChanged	:=	false;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setIsRequired" id="0c17c0f0-8860-4122-93eb-004ea69a102a">
        <updating/>
        <source>setIsRequired(pIsRequired:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 April 2006 by cnwdad1
//
// Purpose:		Sets the receiver's "isRequired" flag.
//
// Parameters:	pIsRequired - True if a date is required, otherwise false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isRequired	:=	pIsRequired;
end;</source>
        <Parameter name="pIsRequired" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="text" id="0cc57e68-4edf-46ed-be98-4e7d1413b470">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>text(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		30 November 2000 by cnwdad1
//
// Purpose:		Mapping method for the "text" property.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentDate	: Date;
	
begin
	if (not self.isInPainter())
	and self.myDateFormat &lt;&gt; null
	and (not set)
	then
		if currentDate.parseForCurrentLocale(value) then
			value	:=	self.getNumericDateFormat(currentDate);
		endif;
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="da6b72a9-58c4-4044-88b3-714314d20ce4">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today	: Date;

begin
	if (not self.isInPainter()) then
		self.myDateFormat	:=	app.currentLocaleInfo.dateInfo;

		if self.defaultToToday then
			self.text			:=	self.getNumericDateFormat(today);
			self.date			:=	today;
			self.isDateValid	:=	(self.date.isValid());
		else
			self.text			:=	self.getNumericDateFormat(null);
			self.date			:=	null;
			self.isDateValid	:=	false;
		endif;

		self.cursorPosition	:=	1;
	endif;

	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
