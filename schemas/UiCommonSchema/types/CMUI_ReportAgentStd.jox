begin
	cmbSubSrc := self.myCmbSubSrc;
	cmbSubSubSrc := self.myCmbSubSubSrc;
	
	cmbSubSubSrc.clear();
	sourceSubLocation := cmbSubSrc.listObject.CM_SourceSubLocation;
	if sourceSubLocation &lt;&gt; null then
		tmpCodeGroup := sourceSubLocation.allSubSubLocations;
	endif;
	//load even if null so as to load an **Any** at the top
	cmbSubSubSrc.listCollectionWithAny(tmpCodeGroup, 'code');
	if tmpCodeGroup &lt;&gt; null and tmpCodeGroup[_srcSubSubLocation] &lt;&gt; null then
		cmbSubSubSrc.text := _srcSubSubLocation;
	else
		cmbSubSubSrc.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_SrcSubSubLocation, Any_String);	

end;</source>
        <Parameter name="_srcSubSubLocation" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadStopsTable" id="15d9e669-2498-43f6-9a09-83b960bb238a">
        <source>doLoadStopsTable(_table : CMUI_ListTable input; _template: CMQF_FilterReports) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _table = null then
		return;
	endif;
	_table.allSelectedObjects.clear();
	self.myAssistant.listTableStopsTableSys(_table);
	//th2 noticed in 7.4.3 testing - was exception casting as CMQF_TrackedItem when it was actually CMQF_Transaction
	if CMQF_TrackedItem.hasInstance(_template) then
		_table.setSelected(_template.CMQF_TrackedItem.allQryStopTables);
	endif;
	_table.lostFocus(_table);
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_template" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadSubCarriers" id="7fc0d49a-a3b7-4321-9d69-67e9ccc21767">
        <source>doLoadSubCarriers(_cmb : CMUI_ComboBox input; _subCarrierCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 
07 Sep 2023 navhl20 Bug 60056: EUP | FR | 53429 - VBS Selector issues
*/

vars
	subCarrier			: CM_Carrier;
	subCarrierDict		: CM_CarrierByCodeDict;
	idx : Integer;
	selectedSubCarrier : CM_Carrier;
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	subCarrierDict := app.myRoot.allSubCarriersRoad;
	
	foreach subCarrier in subCarrierDict do
		idx := _cmb.addItem(subCarrier.code &amp; Tab &amp; subCarrier.description);
		_cmb.itemObject[idx] := subCarrier;
		if subCarrier.code = _subCarrierCode then
			selectedSubCarrier := subCarrier;
		endif;
	endforeach;
			
	if selectedSubCarrier &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selectedSubCarrier);
	else
		_cmb.listIndex := _cmb.findString(1,Any_String);			//07.9.2023 navhl20 #60056
	endif;
		
	self.setValueByName(ETRow_MySubCarrier, _cmb.text);	
	self.setValueByName(ETRow_SubCarrierCode, _cmb.text);
	self.setValueByName(ETRow_SubCarrierFilter, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_subCarrierCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSubTerminals" id="0389d7f0-caa9-4f12-b8b6-fd806dc08f18">
        <source>doLoadSubTerminals(_comboboxObj : ComboBox input; _subTerminalCode : String);
// --------------------------------------------------------------------------------
// Created:		24 April 2009 by cnwdz2
//
// Purpose:		Populates the specified ComboBox control with Sub-Terminals of the
//				specified Terminal.
//
// Parameters:	_comboboxObj - A reference to the combobox control to populate.
//				_subTerminalObj - A reference to the default Sub-Terminal.
//				_terminalObj - A reference to the current Terminal.
//
// Returns:		Nothing
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	subTerminalObj	: CM_SubTerminal;
	rowPointer		: Integer;
	passport		: CM_Passport;
	failedDAC  :CM_DataAccessController;
	terminal		: CM_Terminal;
	selSubTerminal : CM_SubTerminal;
	
begin
	if _comboboxObj = null then
		return;
	endif;
	
	_comboboxObj.clear();
	
	_comboboxObj.addItem(Any_String);
	passport := app.myPassport;
	
	foreach terminal in self.allTerminals do
		foreach subTerminalObj in terminal.allSubTerminals do
			if (not subTerminalObj.canUserAccessSelf(null, failedDAC, passport)) and (subTerminalObj.code &lt;&gt; _subTerminalCode) then
				continue;			
			endif;
		
			rowPointer	:=	_comboboxObj.addItem(subTerminalObj.code);
			_comboboxObj.itemObject[rowPointer]	:=	subTerminalObj;
			if subTerminalObj.code = _subTerminalCode then
				selSubTerminal := subTerminalObj;
			endif;
		endforeach;
	endforeach;
	
	if selSubTerminal &lt;&gt; null then
		_comboboxObj.listIndex := _comboboxObj.findObject(selSubTerminal);
	else
		_comboboxObj.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_MySubTerminal, _comboboxObj.text);
end;</source>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_subTerminalCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadTATypes" id="bba8c922-22c3-4317-85c2-fbb9c71cf4c0">
        <source>doLoadTATypes(_cmb : CMUI_ComboBox input; _taTypeDescription : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	taType			: CM_TerminalAreaType;
	taTypeDict		: CM_TATypeByTypeDict;
	storeTAType		: CM_TerminalAreaType;
	terminal		: CM_Terminal;
	idx				: Integer;
	found			: Boolean;
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.sorted := true;
	_cmb.addItem(Any_String);
	
	taTypeDict := app.myRoot.allTerminalAreaTypes;
	foreach taType in taTypeDict do
		idx := _cmb.addItem(taType.description);
		_cmb.itemObject[idx] := taType;
		
		if taType.description = _taTypeDescription then
			found := true;
		endif;
	endforeach;
	
	if found and _taTypeDescription &lt;&gt; null then
		_cmb.text := _taTypeDescription;
	else
		//things are a bit more difficult:
		terminal := self.allTerminals.first;
		if terminal = null then
			terminal := app.myRoot.allTerminals.first;
		endif;
		
		taType := terminal.getConfig(DefTAType).CM_TerminalAreaType;
		if taType &lt;&gt; null then
			_cmb.text := taType.description;
		else
			_cmb.text := Any_String;
		endif;
	endif;
	
	self.setValueByName(ETRow_TerminalAreaType, _cmb.text);
	self.doLoadTAsByTypeWithAny(_cmb.listObject.CM_TerminalAreaType, null);
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_taTypeDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadTAsByTypeWithAny" id="483b7f61-92c9-42bc-8813-eadd4d11f94f">
        <source>doLoadTAsByTypeWithAny(_taType : CM_TerminalAreaType; _terminalAreaId : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//	
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	str				: String;
	ta				: CM_TerminalArea;
	terminal		: CM_Terminal;
	terminalCode	: String;
	multiTerminal	: Boolean;
	cmb				: CMUI_ComboBox;
	idx : Integer;
	selTerminalArea : CM_TerminalArea;
	
begin
	cmb := self.myCmbTerminalArea;
	cmb.clear();
	cmb.addItem(Any_String);

	multiTerminal := (self.allTerminals.size &gt; 1);
	foreach terminal in self.allTerminals do	
		foreach ta in terminal.allTerminalAreas do
			if (_taType = null) or (ta.type = _taType.type) then
				if multiTerminal then
					str := ta.id &amp; Tab &amp; '-' &amp; terminal.code;
				else
					str := ta.id;
				endif;
				
				idx := cmb.addItem(str);
				cmb.itemObject[idx] := ta;
				
				if _terminalAreaId = ta.id then
					selTerminalArea := ta;
				endif;
			endif;
		endforeach;
	endforeach;
	
	if selTerminalArea &lt;&gt; null then
		cmb.listIndex := cmb.findObject(selTerminalArea);
	else
		cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_TerminalAreaId, cmb.text);
end;</source>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
        <Parameter name="_terminalAreaId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadTIStates" id="6140173f-8b3f-42ac-85ae-ec73005e5fdc">
        <source>doLoadTIStates(_lstTable : CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     
//	03.11.2025	navcs2	MTN-36231 IMT | Prenoted not available during creation of a new Cargo Report	 
// ----------   ----------  --------------------------------------------------
vars
	strColl				: CM_ObjectArray;
	strObj				: CM_String;
	defaultSites		: IntegerArray;
	objToSelect			: ObjectSet;
begin
	create objToSelect transient;
	if CMQF_TrackedItem.hasInstance(_defaultTemplate) then
		defaultSites := _defaultTemplate.CMQF_TrackedItem.allQrySites; 
	elseif _defaultTemplate.isKindOf(CMQF_OrganisationAccess) then
		defaultSites := _defaultTemplate.CMQF_OrganisationAccess.allQrySites;
	elseif _defaultTemplate.isKindOf(CMQF_Invoice) then						//TFS 37093 jlgmd1 21/02/2018
		defaultSites := _defaultTemplate.CMQF_Invoice.allQrySites;			//TFS 37093 jlgmd1 21/02/2018
	elseif _defaultTemplate.isKindOf(CMQF_InvoiceLine) then					//TFS 37093 jlgmd1 21/02/2018
		defaultSites := _defaultTemplate.CMQF_InvoiceLine.allQrySites;		//TFS 37093 jlgmd1 21/02/2018
	endif;

	self.allAllowedTISites.purge();
	//set allSelected to zero
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.clearSelected();

	create strObj transient;
	strObj.string := app.siteEnumToString(TI_SITE_ONSITE);
	if defaultSites &lt;&gt; null and defaultSites.includes(TI_SITE_ONSITE) then
		objToSelect.add(strObj);
	endif;
	self.allAllowedTISites.add(strObj);

	if not _defaultTemplate.isKindOf( CMQF_OrganisationAccess ) then	// 20 Feb 2013	cnwjre1	Par 31156 only want on site or on ship reporting
		create strObj transient;
		strObj.string := app.siteEnumToString(TI_SITE_OFFSITE);
		if defaultSites &lt;&gt; null and defaultSites.includes(TI_SITE_OFFSITE) then
			objToSelect.add(strObj);
		endif;
		self.allAllowedTISites.add(strObj);
	endif;
	
	create strObj transient;
	strObj.string := app.siteEnumToString(TI_SITE_ONSHIP);
	if defaultSites &lt;&gt; null and defaultSites.includes(TI_SITE_ONSHIP) then
		objToSelect.add(strObj);
	endif;
	self.allAllowedTISites.add(strObj);
	
	// 03.11.2025	navcs2	MTN-36231 Start
	create strObj transient;
	strObj.string :=	app.siteEnumToString(SEL_QUERYSITE_NOTIFIED);
	if defaultSites &lt;&gt; null and defaultSites.includes(SEL_QUERYSITE_NOTIFIED) then
		objToSelect.add(strObj);
	endif;
	self.allAllowedTISites.add(strObj);
	// 03.11.2025	navcs2	MTN-36231	End
	
	if not _defaultTemplate.isKindOf( CMQF_TransVoyageCargoChanges ) and	//28 Feb 2012	NDL	Par 29118
	   not _defaultTemplate.isKindOf( CMQF_OrganisationAccess ) then	// 20 Feb 2013	cnwjre1	Par 31156 only want on site or on ship reporting
	
		create strObj transient;
		strObj.string := app.siteEnumToString(TI_SITE_TBA);
		if defaultSites &lt;&gt; null and defaultSites.includes(TI_SITE_TBA) then
			objToSelect.add(strObj);
		endif;
		self.allAllowedTISites.add(strObj);
		
		create strObj transient;
		strObj.string := app.siteEnumToString(TI_SITE_UNDEFINED);
		if defaultSites &lt;&gt; null and defaultSites.includes(TI_SITE_UNDEFINED) then
			objToSelect.add(strObj);
		endif;
		self.allAllowedTISites.add(strObj);
	
	endif;
	
	_lstTable.displayCollection(self.allAllowedTISites, false, Table.DisplayCollection_Forward, null);
	_lstTable.setSelected(objToSelect);
	_lstTable.lostFocus(_lstTable);

epilog
	delete objToSelect;
	strObj := null;
end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadTemplateDateTypes" id="396df198-b7ab-4f87-9724-8625904c2f32">
        <source>doLoadTemplateDateTypes(_combo : ComboBox input);
// ---------------------------------------------------------------------------
// Created:     12 January 2004	cnwth2
//
// Purpose:     
//			 
