    <JadeMethod name="getMatchPriority" id="5750b6e3-a19f-4072-914c-966b65519c61">
        <source>getMatchPriority(arbiter: CM_RTQueueArbiter io;
					_fromLocation,
					_toLocation 	: CM_LocationsController): Integer;
//If this queue matches the (source, target, enforcementLevel) criteria 
//then return true, else false.
// 26/08/2010 cnwmh5	#25510/25512 - Add queue logging
// ### JIRA 35862 08SEP2025 NAVAB1 added Tab for collapsible View
vars
	voyageJob:  CM_VoyageJob;
	loggingText	: String;
	isForVoyageAlloc : Boolean;
begin

	if arbiter.job.allRequests.size &gt; 0 then
		isForVoyageAlloc := arbiter.job.isVoyageAllocLoad(); //cnwrd1 ccms 1303
	endif;
	
	if not arbiter.job.hasBulkReleaseItem and 
		not isForVoyageAlloc and
		inheritMethod(arbiter,_fromLocation,_toLocation) = Match_Fail then
		// voyage doesn't match
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Voyage does not match)");
		return Match_Fail;
	endif;

	// check job is for this crane
	if not arbiter.isVoyageJob then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Job not for this crane)");
		return Match_Fail;
	else
		voyageJob := arbiter.job.CM_VoyageJob;
	endif;
	
	// PAR 24866
	if voyageJob.myVoyage &lt;&gt; self.myVoyage then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Voyages do not match)");
		return Match_Fail;
	endif;

	if voyageJob.getJobCrane = crane then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Crane.String &amp; " (Crane found for voyage)");
		return Match_Crane;
	// PAR 23819
	elseif arbiter.job.isKindOf(CM_VoyageROROJob) 
	and not self.myVoyage.hasCraneGotJS(self.crane) then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Crane.String &amp; " (Crane found for voyage)");
		return Match_Crane;
	endif;

	arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Crane not found)");
	return Match_Fail;
epilog
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_fromLocation" type="CM_LocationsController"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
