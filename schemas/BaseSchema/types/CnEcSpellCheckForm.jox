    <JadeMethod name="populateSuggestedWords" id="decad2c5-ff44-4670-95a0-c20e77e8273b">
        <source>populateSuggestedWords() protected;

vars
	word : String;
	
begin
	lstProspectWords.clear();

	if optSoundex.value then
		foreach word in self.aAllSuggestedSoundexWords do
			lstProspectWords.addItem(word);
		endforeach;
		if self.aMySpellCheck &lt;&gt; null then
			self.aMySpellCheck.setIsMetaphoneSearch(false);
		endif;
	elseif optMetaphone.value then
		foreach word in self.aAllSuggestedMetaphoneWords do
			lstProspectWords.addItem(word);
		endforeach;
		if self.aMySpellCheck &lt;&gt; null then
			self.aMySpellCheck.setIsMetaphoneSearch(true);
		endif;			
	endif;
	
	if self.aAllSuggestedSoundexWords.size() = 0 then
		lstProspectWords.enabled	:=	false;
		lstProspectWords.addItem("No suggestions available...");
	else
		lstProspectWords.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="replaceWordOnce" id="f68c4777-b9f8-4551-909e-a1b8f11f5d02">
        <updating/>
        <source>replaceWordOnce() updating, protected;

begin
	if txtReplace.text &lt;&gt; "" then
		if self.aMySpellCheck &lt;&gt; null then
			self.aMySpellCheck.setReplaceOnce(txtReplace.text.trimBlanks());
		endif;
	endif;
	
	self.nextWord();
end;</source>
        <access>protected</access>
    </JadeMethod>
