    <JadeMethod name="processStopsEDI" id="d3a73ee1-62d3-4630-8490-6a3ab2007d60">
        <updating/>
        <source>processStopsEDI() updating;
// ---------------------------------------------------------------------------
// Created:		January 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxProcessStopsEDIOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Process Customs EDI', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	app.mousePointer := Window.MousePointer_Default;						

end;</source>
    </JadeMethod>
    <JadeMethod name="qualSubForms" id="c9503b5f-e076-459f-ae7b-3945fb223daa">
        <source>qualSubForms() protected;
//-----------------------------------------------------------------------
//	Created:	30 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
begin

	inheritMethod();

end;</source>
        <access>protected</access>
        <text>		Voyage Definition (SHP_VoyageDefinitionForm)
		Bay Definition (SHP_BayDefinitionVoyageForm)
		Exchange Summary (SHP_VoyageExchangeSummaryForm)
		Vessel Definition (SHP_VesselDefinitionForm)
		Translations (CMUI_SysOpsXlationForm)
		Event Schedule Selector (CMUI_EventScheduleSelector)
		Voyage Resourses Used (HMS_VoyageResourceUsedNonMDI)
		Voyage Resourses Used (HMS_VoyageResourceUsedForm)</text>
    </JadeMethod>
    <JadeMethod name="runCurrentStatusReport" id="0588deff-6221-4bb6-a248-64eae945eeec">
        <source>runCurrentStatusReport();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38905

*/

vars

	voyStatus : CM_VoyageStatus;

begin

	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentVoyage.status &gt; 0 then
			voyStatus := app.myRoot.allVoyageStatuses[ self.myCurrentVoyage.status ];
			if voyStatus &lt;&gt; null then
				voyStatus.runStatusReportFor( self.myCurrentVoyage );
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="runProformaReportForOuput" id="e0553039-8d88-4c07-b34c-ea6ca69228e6">
        <source>runProformaReportForOuput();
/*
Purpose:	

Date		Who		Reason
27 August 2024	navab1	CR 65820 TASK 65821
*/

vars
	voyages : CM_VoyageByCodeArrivalDT;
begin
	

	create voyages transient;
	self.tblData.allSelectedObjects.copy(voyages);
	
	if voyages.isEmpty() then
		global.beep;
		return;
	endif;
	
	/* // ### JIRA 33574 06DEC2024 NAVAB1
	// JIRA 32861 27SEP2024 NAVAB1 - Accruals Performance
	if voyages.size &gt; 10 then
		global.beep;
		app.msgBox(app.getErrorString(More_than_voyag_time_profo_rep),app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	
	endif;
	*/
	
	self.runProformaReport(voyages, null);

epilog	
	delete voyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="20a8d5f5-0bf0-4492-af03-556482099a3b">
