    <JadeMethod name="create" id="a9f8fa2e-b479-44be-821c-d7d555085eb5">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin

	self.myDeferredChargesRoot := app.myDeferredChargingRoot;

epilog

end;</source>
