        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
*/

vars
	form : INV_ContractRateMaint;
	bank :CM_Bank;
	cont : CM_InvoiceContractDetails;
begin
	//16/10/2023	navmv20	Bug 60893- start
	form := self.myContractRateMaint;
	if form &lt;&gt; null then
		form.unloadForm();
	endif;
	form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
	self.myContractRateMaint := form;
	form.myParentForm := self;
	/*if form  = null then
		form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
		self.myContractRateMaint := form;
		form.myParentForm := self;
	else
		return;
	endif;*/
	//form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
	//16/10/2023	navmv20	Bug 60893 - end
	
	if form &lt;&gt; null then
		//form.updateMode := false; //31/01/2023	navkc1 Bug 61578
		form.mode := INV_ContractRateMaint.MODE_CREATE; //31/01/2023	navkc1 Bug 61578
		form.setMyCurrentBank(self.myCurrentBank);
		form.setInvContract(self.myInvoiceContract);
		form.setInvContractDetail(null);
		form.centreWindow();
		form.btnAdd.enabled := false;
		form.btnUpdate.enabled := false;
		form.btnRemoveRate.enabled := false;
		form.btnRemoveRtEnt.enabled := false;	
		form.cmbService.enabled := false;
		form.cmbCalculationTypes.enabled := false; // ### TFS CR 61579 TASK 62453 13FEB2024 NAVAB1
		//form.myContractDetails(cont);
		//form.showModal; //16/10/2023	navmv20	Bug 60893
		form.show; //16/10/2023	navmv20	Bug 60893
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAttachmentClick" id="b127961f-f701-4bdc-86b5-7e3f76858f44">
        <source>btnAttachmentClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

