    <JadeMethod name="cnCloseNotify" id="51b40957-936f-4336-93e8-f480f3e4f688">
        <updating/>
        <source>cnCloseNotify(_tcp: CnTcpConnection input) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Oct 2008	cnwkpd1		PAR #17953 - Rework to ensure connections are not leaked
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_tcp);
	self.myTcpIpClientAgent.logMonitor("Connection closed.");
	
	// PAR #17953 - sequence is set parent not connected, try another open
	self.myTcpIpClientAgent.setIsConnected(false);
	
	self.myTcpIpClientAgent.openConnect();

end;</source>
        <Parameter name="_tcp" type="CnTcpConnection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnOpenNotify" id="f8f07295-c8ba-4ada-86e8-9f110643b75f">
        <updating/>
        <source>cnOpenNotify(_tcp: RFC_TcpMsg input) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_tcp); 
	self.myTcpIpClientAgent.setIsConnected(true);
	self.cnRead(self);
	self.myTcpIpClientAgent.logMonitor("Connection Opened.");
	
end;

</source>
        <Parameter name="_tcp" type="RFC_TcpMsg" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnRead" id="49341724-b9a8-4c1d-b4ba-557f9411e061">
        <updating/>
        <source>cnRead(receiver : Object) updating;

//V3 	20.06.01 Don't clear serverMessage here: allow multi-buffer concatenation.
//V2 	21.07.99 Check if logging required
//Reimplemented: note that we do not inheritMethod.

vars
  //	cnCntrl : CnCntrl;		// CnSmtpConnection: Changed from 'cc' as we need that name for the 'carbon copies' class attribute
begin

//	cnCntrl := app.myCnCntrl;
    self.cnArmTcpExceptionHandler;
	self.fillReadBuffer := false; 	//CnSmtpConnection: On each notify, we'll check if CRLF has been received

//	if self.loggingRequired then
	app.writeLog("Connection #" &amp; self.connectionNo.String &amp;
							   " about to readAsync on port " &amp; self.port.String &amp;
							   " .....", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		
//	endif;

	self.cnSetLastAction(Read);
	self.cnSetMyReceiver(receiver);
	self.msgHeader := null;
	self.headerLength := 1024;		//CnSmtpConnection: 
	self.readBinaryAsynch(self.headerLength, receiver, "cnReadNotify");	//CnSmtpConnection: 
end;</source>
        <Parameter name="receiver" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnReadNotify" id="206a3b31-6bbb-404a-922d-b6c03b01990f">
        <updating/>
        <source>cnReadNotify(_tcp: RFC_TcpMsg input; _buf: Binary) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	cc: CnCntrl;
begin
	inheritMethod(_tcp, _buf);
	app.writeLog("Read Notify:"&amp;_buf[1:10].asHex&amp;'x '&amp;_buf.ansiToString(), LogDEBUG);	//cnwrs1 par 25391 17 Aug 2010
	self.myTcpIpClientAgent.processReadData(_buf);										// 16/3/16  cnwns1 PAR 36286 unicode version
epilog
	if self.myTcpIpClientAgent.isConnected then
	 	self.myTcpIpClientAgent.myTcpMsg.cnRead(self);
	endif;
end;</source>
        <Parameter name="_tcp" type="RFC_TcpMsg" usage="input"/>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cnWrite" id="645e50f6-5aac-46d7-b6c7-067f160a8e82">
        <updating/>
        <source>cnWrite(body: Binary; receiver: Object) updating;
//
// par 25391 cnwrs1 17 aug 2010
//
vars

begin
	app.writeLog("write:"&amp;body[1:10].asHex&amp;'x '&amp;body.String, LogDEBUG);
	inheritMethod(body, receiver);
end;
</source>
