    <JadeMethod name="lstData_click" id="4d728460-e083-4b63-9955-42cfd860f234">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstData_click(listbox: ListBox input) updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 17 Mar 2010	cnwcs5		par 22746 - issue clicking on list while it needs to be refreshed
// -----------------------------------------------------------------------------
vars
	theObject	: Object;
	idx			: Integer;

begin
	app.mousePointer := MousePointer_HourGlass;

	if self.timerRefreshActive then	// par 22746
		// list is about to be refreshed so ignore this event
		return;						// par 22746
	endif;							// par 22746
	
	idx := listbox.listIndex;
	if idx &lt;&gt; -1 then
		theObject := listbox.itemObject[idx];
	endif;

	if theObject &lt;&gt; null then
		self.zShowThumbnailData(theObject);
	else
		self.zClearThumbnailData();
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
