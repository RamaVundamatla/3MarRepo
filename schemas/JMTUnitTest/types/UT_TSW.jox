    <JadeMethod name="zTSWFtxDinStorageGenFile" id="2e0f6e1b-4769-40de-996f-452709b5b1c5">
        <source>zTSWFtxDinStorageGenFile(_roleCode : String; _nameCode : String; _responsibleGovernmentAgency : String; _vesselCode, _voyageCode : String; _additionalDetails : JadeDynamicObjectArray input) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 October 2025	navpw1	Initial creation JIRA: MTN-35793

*/

constants
	Placeholder_StatementDescription		: String = "&lt;% StatementDescription %&gt;";
	Placeholder_StatementTypeCode			: String = "&lt;% StatementTypeCode %&gt;";
	Placeholder_SequenceNumeric				: String = "&lt;% SequenceNumeric %&gt;";
	Placeholder_DocumentSectionCode			: String = "&lt;% DocumentSectionCode %&gt;";
	Placeholder_StatementDescription2		: String = "&lt;% StatementDescription2 %&gt;";
	Placeholder_StatementTypeCode2			: String = "&lt;% StatementTypeCode2 %&gt;";
	Placeholder_TransportEquipmentId		: String = "&lt;% TransportEquipmentId %&gt;";
	
vars
	roleCode								: String;
	additionalInformation					: JadeDynamicObject;
	additionalInformationStr,
	additionalInformationSeqStr,
	tempStr									: String;
	transportEquipmentStr					: String;
	nameCode,responsibleGovernmentAgency,
	statementDescription,
	statementTypeCode,
	sequenceNumeric,
	documentSectionCode,
	statementDescription2,
	statementTypeCode2,
	transportEquipmentId					: String;
	
begin
	if _roleCode = null then
		roleCode := "GC";
	else
		roleCode := _roleCode;
	endif;
	
	if _nameCode = null then
		nameCode := "B07";
	else
		nameCode := _nameCode;
	endif;
	
	if _responsibleGovernmentAgency = null then
		responsibleGovernmentAgency := "MPIBIO";
	else
		responsibleGovernmentAgency := _responsibleGovernmentAgency;
	endif;
	
	foreach additionalInformation in _additionalDetails do
		
		statementDescription := additionalInformation.getPropertyValue("statementDescription").String;
		statementTypeCode := additionalInformation.getPropertyValue("statementTypeCode").String;
		sequenceNumeric := additionalInformation.getPropertyValue("sequenceNumeric").String;
		documentSectionCode := additionalInformation.getPropertyValue("documentSectionCode").String;
		
		if statementDescription &lt;&gt; null or statementTypeCode &lt;&gt; null or documentSectionCode &lt;&gt; null then
			//Temp string of our section
			tempStr := "&lt;AdditionalInformation&gt;
							&lt;StatementDescription&gt;&lt;% StatementDescription %&gt;&lt;/StatementDescription&gt;
							&lt;StatementTypeCode&gt;&lt;% StatementTypeCode %&gt;&lt;/StatementTypeCode&gt;
							&lt;Pointer&gt;
								&lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
							&lt;/Pointer&gt;
							&lt;Pointer&gt;
								&lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
								&lt;DocumentSectionCode&gt;28A&lt;/DocumentSectionCode&gt;
							&lt;/Pointer&gt;
							&lt;Pointer&gt;
								&lt;SequenceNumeric&gt;&lt;% SequenceNumeric %&gt;&lt;/SequenceNumeric&gt;
								&lt;DocumentSectionCode&gt;&lt;% DocumentSectionCode %&gt;&lt;/DocumentSectionCode&gt;
							&lt;/Pointer&gt;
						&lt;/AdditionalInformation&gt;" &amp; CrLf &amp; Tab;
			
			//Replace temp string sections
			tempStr := tempStr.replace(Placeholder_StatementDescription, statementDescription)
			.replace(Placeholder_StatementTypeCode, statementTypeCode)
			.replace(Placeholder_SequenceNumeric, sequenceNumeric)
			.replace(Placeholder_DocumentSectionCode, documentSectionCode);
			
			additionalInformationStr &amp;= tempStr;
		endif;
		
		statementDescription2 := additionalInformation.getPropertyValue("statementDescription2").String;
		statementTypeCode2 := additionalInformation.getPropertyValue("statementTypeCode2").String;
		
		if statementDescription2 &lt;&gt; null or statementTypeCode2 &lt;&gt; null then
			tempStr := "&lt;AdditionalInformation&gt;
							&lt;StatementDescription&gt;&lt;% StatementDescription2 %&gt;&lt;/StatementDescription&gt;
							&lt;StatementTypeCode&gt;&lt;% StatementTypeCode2 %&gt;&lt;/StatementTypeCode&gt;
						&lt;/AdditionalInformation&gt;" &amp; CrLf &amp; Tab;
			
			tempStr := tempStr.replace(Placeholder_StatementDescription2, statementDescription2)
			.replace(Placeholder_StatementTypeCode2, statementTypeCode2);
			
			additionalInformationSeqStr &amp;= tempStr;
		endif;
		
		transportEquipmentId := additionalInformation.getPropertyValue("transportEquipmentId").String;
		
		if sequenceNumeric &lt;&gt; null or transportEquipmentId &lt;&gt; null then
			tempStr := "&lt;TransportEquipment&gt;
							&lt;SequenceNumeric&gt;&lt;% SequenceNumeric %&gt;&lt;/SequenceNumeric&gt;
							&lt;FullnessCode&gt;4&lt;/FullnessCode&gt;
							&lt;ID&gt;&lt;% TransportEquipmentId %&gt;&lt;/ID&gt;
						&lt;/TransportEquipment&gt;" &amp; CrLf &amp; Tab;
			
			tempStr := tempStr.replace(Placeholder_SequenceNumeric, sequenceNumeric)
			.replace(Placeholder_TransportEquipmentId, transportEquipmentId);
			
			transportEquipmentStr &amp;= tempStr;
		endif;
		
	endforeach;
	
	additionalInformationSeqStr := additionalInformationSeqStr.stripTrailingChar(Tab).stripTrailingChar(Lf).stripTrailingChar(Cr);
	
	transportEquipmentStr := transportEquipmentStr.stripTrailingChar(Tab).stripTrailingChar(Lf).stripTrailingChar(Cr);
	
	return "&lt;DocumentMetadata xmlns='urn:wco:datamodel:WCO:DM:1' xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'&gt;
    &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
    &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
    &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
    &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
    &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
    &lt;CommunicationMetaData&gt;
        &lt;Recipient&gt;
            &lt;ID&gt;51358641J&lt;/ID&gt;
            &lt;RoleCode&gt;" &amp; roleCode &amp; "&lt;/RoleCode&gt;
        &lt;/Recipient&gt;
    &lt;/CommunicationMetaData&gt;
    &lt;Response xmlns='urn:wco:datamodel:WCO:ResponseModel:1'&gt;
        &lt;IssueDateTime formatCode='204'&gt;20250924155540&lt;/IssueDateTime&gt;
        &lt;FunctionalReferenceID&gt;283&lt;/FunctionalReferenceID&gt;
        &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
        &lt;AdditionalDocument&gt;
            &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
            &lt;ImageBinaryObject filename='PDF7-5078754-2025-09-24-1509795055.pdf' mimeCode='application/pdf' uri='e3a13ccd-0735-4cf6-a058-70b11c0dc417-lodgement'&gt;Attached&lt;/ImageBinaryObject&gt;
        &lt;/AdditionalDocument&gt;
        &lt;OverallDeclaration&gt;
            &lt;Declaration&gt;
                &lt;ID&gt;5078754&lt;/ID&gt;
                &lt;AcceptanceDateTime formatCode='204'&gt;20250924155540&lt;/AcceptanceDateTime&gt;
                &lt;FunctionalReferenceID&gt;EMPTY_1_WLG&lt;/FunctionalReferenceID&gt;
                &lt;VersionID&gt;1&lt;/VersionID&gt;
                &lt;Submitter&gt;
                    &lt;Name&gt;OfficerSubmissionClientCode&lt;/Name&gt;
                &lt;/Submitter&gt;
                &lt;BorderTransportMeans&gt;
                    &lt;Name&gt;" &amp; _vesselCode &amp; "&lt;/Name&gt;
                    &lt;TypeCode&gt;1&lt;/TypeCode&gt;
                    &lt;ArrivalDateTime formatCode='102'&gt;20250805&lt;/ArrivalDateTime&gt;
                    &lt;FirstArrivalLocationID&gt;NZLYT&lt;/FirstArrivalLocationID&gt;
                    &lt;JourneyID&gt;" &amp; _voyageCode &amp; "&lt;/JourneyID&gt;
                &lt;/BorderTransportMeans&gt;
                &lt;Consignment&gt;
                    &lt;GoodsStatusCode StatusType='CLEARANCE'&gt;HLD&lt;/GoodsStatusCode&gt;
                    &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                    "
					&amp; additionalInformationStr &amp;
					additionalInformationSeqStr &amp;
					"
                    &lt;Consignee&gt;
                        &lt;Name&gt;BRD&lt;/Name&gt;
                    &lt;/Consignee&gt;
                    &lt;ConsignmentItem&gt;
                        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                        &lt;GoodsMeasure&gt;
                            &lt;GrossMassMeasure unitCode='KGM'&gt;1234&lt;/GrossMassMeasure&gt;
                        &lt;/GoodsMeasure&gt;
                    &lt;/ConsignmentItem&gt;
                    &lt;Consignor&gt;
                        &lt;Name&gt;CN Chemicals&lt;/Name&gt;
                    &lt;/Consignor&gt;
                    &lt;GoodsLocation&gt;
                        &lt;Name&gt;PORTNZWLG&lt;/Name&gt;
                    &lt;/GoodsLocation&gt;
                    &lt;TransportContractDocument&gt;
                        &lt;ID&gt;332211&lt;/ID&gt;
                        &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
                    &lt;/TransportContractDocument&gt;
                    "
					&amp; transportEquipmentStr &amp; 
					"
                    &lt;UnloadingLocation&gt;
                        &lt;ID&gt;NZWLG&lt;/ID&gt;
                    &lt;/UnloadingLocation&gt;
                &lt;/Consignment&gt;
                &lt;ResponsibleGovernmentAgency&gt;
                    &lt;ID&gt;" &amp; responsibleGovernmentAgency &amp; "&lt;/ID&gt;
                &lt;/ResponsibleGovernmentAgency&gt;
            &lt;/Declaration&gt;
        &lt;/OverallDeclaration&gt;
        &lt;Status&gt;
            &lt;EffectiveDateTime formatCode='204'&gt;20250924155540&lt;/EffectiveDateTime&gt;
            &lt;NameCode&gt;" &amp; nameCode &amp; "&lt;/NameCode&gt;
            &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
            &lt;/Pointer&gt;
            &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
                &lt;TagID&gt;G007&lt;/TagID&gt;
            &lt;/Pointer&gt;
        &lt;/Status&gt;
    &lt;/Response&gt;
&lt;/DocumentMetadata&gt;";

end;</source>
        <access>protected</access>
        <Parameter name="_roleCode" type="String"/>
        <Parameter name="_nameCode" type="String"/>
        <Parameter name="_responsibleGovernmentAgency" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_additionalDetails" type="JadeDynamicObjectArray" usage="input"/>
        <ReturnType type="String"/>
