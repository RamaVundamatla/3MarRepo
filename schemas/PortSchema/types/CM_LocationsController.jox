    <JadeMethod name="totalWeightTonnes" id="e086bfb7-2e68-485f-ba5f-4b3d8b120411">
        <methodInvocation>mapping</methodInvocation>
        <source>totalWeightTonnes(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//  Apr/2003	RJS			Removed serverExecution - sped up move	
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	soh			: CM_SOHLocation;
	tot			: Decimal[14,4];
	loadState	: Boolean;
begin
	if set then
		app.raiseSetVirtualError(Class.name, method.name);
	else
		app.cmsBeginLoad(loadState);
		if self.isStockControlled then
			foreach soh in self.allProductLocations do
				tot := tot + soh.currentWeightKgs;
			endforeach;
		else
			tot := self.getTotalWeightActual();
		endif;
		_value := tot / 1000;	// return as tonnes
	endif;

epilog
	app.cmsEndLoad(loadState);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unplanAllTrackedItems" id="b3524b58-9d09-4852-82e0-1add7db2b18c">
        <updating/>
        <source>unplanAllTrackedItems(_moveMode : Integer) updating;
/*
------------------------------------------------------------------------
Created:			03 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------

------------------------------------------------------------------------
*/
vars
	tis 		: CM_TIArray;
	ti 			: CM_TrackedItem;
	moveControl : CMIF_MoveController;
begin

	create tis transient;
	self.getTIs(tis, _moveMode, true); // PAR 27749
	ti := tis.first;
	if ti = null then
		return;
	endif;
	
	tis.remove(ti); //this TI is used to set the controller

	create moveControl transient;
	moveControl.setMoveMode(PLANNING_MODE);
	moveControl.isFullyUnplan := true;		

	tis.copy(moveControl.allOtherTrackedItems);

	moveControl.setMyTrackedItem(ti);
	moveControl.setMyToPrimaryLocation(null);
	app.myUtilityUA.utlUpdateMoveTIUndo(moveControl, app.myPassport);

epilog
	delete tis;
	delete moveControl;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
