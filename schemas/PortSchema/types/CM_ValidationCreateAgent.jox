    <JadeMethod name="valCreateInOut" id="57fe9d75-ebd1-44c4-b8ec-305f08536ba4">
        <updating/>
        <source>valCreateInOut(pIntFaceCommon : CMIF_InOutCommon input; pIntFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/02/2009	CNWER1		method now called from trxCreateInOut - extracted rest of validation in that method into here
// ---------------------------------------------------------------------------
vars
	item,
	item2 : CMIF_TIObject;
	nullObject	: CM_Object;
	chkHazDocs,
	cancelAutoComplete : Boolean;	
	theTI 		: CM_TrackedItem;
	 hazList			: String;
begin
	chkHazDocs := _passport.myTerminal.getConfig(GateInOutHazardousWarning).Boolean;
	//We should have ONE common interface object and at least ONE
	//other type of interface object. Don't start if not.
	if pIntFaceCommon = null or pIntFaceArray.size &lt; 1 then
		app.raiseCMException(ErrorOnStore_NoJobs, null, null);
		return;
	endif;
	
	// do the validation here
	pIntFaceCommon.validateForCreate(_passport);
	
	foreach item in pIntFaceArray do
		item.validateForCreate(_passport);		//Also does the sub items	
		// ### CCMS 1355
		if chkHazDocs and item.isKindOf(CMIF_ReleaseById) then
			theTI := item.CMIF_ReleaseById.myTrackedItem;
			if theTI &lt;&gt; null and theTI.isHazardous then
				if hazList = null then
					hazList := theTI.id;
				else
					hazList := hazList &amp; "," &amp; theTI.id;
				endif;
			endif;
		endif;
		
		if pIntFaceCommon.autoComplete and item.isKindOf(CMIF_ReleaseByType) then
			pIntFaceCommon.autoComplete := false;
			cancelAutoComplete := true;
		endif;
		
		foreach item2 in pIntFaceArray do
			if item2 = item then
				continue;
			endif;
			item.checkIsDuplicate(item2);
		endforeach;
		if _passport.hasErrors() then
			break;
		endif;
	endforeach;
	
	//### CCMS 1355
	if chkHazDocs and hazList &lt;&gt; null  then
		app.raiseCMWarning1(WarningConfirmHazadousDocos, hazList, null, null, pIntFaceCommon.myProxyRoadJob);
	endif;

	if cancelAutoComplete then
		app.raiseCMWarning(WARN_CANCEL_AUTOCOMPLETE, ETRow_AutoComplete, null, pIntFaceCommon.myProxyRoadJob);
	endif;
epilog
	
	
end;</source>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valCreateInterfaceDefinition" id="fbef323c-027a-4745-a566-5d061e573817">
        <updating/>
        <source>valCreateInterfaceDefinition(_pxyObject:CM_TCPInterfaceDefinition; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Validates the creation of a new Interface Definition object.
//
// Parameters:	_pxyObject - A reference to a proxy Interface Definition object.
