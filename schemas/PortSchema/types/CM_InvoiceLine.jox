    <JadeMethod name="getExtRefForCharges" id="f0e522f4-b2c9-4133-9f81-f9dbaeca8819">
        <source>getExtRefForCharges(_taxExtRef : StringArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
20-04-2023 	navtnr20 Task 57620: EUP - Invoice Line Type / Services Configuration Updated Requirements
*/

vars
	charge  : CM_Charge;
	taxCode : CM_TaxCode;
begin
	_taxExtRef.clear();
	foreach charge in self.charges do
		taxCode:= charge.getTaxCodeObject();
		if taxCode &lt;&gt; null then	//navtnr20 20-04-2023 TFS 57620
			if _taxExtRef.cnFind(taxCode.externalReference1) = 0 then	//navtnr20 20-04-2023 TFS 57620
				_taxExtRef.add(taxCode.externalReference1);
			endif;
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_taxExtRef" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getExternalInvoiceNumber" id="f89d3f43-c7f4-4507-9906-9df1e5d7bd78">
        <source>getExternalInvoiceNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin

	if self.invoice = null then
		return null;
	endif;
	
	return self.invoice.getExternalInvoiceNumber();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="bf563f47-11c4-407a-b75b-bf25514f9295">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
// 16 Dec 2021  navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
// 05 Sep 2024	navnk30	Bug 65912: EUP | FR 53382 - Invoice Line Incoterm and Storage Operator
vars
	isGhana,
	invalidObject		: Boolean;
	charge 				: CM_Charge;
	block 				: CM_DataContainerBlock;
	theTransaction 		: CM_TITransaction;
	aCon 				: CM_ConsigneeConsignor;
	snapShotData		: CM_DynamicObject_Snapshot;
	snapShotQuantity	: CM_SnapshotField;
	calcType 			: CM_CalculationType;
	statusChangeAudit 	: CM_Audit;
	invoice				: CM_Invoice;
	ti					: CM_TrackedItem;
	cooHeader			: CM_OwnershipChange;
	debitTotal : Decimal[23,4];
begin
	theTransaction := self.myTransactionTI;
	calcType 	   := self.invoiceLineDesc.myCalculationType;
	invoice		   := self.invoice;								//16.12.2021 navma1 #52580
	ti			   := self.trackedItem;							//16.12.2021 navma1 #52580
	isGhana 	   := app.myRoot.isClientGhana();				//03/06/2025	navkc1 JIRA MTN 35022

	
	// ### JIRA 33007 03DEC2024 NAVAB1 moved down
	block := _dataContainer.addNewBlock;
	block.addNewItem("Invoice Line Type", DC_Label, 1, self);
	block.addNewItem(self.invoiceLineDesc.narration, 	DC_Data,   1, self);

	// ### JIRA 33007 03DEC2024 NAVAB1
	block := _dataContainer.addNewBlock;
	block.addNewItem("Line Remarks", DC_Label, 1, self);
	block.addNewItem(self.remarks, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Number), DC_Label, 1, self);
	block.addNewItem(self.sequenceNum.String, DC_Data, 1, self);

	if invoice &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Invoice_Number), DC_Label, 1, self.invoice);
		block.addNewItem(self.invoice.sequenceNum.String, DC_Data, 1, self.invoice);
	endif;

	if calcType &lt;&gt; null and calcType.isMeasurementType() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Measurement_type), DC_Label, 1, self);
		block.addNewItem(calcType.getMeasurementTypeDescription(), DC_Data, 1, self);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Original_invoice_quantity), DC_Label, 1, self);
		
		if calcType.myMeasurementType.isWeight() then
			block.addNewItem(self.trackedItemWeight.asStringJMTWithPrecision(2,false) &amp; " (" &amp; app.getErrorString(Weight) &amp; ")", DC_Data, 1, self);
		elseif calcType.myMeasurementType.isVolume() then
			block.addNewItem(self.trackedItemVolume.asStringJMTWithPrecision(2,false) &amp; " (" &amp; app.getErrorString(Volume) &amp; ")", DC_Data, 1, self);
		elseif calcType.myMeasurementType.isLinear() then
			block.addNewItem(self.trackedItemLength.asStringJMTWithPrecision(2,false) &amp; " (" &amp; app.getErrorString(Length) &amp; ")", DC_Data, 1, self);
		endif;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Debtor_GC), DC_Label, 1, self.debtor);
	block.addNewItem(self.debtor.name, DC_Data, 1, self.debtor);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Quantity), DC_Label, 1, self);
	block.addNewItem(self.quantity.String, DC_Data, 1, self);

	if self.quantityNoMinMax &lt;&gt; 0 then		// CCMS 1264
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Quantity_before_minmax), DC_Label, 1, self);
		block.addNewItem(self.quantityNoMinMax.String, DC_Data, 1, self);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Void), DC_Label, 1, self);
	block.addNewItem(self.voided.getYesNo, DC_Data, 1, self);

	statusChangeAudit:=self.getLastStatusChangeAudit();
	if statusChangeAudit &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Status_change_reason_code), DC_Label, 1, null);
		block.addNewItem(statusChangeAudit.statusChangeReasonCode , DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Status_change_reason), DC_Label, 1, null);
		block.addNewItem(statusChangeAudit.clearingRemarks  , DC_Data, 1, null);
		
	endif;
	
	if ti &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Tracked_Item), DC_Label, 1, ti);
		block.addNewItem(ti.id, DC_Data, 1, ti);
		
		if ti.myOperator &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Cargo_Operator), DC_Label, 1, ti.myOperator);
			block.addNewItem(ti.myOperator.description, DC_Data, 1, ti.myOperator);
		endif;
		
		if ti.myFreightForwarder &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Freight Forwarder", DC_Label, 1, ti.myFreightForwarder);
			block.addNewItem(ti.myFreightForwarder.description, DC_Data, 1, ti.myFreightForwarder);
		endif;
		
		aCon := ti.getConsignorObject();
		if aCon  &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Consignor), DC_Label, 1, aCon);
			block.addNewItem(aCon.description, DC_Data, 1, aCon);
		endif;
		
		if ti.myConsignee &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Consignee", DC_Label, 1, ti.myConsignee);
			block.addNewItem(ti.myConsignee.description, DC_Data, 1, ti.myConsignee);
		endif;
		
		if ti.myVoyage &lt;&gt; null and ti.myVoyage.myOperator &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Ship Operator", DC_Label, 1, ti.myVoyage.myOperator);
			block.addNewItem(ti.myVoyage.myOperator.description, DC_Data, 1, ti.myVoyage.myOperator);
		endif;
		
		if ti.myCustomsAgent &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Customs_Agent), DC_Label, 1, ti.myCustomsAgent);
			block.addNewItem(ti.myCustomsAgent.name, DC_Data, 1, ti.myCustomsAgent);
		endif;
			
		// Move here to check for null TI - 20 September 2024	navab1	CR 65827 TASK 65829
		cooHeader := ti.getCOOForDate(self.chargeTime);		//05.09.2024 navnk30 #65912
		if cooHeader &lt;&gt; null then							//05.09.2024 navnk30 #65912
			if cooHeader.myIncoterm &lt;&gt; null then
				block := _dataContainer.addNewBlock();
				block.addNewItem(app.getErrorString(CM_INCO_Terms), DC_Label, 1, self);
				block.addNewItem(cooHeader.myIncoterm.code, DC_Data, 1, self);
			endif;
			
			if cooHeader.myOperatorStorage &lt;&gt; null then
				block := _dataContainer.addNewBlock();
				block.addNewItem(app.getErrorString(CM_Storage_Operator), DC_Label, 1, self);
				block.addNewItem(cooHeader.myOperatorStorage.code, DC_Data, 1, self);
			endif;
		endif;
	endif;
	if theTransaction &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Transaction), DC_Label, 1, theTransaction);
		block.addNewItem(theTransaction.class.name[4:end], DC_Data, 1, theTransaction);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Performed_By), DC_Label, 1, theTransaction);
		block.addNewItem(theTransaction.userId, DC_Data, 1, theTransaction);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Performed_On), DC_Label, 1, theTransaction);
		block.addNewItem(self.systemToLocalTime(theTransaction.dateTime).String, DC_Data, 1, theTransaction);// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_UR_Number), DC_Label, 1, theTransaction);
		block.addNewItem(theTransaction.urNumber, DC_Data, 1, theTransaction);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Operator_Code), DC_Label, 1, theTransaction);
		block.addNewItem(theTransaction.operatorCode, DC_Data, 1, theTransaction);

		// PAR 16898 - RJS June 2008
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(FreightForwarder), DC_Label, 1, theTransaction);
		block.addNewItem(theTransaction.freightForwarderCode, DC_Data, 1, theTransaction);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_No_Charge), DC_Label, 1, theTransaction);
		block.addNewItem(theTransaction.noCharge.getYesNo, DC_Data, 1, theTransaction);
	endif;
	
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	snapShotData := self.mySnapShotData;
	if snapShotData &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, snapShotData, invalidObject);
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Snapshot_definition), DC_Label, 1, snapShotData);
		block.addNewItem(snapShotData.mySnapshotData.name, DC_Data, 1, snapShotData);
	endif;
	snapShotQuantity := self.mySnapShotQuantity;
	if snapShotQuantity &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, snapShotQuantity, invalidObject);
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Heading_Attribute), DC_Label, 1, snapShotQuantity);
		block.addNewItem(snapShotQuantity.heading, DC_Data, 1, snapShotQuantity);
	endif;
	
	
	
	
	
	//16.12.2021 navma1 #52580
	if invoice &lt;&gt; null and not invoice.allWorkOrders.isEmpty  then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(WorkOrder), DC_Label, 1, invoice.allWorkOrders.first);
		block.addNewItem(invoice.allWorkOrders.listString(Comma,CM_WorkOrder::id.name) , DC_Data, 1, invoice.allWorkOrders.first);
	endif;
	
	// ### TFS CR 61911 TASK 62405 08FEB2024 NAVAB1
	if self.contractId &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Contract), DC_Label, 1, self);
		block.addNewItem(self.contractId , DC_Data, 1,self);
	endif;
	if self.myInvoiceContractDetail &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Invoice_contract_criteria), DC_Label, 1, self.myInvoiceContractDetail);
		block.addNewItem(self.myInvoiceContractDetail.invoiceContractCriteria , DC_Data, 1,self.myInvoiceContractDetail);
	endif;

	
	
	
	
	
	foreach charge in self.charges do
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Charge), DC_MoreInfo, 1, charge);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Number), DC_Label, 1, charge);
		block.addNewItem(charge.sequenceNum.String, DC_Data, 1, charge);
		
		//cnwmc5 - 25 Sep 2015 - PAR 36965
		if charge.service &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Service_GC), DC_Label, 1, charge);
			block.addNewItem(charge.service.name, DC_Data, 1, charge);
		endif;

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Quantity), DC_Label, 1, charge);
		
		//03/06/2025	navkc1 JIRA MTN 35022
		if isGhana then
			block.addNewItem(charge.getQuantity().String, DC_Data, 1, charge); // Ghana wants 10 decimals
		else
			// ### TFS BUG 61269 21NOV2023 NAVAB1		block.addNewItem(self.quantity.String, DC_Data, 1, charge);
			block.addNewItem(charge.getQuantity().asStringJMTWithPrecision(2,false), DC_Data, 1, charge); // ### TFS BUG 61269 21NOV2023 NAVAB1
		endif;

		// ### TFS BUG 61269 21NOV2023 NAVAB1 - moved here so is on right column
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Unit), DC_Label, 1, charge);
		block.addNewItem(charge.units, DC_Data, 1, charge);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Rate), DC_Label, 1, charge);
		block.addNewItem(charge.getRate.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true), DC_Data, 1, charge); // TFS 36954 MPD 20 Feb 2018

		// ### TFS BUG 61269 21NOV2023 NAVAB1 - moved here so is on right column
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_GL_Code), DC_Label, 1, charge);
		block.addNewItem(charge.glCode, DC_Data, 1, charge);

		// ### TFS BUG 61269 21NOV2023 NAVAB1
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Total), DC_Label, 1, charge);
		
		//03/06/2025	navkc1 JIRA MTN 35022
		if isGhana then
			block.addNewItem(charge.getChargeTotalTen().String, DC_Data, 1, charge); //03/06/2025	navkc1 JIRA MTN 35022 Ghana wants 10 decimals
		else
			block.addNewItem(charge.total.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true), DC_Data, 1, charge);
		endif;

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Overridden), DC_Label, 1, charge);
		block.addNewItem(charge.overridden.getYesNo, DC_Data, 1, charge);

		// ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Volume_based), DC_Label, 1, charge);
		block.addNewItem(charge.isVolumeBased().getYesNo(), DC_Data, 1, charge);
	endforeach;


	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Totals), DC_MoreInfo, 1, charge);
	block.addNewItem(app.getErrorString(CM_Total_Charge), DC_Label, 1, charge);
	//03/06/2025	navkc1 JIRA MTN 35022
	if isGhana then
		block.addNewItem(self.getLineTotalTen().String, DC_Data, 1, charge); //03/06/2025	navkc1 JIRA MTN 35022 Ghana wants 10 decimals
	else
		block.addNewItem(self.lineTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, charge);
	endif;
		 
	// ### JIRA 35790 01SEP2025 NAVAB1
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Total Amount Static (special)", DC_Warning, 1, null);
		debitTotal := self.totalAmount;
		block.addNewItem(debitTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Line Total Dynamic (special)", DC_Warning, 1, null);
		debitTotal := self.lineTotal;
		block.addNewItem(debitTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);

	
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstNonCancelledPayment" id="8458ad64-63ba-4342-b971-df1670a09fb1">
        <source>getFirstNonCancelledPayment() : CM_CashPayment;
/*
Purpose:	

Date		Who		Reason
29 July 2025	navab1	JIRA 35593
*/

vars
	pay : CM_CashPayment;
begin
	foreach pay in self.allCashPayments discreteLock, reversed do
		if not pay.isCancelled() then
			return pay;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_CashPayment"/>
    </JadeMethod>
