        "postCode": "NextGenOth",
        "email": "NextGenOth@euroports.com"
      }
    ]
  }
]
';

IncomingJsonStringUpdate = '[
  {
    "relatedEntities": {
      "createIfMissing": true,
      "updateEntityDescriptions": true,
      "carriers": [
        {
          "id": "",
          "description": "CAR102"          
        }
      ],
       "consignors": [
        {
          "id": "",
          "description": "CON102"         
        }
      ],
       "customsAgents": [
        {
          "id": "",
          "description": "CUS102"          
        }
      ],
       "operators": [
        {
          "id": "",
          "description": "OPE102"
         
        }
      ],
       "shippingLines": [
        {
          "id": "",
          "description": "SHP102"         
        }
      ],
       "stevedores": [
        {
          "id": "",
          "description": "STV102"         
        }
      ]      
    },
    "id": "'&amp;DebtorId&amp;'",
    "name": "'&amp;DebtorName&amp;'",
    "description": "CustomerName",
    "badCredit": false,
    "suspended": false,
    "termsOfTradeId": "Pay",
    "terminalSpecificConfiguration": [
      {
        "id": "NDL",
        "cashOnly": false,
        "paymentType": "",
        "currencyId": "EUR",
        "localeId": "NL",
        "invoiceReportName": "",
        "organisationCode": "OU",
        "intercompanyCode": "ICO"
      }
    ],
    "tax": {
      "number": "TaxRegNumber1",
      "countryId": "SN"
    },
    "addresses": [
      {        
        "description": "NextGen",
        "type": "Billing",
        "line1": "NextGen",
        "line2": "NextGen",
        "line3": "NextGen",
        "city": "NextGen",
        "region": "NextGen",
        "isoCountryCode": "Cou",
        "postCode": "NextGen",
        "email": "NextGen@euroports.com"
      },
      {        
        "description": "1RealNextGenDef",
        "type": "Default",
        "line1": "RealNextGenAlt",
        "line2": "RealNextGenAlt",
        "line3": "RealNextGenAlt",
        "city": "RealNextGenAlt",
        "region": "RealNextGenAlt",
        "isoCountryCode": "Alt",
        "postCode": "RealNextGenAlt",
        "email": "RealNextGenAlt@euroports.com"
      },
      {        
        "description": "1RealNextGenAlt",
        "type": "Alternate",
        "line1": "RealNextGenAlt",
        "line2": "RealNextGenAlt",
        "line3": "RealNextGenAlt",
        "city": "RealNextGenAlt",
        "region": "RealNextGenAlt",
        "isoCountryCode": "Alt",
        "postCode": "RealNextGenAlt",
        "email": "RealNextGenAlt@euroports.com"
      },
      {             
        "description": "NewOtherNextGenOth",
        "type": "Other",
        "line1": "NextGenOth",
        "line2": "NextGenOth",
        "line3": "NextGenOth",
        "city": "NextGenOth",
        "region": "NextGenOth",
        "isoCountryCode": "Oth",
        "postCode": "NextGenOth",
        "email": "NextGenOth@euroports.com"
      }
    ]
  }
]
';

vars
	incomingJsonString,
	incomingJsonStringTooLong,
	terminalCode,
	loginJson,
	euroPortsLogin,
	euroPortsJson,
	operatorIdNotSupported,
	ret				: String;
	expectFailure	: Boolean;
	result 			: String;
	
	root			: CM_Root;
	debtor			: CM_Debtor;
	carrier			: CM_Carrier;
	consignee		: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	shippingLine	: CM_ShippingLine;
	stevedore		: CM_Stevedore;
	customsAgent	: CM_CustomsAgent;
	debtorOidAsHex	: String;
	hexOid			: String;
begin
	
	
	root := self.getRoot();
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	// Clean up
	debtor := app.myRoot.myRootCompany.debtors[DebtorName];
	
	if debtor &lt;&gt; null then
		if not debtor.allCarriers.isEmpty then
			self.deleteCarrier(debtor.allCarriers.first.CM_Carrier.code);
		endif;
		if not debtor.consignors.isEmpty then
			self.deleteConsigneeConsignor(debtor.consignors.first.CM_ConsigneeConsignor.code);
		endif;
		if not debtor.allCustomsAgents.isEmpty then
			self.deleteCustomsAgent(debtor.allCustomsAgents.first.CM_CustomsAgent.code);
		endif;
		if not debtor.operators.isEmpty then
			self.deleteOperator(debtor.operators.first.CM_Operator.code);
		endif;
		if not debtor.allShippingLines.isEmpty then
			self.deleteShippingLine(debtor.allShippingLines.first.CM_ShippingLine.code);
		endif;
		if not debtor.allStevedores.isEmpty then
			self.deleteStevedore(debtor.allStevedores.first.CM_Stevedore.code);
		endif;
	endif;
	

	self.opts.purge();
	self.opts.addAssoc("RelatedEntities", true.Boolean);
	self.deleteDebtor(DebtorName);
	
		loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	//Create Debtor
	
	// Incoming Json string. Everything OK.
	incomingJsonString := IncomingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);	

	debtor := app.myRoot.myRootCompany.debtors[DebtorName];
	debtorOidAsHex := debtor.getOidAsHex().reverse;
	hexOid	:= debtorOidAsHex[1:4];// 4 characters	
	
	self.assertNotNullMsg(debtor, "Debtor " &amp; DebtorName);
	
	carrier := debtor.allCarriers.first;
	self.assertNotNullMsg(carrier, "Carrier " &amp; hexOid);	
	
	consignee := debtor.consignors.first;
	self.assertNotNullMsg(consignee, "Consignee/or " &amp; hexOid);
	
	customsAgent := debtor.allCustomsAgents.first;
	self.assertNotNullMsg(customsAgent, "Customs Agent " &amp; hexOid);
	
	operator := root.allOperators[hexOid];
	self.assertNotNullMsg(operator, "Operator " &amp; hexOid);
	
	shippingLine := debtor.allShippingLines.first;
	self.assertNotNullMsg(shippingLine, "Shipping Line " &amp; hexOid);
	
	stevedore := debtor.allStevedores.first;
	self.assertNotNullMsg(stevedore, "Stevedore " &amp; hexOid);
	
	
	//Update Debtor 

	// Incoming Json string. Everything OK.
	incomingJsonString := IncomingJsonStringUpdate;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);	

	debtor := app.myRoot.myRootCompany.debtors[DebtorName];
	
	self.assertNotNullMsg(debtor, "Debtor " &amp; DebtorName);
	
	carrier := debtor.allCarriers.first;
	self.assertNotNullMsg(carrier, "Carrier " &amp; hexOid);	
	
	consignee := debtor.consignors.first;
	self.assertNotNullMsg(consignee, "Consignee/or " &amp; hexOid);
	
	customsAgent := debtor.allCustomsAgents.first;
	self.assertNotNullMsg(customsAgent, "Customs Agent " &amp; hexOid);
	
	operator := root.allOperators[hexOid];
	self.assertNotNullMsg(operator, "Operator " &amp; hexOid);
	
	shippingLine := debtor.allShippingLines.first;
	self.assertNotNullMsg(shippingLine, "Shipping Line " &amp; hexOid);
	
	stevedore := debtor.allStevedores.first;
	self.assertNotNullMsg(stevedore, "Stevedore " &amp; hexOid);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uPostSendEDIManifestOnsite" id="eb38c713-61e7-4942-b265-e4223d9e2981">
        <source>uPostSendEDIManifestOnsite();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2023	navdap1		Initial creation TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
//
constants
	IncomingJsonStart = '{
	"clientRef": "';
	
	IncomingJsonMiddle = '",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';
	
	IncomingJsonTrailer = '"}';
	
	EDIClientRef = "ONSITE_";
	OperatorCode : String = "ZMMR";
	VesselId : String = "VESS_56747";
	VoyageId : String = "VOY_56747";
	ShipLine : String = "CMA";
	BlockStack : String = "BS_56747";
	Cargo1 : String = "F3086022D0--A";
	Cargo2 : String = "F3086022D0--B";
	CargoGroupId : String = "64336-1-2-2";
	
vars
	cargoId1, cargoId2, cargoGroupId : String;
	incomingJsonString,
	testScenarioName : String;
	clientRef : String;
	ediFile : CM_EDIFile;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bs : CM_BlockStack;
	ediConfig : CM_EDIConfig;
	now : TimeStamp;
	
begin
	//create data for unit test
    operator := self.getOperator(OperatorCode);
	self.assertNotNullMsg(operator, "ZMMR Operator");
	
	//Delete Vessel/Voyage if exist
	self.deleteVoyage(VoyageId);
	self.deleteVessel(VesselId);
	// Create Vessel/Voyage
	vessel := self.addVesselGeneralCargo(VesselId, operator, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageId, VesselId,operator.code, ShipLine, 2);
	
	// create a block stack
	self.deleteTerminalArea(BlockStack);
	bs := self.getTerminalArea(BlockStack).CM_BlockStack;
	self.assertNullMsg(bs, "Block Stack " &amp; BlockStack &amp; " not deleted");
	bs := self.addBlockStack(BlockStack, null, null);
	self.assertNotNullMsg(bs, "Block Stack " &amp; BlockStack &amp; " not created");
	
	// delete the cargo group and cargo items
	cargoId1 := Cargo1;
	cargoId2 := Cargo2;
	cargoGroupId := CargoGroupId;
	self.deleteTrackedItem(cargoId1, true);
	self.deleteTrackedItem(cargoId2, true);
	self.deleteCargoGroup(cargoGroupId);
	
	testScenarioName := "ManifestOnSite|SunnyDay";
	
	clientRef := EDIClientRef &amp; now.formatAsYYYYMMDDHHMMSSMMM;
	
	incomingJsonString := IncomingJsonStart &amp; clientRef &amp; IncomingJsonMiddle &amp; self.zOnsiteExample(VoyageId, BlockStack, CargoGroupId, "ZI643361D", "Create").Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);	
	
	ediConfig := self.getMyTerminal.myEdiConfig;
	if ediConfig &lt;&gt; null then
		ediFile := ediConfig.allEDIFilesByEdiClientRef[clientRef];
	endif;
	
	self.assertNotNull(ediFile);
	
epilog
	delete emailCarrierAddresses;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPostSendEDIManifestRoad607931" id="3309ec92-f696-46de-bd87-9abee1d71889">
        <updating/>
        <source>uPostSendEDIManifestRoad607931() updating;
//
// Purpose:Timing issue
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05 Mar 2024	navsp1		Initial creation TFS 61039

constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "UTSP02";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON57";
	OperatorCode 			= "UT57";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "MANSH18032401";//"MANRD6079301";
	EDIClientRefShp			= "MANSH18032401";
	EDIClientRef2			= "MANRD6079302";
	HazardClassID			= "HAZRD";
	ItemPrefix				= "SP60793";
	ItemID_1 				= "SP607930001";
	ItemID_2 				= "SP607930002";
	ItemID_3 				= "SP607930003";
	ItemID_4 				= "SP607930004";
vars
	binaryString 		: String;
	incomingJsonString,
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile, ediFile2	: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	edidata, edidata2	: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot 	: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator 			: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	clientRef 			: String;
	now 				: TimeStamp;
	cgStrArray			: StringArray;
	cgStr				: String;
	workOrder 			: CM_WorkOrder;
	workOrderDtl		: CM_WorkOrderDtl;
	cgObjArr , woObjArray: CM_ObjectArray;
	cgId				: String;
	iter				: Iterator;
	vbsProcess, currentProcess : CM_VBSProcess;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	hazardClass						: CM_HazardClass;
	vbs	: CM_VehicleBookingTimeSlot;
	slot : CM_VehicleBookingTimeSlot;
	slotItem : CM_VehicleBookingTimeSlotItem;
	itemsArray : StringArray;
begin
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	vbsProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE];
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
		commitTransaction;
	endif;

	//Delete VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	if slot &lt;&gt; null then
		self.deleteVbsTimeSlotAdv(slot.id);
	endif;
	
	//Add Hazard
	//hazardClass := self.addHazardClass(HazardClassID, "DO NOT USE - UNIT TEST", null, false); 
	
	//cleanup edi data
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(EDIClientRef2, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; EDIClientRef2 then
			break;
		endif;
		app.myTrxDA.trxDeleteEDIData(ediFile.ediData, passport);
	endwhile;
	
	//Add Operator
	operator := self.getOperator("UT57");
	if operator = null then
		operator := self.addOperatorSimple("UT57", "Test Operator");
	endif;	
	
	//Cargo Type
	paperCargoType := app.myRoot.getCargoTypeFromAbbrev(PAPERCT);
	if paperCargoType = null then
		paperCargoType := self.addCargoType(PAPERCT, true);
		self.assertNotNull(paperCargoType);
	endif;
	
	//cargo Subtype
	paperSubCargoType := paperCargoType.allProducts.getAtKeyGeq(null, PAPERSUBCT);
	if paperSubCargoType = null then				
		paperSubCargoType := self.addProduct(PAPERSUBCT, operator, paperCargoType);
		self.assertNotNull(paperSubCargoType);
	endif;
	
	//Add consignee/ consignor
	self.deleteConsigneeConsignor(ConsigneeId1);
	consignee := self.addConsigneeConsignor(ConsigneeId1, ConsigneeId1, true, true, false);
	self.assertTrueMsg(consignee &lt;&gt; null, "Failed to set up Consignee");
	
	//Add vessel
	self.deleteVessel("UTSP002");	
	vessel := self.addVesselCellularWithCode( "UTSP002", "Unit Test - Don't Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	//Add voyage
	self.deleteVoyage("UTSP002");
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	voyage := self.addVoyageWithContainerStructur("UTSP002", "UTSP002", OperatorCode, shippingLineCode);		
	self.assertNotNullMsg(voyage, "Voyage has not been created"); // navlw1
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	
	//  1. create new and check not db loaded case
	self.opts.addAssoc("ItemPrefix","18MAR24");
	self.opts.addAssoc("ItemsCount", 4000);
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "RoadLoadTest");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	//self.ediVerify(ediFile);
	//self.ediDBLoad(ediFile);
	
	/*
	//  1. create new and check not db loaded case
	self.opts.addAssoc("ItemPrefix",ItemPrefix);
	self.opts.addAssoc("ItemsCount", 100);
	self.opts.addAssoc("ManifestType", "Ship");
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "ManifestType");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile);
	self.ediDBLoad(ediFile);*/
	/*
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(edidata.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(edidata.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 2, "This Vehicle booking Should have 2 items");
	*/
	/*//  2. create new and check not db loaded case
	self.opts.addAssoc("ItemPrefix",ItemPrefix);
	self.opts.addAssoc("ItemsCount", 100);
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile2, VBSID, EDIClientRef2, null, "RoadLoadTest");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile2.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata2	:= ediFile2.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile2);*/
	/*
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(edidata2.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile2);
	self.assertEqualMsg(edidata2.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 4, "This Vehicle booking Should have 4 items");
	
	//3.Call update for the first manifest
	self.opts.addAssoc("FirstItem",ItemID_1);
	self.opts.addAssoc("SecondItem", ItemID_2);
	self.sendEDIRequestAndGetLoadedFile("Replace", ediFile, VBSID, EDIClientRef, null, "RoadVBSItems");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	self.assertEqualMsg(edidata.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(edidata.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 4, "This Vehicle booking Should have 4 items");
	
	create itemsArray transient;
	foreach slotItem in slot.allVehicleBookingItems do
		itemsArray.add(slotItem.myTrackedItem.id);
	endforeach;
	
	self.assertTrue(itemsArray.includes(ItemID_1));
	self.assertTrue(itemsArray.includes(ItemID_2));
	self.assertTrue(itemsArray.includes(ItemID_3));
	self.assertTrue(itemsArray.includes(ItemID_4));
	*/
epilog
	delete itemsArray;
	// Set the VBS process back again
	beginTransaction;
		terminal.setMyVBSProcess(currentProcess);
	commitTransaction;
	
	delete ediControllerAgent;
	//delete vbsTimeSlotItem;
	//delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPostSendEDIManifestRoad607932" id="3564dc8d-8c97-4922-bd87-187743014c97">
        <updating/>
        <source>uPostSendEDIManifestRoad607932() updating;
//
// Purpose:Timing issue
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05 Mar 2024	navsp1		Initial creation TFS 61039

constants
	IncomingJsonStart = '{
		"clientRef": "';
	
	IncomingJsonMiddle = '",
		"messageType": "Transport Manifest",
		"synchronous": false,
		"message":"';
	
	IncomingJsonTrailer = '"}';

	VBSID					= "UTSP02";
	PAPERCT	: String 		= "PAPER";
	PAPERSUBCT: String 		= "ROLLS";
	Source_Booking 			= 0;
	ConsigneeId1 			= "CON57";
	OperatorCode 			= "UT57";
	LloydsNumber : String 	= "16661991";
	EDIClientRef 			= "MANRD6079301";
	EDIClientRef2			= "MANRD6079301";
	HazardClassID			= "HAZRD";
	ItemPrefix				= "SP60793";
	ItemID_1 				= "SP607930001";
	ItemID_2 				= "SP607930002";
	ItemID_3 				= "SP607930003";
	ItemID_4 				= "SP607930004";
vars
	binaryString 		: String;
	incomingJsonString,
	terminalCode		: String;
	testScenarioName 	: String;
	ediFile, ediFile2	: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	edidata, edidata2	: CM_EDIDataTransManifest;
	ediDataGateDoc 		: CM_EDIDataGateDoc;
	ediTi 				: CM_EDITrackedItem;
	prenoteCount, 
	hazCount 			: Integer;
	proxyVbsTimeSlot 	: CM_VehicleBookingTimeSlot;
	vbsTimeSlotItem  	: CM_VehicleBookingTimeSlotItem;
	operator 			: CM_Operator;
	paperSubCargoType 	: CM_Product;
	paperCargoType 		: CM_CargoType;
	consignee 			: CM_ConsigneeConsignor;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	passport			: CM_Passport;
	shippingLineCode 	: String;
	ediConfig 			: CM_EDIConfig;
	clientRef 			: String;
	now 				: TimeStamp;
	cgStrArray			: StringArray;
	cgStr				: String;
	workOrder 			: CM_WorkOrder;
	workOrderDtl		: CM_WorkOrderDtl;
	cgObjArr , woObjArray: CM_ObjectArray;
	cgId				: String;
	iter				: Iterator;
	vbsProcess, currentProcess : CM_VBSProcess;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	hazardClass						: CM_HazardClass;
	vbs	: CM_VehicleBookingTimeSlot;
	slot : CM_VehicleBookingTimeSlot;
	slotItem : CM_VehicleBookingTimeSlotItem;
	itemsArray : StringArray;
begin
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	ediConfig := terminal.myEdiConfig;
	
	// Set the vbs process to Slot Type Validation
	currentProcess := terminal.getMyVBSProcess;
	vbsProcess := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE];
	if currentProcess &lt;&gt; vbsProcess then
		beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
		commitTransaction;
	endif;
	
	//Terminal code
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	/*
	//  1. create new and check not db loaded case
	self.opts.addAssoc("ItemPrefix",ItemPrefix);
	self.opts.addAssoc("ItemsCount", 100);
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile, VBSID, EDIClientRef, null, "RoadLoadTest");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile);*/
	/*
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(edidata.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(edidata.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 2, "This Vehicle booking Should have 2 items");
	*/
	//  2. create new and check not db loaded case
	self.opts.addAssoc("ItemPrefix",ItemPrefix);
	self.opts.addAssoc("ItemsCount", 10000);
	self.sendEDIRequestAndGetLoadedFile("Create", ediFile2, VBSID, EDIClientRef2, null, "RoadLoadTest");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile2.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata2	:= ediFile2.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile2);
	/*
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	//self.assertEqualMsg(ediDataGateDoc.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");
	self.assertEqualMsg(edidata2.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile2);
	self.assertEqualMsg(edidata2.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 4, "This Vehicle booking Should have 4 items");
	
	//3.Call update for the first manifest
	self.opts.addAssoc("FirstItem",ItemID_1);
	self.opts.addAssoc("SecondItem", ItemID_2);
	self.sendEDIRequestAndGetLoadedFile("Replace", ediFile, VBSID, EDIClientRef, null, "RoadVBSItems");
	self.opts.purge();
	
	//Verify Data	
	self.assertEqualMsg( ediFile.myEDIFileType.type, EDIFileType_TransportManifest, "Invalid file type" );
	
	//EDI manifest data
	edidata	:= ediFile.ediData.CM_EDIDataTransManifest;
	
	self.ediVerify(ediFile);
	
	//Booking not required for EUP manifest process, but warning still exists. So commented out the below code for the time being.
	self.assertEqualMsg(edidata.myGateDocument.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(edidata.myGateDocument.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	foreach ti in voyage.allNotifiedTIsByCargoTypeId do
		self.assertTrueMsg(ti.myCargoGroup &lt;&gt; null, ti.id&amp;" ti does not have a cargoGroup");
		self.assertTrueMsg(ti.myCargoGroup.allCargoGroupDetails.size &lt;&gt; 0, ti.id&amp;" ti does not have a cargoGroup "&amp;ti.myCargoGroup.String&amp;" with cargoGroupDetails");
	endforeach;
	
	//Verify VBS
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[VBSID];
	self.assertTrueMsg(slot &lt;&gt; null, "Failed to create Vehicle Booking Slot");
	self.assertEqualMsg(slot.allVehicleBookingItems.size, 4, "This Vehicle booking Should have 4 items");
	
	create itemsArray transient;
	foreach slotItem in slot.allVehicleBookingItems do
		itemsArray.add(slotItem.myTrackedItem.id);
	endforeach;
	
	self.assertTrue(itemsArray.includes(ItemID_1));
	self.assertTrue(itemsArray.includes(ItemID_2));
	self.assertTrue(itemsArray.includes(ItemID_3));
	self.assertTrue(itemsArray.includes(ItemID_4));
	*/
epilog
	delete itemsArray;
	// Set the VBS process back again
	beginTransaction;
		terminal.setMyVBSProcess(currentProcess);
	commitTransaction;
	
	delete ediControllerAgent;
	//delete vbsTimeSlotItem;
	//delete proxyVbsTimeSlot;
	//delete vbsBook;
	delete cgStrArray;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPostSendEDIManifestSea" id="caa078b0-d189-4610-96fc-f398983f793b">
        <source>uPostSendEDIManifestSea();
//
// Purpose:	Common UT for CR's - 57807 &amp; 58054		
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25 May 2023	navdap1		Initial creation TFS 57807
// 07 Jun 2023  navsp1      TFS 58054
// 08 June 2023 navra1		TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
constants
IncomingJsonString = '{
	"clientRef": "UT_POSTMANIFESTSEA",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message": ""
}';

vars
	incomingJsonString,
	terminalCode,
	badLoginJson	: String;
	expectFailure	: Boolean;	
	root			: CM_Root;
	activeWebServiceDef 	: CM_APIEndpointServiceDef;	
	testScenarioName : String;
begin
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

	testScenarioName := "ManifestSea|SunnyDay";
	incomingJsonString := IncomingJsonString;	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uPostSendEDIManifestSeaRS" id="c043a49a-8bb9-4aeb-96eb-63e406328925">
        <source>uPostSendEDIManifestSeaRS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023	jlirs1	Initial creation (57807) 58444 Test Sea Manifest Create Cancel and Replace

*/
constants
	VesselCodeString = "EUP_VES01";
	VoyageCodeString = "EUP_VES01VOY01";
IncomingJsonString = '{
	"clientRef": "UT_JLIRS1MANIFESTSEA",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';"
IncomingJsonTrailer = '"	}';

vars
	incomingJsonString,
	terminalCode : String;
	testScenarioName : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	hmsVoyageData : HMS_VoyageData;
	terminal : CM_Terminal;
	workOrder : CM_WorkOrder;
	workOrderDtl : CM_WorkOrderDtl;
	cargoGroup : CM_CargoGroup;
	cargoGroupDtl : CM_CargoGroupDetail;
	errorMsg : String;
	bolTerm : CM_BOLTerminal;
	bol : CM_BOL;
	countCargoGroup : Integer;
	countBOLIn : Integer;
	countWorkOrder : Integer;
	ediTI : CM_EDITrackedItem;
	ti : CM_TrackedItem;
begin
write "002 Start "&amp;method.name;
	// FIRST run Create to make sure that a new voyage can accept a ship manifest
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
//	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	terminal := CM_Root.firstInstance.allTerminals[terminalCode];
	
	// before deleting the voyage cleanup the cargoGroups
	voyage := self.getVoyage(VoyageCodeString);
	if voyage &lt;&gt; null then
		foreach cargoGroupDtl in voyage.allCargoGroupDetails do
			cargoGroup := cargoGroupDtl.myCargoGroup;
			if cargoGroup &lt;&gt; null then
write "010 Delete CargoGroup="&amp;cargoGroup.id;
				self.deleteCargoGroup(cargoGroup.id);
			endif;
		endforeach;
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/1REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/1REEL" then
write "0203 CargoGroup F100012502/1REEL found";
			self.deleteCargoGroup(cargoGroup.id);
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/2REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/2REEL" then
write "030 CargoGroup F100012502/2REEL found";
			self.deleteCargoGroup(cargoGroup.id);
	endif;

	// delete the voyage abd the vessel
	self.deleteVoyage(VoyageCodeString);
	self.deleteVessel(VesselCodeString);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(VesselCodeString, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 10);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	//Create a general cargo voyage 
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageCodeString, 
												  VesselCodeString,
												  self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
												  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
												  10);
	self.assertNotNullMsg(voyage, "Add voyage failed");
	
	// setup some harbour details for the voyage so the work orders can be found in the GUI
	beginTransaction;
	create hmsVoyageData persistent;
	hmsVoyageData.setMyHarbour(terminal.myHarbour);
	hmsVoyageData.setDefaultBerthPreferences(app.myPassport); 
	voyage.setHMSVoyageData(hmsVoyageData);
	commitTransaction;

	testScenarioName := "ManifestSea|WinterDay";
	incomingJsonString := IncomingJsonString &amp; self.zSeaExampleCreate.Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);
	foreach ediFile in CM_EDIFile.instances reversed where ediFile.ediClientRef = "UT_JLIRS1MANIFESTSEA" do
		beginTransaction;
write "040 "&amp;ediFile.ediClientRef&amp;"::"&amp;ediFile.String;
		ediData := ediFile.ediData;
		ediFile.erase(0);
		ediData.erase(0);
		commitTransaction;
		break;
	endforeach;
	ediFile	:=	self.ediLoadFileName(self.zSeaExampleCreate, EDIFileType_TransportManifest, "Transport Manifest", "1" &amp; method.name);
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/1REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/1REEL" then
		countCargoGroup := countCargoGroup + 1;
write "050 CargoGroup F100012502/1REEL found "&amp;cargoGroup.String&amp;' '&amp;cargoGroup.createdTime.String;
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/2REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/2REEL" then
		countCargoGroup := countCargoGroup + 1;
write "060 CargoGroup F100012502/2REEL found "&amp;cargoGroup.String&amp;' '&amp;cargoGroup.createdTime.String;
	endif;
	foreach bolTerm in terminal.allBOLTermsByTypeNum do
		bol := bolTerm.myBOL;
		if bol.bolType = 5003 and
		   bol.number = "F100012502/1" then
			countBOLIn := countBOLIn + 1;
write "070 Found bol="&amp;bol.number;
		endif;
		if bol.bolType = 5003 and
		   bol.number = "F100012502/2" then
			countBOLIn := countBOLIn + 1;
write "080 Found bol="&amp;bol.number;
		endif;
	endforeach;
	workOrder := terminal.allWorkOrders["F100012502/1"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		countWorkOrder := countWorkOrder + 1;
		if workOrderDtl &lt;&gt; null then
write "090 Found first workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
		endif;
	endif;
	workOrder := terminal.allWorkOrders["F100012502/2"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		countWorkOrder := countWorkOrder + 1;
		if workOrderDtl &lt;&gt; null then
write "100 Found second workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
		endif;
	endif;
write "110 bolIns on voyage="&amp;voyage.allBOLInByTypeStatusNumDT.size.String&amp;" and found="&amp;countBOLIn.String;
write "120 cargoGroupDetailss on voyage="&amp;voyage.allCargoGroupDetails.size.String&amp;" and found="&amp;countCargoGroup.String;
write "125 workOrders on voyage="&amp;voyage.allWOReceives.size.String&amp;" and found="&amp;countWorkOrder.String;
write "130 cargo on voyage="&amp;voyage.allOnshipTIsByCargoTypeId.size.String;
	self.assertEqual(ediFile.ediData.CM_EDIDataTransManifest.myShipManifest.allEDITrackedItems.size, 39);
	foreach ediTI in ediFile.ediData.CM_EDIDataTransManifest.myShipManifest.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDICargoTI) then
			if ediTI.id = "L12H24623G" then
write "133 ediTI containerNumberText="&amp;ediTI.CM_EDICargoTI.getContainerNumberText();
			endif;
		endif;
	endforeach;
	foreach ti in voyage.allOnshipTIsByCargoTypeId do
		if ti.id = "L12H24623G" then
write "136 ediTI containerNumberText="&amp;ti.getContainerNumberText();
		endif;
	endforeach;

	// SECOND run Replace to make sure tyhe Sea Manifest can be updated
	testScenarioName := "ManifestSea|WinterDay";
	incomingJsonString := IncomingJsonString &amp; self.zSeaExampleReplace1.Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);
	foreach ediFile in CM_EDIFile.instances reversed where ediFile.ediClientRef = "UT_JLIRS1MANIFESTSEA" do
		beginTransaction;
write "140 "&amp;ediFile.ediClientRef&amp;"::"&amp;ediFile.String;
		ediData := ediFile.ediData;
		ediFile.erase(0);
		ediData.erase(0);
		commitTransaction;
		break;
	endforeach;
	ediFile	:=	self.ediLoadFileName(self.zSeaExampleReplace1, EDIFileType_TransportManifest, "Transport Manifest", "1" &amp; method.name);
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
//	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/1REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/1REEL" then
		write "140 CargoGroup F100012502/1REEL found";
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/2REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/2REEL" then
		write "150 CargoGroup F100012502/2REEL found";
	endif;
	workOrder := terminal.allWorkOrders["F100012502/1"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "160 Found first workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
	workOrder := terminal.allWorkOrders["F100012502/2"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "170 Found second workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;

	self.assertEqual(ediFile.ediData.CM_EDIDataTransManifest.myShipManifest.allEDITrackedItems.size, 40);

	// THIRD run Cancel to make sure that the ship manifest can be deleted
	testScenarioName := "ManifestSea|WinterDay";
	incomingJsonString := IncomingJsonString &amp; self.zSeaExampleCancel.Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);
	foreach ediFile in CM_EDIFile.instances reversed where ediFile.ediClientRef = "UT_JLIRS1MANIFESTSEA" do
		beginTransaction;
write "140 "&amp;ediFile.ediClientRef&amp;"::"&amp;ediFile.String;
		ediData := ediFile.ediData;
		ediFile.erase(0);
		ediData.erase(0);
		commitTransaction;
		break;
	endforeach;
	ediFile	:=	self.ediLoadFileName(self.zSeaExampleCancel, EDIFileType_TransportManifest, "Transport Manifest", "1" &amp; method.name);
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/1REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/1REEL" then
		countCargoGroup := countCargoGroup + 1;
write "180 CargoGroup F100012502/1REEL found";
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/2REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/2REEL" then
		countCargoGroup := countCargoGroup + 1;
write "190 CargoGroup F100012502/2REEL found";
	endif;
	foreach bolTerm in terminal.allBOLTermsByTypeNum do
		bol := bolTerm.myBOL;
		if bol.bolType = 5003 and
		   bol.number = "F100012502/1" then
			countBOLIn := countBOLIn + 1;
write "200 Found bol="&amp;bol.number;
		endif;
		if bol.bolType = 5003 and
		   bol.number = "F100012502/2" then
			countBOLIn := countBOLIn + 1;
write "210 Found bol="&amp;bol.number;
		endif;
	endforeach;
	workOrder := terminal.allWorkOrders["F100012502/1"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		countWorkOrder := countWorkOrder + 1;
write "220 Found first workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
	workOrder := terminal.allWorkOrders["F100012502/2"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		countWorkOrder := countWorkOrder + 1;
write "230 Found second workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
write "240 bolIns on voyage="&amp;voyage.allBOLInByTypeStatusNumDT.size.String&amp;" and found="&amp;countBOLIn.String;
write "250 cargoGroupDetailss on voyage="&amp;voyage.allCargoGroupDetails.size.String&amp;" and found="&amp;countCargoGroup.String;
write "260 workOrders on voyage="&amp;voyage.allWOReceives.size.String&amp;" and found="&amp;countWorkOrder.String;

	self.assertEqual(ediFile.ediData.CM_EDIDataTransManifest.myShipManifest.allEDITrackedItems.size, 39);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uPutCargo1" id="25638348-439b-42b4-9090-dcdbe761329d">
        <updating/>
        <source>uPutCargo1() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2024	naviv1	Initial creation

*/

constants
ThisVoyage = "UTVOY63113";
	ThisVessel = "UTVES63113";
	UTRealBooking				: String = "BK-63619-04";
	IncomingJsonString = '
	[
    {
        "operatorId":"UTOP",
        "destinationPortId":"NZAKL",
        "dischargePortId":"NZBLU",
        "loadPortId":"NZPOE",
        "imexStatus":"EXP",
        "prenotified":true,
        "receivalDetails":
            {
                "type":"Truck"
            },
            "id":"TEST6361904",
            "alternativeId":"6361904-ALT",
            "bookingId":"'&amp; UTRealBooking &amp;'",
            "cargoTypeId":"MAFI",
            "trailerTypeId":"MAFI 60 CUX",
            "weights":
                {
                    "gross":2000,
                    "tare":3000
                },
                "description":null,
                "childCargo":
                [
                    {
                        "operatorId":"UTOP",
                        "destinationPortId":"GBIMM",
                        "dischargePortId":"GBIMM",
                        "loadPortId":"DECUX",
                        "imexStatus":"EXP",
                        "prenotified":true,
                        "receivalDetails":
                        {
                            "type":"Truck"
                        },
                        "id":"CH-63619-04",
                        "alternativeId":"",
                        "bookingId":"",
                        "cargoTypeId":"PAPER",
                        "cargoSubTypeId":"ROLLS",
                        "weights":
                            {"gross":2000,
                            "tare":0
                            },
                        "description":"SINGLE TRAILER",
                        "childCargo":[],
                        "hazards":[],
                        "customsReferences":
                        [{
                            "id":"CH-CR63619-04",
                            "typeId":"AESEXIT",
                            "position":1
                            }
                        ]
                        }  
                ],
                "hazards":[],
                "customsReferences":[{
                            "id":"CR63619-04",
                            "typeId":"AESEXIT",
                            "position":1
                            }],
                "voyageId":"UTVOY63113"
        }
    ]';

	IncomingJsonString2 = '
    {
        "operatorId":"UTOP",
        "destinationPortId":"NZAKL",
        "dischargePortId":"NZBLU",
        "loadPortId":"NZPOE",
        "imexStatus":"EXP",
        "prenotified":true,
        "receivalDetails":
            {
                "type":"Truck"
            },
            "id":"TEST6361904",
            "alternativeId":"6361904-ALT-updated",
            "bookingId":"'&amp; UTRealBooking &amp;'",
            "cargoTypeId":"MAFI",
            "trailerTypeId":"MAFI 60 CUX",
            "weights":
                {
                    "gross":2000,
                    "tare":3000
                },
                "description":null,
                "childCargo":
                [
                    {
                        "operatorId":"UTOP",
                        "destinationPortId":"GBIMM",
                        "dischargePortId":"GBIMM",
                        "loadPortId":"DECUX",
                        "imexStatus":"EXP",
                        "prenotified":true,
                        "receivalDetails":
                        {
                            "type":"Truck"
                        },
                        "id":"CH-63619-04",
                        "alternativeId":"",
                        "bookingId":"",
                        "cargoTypeId":"PAPER",
                        "cargoSubTypeId":"ROLLS",
                        "weights":
                            {"gross":2000,
                            "tare":0
                            },
                        "description":"SINGLE TRAILER",
                        "childCargo":[],
                        "hazards":[],
                        "customsReferences":
                        [{
                            "id":"CH-CR63619-04",
                            "typeId":"AESEXIT",
                            "position":1,
							"alternateId": "alt-updated"
                            },
							{
                            "id":"CH-CR63619-041",
                            "typeId":"updated",
                            "position":2
                            }
                        ]
                        }  
                ],
                "hazards":[],
                "customsReferences":[{
                            "id":"CR63619-04",
                            "typeId":"AESEXIT",
                            "position":1,
							"alternateId": "alt-updated"
                            },
							{
                            "id":"CR63619-041",
                            "typeId":"updated",
                            "position":2
                            }],
                "voyageId":"UTVOY63113"
        }';
	
vars
	realTI		: CM_TrackedItem;
	incomingJsonString,
	terminalCode,
	loginJson			: String;
	expectFailure		: Boolean;
	root				: CM_Root;
	operator 			: CM_Operator;
	terminal 			: CM_Terminal;
	cargoType			: CM_CargoType;
	params				: String;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
begin

	//create utHelperTerminal transient;
	
	root := app.myRoot;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	self.deleteCargo("TEST6361904","MAFI");
	self.deleteCargo("CH-63619-04","PAPER");
	self.deleteVoyage(ThisVoyage);
	voyage := self.getVoyage(ThisVoyage);
	self.assertTrueMsg(voyage = null, "Voyage " &amp; ThisVoyage &amp; " not deleted");
	self.deleteVessel(ThisVessel);
	vessel := self.getVessel(ThisVessel);
	self.assertTrueMsg(vessel = null, "Vessel " &amp; ThisVessel &amp; " not deleted");
	
	// Create Vessel / Voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	voyage := self.getVoyage(ThisVoyage);
	self.assertNotNullMsg(voyage, "Voyage " &amp; ThisVoyage &amp; " not found");
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("MAFI");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Cargo Type MAFI not found");
	
	incomingJsonString := IncomingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("CH-63619-04");
	assertEqual(realTI.allCustomsReferences.size, 1);
	realTI := self.getTrackedItem("TEST6361904");
	
	assertEqual(realTI.alternativeId, "6361904-ALT");
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(realTI.totalWeight, 5000.Decimal);
	assertEqual(realTI.bookingReference, "BK-63619-04");
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode, "UTOP");
	assertEqual(realTI.voyageCode,ThisVoyage);
	
	incomingJsonString := IncomingJsonString2;
	expectFailure := false;
	params := "/Cargo/TEST6361904/MAFI/3?MasterTerminalAPI&amp;bookingId=" &amp; UTRealBooking;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	realTI := self.getTrackedItem("CH-63619-04");
	assertEqual(realTI.allCustomsReferences.size, 2);
	realTI := self.getTrackedItem("TEST6361904");
	
	assertEqual(realTI.alternativeId.toUpper, "6361904-ALT-updated".toUpper);
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(realTI.totalWeight, 5000.Decimal);
	assertEqual(realTI.bookingReference.toUpper, "BK-63619-04".toUpper);
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode.toUpper, "UTOP");
	assertEqual(realTI.voyageCode,ThisVoyage);
	
	
epilog
	
end;</source>
    </JadeMethod>
