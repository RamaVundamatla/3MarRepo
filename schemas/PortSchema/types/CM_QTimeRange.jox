    </JadeMethod>
    <JadeMethod name="setSearchValue" id="000eddaf-495e-4d22-bad2-5cea431c5776">
        <updating/>
        <source>setSearchValue(_timeArray : TimeArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	if _timeArray &lt;&gt; null and _timeArray.size &gt; 1 then

		self.fromTime 	:= _timeArray[1];
		self.toTime		:= _timeArray[2];
		
		// ccms 1593. Queries for Drivers screen. Drivers put dates as strings. So, need check here
		if not ( self.fromTime.isValid() and self.toTime.isValid() ) then
			app.raiseCMException1( Invalid_time_expect_format, "hh:mm", null, self );
		endif;

	endif;

epilog

end;</source>
        <Parameter name="_timeArray" type="TimeArray"/>
    </JadeMethod>
