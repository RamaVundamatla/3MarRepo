    <JadeMethod name="canUserSet" id="2fc2f0e7-0400-4765-899a-27f07d821432">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDICargoFieldUpdateTI::isBOLUpdate.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="equalsIgnoreCase" id="5cdb292d-4e11-4fe5-9925-91582062f00a">
        <source>equalsIgnoreCase(a: String; b: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	navcs2	Initial creation

*/

vars
	
begin
    if a.length &lt;&gt; b.length then
        return false;
    endif;
	
	return a.compareEql(b, true, false, null) ; 
	
epilog

end;</source>
        <Parameter name="a" type="String"/>
        <Parameter name="b" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
