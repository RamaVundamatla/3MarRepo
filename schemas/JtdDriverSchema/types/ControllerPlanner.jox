    <JadeMethod name="runTest" id="05a835cb-cae6-48ae-8e3f-86bf78aef468">
        <updating/>
        <source>runTest(): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwer1	Initial creation re created for 812 lots of changes because of voyage rationalisation

*/

vars
	sa:StringArray;
	meth:String;
begin
	numLanes:=2;  
	
	create sa transient;
	sa.add('cp002_CN_lstTest_click');
	if app.profileName = "YardShipPlanner" then
		sa.add('cp004_CN_lstTest_dblClick');
		sa.add('cp006_SVAF_cmbVoyage_click');
		sa.add('cp008_SVAF_button_click');
		sa.add('cp010_SVAF_picture_click');
