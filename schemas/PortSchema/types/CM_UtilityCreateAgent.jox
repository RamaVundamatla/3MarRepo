				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 01/02/2016 cnwma1	TFS #3286:Issues with Invoicing Audits
// ---------------------------------------------------------------------------
vars
	proxyInvoiceLineDesc : CM_DebtorInvoiceLineDesc;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	proxyInvoiceLineDesc := _theController.myProxyInvoiceLineDebtor;
	
	app.myValCA.valInvoiceLineDescDebtor(proxyInvoiceLineDesc);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewInvoiceLineDesc persistent;

	pNewInvoiceLineDesc.setForCreateController(_theController );
	
	if _passport.noErrors then								// 01/02/2017 cnwma1 TFS #3283
		self.myCreateAuditAgent.audCreateGeneric(pNewInvoiceLineDesc);
	endif;
end;</source>
