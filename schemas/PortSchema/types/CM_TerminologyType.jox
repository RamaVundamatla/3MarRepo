    <JadeMethod name="pxyCreateUpdateProxy" id="234d0ed7-c89a-46f9-a15f-2fa96719a331">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	realExpression,
	pxyExpression		: CM_TerminologyTypeExpression;
	realTermType,
	pxyTermType				: CM_TerminologyType;
	realTermTypeDtl,
	pxyTermTypeDtl		: CM_TerminologyTypeDtl;
	completedOK		: Boolean;
	
begin
	pxyTermType := inheritMethod();
	
	realTermType := pxyTermType.pxyGetRealObject;
	if realTermType &lt;&gt; null then
		foreach realExpression in realTermType.allTerminologyTypeExpressions do
			pxyExpression := realExpression.pxyCreateUpdateProxy().CM_TerminologyTypeExpression;
			pxyExpression.setMyTerminologyType(pxyTermType);
		endforeach;
		
		foreach realTermTypeDtl in realTermType.allTerminologyTypeDtls do
			pxyTermTypeDtl := realTermTypeDtl.pxyCreateUpdateProxy().CM_TerminologyTypeDtl;
			pxyTermTypeDtl.setMyTerminologyType(pxyTermType);
		endforeach;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTermType;
		
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTermType;
	endif;		
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0fab21d7-2bc8-4f62-bc1e-47bf9a71f3ee">
        <updating/>
        <source>setForCreate(_pxyTermType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.setForUpdate(_pxyTermType);
end;</source>
        <Parameter name="_pxyTermType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="511fae6e-3405-41a0-90d1-94b57abb6cc7">
        <updating/>
        <source>setForUpdate(_pxyTermType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	realTermTypeDtl,
	pxyTermTypeDtl					: CM_TerminologyTypeDtl;
	realTermTypeExp,
	pxyTermTypeExp					: CM_TerminologyTypeExpression;	
	allObjsToDelete					: CM_ObjectSet;
	termHdr							: CM_TerminologyDef;
	newTermDtl						: CM_TerminologyDtl;
	
	newTermExp						: CM_TerminologyExpression;
begin
	self.name := _pxyTermType.name;
	self.myRoot := app.myRoot;
	create allObjsToDelete transient;
	
	//process expression objects////////////////////////////////////////////////
	self.allTerminologyTypeExpressions.copy(allObjsToDelete);
	
	foreach pxyTermTypeExp in _pxyTermType.allTerminologyTypeExpressions do
		realTermTypeExp := self.allTerminologyTypeExpressions[pxyTermTypeExp.expressionType];
		if realTermTypeExp = null then
			create realTermTypeExp persistent;
		else
			allObjsToDelete.remove(realTermTypeExp);
		endif;
		
		realTermTypeExp.setForUpdate(pxyTermTypeExp, self);
	endforeach;
	
	allObjsToDelete.purge();
	//check existing header to add any new terminologyType expression objects
	foreach realTermTypeExp in self.allTerminologyTypeExpressions do
		if (not realTermTypeExp.allTerminologyExpressions.isEmpty) then //not a new type detail
			continue;
		endif;

		foreach termHdr in self.allTerminologyDefs do
			create newTermExp persistent;
			newTermExp.set(realTermTypeExp, termHdr, realTermTypeExp.systemExpression);
		endforeach;
	endforeach;
	///////////////////////////////////////////////////////////////////////////
	//process terminology details objects
	self.allTerminologyTypeDtls.copy(allObjsToDelete);
	
	foreach pxyTermTypeDtl in _pxyTermType.allTerminologyTypeDtls do
		realTermTypeDtl := self.allTerminologyTypeDtls[pxyTermTypeDtl.groupName, pxyTermTypeDtl.rowName];
		if realTermTypeDtl = null then
			create realTermTypeDtl persistent;
		else
			allObjsToDelete.remove(realTermTypeDtl);
		endif;
		
		realTermTypeDtl.setForUpdate(pxyTermTypeDtl, self);
	endforeach;
	
	allObjsToDelete.purge();
	
	foreach realTermTypeDtl in self.allTerminologyTypeDtls do
		if (not realTermTypeDtl.allTerminologyDtls.isEmpty) then //now a new type detail
			continue;
		endif;

		foreach termHdr in self.allTerminologyDefs do
			create newTermDtl persistent;
			newTermDtl.set(realTermTypeDtl, termHdr, realTermTypeDtl.systemEntRowHeading, realTermTypeDtl.systemEntRowShortHeading);
		endforeach;
	endforeach;
	////////////////////////////////////////////////////////////////////////////////
	//everything is built, now process the detail's user headings
	foreach termHdr in self.allTerminologyDefs do
		termHdr.processUserHeadings();
	endforeach;
		
epilog
	delete allObjsToDelete;
end;</source>
        <Parameter name="_pxyTermType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="d7d24c7c-86fd-4f39-9321-e20c11e0f016">
        <updating/>
        <source>setProxyFromXML(_name, _xmlBlock : String; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	expType,
	blockLength,
	pos				: Integer;
	
	sysExp,
	expDescr,
	allExpressionsBlock,
	expressionBlock,
	allDtlsBlock,
	dtlBlock,
	rowName,
	groupName				: String;
	allObjsToDelete			: ObjectSet;
	pxyExpressionObj		: CM_TerminologyTypeExpression;
	pxyTypeDtl				: CM_TerminologyTypeDtl;
	entTableRow				: EntTableRow;
	realTermType			: CM_TerminologyType;
begin
	create allObjsToDelete transient;
	self.allTerminologyTypeExpressions.copy(allObjsToDelete);
	self.name := _name;
	
	allExpressionsBlock := _xmlBlock.cnEcGetTagValueOfName(self.XMLTag_AllSystemExpressions);
	blockLength := allExpressionsBlock.length;
	pos := 1;
	
	while pos &lt;= blockLength do
		expressionBlock := allExpressionsBlock.cnEcGetNextTagValueOfName(self.XMLTag_SystemExpression, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		expType := expressionBlock.cnEcGetTagValueOfName(self.XMLTag_ExpressionType).Integer;
		expDescr := expressionBlock.cnEcGetTagValueOfName(self.XMLTag_ExpressionDescr).String;
		sysExp := expressionBlock.cnEcGetTagValueOfName(self.XMLTag_Expression);
		
		pxyExpressionObj := self.allTerminologyTypeExpressions[expType];
		if pxyExpressionObj = null then
			create pxyExpressionObj transient;
		endif;
		
		pxyExpressionObj.setProxy(expType, expDescr, sysExp, self);
		
		if allObjsToDelete.includes(pxyExpressionObj) then
			allObjsToDelete.remove(pxyExpressionObj);
		endif;
	endwhile;
	
	realTermType := self.pxyGetRealObject();
	if realTermType = null then
		//must be creating a new type, so no entRows will be referencing me
		//so no details to create
		return;
	endif;
	
	allObjsToDelete.purge;
	allObjsToDelete.clear();
	
	self.allTerminologyTypeDtls.copy(allObjsToDelete);
	//CNWTH2 inverse to allEntTableRows when able and if neccessary
	//if so, note that entTableRows are destroyed and rebuilt from globs every release
	foreach entTableRow in EntTableRow.instances do
		if entTableRow.myTerminologyType &lt;&gt; realTermType then
			continue;
		endif;
		
		groupName := entTableRow.myGroup.name;
		rowName := entTableRow.name;
		//jlier1 24/6/25 35222
		if rowName = null and entTableRow.myEntTableRowHeader &lt;&gt; null then
			rowName:=entTableRow.myEntTableRowHeader.name;
		endif;
		
		pxyTypeDtl := self.allTerminologyTypeDtls[groupName, rowName];
		if pxyTypeDtl = null then
			create pxyTypeDtl transient;
		endif;
		
		pxyTypeDtl.setProxy(groupName, rowName, self);
		
		if allObjsToDelete.includes(pxyTypeDtl) then
			allObjsToDelete.remove(pxyTypeDtl);
		endif;	
	endforeach;
	
	/*
	allDtlsBlock := _xmlBlock.cnEcGetTagValueOfName(self.XMLTag_AllTypeDtls);
	blockLength := allDtlsBlock.length;
	pos := 1;
	
	while pos &lt;= blockLength do
		dtlBlock := allDtlsBlock.cnEcGetNextTagValueOfName(self.XMLTag_TypeDtl, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		groupName := dtlBlock.cnEcGetTagValueOfName(self.XMLTag_GroupName);
		rowName := dtlBlock.cnEcGetTagValueOfName(self.XMLTag_RowName);
		
		pxyTypeDtl := self.allTerminologyTypeDtls[groupName, rowName];
		if pxyTypeDtl = null then
			create pxyTypeDtl transient;
		endif;
		
		pxyTypeDtl.setProxy(groupName, rowName, self);
		
		if allObjsToDelete.includes(pxyTypeDtl) then
			allObjsToDelete.remove(pxyTypeDtl);
		endif;	
	endwhile;	
	*/
	
	allObjsToDelete.purge;
	
epilog
	delete allObjsToDelete;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_xmlBlock" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="90c5b393-12dc-4352-9ca0-9ac1c05c7ec8">
        <source>validateForCreate(_root : CM_Root);
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'name', 'name', null);
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _root = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'root', 'myRoot', null);
		app.raiseCMException(Input_required_field_root, 'myRoot', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	self.validateForUpdate(_root);
	
end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f23676d4-2023-4f77-90b7-9556b2b368d5">
        <source>validateForUpdate(_root : CM_Root);
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable		 
// ----------   ----------  --------------------------------------------------
vars
	termTypeExp			: CM_TerminologyTypeExpression;
	termTypeDtl			: CM_TerminologyTypeDtl;
	existingTermType,
	realTermType		: CM_TerminologyType;
begin
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'name', 'name', null);
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
	endif;
	
	existingTermType := _root.allTerminologyTypes[self.name];
	realTermType := self.pxyGetRealObject();//null if creating
	
	if (realTermType = null and existingTermType &lt;&gt; null) or
	   ((existingTermType &lt;&gt; null and realTermType &lt;&gt; null) and
	   (existingTermType &lt;&gt; realTermType)) then
		//app.raiseCMException2(DuplicateItem, 'Terminology Type: ' &amp; self.name, 'Root', null, null); //14.06.2022 navds20 53760
		// Terminology Type: %1 already exists for Root : Termin_type_alread_exists_root
		app.raiseCMException1(Termin_type_alread_exists_root,  self.name, null, null); //14.06.2022 navds20 53760
	endif;
	
	foreach termTypeExp in self.allTerminologyTypeExpressions do
		termTypeExp.validateForUpdate();
	endforeach;
	
	foreach termTypeDtl in self.allTerminologyTypeDtls do
		termTypeDtl.validateForUpdate();
	endforeach;

end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
</Class>
