    <JadeMethod name="purgeTableObjects" id="31a8d39c-3743-4f84-83e4-33790b879b19">
        <updating/>
        <source>purgeTableObjects() updating;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	self.allSelectedObjects.clear();
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="rowChecked" id="55a82bd6-1488-4b88-81d0-48526754f0eb">
        <updating/>
        <source>rowChecked(pRow : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if pRow &gt; 0 and pRow &lt;= self.rows then
		if self.accessCell(pRow, self.chkBoxColumn).text[1] = TableCheckBox_Selected then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllToFalse" id="62715b14-f29e-454b-8f37-0b05827b13c2">
        <updating/>
        <source>setAllToFalse()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 29 August 2003
//
//-----------------------------------------------------------------------
vars
	rowPointer		: Integer;
	totalRows		: Integer;
	rowObject		: Object;
	allSelectedObj	: ObjectArray;
begin
	totalRows	:=	self.rows;
	
	if totalRows &lt; 1 then
		return;
	endif;
	
	allSelectedObj	:=	self.allSelectedObjects;
	
	foreach rowPointer in 1 to totalRows do
		self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_NotSelected;
		
		rowObject	:=	self.accessRow(rowPointer).itemObject;
		
		if (allSelectedObj.includes(rowObject)) then
			allSelectedObj.remove(rowObject);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllToTrue" id="74767e99-1cc9-4ede-89b3-d9654cda2409">
        <updating/>
        <source>setAllToTrue()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 29 August 2003
//
//-----------------------------------------------------------------------
vars
	rowPointer		: Integer;
	totalRows		: Integer;
	rowObject		: Object;
	allSelectedObj	: ObjectArray;
	
begin
	totalRows	:=	self.rows;
	
	if totalRows &lt; 1 then
		return;
	endif;
	
	allSelectedObj	:=	self.allSelectedObjects;
	
	foreach rowPointer in 1 to totalRows do
		self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_Selected;
		rowObject	:=	self.accessRow(rowPointer).itemObject;
		
		if (not allSelectedObj.includes(rowObject)) then
			allSelectedObj.add(rowObject);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setRowSelect" id="edcf5648-daf3-45f6-b06c-d5d208d68dfb">
        <updating/>
        <source>setRowSelect(pRow : Integer; _select : Boolean) updating;
//-----------------------------------------
// Created: November 2005 By: cnwgd1
//-----------------------------------------
vars
	rowObject	: Object;
	
begin
	if pRow &gt; 0 and pRow &lt;= self.rows then
		rowObject	:=	self.accessRow(pRow).itemObject;
		
		if rowObject &lt;&gt; null then
			if _select then
				if (not self.allSelectedObjects.includes(rowObject)) then
					self.allSelectedObjects.add(rowObject);
				endif;
			elseif self.allSelectedObjects.includes(rowObject) then
				self.allSelectedObjects.remove(rowObject);
			endif;
		endif;
		
		if self.allSelectedObjects.includes(self.accessRow(pRow).itemObject) then
			self.accessCell(pRow, self.chkBoxColumn).text := TableCheckBox_Selected;
		else
			self.accessCell(pRow, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		endif;

	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="_select" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="69e245d8-8351-4948-9cb4-5a1ef4a5d041">
        <updating/>
        <source>setSelected(_objs : Collection) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     Copies the collection passed in into the allSelectedObjects and
//				sets the "checked" flag on the table.
//
// Parameters:  None
//
// Returns:     The selected string.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	itemObj				: CM_AutoWarningItem;
	requestObj			: CM_AutoWarningRequest;
	allRequestArrayObj	: CM_AutoWarningRequestArray;
	rowPointer			: Integer;
	totalRows			: Integer;

begin
	self.allSelectedObjects.clear();
	
	if _objs.isKindOf(CM_AutoWarningRequestArray) then
		allRequestArrayObj	:=	_objs.CM_AutoWarningRequestArray;
	else
		if _objs &lt;&gt; null then
			_objs.copy(self.allSelectedObjects);
		endif;
	endif;
	
	totalRows	:=	self.rows;
	
	foreach rowPointer in 1 to totalRows do
		if allRequestArrayObj = null then
			if self.allSelectedObjects.includes(self.accessRow(rowPointer).itemObject) then
				self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_Selected;
			else
				self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_NotSelected;
			endif;
		else
			itemObj	:=	self.accessRow(rowPointer).itemObject.CM_AutoWarningItem;
			
			if itemObj = null then
				continue;
			endif;
			
			if allRequestArrayObj.includesClass(itemObj.className) then
				self.allSelectedObjects.add(itemObj);
				self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_Selected;
				self.setCellText(rowPointer, 3, itemObj.minutesBeforeAlert.String);
				self.setCellText(rowPointer, 4, itemObj.alertFrequency.String);
			else
				self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_NotSelected;
				self.setCellText(rowPointer, 3, "0");
				self.setCellText(rowPointer, 4, "0");
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_objs" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setSelectedString" id="7d568cd0-f3fe-4e25-a680-10912712426d">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setSelectedString(_string: String)updating, clientExecution;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	colPointer	: Integer;
	rowPointer	: Integer;
	totalRows	: Integer;
	rowObject	: Object;
	
begin
	if _string = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _string');
		return;
	endif;

	totalRows	:=	self.rows;
	
	if totalRows &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		colPointer	:=	self.chkBoxColumn + 1;
	else
		colPointer	:=	self.chkBoxColumn - 1;
	endif;	
	
	foreach rowPointer in 1 to totalRows do
		rowObject	:=	self.accessRow(rowPointer).itemObject;
		
		if CM_TransactionType.hasInstance(rowObject) then
			if rowObject.CM_TransactionType.description = _string then
				self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_Selected;					
			endif;
		elseif self.accessCell(rowPointer, colPointer).text = _string then
			self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_Selected;		
		endif;
	endforeach;
end;</source>
        <Parameter name="_string" type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="e6394f7f-dd36-4bb7-a4a9-8df9152b0083">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	columnObj	: JadeTableColumn;
	colPointer	: Integer;

begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.columns &lt;= 1 then
		self.columns	:=	4;
	endif;
 
	foreach colPointer in 1 to self.columns do
		columnObj	:=	self.accessColumn(colPointer);
		
		if colPointer = self.chkBoxColumn then
			// Setup the checkbox column.
			columnObj.inputType	:=	self.InputType_CheckBox;
		elseif colPointer = 2 then
			// Setup the text column.
			columnObj.inputType				:=	self.InputType_None;
			columnObj.partialTextIndication	:=	true;
			columnObj.width					:=	130;
		elseif colPointer = 3 or colPointer = 4 then
			// Setup the integer columns.
			columnObj.inputType				:=	self.InputType_TextNumeric;
			columnObj.alignment				:=	self.Alignment_Center_Middle;
		else
			// Setup the text column.
			columnObj.inputType				:=	self.InputType_None;
			columnObj.partialTextIndication	:=	true;
		endif;
	endforeach;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
