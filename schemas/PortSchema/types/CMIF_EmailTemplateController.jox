    <Constant name="Mode_BCC" id="7110e727-60e0-4526-8821-95a3ec8b77e8">
        <source>102</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Mode_CC" id="0687fb67-47fc-462b-987c-149e4e08ca79">
        <source>101</source>
