		&lt;/BOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
			&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
			&lt;id&gt;BOL125&lt;/id&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;notifyParty&gt;CCS&lt;/notifyParty&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;This is a remarks second&lt;/remarks&gt;
			&lt;transportMode&gt;SHIP&lt;/transportMode&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;clientRef1&gt;Service Order Number 4&lt;/clientRef1&gt;
			&lt;clientRef2&gt;Purchase Order Number 4&lt;/clientRef2&gt;
			&lt;vehicle&gt;&lt;/vehicle&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height&gt;12.0000&lt;/height&gt;
					&lt;length&gt;13.0000&lt;/length&gt;
					&lt;weight&gt;49.0000&lt;/weight&gt;
					&lt;width&gt;3.0000&lt;/width&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;colour&gt;1251&lt;/colour&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;BOL125&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
		&lt;/BOLHeader&gt;
	&lt;/AllBOLHeader&gt;
&lt;/JMTInternalBOL&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 10, "incorrect number of EDI trackedItems");
	bol := self.getBOL("BOL122", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 3, "");
	bol := self.getBOL("BOL123", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	bol := self.getBOL("BOL124", 5003, "MSK");
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertNotNull(bol);
	bol := self.getBOL("BOL125", 5003, "MSK");
	self.assertNull(bol);
//	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
//	self.assertTrueMsg( bol.clientRef1 = "Service Order Number 4".toUpper, "clientRef1 not set correctly");	//09 Jun 2017	NDL	TFS 4331
//	self.assertTrueMsg( bol.clientRef2 = "Purchase Order Number 4".toUpper, "clientRef1 not set correctly");	//09 Jun 2017	NDL	TFS 4331

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBOL&gt;
	&lt;AllBOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
			&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
			&lt;id&gt;BOL125&lt;/id&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;notifyParty&gt;CCS&lt;/notifyParty&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;This is a remarks second&lt;/remarks&gt;
			&lt;transportMode&gt;SHIP&lt;/transportMode&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;clientRef1&gt;Service Order Number 4&lt;/clientRef1&gt;
			&lt;clientRef2&gt;Purchase Order Number 4&lt;/clientRef2&gt;
			&lt;vehicle&gt;&lt;/vehicle&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height&gt;12.0000&lt;/height&gt;
					&lt;length&gt;13.0000&lt;/length&gt;
					&lt;weight&gt;49.0000&lt;/weight&gt;
					&lt;width&gt;3.0000&lt;/width&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;colour&gt;1251&lt;/colour&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;BOL125&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
		&lt;/BOLHeader&gt;
	&lt;/AllBOLHeader&gt;
&lt;/JMTInternalBOL&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	bol := self.getBOL("BOL125", 5003, "MSK");
	self.assertNull(bol);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
