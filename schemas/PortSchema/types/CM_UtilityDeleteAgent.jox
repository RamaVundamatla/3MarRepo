    <JadeMethod name="utlDeleteRestAuthTokens" id="7680758f-900a-42d6-b014-5c3eb3406f9b">
        <source>utlDeleteRestAuthTokens(_tokensToDelete : ObjectArray; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/04/2021	navdap1		Initial creation TFS 50491 MTN Reefer Jobs: Auto-create when Externally Monitored changes
//
vars
	obj : Object;
	token : CM_RestAuthToken;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valDeleteRestAuthTokens(_tokensToDelete);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	// erase just in case we want to do some more work on Rest Auth Tokens in future
	foreach obj in _tokensToDelete do
		token := obj.CM_RestAuthToken;
		token.erase(NORMAL_ERASE);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tokensToDelete" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRestrictionHazards" id="8100e14d-b1d2-4bb5-aa89-aeaae927ac3d">
        <source>utlDeleteRestrictionHazards(_restriction : CM_TerminalAreaHazDetails; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	toDelete : CM_TerminalAreaHazDetails;
	terminalArea : CM_TerminalArea;
	details	: String;
	coll : CM_LCSet;
	
begin
	toDelete := _restriction;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.myValDA.valRestrictionHazards(_restriction);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	terminalArea := toDelete.myTerminalArea;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(terminalArea, true, null, CM_AuditTALocations.LocnTypeUpdate_HazRestrict, AuditDeleted, null);
	
	// save off details for post delete audit
	details := _restriction.getAuditTALocationDetails;
	
	create coll transient;
	_restriction.allLocationsControllers.copy(coll);
	
	if _passport.noErrors() then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;
	
	if _passport.noErrors() then
		toDelete.erase(NORMAL_ERASE);
		terminalArea.causeEvent(terminalArea.myTerminal.getTerminalEvent(Event_TALocation_Delete), false, toDelete);
		terminalArea.causeEvent(terminalArea.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, terminalArea);
		
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (terminalArea, false, coll, CM_AuditTALocations.LocnTypeUpdate_HazRestrict, AuditDeleted, details);

	endif;
	
epilog
	delete coll;
end;</source>
        <Parameter name="_restriction" type="CM_TerminalAreaHazDetails"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRestrictionLabour" id="4ebdb1fc-b0b5-4128-8bb8-97365285d120">
        <source>utlDeleteRestrictionLabour(pRestriction : CM_LabourRestriction; _isChild : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDelete				: CM_LabourRestriction;
	aTA 					: CM_TerminalArea;
	queueEntrySet_before	: CM_RTQueueEntrySet;
	details					: String;
	coll					: CM_LCSet;
begin
	toDelete := pRestriction;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.myValDA.valRestrictionLabour(pRestriction);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	aTA := toDelete.myTerminalArea;
	
	// as this causes an update to the terminal area where
	// we want to record the audit record
	// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of ta with an audit that includes the changes to locations as well
	//app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(aTA, true);
	app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(aTA, true, null,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, AuditDeleted, null);
	
	// save off details for post delete audit
	details := pRestriction.getAuditTALocationDetails;
	
	create coll transient;
	pRestriction.allLocationControllers.copy (coll);
	
	if _passport.noErrors() then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;
	
	if _passport.noErrors and not _isChild then
		toDelete.sendCreateDeleteEmail( app.getErrorString(LOB_Delete_Action), _passport);	//08 Jul 2015	NDL	Par 36588
	endif;

	if _passport.noErrors() then
		 create queueEntrySet_before transient;
		 toDelete.getQueueEntries(queueEntrySet_before);
		 toDelete.setQueueTasksStatus(queueEntrySet_before, null);	// ccms1573	cnwvu1
		toDelete.erase(NORMAL_ERASE);
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Delete), false, toDelete); //epr par 16956 11/6/08
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, aTA); //epr par 16956 11/6/08
		
		// as this causes an update to the terminal area where
		// we want to record the audit record
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of TA with audit that includes locations changes
		//app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(aTA, false);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (aTA, false, coll,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, AuditDeleted, details);
		//navsp1 03MAY2022 TFS#53369
		if app.myPassport.isOpsViewEnabled(aTA.myTerminal) then 
			aTA.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, aTA); 
		endif;

	endif;
epilog
	delete queueEntrySet_before;
	delete coll;
end;</source>
        <Parameter name="pRestriction" type="CM_LabourRestriction"/>
        <Parameter name="_isChild" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRestrictionLocation" id="41d135d7-3c99-44c9-9df0-3665e1609949">
        <source>utlDeleteRestrictionLocation(pRestriction : CM_LocationRestriction; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	toDelete	: CM_LocationRestriction;
	aTA : CM_TerminalArea;
begin

	toDelete := pRestriction;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.myValDA.valRestrictionLocation(pRestriction);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;

	if _passport.noErrors then
		aTA := toDelete.myTerminalArea;

		toDelete.erase(NORMAL_ERASE);

		if aTA &lt;&gt; null then   // PAR 27315
			aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA);
			aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Delete),false,toDelete);
		endif;

	endif;
epilog

end;</source>
        <Parameter name="pRestriction" type="CM_LocationRestriction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
