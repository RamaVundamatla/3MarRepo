    <JadeMethod name="dragOver" id="05f787ec-a60b-43c8-be3f-c7a3af3e2ac8">
        <controlMethod name="Form::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dragOver(win: Window input; x: Real; y: Real; state: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if app.myMoveController &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;
epilog

end;</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawShipDeckAndHull" id="40d9dcb9-fe78-4f60-8900-99345dea8691">
        <updating/>
        <source>drawShipDeckAndHull() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ctrl : Control;
	grey, lightBlue, darkBlue : Integer;
	drawWidth : Integer;
	adjust : Integer;
	picLeft, picRight : CMUI_Picture;

begin
	ctrl := self.dkbGridArea.myScrollableFrame;
	ctrl.autoRedraw := true;
	ctrl.clearGraphics();
	
	lightBlue := 37 + (170*256) + (225*256*256);
	darkBlue := 40 + (56*256) + (145*256*256);
	grey := 231 + (231*256) + (232*256*256);
	
	if self.myBulkDrawingController = null or self.myBulkDrawingController.isStarboardBerthed then
		picLeft := self.picStern;
		picRight := self.picBow;
	else
		picLeft := self.picBowRev;
		picRight := self.picSternRev;
	endif;
	
	// top and bottom black lines
	//ctrl.drawWidth := 5;
	ctrl.drawWidth := (ctrl.clientHeight/90).roundedTo(0).Integer;
	ctrl.drawStyle := Window.DrawStyle_Solid;
	//ctrl.drawLine(100, ctrl.clientHeight, ctrl.width-55, ctrl.clientHeight, Black);
	ctrl.drawLine(picLeft.width, ctrl.clientHeight, ctrl.width-picRight.width, ctrl.clientHeight, Black);
	adjust := (ctrl.clientHeight/450).roundedTo(0).Integer;
	if adjust &lt; 1 then
		adjust := 1;
	endif;
	//ctrl.drawLine(100, (ctrl.clientHeight/2)+1, ctrl.width-50, (ctrl.clientHeight/2)+1, Black);
	ctrl.drawLine(picLeft.width, (ctrl.clientHeight/2)+adjust, ctrl.width-picRight.width, (ctrl.clientHeight/2)+adjust, Black);
	
	// fill top area with grey
	//ctrl.drawWidth := 2;
	ctrl.drawFillColor := grey;
	ctrl.drawFillStyle := Window.DrawFillStyle_Solid;
	//ctrl.drawFilledRectangle(picStern.width, (ctrl.clientHeight/2)+8, ctrl.width-50, (ctrl.clientHeight*.715), grey);
	ctrl.drawFilledRectangle(picLeft.width, (ctrl.clientHeight/2)+8, ctrl.width-picRight.width, (ctrl.clientHeight*.715), grey);
	
	// two thin black lines
//	drawWidth := (ctrl.clientHeight/450).Integer;																											// drawWidth = 1
//	if drawWidth &lt; 1 then
//		drawWidth := 1;
//	endif;
//	ctrl.drawWidth := drawWidth;
	//ctrl.drawLine(picStern.width, (ctrl.clientHeight*.715)-5, ctrl.width-50, (ctrl.clientHeight*.715)-5, Black);		// clientHeight-5
	//ctrl.drawLine(picStern.width, (ctrl.clientHeight*.715)-2, ctrl.width-50, (ctrl.clientHeight*.715)-2, Black);	// clientHeight-2
//	ctrl.drawLine(picStern.width, (ctrl.clientHeight*.70444), ctrl.width-55, (ctrl.clientHeight*.70444), Black);		// clientHeight-5
//	ctrl.drawLine(picStern.width, (ctrl.clientHeight*.71111), ctrl.width-55, (ctrl.clientHeight*.71111), Black);	// clientHeight-2
	
	// light blue stripe
	ctrl.drawWidth := 2;
	ctrl.drawFillColor := lightBlue;
	ctrl.drawFillStyle := Window.DrawFillStyle_Solid;
	//ctrl.drawFilledRectangle(picStern.width, (ctrl.clientHeight*.71222), ctrl.width-55, (ctrl.clientHeight*.76666), lightBlue);
	ctrl.drawFilledRectangle(picLeft.width, (ctrl.clientHeight*.711), ctrl.width-picRight.width, (ctrl.clientHeight*.78), lightBlue);
	
	// thin line between light blue and dark blue
	//ctrl.drawWidth := 1;
	//ctrl.drawLine(picStern.width, (ctrl.clientHeight*.715)+(ctrl.clientHeight/19.458), ctrl.width-50, (ctrl.clientHeight*.715)+(ctrl.clientHeight/19.458), Black);
	
	// dark blue stripe
	ctrl.drawWidth := 2;
	ctrl.drawFillColor := darkBlue;
	ctrl.drawFillStyle := Window.DrawFillStyle_Solid;
	//ctrl.drawFilledRectangle(picStern.width, (ctrl.clientHeight*.76888), ctrl.width-55, ctrl.clientHeight-2, darkBlue);
	ctrl.drawFilledRectangle(picLeft.width, (ctrl.clientHeight*.77), ctrl.width-picRight.width, ctrl.clientHeight-2, darkBlue);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableDisableImexBtns" id="1a084583-4b78-451d-812d-3c56ddc5d9c7">
        <source>enableDisableImexBtns(_visible, _enabled : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.btnViewExport.visible	:= _visible;
	self.btnViewImport.visible	:= _visible;

	if _visible then
		self.btnViewExport.enabled	:= _enabled;
		self.btnViewImport.enabled	:= _enabled;
	endif;

epilog

end;</source>
        <Parameter name="_visible" type="Boolean"/>
