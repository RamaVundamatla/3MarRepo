    <JadeMethod name="trxImportWagonClassFromFile" id="5a6abed3-fff8-4c59-8f2d-0db9880fddbf">
        <updating/>
        <source>trxImportWagonClassFromFile( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		MES 1010 Interface load	

Parameters:		Import File and passport	

Date		Who		Reason
13 August 2009	cnwjmn1	Initial creation
20/11/2009		cnwdad1	PAR 21650.  Changed to handle quoted fields.
06/07/2010	cnwrl1	PAR 24606 - Import order changed to match "JMT Default".
07/07/2010	cnwrl1	PAR 24848 - System Admin Import to allow minimum amount of data.
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04/08/2016	cnwdap1	TFS #2447 Ensure wagon class code is upper case
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count						: Integer;
	numCodes					: Integer;
	noLines						: Integer;
	length						: Integer;
	maxInStack					: Integer;
	fieldNo						: Integer;
	fieldValue					: String;
	wagonCode					: String;
	locationIds					: String;
	carrier						: String;
	fileLine					: String;
	maxWeight					: Integer;  //??Decimal[9,4];
	doorAccess					: Boolean;
	notAvailable				: Boolean;
	acceptsGenerator			: Boolean;
	deckHt, maxHt, tareWt		: Decimal[12,2];
	locationIdsArray			: StringArray;
	locationsArray 				: StringArray;	
	fieldArray					: StringArray;
	newWagon					: CM_WagonClass;
	currentWagon				: CM_WagonClass;
	pxyWagon					: CM_WagonClass;
	wagonColl					: CM_WagonClassByCodeDict;
	carrierObj					: CM_Carrier;
	allConsigneeRestrictions	: CM_ConsignCodeArray;	
	theRoot						: CM_Root;
	thePassport					: CM_Passport;
	err							: CM_Error;
	errorStore					: CM_ErrorSet;
	//18 Mar 2013	NDL	Par 31278
	internalHeight : Decimal[12,4];	
	internalLength : Decimal[12,4];
	internalWidth : Decimal[12,4];
	overallHeight : Decimal[12,4];
	overallLength : Decimal[12,4];
	overallWidth : Decimal[12,4];
	wagonType : Integer;
	tierIds : String;	//23 Dec 2014	NDl	Par 35346
	tierIdsArray : StringArray; //23 Dec 2014	NDl	Par 35346
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create wagonColl transient;
	create locationsArray transient;
	create fieldArray transient;
	create errorStore transient;
	create allConsigneeRestrictions transient;
	create tierIdsArray transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine();
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		wagonCode			:= null;
		doorAccess			:= null;
		acceptsGenerator	:= null;
		maxWeight			:= null;
		maxInStack			:= null;
		length				:= null;
		locationIds			:= null;
		notAvailable		:= null;
		deckHt				:= null;
		maxHt				:= null;
		tareWt				:= null;
		carrier				:= null;
		tierIds				:= null;
		// cnwrl1 07/07/2010 PAR 24848 - end of coding
		//18 Mar 2013	NDL	Par 31278
		internalHeight := 0;
		internalLength := 0;
		internalWidth := 0;
		overallHeight := 0;
		overallLength := 0;
		overallWidth := 0;
		wagonType := 1;	// default value
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo :=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				//wagonCode			:=	fieldValue.trimBlanks();					// TFS #2447
				wagonCode			:=	fieldValue.trimBlanks().toUpper;			// TFS #2447
			elseif fieldNo = 2 then
				doorAccess			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 3 then
				acceptsGenerator	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 4 then
				maxWeight			:=	fieldValue.Integer; //??Decimal;	
			elseif fieldNo = 5 then
				maxInStack			:=	fieldValue.Integer;	
			elseif fieldNo = 6 then
				length				:=	fieldValue.Integer;	
			elseif fieldNo = 7 then
				locationIds			:=	fieldValue.trimBlanks();
			elseif fieldNo = 8 then
				notAvailable		:=	fieldValue.trimBlanks().asBooleanJMT;
			elseif fieldNo = 9 then
				deckHt				:=	fieldValue.asDecimalJMT();
			elseif fieldNo = 10 then
				maxHt				:=	fieldValue.asDecimalJMT();
			elseif fieldNo = 11 then
				tareWt				:=	fieldValue.asDecimalJMT();
			elseif fieldNo = 12 then
				carrier				:=	fieldValue.trimBlanks();
			//18 mar 2013	NDL	Par 31278
			elseif fieldNo = 13 then
				internalHeight :=	fieldValue.asDecimalJMT();
			elseif fieldNo = 14 then
				internalLength :=	fieldValue.asDecimalJMT();
			elseif fieldNo = 15 then
				internalWidth :=	fieldValue.asDecimalJMT();
			elseif fieldNo = 16 then
				overallHeight :=	fieldValue.asDecimalJMT();
			elseif fieldNo = 17 then
				overallLength :=	fieldValue.asDecimalJMT();
			elseif fieldNo = 18 then
				overallWidth :=	fieldValue.asDecimalJMT();
			elseif fieldNo = 19 then
				wagonType :=	fieldValue.Integer;	
			elseif fieldNo = 20 then
				tierIds :=	fieldValue.trimBlanks();
			endif;
		endforeach;
		
		locationsArray.clear();
		locationIds.cnReplaceChar(",", " ");		// 21/05/2010 cnwmh5 #24264 - expects to be " " delimited.  Check as extract puts out "," delimited
		locationIds.getTokensForDelimiter(' ', locationsArray);
		
		tierIdsArray.clear();
		if tierIds &lt;&gt; null then
			tierIds.cnReplaceChar(",", " ");
			tierIds.getTokensForDelimiter(' ', tierIdsArray);
		endif;
		
		if carrier &lt;&gt; null then
			carrierObj	:=	theRoot.allCarriers[carrier];
			
			if carrierObj = null then
				create err transient;
				err.set(0,
						app.getErrorString(Wagon_class) &amp; ' : ' &amp; wagonCode &amp; '  ' &amp; app.getErrorString(Invalid) &amp; app.getErrorString(Carrier) &amp; ' : ' &amp; carrier,
						false,
						'',
						null,
						null);
				errorStore.add(err);
				continue;
			endif;
		else
			carrierObj	:= null;
		endif;
		
		if wagonType &lt;&gt; CM_WagonClass.Wagon_Boxcar and wagonType &lt;&gt; CM_WagonClass.Wagon_Flatcar and  wagonType &lt;&gt; CM_WagonClass.Wagon_Wellcar then
			create err transient;
				err.set(0,
						app.getErrorString(Wagon_class) &amp; ' : ' &amp; wagonCode &amp; '  ' &amp; app.getErrorString(Invalid) &amp; app.getErrorString(Wagon_type) &amp; ' : ' &amp; wagonType.String,
						false,
						'',
						null,
						null);
				errorStore.add(err);
				continue;
		endif;
		
		create pxyWagon transient;
		pxyWagon.setProxy(	wagonCode,
							acceptsGenerator,
							doorAccess,
							notAvailable,
							maxWeight,
							maxInStack,
							length,
							locationsArray,
							allConsigneeRestrictions,
							deckHt,
							maxHt,
							tareWt,
							carrierObj,
							internalHeight,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
							internalLength,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
							internalWidth,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
							overallHeight,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
							overallLength,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
							overallWidth,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
							wagonType,	//pWagonType : Integer;
							tierIdsArray,		//pTierIds : StringArray
							null, //pSealTypes : CM_SealTypeDict	//10 Mar 2015	NDL	Par 35828
							CM_BoxcarVisit.BoxcarGraphicBreakBulk // TFS 49523
							);
		
		if not wagonColl.includesKey(wagonCode) then
			wagonColl.add(pxyWagon);
		else
			create err transient;
			err.set(0,
					app.getErrorString(Wagon_class) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(Wagon_class)) &amp; wagonCode,
					false,
					'',
					pxyWagon,
					null);
			errorStore.add(err);
		endif;
		
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count:= 0;
	numCodes := wagonColl.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyWagon in wagonColl do
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Wagon_class)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentWagon	:=	theRoot.allWagonClasses[pxyWagon.code];
		
		if currentWagon = null then
			app.myUtilityCA.utlCreateWagonClass(pxyWagon, newWagon, thePassport);
		else
			app.myProxyManager.createProxyLink(currentWagon, pxyWagon);
			app.myUtilityUA.utlUpdateWagonClass(pxyWagon, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Wagon_class) &amp; ' : ' &amp; pxyWagon.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	if wagonColl &lt;&gt; null then
		wagonColl.purge();
		delete wagonColl;
	endif;
	
	delete locationIdsArray;
	delete locationsArray;
	delete fieldArray;
	delete allConsigneeRestrictions;
	delete tierIdsArray;
	
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLoadErrMsgsFromGlbConsts" id="7202b64a-0ba2-4268-a575-3c2858fe1206">
        <updating/>
        <source>trxLoadErrMsgsFromGlbConsts(baseScmName : String; constCategory : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
//	errMsg 		: CM_ErrorMessage;
	constDict	: ConstantNDict;
	deleteSet	: ObjectSet;
	tmpRoot		: CM_Root;
	tmpLocale	: CM_Locale;
	xml			: String;

begin
	/*
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	tmpRoot := app.myRoot;

	if app.baseErrorNum = Max_Integer then
		//The PortSchema stuff has NOT been called
		app.raiseCMException(ErrJadeMasterMethodNotCalled, null, null);
		return;
	endif;

	if baseScmName.trimBlanks = null or constCategory.trimBlanks = null then
		app.raiseCMException1(REQUIRED_FIELD, 'schema or constant category', null, null);
		return;
	endif;
	
	baseScm := rootSchema.getSchema(baseScmName);
	if baseScm = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Schema', null, null);
	endif;
	category := baseScm.getCategory(constCategory);
	if category = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Constant Cantegory', null, null);
	endif;
	
	// get hold of all the error messages to delete
	create deleteSet transient;
	foreach errMsg in tmpRoot.allErrorMessages where errMsg.number &gt;= ExtDev_BaseErrorNo do
		deleteSet.add(errMsg);
	endforeach;	
	foreach tmpLocale in tmpRoot.allLocales do
		foreach errMsg in tmpLocale.allErrorMessages where errMsg.number &gt;= ExtDev_BaseErrorNo do
			deleteSet.add(errMsg);
		endforeach;	
	endforeach;

	beginTransaction;
	
	if (not deleteSet.isEmpty) then
		deleteSet.purge;
	endif;
	
	constDict := category.getConstants();
	foreach const in constDict do
		if const.valueAsInteger &lt;= ExtDev_BaseErrorNo then
			app.raiseCMException3(ExtDevErrNoOutsideRange, const.valueAsInteger.String, const.name, ExtDev_BaseErrorNo.String, null, null);
			break;
		endif;
		xml := const.text;
		if xml = null then
			continue;
		endif;
		tmpRoot.addErrorMessage(const.valueAsInteger, const);
	endforeach;
*/
epilog
	delete deleteSet;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="baseScmName" type="String"/>
        <Parameter name="constCategory" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLoadErrMsgsGlbConstsExtUser" id="7e4e28f1-f887-4bef-9cd1-2b9b12cc7a69">
        <updating/>
        <source>trxLoadErrMsgsGlbConstsExtUser(baseScmName : String; constCategory : String; _passport : CM_Passport input) updating;

//DO NOT DELETE.  USED FOR LOADING EXTERNAL USERS ERROR MESSAGES.  CENTREPORT NEED THIS FOR THEIR SYSTEM.
// Load existing translations into a collection, any remaining at the end WILL be removed

vars
	agent					: CM_TranslationAgent;
	constantCategory		: ConstantCategory;
	constant				: Constant;
	locale					: CM_Locale;
	existingTranslations	: XLAT_TranslatableTextByCatNmbr;
	translatableText		: XLAT_TranslatableText;
	category				: XLAT_Category;
	
	tmpRoot : CM_Root;
	baseScm : Schema;
	deleteSet : ObjectSet;
	proxy	: XLAT_TranslationsAndGCProxy;
	xlation	: XLAT_Translation;
begin
	app.setContinueCMExceptions(false);
	
	create existingTranslations transient;
	create agent transient;
	
	tmpRoot := app.myRoot;
			
	if app.baseErrorNum = Max_Integer then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'PortSchema Method has NOT been called');
		return;
	endif;
	
	//Get Schema that has the error constants.
	baseScm := rootSchema.getSchema(baseScmName);
	if baseScm = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Schema', null, null);
	endif;
	
	constantCategory  := baseScm.getCategory(constCategory);
	if constantCategory = null then 
		app.raiseCMException1(ERR_NO_OBJECT, 'Constant Category', null, null);
	endif;
	
	if app.myRoot.allLocales.isEmpty then
		app.raiseCMException1(ERR_NO_OBJECT, 'Locale', null, null);
	endif;

	//Get exception Constants
	category := tmpRoot.allXLAT_Categories[XLAT_Exceptions];
	
	//CHECK FOR EXTERNAL DEVELOPMENT ERRORS FALL IN CORRECT NUMBER RANGE
	//WE ONLY WANT MESSAGES THAT HAVE BEEN CREATED BY EXTERNAL USERS.
	foreach translatableText in tmpRoot.allXLAT_TranslatableText where translatableText.number &gt;= ExtDev_BaseErrorNo do
		existingTranslations.add(translatableText);
	endforeach;	
	
	beginTransaction;
		//We need to 
		foreach constant in constantCategory.getConstants where constant.text &lt;&gt; null do
			//Create the translatable text
			translatableText := agent.subTrxLoadFromGlobalConstant(category, constant.GlobalConstant);
					
			// remove from the existing collection as we go ..
			if translatableText &lt;&gt; null and
			   existingTranslations[translatableText.myConstantCategoryName, translatableText.number] &lt;&gt; null then
				existingTranslations.removeKey(translatableText.myConstantCategoryName,translatableText.number);
			endif;
			
			//Create the Translation from the translatable text
			//xlation := translatableText.getTranslation(app.myCurrentLocale);
			//xlation.update(app.myRoot, translatable, app.myCurrentLocale, translatableText.
		endforeach;	

		// any remaining in existingTranslations can be purged but we will need to delete the translation too.
		foreach translatableText in existingTranslations do
			xlation := translatableText.getTranslation(app.myCurrentLocale);
			if xlation &lt;&gt; null then
				delete xlation;
			endif;
		endforeach;
		existingTranslations.purge;

	commitTransaction;

	
	
epilog
	delete existingTranslations;
	delete agent;
end;</source>
        <Parameter name="baseScmName" type="String"/>
        <Parameter name="constCategory" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPerformBlending" id="431fc6ff-0d0c-4ce9-96a3-9bd3fa56e28f">
        <updating/>
        <source>trxPerformBlending( _agent : CMIF_BlendingAgent input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlPerformBlending( _agent, _passport );
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_agent" type="CMIF_BlendingAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessBulkGateIn" id="2c4ce12e-73e1-4d28-83db-1fc9f2b45081">
        <updating/>
        <source>trxProcessBulkGateIn(	_pxyVVR : CM_VehicleVisitRecord input;
						_realVVR : CM_VehicleVisitRecord io;
						_newScaleWeight : Decimal;	//May have been modified
						_rawScaleWeight : Decimal;	//What came off the scale
						_weighBridge : CM_WeighBridgeObj;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2016	cnwndl1	Initial creation	TFS 2867 / 2779
//TFS 5560 jlgns1 28/7/17
//26 March 2018 jlgrh7 TFS37768 PKT - Discrepancy in export cargo
3/05/2018 JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
10/08/2022 navkc1	Bug 54494: CUX - Drivers with multiple vehicles not saved
19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
*/

vars
	item 			: CMGTE_Entity;
	realVVR 		: CM_VehicleVisitRecord;
	tmpEvent		: Integer;
	tmpTerminal		: CM_Terminal;
	pxyTIs			: CM_ObjectByStringDict; 
	strArray 		: StringArray;
	ti 				: CM_TrackedItem;
	pxyTi 			: CM_TrackedItem;
	pxyGTE 			: CMGTE_Entity;
	gte 			: CMGTE_Entity;
	vvrd 			: CM_VehicleVisitRecordDetail;
	updateWeightOnly : Boolean;
	oldScaleWeight : Decimal [16,4];
		
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	tmpTerminal := _passport.myTerminal;

	//app.setContinueCMExceptions(false);
	app.setContinueCMExceptions(true);

	realVVR := _pxyVVR.pxyGetRealObject();
	
	// This validation is repeated in utlCreateVehicleVisitFlexi/Update, but done here
	// as loads objects into cache, and want to do this before calling validateForCreateJobFlexi
	if realVVR = null then
		_pxyVVR.validateForCreate(_passport);
	else
		_pxyVVR.validateForUpdate(_passport);
	endif;
	
	if _passport.hasErrorsIgnored then
		return;
	endif;
	
	app.myValUA.doProformaValidation( realVVR, true, true, null, true, app.myPassport );	
	
	if _passport.hasErrorsIgnored then
		return;
	endif;
	
	create pxyTIs transient;
	_pxyVVR.validateForCreateJobFlexi(_passport, pxyTIs, false);

	if _passport.hasErrorsIgnored then
		return;
	endif;
	
	if _passport.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		_pxyVVR.validateReserveTI(null);
	endif;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	_pxyVVR.validateForFlexiDuplicates(null);
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	pxyGTE := _pxyVVR.allGateEntities.first;
	
	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate	:= true;
	_passport.useTITransactionDeferUpdate := true;
	
	if realVVR &lt;&gt; null then
		updateWeightOnly := realVVR.getBulkGateIn(null) &lt;&gt; null;
	endif;
	
	
	// Start the transaction
	beginTransaction;
	
	if updateWeightOnly then
		oldScaleWeight := realVVR.getBulkGateIn(null).getExtraInfo_BulkGateInOrOut;
		if oldScaleWeight &lt;&gt; _newScaleWeight then
			vvrd := realVVR.createVisitRecordDetail (VisitRecord_Bulk_In, _newScaleWeight, null);
		endif;
		return;
		
	endif;
		
	
	if _passport.hasErrors then
		return;
	endif;
	
	// Do the validataion for the creation of a job.  This should do all validation on
	// the sub-objects as well.
	// This will hold a collection of validated TIs.
	
	
	pxyGTE := _pxyVVR.allGateEntities.first;
	
	if realVVR = null then
		app.myUtilityCA.utlCreateVehicleVisitFlexi(_pxyVVR, realVVR, _passport);
	else
		app.myUtilityUA.utlUpdateVehicleVisitFlexi(_pxyVVR,true, _passport);
	endif;
	
	if _passport.hasErrors then	//TFS 5560 jlgns1 28/7/17
		return;					//TFS 5560 jlgns1 28/7/17
	endif;						//TFS 5560 jlgns1 28/7/17
	
	if _newScaleWeight &lt;&gt; _rawScaleWeight then
		vvrd := realVVR.createVisitRecordDetail (VisitRecord_Bulk_In, "Modified " &amp; _rawScaleWeight.String &amp; "^" &amp; _newScaleWeight.String ,null );
	endif;
	
	if _passport.noErrors and realVVR.getBulkGateIn(null) = null then
		vvrd := realVVR.createVisitRecordDetail (VisitRecord_Bulk_In, _newScaleWeight, _weighBridge);
	endif;
	

	if _passport.noErrors() and realVVR.allGateEntities.isEmpty and pxyGTE &lt;&gt; null then
		if not pxyTIs.isEmpty then
			pxyTIs.purge();
		endif;
		app.myUtilityCA.utlCreateInOutFlexiGateEntity(realVVR, pxyGTE, gte, _passport);
	endif;
		
	if _passport.noErrorsIgnored() then

		if gte &lt;&gt; null then
			//MTN-34221 jlier1 already have the pxyTI use that
			if pxyTIs &lt;&gt; null  then
				pxyTi := pxyTIs[gte.getStringDictKey].CM_TrackedItem;
			endif;
		
			if pxyTi &lt;&gt; null then
				if gte.isKindOf(CMGTE_Receival) then
					pxyTi.setTotalWeightWithoutTrans(1);
					if ti.myCargoType.useTareCargoWeight then				//Bug 38457
						pxyTi.setWeightCargo(1);			//+TFS37768		//Bug 38457
					else													//Bug 38457
						pxyTi.setWeightCargo(0);							//Bug 38457
					endif;													//Bug 38457
					pxyTi.setWeightTare(0);			//+TFS37768	
				endif;
			endif;
		endif;
		app.myUtilityCA.utlCreateInOutFlexiJob(realVVR, _passport, pxyTIs);
	endif;	
		
	// did the TI successfully autoplan? If not we have to raise an exception here
	if _passport.noErrors and (_passport.noWarnings or _passport.warningsAcknowledged) then
		gte := realVVR.allGateEntities.first;
		if gte.isKindOf(CMGTE_Receival) then
			ti := gte.CMGTE_Receival.myTrackedItem;
		elseif gte.isKindOf(CMGTE_Release) then
			ti := gte.CMGTE_Release.myTrackedItem;
		else
			ti := null;
		endif;
		if ti &lt;&gt; null and ti.myPrimaryQueuedLocation = null then
			app.raiseCMException1(Failed_auto_plan, ti.id, null, null);
			return;
		endif;
	endif;
		
	if _passport.noErrors() then
		// Issue notifications for received containers
		tmpEvent := tmpTerminal.getTerminalEvent(TIEvent_Terminal_Receival);
		foreach item in realVVR.allGateEntities do
			if item.isKindOf(CMGTE_Receival) and item.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				item.CMGTE_Receival.myTrackedItem.causeEvent(tmpEvent, false, null);
			endif;
		endforeach;
	endif;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog

	self.finaliseActivityWithPassportEW(_passport, false);
	if _passport.trxCompletedOK or _realVVR &lt;&gt; null then
		_realVVR := realVVR;
	endif;
	if  pxyTIs &lt;&gt; null  then
		pxyTIs.purge();
	endif;
	
	delete pxyTIs;		
	delete strArray;
	
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_newScaleWeight" type="Decimal"/>
        <Parameter name="_rawScaleWeight" type="Decimal"/>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessBulkGateOut" id="cec53bc1-2f48-425a-a083-6d2886a3b7e0">
        <updating/>
        <source>trxProcessBulkGateOut(	_agent : CM_BulkGateProcessingAgent io;
						_newScaleWeight : Decimal;	//May have been modified
						_rawScaleWeight : Decimal;	//What came off the scale
						_cargoWeight : Decimal;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/11/2016	cnwns1	Initial creation	TFS 2867
04/05/2017	cnwdap1	TFS 4111 PKT Do Cash proforma calculations before road exit (road exit deletes proforma information)
18/10/17	jlgns1	TFS 7453 Bulk gate Proforma not working
14/11/2017	cnwma1	TFS #7610 PKT - REQUIRED FIELD FOR REPORTING
26 March 2018 jlgrh7 TFS37768 PKT - Discrepancy in export cargo
3/05/2018 JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
31/05/2022	jlier1	TFS 53650 - refactored schedule packages now called from vvr.departureProcess
12/04/2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
*/

vars

	tmpTerminal : CM_Terminal;
	vvrd 		: CM_VehicleVisitRecordDetail;
	job 		: CM_Job;
	ti 			: CM_TrackedItem;
	moveController : CMIF_MoveController;
	prenotedTI : CM_TrackedItem;
	vehicle : CM_Vehicle;
	wle : CM_WorkListEntry;
	realVVR : CM_VehicleVisitRecord;
	
	gte : CMGTE_Entity;
	reserveDetail : CM_ReserveDetail;
	manualWeightEntry : Boolean;	//02 Feb 2021	NDL	TFS 50152
	preWeight : String;	//02 Feb 2021	NDL	TFS 50152
	postWeight : String;	//02 Feb 2021	NDL	TFS 50152
	splitTi : CM_TrackedItem;//02 Feb 2021	NDL	TFS 50152
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	tmpTerminal := _passport.myTerminal;

	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	      
	realVVR := _agent.myRealVVR;	  
	vehicle := realVVR.vehicle;
	if realVVR.myRoadJob = null or realVVR.myRoadJob.workListEntries.size() = 0 then	// 15/2/18 MAP TFS37006
		wle := vehicle.allRoadJobs.first.workListEntries.first;
	else
		wle := realVVR.myRoadJob.workListEntries.first();
	endif;
	//15 Nov 2017	NDL	TFS 7820
	if realVVR &lt;&gt; null and not realVVR.allGateEntities.isEmpty then
		gte := realVVR.allGateEntities.first;
	endif;

	app.setContinueCMExceptions(false);

	/////// TFS 7453 
	if tmpTerminal.isCashOnlyEnabled then
		//do the proforma stuff if the terminal uses it
		_passport.useTITransactionDeferUpdate := false;
		if not _passport.warningsAcknowledged then
			app.myValUA.doProformaValidation( realVVR, false, true, null, false, _passport );
		endif;
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	/////// TFS 7453 
	
	
	// Start the transaction
	beginTransaction; 
	
	_passport.useTIDictDeferUpdate	:= true;
	_passport.useTITransactionDeferUpdate := true;
		
	if realVVR.getBulkGateIn(null) &lt;&gt; null then
		if _newScaleWeight &lt;&gt; _rawScaleWeight then
			manualWeightEntry := true;	//02 Feb 2021	NDL	TFS 50152
			vvrd := realVVR.createVisitRecordDetail (VisitRecord_Bulk_Out, "Modified " &amp; _rawScaleWeight.String &amp; "^" &amp; _newScaleWeight.String ,null );
		endif;
	
		vvrd := realVVR.createVisitRecordDetail(VisitRecord_Bulk_Out, _newScaleWeight, null);
	else
		app.raiseCMException1(Vehicle_Visit__Not_Bulk_only,app.getErrorString(Bulk_gate_out),"wrongGate", null);
		return;
	endif;
	
	//02 Feb 2021	NDL	TFS 50152
	if not manualWeightEntry then
		//need to check to see if it was on the way in
		manualWeightEntry := realVVR.hasManualWeightEntry();
	endif;
	
	// store reference to ti from WLE because this gets cleared once the move is complete
	ti := wle.myTrackedItem;
	
	//adjust the amount - weight on wle to be difference between in and out
	
//	if _agent.myRealVVR.allGateEntities.first.isKindOf(CMGTE_Receival) then
	if gte &lt;&gt; null and gte.isKindOf(CMGTE_Receival) then		
		//set cargoWeight from the form Bulk Gate Out Form (scale weight at gate-in -  scale weigth at gate-out)
		ti.setTotalWeightWithoutTrans(_cargoWeight);
		//02 Feb 2021	NDL`TFS 50152
		if manualWeightEntry then
			ti.recordWeightSetManually( app.getErrorString1( Bulk_gate_bulk_gate_weigh_manu, realVVR.visitNumber), null, _cargoWeight.asStringJMT, _passport);
		endif;
		if ti.myCargoType.useTareCargoWeight then				//Bug 38457
			ti.setWeightCargo(_cargoWeight);	//+TFS37768		//Bug 38457
		else													//Bug 38457
			ti.setWeightCargo(0);								//Bug 38457
		endif;													//Bug 38457
		ti.setWeightTare(0);					//+TFS37768		//Bug 38457
		prenotedTI:=  tmpTerminal.allNotifiedTIsByCargoTypeId[ti.myCargoType.id, ti.id];
	else
		//02 Feb 2021	NDL	TFS 50152 - for the Release version for the cargo staying on-site
		if manualWeightEntry then
			postWeight := (ti.totalWeight - _cargoWeight + 1).asStringJMT;	//02 Feb 2021	NDL	TFS 50152
			ti.recordWeightSetManually(app.getErrorString1( Bulk_gate_bulk_gate_weigh_manu, realVVR.visitNumber), ti.totalWeight.asStringJMT, postWeight, _passport);
		endif;
	endif;
		
	wle.setWeight(_cargoWeight);	
	job := wle.job;

	// 25//2/19 epr TFS 43547 validate before the move
	if gte &lt;&gt; null then
		if gte.isCMGTE_Release then
			reserveDetail := gte.CMGTE_Release.myReserveDetail;
			if reserveDetail &lt;&gt; null then
				if reserveDetail.isBulkMulti then
					reserveDetail.validateWeightQuantityAdd( 0, _cargoWeight, true );
				endif;
			endif;
		elseif gte.isCMGTE_Receival then
			gte.CMGTE_Receival.validateBooking( true );
		endif;
		if _passport.hasErrors() then
			return;
		endif;
	endif;
		
	//do move qued to real boy
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(wle.getTargetLocation());
	moveController.setMoveMode(REAL_MODE);	
	moveController.setMyTrackedItem(ti);
	moveController.setWeight(_cargoWeight);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	//02 Feb 2021 NDL	TFS 50152
	if postWeight &lt;&gt; null then
		// for the Release version for the cargo goinging off-site
		splitTi := moveController.myTrackedItem;
		splitTi.recordWeightSetManually(app.getErrorString1( Bulk_gate_bulk_gate_weigh_manu, realVVR.visitNumber), null, splitTi.totalWeight.asStringJMT, _passport);
	endif;
	
	delete moveController;	
	
	
	
	/////// TFS 7453 
	// This must be done after move is finished because there is no TI in .allReleasedTrackedItems till then
	if tmpTerminal.isCashOnlyEnabled then	
		foreach ti in realVVR.allReleasedTrackedItems discreteLock do
			app.myUtilityUA.utlUpdateCashPaymentFromTI(ti,realVVR,_passport);
			if _passport.hasErrors() then
				return;
			endif;
		endforeach;	
	endif;
	///////
	
	if not _passport.noErrors then
		return;
	endif;
	
	if CM_RoadJob.hasInstance(job) then
		// to avoid deadlock(s)
		job.CM_RoadJob.lockVehicleTerminalAreaLocns();
	endif;
	
	//Adjust weight on prenote
	if not job.CM_RoadJob.allReceiveTrackedItems.isEmpty then
		prenotedTI:=  tmpTerminal.allNotifiedTIsByCargoTypeId[ti.myCargoType.id, ti.id];
		if prenotedTI &lt;&gt; null then
			preWeight := ( prenotedTI.totalWeight + 1 ).asStringJMT;	//02 Feb 2021	NDL	TFS 50152
			create moveController transient;
			moveController.setMyPassport(app.myPassport);
			moveController.setWeight(_cargoWeight -1);	 //epr TFS 8220 6/12/17 
			if ti.getDensity &gt; 0 then
				moveController.setVolume((moveController.weight / ti.getDensity));
			endif;
			prenotedTI.splitSetQVW(moveController,null); 
			delete moveController;
			//02 Feb 2021	NDL`TFS 50152
			if manualWeightEntry then
				prenotedTI.recordWeightSetManually(app.getErrorString1( Bulk_gate_bulk_gate_weigh_manu, realVVR.visitNumber), preWeight, prenotedTI.totalWeight.asStringJMT, _passport);
			endif;
		endif;
	endif;
	
	if _passport.noErrors() and job.status = JOB_COMPLETE then  //14.11.2017 cnwma1 TFS #7610 
		if _agent.myGateAreaLaneController &lt;&gt; null then
			app.myUtilityUA.utlMoveVehicle(vehicle,_agent.myGateAreaLaneController, _passport);
		endif;
	endif;
	
	if _passport.noErrors() and job.status = JOB_COMPLETE then	
		job.departureProcess(_passport);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//should err on wle not complete
	if not vehicle.allRoadJobs.isEmpty then
		vehicle.roadExitProcess(_passport);
	endif;
	//epr par 21/3/2013 31268 if don't return will get the 75755 exception
	if _passport.hasErrors() then
		return;
	endif;
	
	// ### TFS 55215 23Nov2022 NAVPW1
	if _passport.noErrors() then
		CMIF_TrxActionTransport@createAction(null, null, realVVR, CMIF_TrxActionTransport.ProcessTruckDeparture, _passport);	// TFS 57362
	endif;
	// ### TFS 55215 23Nov2022 NAVPW1
	
	// rebuild these as in some cases the TI is deleted
	// above which can result in invalid objects in the
	// deferred dicts
	_passport.rebuildDeferredDicts();
	_passport.doDeferredUpdates();
	
epilog
	
	delete moveController;
	self.finaliseActivityWithPassportEW(_passport, false);
	
end;</source>
        <Parameter name="_agent" type="CM_BulkGateProcessingAgent" usage="io"/>
        <Parameter name="_newScaleWeight" type="Decimal"/>
        <Parameter name="_rawScaleWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRawDataToHSA" id="4083b525-b622-47f2-b655-e5aa45e13b6f">
        <updating/>
        <source>trxRawDataToHSA(_pxyEDIFile : CM_EDIFile; 
				_passport : CM_Passport input;
				_theLines : HugeStringArray io
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
6/07/2018 	jlgns1	Initial creation
6/07/2018 	JLGNS1	Bug 39173: MSL - Roro baplie not entirely loaded - HIGH PRIORITY
*/

vars

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Just Arm our base exception handlers so error messages look nice
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	_pxyEDIFile.myEDIFileType.rawDataToHSA(_pxyEDIFile,_theLines);
		
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyEDIFile" type="CM_EDIFile"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxReceiveExtraCargoFromBoxcar" id="03aeed3b-cf0e-4455-b2a6-63bf5503e49d">
        <updating/>
        <source>trxReceiveExtraCargoFromBoxcar( _pxyTI : CM_TrackedItem input;
								_realTi : CM_TrackedItem output;
								_boxcarVisit : CM_BoxcarVisit;
								_yardLocation : CM_LocationsController;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 March 2013	cnwndl1	Initial creation	Par 31278
18 March 2024	navpw1	TFS: 62857 (62858) - Changed signature of createRailReceiveJob

*/

vars

	wagCont : CM_WagonController;
	updController : CMIF_TIUpdateController;
	tiSet : CM_TISet;
	moveController : CMIF_MoveController;
	wagonRecptTime : TimeStamp;
	receive : CM_Receive;
	railJob : CM_RailJob;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	if not _boxcarVisit.confirmed or _boxcarVisit.confirmedOutwards then
		app.raiseCMException1(Not_creat_cargo_wagon_not_site, _boxcarVisit.id, null, _boxcarVisit);
		return;
	endif;

	//wagCont := _boxcarVisit.allLocationsControllers.first;
	wagCont := _boxcarVisit.allLocationsControllersArray[1];	//04 Dec 2014	NDL	Par 35345
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	create tiSet transient;
	tiSet.add(_pxyTI);
	updController.setMyTransientTIs(tiSet);
	
	app.setContinueCMExceptions(true);
	app.myValCA.valTrackedItems( updController, _passport );

	// ensure any locks are cleared
	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	beginTransaction;

	//create the trackeditem (as a pre-note)
	self.createTrackedItems( updController, _passport );
		
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	_realTi := updController.allPersistentTIs.first;
	
	// move the pre-note to the wagon - if the wagon is onsite, this will bring the cargo onsite.		
	create moveController transient;
	moveController.setMyTrackedItem(_realTi);
	moveController.setMyToPrimaryLocation(wagCont);
	moveController.isSystemMove := true;
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	delete moveController;
	
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	//find and update the time on the receive trx.
	wagonRecptTime := _boxcarVisit.getReceiptTimeStamp();
	receive := _realTi.getTransReceiveFirst();
	if receive &lt;&gt; null and wagonRecptTime &lt; receive.dateTime then
		receive.updateDateTime( wagonRecptTime );
	endif;
	
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	if _yardLocation = null and _boxcarVisit.confirmed then
		//create the rail job for the trackeditem
		railJob := _boxcarVisit.getReceiveJob(); 
		if railJob = null then 
			railJob := _boxcarVisit.createRailReceiveJob(_passport, null);
		endif;
		//epr par 34466 7/7/14  
		railJob.addJobRequest(_realTi, true, null,null, _passport);		
		app.myEventManager.createSingleObjInfoNoteEvt(_boxcarVisit, app.myPassport.myTerminal.getTerminalEvent(Wagon_Update_Event), _boxcarVisit);	
		railJob.causeTerminalEvent(railJob.Event_Mode_Create);
		
			
	elseif _yardLocation &lt;&gt; null and _boxcarVisit.confirmed then
		// move the ti to the yard area.
		create moveController transient;
		moveController.setMyTrackedItem(_realTi);
		moveController.setMyToPrimaryLocation(_yardLocation);
		moveController.isSystemMove := true;
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		delete moveController;
		
	endif;
		
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog

	delete updController;
	delete tiSet;
	delete moveController;
	
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTi" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_boxcarVisit" type="CM_BoxcarVisit"/>
        <Parameter name="_yardLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxReceiveFromTransArea" id="a89322ee-b410-43af-87ed-1ba86051fef6">
        <updating/>
        <source>trxReceiveFromTransArea(pTI : CM_TrackedItem io; pTAString : String; pBusinessUnit : String;
				_passport : CM_Passport input) updating;
/* NFS 3833: This code receives a prenoted tracked item onto site by placing it in the
nominated receive transfer area stack. We check that the area IS a receive TA.

*/
vars
	ta : CM_TerminalArea;
	theBusinessUnit : CM_Bank;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);	
	
	if pTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Tracked Item", null, null);
		return;
	endif;

	if pTI.isChild then
		//We can't release a child or an attached COU
		app.raiseCMException(ERR_MOVING_CHILD, 'id', null);	
		return;							
	endif;

	beginTransaction;
	
	//First set the business unit if the user has supplied one
	theBusinessUnit := _passport.myTerminal.companies[pBusinessUnit];
	if theBusinessUnit &lt;&gt; null then
		pTI.setCompanyOid(theBusinessUnit);
	endif;
	
	pTI.receiveFromTransferArea(pTAString, _passport);
	
	// If operation raises an exception, our handler will resume to here
	if _passport.noErrors then
		// No errors, so commit
		pTI.causeEvent(pTI.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival), false,null); // XPOSE 1594 AKBK2001DEC
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem" usage="io"/>
        <Parameter name="pTAString" type="String"/>
        <Parameter name="pBusinessUnit" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRegenerateBarrierCode" id="92d19de3-c73b-46f9-a16a-4ade27b77673">
        <updating/>
        <source>trxRegenerateBarrierCode(_vvr  : CM_VehicleVisitRecord input; _inward : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	jlier1	Initial creation 57936

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);	
	
	beginTransaction;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_vvr, true);
	
	app.myUtilityCA.utlCreateBarrierCode(_vvr,_inward,true,_passport);
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_vvr, false);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSendSAPPrePayWSDL112" id="575a8374-b61c-45ff-883d-a6adb4679d85">
        <updating/>
        <source>trxSendSAPPrePayWSDL112(_invoice : CM_Invoice input;
						_passport : CM_Passport input
						) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2019	jlgndl1	Initial creation	TFS 44248

*/

vars

	invLines : CM_InvoiceLineSet;
	msg : String;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	
	if _invoice.myPostedPendingInvoice &lt;&gt; null then
		create invLines transient;
		_invoice.invoiceLines.copy( invLines );
		msg := method.qualifiedName &amp; " - about to call CM_Invoice.sendSAP";
		app.writeLog(msg,LogINFO);	//07 May 2019	NDL	TFS 44248
		_invoice.sendSAP( 0, CM_Invoice.INVOICE_SEND_WSDL112, invLines );
	else
		msg := method.qualifiedName &amp; " - about to call CM_Invoice.sendSAPPrePayWSDL112";	
		_invoice.sendSAPPrePayWSDL112();
	endif;
	
epilog

	delete invLines;
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxVoyageVesselChange" id="8d68859d-4033-4bb2-a664-c3728fbe302d">
        <updating/>
        <source>trxVoyageVesselChange( _realVoyage : CM_Voyage io; _vessel : CM_Vessel; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	app.myUtilityUA.utlVoyageVesselChange( _realVoyage, _vessel, _passport );

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_realVoyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
