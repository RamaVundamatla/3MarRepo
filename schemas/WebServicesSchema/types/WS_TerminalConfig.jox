    <JadeMethod name="delete" id="32776755-3c20-4b45-94a0-fdeb2ff06a82">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2017	jlghl1	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin
	self.allWeightAuthorities.purge();
	delete self.myDamageDefSizeMeasureType;   //08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="76528a1e-0c5f-4fed-aba6-1ac39dd81cdf">
        <updating/>
        <source>setProxyFromObject(_object: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/09/2016	cnwrh7	Initial creation
11/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
16/08/2017  cnwhl1	C# changes, array of authorities, which has an array of names
14/10/2022 	navlw1	TFS 54812 Extra Damage Details optional fields and measurement type required from terminal
17 Oct 2022 navvt20 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
13 Oct 2023 navhn30 TFS 58619: EUP | INB/MOB - Scanning App config
18 Oct 2023 navhn30 ChangeRequest 58762: EUP | VAS Mobile App - [53813.080] VAS Remarks notification
13 Nov 2023	jlizm1	TFS 61018 Cux Retain Target Location ID
09 jan 2024	navnk30	Bug 61228: MTN - Mobile Apps - Terminal Config is not updated
29 May 2024	jlizm1	TFS 62775 Web Portal public multi id search 
07 May 2025 navtr3	MTN-34736 [Enstructure] 54638.030 "Retain Location" Jade settings - Ship To Yard Lander
23 may 2025	jlizm1	MTN 33858 Degraded performance over time
28 Nov 2025	navtr3	MTN-36694 SNO - Release Empties - Database changes
*/

constants
	CERT_NAME_MAX_LEN		: Integer = 100;				// Value as per CM_WeighAuthority's certifiedName's Length
vars
	authTerm 				: CM_WeighAuthTerminal;			// TFS 4492
	weighAuth				: CM_WeighAuthority;
	waDict					: CM_WeighAuthorityDict;
	waDictByCertNameDict	: DynaDictionary;
	iter					: Iterator;
	wsAuthorityObj 			: WS_WeighAuthority;
	wsMeasureType			: WS_MeasurementType;
	measureType				: CM_MeasurementType;
	allWATerms				: CM_WeighAuthTerminalByAuth;
begin
	inheritMethod(_object);
	
	self.allowPublicMultiSeach			:= _object.getConfig(WpAllowPublicMultiSeach).Boolean;
	self.certifiedWeightNeedsVGM 		:= _object.getConfig(CertifiedWeightNeedsVGM).Boolean;
	self.isOverlandedDefaultValue 		:= _object.getConfig(IsOverlandedDefaultValue).Boolean;
	// navlw1 14OCT2022 damage optional fields required
	self.optionalDamageSeverity 		:= _object.getConfig(DamageSeverityOptional).Boolean;
	self.optionalDamageDetails  		:= _object.getConfig(DamageDetailsOptional).Boolean;
	self.railRetainTarget 				:= _object.getConfig(RailRetainTarget).Boolean;			//TFS 61018
	self.railRetainTargetByDefault 		:= _object.getConfig(RailRetainTargetByDef).Boolean;	//TFS 61018
	self.truckRetainTarget 				:= _object.getConfig(TruckRetainTarget).Boolean;		//TFS 61018
	self.truckRetainTargetByDefault		:= _object.getConfig(TruckRetainTargetByDef).Boolean;	//TFS 61018
	self.useWorkPointsForScanningApp 	:= _object.getConfig(UseWPForScanningApp).Boolean;  //13 October 2023 navhn30 TFS 58619
	self.webMOBRemarksDuration			:= _object.getConfig(ETRow_WebMOBRemarksDuration).Integer;	   //18 October 2023 navhn30 TFS 58762
	self.webMOBRemarksOptions   		:= _object.getConfig(ETRow_WebMOBRemarksOptions).Integer;   //17 October 2022 navvt20 TFS 53424
	self.webWPRemarksOptions    		:= _object.getConfig(ETRow_WebWPRemarksOptions).Integer;   //17 October 2022 navvt20 TFS 53424
	self.webWPBookingRelReq				:= _object.getConfig(WebWPBookingRelReq).Boolean;	//28-Nov-2025 navtr3 MTN-36694
	self.shipToYardRetainTarget 		:= _object.getConfig(ShipToYardRetainTarget).Boolean;	//07-May-2025 navtr3 MTN-34736
	self.shipToYardRetTargByDef 		:= _object.getConfig(ShipToYardRetTargByDef).Boolean;	//07-May-2025 navtr3 MTN-34736
	self.shipToYardConfirmTarget 		:= _object.getConfig(ShipToYardConfirmTarget).Boolean;	//07-May-2025 navtr3 MTN-34736
	
	// start navlw1 14OCT2022 tfs 54812 damage measurement type
	measureType := _object.getConfig(DamageSizeDMType).CM_MeasurementType;
	if measureType = null then
		measureType := app.myRoot.getDefaultMeasurementForType(Type_Length);
	endif;
	
	if measureType &lt;&gt; null then
		create wsMeasureType transient;
		wsMeasureType.setProxyFromObject(measureType);
		self.myDamageDefSizeMeasureType	:= wsMeasureType;
	endif;
	// end navlw1 14OCT2022 tfs 54812 damage measurement type
	
	//self.weightCertifiedReference := _object.getConfig(DefaultWeightCertifiedBy).String;	// TFS 4492
	//self.weightCertifiedName := _object.getConfig(DefaultAuthPersonWeight).String;		// TFS 4492
	authTerm := _object.getDefaultWeighAuthority();											// TFS 4492
	if authTerm &lt;&gt; null then																// TFS 4492
		self.weightCertifiedReference := authTerm.myWeighAuthority.certifiedName;			// TFS 4492
		self.weightCertifiedName := authTerm.myWeighAuthority.authorisedName;				// TFS 4492
	endif;
	
	// create collections of all authorities, and all unique authorities
	//09.01.2024 navnk30 #61228 start
	create waDictByCertNameDict transient;
	waDictByCertNameDict.setMembership(CM_WeighAuthorityDict);
	waDictByCertNameDict.addExternalKey(String, CERT_NAME_MAX_LEN, false, false);
	waDictByCertNameDict.endKeys(false);
	
	allWATerms := _object.allWeighAuthTerminals;
	iter := allWATerms.createIterator();
	while iter.next(authTerm) do
		weighAuth := authTerm.myWeighAuthority;
		if weighAuth.notAvailableForUse then
			continue;
		endif;
		if waDictByCertNameDict.getAtKey(weighAuth.certifiedName) = null then
			create waDict transient;
			waDictByCertNameDict.putAtKey(weighAuth.certifiedName, waDict);
		endif;
		waDictByCertNameDict.getAtKey(weighAuth.certifiedName).CM_WeighAuthorityDict.add(weighAuth);
	endwhile;
	delete iter;
	
	iter := waDictByCertNameDict.createIterator;
	while iter.next(waDict) do
		create wsAuthorityObj transient;
		create wsAuthorityObj.authorisedNames transient;
		foreach weighAuth in waDict do
			wsAuthorityObj.authorisedNames.add(weighAuth.authorisedName);
		endforeach;
		wsAuthorityObj.setProxyFromObject(weighAuth);
		self.allWeightAuthorities.add(wsAuthorityObj);
	endwhile;
	delete iter;
	//09.01.2024 navnk30 #61228 end
epilog
	if waDictByCertNameDict &lt;&gt; null then
		waDictByCertNameDict.purge();
		delete waDictByCertNameDict;
	endif;
	
end;
</source>
        <Parameter name="_object" type="CM_Terminal"/>
    </JadeMethod>
</Class>
