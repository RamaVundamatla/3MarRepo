    <JadeMethod name="validateHoldName" id="eb22785c-872a-4c11-af17-90323bb6aa42">
        <source>validateHoldName():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2015	cnwma1	Initial creation  PAR #35519 1035 Error String Too Long
*/

vars

	vesselCode : String;
	returnStr : String;
	totalLength : Integer;
	
	rawString : String;
	rawLength : Integer;
	maxVoyCodeLength : Integer;
	
begin
	if self.myGCVesselStructure.myVessel &lt;&gt; null then
		vesselCode := self.myGCVesselStructure.myVessel.code;
	endif;
//	returnStr := vesselCode &amp; ' ' &amp; self.hatch.padLeadingWith('0',2) &amp; self.place.padLeadingWith('0',2);	
//	if self.name.trimBlanks &lt;&gt; null then
//		returnStr := returnStr &amp; ' ' &amp; self.name;
//	endif;

	rawString := ' ' &amp; self.hatch.padLeadingWith('0',2) &amp; self.place.padLeadingWith('0',2);
	if self.name.trimBlanks &lt;&gt; null then
		rawString := rawString &amp; ' ' &amp; self.name;
	endif;
	rawLength := rawString.length;
	returnStr := vesselCode &amp; rawString;
	
	if self.name &lt;&gt; null then
		totalLength :=returnStr.length;
		if totalLength &gt; 30 then
			app.raiseCMException1(ERR_VSL_HOLDS_LENGTH,returnStr,null, null);
			return false;
		endif;
	endif;
	
	//10 Sep 2015	NDL	Par 36812
	//locations controller id max length = 30
	//voyage code max length = 20
	if not  app.isJMTUnitTest then
		if rawLength &gt; 10 then
			maxVoyCodeLength := 30 - rawLength;
			app.raiseCMWarning2(Lengt_hold_name_used_maxim_len,self.name,maxVoyCodeLength.String,null, null,null);
		endif;
	endif;
	
	return true;
	
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="6c6dcf3e-0aa8-4aa6-9b8c-6002690d08e8">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965
22 JAN  2015    cnwma1 PAR #35519 1035 Error String Too Long
*/

vars

	existing : CM_GCHoldLocationDefn;
	real : CM_GCHoldLocationDefn;

begin

	if self.myGCVesselStructure = null then
		app.raiseCMException(Invalid_GC_structure, null, self);
		return;
	endif;

	if self.place &gt; Max_GC_HoldLocations then		// TFS 2229 was 10
		app.raiseCMException1(Vessel_GC_LocID_max, Max_GC_HoldLocations.String, self.place.String, self);
	endif;
	
	if self.name = null then
		app.raiseCMException(Must_enter_name, null, self);
	endif;
	
	existing := self.myGCVesselStructure.allHoldLocnDefnByHatchPlace.getAtKey(self.hatch,self.place);
	if self.isTransient then
		real := self.pxyGetRealObject();
	else
		real := self;
	endif;
	
	if self.name &lt;&gt; null then					//22/01/2015 cnwma1 PAR #35519
		if not (validateHoldName()) then
			return ;
		endif;
	endif;
	if existing &lt;&gt; null and existing &lt;&gt; real then
		app.raiseCMException2(Loactio_already_defined_hold, self.place.String, self.hatch.String, null, self);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
