    <JadeMethod name="getAverageWeight" id="b40ec332-2db9-49b7-bbca-e390aaa332f8">
        <source>getAverageWeight() : Integer;
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	trackedItem   : CM_TrackedItem;
	totalWeight   : Decimal[14,4];
	numberOfItems : Integer;
	averageWeight : Integer;
	allTis		  : CM_TISet;
begin
	create allTis transient; 					//23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); 	//23/06/2023	navkc1	CR 58406 Task 58408
	if allTis.isNotEmpty then
		foreach trackedItem in allTis discreteLock do
			totalWeight   := totalWeight   + trackedItem.totalWeight;
			numberOfItems := numberOfItems + 1;
		endforeach;
		
		if totalWeight &gt; 0 then
			averageWeight := (totalWeight / numberOfItems).Integer;
		endif;
	else
		// Just use the tare weight of the cargo tytpe
		averageWeight := self.getWeight();
	endif;
	
	return averageWeight;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
