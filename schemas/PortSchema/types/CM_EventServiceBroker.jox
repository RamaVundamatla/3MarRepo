    <JadeMethod name="pxyCreateUpdateProxy" id="d43082a1-be78-4787-a9c9-b22d70d85741">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe 			: SelfType;
	completedOK		: Boolean;
begin
	pxyMe :=  inheritMethod();

	pxyMe.myEventType := self.myEventType;
	pxyMe.myTranMap := self.myTranMap;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e4db44cd-3ba0-444d-97fe-4ac4a0952021">
        <updating/>
        <source>setForCreate(_pxySB: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxySB);

	self.myEventType := _pxySB.myEventType;
	self.myTranMap := _pxySB.myTranMap;
	
	self.initialise(_pxySB.myTranMap.myBank);
end;</source>
        <Parameter name="_pxySB" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxyRSB" id="089c9a76-d222-4771-ac88-54c89ba5d6cc">
        <updating/>
        <source>setProxyRSB(_event : CM_EventType; _tmTM : CM_TranMapEvent) updating;
