    <JadeMethod name="doSortByColumn" id="ab7557f1-78ef-44a9-b51f-66f64a5d6bf3">
        <source>doSortByColumn(_table :CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:     04 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/05/2010	cnwcs5		par 23580 - refactored code so it can be called from &gt;1 place
// ---------------------------------------------------------------------------
vars

begin
	if not self.useTableSorting then
		return;
	endif;
	
	if _table.row &gt; _table.fixedRows then
		return;
	endif;

	if _table.sortColumn[1] &gt; 0 then
		_table.accessCell(1,_table.sortColumn[1]).fontBold := false;
	endif;

	_table.resortTableByColumn(_table.column);

	_table.accessCell(1,_table.column).fontBold := true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
