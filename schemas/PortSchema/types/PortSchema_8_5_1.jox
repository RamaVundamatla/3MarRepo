	inheritMethod(pControllerObj);
	
	self.adjustVoyageEventsAmount(pControllerObj);
	self.rebuildOperatorInvalidKey();
	self.updateInvoiceStatusPermission2(pControllerObj);
	
	self.rebuildCalculationTypeHookCode();			// cnwmc5 - 14 Oct 2015 - PAR 36920
