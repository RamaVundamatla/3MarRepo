    <JadeMethod name="initForm" id="17441af1-c9f8-4442-9e73-157fdbb4c330">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	self.allowNext := true; // TFS 38113
	
	// 35872 if more than one business unit, enable business unit search
	if self.cmbBank.listCount &gt; 1 then
		self.allowSearch := true;
	endif;
	self.allowTblDataSearch := true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled 	:= true;	
	self.mnuTblVExportCSV.enabled := true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();	
	
	self.fldEntDetail.visible := false;
	self.fldEntDetail.useSheetBackColors := true;
	self.fldEntDetail.setDefaultSheetBackColors();
	self.fldEntDetail.initSheetBackColors();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initMSG" id="e946f294-ef83-42ad-a4b0-7db4464fd516">
        <source>initMSG();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 07/02/2025	navlw1		JIRA-33945: MTN | Add Filter MSG to Some Forms
// ---------------------------------------------------------------------------
vars
	theGroupBox : CMUI_MultiSelectFilterGroupBox; // navlw1 #JIRA-33945 07/02/2025
begin
	theGroupBox := self.msgServices;
	theGroupBox.caption := null;
	
	// navlw1 Start #JIRA-33945 07/02/2025
	theGroupBox.myAvailableListBox.stretchHeight	:= true;
	theGroupBox.myAvailableListBox.stretchWidth		:= false;
	theGroupBox.myAvailableListBox.integralHeight	:= false;

	theGroupBox.mySelectedListBox.stretchHeight		:= true;
	theGroupBox.mySelectedListBox.stretchWidth		:= false;
	theGroupBox.mySelectedListBox.integralHeight	:= false;
	// navlw1 End #JIRA-33945 07/02/2025
	
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayService";
	theGroupBox.availableHeading := app.getErrorString(Available_services);
	theGroupBox.selectedHeading := app.getErrorString(Selected_services);
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.readOnly := false;


end;</source>
    </JadeMethod>
    <JadeMethod name="initModalDialog" id="79ba9775-5630-47eb-901a-24e87a6ebfcd">
        <source>initModalDialog();
/*

Purpose:			Initializes the modal dialog for the form

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.frmModalDialog.centreWindow;
	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.frmModalDialog.backColor 	:= self.backColor;
