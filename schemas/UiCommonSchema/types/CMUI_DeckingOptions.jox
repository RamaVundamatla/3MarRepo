    <JadeMethod name="translateForm" id="42e06522-a663-4319-b305-3b9c1f314d38">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007361, locale);
	btnAddIn.translateCaption(Xlat_0000323, locale);
	btnAddOut.translateCaption(Xlat_0000324, locale);
	btnCustomCancel.translateCaption(Xlat_0000314, locale);
	btnCustomIn.translateCaption(Xlat_0000325, locale);
	btnCustomOut.translateCaption(Xlat_0000320, locale);
	btnCustomSave.translateCaption(Xlat_0000319, locale);
	btnDeleteIn.translateCaption(Xlat_0000326, locale);
	btnDeleteOut.translateCaption(Xlat_0000321, locale);
	btnMark.translateCaption(Xlat_0000327, locale);
	btnMoveToMarker.translateCaption(Xlat_0000315, locale);
	btnRevSelection.translateCaption(Xlat_0000316, locale);
	chkOutUseRevOfIn.translateCaption(Xlat_0000311, locale);
	chkShowHeights.translateCaption(Xlat_0000318, locale);
	lblCustomSetting.translateCaption(Xlat_0000312, locale);
	lblHeightFromIn.translateCaption(Xlat_0000317, locale);
	lblHeightFromOut.translateCaption(Xlat_0000313, locale);
	lblIn.translateCaption(Xlat_0000328, locale);
	lblOptionIn.translateCaption(Xlat_0000329, locale);
	lblOptionOut.translateCaption(Xlat_0000322, locale);
	lblOut.translateCaption(Xlat_0000330, locale);
	lblToIn.translateCaption(Xlat_0000331, locale);
	lblToOut.translateCaption(Xlat_0000332, locale);
end;</source>
    </JadeMethod>
