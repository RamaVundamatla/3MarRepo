    <JadeMethod name="addCCVoyAllocRow" id="69c78b90-aa57-4fc4-ae7e-e0aeb8e88385">
        <source>addCCVoyAllocRow( _voyageAllocation : CM_VoyageAllocation ) : CMIF_CCVoyAllocRow;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	ccAllocRow : CMIF_CCVoyAllocRow;

begin

	create ccAllocRow transient;
	ccAllocRow.setBaseDetails( _voyageAllocation, self );

epilog

	return ccAllocRow;

end;</source>
        <Parameter name="_voyageAllocation" type="CM_VoyageAllocation"/>
        <ReturnType type="CMIF_CCVoyAllocRow"/>
    </JadeMethod>
    <JadeMethod name="addNoteableObject" id="fcd875e1-faa7-416b-bb37-c59ad4564897">
        <updating/>
        <source>addNoteableObject( _obj : Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	if not self.allNotableObjects.includes( _obj ) then
		self.allNotableObjects.add( _obj );
		self.beginNotification( _obj, Object_Update_Event, Response_Continuous, null);
		self.beginNotification( _obj, Object_Delete_Event, Response_Continuous, null);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addObjectIfAppropriate" id="085bdaf6-6ef1-4b9a-9de2-c868361695b7">
        <source>addObjectIfAppropriate( cm_Object : CM_Object ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	ccAllocRow : CMIF_CCVoyAllocRow;
	
	usesTS : Boolean;
	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	
	voyAllocsByPriority : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;
	
	iter : Iterator;
	theTi : CM_TrackedItem;
	export : Boolean;
	rehandle : Boolean;
	sob : Boolean;
	
	req : CM_Request;

	invalid : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, cm_Object, invalid);
	
	if not CM_TrackedItem.hasInstance( cm_Object ) then
		if CM_VoyageAllocation.hasInstance( cm_Object ) then
			self.addOneVoyageAllocation( cm_Object.CM_VoyageAllocation );
		endif;
		return;
	endif;
	theTi := cm_Object.CM_TrackedItem;

	if self.myVoyage = null or self.myVoyage.allVoyageAllocations.isEmpty then
		return;
	endif;
	usesTS := self.myVoyage.haveVoyAllocTranship(); // If the voyage does use istranship in the voyage allocations then the allocations for T/S will be an IMEX of TRANSHIP, else it will be IMEX of EXPORT
	
	iter := self.myVoyage.allNotifiedTIsByIdCargoType.createIterator();
	while iter.next( ti ) do
		if ti &lt;&gt; theTi then
			continue;
		endif;
		if ti.isExport or ti.isTranshipOutbound then
			export := true;
		endif;
		break;
	endwhile;
	delete iter;
		
	iter := self.myVoyage.allOnsiteTIsByCargoTypeId.createIterator();
	while iter.next( ti ) do
		if ti &lt;&gt; theTi then
			continue;
		endif;
		if ti.isExport then
			export := true;
		elseif  ti.isTranshipItem then
			if ti.isChild then // PAR 34186
				continue;
			endif;

			if usesTS then
				export := true;
			else
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					export := true;
				endif;
			endif;
		endif;
		if ti.isRehandle then 
			rehandle := true;		
		endif;
		break;
	endwhile;
	delete iter;
	
	iter := self.myVoyage.allOnshipTIsByCargoTypeId.createIterator();
	while iter.next( ti ) do
		if ti &lt;&gt; theTi then
			continue;
		endif;
		if ti.isRehandle then 
			rehandle := true;		
		endif;
		if ti.isSOB then 
			sob := true;		
		endif;
		break;
	endwhile;
	delete iter;
	
	iter := self.myVoyage.allTranshipTIsExport.createIterator();
	while iter.next( ti ) do
		if ti &lt;&gt; theTi then
			continue;
		endif;
		if ti.isChild then // PAR 34186
			continue;
		endif;

		if usesTS then
			export := true;
		else
			if not self.myVoyage.allOnsiteTIsByCargoTypeId.includes(ti) then // already done on site items
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					// TFS 2122 add null test
					if ti.myTranshipDetail &lt;&gt; null then
						pxyTI.setDischargePort(ti.myTranshipDetail.dischargePort());	// from 30138, checking other usage of myDischargePort.code, Aug 2012
					endif;
					export := true;
				endif;
			endif;
		endif;
		break;
	endwhile;
	delete iter;
	
	//now find which allocation each ti should use.	
	create voyAllocsByPriority transient;
	self.myVoyage.populateAllocationsByPriority(voyAllocsByPriority);
		
	if export then
		if pxyTI &lt;&gt; null then
			voyAlloc := self.myVoyage.getTIsVoyageAllocation(pxyTI,voyAllocsByPriority);
		else
			voyAlloc := self.myVoyage.getTIsVoyageAllocation(theTi,voyAllocsByPriority);
		endif;
		if voyAlloc &lt;&gt; null then	
			ccAllocRow := self.allCCVoyAllocRows.getAtKey(voyAlloc);
			if ccAllocRow = null then
				ccAllocRow := self.addCCVoyAllocRow( voyAlloc );
			endif;
			//ETRow_MatchingTIsCollection
			ccAllocRow.addCargo( theTi, true, false, false, false );
		endif;
	endif;
		
	if rehandle then
		voyAlloc := self.myVoyage.getTIsVoyageAllocation(theTi,voyAllocsByPriority);
		if voyAlloc &lt;&gt; null then
			ccAllocRow := self.allCCVoyAllocRows.getAtKey(voyAlloc);
			if ccAllocRow = null then
				ccAllocRow := self.addCCVoyAllocRow( voyAlloc );
			endif;
			//ETRow_NumRehandles
			ccAllocRow.addCargo( theTi, false, true, false, false );
		endif;
	endif;
	
	if sob then
		voyAlloc := self.myVoyage.getTIsVoyageAllocation(theTi,voyAllocsByPriority);
		if voyAlloc &lt;&gt; null then
			ccAllocRow := self.allCCVoyAllocRows.getAtKey(voyAlloc);
			if ccAllocRow = null then
				ccAllocRow := self.addCCVoyAllocRow( voyAlloc );
			endif;
			//ETRow_NumSoB
			ccAllocRow.addCargo( theTi, false, false, true, false );
		endif;
	endif;
	
	if voyAlloc &lt;&gt; null then
		foreach req in voyAlloc.allSlotRequests do	// slot requests
			if req.getTrackedItem = theTi then
				ccAllocRow.addCargo( theTi, false, false, false, true );
				return;
			endif;
		endforeach;
		foreach req in voyAlloc.allRequests do	// roro requests
			if req.getTrackedItem = theTi then
				ccAllocRow.addCargo( theTi, false, false, false, true );
				return;
			endif;
		endforeach;
	endif;
	
epilog
		
	delete voyAllocsByPriority;
	delete pxyTI;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="cm_Object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addOneVoyageAllocation" id="736e7036-eacb-4ab9-8485-e1acdad44b1c">
        <source>addOneVoyageAllocation( _voyAlloc : CM_VoyageAllocation ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Feb 2012	cnwndl1	Initial creation	Par 28896
09 Jan 2012	cnwkpd1	PAR #30964 - Performance enhancements, split the allocations up by Discharge Port
					and use this as a high-level filter to reduce the number of calls to check a TI's allocation

*/

vars

	ccAllocRow : CMIF_CCVoyAllocRow;
	
	req : CM_Request;
	exportReqs : CM_RequestSet;
	rhReqs : CM_RequestSet;
	sobReqs : CM_RequestSet;
	
	allExportTIs : CM_TISet;
	pxyTIs : CM_TISet;
	allRHTIs : CM_TISet;
	allSoBTIs : CM_TISet;
	
	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	realTi : CM_TrackedItem;
	
	allocs : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;

	allocsByPriorityByPort : ObjectLongNameDict;
	allocsByPriority : CM_VoyAllocationByPriority;
	allocDischargePort : CM_Port;
	allocPortCode : String;
	
begin

	if self.myVoyage = null or _voyAlloc = null then
		return;
	endif;
	
	if not ( _voyAlloc.isExportAllocation() or _voyAlloc.isTranshipAllocation() ) then		
		return;
	endif;
	
	create allocs transient;
	self.myVoyage.populateAllocationsByPriority(allocs);
	
	// PAR #30964 - Now split list of allocs into list keyed by Discharge Port code
	create allocsByPriorityByPort transient;
	
	foreach voyAlloc in allocs do
		allocDischargePort := voyAlloc.getDischargePort();
		if allocDischargePort &lt;&gt; null then
			allocPortCode := allocDischargePort.code;
		else
			allocPortCode := null;
		endif;
		
		allocsByPriority := allocsByPriorityByPort[allocPortCode].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			create allocsByPriority transient;
			allocsByPriorityByPort.putAtKey(allocPortCode, allocsByPriority);
		endif;
		
		allocsByPriority.add(voyAlloc);
	endforeach;
	
	// Sort out the slots collections first.
	create exportReqs transient;
	create rhReqs transient;
	create sobReqs transient;
		
	ccAllocRow := self.addCCVoyAllocRow( _voyAlloc.CM_VoyageAllocation );
	
	//ETRow_ColourCodedExports
	//ETRow_ColourCodedRehandles
	//ETRow_ColourCodedSobs
	_voyAlloc.getSlotCollections( exportReqs, rhReqs, sobReqs );
	foreach req in exportReqs do
		ccAllocRow.addRequest( req, true, false, false );
	endforeach;
	foreach req in rhReqs do
		ccAllocRow.addRequest( req, false, true, false );
	endforeach;
	foreach req in sobReqs do
		ccAllocRow.addRequest( req, false, false, true );
	endforeach;
		
	//slot requestss done..
	

	//OK now gather up all the Tis..
	create allExportTIs transient;
	create allRHTIs transient;
	create allSoBTIs transient;
	create pxyTIs transient;
	
	self.gatherVoyageTis(	allExportTIs,	//allExportTIs : CM_TISet io;
							pxyTIs,	//pxyTIs : CM_TISet io;
							allRHTIs,	//allRHTIs : CM_TISet io;
							allSoBTIs	//allSoBTIs : CM_TISet io
							);
	

	//now find which tis would use our allocation.	
	foreach ti in allExportTIs discreteLock do
		if ti.isTransient then
			realTi := ti.pxyGetRealObject;
		else
			realTi := ti;
		endif;
		if self.allNotableObjects.includes( realTi ) then
			// must already be in another allocation...
			continue;
		endif;

		// PAR 30964 - choose appropriate subset by Discharge Port
		allocsByPriority := allocsByPriorityByPort[ti.dischargePort].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			allocsByPriority := allocsByPriorityByPort[null].CM_VoyAllocationByPriority;
			if allocsByPriority = null then
				continue;
			endif;
		endif;

		voyAlloc := self.myVoyage.getTIsVoyageAllocation(ti,allocsByPriority);
		if voyAlloc = null or voyAlloc &lt;&gt; _voyAlloc then
			continue;
		endif;
			
		if realTi &lt;&gt; null then
			//ETRow_MatchingTIsCollection
			ccAllocRow.addCargo( realTi, true, false, false, false );
		endif;	
	endforeach;
	
	foreach realTi in allRHTIs discreteLock do
		if self.allNotableObjects.includes( realTi ) then
			// must already be in another allocation...
			continue;
		endif;
		
		// PAR 30964 - choose appropriate subset by Discharge Port
		allocsByPriority := allocsByPriorityByPort[realTi.dischargePort].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			allocsByPriority := allocsByPriorityByPort[null].CM_VoyAllocationByPriority;
			if allocsByPriority = null then
				continue;
			endif;
		endif;	
	
		voyAlloc := self.myVoyage.getTIsVoyageAllocation(realTi,allocsByPriority);
		if voyAlloc = null or voyAlloc &lt;&gt; _voyAlloc then
			continue;
		endif;
		//ETRow_NumRehandles
		ccAllocRow.addCargo( realTi, false, true, false, false );	
	endforeach;
	
	foreach realTi in allSoBTIs discreteLock do
		if self.allNotableObjects.includes( realTi ) then
			// must already be in another allocation...
			continue;
		endif;
		
		// PAR 30964 - choose appropriate subset by Discharge Port
		allocsByPriority := allocsByPriorityByPort[realTi.dischargePort].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			allocsByPriority := allocsByPriorityByPort[null].CM_VoyAllocationByPriority;
			if allocsByPriority = null then
				continue;
			endif;
		endif;
		
		voyAlloc := self.myVoyage.getTIsVoyageAllocation(realTi,allocsByPriority);
		if voyAlloc = null or voyAlloc &lt;&gt; _voyAlloc then
			continue;
		endif;
		//ETRow_NumSoB
		ccAllocRow.addCargo( realTi, false, false, true, false );
	endforeach;

epilog
	
	delete exportReqs;
	delete rhReqs;
	delete sobReqs;
	
	if pxyTIs &lt;&gt; null and not pxyTIs.isEmpty then
		pxyTIs.purge();
	endif;
	delete pxyTIs;
	delete allExportTIs;
	delete allRHTIs;
	delete allSoBTIs;
	
	delete allocs;
	
	if allocsByPriorityByPort &lt;&gt; null then
		allocsByPriorityByPort.purge();
		delete allocsByPriorityByPort;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="beginGeneralNotifications" id="0f8491f8-d348-4856-b9e0-fa98f7c24fce">
        <source>beginGeneralNotifications();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2012	cnwndl1	Initial creation	Par 28896
09 Jan 2013	cnwkpd1	PAR #30964 - Subscribe for new notification for Voyage Allocation maintenance

*/

vars
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	invalid : Boolean;
	ed : Integer;

begin
	create tiSet transient;
	
	// get all of the cargo related to the voyage that we could be interested in.
	self.myVoyage.allOnsiteTIsByCargoTypeId.copy( tiSet );
	
	foreach ti in self.myVoyage.allNotifiedTIsByIdCargoType discreteLock do
		tiSet.addNoDuplicates( ti, false );
	endforeach;
	
	foreach ti in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do
		tiSet.addNoDuplicates( ti, false );
	endforeach;
	
	foreach ti in self.myVoyage.allTranshipTIsExport discreteLock do
		tiSet.addNoDuplicates( ti, false );
	endforeach;
		
	on Exception do app.handleDeletedObject(exception,ti,invalid);
	foreach ti in tiSet do		
		invalid := false;
		ed := ti.edition;
		if invalid then
			continue;
		endif;
		self.allNotableObjects.add( ti );
		beginNotification(ti, Object_Update_Event, Response_Continuous, null);
		beginNotification(ti, Object_Delete_Event, Response_Continuous, null);
	endforeach;

	self.beginNotification(self.myVoyage, self.myVoyage.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), Response_Continuous, null);
	self.beginNotification(self.myVoyage, self.myVoyage.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myVoyage, self.myVoyage.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_MAINT), Response_Continuous, null);	// PAR #30964
	self.beginNotification(self.myVoyage, self.myVoyage.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_DELETE), Response_Continuous, null);	
	
	self.beginClassNotification(CM_TrackedItem, false, self.myVoyage.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myVoyage.myTerminal.getTerminalEvent(TIEvent_PreNote_Update), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myVoyage.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myVoyage.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival), Response_Continuous, 0);

epilog

	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="77d75755-e397-4aa4-b0cf-7d3795ee87f1">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	option : Integer;
	time : Integer;

begin

	self.isSelfDestructing := true;
	self.setVoyage( null );
	
	if self.getTimerStatus(self.Timer_Tag_Part_Refresh, option, time) then
		self.endTimer(self.Timer_Tag_Part_Refresh);
	endif;
	if self.getTimerStatus(self.Timer_Tag_Full_Refresh, option, time) then
		self.endTimer(self.Timer_Tag_Full_Refresh);
	endif;
	
	endGeneralNotifications();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildQueuedAllocations" id="42f7e710-02da-46eb-8357-bf6dae28661d">
        <source>doBuildQueuedAllocations();

/*

Purpose:			Called from a partial refresh timer event - rebuild all the counts for 
					any allocations in the pending refresh list

Parameters:			None

Return Value:		None


Date		Who		Reason
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding

*/

vars
	iter		: Iterator;
	invalid		: Boolean;
	alloc		: CM_VoyageAllocation;
	
begin
	on Exception do app.handleDeletedObject(exception, alloc, invalid);
	
	iter := self.allAllocationsPendingRefresh.createIterator();
	while iter.next(alloc) do
	
		self.doRemoveAndBuildAllocation(alloc);
		
	endwhile;
	
	self.allAllocationsPendingRefresh.clear();		

epilog
	delete iter;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doQueueAllocationRefresh" id="0bd3e60e-0b23-438d-902e-37e95458062e">
        <updating/>
        <source>doQueueAllocationRefresh(_allocation : CM_VoyageAllocation) updating;

/*

Purpose:			Queue a partial refresh of the table, adding the passed in allocation to 
					the list that needs updating

Parameters:			Allocation that has been updated

Return Value:		None


Date		Who		Reason
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding

*/

vars

begin
	// Do nothing if we already have a full refresh queued
	if self.fullRefreshIsQueued then
		return;
	endif;
	
	// If there is already a partial refresh queued, and this allocation is already in the
	// list, then do nothing
	if self.allAllocationsPendingRefresh.includes(_allocation) then
		return;
	endif;
	
	self.allAllocationsPendingRefresh.add(_allocation);
	
	// Queue a partial refresh
	self.doQueueRefresh();
	
epilog

end;</source>
        <Parameter name="_allocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doQueueFullRefresh" id="2b36fd31-c078-49a9-b52e-2330f5fdd7bd">
        <updating/>
        <source>doQueueFullRefresh() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Jan 2012	cnwndl1	Initial creation	Par 28896
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding

*/

vars

begin

	if self.fullRefreshIsQueued or self.isSelfDestructing then
		return;
	endif;
	
	//yes we mark it as queued anyway.
	self.fullRefreshIsQueued := true;
	self.partRefreshIsQueued := true;
	
	// PAR #30964 - Clear the list of pending allocation refreshes, because these are no longer relevant
	// when a full refresh is queued
	self.allAllocationsPendingRefresh.clear();
	
	// Queue a refresh in 2 seconds, unless initialising.
	// if initialising then that method will call 'startTimerForFullRefresh'
	if not self.myTable.getPropertyValue("isInitialising").Boolean then
		self.startTimerForFullRefresh();
	endif;
	
	return;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueRefresh" id="0c16b916-75b3-4df9-982b-d1ebd1ff0121">
        <updating/>
        <source>doQueueRefresh() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2012	cnwndl1	Initial creation	Par 28896

*/

vars
	option,
	time			: Integer;

begin

	if self.partRefreshIsQueued or self.fullRefreshIsQueued or self.isSelfDestructing then
		return;
	endif;
	
	//yes we mark it as queued anyway.
	self.partRefreshIsQueued := true;
	
	// Queue a refresh in 2 seconds, unless initialising.
	// if initialising then that method will call startTimerForPartRefresh.
	if not self.myTable.getPropertyValue("isInitialising").Boolean then
		self.startTimerForPartRefresh();
	endif;
	
	return;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveAndBuildAllocation" id="272eb6b7-6803-4b96-bc75-85a2cce66826">
        <source>doRemoveAndBuildAllocation( _allocation : CM_VoyageAllocation );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	existingAllocationRow : CMIF_CCVoyAllocRow;

begin

	existingAllocationRow := self.getCCVoyAllocRowFor( _allocation );
	
	if existingAllocationRow &lt;&gt; null then
		// need to remove the row related to this allocation.
		self.removeCCVoyAllocRow( existingAllocationRow );
	endif;
	
	
	//now add the allocation.
	self.addObjectIfAppropriate( _allocation );

epilog

end;</source>
        <Parameter name="_allocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doUpdateVoyageAllocationsFor" id="63be4b56-9603-4082-aeb4-5aa26f1cd1f1">
        <updating/>
        <source>doUpdateVoyageAllocationsFor( userInfo : CM_VoyageController ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2012	cnwndl1	Initial creation
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding

*/

vars

	slotCont : CM_SlotController;
	//roroCont : CM_ROROSlotController;
	voyCont : CM_VoyageROROController;
	
	orignalAllocationRow : CMIF_CCVoyAllocRow;
	
	orignalAllocation : CM_VoyageAllocation;
	newAllocation : CM_VoyageAllocation;
	
	link : CMIF_CCVoyAllocObjectLink;
	
	error : Boolean;


begin

	if self.fullRefreshIsQueued then
		return;
	endif;

	//need to find the original allocation and rebuild it
	//then find the current allocation if its different and rebuild it too.
	
	link := self.allCCVoyAllocObjectLinkByObjs.getAtKeyGeq( userInfo, null );
	if link &lt;&gt; null and link.myCollectedObject = userInfo then
		orignalAllocationRow := link.myCCVoyRowAllocRow;
		orignalAllocation := orignalAllocationRow.myVoyageAllocation;
	endif;
	
	if userInfo.isKindOf(CM_SlotController) then
		slotCont := userInfo.CM_SlotController;
		if slotCont.mySlotRequestLoad &lt;&gt; null then
			newAllocation := slotCont.mySlotRequestLoad.allAllocations.first.CM_VoyageAllocation;
		endif;
//	elseif userInfo.isKindOf(CM_ROROSlotController) then
//		roroCont := userInfo.CM_ROROSlotController;
	elseif userInfo.isKindOf(CM_VoyageROROController) then	//26 Nov 2012	Par 30754
		voyCont := userInfo.CM_VoyageROROController;
		if voyCont.myRORORequestLoad &lt;&gt; null then
			newAllocation := voyCont.myRORORequestLoad.allAllocations.first.CM_VoyageAllocation;
		endif;
	endif;
	
	if orignalAllocation &lt;&gt; null then
		// PAR #30964 - changed to just queue a refresh of the affected allocation
		self.doQueueAllocationRefresh(orignalAllocation);
		
//		on Exception do app.handleDeletedObject( exception, orignalAllocation, error);
//		self.doRemoveAndBuildAllocation(orignalAllocation);
	endif;
	
	if newAllocation &lt;&gt; null and newAllocation &lt;&gt; orignalAllocation then
		// PAR #30964 - changed to just queue a refresh of the affected allocation
		self.doQueueAllocationRefresh(newAllocation);

//		self.doRemoveAndBuildAllocation(newAllocation);
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="userInfo" type="CM_VoyageController"/>
    </JadeMethod>
    <JadeMethod name="endGeneralNotifications" id="9d7c74f2-2350-4226-8f78-9f92460a423e">
        <source>endGeneralNotifications();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	self.allNotableObjects.clear();
	self.endNotificationForSubscriber( self );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="gatherVoyageTis" id="b03458d9-96c6-4603-8b0e-cfe6f5237c95">
        <source>gatherVoyageTis(	allExportTIs : CM_TISet io;
					pxyTIs : CM_TISet io;
					allRHTIs : CM_TISet io;
					allSoBTIs : CM_TISet io
					);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2012	cnwndl1	Initial creation

*/

vars

	usesTS : Boolean;
	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;

begin

	usesTS := self.myVoyage.haveVoyAllocTranship();
	
	foreach ti in self.myVoyage.allNotifiedTIsByIdCargoType discreteLock do
		if ti.isExport or ti.isTranshipOutbound then
			allExportTIs.addNoDuplicates(ti, false);
		endif;
	endforeach;
	foreach ti in self.myVoyage.allOnsiteTIsByCargoTypeId discreteLock do
		if ti.isExport then
			allExportTIs.addNoDuplicates(ti, false);
		elseif  ti.isTranshipItem then
			// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
			//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
			if usesTS then
				allExportTIs.addNoDuplicates(ti, false);
			else
				if ti.isChild then // PAR 34186
					continue;
				endif;
			
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					allExportTIs.addNoDuplicates(pxyTI, false);
				endif;
			endif;
		endif;
		if ti.isRehandle then 
			allRHTIs.addNoDuplicates(ti, false);		
		endif;
	endforeach;
	
	foreach ti in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do	
		if ti.isRehandle then 
			allRHTIs.addNoDuplicates(ti, false);		
		endif;
		if ti.isSOB then 
			allSoBTIs.addNoDuplicates(ti, false);		
		endif;
	endforeach;

	foreach ti in self.myVoyage.allTranshipTIsExport discreteLock do
		// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
		//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
		if usesTS then
			allExportTIs.addNoDuplicates(ti, false);
		else
			if ti.isChild then // PAR 34069
				continue;
			endif;
			if not self.myVoyage.allOnsiteTIsByCargoTypeId.includes(ti) then // already done on site items
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					// TFS 2122 add null test
					if ti.myTranshipDetail &lt;&gt; null then
						pxyTI.setDischargePort(ti.myTranshipDetail.dischargePort());	// from 30138, checking other usage of myDischargePort.code, Aug 2012
					endif;
					allExportTIs.addNoDuplicates(pxyTI, false);
				endif;
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="allExportTIs" type="CM_TISet" usage="io"/>
        <Parameter name="pxyTIs" type="CM_TISet" usage="io"/>
        <Parameter name="allRHTIs" type="CM_TISet" usage="io"/>
        <Parameter name="allSoBTIs" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCCVoyAllocRowFor" id="634b7abd-cf29-4f0a-a9fb-8f2518ad8b8a">
        <source>getCCVoyAllocRowFor( _voyAlloc : CM_VoyageAllocation ) : CMIF_CCVoyAllocRow;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	return self.allCCVoyAllocRows.getAtKey( _voyAlloc );

epilog

end;</source>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <ReturnType type="CMIF_CCVoyAllocRow"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="e267211f-9079-4dad-acc5-ec059d46d798">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2012	cnwndl1	Initial creation	Par 28896
09 Jan 2013	cnwkpd1	PAR #30964 - Deal with new notification for Voyage Allocation maintenance

*/

vars

	link : CMIF_CCVoyAllocObjectLink;
	ti : CM_TrackedItem;
	actualEvent : Integer;
	error : Boolean;

begin

	actualEvent := self.myVoyage.myTerminal.getEventFromTerminalEvent(eventType);
	
	if theObject.isKindOf( CM_Object ) then
		link := self.allCCVoyAllocObjectLinkByObjs.getAtKeyGeq( theObject.CM_Object, null );
		if link &lt;&gt; null and link.myCollectedObject = theObject then
			// this is an object that we have loaded in our structure...  ( Tracked item )
			// then remove it and re-add if appropriate
			self.removeCollectedObject(theObject.CM_Object);
			if eventTag = Object_Delete_Event then
				self.removeNoteableObject(theObject.CM_Object);
				// nothing more to do.
				return;
			else
				// need to potentially add this one back in
				self.addObjectIfAppropriate( theObject.CM_Object );
				return;
			endif;
		else
			// the note was for a TI that we are not displaying
			//or for some other class of object.
			if theObject.isKindOf( CM_TrackedItem ) then
				//A tracked item that we havent loaded.
				if eventTag = Object_Delete_Event then
					return;
				else
					// will capture "TIEvent_PreNote_Add", "TIEvent_PreNote_Update", "TIEvent_Terminal_Receival"
					ti := theObject.CM_TrackedItem;
					on Exception do app.handleDeletedObject(exception, ti, error);
					if ti.myVoyage = self.myVoyage then
						self.addObjectIfAppropriate( ti );
					endif;
					return;
				endif;
				
			elseif actualEvent = EVENT_UPDATE_VOYAGE_AREA and userInfo &lt;&gt; null and 
			   (userInfo.isKindOf(CM_SlotController) or	
				//userInfo.isKindOf(CM_ROROSlotController)) then
				userInfo.isKindOf(CM_VoyageROROController)) then	//26 Nov 2012	Par 30754
				// need to refresh the allocation/s involved.
				on Exception do app.handleDeletedObject(exception, userInfo.CM_VoyageController, error);
				self.doUpdateVoyageAllocationsFor( userInfo.CM_VoyageController );
				
			elseif actualEvent = EVENT_VOY_ALLOC_UPDATE and userInfo &lt;&gt; null and userInfo.isKindOf(CM_VoyageAllocation) then			// PAR #30964
				on Exception do app.handleDeletedObject(exception, userInfo.CM_VoyageAllocation, error);
				if not ( userInfo.CM_VoyageAllocation.isExportAllocation() or userInfo.CM_VoyageAllocation.isTranshipAllocation() ) then		
					// not a load one, ignore it.
					return;
				endif;
				// Queue a partial refresh of the affected allocation
				self.doQueueAllocationRefresh(userInfo.CM_VoyageAllocation);

			elseif actualEvent = EVENT_VOY_ALLOC_MAINT and userInfo &lt;&gt; null and userInfo.isKindOf(CM_VoyageAllocation) then			// PAR #30964
				on Exception do app.handleDeletedObject(exception, userInfo.CM_VoyageAllocation, error);
				if not ( userInfo.CM_VoyageAllocation.isExportAllocation() or userInfo.CM_VoyageAllocation.isTranshipAllocation() ) then		
					// not a load one, ignore it.
					return;
				endif;
				// need to refresh everything.
				self.doQueueFullRefresh();
				
			elseif actualEvent = EVENT_VOY_ALLOC_DELETE and userInfo &lt;&gt; null and userInfo.isKindOf(CM_VoyageAllocation) then
				// need to refresh everything.
				self.doQueueFullRefresh();
			
			endif;
			
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="populate" id="142a4ca8-f9aa-473f-99bb-92417ae22235">
        <updating/>
        <source>populate() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2012	cnwndl1	Initial creation	Par 28896
09 Jan 2012	cnwkpd1	PAR #30964 - Performance enhancements, split the allocations up by Discharge Port
					and use this as a high-level filter to reduce the number of calls to check a TI's allocation
					
*/

vars
	ccAllocRow : CMIF_CCVoyAllocRow;
	slot : CM_SlotRequest;
	roroReq : CM_VoyageRequest;
	
	req : CM_Request;
	exportReqs : CM_RequestSet;
	rhReqs : CM_RequestSet;
	sobReqs : CM_RequestSet;
	
	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	realTi : CM_TrackedItem;
	allExportTIs : CM_TISet;
	pxyTIs : CM_TISet;
	allRHTIs : CM_TISet;
	allSoBTIs : CM_TISet;
	
	allocs : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;

	allocsByPriorityByPort : ObjectLongNameDict;
	allocsByPriority : CM_VoyAllocationByPriority;
	allocDischargePort : CM_Port;
	allocPortCode : String;

begin

	if self.myVoyage = null or self.myVoyage.allVoyageAllocations.isEmpty then
		return;
	endif;
	
	create allocs transient;
	self.myVoyage.populateAllocationsByPriority(allocs);
	
	// PAR #30964 - Now split list of allocs into list keyed by Discharge Port code
	create allocsByPriorityByPort transient;
	
	foreach voyAlloc in allocs do
		allocDischargePort := voyAlloc.getDischargePort();
		if allocDischargePort &lt;&gt; null then
			allocPortCode := allocDischargePort.code;
		else
			allocPortCode := null;
		endif;
		
		allocsByPriority := allocsByPriorityByPort[allocPortCode].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			create allocsByPriority transient;
			allocsByPriorityByPort.putAtKey(allocPortCode, allocsByPriority);
		endif;
		
		allocsByPriority.add(voyAlloc);
	endforeach;

	// Sort out the slots collections first.
	create exportReqs transient;
	create rhReqs transient;
	create sobReqs transient;
	
	foreach voyAlloc in allocs do	
		if not ( voyAlloc.isExportAllocation() or voyAlloc.isTranshipAllocation() ) then		
			continue;
		endif;
		
		ccAllocRow := self.addCCVoyAllocRow( voyAlloc.CM_VoyageAllocation );
		
		//ETRow_ColourCodedExports
		//ETRow_ColourCodedRehandles
		//ETRow_ColourCodedSobs
		exportReqs.clear();
		rhReqs.clear();
		sobReqs.clear();
		voyAlloc.getSlotCollections( exportReqs, rhReqs, sobReqs );
		foreach req in exportReqs do
			ccAllocRow.addRequest( req, true, false, false );
		endforeach;
		foreach req in rhReqs do
			ccAllocRow.addRequest( req, false, true, false );
		endforeach;
		foreach req in sobReqs do
			ccAllocRow.addRequest( req, false, false, true );
		endforeach;
		
	endforeach;	
	//slot requestss done..
	
	//OK now gather up all the Tis..
	create allExportTIs transient;
	create allRHTIs transient;
	create allSoBTIs transient;
	create pxyTIs transient;
	
	self.gatherVoyageTis(	allExportTIs,	//allExportTIs : CM_TISet io;
							pxyTIs,	//pxyTIs : CM_TISet io;
							allRHTIs,	//allRHTIs : CM_TISet io;
							allSoBTIs	//allSoBTIs : CM_TISet io
							);
	

	//now find which allocation each ti should use.	
	foreach ti in allExportTIs discreteLock do
	
		// PAR 30964 - choose appropriate subset by Discharge Port
		allocsByPriority := allocsByPriorityByPort[ti.dischargePort].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			allocsByPriority := allocsByPriorityByPort[null].CM_VoyAllocationByPriority;
			if allocsByPriority = null then
				continue;
			endif;
		endif;

		voyAlloc := self.myVoyage.getTIsVoyageAllocation(ti,allocsByPriority);
		if voyAlloc = null then
			continue;
		endif;
		
		if ti.isTransient then
			realTi := ti.pxyGetRealObject;
		else
			realTi := ti;
		endif;	
			
		if realTi &lt;&gt; null then
			ccAllocRow := self.allCCVoyAllocRows.getAtKey(voyAlloc);
			if ccAllocRow = null then
				ccAllocRow := self.addCCVoyAllocRow( voyAlloc );
			endif;
			//ETRow_MatchingTIsCollection
			ccAllocRow.addCargo( realTi, true, false, false, false );
		endif;	
	endforeach;
	
	foreach realTi in allRHTIs discreteLock do
	
		// PAR 30964 - choose appropriate subset by Discharge Port
		allocsByPriority := allocsByPriorityByPort[realTi.dischargePort].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			allocsByPriority := allocsByPriorityByPort[null].CM_VoyAllocationByPriority;
			if allocsByPriority = null then
				continue;
			endif;
		endif;	
	
		voyAlloc := self.myVoyage.getTIsVoyageAllocation(realTi,allocsByPriority);
		if voyAlloc = null then
			continue;
		endif;
		ccAllocRow := self.allCCVoyAllocRows.getAtKey(voyAlloc);
		if ccAllocRow = null then
			ccAllocRow := self.addCCVoyAllocRow( voyAlloc );
		endif;
		//ETRow_NumRehandles
		ccAllocRow.addCargo( realTi, false, true, false, false );	
	endforeach;
	
	foreach realTi in allSoBTIs discreteLock do
	
		// PAR 30964 - choose appropriate subset by Discharge Port
		allocsByPriority := allocsByPriorityByPort[realTi.dischargePort].CM_VoyAllocationByPriority;
		if allocsByPriority = null then
			allocsByPriority := allocsByPriorityByPort[null].CM_VoyAllocationByPriority;
			if allocsByPriority = null then
				continue;
			endif;
		endif;
		
		voyAlloc := self.myVoyage.getTIsVoyageAllocation(realTi,allocsByPriority);
		if voyAlloc = null then
			continue;
		endif;
		ccAllocRow := self.allCCVoyAllocRows.getAtKey(voyAlloc);
		if ccAllocRow = null then
			ccAllocRow := self.addCCVoyAllocRow( voyAlloc );
		endif;
		//ETRow_NumSoB
		ccAllocRow.addCargo( realTi, false, false, true, false );
	endforeach;

epilog
	
	delete exportReqs;
	delete rhReqs;
	delete sobReqs;
	
	if pxyTIs &lt;&gt; null and not pxyTIs.isEmpty then
		pxyTIs.purge();
	endif;
	delete pxyTIs;
	delete allExportTIs;
	delete allRHTIs;
	delete allSoBTIs;
	
	delete allocs;
	
	if allocsByPriorityByPort &lt;&gt; null then
		allocsByPriorityByPort.purge();
		delete allocsByPriorityByPort;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeCCVoyAllocRow" id="c358a277-6015-41b5-b6b0-9dfbb47ef2a8">
        <source>removeCCVoyAllocRow( _allocationRow : CMIF_CCVoyAllocRow io )protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	obj : CM_Object;

begin

	foreach obj in _allocationRow.allActualCargoExports do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	foreach obj in _allocationRow.allActualCargoRH do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	foreach obj in _allocationRow.allActualCargoSoB do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	foreach obj in _allocationRow.allColourCodingExports do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	foreach obj in _allocationRow.allColourCodingRH do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	foreach obj in _allocationRow.allColourCodingSoB do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	foreach obj in _allocationRow.allPlanned do
		self.removeCollectedObject( obj );
		self.removeNoteableObject( obj );
	endforeach;
	
	delete _allocationRow;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allocationRow" type="CMIF_CCVoyAllocRow" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeCollectedObject" id="5c306318-f785-420d-8b5b-2e1a9640fd4c">
        <source>removeCollectedObject( _collectedObj : CM_Object ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	link : CMIF_CCVoyAllocObjectLink;
	retValue : Boolean;

begin

	while true do
	
		link := self.allCCVoyAllocObjectLinkByObjs.getAtKeyGeq(_collectedObj,null);
		if link = null or link.myCollectedObject &lt;&gt; _collectedObj then
			break;
		endif;
			
		delete link;
		link := null;
		retValue := true;
		
	endwhile;
	

epilog

	return retValue;

end;</source>
        <Parameter name="_collectedObj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeNoteableObject" id="f004b933-d7a7-4d22-b131-5d8d2fb59e4c">
        <source>removeNoteableObject( _obj : Object );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.allNotableObjects.includes( _obj ) then
		self.allNotableObjects.remove( _obj );
		self.endNotification( _obj, Object_Update_Event );
		self.endNotification( _obj, Object_Delete_Event );
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setMyTable" id="1e6b9e3f-4c98-42d6-8e8b-baab0591fb02">
        <updating/>
        <source>setMyTable( _table : Table ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	self.myTable := _table;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="setVoyage" id="69d23623-61ad-47f1-84a7-b94f333bb9ff">
        <updating/>
        <source>setVoyage( _voyage : CM_Voyage ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding

*/

vars

begin

	self.allCCVoyAllocObjectLinkByObjs.purge();
	self.allCCVoyAllocRows.purge();
	self.allAllocationsPendingRefresh.clear();		// PAR #30964
	
	if self.myVoyage &lt;&gt; null then
		self.endGeneralNotifications();
	endif;
	
	if self.myTable &lt;&gt; null then
		self.fullRefreshIsQueued := false;
		self.partRefreshIsQueued := false;
	endif;

	self.myVoyage := _voyage;
	
	if self.myVoyage &lt;&gt; null then
		self.beginGeneralNotifications();
	endif;
	self.populate();

epilog

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="startTimerForFullRefresh" id="1207d782-c784-4407-9769-cec56447a96e">
        <source>startTimerForFullRefresh();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	option,
	time			: Integer;
begin

	if not self.getTimerStatus(self.Timer_Tag_Full_Refresh, option, time) then
		self.beginTimer(2000, Timer_OneShot, self.Timer_Tag_Full_Refresh);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startTimerForPartRefresh" id="d04edc51-b071-4552-ba63-5c95f1b2db7a">
        <source>startTimerForPartRefresh();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	option,
	time			: Integer;
begin

	if not self.getTimerStatus(self.Timer_Tag_Part_Refresh, option, time) then
		self.beginTimer(2000, Timer_OneShot, self.Timer_Tag_Part_Refresh);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="1056d7ab-5c12-4903-b462-f6047b1ce3ef">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

begin

	self.handleNotification( eventType, theObject, eventTag, null );

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="535af0fa-e5a9-45dd-ae2b-9d4c13e3b8dd">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Feb 2012	cnwndl1	Initial creation	Par 28896
10 Jan 2013	cnwkpd1	PAR #30964 - Performance improvements to load colour coding

*/

vars

	ccVoyAllocRow : CMIF_CCVoyAllocRow;

begin

	if eventTag = Timer_Tag_Full_Refresh and self.fullRefreshIsQueued then
		self.myTable.setPropertyValue("isInitialising",true);
		self.setVoyage(self.myVoyage);
		self.myTable.sendMsgWithParams("doRefreshAll", self.myVoyage );
		return;
	endif;
	
	if eventTag = Timer_Tag_Part_Refresh and self.fullRefreshIsQueued then
		// don't bother doing a part refresh we will be doing a full rebuild within 2 seconds.
		return;
	endif;
	
	if eventTag = Timer_Tag_Part_Refresh and self.partRefreshIsQueued then
		self.doBuildQueuedAllocations();			// PAR #30964
		self.myTable.sendMsg("doRefreshFromChanges");
	endif;

epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="efe05fb6-8fe1-4dff-9051-839c3ff10860">
