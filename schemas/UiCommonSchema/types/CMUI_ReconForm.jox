    <JadeMethod name="btnCancelComplet_click" id="ff0f665d-1bc1-47cd-94f5-a93da911501e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancelComplet_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwml2	Initial creation

*/

vars

begin
	self.frmComplete.visible := false;
	self.doClearComplete();
	self.frmMain.enabled := true;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCompleteRecon_click" id="b0bab8e7-cdcf-4847-8993-a1befead78d2">
