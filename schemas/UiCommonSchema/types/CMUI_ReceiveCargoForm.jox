    <JadeMethod name="setCargoTypeToISOContainer" id="102d812b-a1ad-45c8-a357-4332e347fe6f">
        <source>setCargoTypeToISOContainer(_combo: CMUI_FieldComboBox);
/*

Purpose:			Sets the cargo type to iso container

Parameters:			_combo	CMUI_FieldComboBox	Combo box to set the cargo type for

Return Value:		NONE

Date			Who		Reason
02 August 2023	navpw1	Initial creation TFS: 59297

*/

vars
	cargoType : CM_CargoType;
	
begin
	inheritMethod(_combo);
	
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
	if not cargoType.allowDuplicates then
		self.chkItemised.getEmbeddedControl.CheckBox.value := true;
	else
		self.chkItemised.getEmbeddedControl.CheckBox.value := false;
	endif;
	
end;</source>
        <Parameter name="_combo" type="CMUI_FieldComboBox"/>
    </JadeMethod>
    <JadeMethod name="setColourDetails" id="8bfa453a-c5af-43a7-a028-74342e9188e7">
        <updating/>
        <source>setColourDetails(_colours : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	colours	: StringArray;
	col		: String;
	colour 	: CM_VehicleColour;
	colDict	: CM_VehicleColourByColour;

begin
	if self.myTerminal.getConfig(ValidateColour).Boolean then
		create colours transient;
		create colDict transient;
		colours := _colours.getTokens();
		
		foreach col in colours do
			colour := app.myDutyDocRoot.allVehicleColours[col];
			if colour &lt;&gt; null then
				colDict.add(colour);
			endif;
		endforeach;
		
		self.lstColourList.setSelected(colDict);
		if app.myCurrentUserCan(self.myTerminal, PmAdmVehicleColourMaint) then
			self.lstColourList.accessCell(1,1).inputType := null;
			self.lstColourList.accessedCell.text := null;
		endif;
		self.lstColour.hasLostFocus(self.lstColour);
	else
		self.txtColourList.text := _colours;
	endif;
epilog
	delete colours;
	delete colDict;
end;</source>
        <Parameter name="_colours" type="String"/>
    </JadeMethod>
    <JadeMethod name="setContainerAdditionalDetails" id="f10b8208-0731-4c18-b2da-f193f1df801c">
        <updating/>
        <source>setContainerAdditionalDetails(_item : Object) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who			Reason
19 July 2009	cnwdap1		Initial creation
18 August 2010	cnwjo3		par 25442.  Only adding Stops and ToDos from TI Master.  Note, fix will not work if CMGTE_Receival section occurs after CM_TIMaster section.
25/11/2015		cnwma1  	PAR #36943 Shipping Reference error during extract
15/03/2016		cnwdap1		PAR #37606 "Not available for entry" customs agent
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
28 August 2024	jlizm1		TFS 65873 Prenoted Customer Priority is lost when Gating In
*/

vars
	brItem			: CM_BRefItemContainer;
	item 			: CM_TrackedItem;
	entity			: CMGTE_Receival;
	toDoTask		: CM_ToDoTask;
	intArray		: IntegerArray;
	stop			: CM_Stops;
	toDo			: CM_ToDoTaskDesc;
	strArray		: StringArray;
	spLift			: CM_SpecialLift;
	preNote			: CMIF_PreNote;
	master			: CM_TIMaster;
	stopTable 		: CM_StopsTable;
	taskDesc		: CM_ToDoTaskDesc;
	allStops		: CM_StopsByIdDict;
	obj				: Object;
	booking			: CM_BookingRef;					// 16/02/2011 cnwmh5 #26961
	invalid : Boolean;	//23 May 2014	NDL	Testing
	agent			: CM_CustomsAgent;					// PAR #37606
	bank :CM_Bank;
	contract : CM_InvoiceContract;
	contractIdStr : String;
	op 			: CM_Operator;
	debtor 		: CM_Debtor;
	myContract  : CM_InvoiceContract;
	banks		: String;
	priority	: CM_CustomerPriority;
	
begin
	if _item.isKindOf(CM_BRefItemContainer) then
	
		brItem := _item.CM_BRefItemContainer;
		
		txtDescription.setValue(brItem.description);
		cmbSpecialStow.setForObject(brItem.mySpecialStow);

		// special lift
		create strArray transient;
		strArray.clear;
		foreach spLift in brItem.allSpecialLifts do
			strArray.add(spLift.code);
		endforeach;
		self.myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
		self.txtSpecialLift.text := self.truncateDisplayString(self.lstSpecialLift.getSelectedString(CM_SpecialLift::code.name), -1);
		
		// 16/02/2011 cnwmh5 #26961 - Start
		if brItem.myBookingReference &lt;&gt; null then
			booking := brItem.myBookingReference;
			if booking &lt;&gt; null then
				self.cmbCustomsAgent.setForObject(booking.getCustomsAgentObject());	// PAR 26922 - change to use new method
				self.chkDirDel.setValue( booking.directDelivery );	//04 Apr 2013	NDL	CCMS 1299		Par 31102
				txtShippingRef.setValue(booking.shippingReference);  //25/11/2015 cnwma1 PAR #36943
			endif;
			
		endif;
		// 16/02/2011 cnwmh5 #26961 - End
		
	elseif _item.isKindOf(CM_TrackedItem) then
	
		item := _item.CM_TrackedItem;
	
		create intArray transient;
		self.lstAllStops.clearSelected();
//		foreach stop in item.getAllStops() do		// cnwrl1 15/12/2009 PAR 21889 - what it was
		create allStops transient;
		item.getAllActiveStops( allStops );
		foreach stop in allStops do
			intArray.add(stop.myStopsTable.id);
		endforeach;
		self.myAssistant.setListTableStopsTables(self.lstAllStops, intArray);
		self.lstStops.hasLostFocus(self.lstStops);
		
		intArray.clear;
		self.lstToDoTasks.clearSelected();
		foreach toDoTask in item.allToDoTasksToDo do
			intArray.add(toDoTask.toDoTaskDesc.code);
		endforeach;
		self.myAssistant.setListTableToDoTasks(self.lstToDoTasks, intArray);
		self.lstToDo.hasLostFocus(self.lstToDo);
		
		txtDescription.setValue(item.description);
		cmbSpecialStow.setForObject(item.getSpecialStow());  //CCMS 1028 par 21746, cnwjo3
		cmbShippingLine.setForObject(item.myShippingLine);   //20 may 2022 navgm20 TFS 53204		// 14.07.2022 navsrk20 53195
		cmbCtryOfOrigin.setForObject(item.myCountryOfOrigin); 	// 16.08.2022 navak20 TFS 54441
 // ### TFS BUG 57332 29MAR2023 NAVAB1		cmbInvContractID.setForObject(item.myContract);//21.02.2023 navtnr20 TFS CR 55648 Task 55663
		if item.myContract &lt;&gt; null then		//28.03.2023 navtnr20 TFS 57332
			self.cmbInvContractID.getEmbeddedControl.ComboBox.listIndex := self.cmbInvContractID.addItemObject(item.myContract.contractId,item.myContract);	
		endif;
		// special lift
		create strArray transient;
		strArray.clear;
		foreach spLift in item.allSpecialLifts do
			strArray.add(spLift.code);
		endforeach;
		self.myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
		self.txtSpecialLift.text := self.truncateDisplayString(self.lstSpecialLift.getSelectedString(CM_SpecialLift::code.name), -1);
		
		if item.isKindOf(CM_Container) then
			chkPreTrip.setValue(item.CM_Container.offsitePreTrip);
			chkCleaned.setValue(item.CM_Container.offsiteCleaned);
		endif;
		txtRemarks.setValue(item.remarks);
		
		cmbFreightFwdr.setForObject(item.myFreightForwarder);
		cmbCustomsAgent.setForObject(item.myCustomsAgent);
		txtHouseBOL.setValue(item.billOfLading);
		txtConsignVoy.setValue(item.consignorVoyageCode);
		txtEquipXchg.setValue(item.eirNumber);
		txtPurchaseOrder.setValue(item.purchaseOrder);
		cmbTransportMode.setForText(app.transModeToString(item.receiptTransportMode));
		txtWagon.setValue(item.wagon);
		txtWagonTrain.setValue(item.getMyNotifiedTrainString);	//04 Nov 2009	NDL Par 21519
		cmbWagonClass.setForObject(item.getMyNotifiedWagonClass);	//12 May 2014	NDL	Par 33615
		cmbBusUnit.setForText(item.companyCode);
		
		if item.isKindOf(CM_Car) then
			chkRadio.setValue(item.CM_Car.hasRadio = CM_Car.HasRadio);
			chkSelfPropelled.setValue(item.CM_Car.selfPropelled);
		endif;
		
		// PAR #23442 Timber specifics
		if item.isKindOf(CM_Timber) then
			self.chkPreSlung.setValue(item.CM_Timber.preSlung);
			self.chkWet.setValue(item.CM_Timber.wet);
		endif;
		
		self.chkDirDel.setValue( item.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102
		self.cmbCustPriority.getEmbeddedControl.ComboBox.listObject := item.myCustomerPriority;
				
	elseif _item.isKindOf(CMGTE_Receival) then
	
		entity := _item.CMGTE_Receival;
		create intArray transient;
		
		self.lstAllStops.clearSelected();
		self.myAssistant.setListTableStopsTables(self.lstAllStops, entity.allStops);
		self.lstStops.hasLostFocus(self.lstStops);
		
		intArray.clear;
		self.lstToDoTasks.clearSelected();
		foreach toDo in entity.allToDoTasks do
			intArray.add(toDo.code);
		endforeach;
		self.myAssistant.setListTableToDoTasks(self.lstToDoTasks, intArray);
		self.lstToDo.hasLostFocus(self.lstToDo);
		
		txtDescription.setValue(entity.description);
		cmbSpecialStow.setForObject(app.myRoot.allSpecialStows[entity.specialStow]);
		
		cmbShippingLine.setForObject(app.myRoot.allShippingLines[entity.shippingLineCode]);   // 20 May 2022 navgm20 TFS 53204
		cmbCtryOfOrigin.setForObject(app.myRoot.allCountries[entity.countryOfOriginCode]); 	// 16.08.2022 navak20 TFS 54441
		banks := entity.companyCode;
	// start 24.02.2023 navtnr20 TFS CR 55648 Task 55663
		if entity.invoiceContractId &lt;&gt; null then
			contractIdStr := entity.invoiceContractId;
			if contractIdStr &lt;&gt; null then
				op := self.cmbOperatorCode.listObject.CM_Operator;
				if op &lt;&gt; null then
					debtor := op.debtor;
					if debtor &lt;&gt; null then
						//bank :=self.cmbBusUnit.getEmbeddedControl.ComboBox.listObject.CM_Bank;
						bank := self.myTerminal.companies[banks];
						myContract := debtor.allInvoiceContracts[bank,contractIdStr];
					endif;
				endif;
			endif;
		endif;
 // ### TFS BUG 57332 29MAR2023 NAVAB1		self.cmbInvContractID.setForObject(myContract);
		if entity.invoiceContractId &lt;&gt; null then		//28.03.2023 navtnr20 TFS 57332
			self.cmbInvContractID.getEmbeddedControl.ComboBox.listIndex := self.cmbInvContractID.addItemObject(entity.invoiceContractId,myContract);	//28.03.2023 navtnr20 TFS 57332
		endif;
		//end 24.02.2023 navtnr20 TFS CR 55648 Task 55663
		// Special Lift
		create strArray transient;
		on Exception do app.handleDeletedObject(exception,spLift,invalid);
		foreach spLift in entity.allSpecialLifts do
			strArray.add(spLift.code);
		endforeach;
		on Exception do null;
		self.myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);		
		self.txtSpecialLift.text := self.truncateDisplayString(self.lstSpecialLift.getSelectedString('code'), -1);
		
		cmbFreightFwdr.setForObject(app.myRoot.allConsigneeConsignors[entity.freightForwarderCode]);
		//cmbCustomsAgent.setForObject(app.myRoot.allCustomsAgents[entity.customsAgentCode]);	// 16/02/2011 cnwmh5 #26961
		txtHouseBOL.setValue(entity.billOfLading);
		txtConsignVoy.setValue(entity.consignorVoyageCode);
		txtEquipXchg.setValue(entity.eirNumber);
		txtPurchaseOrder.setValue(entity.purchaseOrder);      //25/11/2015 cnwma1 PAR #36943
		
		txtShippingRef.setValue(entity.shippingReference);
		cmbBusUnit.setForText(entity.companyCode);
		
		if entity.isKindOf(CMGTE_Car) then
			chkRadio.setValue(entity.CMGTE_Car.hasRadio);
			chkSelfPropelled.setValue(entity.CMGTE_Car.selfPropelled);
		endif;
		
		// PAR #23442 Timber specifics
		if entity.isKindOf(CMGTE_Cargo) then
			self.chkPreSlung.setValue(entity.CMGTE_Cargo.preSlung);
		endif;
		self.chkWet.setValue(entity.wet);
		
		// 16/02/2011 cnwmh5 #26961 - Start
		if entity.customsAgentCode &lt;&gt; null then
			//self.cmbCustomsAgent.setForObject(app.myRoot.allCustomsAgents[entity.customsAgentCode]);													// PAR #37606
			agent := app.myRoot.allCustomsAgents[entity.customsAgentCode];																				// PAR #37606
			if agent.isNotAvailableForEntry then																										// PAR #37606
				self.cmbCustomsAgent.getEmbeddedControl.ComboBox.listIndex := self.cmbCustomsAgent.addItemObject(agent.code &amp; Tab &amp; agent.name, agent);	// PAR #37606
			else																																		// PAR #37606
				self.cmbCustomsAgent.setForObject(agent);																								// PAR #37606
			endif;																																		// PAR #37606
		elseif entity.bookingReference &lt;&gt; null then
			booking := self.myTerminal.allBookingRefsByRef[entity.bookingReference];
			if booking &lt;&gt; null then
				self.cmbCustomsAgent.setForObject(booking.getCustomsAgentObject());	// PAR 26922 - change to use new method
			endif;
		endif;
		// 16/02/2011 cnwmh5 #26961 - End
		
		self.chkDirDel.setValue( entity.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102
		self.cmbCustPriority.getEmbeddedControl.ComboBox.listObject := entity.myCustomerPriority;
		
	elseif _item.isKindOf(CM_TIMaster) then
		master := _item.CM_TIMaster;
		
		// Stops
		create intArray transient;
		foreach stopTable in master.allStopsNew do
			if master.isStopValid(stopTable)  then
				intArray.add(stopTable.id);
			endif;
		endforeach;
		
		//Stops that have been already set on the form.  ie: from a CMGTE_Receival (Prenote)
		foreach obj in self.lstAllStops.allSelectedObjects do
			if obj.isKindOf(CM_StopsTable) then
				stopTable := obj.CM_StopsTable;
				intArray.add(stopTable.id);
			endif;
		endforeach;
		
		self.myAssistant.setListTableStopsTables(self.lstAllStops, intArray);
		self.lstStops.hasLostFocus(self.lstStops);

		
		// Todo tasks
		intArray.clear;
		foreach taskDesc in master.allToDoTaskDesc do
			intArray.add(taskDesc.code);
		endforeach;

		//ToDo tasks that have already been set on form.
		foreach obj in self.lstToDoTasks.allSelectedObjects do
			if obj.isKindOf(CM_ToDoTaskDesc) then
				taskDesc := obj.CM_ToDoTaskDesc;
				intArray.add(taskDesc.code);
			endif;
		endforeach;		
		
		self.myAssistant.setListTableToDoTasks(self.lstToDoTasks, intArray);
		self.lstToDo.hasLostFocus(self.lstToDo);
		
		
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote := _item.CMIF_PreNote;
		create intArray transient;
		
		self.lstAllStops.clearSelected();
		self.myAssistant.setListTableStopsTables(self.lstAllStops, preNote.allStops);
		self.lstStops.hasLostFocus(self.lstStops);
		
		intArray.clear;
		self.lstToDoTasks.clearSelected();
		foreach toDo in preNote.allToDoTasks do
			intArray.add(toDo.code);
		endforeach;
		self.myAssistant.setListTableToDoTasks(self.lstToDoTasks, intArray);
		self.lstToDo.hasLostFocus(self.lstToDo);
		
		txtDescription.setValue(preNote.description);
		cmbSpecialStow.setForObject(app.myRoot.allSpecialStows[preNote.specialStow]);
		
		// Special Lift
		create strArray transient;
		foreach spLift in preNote.allSpecialLifts do
			strArray.add(spLift.code);
		endforeach;
		self.myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);		
		self.txtSpecialLift.text := self.truncateDisplayString(self.lstSpecialLift.getSelectedString('code'), -1);
		
		cmbFreightFwdr.setForObject(app.myRoot.allConsigneeConsignors[preNote.freightForwarderCode]);
		cmbCustomsAgent.setForObject(app.myRoot.allCustomsAgents[preNote.customsAgentCode]);
		txtHouseBOL.setValue(preNote.billOfLading);
		txtConsignVoy.setValue(preNote.consignorVoyageCode);
		txtEquipXchg.setValue(preNote.eirNumber);
		txtPurchaseOrder.setValue(preNote.purchaseOrder);
		cmbBusUnit.setForText(preNote.companyCode);
		txtWagon.setValue(preNote.wagon);
		txtWagonTrain.setValue(preNote.getTrainOfPreNoteWagon);	//04 Nov 2009	NDL Par 21519
		cmbWagonClass.setForObject(preNote.myWagonClass);	//12 May 2014	NDL	Par 33615

		self.chkRadio.setValue(preNote.hasRadio);
		self.chkSelfPropelled.setValue(preNote.selfPropelled);
		
		// PAR #23442 Timber specifics
		self.chkPreSlung.setValue(preNote.preSlung);
		self.chkWet.setValue(preNote.wet);
		
		self.chkDirDel.setValue( preNote.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102
		
		if preNote.myCustomerPriority = null and preNote.customerPriority &lt;&gt; null then
			priority	:= app.myRoot.allCustomerPriorities[preNote.customerPriority];
			self.cmbCustPriority.getEmbeddedControl.ComboBox.listObject := priority;
		else
			self.cmbCustPriority.getEmbeddedControl.ComboBox.listObject := preNote.myCustomerPriority;
		endif;
		
	elseif _item = null then
	
	
	endif;
	
	self.setAdditionalDetailsLabel();
	
epilog
	delete intArray;
	delete strArray;
	delete allStops;
	
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerCargoDetails" id="dfe9e0f5-1b06-4000-afbc-e8c2fba45c5d">
        <updating/>
        <source>setContainerCargoDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/07/2009	cnwdap1	Initial creation
23/10/2009	cnwdap1	PAR #21139 Set colour from tracked item and prenote
29/03/2010	cnwdap1	PAR #23355 Do not carry hazards across to attachments
12/08/2013	cnwdap1	PAR #32123 Use Colour table / text box depending on terminal config
13/09/2013	cnwdap1	PAR #32215 New car attributes
05/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
07/07/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
25/11/2015	cnwma1  PAR #36943 Shipping Reference error during extract
15-06-2022 	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
09/09/2022  navds20  Bug 54615: CUX - Road Gate not retaining pre-noted HAZ info
*/
vars
	brItem		: CM_BRefItemContainer;
	item 		: CM_TrackedItem;
	entity		: CMGTE_Receival;
	strArray	: StringArray;
	str			: String;
	hazard		: CM_Hazard;
	preNote		: CMIF_PreNote;
	entityByType	: CMGTE_ReceivalByType;		// 10/12/2010 cnwmh5 #26556
	hazards		: CM_ObjectSet;					// PAR #36421
	child		: CMGTE_Entity;					// PAR #36421
	hazardsText	: String;						// PAR #36421
	contract : CM_InvoiceContract;
begin
	
	if _item.isKindOf(CM_BRefItemContainer) then
	
		brItem := _item.CM_BRefItemContainer;
		
		chkCleaned.setValue(brItem.clean);
		self.chkPreTrip.setValue(brItem.inspected);
		txtRemarks.setValue(brItem.remarks);
		self.txtMark.setValue(brItem.shippingMarks);
		self.txtMarkNumber.setValue(brItem.markNumber);
		//self.txtColour.setValue(brItem.colour);												// PAR #32123
		self.setColourDetails(brItem.colour);													// PAR #32123
		// PAR #23355 don't carry hazards on to attachment form from booking
		if not self.isAttachmentForm then
			self.lstHazardList.setSelectedFromObject(brItem);
			self.txtHazards.text := self.truncateDisplayString(self.lstHazardList.getSelectedString(), -1);
			if not brItem.allTIHazards.isEmpty then							// PAR #36421
				self.chkIsHazardous.value := true;							// PAR #36421
				self.chkIsHazardous_change(self.chkIsHazardous);			// PAR #36421
			endif;															// PAR #36421
		endif;
		
		self.txtPurchaseOrder.setValue(brItem.purchaseOrder);				// PAR #33193 
		self.txtServiceOrder.setValue(brItem.serviceOrder);				// PAR #33193 
		
	elseif _item.isKindOf(CM_TrackedItem) then
	
		item := _item.CM_TrackedItem;
		
		self.txtAlternativeId.setValue(item.alternativeId);
		self.txtMark.setValue(item.mark);
		self.txtMarkNumber.setValue(item.markNumber);
		if item.isKindOf(CM_BreakBulkGeneric) then
			//self.txtColour.setValue(item.CM_BreakBulkGeneric.colour);							// PAR #32123
			self.setColourDetails(item.CM_BreakBulkGeneric.colour);								// PAR #32123
		elseif item.isKindOf(CM_Car) then													// PAR #32215
			self.setColourDetails(item.CM_Car.colour);										// PAR #32215
		endif;
		txtLocation.setValue(item.getPrimaryLocationId(REAL_MODE));
		txtOpExRelNbr.setValue(item.getOperatorExpReleaseNo);
		txtCustomsExDel.setValue(item.customExportEntryNumber);
		self.cmbShippingLine.setForObject(item.myShippingLine); 	//15-0602022 navtnr20 53204
		self.cmbCtryOfOrigin.setForObject(item.myCountryOfOrigin); 	// 16.08.2022 navak20 TFS 54441
 // ### TFS BUG 57332 29MAR2023 NAVAB1		self.cmbInvContractID.setForObject(item.myContract);	//21.02.2023 navtnr20 TFS CR 55648 Task 55663
		if item.myContract &lt;&gt; null then		//28.03.2023 navtnr20 TFS 57332
			self.cmbInvContractID.getEmbeddedControl.ComboBox.listIndex := self.cmbInvContractID.addItemObject(item.myContract.contractId,item.myContract);	
		endif;
		if item.canSetAvailabilityGrade then
			cmbMTGrade.setForObject(app.myRoot.allAvailabilityGrades[item.getAvailabilityGrade]);
		endif;
	//	if self.isOnshipForm then
	//		self.txtNumItems.setValue(item.quantity);
	//	endif;
		self.setNumItemsValueFormObject(item);	//04 Mar 2014	NDL	Par 33596

		// hazards
		self.lstHazardList.setSelectedFromObject(item);
		self.txtHazards.text := self.truncateDisplayString(self.lstHazardList.getSelectedString(), -1);
		if not item.allTIHazards.isEmpty then								// PAR #36421
			self.chkIsHazardous.value := true;								// PAR #36421
			self.chkIsHazardous_change(self.chkIsHazardous);				// PAR #36421
		endif;																// PAR #36421
		
		self.chkDirDel.setValue( item.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102
		
		self.txtClientRef.setValue( item.clientRef); //cnwrd1 par 23337 20-5-2010
		
		self.txtPurchaseOrder.setValue(item.purchaseOrder);				// PAR #33193 
		self.txtServiceOrder.setValue(item.serviceOrder);				// PAR #33193 
		
		self.lblVehicleBook.caption := self.myProxyTrackedItem.getDisplayStringForAttribute(ETRow_VsBookingSlot,false);	//17 Apr 2013	NDL	Par 31393
		
		// PAR #23442 Timber
		if item.isKindOf(CM_Timber) then
			//self.txtTotalVolume.setValue(item.getMyTotalVolume);								// PAR #31155
			self.tblTotalVolume.setValueDefault(item.getMyTotalVolume.String);					// PAR #31155
		endif;
		
		// PAR #32215 Car														// PAR #32215
		if item.isCar then														// PAR #32215
			self.cmbVehicleMake.setForText(item.CM_Car.make);					// PAR #32215
			self.cmbVehicleModel.setForText(item.CM_Car.model);					// PAR #32215
			self.cmbVehicleType.setForText(item.CM_Car.carType);				// PAR #32215
			self.txtYear.setValue(item.CM_Car.year);							// PAR #32215
			self.txtTracking1.setValue(item.CM_Car.trackingNumber1);			// PAR #32215
			self.txtTracking2.setValue(item.CM_Car.trackingNumber2);			// PAR #32215
			self.txtDocsReceived.setValue(item.CM_Car.docsReceived.Date);		// PAR #32215
			self.txtDocsSent.setValue(item.CM_Car.docsSent.Date);				// PAR #32215
			self.txtDocsCleared.setValue(item.CM_Car.docsCleared.Date);			// PAR #32215
			self.txtDocsReturned.setValue(item.CM_Car.docsReturned.Date);		// PAR #32215
			self.txtDoors.setValue(item.CM_Car.nbrDoors);						// PAR #32215
			self.chkNew.setValue(item.CM_Car.isNew);							// PAR #32215
		endif;																	// PAR #32215
		
	elseif _item.isKindOf(CMGTE_Receival) then
	
		entity := _item.CMGTE_Receival;
		
		if entity.isKindOf(CMGTE_Container) then
			self.chkCleaned.setValue(entity.CMGTE_Container.offsiteCleaned);
			self.chkPreTrip.setValue(entity.CMGTE_Container.offsitePreTrip);
		else
			//epr CCMS 2274 28/5/13 
			self.setNumItemsValueFormObject(entity);	//04 Mar 2014	NDL	Par 33596
		endif;
		
		//epr par 32621 18/10/13
		if entity.canSetAvailabilityGrade then
			self.cmbMTGrade.setForObject(app.myRoot.allAvailableAvailabilityGrades[entity.getAvailabilityGrade]);
		endif;
		
		txtLocation.setValue(entity.yardLocationTxt);
		txtOpExRelNbr.setValue(entity.operatorExportReleaseNumber);
		txtCustomsExDel.setValue(entity.customExportEntryNumber);
		self.cmbShippingLine.setForObject(app.myRoot.allShippingLines[entity.shippingLineCode]); 	//15-06-2022 navtnr20 53204
		self.cmbCtryOfOrigin.setForObject(app.myRoot.allCountries[entity.countryOfOriginCode]); 	// 16.08.2022 navak20 TFS 54441
 // ### TFS BUG 57332 29MAR2023 NAVAB1		self.cmbInvContractID.setForText(entity.invoiceContractId);//21.02.2023 navtnr20 TFS CR 55648 Task 55663
		if entity.invoiceContractId &lt;&gt; null  then	//28.03.2023 navtnr20 TFS 57332
			self.cmbInvContractID.getEmbeddedControl.ComboBox.listIndex := self.cmbInvContractID.addItemObject(entity.invoiceContractId,null);	 // ### TFS BUG 57332 29MAR2023 NAVAB1
		endif;
		txtRemarks.setValue(entity.remarks);
		
		self.txtAlternativeId.setValue(entity.alternativeId);
		self.txtMark.setValue(entity.mark);
		self.txtMarkNumber.setValue(entity.markNumber);
		self.setColourDetails(entity.colour);													// PAR #32123
		
		// hazard details
		if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then		// PAR #36421
			create hazards transient;										// PAR #36421
			foreach child in entity.allChildren do							// PAR #36421
				foreach hazard in child.CMGTE_Receival.allTIHazards do		// PAR #36421
					hazards.add(hazard);									// PAR #36421
				endforeach;													// PAR #36421
			endforeach;														// PAR #36421
			//self.lstHazardList.setSelected(hazards);						// PAR #36421	//09/09/2022 navds20 TFS 54615
			//hazardsText := self.lstHazardList.getSelectedString();		// PAR #36421	//09/09/2022 navds20 TFS 54615
			//self.txtHazards.text := hazardsText;							// PAR #36421	//09/09/2022 navds20 TFS 54615
			self.lstHazardList.setSelectedFromObject(entity);		                                           //09/09/2022 navds20 TFS 54615		
			self.txtHazards.text := self.truncateDisplayString(self.lstHazardList.getSelectedString(), -1);    //09/09/2022 navds20 TFS 54615
		else																// PAR #36421
			self.lstHazardList.setSelectedFromObject(entity);
			self.txtHazards.text := self.truncateDisplayString(self.lstHazardList.getSelectedString(), -1);
		endif;																// PAR #36421
		if not entity.allTIHazards.isEmpty then								// PAR #36421
			self.chkIsHazardous.value := true;								// PAR #36421
			self.chkIsHazardous_change(self.chkIsHazardous);				// PAR #36421
		endif;																// PAR #36421
		
		self.chkDirDel.setValue( entity.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102
		
		self.txtClientRef.setValue( entity.clientRef); //cnwrd1 par 23337 20-5-2010
	
		self.txtPurchaseOrder.setValue(entity.purchaseOrder);				// PAR #33193 
		self.txtServiceOrder.setValue(entity.serviceOrder);				// PAR #33193 
		self.txtShippingRef.setValue(entity.shippingReference);	        //25/11/2015 cnwma1 PAR #36943
		
		// PAR #32215 Car														// PAR #32215
		if entity.isKindOf(CMGTE_Car) then										// PAR #32215
			self.cmbVehicleMake.setForText(entity.CMGTE_Car.make);				// PAR #32215
			self.cmbVehicleModel.setForText(entity.CMGTE_Car.model);			// PAR #32215
			self.cmbVehicleType.setForText(entity.CMGTE_Car.carType);			// PAR #32215
			self.txtYear.setValue(entity.CMGTE_Car.year);						// PAR #32215
			self.txtTracking1.setValue(entity.CMGTE_Car.trackingNumber1);		// PAR #32215
			self.txtTracking2.setValue(entity.CMGTE_Car.trackingNumber2);		// PAR #32215
			self.txtDocsReceived.setValue(entity.CMGTE_Car.docsReceived.Date);	// PAR #32215
			self.txtDocsSent.setValue(entity.CMGTE_Car.docsSent.Date);			// PAR #32215
			self.txtDocsCleared.setValue(entity.CMGTE_Car.docsCleared.Date);	// PAR #32215
			self.txtDocsReturned.setValue(entity.CMGTE_Car.docsReturned.Date);	// PAR #32215
			self.txtDoors.setValue(entity.CMGTE_Car.nbrDoors);					// PAR #32215
			self.chkNew.setValue(entity.CMGTE_Car.isNew);						// PAR #32215
		endif;																	// PAR #32215
		
		//epr par 31845 add damage to receival form
		self.myPxyGTEEntity.allDamageInstancesByPos.copy(self.allDamageInstancesByPos);
		self.setDamageText();
		
		self.myPxyGTEEntity.allAttachments.copy(self.allPhotos);
		self.setPhotosText();
	// 10/12/2010 cnwmh5 #26556 - Start
	elseif _item.isKindOf(CMGTE_ReceivalByType) then
		
		entityByType := _item.CMGTE_ReceivalByType;
		
		txtLocation.setValue(entityByType.yardLocationTxt);
		if entityByType.myReceivalInfo.myBookingItem &lt;&gt; null then
			txtRemarks.setValue(entityByType.myReceivalInfo.myBookingItem.remarks);
			//self.txtColour.setValue(entityByType.myReceivalInfo.myBookingItem.colour);		// PAR #32123
			self.setColourDetails(entityByType.myReceivalInfo.myBookingItem.colour);			// PAR #32123
			// hazard details
			self.lstHazardList.setSelectedFromObject(entityByType.myReceivalInfo.myBookingItem);
			self.txtHazards.text := self.truncateDisplayString(self.lstHazardList.getSelectedString(), -1);
			if not entityByType.myReceivalInfo.myBookingItem.allTIHazards.isEmpty then	// PAR #36421
				self.chkIsHazardous.value := true;										// PAR #36421
				self.chkIsHazardous_change(self.chkIsHazardous);						// PAR #36421
			endif;																		// PAR #36421
			
			if entityByType.myReceivalInfo.myBookingItem.myBookingReference &lt;&gt; null then
				self.chkDirDel.setValue( entityByType.myReceivalInfo.myBookingItem.myBookingReference.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102
			endif;
			
		endif;
		// 10/12/2010 cnwmh5 #26556 - End
		
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote := _item.CMIF_PreNote;

		chkCleaned.setValue(preNote.offsiteCleaned);
		chkPreTrip.setValue(preNote.offsitePreTrip);
		self.cmbMTGrade.setForObject(app.myRoot.allAvailableAvailabilityGrades[preNote.availabilityGrade]);
		
		txtLocation.setValue(preNote.yardLocationTxt);
		txtOpExRelNbr.setValue(preNote.operatorExportReleaseNumber);
		txtCustomsExDel.setValue(preNote.customExportEntryNumber);
		self.cmbShippingLine.setForObject(app.myRoot.allShippingLines[preNote.shippingLineCode]); 	//15-06-2022	navtnr20 53204
		self.cmbCtryOfOrigin.setForObject(app.myRoot.allCountries[preNote.countryOfOriginCode]); 	// 16.08.2022 navak20 TFS 54441
		self.cmbInvContractID.setForText(preNote.contractId);//21.02.2023 navtnr20 TFS CR 55648 Task 55663
		txtRemarks.setValue(preNote.remarks);
		
		self.txtAlternativeId.setValue(preNote.alternativeId);
		self.txtMark.setValue(preNote.mark);
		self.txtMarkNumber.setValue(preNote.markNumber);
		//self.txtColour.setValue(preNote.colour);												// PAR #32123
		self.setColourDetails(preNote.colour);													// PAR #32123
		
		// hazard details
		self.lstHazardList.setSelectedFromObject(preNote);
		self.txtHazards.text := self.truncateDisplayString(self.lstHazardList.getSelectedString(), -1);
		if not preNote.allTIHazards.isEmpty then							// PAR #36421
			self.chkIsHazardous.value := true;								// PAR #36421
			self.chkIsHazardous_change(self.chkIsHazardous);				// PAR #36421
		endif;																// PAR #36421
		
		self.chkDirDel.setValue( preNote.directDelivery );	//28 Jan 2013	NDL	CCMS 1299		Par 31102

		self.txtPurchaseOrder.setValue(preNote.purchaseOrder);				// PAR #33193 
		self.txtServiceOrder.setValue(preNote.serviceOrder);				// PAR #33193 
		self.txtShippingRef.setValue(preNote.shippingReference);				//25/11/2015 cnwma1 PAR #36943
		
		
	endif;
		
epilog
	delete strArray;
	delete hazards;															// PAR #36421
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerMainDetails" id="0398df38-5e79-48e2-be6a-4aa89f5604b7">
        <updating/>
        <source>setContainerMainDetails(_item : Object) updating, protected;
/*
Date		Who		Reason
19/07/2009	cnwdap1	Initial creation
09/10/2009	cnwdap1	PAR #21159 Prevent booking item picker from showing when receipting a prenoted item from a booking
12/10/2009	cnwdap1	PAR #20814 New Ent Def for reefers via the Rail Pre Note form
28/10/2009	cnwdap1	PAR #20964 New parameter to loadSubCargoCommodityCombos
23/11/2009	cnwdap1	#21658 For Trailer and Vehicle Cargo Types, show length/width/height dimensions fields
17/12/2009	cnwdap1	PAR #21586 Save entered booking reference even if we don't have a booking ref object
12/03/2010	cnwdap1	PAR #23164 Correct re-displaying a CMIF_PreNote transient attachment object
26/03/2010	cnwcs5	pAR 23338 Display trailer type and generator type from booking items
18/05/2010	cnwcs5	par 24178	Display correct default weight when setting from TI Master
19/08/2013	cnwdap1	PAR #32289 Check (totalWeight - tareWeight) &gt; 0 before setting cargo weight field
30/08/2013	cnwdap1	PAR #32371 Convert total weight and total volume to subcargo type measurement type
08/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
15/05/2014	cnwdap1	PAR #34157 Avoid Error 4 created when a booking is deleted with a CMGTE_Receival still pointing to it
15/03/2016	cnwdap1	PAR #37606 "Not available for entry" iso types
28/07/2016	cnwdap1	TFS #2384 Correct attachment handling when "Use Hazardous Child Form" config option is set 
							  - only put non-hazardous children in the attachments combo if this config is set
05/01/2017	cnwdap1	TFS 2867 Show Cargo id from booking item 
3/05/2018 	JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
21 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
24/07/2023	jlizm1	TFS 57333 Empty becoming full when editing road gate receivals
02/10/2023  navma1	Bug 60530: MTN - Cargo Group will be cleared when using Receive Cargo Form
15/03/2024	navdap1	TFS 62961 LNX - Export Booking number disappears after Gate in
02/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/
vars
	brItem			: CM_BookingRefItem;
	bookingRef		: CM_BookingRef;
	item			: CM_TrackedItem;
	entity			: CMGTE_Receival;
	isoType			: CM_ISOType;
	commodity		: CM_Commodity;
	commodityStr	: String;
	attachedItem	: CM_TrackedItem;
	attachedEntity	: CMGTE_Entity;
	preNote			: CMIF_PreNote;
	cargoType		: CM_CargoType;
	attachedPreNote	: CMIF_TIObject;
	idx				: Integer;
	master			: CM_TIMaster;
	product			: CM_Product;
	receivalInfo	: CM_ReceivalInfo;	
	tareWeight		: Decimal [14,4];	
	cargoGroup		: CM_CargoGroup;
	useHazDetails	: Boolean;
	root			: CM_Root;
	bookingRefItem  : CM_BookingRefItem;
	contentsCargoType : CM_CargoType;		// MTN-36141
begin
	
	root			:= app.myRoot;															//02.10.2023 navma1 #60530									
	useHazDetails   := self.myTerminal.getConfig(UseDetailedHazEntry).Boolean;				//02.10.2023 navma1 #60530
	
	if _item.isKindOf(CM_BRefItemContainer) then 
		brItem 		:= _item.CM_BRefItemContainer;
		bookingRef	:= brItem.myBookingReference;
		isoType		:= brItem.myISOType;
		
		self.txtBookingRef.setValue(bookingRef.bookingReference);
		self.cmbBRItem.listCollection(bookingRef.allBookingRefItems, true, 1);
		self.cmbBRItem.setForObject(brItem);
		self.cmbType.setForObject(brItem.myCargoType);
		
		// populate product type combo and commodity
		self.loadSubCargoCommodityCombos(brItem.myCargoType, self.existingCargoType, self.cmbSubCargo, self.cmbCommodity);
		self.loadGeneratorAndTrailerCombos(brItem.myCargoType);
		
		cargoType := brItem.myCargoType;

		self.cmbCommodity.setForObject(brItem.getMyCommodity);

		self.cmbISOType.setForObject(isoType);
		// for bookings created with an iso type that is not not available for entry, add an entry in													// PAR #37606
		if isoType &lt;&gt; null and isoType.isNotAvailableForEntry then																						// PAR #37606
			self.cmbISOType.getEmbeddedControl.ComboBox.listIndex := self.cmbISOType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
		endif;																																			// PAR #37606
		self.doISOTypeChange();						//+cnwml2 PAR24904
		
		if brItem.weight &lt;&gt; null then
			if brItem.quantity = 1 then																	//+cnwml2	PAR18498
				self.tblTotalWeight.setValueDefault(brItem.weight.asStringJMT);	//25 Oct 2013	NDL	Par 32720			
			endif;
			if brItem.myCargoType.isBulkByWeight then																			// PAR #33606				
				self.tblTotalWeight.setValues(brItem.getWeightDisplay);	// PAR #33606
			endif;																											// PAR #33606
		else
			product := self.cmbSubCargo.getObject.CM_Product;

			if product &lt;&gt; null and product.isMyWeightViewable then
				if product.getMyWeight &lt;&gt; null then 
					self.tblTotalWeight.setValueDefault(product.getMyWeight.getDisplayValueString);		// PAR #31155
				endif;
			endif;
		endif;
		//24/01/2011 cnwdz2 25149
		//if (brItem.id &lt; null) then						// TFS 2867
		if (brItem.id &lt;&gt; null) then							// TFS 2867
			self.txtCargoID.setValue(brItem.id);
		endif;
		
		// General cargo specific
		self.cmbSubCargo.setForObject(brItem.myProduct);

		// PAR 23338 26/03/2010 cnwcs5 - display trailer type/generator tyep from booking item
		if cargoType &lt;&gt; null and cargoType.isTrailer then
			self.cmbTrailerType.setForObject(brItem.myTrailerType);
		elseif cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Generator then
			self.cmbGeneratorType.setForObject(brItem.myGeneratorType);
		endif;

		self.tblTotalVolume.setValueDefault(brItem.volume.asStringJMT);									// PAR #31155
		if brItem.myCargoType.isBulkMulti then																				// PAR #33606
			self.tblTotalVolume.setValues(brItem.getWeightDisplay);		// PAR #33606
		endif;	
		
		/*
		When using pin number of booking 
		02.10.2023 navma1
		*/
		if self.txtCargoGroupID.getString() = null then
			if  app.isCargoGroupEnabled and self.myTI &lt;&gt; null then
				cargoGroup := self.myTI.myCargoGroup;
				if cargoGroup &lt;&gt; null then
					self.txtCargoGroupID.setValue(cargoGroup.id);
					self.txtCargoGroupID.userObject := cargoGroup;
				endif;
			endif;
		endif;
	elseif _item.isKindOf(CM_TrackedItem) then
		
		item 			:= _item.CM_TrackedItem;
		isoType			:= item.getISOTypeObject;
		commodity		:= root.allCommodities[item.commodity];
		
		if item.myBookingRef &lt;&gt; null then
			self.txtBookingRef.setValue(item.myBookingRef.bookingReference);
			self.cmbBRItem.listCollection(item.myBookingRef.allBookingRefItems, true, 0);
			self.cmbBRItem.setForObject(item.myBookingRefItem);
			
			self.myBookingRefItem := item.myBookingRefItem;	// PAR#21159 to stop picker showing
			
		elseif item.bookingReference &lt;&gt; null then
			self.txtBookingRef.setValue(item.bookingReference);
		endif;
		
		// cnwjre1 CCMS 1071 General Cargo, show BOL details, quantity
		if item.myReceivalBOL &lt;&gt; null then
			self.txtBOLNumber.CMUI_FieldTextBox.setValue(item.myReceivalBOL.number);
			self.doLoadBOLItems(self.myBOLDtl);
		endif;
		if self.isOnshipForm then
			self.setNumItemsValueFormObject(item);	//04 Mar 2014	NDL	Par 33596
		endif;
		
		self.cmbType.setForObject(item.myCargoType);
		// populate product type combo and commodity
		self.loadSubCargoCommodityCombos(item.myCargoType, self.existingCargoType, self.cmbSubCargo, self.cmbCommodity);
		self.cmbSubCargo.setForObject(item.myProduct);
		self.loadGeneratorAndTrailerCombos(root.allCargoTypesById[item.cargoType]);
		
		cargoType := item.myCargoType;

		self.cmbCommodity.setForObject(commodity);
		self.txtCargoID.setValue(item.id);
		self.cmbISOType.setForObject(isoType);

		if item.myCargoType.useTareCargoWeight then																//Bug 38457
			self.tblTareWeight.setValueDefault(item.weightTare.asStringJMT);									//25 Oct 2013	NDL	Par 32720
				
			if item.weightCargo &lt;&gt; null then
				self.tblNettWeight.setValueDefault(item.weightCargo.asStringJMT);								//25 Oct 2013	NDL	Par 32720
			else
				// work out what the cargo weight is based on the total weight and the tare weight
				if (item.totalWeight - item.getTareWeight) &gt; 0 then												// PAR #32289
					self.tblNettWeight.setValueDefault((item.totalWeight - item.getTareWeight).asStringJMT);	//25 Oct 2013	NDL	Par 32720
				endif;																							// PAR #32289
			endif;
		endif;																									//Bug 38457		
		//epr par 34935 26/9/14 refactoring
		self.tblTotalWeight.setValues(item.getDefaultTotalWeightDisplay);
		self.tblTotalVolume.setValues(item.getDefaultTotalVolumeDisplay);
		
		// PAR #32371
		self.cmbSubTerminal.setForObject(item.mySubTerminal);	
		//+cnwml2 MSL CCMS 1019
		//29 Jul 2013	NDL	Par 31763
		self.dateExpArrival.setValue(item.getExpectedArrivalDate);
		self.timeExpArrival.setValue(item.getExpectedArrivalTime);
		
		if item.isKindOf(CM_TILC) then
			self.cmbTrailerType.setForObject(item.CM_TILC.myTILCType);
		elseif item.isKindOf(CM_Generator) then 
			self.cmbGeneratorType.setForObject(item.CM_Generator.myGeneratorType);
		endif;
		
		self.purgeTransientAttachments();	//10 Oct 2012	NDL	Par 30503
		foreach attachedItem in item.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			self.allAttachments.add(attachedItem);
			if useHazDetails 																// TFS #2384	//02.10.2023 navma1 #60530
			and not attachedItem.allTIHazards.isEmpty then									// TFS #2384
				continue;																	// TFS #2384
			endif;																			// TFS #2384
			idx := self.cmbAttachments.addItem(attachedItem.id);
			self.cmbAttachments.itemObject[idx] := attachedItem;		
		endforeach;
		
		if  app.isCargoGroupEnabled and item.myCargoGroup &lt;&gt; null then
			//jlier1 TFS 53515 30/5/22
			self.txtCargoGroupID.setValue(item.myCargoGroup.id);
			self.txtCargoGroupID.userObject:=item.myCargoGroup;
		endif;
		
		// MTN-36141 show cargo type for contents and cargo sub type
		if isoType &lt;&gt; null and isoType.isRotatable() then
			contentsCargoType := item.getCargoTypeForContents;
			self.cmbContentsCargoType.setForObject(contentsCargoType);
			self.cmbContentsCargoType_change(self.cmbContentsCargoType);
			self.cmbProdType.setForObject(item.myProduct);
			self.cmbCommodity.setForObject(commodity);
		endif;
	
	elseif _item.isKindOf(CMGTE_Receival) then
		
		entity 			:= _item.CMGTE_Receival;
		
		// For checking pre-note changes
		self.myTI 	:= entity.myTrackedItem;
		
		if self.myTI &lt;&gt; null then 
			self.tiPrenoteEdition := self.myTI.edition;
		endif;
		
		if entity.isKindOf(CMGTE_Container) then
			isoType		:= root.allISOTypes[entity.CMGTE_Container.isoType];
		elseif entity.isKindOf(CMGTE_Machinery) then //epr par 34376 11/9/14
			isoType		:= root.allISOTypes[entity.CMGTE_Machinery.isoType];
		endif;

		commodity	:= root.allCommodities[entity.commodity];
		
		if commodity = null and entity.jobType = CMGTE_Entity.JobType_EmptyIN then	// TFS 57333
			commodityStr := self.myTerminal.getDefaultEmptyCommodity();
			commodity	 := root.allCommodities[commodityStr];
		endif;
		
		bookingRefItem := entity.myBookingRefItem;
		if bookingRefItem &lt;&gt; null and app.isValidObject(bookingRefItem) then			// PAR #34157
			txtBookingRef.setValue(bookingRefItem.myBookingReference.bookingReference);
			cmbBRItem.listCollection(bookingRefItem.myBookingReference.allBookingRefItems, true, 0);
			cmbBRItem.setForObject(bookingRefItem);
			
			self.myBookingRefItem := bookingRefItem;
		else														// PAR #21586	// TFS 62961 this else got accidentally deleted
			if entity.bookingReference &lt;&gt; null then					// PAR #21586
				txtBookingRef.setValue(entity.bookingReference);	// PAR #21586
			endif;													// PAR #21586
		endif;
		
		cmbType.setForText(entity.getCargoTypeDescription);
		cargoType := root.allCargoTypesById[entity.cargoType];											// PAR #32371
		cmbType.setForObject(cargoType);																// PAR #32371
		
		// populate product type combo and commodity
		self.loadSubCargoCommodityCombos(cargoType, self.existingCargoType, self.cmbSubCargo, self.cmbCommodity);											// PAR #32371
		self.cmbSubCargo.setForObject(entity.myProduct);
		

		self.loadGeneratorAndTrailerCombos(cargoType); 													// PAR #32371
		
		cargoType := entity.getMyCargoType();

		cmbCommodity.setForObject(commodity);
		txtCargoID.setValue(entity.id);
		//jlier1 TFS 26/5/22
		if app.isCargoGroupEnabled and entity.myCargoGroup &lt;&gt; null then
			self.txtCargoGroupID.setValue(entity.myCargoGroup.id);
			self.txtCargoGroupID.userObject:=entity.myCargoGroup;
		endif;
			
		cmbISOType.setForObject(isoType);
		// for prenotes created with an iso type that is not not available for entry, add an entry in													// PAR #37606
		if isoType &lt;&gt; null and isoType.isNotAvailableForEntry then																						// PAR #37606
			self.cmbISOType.getEmbeddedControl.ComboBox.listIndex := self.cmbISOType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
		endif;																																			// PAR #37606
		

		if cargoType.useTareCargoWeight then																//Bug 38457
			tblTareWeight.setValueDefault(entity.weightTare.asStringJMT);									//25 Oct 2013	NDL	Par 32720
			
			if entity.weightCargo &lt;&gt; null then																//+cnwml2 MSL CCMS 1017
				self.tblNettWeight.setValueDefault(entity.weightCargo.asStringJMT());						//25 Oct 2013	NDL	Par 32720
			else
				if (entity.weightTotal - entity.weightTare) &gt; 0 then										// PAR #32289
					self.tblNettWeight.setValueDefault((entity.weightTotal - entity.weightTare).asStringJMT);	//25 Oct 2013	NDL	Par 32720
				endif;																						// PAR #32289
			endif;
		endif;																							//Bug 38457
		
		product := entity.myProduct;																	// PAR #32371
		if product = null then																			// PAR #32371
			product := cargoType.mySystemProductType;													// PAR #32371
		endif;																							// PAR #32371
		
		//epr par 34935 25/9/14 gets the correct value and units to use from the GTE_Receival object
		self.tblTotalWeight.setValues(entity.getWeightTotalDisplay);
		self.tblTotalVolume.setValues(entity.getTotalVolumeDisplay());
		
		//epr VGM tfs 24/3/19 prenotes can have weight certified we need that value retain as they go through the gate
		self.chkWeightCert.value := entity.isWeightCertified;
		//epr TFS 2011 8/6/16
		self.chkIsWeightCertified.setValue( entity.isWeightCertified);

		
		//23 Aug 2017	NDL	TFS 5803
		self.setWeightByAuthPerson( entity.weightCertifiedReference, entity.weightCertifiedName );
		
		cmbSubTerminal.setForObject(self.myTerminal.allSubTerminals[entity.subTerminalCode]);
		
		if entity.isKindOf(CMGTE_TILC) then
			self.cmbTrailerType.setForObject(entity.CMGTE_TILC.myTILCType); 
			
		elseif entity.isKindOf(CMGTE_Generator) then
			self.cmbGeneratorType.setForObject(entity.CMGTE_Generator.myGeneratorType);
		endif;

		//self.allAttachments.purge;
		self.purgeTransientAttachments();	//10 Oct 2012	NDL	Par 30503
		
		if self.myPxyGTEEntity &lt;&gt; null then	// 23 May 2011	NDL	Par 27599
		
			if not self.myPxyGTEEntity.allChildren.isEmpty then
				foreach attachedEntity in self.myPxyGTEEntity.allChildren do
					self.allAttachments.add(attachedEntity);
					if attachedEntity.isKindOf(CMGTE_Receival) then							// TFS #2384
						if useHazDetails 													// TFS #2384	//02.10.2023 navma1 #60530	
						and not attachedEntity.CMGTE_Receival.allTIHazards.isEmpty then		// TFS #2384
							continue;														// TFS #2384
						endif;																// TFS #2384
					endif;																	// TFS #2384
					idx := self.cmbAttachments.addItem(attachedEntity.getID);
					self.cmbAttachments.itemObject[idx] := attachedEntity;
				endforeach;
			endif;
		
		endif;
		
		// MTN-36141 show cargo type for contents and cargo sub type
		if isoType &lt;&gt; null and isoType.isRotatable() then
			contentsCargoType := app.myRoot.allCargoTypesById[entity.cargoTypeContents];
			self.cmbContentsCargoType.setForObject(contentsCargoType);
			self.cmbContentsCargoType_change(self.cmbContentsCargoType);
			self.cmbProdType.setForObject(entity.myProduct);
			self.cmbCommodity.setForObject(commodity);
		endif;
		
	elseif _item.isKindOf(CMGTE_ReceivalByType) then					// cnwjk3 ccms 1071 19/02/10
		receivalInfo := _item.CMGTE_ReceivalByType.myReceivalInfo;
		commodity 	 := root.allCommodities[receivalInfo.commodity];
		self.cmbCommodity.setForObject(commodity);
		
		self.cmbOperatorCode.setObject(root.allOperators[_item.CMGTE_ReceivalByType.operatorCode]);
		
		self.setNumItemsValueFormObject(receivalInfo);	//04 Mar 2014	NDL	Par 33596
		
		if receivalInfo.myBookingItem &lt;&gt; null then
			txtBookingRef.setValue(receivalInfo.myBookingItem.myBookingReference.bookingReference);
			cmbBRItem.listCollection(receivalInfo.myBookingItem.myBookingReference.allBookingRefItems, true, 0);
			cmbBRItem.setForObject(receivalInfo.myBookingItem);
			self.myBookingRefItem := receivalInfo.myBookingItem;
		endif;
		
		// populate product type combo and commodity
		if receivalInfo.myCargoType &lt;&gt; null then
			cmbType.setForText(receivalInfo.myCargoType.description);
			cmbType.setForObject(receivalInfo.myCargoType);
			self.loadSubCargoCommodityCombos(receivalInfo.myCargoType, self.existingCargoType, self.cmbSubCargo, self.cmbCommodity);
			self.cmbSubCargo.setForObject(receivalInfo.myCargoSubtype);
			self.loadGeneratorAndTrailerCombos(receivalInfo.myCargoType);
			if receivalInfo.myBookingItem &lt;&gt; null and receivalInfo.myCargoType.id = TI_CargoType_Generator then     // 10/12/2010 cnwmh5 #26556
				cmbGeneratorType.setForText(receivalInfo.myBookingItem.myGeneratorType.description);
			endif;
		endif;
		
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote := _item.CMIF_PreNote;
		
		isoType		:= root.allISOTypes[preNote.isoType];
		commodity	:= root.allCommodities[preNote.commodity];
		
		if preNote.myBookingRefItem &lt;&gt; null then
			bookingRef := preNote.myBookingRefItem.myBookingReference;
			txtBookingRef.setValue(bookingRef.bookingReference);
			cmbBRItem.listCollection(bookingRef.allBookingRefItems, true, 0);
			cmbBRItem.setForObject(preNote.myBookingRefItem);
			// PAR #23164 suppress the "booking item selection" popup
			self.myBookingRefItem := preNote.myBookingRefItem;
		else														// PAR #21586
			if preNote.bookingReference &lt;&gt; null then				// PAR #21586
				txtBookingRef.setValue(preNote.bookingReference);	// PAR #21586
			endif;													// PAR #21586
		endif;
		
		cargoType := root.allCargoTypesById[preNote.cargoType];
		cmbType.setForObject(cargoType);
		// populate product type combo and commodity
		self.loadSubCargoCommodityCombos(cargoType, self.existingCargoType, self.cmbSubCargo, self.cmbCommodity);
		self.cmbSubCargo.setForObject(preNote.myProduct);
		self.loadGeneratorAndTrailerCombos(root.allCargoTypesById[preNote.cargoType]);
		
		if  app.isCargoGroupEnabled then
			//jlier1 TFS 53515 30/5/22
			self.txtCargoGroupID.setValue(preNote.cargoGroupId);
		endif;
		
		cmbCommodity.setForObject(commodity);
		txtCargoID.setValue(preNote.id);
		cmbISOType.setForObject(isoType);

		tblNettWeight.setValueDefault(preNote.weightTotal.asStringJMT);	//25 Oct 2013	NDL	Par 32720

		self.tblTotalVolume.setValueDefault(preNote.volumeTotal.asStringJMT);							// PAR #31155
		cmbSubTerminal.setForObject(preNote.mySubTerminal);
		
		self.cmbTrailerType.setForObject(root.allTILCTypes[null, preNote.trailerType]);
		self.cmbGeneratorType.setForObject(preNote.myGeneratorType);
		
		// MTN-36141 show cargo type for contents and cargo sub type
		if isoType &lt;&gt; null and isoType.isRotatable() then
			contentsCargoType := app.myRoot.allCargoTypesById[preNote.cargoTypeContents];
			self.cmbContentsCargoType.setForObject(contentsCargoType);
			self.cmbContentsCargoType_change(self.cmbContentsCargoType);
			self.cmbProdType.setForObject(preNote.myProduct);
			self.cmbCommodity.setForObject(commodity);
		endif;
		
		//self.allAttachments.purge;
		self.purgeTransientAttachments();	//10 Oct 2012	NDL	Par 30503
		
		foreach attachedPreNote in preNote.allSubItems do
			self.allAttachments.add(attachedPreNote);
			if attachedPreNote.isKindOf(CMIF_PreNote) then									// TFS #2384
				if useHazDetails 															// TFS #2384	//02.10.2023 navma1 #60530
				and not attachedPreNote.CMIF_PreNote.allTIHazards.isEmpty then				// TFS #2384
					continue;																// TFS #2384
				endif;																		// TFS #2384
			endif;																			// TFS #2384
			idx := self.cmbAttachments.addItem(attachedPreNote.getID);
			self.cmbAttachments.itemObject[idx] := attachedPreNote;
		endforeach;
		
	elseif _item.isKindOf(CM_TIMaster) then
		master 		:= _item.CM_TIMaster;
		tareWeight  := master.getTareWeight;									// par 24178 cnwcs5 18/05/2010
		self.tblTareWeight.setValueDefault(tareWeight.asStringJMT());			//25 Oct 2013	NDL	Par 32720

		if _item.isKindOf(CM_TIMasterContainer) then
			isoType	:= root.allISOTypes[master.CM_TIMasterContainer.isoType];
			if self.myAssistant.validateMasterISOType(isoType, self.cmbISOType.getObject().CM_ISOType) = MsgBox_Return_OK then
				self.cmbISOType.setForObject(isoType);
			endif;
			// for empties if we are setting values from TIMaster then the totalWeight and tareWeight
			// should be the same
			commodity := self.cmbCommodity.getObject.CM_Commodity;			// par 24178 cnwcs5 18/05/2010
		
			if commodity &lt;&gt; null and commodity.code = "MT" then				// par 24178 cnwcs5 18/05/2010
				// total weight is the same as tare weight for any empty
				self.tblTotalWeight.setValueDefault(tareWeight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
			endif;

			if _item.CM_TIMasterContainer.allTIMasterAttachees.isNotEmpty() and root.getConfig(AutoLinkRefTraGen).Boolean then // --&gt; TFS 46767
				idx := self.cmbAttachments.addItem(_item.CM_TIMasterContainer.allTIMasterAttachees.first.id); // 31/10/2019 - enable autocreation for 100
				self.cmbAttachments.itemObject[idx] := _item.CM_TIMasterContainer.allTIMasterAttachees.first;
				self.cmbAttachments.setIndex(idx);
			endif; // &lt;-- TFS 46767

			cargoType := root.allCargoTypesById[TI_CargoType_Container];					//+cnwml2 PAR21658
		elseif _item.isKindOf(CM_TIMasterTILC) then
			// Set trailer type 
			if self.myAssistant.validateMasterTILCType(master.CM_TIMasterTILC.myTILCType, cmbTrailerType.getObject().CM_TILCType) = MsgBox_Return_OK then
				self.cmbTrailerType.setForObject(master.CM_TIMasterTILC.myTILCType);
			endif;
			cargoType := root.allCargoTypesById[TI_CargoType_Chassis];					//+cnwml2 PAR21658
		elseif _item.isKindOf(CM_TIMasterGenerator) then
			// Set generator type 
			if self.myAssistant.validateMasterGeneratorType(master.CM_TIMasterGenerator.myGeneratorType, cmbGeneratorType.getObject().CM_GeneratorType) = MsgBox_Return_OK then
				self.cmbGeneratorType.setForObject(master.CM_TIMasterGenerator.myGeneratorType);
			endif;
			cargoType := root.allCargoTypesById[TI_CargoType_Generator];					//+cnwml2 PAR21658
		endif;
	endif;
	
	if _item &lt;&gt; null then
		self.onCargoTypeChange();
		//08 May 2018	NDL	TFS 37795
		if self.myProxyTrackedItem &lt;&gt; null then
			if _item.isKindOf(CMGTE_Receival) and self.myTI &lt;&gt; null then
				self.myProxyTrackedItem.setRemarksAdditionals( self.myTI.remarksAdditional1, self.myTI.remarksAdditional2 );
			endif;
		endif;
	endif;
	
	// check if we're a reefer or not
	if isoType &lt;&gt; null and isoType.isReefer then
		if self.currentEntTableDef = ETDef_ContainerFull then
			self.initFieldsForEntDefName(ETDef_ContainerFullReefer, false);
		elseif self.currentEntTableDef = ETDef_RailPreNote then				// PAR #20814
			self.initFieldsForEntDefName(ETDef_RailPreNoteReefer, false);	// PAR #20814
		endif;
	endif;
	
	// pAR #21658 if we're a vehicle or trailer, open the dimensions section
	if cargoType &lt;&gt; null and cargoType.productType.isOneOf(ProductType_Trailer, ProductType_Vehicle) then	// cnwjk3 ccms 1071 19/02/10
		if _item.isKindOf(CM_BreakBulkGeneric) or _item.isKindOf(CMIF_PreNote) or _item.isKindOf(CM_TILC) or _item.isKindOf(CM_Car) then
			self.doOpenCloseDimensionsSection;
		endif;
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerOverDimDetails" id="808d31c4-5004-41e1-a155-5135eb9afd92">
        <updating/>
        <source>setContainerOverDimDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/07/2009	cnwdap1	Initial creation
02/11/2009	cnwdap1	CCMS MES 1017 Tidy up handling of OverDimensions form
						Don't call _change event here, as this opens the form and if we're editing an existing item, the 
						the overdimensinos form appears before the main form does
28/01/2011	cnwdap1	PAR #26769 Allow for over dmensions from booking items
//04/07/2018	jlgrh7 TFS #39209 	AAT - FW: OTMU5005854
*/
vars
	brItem	: CM_BRefItemContainer;
	item,gateContainer 	: CM_Container;			//+TFS39209
	entity	: CMGTE_Container;
	preNote	: CMIF_PreNote;
begin
	if _item.isKindOf(CM_Container) then
	
		item := _item.CM_Container;

		chkIsOverDim.value := item.isOverDimensions;
		//chkIsOverDim_change(chkIsOverDim);	// CCMS 1017
		self.setOverDimensionDetails(item.overLengthFront, item.overLengthRear, item.overWidthLeft, item.overWidthRight, item.height);
		
	elseif _item.isKindOf(CMGTE_Container) then
	
		entity := _item.CMGTE_Container;
		
		chkIsOverDim.value := entity.isOverDimensions;
		//chkIsOverDim_change(chkIsOverDim);	// CCMS 1017
		//self.setOverDimensionDetails(entity.dimLenFront, entity.dimLenRear, entity.dimWidthLeft, entity.dimWidthRight, entity.height);			//-TFS
		gateContainer := entity.getContainer();				//+TFS39209
		if gateContainer &lt;&gt; null then
			self.setOverDimensionDetails(entity.getContainer.overLengthFront , entity.getContainer.overLengthRear, entity.getContainer.overWidthLeft, entity.getContainer.overWidthRight, entity.getContainer.overHeight);
		endif;
		
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote := _item.CMIF_PreNote;
		
		chkIsOverDim.value := preNote.overLengthFront &lt;&gt; null or preNote.overLengthRear &lt;&gt; null or preNote.overWidthLeft &lt;&gt; null or preNote.overWidthRight &lt;&gt; null or preNote.overHeight &lt;&gt; null;
		//chkIsOverDim_change(chkIsOverDim);	// CCMS 1017
		self.setOverDimensionDetails(preNote.overLengthFront, preNote.overLengthRear, preNote.overWidthLeft, preNote.overWidthRight, preNote.overHeight);
		
	// PAR #26769 start
	elseif _item.isKindOf(CM_BRefItemContainer) then
	
		brItem := _item.CM_BRefItemContainer;
		
		chkIsOverDim.value := brItem.length &lt;&gt; null or brItem.width &lt;&gt; null or brItem.height &lt;&gt; null;
		self.setOverDimensionDetails(brItem.length, null, brItem.width, null, brItem.height);
	// PAR #26769 end
	
	endif;
	
	// CCMS 1017
	if self.chkIsOverDim.value then
		self.btnIsOverDim.enabled := true;
	else
		self.btnIsOverDim.enabled := false;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerReeferDetails" id="9a210a23-276e-4bda-a9d4-a876ee97487f">
        <updating/>
        <source>setContainerReeferDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/07/2009	cnwdap1	Initial creation
13/10/2009	cnwdap1	PAR #20856 Correct redisplay of cooling and voltage types for tracked item
24/03/2010	cnwdap1	PAR #22938 Allow for other CM_TrackedItem types, not just BreakBulkGeneric 
								and other CMGTE_Entity types, not just CMGTE_Container
16/01/2013	cnwdap1	PAR #31018 CCMS POL 2223 Added in transit on power attributes
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements. 
					Also display temps in F if operator wants them (some temps were being done, but not all)
10/02/2015  cnwma1  PAR #35651  Text Exceed Error 14079
20/02/2015	cnwdap1	PAR #35672 Rejig carriage temp stuff to get temperatures displaying correctly in Fahrenheit
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
4/10/2016   cnwns1  TFS 2755:Time saved incorrectly - multi-timezone issue
15 Mar 2017 cnwer1	TFS 3581 added is externally monitored - removed large chunk of code for containers will fall into trackeditem code block
*/
vars
	brItem			: CM_BRefItemContainer;
	ti				: CM_TrackedItem;		// PAR #22938
	resDetail		: CM_ReserveDetail;
	availGrade		: CM_MTGrade;
	entity			: CMGTE_Receival;		// PAR #22938
	preNote			: CMIF_PreNote;
	masterContainer	: CM_TIMasterContainer;
	op 				: CM_Operator;  //cnwrd1 par 29126 17.2.2012 
	packTSSystem			: TimeStamp;
	packTSLocal				: TimeStamp;
	transitOnPowerTSLocal 	: TimeStamp;
	transitOnPowerTSSystem 	: TimeStamp;
	expiryTsSystem 			: TimeStamp;
begin
	if _item.isKindOf(CM_BRefItemContainer) then
	
		brItem := _item.CM_BRefItemContainer;
		
		if brItem.getTemperature() &lt;&gt;  NULL_TEMPERATURE  then
			if brItem.myBookingReference.myOperator &lt;&gt; null and brItem.myBookingReference.myOperator.displayTempFahrenheit then	// PAR #31155
				self.txtCarriageTemp.setValue(app.temperatureConversion(true, brItem.getTemperature).asStringJMT);				// PAR #31155
			else																												// PAR #31155
				self.txtCarriageTemp.setValue(brItem.getTemperature.asStringJMT);
			endif;																												// PAR #31155
		endif;
		if brItem.getCarbonDioxide() &lt;&gt; NULL_CARBON_DIOXIDE then
			self.txtCO2Percent.setValue(brItem.getCarbonDioxide.asStringJMT);
		endif;
		if brItem.getOxygen() &lt;&gt; NULL_OXYGEN then
			self.txtOxygenPercent.setValue(brItem.getOxygen.asStringJMT);
		endif;
		self.chkCurtainsIn.setValue(brItem.getCurtainsIn());
		if brItem.getHumidity() &lt;&gt; NULL_HUMIDITY then
			self.txtHumidity.setValue(brItem.getHumidity.asStringJMT);
		endif;
		if brItem.getVentilation &lt;&gt; NULL_VENTILATION then
			self.tblVentilation.setValueDefault(brItem.getVentilationAsString);				// PAR #31155
		endif;
		resDetail := brItem.myReserveDetail;
		if resDetail &lt;&gt; null and resDetail.isKindOf(CM_ReserveSelection) then
			if resDetail.CM_ReserveSelection.allAvailabilityGrades.size() &gt; 0 then
				availGrade := app.myRoot.allAvailableAvailabilityGrades[resDetail.CM_ReserveSelection.allAvailabilityGrades.first];
				if availGrade &lt;&gt;  null then
					self.cmbMTGrade.setForObject(availGrade);
				endif;
			endif;	
		endif;	
	elseif _item.isKindOf(CMGTE_Receival) then		// PAR #22938
	
		entity := _item.CMGTE_Receival;				// PAR #22938
		
		if entity.allowableTimeOffPower &lt;&gt; NULL_ALLOWABLE_TIME_OFF_POWER then			//cnwas3 par 26199
			txtTimeOffPower.setValue(entity.allowableTimeOffPower.asStringJMT);
		endif;

		if entity.operatorCode &lt;&gt; null then													//PAR #35651
			op := app.myRoot.allOperators[entity.operatorCode];
		endif;
		if op &lt;&gt; null and op.displayTempFahrenheit then
			if entity.carriageTempF &lt;&gt; app.temperatureConversion(true, NULL_TEMPERATURE) then	// PAR #36094
				txtCarriageTemp.setValue(entity.carriageTempF.asStringJMT);
			endif;																				// PAR #36094
		else
			if entity.carriageTempC &lt;&gt; NULL_TEMPERATURE then									// PAR #36094
				txtCarriageTemp.setValue(entity.carriageTempC.asStringJMT);
			endif;																				// PAR #36094
		endif;	
		
		if entity.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
			self.txtCO2Percent.setValue(entity.getCarbonDioxide.asStringJMT);
		endif;
		if entity.getOxygen &lt;&gt; NULL_OXYGEN then
			self.txtOxygenPercent.setValue(entity.getOxygen.asStringJMT);
		endif;
		self.chkCurtainsIn.setValue(entity.curtainsIn);
		if entity.getHumidity &lt;&gt; NULL_HUMIDITY then
			txtHumidity.setValue(entity.getHumidity.asStringJMT);
		endif;
		if entity.ventilation &lt;&gt; NULL_VENTILATION then
			//self.txtVentilation.setValue(entity.ventilation.asStringJMT);					// PAR #31155
			self.tblVentilation.setValueDefault(entity.ventilation.asStringJMT);			// PAR #31155
		endif;
		
		packTSSystem.cnEcSetDateAndTime(entity.packDate,entity.packTime);					//TFS 2755
		packTSLocal := self.systemToLocalTime(packTSSystem);								//TFS 2755
		txtPackDate.setValue(packTSLocal.date());											//TFS 2755
			
		// PAR #35672 rejig pack temp code to avoid converting blank or NULL temperatures	// PAR #35672
		if op &lt;&gt; null and op.displayTempFahrenheit then										// PAR #35651
			if entity.packTempF &lt;&gt; app.temperatureConversion(true, NULL_TEMPERATURE) then	// PAR #35672
				txtPackTemp.setValue(entity.packTempF.asStringJMT);							// PAR #35672
			endif;																			// PAR #35672
		else																				// PAR #35672
			if entity.packTempC.Real &lt;&gt; NULL_TEMPERATURE then								// PAR #35672
				txtPackTemp.setValue(entity.packTempC.asStringJMT);							// PAR #35672
			endif;																			// PAR #35672
		endif;																				// PAR #35672
		
		
		txtPackTime.setValue(packTSLocal.time());											//TFS 2755
		cmbCoolingType.setForText(app.coolingTypeENumToString(entity.coolingType, false));
		cmbVoltageType.setForText(app.voltageTypeENumToString(entity.voltageType, false));
	
		self.chkTransitPower.setValue(entity.onPowerDuringTransit);				// PAR #31018
		
		transitOnPowerTSSystem.cnEcSetDateAndTime(entity.transitOnPowerDate,entity.transitOnPowerTime);//TFS 2755
		transitOnPowerTSLocal := self.systemToLocalTime(transitOnPowerTSSystem);								//TFS 2755
		self.txtTransitOnDate.setValue(transitOnPowerTSLocal.date());				// PAR #31018				//TFS 2755
		self.txtTransitOnTime.setValue(transitOnPowerTSLocal.time());				// PAR #31018				//TFS 2755
		self.txtTransitRemark.setValue(entity.transitOnPowerRemarks);			// PAR #31018
		expiryTsSystem.cnEcSetDateAndTime(entity.expiryDate,TimeEndOfDay);										//TFS 2755									
		self.txtExpiryDate.setValue(self.systemToLocalTime(expiryTsSystem).date());				// PAR #36094	//TFS 2755
		
		self.chkExternallyMonitor.setValue(entity.isExternallyMonitored); //epr TFS 3581 15/3/17
		
	elseif _item.isKindOf(CM_TIMaster) then
		if _item.isKindOf(CM_TIMasterContainer) then
			masterContainer := _item.CM_TIMasterContainer;
			if self.myAssistant.validateMasterCoolingType(masterContainer.coolingType, cmbCoolingType.getString()) = MsgBox_Return_OK then
				cmbCoolingType.setForText(app.coolingTypeENumToString(masterContainer.coolingType, false));
			endif;
			if self.myAssistant.validateMasterVoltageType(masterContainer.voltageType, cmbVoltageType.getString()) = MsgBox_Return_OK then
				cmbVoltageType.setForText(app.voltageTypeENumToString(masterContainer.voltageType, false));
			endif;
		endif;
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote := _item.CMIF_PreNote;	
		
		if preNote.allowableTimeOffPower &lt;&gt; NULL_ALLOWABLE_TIME_OFF_POWER then	//cnwas3 par 26199
			txtTimeOffPower.setValue(preNote.allowableTimeOffPower.asStringJMT);
		endif;
		
		if preNote.operatorCode &lt;&gt; null then												// PAR #31155
			op := app.myRoot.allOperators[preNote.operatorCode];							// PAR #31155
			if op &lt;&gt; null	// 22/09/2014 cnwar2 #34792
			and op.displayTempFahrenheit then												// PAR #31155
				if preNote.carriageTempF &lt;&gt; NULL_TEMPERATURE then							// PAR #31155
					txtCarriageTemp.setValue(preNote.carriageTempF.asStringJMT);			// PAR #31155
				endif;																		// PAR #31155
			else																			// PAR #31155
				txtCarriageTemp.setValue(preNote.carriageTempC.asStringJMT);				// PAR #31155
			endif;																			// PAR #31155
		else				
			txtCarriageTemp.setValue(preNote.getDisplayTempCelcius);
		endif;																				// PAR #31155
		if preNote.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
			self.txtCO2Percent.setValue(preNote.getCarbonDioxide.asStringJMT);
		endif;
		if preNote.getOxygen &lt;&gt; NULL_OXYGEN then
			self.txtOxygenPercent.setValue(preNote.getOxygen.asStringJMT);
		endif;
		self.chkCurtainsIn.setValue(preNote.curtainsIn);
		if preNote.getHumidity &lt;&gt; NULL_HUMIDITY then
			txtHumidity.setValue(preNote.getHumidity.asStringJMT);
		endif;
		if preNote.ventilation &lt;&gt; NULL_VENTILATION then
			//self.txtVentilation.setValue(preNote.ventilation.asStringJMT);				// PAR #31155
			self.tblVentilation.setValueDefault(preNote.ventilation.asStringJMT);			// PAR #31155
		endif;
		
		packTSSystem.cnEcSetDateAndTime(preNote.packDate,preNote.packTime);						//TFS 2755
		packTSLocal := self.systemToLocalTime(packTSSystem);							//TFS 2755
		txtPackDate.setValue(packTSLocal.date());											//TFS 2755
		
		if op &lt;&gt; null then																	// PAR #31155
			if op.displayTempFahrenheit then												// PAR #31155
				if preNote.packTempF &lt;&gt; NULL_TEMPERATURE then								// PAR #31155
					txtPackTemp.setValue(preNote.packTempF.asStringJMT);					// PAR #31155
				endif;																		// PAR #31155
			else																			// PAR #31155
				if preNote.packTempC &lt;&gt; NULL_TEMPERATURE then								// PAR #31155
					txtPackTemp.setValue(preNote.packTempC.asStringJMT);					// PAR #31155
				endif;																		// PAR #31155
			endif;																			// PAR #31155
		else																				// PAR #31155
			if preNote.packTempC &lt;&gt; NULL_TEMPERATURE then									// PAR #31155
				txtPackTemp.setValue(preNote.packTempC.asStringJMT);
			endif;																			// PAR #31155
		endif;																				// PAR #31155
		txtPackTime.setValue(packTSLocal.time().asStringJMT);
		cmbCoolingType.setForText(app.coolingTypeENumToString(preNote.coolingType, false));
		cmbVoltageType.setForText(app.voltageTypeENumToString(preNote.voltageType, false));
		
		self.chkTransitPower.setValue(preNote.onPowerDuringTransit);			// PAR #31018
		transitOnPowerTSSystem.cnEcSetDateAndTime(preNote.transitOnPowerDate,preNote.transitOnPowerTime);	//TFS 2755
		transitOnPowerTSLocal := self.systemToLocalTime(transitOnPowerTSSystem);							//TFS 2755
		self.txtTransitOnDate.setValue(transitOnPowerTSLocal.date());				// PAR #31018			//TFS 2755
		self.txtTransitOnTime.setValue(transitOnPowerTSLocal.time());				// PAR #31018			//TFS 2755
		self.txtTransitRemark.setValue(preNote.transitOnPowerRemarks);			// PAR #31018
		expiryTsSystem.cnEcSetDateAndTime(preNote.expiryDate,TimeEndOfDay);									//TFS 2755									
		self.txtExpiryDate.setValue(self.systemToLocalTime(expiryTsSystem).date());			// PAR #36094	//TFS 2755		
	elseif _item.isKindOf(CM_TrackedItem) then 		  // PAR #22938
		ti := _item.CM_TrackedItem;					// PAR #22938
		if ti.getAllowableTimeOffPower() &lt;&gt; NULL_ALLOWABLE_TIME_OFF_POWER then	//cnwas3 par 26199
			txtTimeOffPower.setValue(ti.getAllowableTimeOffPower.asStringJMT);
		endif;
		
		if ti.myOperator &lt;&gt; null then																			// PAR #31155
			if ti.myOperator.displayTempFahrenheit then															// PAR #31155
				if ti.getTemperature &lt;&gt; NULL_TEMPERATURE then													// PAR #31155
					txtCarriageTemp.setValue(app.temperatureConversion(true, ti.getTemperature).asStringJMT);	// PAR #31155
				endif;																							// PAR #31155
			else																								// PAR #31155
				if ti.getTemperature() &lt;&gt;  NULL_TEMPERATURE  then												// PAR #31155
					txtCarriageTemp.setValue(ti.getTemperature().asStringJMT);									// PAR #31155
				endif;																							// PAR #31155
			endif;																								// PAR #31155
		else																									// PAR #31155
			if ti.getTemperature() &lt;&gt;  NULL_TEMPERATURE  then
				txtCarriageTemp.setValue(ti.getTemperature().asStringJMT);
			endif;
		endif;																									// PAR #31155
		if ti.getCarbonDioxide() &lt;&gt; NULL_CARBON_DIOXIDE then
			self.txtCO2Percent.setValue(ti.getCarbonDioxide().asStringJMT);
		endif;
		if ti.getOxygen() &lt;&gt; NULL_OXYGEN then
			self.txtOxygenPercent.setValue(ti.getOxygen().asStringJMT);
		endif;
		self.chkCurtainsIn.setValue(ti.getCurtainsIn);
		if ti.getHumidity() &lt;&gt; NULL_HUMIDITY then
			txtHumidity.setValue(ti.getHumidity.asStringJMT);
		endif;
		if ti.getVentilation() &lt;&gt; NULL_VENTILATION then
			//self.txtVentilation.setValue(ti.ventilationString);							// PAR #31155
			self.tblVentilation.setValueDefault(ti.ventilationString);						// PAR #31155
		endif;
			packTSSystem.cnEcSetDateAndTime(ti.packDate,ti.packTime);						//TFS 2755
		packTSLocal := self.systemToLocalTime(packTSSystem);							//TFS 2755
		txtPackDate.setValue(packTSLocal.date());											//TFS 2755
		
		
		if  ti.myOperator &lt;&gt; null then														// PAR #35651
			if ti.packTempC.Real &lt;&gt; NULL_TEMPERATURE then
				if ti.displayTempFahrenheit then
					txtPackTemp.setValue(ti.packTempF.asStringJMT);
				else
					txtPackTemp.setValue(ti.packTempC.asStringJMT);
				endif;
			endif;
		endif;
		
		txtPackTime.setValue(packTSLocal.time());									//TFS 2755
		cmbCoolingType.setForText(app.coolingTypeENumToString(ti.getCoolingType, false));
		cmbVoltageType.setForText(app.voltageTypeENumToString(ti.getVoltageType, false));
			
		self.chkTransitPower.setValue(ti.getOnPowerDuringTransit);			// PAR #31018
		
		transitOnPowerTSSystem.cnEcSetDateAndTime(ti.getTransitOnPowerDate,ti.getTransitOnPowerTime);	//TFS 2755
		transitOnPowerTSLocal := self.systemToLocalTime(transitOnPowerTSSystem);								//TFS 2755
		self.txtTransitOnDate.setValue(transitOnPowerTSLocal.date());				// PAR #31018				//TFS 2755
		self.txtTransitOnTime.setValue(transitOnPowerTSLocal.time());				// PAR #31018				//TFS 2755
		
		self.txtTransitRemark.setValue(ti.getTransitOnPowerRemarks);		// PAR #31018
		expiryTsSystem.cnEcSetDateAndTime(ti.getExpiryDate,TimeEndOfDay);										//TFS 2755									
		self.txtExpiryDate.setValue(self.systemToLocalTime(expiryTsSystem).date());				// PAR #36094	//TFS 2755
		self.chkExternallyMonitor.setValue(ti.getExternalMonitoring()); //epr TFS 3581 15/3/17
		
	endif;
	
	// Set temperature labels																// PAR #31155
	self.doSetTemperatureLabels();															// PAR #31155
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setContainerVoyageDetails" id="e816a2e7-bc77-4848-823e-c08feaf92d08">
        <updating/>
        <source>setContainerVoyageDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/07/2009	cnwdap1	Initial creation
15/03/2016	cnwdap1	PAR #37606 "Not available for entry" consignee / consignor / freight forwarder
02/02/2018	jlgdap1	TFS 36825 Fleet File Operator and Voyage Operators mismatch
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	brItem		: CM_BRefItemContainer;
	bookingRef	: CM_BookingRef;
	item		: CM_TrackedItem;
	assistant	: CMUI_Assistant;
	voyage		: CM_Voyage;
	str			: String;
	entity		: CMGTE_Receival;
	ports		: StringArray;
	preNote		: CMIF_PreNote;
	master		: CM_TIMaster;
	entityByType	: CMGTE_ReceivalByType;		// 09/12/2010 cnwmh5 #26556
	cons			: CM_ConsigneeConsignor;			// PAR #37606
	consDesc		: String;							// PAR #37606
begin
	assistant := self.myAssistant;
	
	if _item.isKindOf(CM_BRefItemContainer) then
	
		brItem 		:= _item.CM_BRefItemContainer;
		bookingRef	:= brItem.myBookingReference;
		voyage 		:= bookingRef.myVoyage;
		ports		:= bookingRef.allDischargePorts;
		
		//cmbImexStatus.setText(_brItem.myBookingReference.			// CM_TrackedItem.getImexStatus
		assistant.comboBoxVoyageCurrent(cmbVoyageCode,
										voyage,
										true,
										false,
										false,
										true,
										true,
										false,
										true,
										false,
										true);
		
		cmbOperatorCode.setObject(bookingRef.myOperator);
		cmbDestPort.setObjectFromCode(bookingRef.destinationPort);
		
		
		if voyage &lt;&gt; null then
			cmbDischargePort.setObjectFromCodeAndVoyage(bookingRef.dischargePort,voyage);
			cmbTranshipPort.setObjectAndVoyageDischPort(cmbDischargePort.listObject.CM_Port,voyage);
		else
			cmbDischargePort.setObjectFromCode(bookingRef.dischargePort);
		endif;	
		if bookingRef.myTranshipToPort &lt;&gt; null then
			cmbTranshipPort.setObject(bookingRef.myTranshipToPort);
		endif;
		
		cmbConsignor.setForObject(bookingRef.myConsignor);
		cmbConsignee.setForObject(bookingRef.myConsignee);
		cmbCarrier.setForObject(bookingRef.myCarrier);
		cmbStevedore.setForObject(bookingRef.myStevedore);              //02.10.2020 cnwma1 TFS #50112
		cmbFreightFwdr.setForObject(bookingRef.myFreightForwarder);		//cnwmc5 - 23 Oct 2013 - PAR 32735
		
		// if this is a booking created with a consignor / consignee / freight forwarder that was valid but is				// PAR #37606
		// now not available for entry, add manually to the combo															// PAR #37606
		cons := bookingRef.myConsignor;																						// PAR #37606
		if cons &lt;&gt; null and cons.isNotAvailableForEntry then																// PAR #37606
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #37606
				consDesc := cons.getDescriptionTabCode;																		// PAR #37606
			else																											// PAR #37606
				consDesc := cons.getYADisplay;																				// PAR #37606
			endif;																											// PAR #37606
			self.cmbConsignor.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignor.addItemObject(consDesc, cons);		// PAR #37606
		endif;																												// PAR #37606
		cons := bookingRef.myConsignee;																						// PAR #37606
		if cons &lt;&gt; null and cons.isNotAvailableForEntry then																// PAR #37606
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #37606
				consDesc := cons.getDescriptionTabCode;																		// PAR #37606
			else																											// PAR #37606
				consDesc := cons.getYADisplay;																				// PAR #37606
			endif;																											// PAR #37606
			self.cmbConsignee.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignee.addItemObject(consDesc, cons);		// PAR #37606
		endif;																												// PAR #37606
		cons := bookingRef.myFreightForwarder;																				// PAR #37606
		if cons &lt;&gt; null and cons.isNotAvailableForEntry then																// PAR #37606
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #37606
				consDesc := cons.getDescriptionTabCode;																		// PAR #37606
			else																											// PAR #37606
				consDesc := cons.getYADisplay;																				// PAR #37606
			endif;																											// PAR #37606
			self.cmbFreightFwdr.getEmbeddedControl.ComboBox.listIndex := self.cmbFreightFwdr.addItemObject(consDesc, cons);	// PAR #37606
		endif;																												// PAR #37606
		
	elseif _item.isKindOf(CM_TrackedItem) then
	
		item 	:= _item.CM_TrackedItem;
		voyage 	:= self.myTerminal.allVoyagesByCode.getAtKeyGeq(item.voyageCode, null);
		if item.myBookingRef &lt;&gt; null then
			ports := item.myBookingRef.allDischargePorts;
		else
			ports := item.allDischargePorts;
		endif;
		
		cmbImexStatus.setForObject(item.getImExStatusObject);
		cmbVoyageCode.setIndexFromObject(voyage);
		cmbOperatorCode.setObject(item.myOperator);
		cmbDestPort.setObjectFromCode(item.destinationPort);
		
		if voyage &lt;&gt; null then
			cmbDischargePort.setObjectFromCodeAndVoyage(item.dischargePort,voyage);
			cmbTranshipPort.setObjectAndVoyageDischPort(cmbDischargePort.listObject.CM_Port,voyage);
		else
			cmbDischargePort.setObjectFromCode(item.dischargePort);
		endif;	
		if item.myTranshipToPort &lt;&gt; null then
			cmbTranshipPort.setObject(item.myTranshipToPort);
		endif;
		
		cmbConsignor.setForObject(app.myRoot.allConsigneeConsignors[item.consignor]);
		cmbConsignee.setForObject(app.myRoot.allConsigneeConsignors[item.consignee]);
		cmbCarrier.setForObject(app.myRoot.allCarriers[item.carrier]);
		cmbStevedore.setForObject(app.myRoot.allStevedores[item.stevedoreCodeRecieve]);         //02.10.2020 cnwma1 TFS #50112
	elseif _item.isKindOf(CMGTE_Receival) then
	
		entity 	:= _item.CMGTE_Receival;
		voyage	:= self.myTerminal.allVoyagesByCode.getAtKeyGeq(entity.voyageCode, null);
		ports	:= entity.allDischargePorts;
		
		cmbImexStatus.setForObject(app.myRoot.allImexStatuses[entity.imexStatus]);
		cmbVoyageCode.setIndexFromObject(voyage);
		cmbOperatorCode.setObject(entity.getOperatorObject);
		cmbDestPort.setObjectFromCode(entity.destinationPort);
		
		if voyage &lt;&gt; null then
			cmbDischargePort.setObjectFromCodeAndVoyage(entity.dischargePort,voyage);
			cmbTranshipPort.setObjectAndVoyageDischPort(cmbDischargePort.listObject.CM_Port,voyage);
		else
			cmbDischargePort.setObjectFromCode(entity.dischargePort);
		endif;		
		if entity.myTranshipToPort &lt;&gt; null then
			cmbTranshipPort.setObject(entity.myTranshipToPort);
		endif;
		
		cmbConsignor.setForObject(app.myRoot.allConsigneeConsignors[entity.consignorCode]);
		cmbConsignee.setForObject(app.myRoot.allConsigneeConsignors[entity.consigneeCode]);
		cmbCarrier.setForObject(app.myRoot.allCarriers[entity.carrier]);
		cmbStevedore.setForObject(app.myRoot.allStevedores[entity.stevedoreCode]);         //02.10.2020 cnwma1 TFS #50112
		// if this is a prenote created with a consignor / consignee / freight forwarder that was valid but is				// PAR #37606
		// now not available for entry, add manually to the combo															// PAR #37606
		cons := app.myRoot.allConsigneeConsignors[entity.consignorCode];													// PAR #37606
		if cons &lt;&gt; null and cons.isNotAvailableForEntry then																// PAR #37606
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #37606
				consDesc := cons.getDescriptionTabCode;																		// PAR #37606
			else																											// PAR #37606
				consDesc := cons.getYADisplay;																				// PAR #37606
			endif;																											// PAR #37606
			self.cmbConsignor.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignor.addItemObject(consDesc, cons);		// PAR #37606
		endif;																												// PAR #37606
		cons := app.myRoot.allConsigneeConsignors[entity.consigneeCode];													// PAR #37606
		if cons &lt;&gt; null and cons.isNotAvailableForEntry then																// PAR #37606
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #37606
				consDesc := cons.getDescriptionTabCode;																		// PAR #37606
			else																											// PAR #37606
				consDesc := cons.getYADisplay;																				// PAR #37606
			endif;																											// PAR #37606
			self.cmbConsignee.getEmbeddedControl.ComboBox.listIndex := self.cmbConsignee.addItemObject(consDesc, cons);		// PAR #37606
		endif;																												// PAR #37606
		cons := app.myRoot.allConsigneeConsignors[entity.freightForwarderCode];												// PAR #37606
		if cons &lt;&gt; null and cons.isNotAvailableForEntry then																// PAR #37606
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #37606
				consDesc := cons.getDescriptionTabCode;																		// PAR #37606
			else																											// PAR #37606
				consDesc := cons.getYADisplay;																				// PAR #37606
			endif;																											// PAR #37606
			self.cmbFreightFwdr.getEmbeddedControl.ComboBox.listIndex := self.cmbFreightFwdr.addItemObject(consDesc, cons);	// PAR #37606
		endif;																												// PAR #37606
		
	elseif _item.isKindOf(CM_TIMaster) then
		master := _item.CM_TIMaster;
		if self.myAssistant.validateMasterOperator(master.myOperatorNew, self.cmbOperatorCode.listObject.CM_Operator) = MsgBox_Return_OK then
			// TFS 36825 if the fleet file operator isn't valid for the voyage, raise an error and leave the operator combo blank
			voyage := self.cmbVoyageCode.listObject.CM_Voyage;
			if voyage &lt;&gt; null and not voyage.isNullVoyage then
				if voyage.allOperators[master.myOperatorNew.code] = null then
					self.cmbOperatorCode.listIndex := -1;
					app.raiseCMException2(Fleet_File_Operator_Not_Valid, master.myOperatorNew.code, voyage.code, null, null);
				endif;
			endif;
			// TFS 36825 end
			self.cmbOperatorCode.setObject(master.myOperatorNew);
		endif;
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote	:= _item.CMIF_PreNote;
		voyage	:= self.myTerminal.allVoyagesByCode.getAtKeyGeq(preNote.voyageCode, null);
		ports	:= preNote.allDischargePorts;
		
		cmbImexStatus.setForObject(preNote.imExStatus);
		cmbVoyageCode.setIndexFromObject(voyage);
		cmbOperatorCode.setObject(app.myRoot.allOperators[preNote.operatorCode]);
		cmbDestPort.setObjectFromCode(preNote.destinationPort);
		
		if voyage &lt;&gt; null then
			cmbDischargePort.setObjectFromCodeAndVoyage(preNote.dischargePort,voyage);
			cmbTranshipPort.setObjectAndVoyageDischPort(cmbDischargePort.listObject.CM_Port,voyage);
		else
			cmbDischargePort.setObjectFromCode(preNote.dischargePort);
		endif;	
		if preNote.myTranshipToPort &lt;&gt; null then
			cmbTranshipPort.setObject(preNote.myTranshipToPort);
		endif;
		
		cmbConsignor.setForObject(app.myRoot.allConsigneeConsignors[preNote.consignorCode]);
		cmbConsignee.setForObject(app.myRoot.allConsigneeConsignors[preNote.consigneeCode]);
		cmbCarrier.setForObject(app.myRoot.allCarriers[preNote.carrier]);
		cmbStevedore.setForObject(app.myRoot.allStevedores[preNote.stevedoreCode]);             //02.10.2020 cnwma1 TFS #50112
	// 09/12/2010 cnwmh5 #26556 - 
	elseif _item.isKindOf(CMGTE_ReceivalByType) then
		
		entityByType	:= _item.CMGTE_ReceivalByType;
		if entityByType.myReceivalInfo.myBookingItem &lt;&gt; null then
			brItem 		:= entityByType.myReceivalInfo.myBookingItem.CM_BRefItemContainer;
			bookingRef	:= brItem.myBookingReference;
			voyage 		:= bookingRef.myVoyage;
			ports		:= bookingRef.allDischargePorts;
			
			assistant.comboBoxVoyageCurrent(cmbVoyageCode,
											voyage,
											true,
											false,
											false,
											true,
											true,
											false,
											true,
											false,
											true);
			
			cmbOperatorCode.setObject(bookingRef.myOperator);
			cmbDestPort.setObjectFromCode(bookingRef.destinationPort);
						
			if voyage &lt;&gt; null then
				cmbDischargePort.setObjectFromCodeAndVoyage(bookingRef.dischargePort,voyage);
				cmbTranshipPort.setObjectAndVoyageDischPort(cmbDischargePort.listObject.CM_Port,voyage);
			else
				cmbDischargePort.setObjectFromCode(bookingRef.dischargePort);
			endif;	
			if bookingRef.myTranshipToPort &lt;&gt; null then
				cmbTranshipPort.setObject(bookingRef.myTranshipToPort);
			endif;
			
			cmbConsignor.setForObject(bookingRef.myConsignor);
			cmbConsignee.setForObject(bookingRef.myConsignee);
			cmbCarrier.setForObject(bookingRef.myCarrier);
			
			self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
		endif;
		// 09/12/2010 cnwmh5 #26556 - End
		
	endif;		
	
	self.setOptionalDischargePortsList(voyage, ports);

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="b5978783-02c5-4d0c-89c7-bba5c064ff0b">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbAttachments.style := 2;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDamageText" id="e35adae3-9072-4603-b2d4-7cb5f22a93e1">
        <source>setDamageText();
/*

Date		Who		Reason
24 Oct 2013	cnwer1	Initial creation PAR
05 Feb 2025	navnk30	JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
*/

vars
	damageInstance : CM_DamageInstance;
	str						: String;
begin
    //foreach damageInstance in self.allDamageInstancesByPos do												//05.02.2025 navnk30 JIRA 33887
    foreach damageInstance in self.allDamageInstancesByPos where global.isValidObject(damageInstance) do	//05.02.2025 navnk30 JIRA 33887
		if damageInstance.myDamagePosition = null then
			continue;
		endif;	
		if str = null then
			str := damageInstance.description;
		else
			str := str &amp; ", " &amp;  damageInstance.description; 
		endif;
	
	endforeach;

	self.lblDamage.caption:= str;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDimTypeDetails" id="fa76e888-0f20-4c89-bb41-338a2039ba14">
        <source>setDimTypeDetails(_cargoType : CM_CargoType; _product : CM_Product; _type : String);
/*
Purpose:		Load the Type Combo			

Parameters:			

Return Value:		

Date		Who		Reason
19/11/2009	cnwmh5	Initial creation
17/02/2010	cnwdap1	PAR #22397Check for system product type if the item doesn't have a product
15/03/2010	cnwdap1	PAR # 23190 Type could be a combo or textbox, depending on validation type
*/
vars
	code		: CM_ProductAttributeCode;
	product		: CM_Product;
begin
	
	// clear the combobox
	self.cmbDimType.clear();
	
	// PAR #22397 if product parameter is null, see if we have a system product type
	if _product &lt;&gt; null then
		product := _product;
	else
		product := _cargoType.mySystemProductType;
	endif;
	// product is null then return
	//if _product = null then	// PAR #22397
	if product = null then
		return;
	endif;
				
	// load the details and set
	// PAR # 23190 type could be a combo or textbox, depending on validation type
	if product.myType.validationType = product.myType.ValidationType_Codes then
		code := product.myType.allCodes[_type];		// PAR #22397
		if self.cmbDimType.getEmbeddedControl.CMUI_FieldComboBoxControl.listCount = null then
			self.cmbDimType.listCollection(product.myType.allCodes, true, ComboBox.DisplayCollection_Forward);		// PAR #22397
		endif;
		if code &lt;&gt; null then		
			self.cmbDimType.setForText(code.code &amp; ' - ' &amp; code.description);
		endif;
		//epr TFS 7756 20/2/18 set in one place
		self.cmbDimType.setMyCaption(product.myType.displayName);
		self.cmbDimType.isHidden:=false;
	else
		self.txtDimType.setMyCaption(product.myType.displayName);
		txtDimType.setValue(_type);
		self.txtDimType.isHidden:=false;
	endif;
			
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromBOLDetail" id="e597d731-f333-4b7d-a1c1-cb168738e9aa">
        <updating/>
        <source>setFieldsFromBOLDetail() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 Jan 2010		cnwjre1	Initial creation - copied from setFieldFromBookingItem
26/04/2010		cnwmh5	PAR23821 - Add loading of missing BOL Detail fields
13/08/2013		cnwdap1	PAR #32123 Colour picker changes
13/05/2015	    cnwma1  PAR #36217 Load Port not Copied from BOL
*/
vars
	bolDetail	: CM_BOLDtl;
	commodity 	: CM_Commodity;
	sBOL 		: String;
	entDef		: String;
	
begin
	
	bolDetail := self.myBOLDtl;
	if bolDetail = null then 
		return;
	endif;
	
	if bolDetail.cargoType = TI_CargoType_Container then
		commodity := app.myRoot.allCommodities[bolDetail.commodity];
		if commodity &lt;&gt; null and commodity.isEmpty then
			self.setIsEmptyContainer();
		else
			self.setIsFullContainer();
		endif;
	else
		self.setIsGeneralCargo();
	endif;
	self.doLoadBOLItems(bolDetail);

	self.doSetCaption();
	self.doShowPicture();
	
	// if the subcargo type combo is hidden, this cargo type has not subcargo types
	// - open the dimensions section
	if self.cmbSubCargo.isHidden and self.closedDimensions then
		self.doOpenCloseDimensionsSection();
	endif;
		
	self.enableControls();	

	sBOL := bolDetail.myBOL.number;
	self.txtBOLNumber.setFocus();
	self.txtBOLNumber.CMUI_FieldTextBox.setValue(sBOL);

	self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
	self.cmbVoyageCode.setObject(bolDetail.myBOL.CM_BOLIn.myVoyage);
	self.doSelectVoyage();
	if bolDetail.myBOL.CM_BOLIn.myVoyage &lt;&gt; null then
		self.cmbOperatorCode.setObject(bolDetail.myBOL.CM_BOLIn.myVoyage.myOperator);
	endif;
	self.cmbCommodity.setForObject(bolDetail.getMyCommodity);
	self.cmbType.setForObject(bolDetail.myCargoType);

	// 26/04/2010 cnwmh5 PAR23821 - Start
	//self.lstColour.setValue(bolDetail.colour);								// PAR #32123
	self.setColourDetails(bolDetail.colour);									// PAR #32123
	self.txtMarkNumber.setValue(bolDetail.markNumber);
	//self.txtTotalWeight.setValue(bolDetail.weight.asStringWeightJMT);								// PAR #31155
	//self.txtTotalVolume.setValue(bolDetail.volume);												// PAR #31155
	//self.tblTotalWeight.setValueDefault(bolDetail.weight.asStringWeightJMT);						// PAR #31155
	self.tblTotalWeight.setValueDefault(bolDetail.weight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
	self.tblTotalVolume.setValueDefault(bolDetail.volume.String);									// PAR #31155
	self.cmbConsignee.setForObject(app.myRoot.allConsigneeConsignors[bolDetail.consigneeCode]);
	self.cmbConsignor.setForObject(app.myRoot.allConsigneeConsignors[bolDetail.consignorCode]);
	//self.txtLength.setValue(bolDetail.length.asStringJMT);					// 11/01/2011 cnwmh5 #26710 - moved to setBOLDimensionDetails				
	//self.txtWidth.setValue(bolDetail.width.asStringJMT);						// 11/01/2011 cnwmh5 #26710 - moved to setBOLDimensionDetails
	//self.txtHeight.setValue(bolDetail.height.asStringJMT);					// 11/01/2011 cnwmh5 #26710 - moved to setBOLDimensionDetails
	self.cmbDestPort.setObjectFromCode(bolDetail.myBOL.destinationPort);
	self.cmbDischargePort.setObjectFromCode(bolDetail.myBOL.dischargePort);
	self.cmbLoadPortCombo.setObjectFromCode(bolDetail.myBOL.loadPortCode);		// 13/05/2015 cnwma1 #36127
	
	self.txtRemarks.setValue(bolDetail.remarks);
	// 26/04/2010 cnwmh5 PAR23821 - End 
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldsFromBookingItem" id="0cb67f32-bb25-42e0-bfeb-38dab9a0302e">
        <updating/>
        <source>setFieldsFromBookingItem() updating, protected;
/*
Date		Who		Reason
24/07/2009	cnwdap1	Initial creation
24/03/2010	cnwdap1	PAR #22938 Cater for Bookings of general cargo reefers
30/06/2010	cnwdap1	PAR #23538 Set ent def correctly for rail prenote form
*/
vars
	brItem			: CM_BookingRefItem;
	commodity 		: CM_Commodity;
	sBooking 		: String;
	entDef			: String;
	
begin
	inheritMethod();
	
	brItem := self.myBookingRefItem;
	
	if brItem = null then 
		return;
	endif;
	
	if brItem.cargoType = TI_CargoType_Container then
		commodity := app.myRoot.allCommodities[brItem.commodity];

		if commodity &lt;&gt; null and commodity.isEmpty then
			self.setIsEmptyContainer();
		else
			self.setIsFullContainer();
		endif;
	else
		self.setIsGeneralCargo();
	endif;

	self.doSetCaption();
	self.doShowPicture();
	
	// what sort of booking ref item do we have?
	if brItem.isKindOf(CM_BRefItemContainer) then
		if brItem.cargoType = TI_CargoType_Container then
			if self.isAttachmentForm() then
				entDef := ETDef_AttachmentDetails;
				
			elseif self.isRailPreNoteForm then					// PAR #23538
				if brItem.CM_BRefItemContainer.isReefer then	// PAR #23538
					entDef := ETDef_RailPreNoteReefer;			// PAR #23538
				else											// PAR #23538
					entDef := ETDef_RailPreNote;				// PAR #23538
				endif;											// PAR #23538
			else
				if brItem.CM_BRefItemContainer.isReefer then
					entDef := ETDef_ContainerFullReefer;
					
				elseif brItem.CM_BRefItemContainer.getMyCommodity &lt;&gt; null and brItem.CM_BRefItemContainer.getMyCommodity.isEmpty then
					entDef := ETDef_ContainerEmpty;
					
				else
					entDef := ETDef_ContainerFull;
				endif;
			endif;
		else
			if self.isAttachmentForm() then
				entDef := ETDef_AttachmentGeneral;
				
			elseif self.isRailPreNoteForm then					// PAR #23538
				entDef := ETDef_RailPreNoteCargo;				// PAR #23538
				
			else
				// PAR #22938 is the booking item a reefer?
				if brItem.CM_BRefItemContainer.isReefer then
					entDef := ETDef_GeneralCargoReefer;
				else
					entDef := ETDef_GeneralCargo;
				endif;
			endif;
		endif;
		self.initFieldsForEntDefName(entDef, false);
		self.setFieldsFromItem(brItem);
		self.doFilterDetailsBySubCargoType(self.cmbSubCargo.getObject().CM_Product);
		
		// if the subcargo type combo is hidden, this cargo type has not subcargo types
		// - open the dimensions section
		if self.cmbSubCargo.isHidden and self.closedDimensions then
			self.doOpenCloseDimensionsSection();
		endif;
		
		self.doSetCaption();
		self.doShowPicture();
		self.enableControls();	
		
		//cnwas3 begin
		sBooking := self.txtBookingRef.CMUI_FieldTextBox.getString();
		self.txtBookingRef.setFocus();
		self.txtBookingRef.CMUI_FieldTextBox.setValue("");
		self.txtBookingRef.CMUI_FieldTextBox.setValue(sBooking);
		//cnwas3 end
		self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
		
		//cnwmc5 - 1 Nov 2013 - PAR 32901
		if self.isFlexiGateForm and self.myCurrentVehicleVisit &lt;&gt; null then
			self.cmbCarrier.setForObject(self.myCurrentVehicleVisit.getCarrier());
		endif;
		
		// cnwmc5 - 21 June 2016 - TFS 2149
		self.doSetSubTerminal();
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldsFromCMIFPreNote" id="cc9d661b-b028-4d6c-a167-a850ef081ee1">
        <updating/>
        <source>setFieldsFromCMIFPreNote(_intFacePreNote : CMIF_PreNote) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2009	cnwdap1	Initial creation
*/
vars

begin
	self.setFieldsFromItem(_intFacePreNote);
epilog

end;</source>
        <Parameter name="_intFacePreNote" type="CMIF_PreNote"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromGTEEntity" id="6561fdc4-97a5-4ab0-b708-4ffd1d324ab4">
        <updating/>
        <source>setFieldsFromGTEEntity(_item : CMGTE_Entity) updating, protected;
/*
Date		Who		Reason
24/07/2009	cnwdap1	Initial creation
12/10/2009	cnwdap1	PAR #21125 Call setGeneralCargoDetails to display these details for CMGTE_Entity
*/
vars

begin 
	self.setContainerMainDetails(_item);
	self.setContainerVoyageDetails(_item);
	self.setSubCargoDetails(_item);
	self.setContainerCargoDetails(_item);
	self.setContainerAdditionalDetails(_item);
	
	// Reefer Details
	self.setContainerReeferDetails(_item);
	
	// Over Dimension details
	self.setContainerOverDimDetails(_item);
	
	// General Cargo Details (breakbulk tracked items and prenotes only
	self.setGeneralCargoDetails(_item);
	
	//21 Sep 2010	NDL	Par 25608
	self.setSealDetails(_item);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromItem" id="a2a1fc32-5073-437f-a392-7a0ac82f4296">
        <updating/>
        <source>setFieldsFromItem(_item : Object) updating, protected;
/*
Date		Who		Reason
17/07/2009	cnwdap1	Initial creation
24/03/2010	cnwdap1	PAR #22938 Call setGeneralCargoDetails for booking items too (to display length/width/height)
*/
vars

begin 
	self.setContainerMainDetails(_item);

	self.setContainerVoyageDetails(_item);
	self.setContainerCargoDetails(_item);
	self.setSubCargoDetails(_item);
	self.setContainerAdditionalDetails(_item);
	
	// Reefer Details
	self.setContainerReeferDetails(_item);
	
	// Over Dimension Details
	self.setContainerOverDimDetails(_item);
	
	// General Cargo Details (breakbulk tracked items and prenotes only
	if _item.isKindOf(CM_BreakBulkGeneric) or _item.isKindOf(CMIF_PreNote) or _item.isKindOf(CM_BookingRefItem) then
		self.setGeneralCargoDetails(_item);
	endif;

	//+cnwml2 PAR23715 SFW CCMS1131
	self.setSealDetails(_item);
	
	//cnwmc5 - 27 August 2014 - PAR 34818
	self.clearReeferDetails();
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromPreNote" id="d080c453-0262-49ca-9623-6edf276295d3">
        <updating/>
        <source>setFieldsFromPreNote(_ti: CM_TrackedItem) updating, protected;

/*
Date			Who		Reason
26 January 2012	cnwar2	Initial creation - #28860

*/
vars
	gteClass : Class;
	
begin
	inheritMethod(_ti);

	if self.isFlexiGateForm then
		if self.myPxyGTEEntity &lt;&gt; null then
			return;		// prenote fields already prefilled from PIN
		endif;

		gteClass := _ti.getGTEClassToCreate();
		create self.myPxyGTEEntity as gteClass transient;
		self.myPxyGTEEntity.setPxyFromTI(_ti);
		self.setFieldsFromGTEEntity(self.myPxyGTEEntity);
	else
		self.setFieldsFromItem(_ti);	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setGeneralCargoDetails" id="0a615794-ab78-4a34-b2f5-e5d9995a2a63">
        <updating/>
        <source>setGeneralCargoDetails(_item : Object) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/08/2009	cnwdap1	Initial creation
12/10/2009	cnwdap1	PAR #21125 call doOpenCloseDimensions to open the dimensions section when editing
13/10/2009	cnwdap1	PAR #21098 Set fields from booking item (if we are prenoting an existing booking item)
17/02/2010	cnwdap1	PAR #22397 New parameter for setDimTypeDetails method
17/02/2010	cnwdap1	PAR #21624 Display dimensions with no decimal places
06/04/2010	cnwdap1	PAR #23442 Open dimensions section if we have a TI (used to call doOpenCloseDimensionsSection regardless, which meant it would close it if already open
								as would happen for Timber and Vehicles as these are opened specifically already before we get here
13/04/2010	cnwdap1	PAR #23673 Remove usage of cnEcStripDecimalZeros - this doesn't work with locales
04/08/2010	cnwdap1	PAR #25296 Set total volume text box for general cargo
28/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
24/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - display booking ref item product weight and volume, not total weight and volume
20/02/2018 	cnwer1	removed all the commented out code i.e half this method
19/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/
vars
	breakBulk		: CM_BreakBulkGeneric;
	preNote			: CMIF_PreNote;
	receival		: CMGTE_Receival;
	brItem			: CM_BookingRefItem;
	receivalByType 	: CMGTE_ReceivalByType; //cnwas3 par 26524
	product			: CM_Product;			// PAR #31155
	measure			: CM_MeasurementType;	// PAR #31155
	cargoType		: CM_CargoType;			// PAR #31155

begin
	if _item.isKindOf(CM_BreakBulkGeneric) then
		
		breakBulk := _item.CM_BreakBulkGeneric;
		product := breakBulk.myProduct;													// PAR #31155
		if product = null then															// PAR #31155
			product := breakBulk.myCargoType.mySystemProductType;						// PAR #31155
		endif;																			// PAR #31155
		
		self.cmbSubCargo.setForObject(breakBulk.myProduct);
		if product &lt;&gt; null and product.getMyLength &lt;&gt; null and product.getMyLength.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyLength.myMeasurementType;							// PAR #31155
			self.tblLength.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.length.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblLength.setValueDefault(breakBulk.length.String);					// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyWidth &lt;&gt; null and product.getMyWidth.myMeasurementType &lt;&gt; null then		// PAR #31155
			measure := product.getMyWidth.myMeasurementType;							// PAR #31155
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.width.Decimal) &amp; Space &amp; measure.shortName);	// PAR #31155
		else																			// PAR #31155
			self.tblWidth.setValueDefault(breakBulk.width.String);						// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyHeight &lt;&gt; null and product.getMyHeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyHeight.myMeasurementType;							// PAR #31155
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.height.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblHeight.setValueDefault(breakBulk.height.String);					// PAR #31155
		endif;																			// PAR #31155
		
		self.txtLengthText.setValue(breakBulk.lengthString);
		self.txtWidthText.setValue(breakBulk.widthString);
		self.txtHeightText.setValue(breakBulk.heightString);
		
		self.setQuantityValueFormObject( breakBulk ); //04 Mar 2014	NDL	Par 33596
		if product &lt;&gt; null and product.getMyWeight &lt;&gt; null and product.getMyWeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyWeight.myMeasurementType;							// PAR #31155
			self.tblWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.unsplitWeight.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblWeight.setValueDefault(breakBulk.unsplitWeight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.myDensityDec &lt;&gt; null and product.myDensityDec.myMeasurementType &lt;&gt; null then		// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			measure := product.myDensityDec.myMeasurementType;								// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			self.tblDensity.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.density.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblDensity.setValueDefault(breakBulk.density.asStringJMT);				// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyVolume &lt;&gt; null and product.getMyVolume.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyVolume.myMeasurementType;							// PAR #31155
			self.tblVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.unsplitVolume.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
			self.tblTotalVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.unsplitVolume.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblVolume.setValueDefault(breakBulk.unsplitVolume.asStringJMT);		// PAR #31155
			self.tblTotalVolume.setValueDefault(breakBulk.unsplitVolume.asStringJMT);	// PAR #31155
		endif;																			// PAR #31155		
		self.txtAlternativeId.setValue(breakBulk.alternativeId);
		self.txtMark.setValue(breakBulk.mark);
		self.txtMarkNumber.setValue(breakBulk.markNumber);
		
		self.setDimTypeDetails(breakBulk.myCargoType, breakBulk.myProduct, breakBulk.type);			// 19/11/2009 cnwmh5 par21492
		// jlika1 TFS 53316 --&gt;
		measure := app.getDefaultMeasurementForType(Type_Length);
		//self.tblDiameter.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.diameter.Decimal) &amp; Space &amp; measure.shortName);
		self.tblDiameter.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.getDiameter().Decimal) &amp; Space &amp; measure.shortName); 			// ### TFS 54021 29June2022 NAVPW1
		//self.txtGrade.setValue(breakBulk.grade);
		self.txtGrade.setValue(breakBulk.getGrade());																											// ### TFS 54021 29June2022 NAVPW1
		//self.txtGrammage.setValue(breakBulk.grammage.Decimal);
		self.txtGrammage.setValue(breakBulk.getGrammage().Decimal);																								// ### TFS 54021 29June2022 NAVPW1
		//self.tblRollingLength.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.rollingLength.Decimal) &amp; Space &amp; measure.shortName);
		self.tblRollingLength.setValues(app.convertMeasurementForDisplay(measure.shortName, breakBulk.getRollingLength().Decimal) &amp; Space &amp; measure.shortName);	// ### TFS 54021 29June2022 NAVPW1
		// jlika1 TFS 53316 &lt;--
	elseif _item.isKindOf(CMIF_PreNote) then
	
		preNote := _item.CMIF_PreNote;
		product := preNote.myProduct;													// PAR #31155
		if product = null then															// PAR #31155
			cargoType := app.myRoot.allCargoTypesById[preNote.cargoType];				// PAR #31155
			product := cargoType.mySystemProductType;									// PAR #31155
		endif;																			// PAR #31155

		self.cmbSubCargo.setForObject(product);	//18 Oct 2013	NDL	Par 32616
		if product &lt;&gt; null and product.getMyLength &lt;&gt; null and product.getMyLength.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyLength.myMeasurementType;							// PAR #31155
			self.tblLength.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.length.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblLength.setValueDefault(preNote.length.String);						// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyWidth &lt;&gt; null and product.getMyWidth.myMeasurementType &lt;&gt; null then		// PAR #31155
			measure := product.getMyWidth.myMeasurementType;							// PAR #31155
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.width.Decimal) &amp; Space &amp; measure.shortName);	// PAR #31155
		else																			// PAR #31155
			self.tblWidth.setValueDefault(preNote.width.String);						// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyHeight &lt;&gt; null and product.getMyHeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyHeight.myMeasurementType;							// PAR #31155
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.height.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblHeight.setValueDefault(preNote.height.String);						// PAR #31155
		endif;																			// PAR #31155

		self.txtLengthText.setValue(preNote.lengthString);
		self.txtWidthText.setValue(preNote.widthString);
		self.txtHeightText.setValue(preNote.heightString);
		
		self.setQuantityValueFormObject( preNote ); //04 Mar 2014	NDL	Par 33596
		self.setNumItemsValueFormObject( preNote ); //08 July 2014	NDL Par 34526 
		if product &lt;&gt; null and product.getMyWeight &lt;&gt; null and product.getMyWeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyWeight.myMeasurementType;							// PAR #31155
			self.tblWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.weight.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
			self.tblTotalWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.weightTotal.Decimal) &amp; Space &amp; measure.shortName);	//08 July 2014	NDL Par 34526
		else																			// PAR #31155
			self.tblWeight.setValueDefault(preNote.weight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
			self.tblTotalWeight.setValueDefault(preNote.weightTotal.asStringJMT);	//08 July 2014	NDL Par 34526 
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.myDensityDec &lt;&gt; null and product.myDensityDec.myMeasurementType &lt;&gt; null then		// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			measure := product.myDensityDec.myMeasurementType;								// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			self.tblDensity.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.density.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblDensity.setValueDefault(preNote.density.asStringJMT);				// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyVolume &lt;&gt; null and product.getMyVolume.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyVolume.myMeasurementType;							// PAR #31155
			self.tblVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, preNote.volume.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblVolume.setValueDefault(preNote.volume.asStringJMT);					// PAR #31155
		endif;																			// PAR #31155
		
		self.txtAlternativeId.setValue(preNote.alternativeId);
		self.txtMark.setValue(preNote.mark);
		self.txtMarkNumber.setValue(preNote.markNumber);
	
	elseif _item.isKindOf(CMGTE_Receival) then
	
		receival := _item.CMGTE_Receival;
		product := receival.myProduct;													// PAR #31155
		if product = null then															// PAR #31155
			cargoType := app.myRoot.allCargoTypesById[receival.cargoType];				// PAR #31155
			product := cargoType.mySystemProductType;									// PAR #31155
		endif;																			// PAR #31155
		
		self.cmbSubCargo.setForObject(receival.myProduct);
		
		if product &lt;&gt; null and product.getMyLength &lt;&gt; null and product.getMyLength.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyLength.myMeasurementType;							// PAR #31155
			self.tblLength.setValues(app.convertMeasurementForDisplay(measure.shortName, receival.length.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblLength.setValueDefault(receival.length.String);						// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyWidth &lt;&gt; null and product.getMyWidth.myMeasurementType &lt;&gt; null then		// PAR #31155
			measure := product.getMyWidth.myMeasurementType;							// PAR #31155
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measure.shortName, receival.width.Decimal) &amp; Space &amp; measure.shortName);	// PAR #31155
		else																			// PAR #31155
			self.tblWidth.setValueDefault(receival.width.String);						// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyHeight &lt;&gt; null and product.getMyHeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyHeight.myMeasurementType;							// PAR #31155
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measure.shortName, receival.height.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblHeight.setValueDefault(receival.height.String);						// PAR #31155
		endif;																			// PAR #31155
		
		self.txtLengthText.setValue(receival.lengthString);
		self.txtWidthText.setValue(receival.widthString);
		self.txtHeightText.setValue(receival.heightString);

		self.setQuantityValueFormObject( receival ); //04 Mar 2014	NDL	Par 33596
		if product &lt;&gt; null and product.getMyWeight &lt;&gt; null and product.getMyWeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyWeight.myMeasurementType;							// PAR #31155
			self.tblWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, receival.weight.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblWeight.setValueDefault(receival.weight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.myDensityDec &lt;&gt; null and product.myDensityDec.myMeasurementType &lt;&gt; null then		// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			measure := product.myDensityDec.myMeasurementType;								// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			self.tblDensity.setValues(app.convertMeasurementForDisplay(measure.shortName, receival.density.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblDensity.setValueDefault(receival.density.asStringJMT);				// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyVolume &lt;&gt; null and product.getMyVolume.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyVolume.myMeasurementType;							// PAR #31155
			self.tblVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, receival.getMyVolume.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblVolume.setValueDefault(receival.getMyVolume.asStringJMT);			// PAR #31155
		endif;																			// PAR #31155
		
		self.txtAlternativeId.setValue(receival.alternativeId);
		self.txtMark.setValue(receival.mark);
		self.txtMarkNumber.setValue(receival.markNumber);
	
	elseif _item.isKindOf(CMGTE_ReceivalByType) then				//cnwas3 par 26524 begin
	
		receivalByType := _item.CMGTE_ReceivalByType;
		product := receivalByType.myProduct;											// PAR #31155
		
		self.cmbSubCargo.setForObject(receivalByType.myProduct);		
		
		if product &lt;&gt; null and product.getMyLength &lt;&gt; null and product.getMyLength.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyLength.myMeasurementType;							// PAR #31155
			self.tblLength.setValues(app.convertMeasurementForDisplay(measure.shortName, receivalByType.length.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblLength.setValueDefault(receivalByType.length.String);				// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyWidth &lt;&gt; null and product.getMyWidth.myMeasurementType &lt;&gt; null then		// PAR #31155
			measure := product.getMyWidth.myMeasurementType;							// PAR #31155
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measure.shortName, receivalByType.width.Decimal) &amp; Space &amp; measure.shortName);	// PAR #31155
		else																			// PAR #31155
			self.tblWidth.setValueDefault(receivalByType.width.String);					// PAR #31155
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyHeight &lt;&gt; null and product.getMyHeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyHeight.myMeasurementType;							// PAR #31155
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measure.shortName, receivalByType.height.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblHeight.setValueDefault(receivalByType.height.String);				// PAR #31155
		endif;																			// PAR #31155
		self.autoCalcVolume();
		
		self.txtLengthText.setValue(receivalByType.lengthString);
		self.txtWidthText.setValue(receivalByType.widthString);
		self.txtHeightText.setValue(receivalByType.heightString);
		
		self.setQuantityValueFormObject( receivalByType ); //04 Mar 2014	NDL	Par 33596
		if product &lt;&gt; null and product.getMyWeight &lt;&gt; null and product.getMyWeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyWeight.myMeasurementType;							// PAR #31155
			self.tblWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, receivalByType.weight.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblWeight.setValueDefault(receivalByType.weight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		endif;																			// PAR #31155
		if product &lt;&gt; null and product.getMyVolume &lt;&gt; null and product.getMyVolume.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyVolume.myMeasurementType;							// PAR #31155
			self.tblVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, receivalByType.getMyVolume.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																			// PAR #31155
			self.tblVolume.setValueDefault(receivalByType.getMyVolume.asStringJMT);		// PAR #31155
		endif;																			// PAR #31155
		
		self.txtMark.setValue(receivalByType.mark);
		self.txtMarkNumber.setValue(receivalByType.markNumber);			//cnwas3 par 26524 end
		
		//05 Mar 2014	NDL	Par 33596
		self.chkDirDel.setValue( receivalByType.directDelivery );
		self.txtEquipXchg.setValue(receivalByType.eirNumber);
		self.cmbFreightFwdr.setForObject(app.myRoot.allConsigneeConsignors[receivalByType.freightForwarderCode]);
		self.cmbVoyageCode.setObject(self.myTerminal.lookupVoyage(receivalByType.voyageCode, null, false));
	
		if receivalByType.myReceivalInfo.myBookingItem &lt;&gt; null then	// 10/12/2010 cnwmh5 #26556
			//self.txtDensity.setValue(receivalByType.myReceivalInfo.myBookingItem.density.asStringJMT);		// PAR #31155
			self.tblDensity.setValueDefault(receivalByType.myReceivalInfo.myBookingItem.density.asStringJMT);	// PAR #31155
			self.setDimTypeDetails(receivalByType.myReceivalInfo.myCargoType, receivalByType.myReceivalInfo.myBookingItem.myProduct, 
				receivalByType.myReceivalInfo.myBookingItem.typeString);	
			self.cmbSubCargo.setForObject(receivalByType.myReceivalInfo.myBookingItem.myProduct);
		endif;
	
	elseif _item.isKindOf(CM_BookingRefItem) then
	
		brItem := _item.CM_BookingRefItem;
		product := brItem.myProduct;												// PAR #31155
		if product = null then														// PAR #31155
			product := brItem.myCargoType.mySystemProductType;						// PAR #31155
		endif;																		// PAR #31155
		
		self.cmbSubCargo.setForObject(brItem.myProduct);
		
		if product &lt;&gt; null and product.getMyLength &lt;&gt; null and product.getMyLength.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyLength.myMeasurementType;						// PAR #31155
			self.tblLength.setValues(app.convertMeasurementForDisplay(measure.shortName, brItem.length.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																		// PAR #31155
			self.tblLength.setValueDefault(brItem.length.String);					// PAR #31155
		endif;																		// PAR #31155
		if product &lt;&gt; null and product.getMyWidth &lt;&gt; null and product.getMyWidth.myMeasurementType &lt;&gt; null then		// PAR #31155
			measure := product.getMyWidth.myMeasurementType;						// PAR #31155
			self.tblWidth.setValues(app.convertMeasurementForDisplay(measure.shortName, brItem.width.Decimal) &amp; Space &amp; measure.shortName);	// PAR #31155
		else																		// PAR #31155
			self.tblWidth.setValueDefault(brItem.width.String);						// PAR #31155
		endif;																		// PAR #31155
		if product &lt;&gt; null and product.getMyHeight &lt;&gt; null and product.getMyHeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyHeight.myMeasurementType;						// PAR #31155
			self.tblHeight.setValues(app.convertMeasurementForDisplay(measure.shortName, brItem.height.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																		// PAR #31155
			self.tblHeight.setValueDefault(brItem.height.String);					// PAR #31155
		endif;																		// PAR #31155
		
		self.txtLengthText.setValue(brItem.lengthString);
		self.txtWidthText.setValue(brItem.widthString);
		self.txtHeightText.setValue(brItem.heightString);
		
		self.setQuantityValueFormObject( brItem ); //04 Mar 2014	NDL	Par 33596
		if product &lt;&gt; null and product.getMyWeight &lt;&gt; null and product.getMyWeight.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyWeight.myMeasurementType;						// PAR #31155
			self.tblWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, brItem.productWeight.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155	// PAR #33606
		else																		// PAR #31155
			self.tblWeight.setValueDefault(brItem.productWeight.asStringJMT);	//25 Oct 2013	NDL	Par 32720														// PAR #33606
		endif;																		// PAR #31155
		if product &lt;&gt; null and product.myDensityDec &lt;&gt; null and product.myDensityDec.myMeasurementType &lt;&gt; null then		// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			measure := product.myDensityDec.myMeasurementType;							// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
			self.tblDensity.setValues(app.convertMeasurementForDisplay(measure.shortName, brItem.density.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155
		else																		// PAR #31155
			self.tblDensity.setValueDefault(brItem.density.asStringJMT);			// PAR #31155
		endif;																		// PAR #31155
		if product &lt;&gt; null and product.getMyVolume &lt;&gt; null and product.getMyVolume.myMeasurementType &lt;&gt; null then	// PAR #31155
			measure := product.getMyVolume.myMeasurementType;						// PAR #31155
			self.tblVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, brItem.productVolume.Decimal) &amp; Space &amp; measure.shortName);// PAR #31155	// PAR #33606
		else																		// PAR #31155
			self.tblVolume.setValueDefault(brItem.productVolume.asStringJMT);			// PAR #31155																// PAR #33606
		endif;																		// PAR #31155
		
		self.txtMark.setValue(brItem.shippingMarks);
		self.txtMarkNumber.setValue(brItem.markNumber);
		
		self.setDimTypeDetails(brItem.myCargoType, brItem.myProduct, brItem.typeString);			// 19/11/2009 cnwmh5 par21492

	endif;
	
	if _item &lt;&gt; null and self.closedDimensions then		// PAR #23442
		self.doOpenCloseDimensionsSection();
	endif;
	
epilog

end;</source>
