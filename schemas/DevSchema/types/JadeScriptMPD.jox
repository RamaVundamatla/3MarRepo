    </JadeMethod>
    <JadeMethod name="mpdFind3195Oids" id="fafc5f52-a942-403d-a94c-d53014db579b">
        <source>mpdFind3195Oids();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 June 2021	navmd1	Initial creation - based on Jadescript::certifyForPAR60493

*/

constants
	DAT_FILE : String = "cmsmap";	// don't include the .dat
vars
	dba				: JadeDatabaseAdmin;
	dbFiles			: DbFileArray;
	dbFile			: DbFile;
	certifyLogFile	: File;
	now				: TimeStamp;
	result 			: Integer;
	readOnlySet		: Boolean;
	certFileText	: String;
begin
	// Activate CnKarmaCntrl for logging
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	
	// Firstly rename any existing certify log file
	create certifyLogFile transient;
	certifyLogFile.usePresentationFileSystem := false;
	certifyLogFile.fileName := app.myCnCntrl.logPath &amp; "\certify.log";
	
	if certifyLogFile.isAvailable() then
		certifyLog("Renaming existing certify.log file");
		certifyLogFile.rename(app.myCnCntrl.logPath &amp; "\certify" &amp; "_" &amp; now.getNumeralString &amp; ".log");
	endif;

	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	
	foreach dbFile in dbFiles where dbFile.getFileStatus() = DbFile.Status_Resident do
		if not dbFile.name = DAT_FILE then
			continue;
		endif;
		
		write "Starting certify of " &amp; dbFile.name;
		
		dbFile.changeAccessMode(DbFile.Mode_ReadOnly);
		readOnlySet := true;
		result := result + dbFile.certifyFile();
		dbFile.changeAccessMode(DbFile.Mode_Update);
		readOnlySet := false;
		
		write "Certify of " &amp; dbFile.name &amp; " complete, duration " &amp; (app.actualTime - now).String &amp; ", " &amp; result.String &amp; " errors detected";
		
		break;
	endforeach;
	
	if result = 0 then
		return;
	endif;
	
	certFileText := certifyLogFile.readString(certifyLogFile.fileLength);
	write certFileText;

epilog
	if readOnlySet then
		dbFile.changeAccessMode(DbFile.Mode_Update);
	endif;
	
	delete certifyLogFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdFindBadXlatExceptions" id="a5030cc8-bd27-44ed-bb22-74b8fbb0ff11">
        <source>mpdFindBadXlatExceptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 October 2022	navmd1	Initial creation

*/

vars
	schema 			: Schema;
	category		: ConstantCategory;
	allConstants,
	badConstants	: ConstantNDict;
	const			: Constant;
	dyna			: DynaDictionary;
begin
	schema := rootSchema.getSchema(PortSchemaName);
	category := schema.getConstantCategory(XLAT_Exceptions);
	allConstants := category.cnEcGetConstants();
	
	create badConstants transient;
	
	create dyna transient;
	dyna.setMembership(Constant);
	dyna.addExternalKey(TimeStamp, 0, true, false);
	dyna.endKeys(true);
	
	foreach const in allConstants do
		if const.numScriptRefs = 0 then
			badConstants.add(const);
			dyna.putAtKey(const.creationTime, const); 
		endif;
	endforeach;
	
	if badConstants.size = 0 then
		write "No bad XLAT Exceptions found :)";
		return;
	endif;
	
	write "Found: " &amp; badConstants.size.String &amp; " XLAT Exceptions without references";
		
	foreach const in badConstants do
		write const.name &amp; Tab &amp; const.getSource() &amp; Tab &amp; const.creationTime.String;
	endforeach;
	
	badConstants.inspectModal();
	dyna.inspectModal();
epilog
	delete badConstants;
	delete dyna;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdFindWebProcAtTime" id="da395043-63e1-4604-83f9-faa20fe602b2">
        <source>mpdFindWebProcAtTime();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2019	jlgmd1	Initial creation

*/

vars
begin
	// Use Options -&gt; Log Parser instead
end;

/*constants
	ProcName : String = "JMTWebService/831";
	DateTime : TimeStamp = "09/08/2019 16:28:06.578".TimeStamp;
	
	LogDirectory : String = "C:\Temp\TFS\TFS43812\5-11 Aug\PELPJMT_LogArchive_20190809235716\pelpjmt\logs\archive\cnwhousekeeper";
	
	START_MAGIC : String = "input=";
	ENV_OVERRIDE : String = "";		// enter the environment name here, if auto detection fails
vars
	folder		: FileFolder;
	file		: FileNode;
	str,
	envName,
	dateStr,
	tmpStr,
	curLine		: String;
	idx,
	i			: Integer;
	kvDict		: CM_AssociationDict;
	kvVal		: CM_Association;
	iter		: Iterator;
	badDate		: Boolean;
	sa			: StringArray;
	
	endStr,
	firstStr	: String;
begin
	create folder transient;
	folder.mask := "cn_*.log";
	folder.usePresentationFileSystem := true;
	folder.fileName := LogDirectory;
	
	// ************************************************************************
	// Have a guess what environment we are
	if ENV_OVERRIDE &lt;&gt; null then
		envName := ENV_OVERRIDE;
		write "Environment detected: " &amp; envName &amp; " (override)";
	else
		create kvDict transient;
		foreach file in folder.files do
			idx := 4;
			envName := file.name.scanUntil("0123456789", idx).toUpper;
			kvVal := kvDict[envName];
			if kvVal = null then
				kvDict.addAssoc(envName, 1);
			else
				kvVal.setValue(kvVal.asInteger+1);
			endif;
		endforeach;
		idx := 0;
		iter := kvDict.createIterator();
		while iter.next(kvVal) do
			if kvVal.asInteger &gt; idx then
				envName := iter.getCurrentKey(1).String.toLower;
				idx := kvVal.asInteger;
			endif;
		endwhile;
		create sa transient;
		envName.getTokensForDelimiter("_", sa);
		envName := sa[1];
		write "Environment detected: " &amp; envName;
	endif;
	// ************************************************************************
	
	delete iter;
	folder.mask := "cn_" &amp; envName &amp; "*.log";
	iter := folder.files.createIterator();
	
	// ************************************************************************
	// Start by finding the first log file modified after the timestamp
	write "Starting forward search...";
	while iter.next(file) do :forwardFind
		if file.cnEcIsFolder then continue; endif;
		if file.lastModifiedTime &lt; DateTime then continue; endif;
		
		write file.name;
		file.File.seek(0);	// make sure we start at the beginning
		str := file.File.readString(file.File.fileLength);
		
		idx := str.pos(ProcName, 1);
		while idx &gt; 0 do
			// Found!
			idx := str.reversePosIndex(CrLf, idx);								// go to the beginning of the line
			if idx = 0 then idx := 1; endif;									// reversPosIndex returns 0 when it hits the beginning of the file
			str.scanWhile(CrLf, idx);
			
			// The 'end of the line' might actually be split across multiple lines
			// So keep reading until the next date segment
			badDate := false;
			dateStr := str.scanUntil(" ", idx);
			if dateStr.length &lt; 10 then
				badDate := true;
			endif;
			
			curLine := null;
			tmpStr := str.scanUntil(CrLf, idx);									// and grab all text until the end
			
			if badDate then
				curLine := dateStr &amp; tmpStr;
			else
				while tmpStr.pos(dateStr, 1) &lt;&gt; 1 and idx &gt; 0 do
					if curLine = null then
						curLine := dateStr &amp; tmpStr;
					else
						curLine := curLine &amp; CrLf &amp; tmpStr;
					endif;
					
					str.scanWhile(CrLf, idx);
					if idx &gt; 0 then
						tmpStr := str.scanUntil(CrLf, idx);
					endif;
				endwhile;
			endif;
			
			if curLine[1:23].TimeStamp &lt; DateTime then
				curLine := null;
			endif;
			
			if curLine.pos(START_MAGIC, 1) &gt; 0 then
				break forwardFind;												// We've found the next start message, so we can stop looping now
			endif;
			
			if endStr = null then
				endStr := curLine;
			else
				endStr := endStr &amp; CrLf &amp; curLine;
			endif;
			//write "LAST: " &amp; endStr;
			
			if idx &gt; 0 then
				idx := str.pos(ProcName, idx);									// Find-next
			endif;
			
			// ... and repeat
		endwhile;
	endwhile;
	iter.next(file);	// Go forward one log, so the reverseFind starts at the current log
	// ************************************************************************
	
	if endStr = null then
		write "Error, unable to find web message for " &amp; ProcName &amp; "@" &amp; DateTime.String;
		return;
	endif;
	
	// ************************************************************************
	// Then find the first mention of it before the current log
	//foreach file in folder.files reversed where file.lastModifiedTime &lt;= DateTime do :reverseFind
	write "Starting reverse search...";
	while iter.back(file) do :reverseFind
		if file.cnEcIsFolder then continue; endif;
		
		write file.name;
		file.File.seek(0);	// make sure we start at the beginning
		str := file.File.readString(file.File.fileLength);
		
		idx := str.reversePos(ProcName);
		while idx &gt; 0 do
			// Found!
			idx := str.reversePosIndex(CrLf, idx);								// go to the beginning of the line
			if idx = 0 then idx := 1; endif;									// reversPosIndex returns 0 when it hits the beginning of the file
			str.scanWhile(CrLf, idx);
			
			// The 'end of the line' might actually be split across multiple lines
			// So keep reading until the next date segment
			badDate := false;
			dateStr := str.scanUntil(" ", idx);
			if dateStr.length &lt; 10 then
				badDate := true;
			endif;
			
			curLine := null;
			tmpStr := str.scanUntil(CrLf, idx);									// and grab all text until the end
			
			if badDate then
				curLine := dateStr &amp; tmpStr;
			else
				while tmpStr.pos(dateStr, 1) &lt;&gt; 1 and idx &gt; 0 do
					if curLine = null then
						curLine := dateStr &amp; tmpStr;
					else
						curLine := curLine &amp; CrLf &amp; tmpStr;
					endif;
					
					str.scanWhile(CrLf, idx);
					if idx &gt; 0 then
						tmpStr := str.scanUntil(CrLf, idx);
					endif;
				endwhile;
			endif;
			
			if curLine[1:23].TimeStamp &gt; DateTime then
				curLine := null;
			endif;
			
			if firstStr = null then
				firstStr := curLine;
			else
				firstStr := curLine &amp; CrLf &amp; firstStr;
			endif;
			//write "FIRST: " &amp; firstStr;
			
			if curLine.pos(START_MAGIC, 1) &gt; 0 then
				break reverseFind;												// We've found our start message, so we can stop looping now
			endif;

			if idx = 0 then
				idx := file.File.fileLength;									// idx will be 0 here if we're the very last line in the log
			endif;
			
			idx := idx - 1;		// Cr/Lf
			idx := str.reversePosIndex(CrLf, idx);								// Back to the beginning of the curLine
			idx := str.reversePosIndex(ProcName, idx);							// back to where we started
			idx := str.reversePosIndex(ProcName, idx);							// Find-previous
			
			// ... and repeat
		endwhile;
	endwhile;
	// ************************************************************************
	
	write firstStr;
	write "******** PING REQUEST HERE (ish) ********";		// Not always - this is just the log modified time boundry
	write endStr;
	
	write CrLf &amp; "Done";
	write "(If you only see done, then save the output to file)";
epilog
	delete folder;
	if kvDict &lt;&gt; null then
		kvDict.purge();
	endif;
	delete kvDict;
	delete sa;
	delete iter;
end;*/</source>
    </JadeMethod>
    <JadeMethod name="mpdFixDebtorAddresses" id="3ff02d03-d7e4-483e-9d8f-4996a85cf993">
        <source>mpdFixDebtorAddresses();

/*

Purpose:			Helper script to keep the data the same after re-creating the CM_AddressByCode collection.
					WMAST: MemberKeyDictionary
					DMAST: CM_MemberKeyDictionary	-&gt;	MemberKeyDictionary

Parameters:			

Return Value:		


Date				Who		Reason
30 January 2020		jlgmd1	Initial creation

*/

constants
	CLEARREFS	: Boolean = false;
vars
	datFile		: File;
	now			: TimeStamp;
	oa			: ObjectArray;
	obj			: Object;
	debtor		: CM_Debtor;
	address		: CM_Address;
	line		: String;
	hasAddress	: Boolean;
	isOk		: Boolean;
	idx			: Integer;
	datName		: String;
begin
	create datFile transient;
	
	datName := method.name &amp; "_" &amp; now.fileNameFormat &amp; ".dat";
	
	if not CLEARREFS then
		datName := "Previous DAT File Name &lt;" &amp; datName &amp; "&gt;";
		read datName;
	endif;
	
	if datName = null then
		return;
	endif;

	datFile.fileName := datName;
	datFile.usePresentationFileSystem := true;
	datFile.mode := File.Mode_IO;
	datFile.kind := File.Kind_ANSI;
	
	beginTransaction;
	
	if CLEARREFS then
	
		create oa transient;
		CM_Debtor.allInstances(oa, 0, true);
		foreach obj in oa discreteLock do
			debtor := obj.CM_Debtor;
			line := debtor.getOidAsString();
			hasAddress := false;
			foreach address in debtor.allAddressesByCode do
				line := line &amp; "|" &amp; address.getOidAsString();
				address.setPropertyValue(CM_Address::myDebtor.name, null);
				hasAddress := true;
			endforeach;
			if hasAddress then
				datFile.writeLine(line);
			endif;
		endforeach;
		
	else
		
		line := datFile.readLine();
		while line &lt;&gt; null do
			idx := 1;
			debtor := line.scanUntil("|", idx).asOid.CM_Debtor;
			if not app.isValidObject(debtor) then
				write debtor.getOidAsString &amp; " is Invalid!";
				continue;
			endif;
			
			while idx &gt; 0 do
				idx := idx + 1;
				address := line.scanUntil("|", idx).asOid.CM_Address;
				if not app.isValidObject(address) then
					write address.getOidAsString &amp; " is Invalid!";
				endif;
				address.setPropertyValue(CM_Address::myDebtor.name, debtor);
			endwhile;
		
			line := datFile.readLine();
		endwhile;
	
	endif;
	
	CM_Debtor.inspectModal;
	
	commitTransaction;
	//abortTransaction;
	
	isOk := true;
epilog
	if not isOk then
		abortTransaction;
	endif;

	if datFile &lt;&gt; null then
		datFile.close();
		delete datFile;
	endif;
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdFixInvalidDataTables" id="c45a6ca3-4bb1-4cfb-bd77-74af2ba0183c">
