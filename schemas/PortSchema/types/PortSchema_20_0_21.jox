    </JadeMethod>
    <JadeMethod name="updateVBSSlotTypes" id="342dfb7e-b762-4dd3-b635-4b354b718078">
        <source>updateVBSSlotTypes(_controller : CnEcReleaseController);
/*

Purpose:			Creates new VBS slot types on terminal and migrates all the VBS slots to use the new type.
					Also Migrates the Vehicle Booking Time Templates to use the new time slot type.
					Finally at the end deletes all the VBS Time slot types that do not have a myTerminal reference set on them

Parameters:			

Return Value:		

Date			Who		Reason
24 January 2023	navpw1	Initial creation TFS: 53697 (55830) Upgrade Script for adding new VBS Processes
16 March 2023	navpw1	TFS: 57158 - Issue with Vehicle Booking Slot Upgrade script - Fixed the elseif statements below to be if statements

*/

vars
	terminal				: CM_Terminal;
	slotTypeNew,
	slotType 				: CM_VehicleBookingTimeSlotType;
	vbsProcessStandard		: CM_VBSProcessStandard;
	
	dayTemplate				: CM_VehicleBookingDayTemplate;
	timeTemplate			: CM_VehicleBookingTimeTemplate;
	timeSlot				: CM_VehicleBookingTimeSlot;
	iter					: Iterator;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Updating VBS Slot Types", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating VBS Slot Types") ;	
	endif;
	
	vbsProcessStandard := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE].CM_VBSProcessStandard;
	
	beginTransaction;
	foreach slotType in CM_VehicleBookingTimeSlotType.instances do
		foreach terminal in app.myRoot.allTerminals do :terminalLoop
			//3- Copy the VBS Slot types to each terminal on the system
			if terminal.allTerminalVBSSlotTypes[slotType.code] = null then
				create slotTypeNew persistent;
				slotTypeNew.setPropertyValue(CM_VehicleBookingTimeSlotType::code.name, slotType.code);
				slotTypeNew.setPropertyValue(CM_VehicleBookingTimeSlotType::description.name, slotType.description);
				slotTypeNew.setPropertyValue(CM_VehicleBookingTimeSlotType::myTerminal.name, terminal);
				slotTypeNew.setPropertyValue(CM_VehicleBookingTimeSlotType::myVBSProcess.name, vbsProcessStandard);
			endif;
			
			vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
			
			if vehicleBookingTerminal = null then
				//Create Vehicle Booking Terminal object
				continue terminalLoop;
			endif;
			
			if vehicleBookingTerminal.allVehicleBookingDayTemplates.isEmpty and vehicleBookingTerminal.allVBTimeslotsById.isEmpty then
				continue;
			endif;
			
			if vehicleBookingTerminal.allVehicleBookingDayTemplates.isNotEmpty then
				//4- Update the Template of each terminal with the new ones created at each terminal matching with the code
				foreach dayTemplate in vehicleBookingTerminal.allVehicleBookingDayTemplates do
					if dayTemplate.allTimeTemplates.isEmpty then
						continue;
					endif;
					
					foreach timeTemplate in dayTemplate.allTimeTemplates do
						if timeTemplate.myVBTimeslotType = null or timeTemplate.myVBTimeslotType.code &lt;&gt; slotTypeNew.code then
							continue;
						endif;
						
						timeTemplate.setPropertyValue(CM_VehicleBookingTimeTemplate::myVBTimeslotType.name, slotTypeNew);
						
					endforeach;
					
				endforeach;
			endif;
			
			if vehicleBookingTerminal.allVBTimeslotsById.isNotEmpty then
				//5- Update The VBS Slots with the new VBS Types of the terminal matching with the code 
				foreach timeSlot in vehicleBookingTerminal.allVBTimeslotsById do
					if timeSlot.myVBTimeSlotType = null or timeSlot.myVBTimeSlotType.code &lt;&gt; slotTypeNew.code then
						continue;
					endif;
					
					timeSlot.setPropertyValue(CM_VehicleBookingTimeSlot::myVBTimeSlotType.name, slotTypeNew);
					
				endforeach;
				
			endif;
		endforeach;
		
	endforeach;
	commitTransaction;
	
	//6- Delete the VBS Slot types with myterminal = null 
	beginTransaction;
	iter := CM_VehicleBookingTimeSlotType.instances.createIterator;
	while iter.next(slotType) do
		if slotType.myTerminal &lt;&gt; null then
			continue;	
		endif;
		
		delete slotType;
		
	endwhile;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Updating VBS Slot Types complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Updating VBS Slot Types complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageProcesses" id="bcf30ddf-24d4-450e-a9e9-71f92d59eda8">
        <source>updateVoyageProcesses(_controller: CnEcReleaseController);
/*

Purpose:			Delete InaPortNet Voyage Process and Statuses
					Delete Pel1 voyage process
					Rename some old statuses

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars
	defaultProcess,
	inaPortNetProcess,
	pelindoProcess,
	woProcess				: CM_VoyageProcess;
	pxyStatus, realStatus 	: CM_VoyageStatus;
	terminal 				: CM_Terminal;
	defaultEmail 			: CM_VoyStatusDefaultEmail;
	defaultVP : String;
begin
	
	
	
	app.writeLog(method.qualifiedName &amp; " Deleting Unused Voyage Processes and Statuses", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Deleting Unused Voyage Processes and Statuses") ;	
	endif;
	
	beginTransaction;
	// inaportnet process is no longer needed, remove process and all statuses 
	inaPortNetProcess := CM_VoyageProcessIPN1.firstInstance;
	if inaPortNetProcess &lt;&gt; null then
		foreach realStatus in inaPortNetProcess.allStatusesById do
			delete realStatus;
		endforeach;
		delete inaPortNetProcess;	
	endif;
	
	// If the pelindo process was set as the default process, update to use mtnwo process
	foreach terminal in app.myRoot.allTerminals do
		defaultVP:=terminal.getConfig(DefaultVoyageProcess).String;
		if defaultVP = VoyageProcessPelindo1 then
			terminal.setConfig(DefaultVoyageProcess, VoyageProcessWO);
		elseif defaultVP = "JMT"  or defaultVP = null  then
			terminal.setConfig(DefaultVoyageProcess, VoyageProcessDefault);
		endif;
	endforeach;
	
	// pelindo process is being replaced by mtn work orders process.
	pelindoProcess := CM_VoyageProcessPEL1.firstInstance;	
	if pelindoProcess &lt;&gt; null then
		// status should have already by transfered by createWOVoyageProcess script run in specificPreStandard
		// but for sake of completeness, delete any that remain
		foreach realStatus in pelindoProcess.allStatusesById do
			delete realStatus;
		endforeach;
		delete pelindoProcess;
	endif;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Deleting Unused Voyage Processes and Statuses COMPLETE", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Deleting Unused Voyage Processes and Statuses COMPLETE") ;	
	endif;
	//jlier1 TFS 52213 lets make sure terminals have default set
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Renaming old voyage statuses to MTNWO status names", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renaming old voyage statuses to MTNWO status names") ;	
	endif;
	
	beginTransaction;
	woProcess := CM_VoyageProcessWO.firstInstance;
	if woProcess &lt;&gt; null then
		realStatus := woProcess.allStatusesById[Voyage_Status_VoyRequested];
		if realStatus &lt;&gt; null then
			// Rename voyage status 'Voyage Request - Manual ETMAL Required' to be 'Voyage Requested'
			pxyStatus := realStatus.pxyCreateUpdateProxy();
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Voyage Requested", woProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
		
		realStatus := woProcess.allStatusesById[Voyage_Status_VoyReqSubmitted];
		if realStatus &lt;&gt; null then
			// Rename voyage status 'ETMAL Calculated' to be 'Voyage Request Submitted'.
			pxyStatus := realStatus.pxyCreateUpdateProxy();
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Voyage Request Submitted", woProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
		
		// If default emails using the default subject line, update to new name
		defaultEmail := app.myRoot.allVoyStatusDefaultEmails[PINEmail_VoyVoyageRequested];
		if defaultEmail &lt;&gt; null and defaultEmail.subjectLine = "Voyage Requested (Manual PKK)" then
			defaultEmail.setPropertyValue( CM_VoyStatusDefaultEmail::subjectLine.name, "Voyage Requested");
		endif;
		defaultEmail := app.myRoot.allVoyStatusDefaultEmails[PINEmail_VoyReqSubmitted];
		if defaultEmail &lt;&gt; null and (defaultEmail.subjectLine = "ETMAL Calculated" or defaultEmail.subjectLine = "Voyage Requested (Manual PKK)") then
			defaultEmail.setPropertyValue( CM_VoyStatusDefaultEmail::subjectLine.name, "Voyage Request Submitted");
		endif;
	endif;		
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Renaming old voyage statuses to MTNWO status names COMPLETE", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renaming old voyage statuses to MTNWO status names COMPLETE") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete pxyStatus;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateWoDtlTransportMode" id="14bd7d6e-e4e1-4f1b-acc1-08ba6bda799a">
        <source>updateWoDtlTransportMode(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date	    Who		Reason
21 Dec 2022	navdp20 ChangeRequest 56661:[56013] - Add Transport Mode to Receive and Release work orders

*/

vars
	wodRel : CM_WodRelease;
	wodRec : CM_WodReceive;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Update Transport Mode", LogINFO); 
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Transport Mode") ;	
	endif;
	
	beginTransaction;
		foreach wodRel in CM_WodRelease.instances  do
			wodRel.setTransportMode(TI_TRANSMODE_ROAD);
		endforeach;
		
		foreach wodRec in CM_WodReceive.instances  do
			wodRec.setTransportMode(TI_TRANSMODE_ROAD);
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Transport Mode updated Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Transport Mode updated Complete");
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
