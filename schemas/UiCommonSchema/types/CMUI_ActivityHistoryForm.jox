    <JadeMethod name="doUserNotify" id="7c9fb46b-e93b-45cc-9735-0665f6e7c04d">
        <updating/>
        <source>doUserNotify(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) protected, updating;
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
vars
	tmpEvent	: Integer;
	tmpTerminal	: CM_Terminal;
	
begin

	//22 Nov 2018	NDL	TFS 42116
	if self.isPreSelected then
		return;
	endif;

	if self.displayType = DISPLAY_BOTH or self.displayType = DISPLAY_SYSTEM then
		if _eventType = EventSystemActivityAdd then
			self.handleAlertAdd(_userInfo.CM_ActivityHistory);
		elseif _eventType = EventSystemActivityDelete then
			self.handleAlertDelete(_userInfo.CM_ActivityHistory);
		endif;
	endif;
	if self.displayType = DISPLAY_BOTH or self.displayType = DISPLAY_TERMINAL then
		tmpTerminal := self.myTerminal;
		tmpEvent := tmpTerminal.getEventFromTerminalEvent(_eventType);
		if tmpEvent = EventTerminalActivityAdd then
			self.handleAlertAdd(_userInfo.CM_ActivityHistory);
		elseif tmpEvent = EventTerminalActivityDelete then
			self.handleAlertDelete(_userInfo.CM_ActivityHistory);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="filterCollectionByDate" id="fdafdb37-547a-499e-b727-7a6ac8c1c406">
        <source>filterCollectionByDate(_persistentSource : CM_ActivityByCreatedTsTypeDict;
					   _targetColl : Collection input) protected;

/*

Purpose:			Using the date range specified in self.queryDateFrom and self.queryDateTo,
					add any matching Activity History objects in the passed in persistent
					collection to the _targetColl

Parameters:			Persistent collection to copy from, and target to update

Return Value:		None


Date		Who		Reason
08 May 2009	cnwkpd1	PAR #19355 - Speed up Activity History form

*/

vars
	startTS,
	endTS			: TimeStamp;
	iter			: Iterator;
	activity		: CM_ActivityHistory;
	endTime			: Time;
	
begin
	startTS := null;
	if self.queryDateFrom.isValid then
		startTS.setDate(self.queryDateFrom);
		startTS.setTime( self.queryTimeFrom );	// 27 Oct 2011	NDL	Par 28449
	endif;
	
	endTS := null;
	if self.queryDateTo.isValid then
		//endTS.setDate(self.queryDateTo + 1);
		endTS.setDate(self.queryDateTo);	// 27 Oct 2011	NDL	Par 28449
		endTime.setTime( self.queryTimeTo.hour, self.queryTimeTo.minute, 59, 999);	// 28 Oct 2011	NDL	Par 28449
		endTS.setTime( endTime );	// 28 Oct 2011	NDL	Par 28449
	else
		//endTS.setDate(app.actualTimeServer.date + 1);
		endTS.setDate(app.actualTimeServer.date);// 27 Oct 2011	NDL	Par 28449
		endTS.setTime(app.actualTimeServer.time);// 28 Oct 2011	NDL	Par 28449
	endif;
	
	iter := _persistentSource.createIterator();
	_persistentSource.startKeyGeq(startTS, null, iter);
	
	while iter.next(activity) do
		if activity.dateTime &gt;= endTS then
			break;
		endif;
		
		_targetColl.add(activity);
	endwhile;
	
		
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_persistentSource" type="CM_ActivityByCreatedTsTypeDict"/>
        <Parameter name="_targetColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterObjectByDate" id="51e08556-ef1a-4ff3-ba77-9715e1c8c142">
        <source>filterObjectByDate(_activity : CM_ActivityHistory) : Boolean protected;
// Feb 2012 par 28754 filter activity history adds via notifications by the query date/times to avoid adding new instances
//  to an historical enquiry.
//  Return true if the history is within the dates otherwise false.
vars
	endTS			: TimeStamp;
	endTime			: Time;
	
begin
	if _activity = null then
		return false;
	endif;
	
	endTS := null;
	if self.queryDateTo.isValid then
		endTS.setDate(self.queryDateTo);
		endTime.setTime( self.queryTimeTo.hour, self.queryTimeTo.minute, 59, 999);
		endTS.setTime( endTime );
	else
		endTS.setDate(app.actualTimeServer.date);
		endTS.setTime(app.actualTimeServer.time);
	endif;
	
	return (_activity.dateTime &lt; endTS);
		
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_activity" type="CM_ActivityHistory"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="e2707577-0ce5-4846-b181-b08a03cc5d23">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2016	cnwndl1	Initial creation	Make Activity History form use column organiser

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );


epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleAlertAdd" id="03502769-41c4-49a8-a40c-447828cb4d5d">
        <updating/>
        <source>handleAlertAdd(_activityHistory : CM_ActivityHistory) updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if (not self.includeActivityHistory(_activityHistory, self.currentButton)) then
		return;
	endif;
	
	// 28754 filter notifications
	if not self.filterObjectByDate(_activityHistory) then
		return;
	endif;

	self.displayHistory(_activityHistory, self.tblActivity.fixedRows + 1);
	// also from 28754 update the form caption
	self.setFormCaption(self.tblActivity.rows - self.tblActivity.fixedRows);
end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistory"/>
    </JadeMethod>
    <JadeMethod name="handleAlertDelete" id="ad1c318e-d41b-4ce2-aaf5-c0b9ade4c454">
        <updating/>
        <source>handleAlertDelete(_alert : CM_ActivityHistory) updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.tblActivity.removeDeletedObject(_alert);
	self.setFormCaption(self.tblActivity.rows - self.tblActivity.fixedRows);
end;</source>
        <Parameter name="_alert" type="CM_ActivityHistory"/>
    </JadeMethod>
    <JadeMethod name="includeActivityHistory" id="bcb7d25a-f2c2-4cef-b49d-3555db191af3">
        <source>includeActivityHistory(_activity : CM_ActivityHistory; _currentButton : Integer) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 May 2009	cnwkpd1	PAR #19355 - Improve performance of Activity History form
					Added exception handling of invalid Activity History to caller

*/

vars
	
begin
//	Removed - PAR #19355
//	if not global.isValidObject(_activity) then // and alert.hasDetails then		
//		return false;
//	endif;

	//20 Sep 2019	NDL TFS 46655
	if self.queryString &lt;&gt; null then
		if _activity.description.pos( self.queryString, 1 ) &lt; 1
		and _activity.userCode.pos( self.queryString, 1 ) &lt; 1	//24 Sep 2019	NDL	TFS 4665
		then
			return false;
		endif;
	endif;
		
	if _currentButton = self.BTN_ALL then
		return true;
	elseif _activity.activityType = _currentButton then
		return true;
	else
		if _currentButton = ActivityHistoryCams and _activity.activityType = ActivityHistoryEmail then
			if _activity.CM_ActivityHistoryEmail.sourceOfEmail = EmailSource_CAMS then
				return true;
			endif;
		endif;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_activity" type="CM_ActivityHistory"/>
        <Parameter name="_currentButton" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="d757ca7d-443d-4b0e-95c9-c477c4ac0ba8">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	13 Jul 2016	NDL Make Activity History form use column organiser
// ---------------------------------------------------------------------------

vars

	entTableDef : EntTableDef;

begin

	self.tblActivity.rows := 0;
//	self.tblActivity.columns := 5;
//	self.tblActivity.addItem(Tab &amp; app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(Type_GC) &amp; Tab  &amp; app.getErrorString(Detail));
	self.tblActivity.fixedRows := 1;
	self.tblActivity.fixedColumns := 0;
	self.tblActivity.selectMode := Table.SelectMode_Row;
	self.tblActivity.accessMode := Table.AccessMode_Row;
	self.tblActivity.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblActivity.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblActivity.defaultRowHeight := 30; // TFS 50421 was - 17;
	self.tblActivity.allSelectedObjects.clear;
	
	
	entTableDef := app.myController.getEntTableDef(ETDef_ActivityDisplay);
	self.tblActivity.setMyEntTableDef( entTableDef );
	self.tblActivity.setTblDataEntRowsFromDef(entTableDef);
	

end;</source>
