/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2016	cnwndl1	Initial creation TFS 1752

*/

vars

	tAreaUtilisForm : CMUI_TermAreaUtilisationForm;

begin

	tAreaUtilisForm := app.getForm(CMUI_TermAreaUtilisationForm.name).CMUI_TermAreaUtilisationForm;

