    <DbClassMap file="basedocumentation"/>
    <ExplicitInverseRef name="allDocSchemas" id="c5d1432b-91d1-4486-98b6-4029813542af">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CnEcDocModelSchemaByNameDict"/>
        <access>readonly</access>
        <Inverse name="CnEcDocModelSchema::myDocList"/>
    </ExplicitInverseRef>
    <JadeMethod name="createDocSchema" id="c3088a5e-bd27-411d-b83e-0f12ae1aeaa6">
        <source>createDocSchema(pSchemaObj:Schema):CnEcDocModelSchema;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Create a Documentation Schema object, and return it to the caller.
//
// Parameters:	pSchemaObj - The Schema object to be represented by the Documentation
//					Schema object.
//
// Returns:		The newly created object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/03/2003	cnwdad1		Added check for duplicate schemas.
// --------------------------------------------------------------------------------
vars
	docSchemaObj	: CnEcDocModelSchema;
	
begin
	if self.allDocSchemas[pSchemaObj.name] &lt;&gt; null then
		CnEcBaseSchemaException.raise_(CNEC_X_03000, "Duplicate schema: " &amp; pSchemaObj.name);
	endif;
	
	if self.isTransient() then
		create docSchemaObj transient;
	else
		create docSchemaObj;
	endif;
	
	docSchemaObj.updateMe(pSchemaObj, self);
	
	return docSchemaObj;
end;</source>
        <Parameter name="pSchemaObj" type="Schema"/>
        <ReturnType type="CnEcDocModelSchema"/>
    </JadeMethod>
</Class>
