    <JadeMethod name="doSave" id="c11ded24-1236-45df-85a5-8f368c93dda1">
        <updating/>
        <source>doSave(): Boolean updating;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm				: SOP_TableMaintForm;
	pxyGeneratorType	: CM_GeneratorType;
	code,
	description,
	genType				: String;
	defaultWeight : Decimal [14,2];
	measureTable : CMUI_MeasurementTable;
	
begin

	theForm := self.myForm; 
	
	code			:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	description		:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	genType			:= theForm.tblInput1.getValueByName(ETRow_Type).String;
	
	//18 Mar 2014	NDL Par 33268
	defaultWeight := self.getConvertedDisplayValue( ETRow_DefaultWeight, self.weightType );
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_GeneratorType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyGeneratorType := theForm.myProxyObject.CM_GeneratorType;
	pxyGeneratorType.setProxy( code, description, genType, defaultWeight);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateGeneratorType( pxyGeneratorType, theForm.myCurrentObject.CM_GeneratorType, app.myPassport );
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateGeneratorType( pxyGeneratorType, app.myPassport );
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
