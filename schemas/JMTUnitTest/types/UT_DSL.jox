    <JadeMethod name="createTransaction" id="f33eb6d4-63ea-4f6a-a944-6a45f71304f6">
        <source>createTransaction(_realTI : CM_TrackedItem input; _type : Integer; _ts : TimeStamp) : CM_TITransaction;
// cnwrs1 
vars
	transParams: CMIF_TITransactionController;
	tranTS : TimeStamp;
	now : Date;
	transObj : CM_TITransaction;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	create transParams transient;
	transParams.type := _type;
	transParams.noCharge := false;
	transParams.userId := app.getMyUserCode();
	if _ts = null or
	   not _ts.isValid() then
		tranTS.setDate(now);
		transParams.dateTime := tranTS;
	else
		transParams.dateTime := _ts;
	endif;
	beginTransaction;
	transObj := _realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	return transObj;
epilog
	delete transParams;
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="createTransactionMap" id="afb37a12-2a1c-47ca-aedd-07f0135311ab">
        <source>createTransactionMap(_mapName : String) : CM_TranMap;

vars
	bank		: CM_Bank;
	cargoMap,
	proxyMap	: CM_TranMap;

begin
	bank := self.getTerminal().getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[_mapName];
	if cargoMap = null then
		create proxyMap transient;
		proxyMap.setProxy(bank, _mapName, _mapName);
		app.myTrxCA.trxCreateInvoiceTranMap(proxyMap, cargoMap, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	return cargoMap;
epilog
	delete proxyMap;
end;
</source>
        <Parameter name="_mapName" type="String"/>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="createUpdateYATemplate" id="a243cf70-0cd1-417f-a423-b65f69b58e42">
        <source>createUpdateYATemplate(_yATemplate: CM_YATemplate; proxyYA: CM_YardAllocation io; proxyCriterias: CMIF_Array io) : CM_YATemplate;
//18 July 2008	cnwdw1	
//
vars
	proxyYATemplate: CM_YATemplate;
	criteria: CM_YACriteria;
begin
	proxyYATemplate := app.createUpdateProxy(_yATemplate).CM_YATemplate;
	proxyYA := proxyYATemplate.myYardAllocation;
	create proxyCriterias transient;
	foreach criteria in _yATemplate.myYardAllocation.allCriteria do
		proxyCriterias.add(criteria.getTransient());
	endforeach;
	
	return proxyYATemplate;
end;</source>
        <Parameter name="_yATemplate" type="CM_YATemplate"/>
        <Parameter name="proxyYA" type="CM_YardAllocation" usage="io"/>
        <Parameter name="proxyCriterias" type="CMIF_Array" usage="io"/>
        <ReturnType type="CM_YATemplate"/>
    </JadeMethod>
    <JadeMethod name="createVesselFromXML" id="e4ca942f-f65a-4098-849a-37d951405f28">
        <source>createVesselFromXML(_code, _theXML : String) : CM_Vessel;

vars
	proxyVessel : CM_Vessel;
	realVessel : CM_Vessel;
	conflictManager		: CMIF_HMS_ConflictsManager;
begin
	create proxyVessel as CM_Vessel transient;	
	proxyVessel.setProxyVesselFromXML(_theXML);
	if proxyVessel.myCellularVesselStructure &lt;&gt; null then
		proxyVessel.myCellularVesselStructure.setPropertyValue(CM_CellularVesselStructure::isImported.name, true);
	endif;
	proxyVessel.setPropertyValue(CM_Vessel::code.name, _code);
	proxyVessel.myHMSVesselData.setPropertyValue(HMS_VesselData::myRoot.name, app.myRoot);
	app.myTrxCA.trxCreateVessel(proxyVessel, realVessel, conflictManager, app.myPassport);
	return realVessel;
epilog
	delete proxyVessel;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_theXML" type="String"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="4b6af65e-db59-46da-bda5-d7b9c0929de9">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyage : CM_Voyage;
	vessel : CM_Vessel; 
	
begin
	voyage := self.getVoyage(null);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	
	deleteVoyage(_voyage);
	deleteVessel(_vessel);
	
	vessel := self.addVesselLOLOholdsRORO(_vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	self.addVesselDefnReefer40(vessel);

	voyage := self.addVoyageWithConRORO(_voyage, _vessel, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyBulkXlation" id="917024f5-5b6a-470a-961c-fc74520a8efc">
        <source>createVoyBulkXlation(_foreignCode : String;_customsManifest : String; _voyage : CM_Voyage input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	translations	: CM_XlationSet;
	result 			: Boolean;
	xlationTable	: CM_XlationTable;	
	pxyXlationIn	: CM_Xlation_In;
	xlationOut, 
	pxyXlationOut	: CM_Xlation_Out;
	operator		: CM_Operator;
	systemCode		: String;
	terminal		: CM_Terminal;
	pxyOpTerm		: CM_OperatorTerminal;
	xlation			: CM_Xlation;
	cleanupObject	: CM_ObjectArray;
begin
	create cleanupObject transient;
	create translations transient;
	terminal := self.getTerminal();
	
	foreach operator in _voyage.allOperators do				
				systemCode := _voyage.code;
				
				pxyXlationIn:= null;
				pxyXlationOut:= null;			
				
				create xlationTable transient;						
				
				self.addToCleanUpObject(cleanupObject, xlationTable);
				
				create pxyOpTerm transient;
				self.addToCleanUpObject(cleanupObject, pxyOpTerm);
				
				pxyOpTerm.setMyOperator (operator);
				pxyOpTerm.setMyTerminal (terminal);
				
				xlationTable.setProxy(XLATION_TYPE_VOYAGETERMINAL, null, null, pxyOpTerm, null,null);
				
				create pxyXlationIn as CM_Xlation_In transient;		
				self.addToCleanUpObject(cleanupObject, pxyXlationIn);
				
				pxyXlationIn.setSystemObject(XLATION_TYPE_VOYAGETERMINAL, terminal);
					
				// set inward xlation values
				if pxyXlationIn &lt;&gt; null then
					pxyXlationIn.setProxy (systemCode, _foreignCode, xlationTable);
					pxyXlationIn.setXlationTable (xlationTable);		
				endif;
				
				// set outward xlation values				
				if xlationTable &lt;&gt; null then					
					xlationOut := xlationTable.allOutwardTranslations[systemCode];
				endif;
				
				create pxyXlationOut as CM_Xlation_Out transient;
				self.addToCleanUpObject(cleanupObject, pxyXlationOut);
				
				if pxyXlationOut &lt;&gt; null then		
					pxyXlationOut.setProxy (systemCode, _foreignCode, xlationTable);					
				endif;
				
			xlationTable.allInwardTranslations.copy(translations);			
			
	endforeach;
	
	app.myTrxUA.trxUpdateMultipleEDITrans(_voyage, translations, _customsManifest, app.myPassport);		
	
epilog		
	delete pxyXlationOut;
	delete pxyXlationIn;
	if xlationTable &lt;&gt; null then
		xlationTable.allInwardTranslations.purge();
		xlationTable.allOutwardTranslations.purge();
	endif;
	delete xlationTable;
	delete pxyOpTerm;
	
	if translations &lt;&gt; null then
		translations.purge();
	endif;
	delete translations;
	
	if cleanupObject &lt;&gt; null then
		cleanupObject.purge();
	endif;
	delete cleanupObject;
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
