    <JadeMethod name="btnViewDiscrep_click" id="a44eb40a-cfcd-4d54-b7cf-0e3efa8fe791">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewDiscrep_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwndl1	Initial creation	CCMS 1609	Par 20521

*/

vars
	trackedItems : CM_TISet;
begin

	if CM_TrackedItem.hasInstance(self.myCurrentObject) then
		create trackedItems transient;
		trackedItems.add(self.myCurrentObject.CM_TrackedItem);
		self.doViewDiscrepancy( trackedItems );
	endif;

epilog
	delete trackedItems;
end;</source>
