        <updating/>
        <source>btn_BackgroundGe_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
