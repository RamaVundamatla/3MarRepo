    <JadeMethod name="isCompletedBetween" id="4ce1401b-cb82-4530-b2b5-907fb96e8230">
        <source>isCompletedBetween( _tsFrom : TimeStamp; _tsTo : TimeStamp ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

begin

	if self.isCompleted then
		if _tsFrom.isValid and _tsTo.isValid then
			if self.completedTS &lt; _tsFrom then
				return false;
			elseif self.completedTS &gt; _tsTo then
				return false;
			endif;
		elseif _tsFrom.isValid then
			if self.completedTS &lt; _tsFrom then
				return false;
			endif;
		elseif _tsTo.isValid then
			if self.completedTS &gt; _tsTo then
				return false;
			endif;
		endif;
		
		return true;
	
	else
		return false;
		
	endif;

epilog

end;</source>
        <Parameter name="_tsFrom" type="TimeStamp"/>
        <Parameter name="_tsTo" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
