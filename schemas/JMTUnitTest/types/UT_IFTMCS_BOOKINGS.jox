	self.deleteBooking(BookingId5);
	self.deleteBooking(BookingId6);

	self.createEDIXlation ("COD", "FISH", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, NULL_TEMPERATURE, NULL_TEMPERATURE);
	self.createEDIXlation ("COD", "FZFS", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, -21, -19);

	// Load  BAPLIE file
	text :=
"UNB+UNOC:1+"&amp;operatorCode&amp;"+SFL+0908210954:1403110+207'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
