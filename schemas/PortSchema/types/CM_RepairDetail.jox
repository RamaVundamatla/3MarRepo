*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBBDiscrepancy" id="7432e066-b5d3-4b5e-9417-46a09beca92d">
        <updating/>
        <source>setBBDiscrepancy(_bbDisc : CM_BBDiscrepancy) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 August 2023	navcs2	ChangeRequest 59017: FR - 54536 EUP - Damage Location Triggering Damage Message During Repair Process

*/

vars

begin
	self.myBBTransReference := _bbDisc;
epilog

end;</source>
        <Parameter name="_bbDisc" type="CM_BBDiscrepancy"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="d64c541c-4651-4ff0-babb-1bd390db0be9">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_RepairDetailsController; _passport: CM_Passport input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description
24 June 2022	navsj20		TFS 53862 	EUP - WMS - Damage Recording Extra Details
****************************************************/

begin

	inheritMethod(_tiTransCntrl, _passport);
	
	self.damageCode 		:= _tiTransCntrl.damageCode;
	self.damageDesc 		:= _tiTransCntrl.damageDesc;
	self.damagePositionCode := _tiTransCntrl.damagePositionCode;
	self.damagePositionDesc := _tiTransCntrl.damagePositionDesc;
	self.damageTS 			:= _tiTransCntrl.damageTS;
	self.locationString 	:= _tiTransCntrl.locationString;
	self.quantity 			:= _tiTransCntrl.quantity;
	self.remarks 			:= _tiTransCntrl.remarks;
	//self.severity 			:= _tiTransCntrl.severity;	// 20.10.2022 navak20 TFS 53862
	self.severity 			:= _tiTransCntrl.severity; // ### TFS 55267 02NOV2022 NAVAB1
	// START 24 Jun 2022	navsj20	TFS 53862
	self.myRepairReason		:= _tiTransCntrl.myRepairReason;	
	self.repairedDateTime 	:= _tiTransCntrl.repairedDateTime;	
	if self.myDamagesInstance &lt;&gt; null then
		self.myDamagesInstance.setMyDamageParty(_tiTransCntrl.myDamageParty);
	endif;
	// END 24 Jun 2022	navsj20	TFS 53862
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_RepairDetailsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="severity" id="49834b87-9dcd-4595-a2da-4060c14f6591">
        <methodInvocation>mapping</methodInvocation>
        <source>severity(set : Boolean; _value : Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/06/2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if set then

	else
		if myDamagesInstance &lt;&gt; null and myDamagesInstance.myDamageSeverity &lt;&gt; null then
			_value := myDamagesInstance.myDamageSeverity.level;
		else
			_value := self.severity;// ### TFS 55267 02NOV2022 NAVAB1
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
