    <JadeMethod name="startup2" id="2c223041-7e3e-4a7d-b284-84fc17da9708">
        <updating/>
        <source>startup2() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2019	jlger1	Initial creation

*/

vars

begin
	inheritMethod();
	self.myWebServiceTestForm.txtWebURL.text:="http://localhost/dmastLocal/bin_public/jadehttp.dll?JMTWebService";
	self.myWebServiceTestForm.txtUser.text :="CNWER1";
	self.myWebServiceTestForm.txtPassword.text:="1";
	self.myWebServiceTestForm.txtTerminal.text:=app.jtdMyContext.jtdTerminalId;
	self.myWebServiceTestForm.txtMachine.text:=app.jtdMyContext.jtdMachineId;
	if self.myWebServiceTestForm.txtMachine = null then  //just from testing
		self.myWebServiceTestForm.txtTerminal.text:="JBL";
		self.myWebServiceTestForm.txtMachine.text:="ESS";
	endif;
	
	self.logonWithMachine();
epilog

end;</source>
    </JadeMethod>
