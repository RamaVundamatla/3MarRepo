    <JadeMethod name="setControlsForAddEdit" id="997c24cc-8714-49ed-8141-d56e81da5c4e">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);	
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_LoggingOrganisation);
		// cannot update code
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);

	endif;
	theForm.tblInput1.cnEcResizeContents();
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="a00016bf-454d-48bb-ae96-bbd5ad3e9dcb">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="6732449d-120c-48af-9f4d-c5bfdaaaa88b">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin

  
  	theForm := self.myForm;
  	theForm.tblData.userInputEnabled := false;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_LoggingOrgTbl);
	//theForm.zAddColumn('Log Condition Code', 'code', Table.InputType_None, 40);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 60);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_LoggingOrgMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a83907ab-8797-4763-a021-a7f585d89159">
        <updating/>
        <source>showThumbnail(pObj: CM_LoggingOrganisation) updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pObj.notAvailableForEntry);

end;</source>
        <Parameter name="pObj" type="CM_LoggingOrganisation"/>
    </JadeMethod>
</Class>
