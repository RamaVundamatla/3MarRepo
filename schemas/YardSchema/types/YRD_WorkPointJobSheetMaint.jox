    <JadeMethod name="delete" id="70787c15-514c-4259-88b1-d328aa1d1adb">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars
	
begin
	if self.myPxyWorkPointJobSheet &lt;&gt; null then
		delete self.myPxyWorkPointJobSheet;
	endif;
	self.allShiftsDays.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2daf99a3-b2a8-4b59-828f-bbd2812f0427">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet

*/

vars
	result 		: Integer;
begin
	while true do
		app.myTrxDA.trxDeleteWorkPointJobSheet(self.myWorkPointJobSheet, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_job), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="dce9a7b6-7558-4fc3-834c-7c08088f9ec2">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars

begin
	self.doSave();
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e2a22945-a9e5-41ec-9e0e-240e9be6dbb4">
        <updating/>
        <source>doSave()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
12 June 2023 navhl20 ChangeRequest 56777: EUP | LMS Gang API - Additional Attribute
*/

vars
	realJobSheet : CM_WorkPointJobSheet;
	result		 : Integer;
	shift		 : CM_Shift;
	workPoint    : CM_WorkPoint;
	startDate	 : Date;
	startTime	 : Time;
	startDateTime: TimeStamp;
	externalName : String;
	externalRef1 : String;
	externalRef2 : String;
	externalRef3 : String;
begin
	shift 			:= self.cmbShift.listObject.CM_Shift;
	externalName	:= self.txtName.text.toUpper;
	workPoint		:= self.cmbWorkPoint.listObject.CM_WorkPoint;
	startDate       := self.dtDateFrom.getDate();
	startTime		:= self.tmFrom.getTime();
	externalRef1	:= self.txtExternalRef1.text;
	externalRef2 	:= self.txtExternalRef2.text;
	externalRef3 	:= self.txtExternalRef3.text;																										//12.6.2023 navhl20 #56777
	
	startDateTime.setDate(startDate);
	startDateTime.setTime(startTime);
	
	self.myPxyWorkPointJobSheet.setProxy(shift,self.myTerminal,workPoint,startDateTime,externalName,externalRef1,externalRef2,externalRef3);			//12.6.2023 navhl20 #56777
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateWorkPointJobSheet(self.myPxyWorkPointJobSheet, realJobSheet, app.myPassport);	
		else
			app.myTrxUA.trxUpdateWorkPointJobSheet(self.myPxyWorkPointJobSheet, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.myWorkPointJobSheet := realJobSheet;
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_job), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbShifts" id="dd58c09b-7e67-4735-ae0c-dca24ed1de42">
        <source>loadCmbShifts(_shift : CM_Shift);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
13 June 2023 navhl20 Defect 58611: MTN - 1090 Exception when defining a job sheet without entering Shift
*/

vars
	startDT,
	now,
	endDT	  : TimeStamp;
	tmpTime   : Time;
begin
	
	now := app.actualTimeServer().addDays(-30); //May need configuration later
	
	startDT.setDate(now.date());
	tmpTime.setTime(0,0,0,0);
	startDT.setTime(tmpTime);
	
	
	endDT.setDate(now.date() + 30);
	tmpTime.setTime(23,59,59,0);
	endDT.setTime(tmpTime);
	
	self.allShiftsDays.purge;
	self.myTerminal.getShiftsFromRange(self.allShiftsDays, startDT, endDT);
	
	if _shift &lt;&gt; null then														//13.6.2023 navhl20 #58611
		self.allShiftsDays.addNoDuplicates(_shift,false);
	endif;
	
	self.cmbShift.clear;
	self.cmbShift.sorted := false;
	
	self.cmbShift.listCollection(self.allShiftsDays, false, ComboBox.DisplayCollection_Reversed);
	
epilog

end;</source>
        <Parameter name="_shift" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="loadCmbWorkPoint" id="c9a98953-fcbb-4cc1-a1cf-2e665087496c">
        <source>loadCmbWorkPoint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars
	iter		 	: Iterator;
	workPoint		: CM_WorkPoint;
	workPointType	: CM_WorkPointType;
begin
	iter 			:= self.myTerminal.allWorkPointsByCode.createIterator;
	workPointType	:= self.cmbWorkPointType.listObject.CM_WorkPointType;
	self.cmbWorkPoint.clear;
	
	self.cmbWorkPoint.addItemObject("", null);
	
	while iter.next(workPoint) do
		
		if workPointType &lt;&gt; null then
			if workPointType &lt;&gt; workPoint.myWorkPointType then
				continue;
			endif;
		endif;
		self.cmbWorkPoint.addItemObject(workPoint.code &amp; Tab &amp; workPoint.description, workPoint);

	endwhile; 
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbWorkPointType" id="9e7727ba-34c4-49f6-a73b-1d9457e70248">
        <source>loadCmbWorkPointType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
14 Mar 2023 navma1	Bug 62834: EUP - Not Available for Entry Work Point Types in Work Order Operation
*/

vars
	iter		 	: Iterator;
	workPointType	: CM_WorkPointType;
begin
	iter := self.myTerminal.allWorkPointTypes.createIterator;
	
	self.cmbWorkPointType.clear;
	
	self.cmbWorkPointType.addItemObject("", null);

	while iter.next(workPointType) do
		if workPointType.notAvailableForEntry then		//14.03.2024 navma1 #62834
			continue;
		endif;
		
		self.cmbWorkPointType.addItemObject(workPointType.code &amp; Tab &amp; workPointType.description, workPointType);
	endwhile; 
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateWorkPointJobSheet" id="4c52f850-643c-46ab-baa5-6999c4fd7f38">
        <source>populateWorkPointJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
12 June 2023 navhl20 ChangeRequest 56777: EUP | LMS Gang API - Additional Attribute
13 June 2023 navhl20 Defect 58611: MTN - 1090 Exception when defining a job sheet without entering Shift
*/

vars
	shift,
	pxyShift		: CM_Shift;
begin
	if self.myPxyWorkPointJobSheet &lt;&gt; null then
		self.cmbWorkPoint.setIndexFromObject(self.myPxyWorkPointJobSheet.myWorkPoint);
		if self.myPxyWorkPointJobSheet.myWorkPoint &lt;&gt; null then
			self.cmbWorkPointType.setIndexFromObject(self.myPxyWorkPointJobSheet.myWorkPoint.myWorkPointType);
		endif;
		if self.myPxyWorkPointJobSheet.myShift &lt;&gt; null then
			shift := self.allShiftsDays[self.myPxyWorkPointJobSheet.myShift.startDateTime,self.myPxyWorkPointJobSheet.myShift.code];
			if shift = null then																	//13.6.2023 navhl20 #58611
				pxyShift := app.createUpdateProxy(self.myPxyWorkPointJobSheet.myShift).CM_Shift;
				self.loadCmbShifts(pxyShift);
				shift := self.allShiftsDays[self.myPxyWorkPointJobSheet.myShift.startDateTime,self.myPxyWorkPointJobSheet.myShift.code];
			endif;
			if shift &lt;&gt; null then
				self.cmbShift.setIndexFromObject(shift);
				self.dtDateTo.setDate(shift.endDateTime.date);
				self.tmTo.setTime(shift.endDateTime.time);
			endif;
		endif;
		self.txtName.text := self.myPxyWorkPointJobSheet.externalName;
		self.txtExternalRef1.text := self.myPxyWorkPointJobSheet.externalReference1;
		self.txtExternalRef2.text := self.myPxyWorkPointJobSheet.externalReference2;
		self.txtExternalRef3.text := self.myPxyWorkPointJobSheet.externalReference3;				//12.6.2023 navhl20 #56777
		self.dtDateFrom.setDate(self.myPxyWorkPointJobSheet.startDateTime.date);
		self.tmFrom.setTime(self.myPxyWorkPointJobSheet.startDateTime.time);
	endif;
epilog

end;</source>
    </JadeMethod>
