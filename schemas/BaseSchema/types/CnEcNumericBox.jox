    <JadeMethod name="cnEcDate" id="37344f76-642c-46cb-8208-72a7e3507137">
        <source>cnEcDate(): Date;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's numeric Julian day number as a date.
//
// Parameters:	None
//
// Returns:		The current date setting.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateValue	: Date;
	
begin
	dateValue	:=	self.text.Integer.Date;
	
	if dateValue.isValid() then
		return dateValue;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcDecimal" id="b7d56ce4-6592-42ae-b7d3-7a07b22d952c">
        <source>cnEcDecimal(): Decimal;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Decimal value.
//
// Parameters:	None
//
// Returns:		The decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.cnEcAsNumeric(self.myNumberFormat).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcInteger" id="11a7d861-e785-4123-b0ce-a37b7c60017d">
        <source>cnEcInteger(): Integer;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as an Integer value.
//
// Parameters:	None
//
// Returns:		The integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.cnEcAsNumeric(self.myNumberFormat).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcReal" id="1af4d219-bc72-48b7-acc9-87255c73fb9a">
        <source>cnEcReal(): Real;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Real value.
//
// Parameters:	None
//
// Returns:		The real value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.cnEcAsNumeric(self.myNumberFormat).Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcTime" id="b3204283-a027-478d-a780-f8089eb2b40b">
        <source>cnEcTime(): Time;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's number as a time, assuming that the value
//				is the number of milliseconds since midnight.
//
// Parameters:	None
//
// Returns:		The current time setting.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timeValue	: Time;
	
begin
	timeValue	:=	self.text.cnEcAsNumeric(self.myNumberFormat).Integer.Time;
	
	if timeValue.isValid() then
		return timeValue;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcTimeStamp" id="64230beb-d07f-4a22-a8f9-e9f7a6b5c2b9">
        <source>cnEcTimeStamp(): TimeStamp;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		This reimplementation returns a null value since a time stamp value
//				is not relevant in the context of this control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="delete" id="67440194-891e-4dbf-8fba-192d1ac47c20">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		24 June 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/06/2002	cnwdad1		To allow for multiple instances of this control on one
//							form, with different user-decimals settings, each of
//							the instances requires its own NumberFormat object (i.e.
//							a user-format object).
// --------------------------------------------------------------------------------
begin
	delete self.myNumberFormat;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="e11c9c48-8fe3-48ea-a9ab-1e2f0c9a3fe6">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		12 March 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/03/2002	cnwdad1		Added check for a selection style of "Select All".  If
//							this option is used, then the contents will be selected
//							after the newly formatted contents are set.  This is
//							necessary because we're switching from an alphanumeric
//							textbox to a numeric textbox.
// --------------------------------------------------------------------------------
vars
	textValue		: String;
	
begin
	inheritMethod(textbox);
	
	textValue	:=	textbox.text.cnEcAsNumeric(self.myNumberFormat);
	
	self.setIsIgnoreState(true);
	textbox.text	:=	null;
	self.dataType	:=	TextBox.DataType_SignedNumeric;
	self.decimals	:=	self.userDecimals;
	self.setIsIgnoreState(false);
	textbox.text	:=	textValue;
	
	if self.selectionStyle = TextBox.SelectionStyle_SelectAll then
		textbox.selStart	:=	0;
		textbox.selLength	:=	textValue.length;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="42f0e24a-8616-4847-91d6-6c1c6fd5265a">
        <updating/>
        <source>lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textValue	: String;
	
begin
	textValue		:=	textbox.text.Decimal.userNumberFormat(self.myNumberFormat);
	self.dataType	:=	TextBox.DataType_AlphaNumeric;
	
	if textValue &lt;&gt; null then
		textbox.text	:=	textValue;
	endif;
	
	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAlignment" id="9b6ae82d-9093-458e-b44e-db8611fc4a91">
        <updating/>
        <source>setAlignment() updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 September 2002 by cnwdad3
//
// Purpose:		Sets the receiver's alignment to be right-aligned.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alignment		:=	TextBox.Alignment_Right;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setIsIgnoreState" id="370c1192-c989-43e1-95af-4a5e37f44db7">
        <updating/>
        <source>setIsIgnoreState(pIsOverride:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 March 2002 by cnwdad1
//
// Purpose:		Sets a flag to indicate that the "text" mapping method should ignore
//				the formatting while the receiver's text is formatted back to a
//				numeric value for user input.
//
// Parameters:	pIsOverride - If true, the mapping method won't format the text.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isIgnoreState	:=	pIsOverride;
end;</source>
        <access>protected</access>
        <Parameter name="pIsOverride" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLayout" id="b2ae1300-fe49-4719-846b-8fd57654aa83">
        <updating/>
        <source>setLayout(pLayout:String; pUserDecimals:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		14 April 2003 by cnwdad1
//
// Purpose:		Sets the number layout and the number of decimal places.
//
// Parameters:	pLayout - The number layout (refer to the class constants for
//					valid settings).  Invalid settings will be ignored.
//				pUserDecimals - The number of decimal places.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.numberLayout &lt;&gt; pLayout then
		if pLayout = self.LAYOUT_DECIMAL
		or pLayout = self.LAYOUT_INTEGER
		or pLayout = self.LAYOUT_REAL
		then
			self.numberLayout	:=	pLayout;
		endif;
	endif;
	
	self.setUserDecimals(pUserDecimals);
	
	if pLayout = self.LAYOUT_DECIMAL then
		self.text	:=	self.cnEcDecimal().String;
	elseif pLayout = self.LAYOUT_INTEGER then
		self.text	:=	self.cnEcInteger().String;
	elseif pLayout = self.LAYOUT_REAL then
		self.text	:=	self.cnEcReal().String;
	endif;
end;</source>
        <Parameter name="pLayout" type="String"/>
        <Parameter name="pUserDecimals" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setUserDecimals" id="dd014e5f-a783-4bac-a2f5-6184db10d88b">
        <updating/>
        <source>setUserDecimals(pUserDecimals:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		19 May 2002 by cnwdad1
//
// Purpose:		Sets the number of decimal places the developer wishes to use.
//
// Parameters:	pUserDecimals - The number of decimal places.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.numberLayout = self.LAYOUT_INTEGER then
		self.userDecimals					:=	0;
		self.myNumberFormat.decimalPlaces	:=	0;
	else
		self.userDecimals					:=	pUserDecimals;
		self.myNumberFormat.decimalPlaces	:=	pUserDecimals;
	endif;
end;</source>
        <Parameter name="pUserDecimals" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="text" id="bf85a6df-6ce2-4d72-8d8c-491077bad861">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>text(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/02/2002	cnwdad1 	Added check for whether the textbox is currently expecting
//							a numeric value or a formatted string, and converted the
//							"value" parameter accordingly.
//
// 13/02/2002	cnwdad1		Added check for whether the receiver's NumericFormat is
//							null or not.
//
// 27/07/2002	cnwdad1		Added a feature to optionally strip out trailing zeros
//							from the values following the decimal point.
//
// 19/09/2002	cnwdad1		For the Integer layout, the text was defaulting to "0.00".
//							Changed to use the $CNEC_NO_DECIMALS User Format.
// --------------------------------------------------------------------------------
vars
	workValue	: String;
	
begin
	if set
	and (not self.isIgnoreState)
	and self.myNumberFormat &lt;&gt; null
	then
		if self.dataType = TextBox.DataType_AlphaNumeric then
			if self.numberLayout = self.LAYOUT_DECIMAL then
				value	:=	self.myNumberFormat.cnEcStripNonNumeric(value).Decimal.userNumberFormat(self.myNumberFormat);
				
				if self.isStripDecimalZeros then
					value	:=	value.cnEcStripDecimalZeros();
				endif;
				
			elseif self.numberLayout = self.LAYOUT_INTEGER then
				value	:=	self.myNumberFormat.cnEcStripNonNumeric(value).Integer.userNumberFormat($CNEC_NO_DECIMALS);
				
			elseif self.numberLayout = self.LAYOUT_REAL then
				value	:=	self.myNumberFormat.cnEcStripNonNumeric(value).Real.userNumberFormat(self.myNumberFormat);
				
			endif;
		else
			value 	:=	value.cnEcAsNumeric(self.myNumberFormat);
		endif;
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="84eca7e1-4e78-478e-9d26-c916ab9d1847">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		26 September 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/03/2002	cnwdad1		Changed to switch between alphanumeric and numeric
//							input so that after loosing focus, the full format can
//							be displayed.
// 19/05/2002	cnwdad1		Changed the userDecimals attribute to be enterable by
//							developers so that the decimal places setting is not
//							lost when switching between alphanumeric/numeric modes.
// 24/06/2002	cnwdad1		Changed the set up of the myNumberFormat from using the
//							application's NumberFormat object to using a specifically
//							created user-format. Needed because multiple instances
//							of the control on one form, with different user-decimal
//							values require their own NumberFormat object.
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	create self.myNumberFormat transient;
	self.myNumberFormat.cnEcCopyInfo(app.currentLocaleInfo.numericInfo);
	
	if self.numberLayout = null then
		self.numberLayout	:=	self.LAYOUT_DECIMAL;
	endif;
	
	if self.numberLayout &lt;&gt; self.LAYOUT_INTEGER then
		self.myNumberFormat.decimalPlaces	:=	self.userDecimals;
	endif;
	
	self.setAlignment();
	self.dataType		:=	TextBox.DataType_AlphaNumeric;
	self.text			:=	self.text;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
