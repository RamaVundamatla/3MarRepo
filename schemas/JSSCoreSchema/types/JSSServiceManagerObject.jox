    <JadeMethod name="create" id="3842976c-8ba6-49d8-9a78-a50f2a03cffa">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2002 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.myTA as self.getTAClass() transient;
	self.myTA.setServiceManager(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="finalize" id="e6e764c4-d9f1-4ac2-8c02-6a2b89c2d0f0">
        <updating/>
        <source>finalize() updating;
// --------------------------------------------------------------------------------
// Created:		21 May 2002 by cnwwmb1
//
// Purpose:		Called by the service object's destructor to clean up any process
//				objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	//	remove this application from the process dictionary
	if self.myTA &lt;&gt; null then
		self.myTA.trxRemoveProcessObjectForApp(self);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getErrorMessageSchema" id="12b6ab4a-f9bd-4d89-89f3-14497e39c864">
        <source>getErrorMessageSchema():Schema protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Returns the schema (JSSCoreSchema) where the error message stuff is
//				implemented.
//
// Parameters:	None
//
// Returns:		A reference to the core schema.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return rootSchema.getSchema(JSSCoreSchema.name);
end;</source>
        <access>protected</access>
        <ReturnType type="Schema"/>
    </JadeMethod>
    <JadeMethod name="getErrorString" id="84d97cc3-46e0-4b0d-a826-e501843c0431">
        <source>getErrorString(pErrorCode : Integer):String protected;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad2
//
// Purpose:		Returns an error message for the supplied error code.
//
// Parameters:	pErrorCode - The error (exception) code.
//
// Returns:		The error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorObj	: JSSErrorMessage;
	
begin
	if pErrorCode &lt; JSS_EX_00001 then
		return "Non-package error code: " &amp; pErrorCode.String;
	endif;
	
	errorObj	:=	self.allErrorMessages[pErrorCode];
	
	if errorObj = null then
		return "Error " &amp; pErrorCode.String &amp; ": Unknown message";
	endif;
	
	return errorObj.errorText;	
end;</source>
        <access>protected</access>
        <Parameter name="pErrorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString1" id="886bbc80-1629-4f7a-bea4-49e2d2fd7cfb">
        <source>getErrorString1(pErrorCode : Integer; pParameter1:String):String protected;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad2
//
// Purpose:		Returns an error message for the supplied error code.
//
// Parameters:	pErrorCode - The error (exception) code.
//				pParameter(n)... - List of message parameters.
//
// Returns:		The error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorObj		: JSSErrorMessage;
	allParameters	: HugeStringArray;
	
begin
	if pErrorCode &lt; JSS_EX_00001 then
		return "Non-package error code: " &amp; pErrorCode.String;
	endif;
	
	errorObj	:=	self.allErrorMessages[pErrorCode];
	
	if errorObj = null then
		return "Error " &amp; pErrorCode.String &amp; ": Unknown message";
	endif;
	
	create allParameters transient;
	allParameters[1]	:=	self.truncateString(pParameter1, 2030);
	
	return errorObj.getParameterizedText(allParameters);
epilog
	delete allParameters;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pParameter1" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
