    <JadeMethod name="action" id="e161a411-c53c-4754-868c-a57229e17830">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2018	jlger1	Initial creation

*/

vars
	agent			: CM_CargoChainWSAgent;
	wsDefinition	: CM_CargoChainServiceDef;
	returnVal		: Boolean;
	errorMessage	: String;
	timeoutOccurred	: Boolean;
	response		: CMIF_ExternalWSResponse;
begin
	
	wsDefinition := app.myBGPObject.BGP_ExternalWSController.myExternalWSDef.CM_CargoChainServiceDef;
	create agent transient;
	agent.setupFromWebServiceDefinition(wsDefinition);
	
	if self.myTrackedItem &lt;&gt; null then
		returnVal := agent.createCargoProfile(self.myTrackedItem, timeoutOccurred);
	elseif self.myTITransaction &lt;&gt; null then
		//epr TFS 45963 7/8/19
		returnVal := agent.addCargoChainEvent(self.myTITransaction,timeoutOccurred);
	endif;
		
	
	// Handle timeout
	if timeoutOccurred then
		if self.doWebServiceTimeoutProcessing(wsDefinition) then
			returnVal := false;
		endif;
	endif;

//	return inheritMethod();
	return returnVal;

epilog
	delete agent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTITransaction" id="31a9c007-eb9b-4e95-ab0b-d9ea7cbe1fea">
