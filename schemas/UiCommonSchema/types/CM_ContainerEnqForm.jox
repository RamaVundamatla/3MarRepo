    <JadeMethod name="initForm" id="958ae159-61e9-4015-8d6c-55ae1b761d04">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2001 by cnwrs2
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 15/06/2010	cnwcs5		par 24342 - no longer using CMUI_StopsListTable
// 30/06/2010	cnwdap1		PAR #24516 Include new tranship combos
// 13/08/2013	cnwdap1		PAR #32123 Add Colour Picker
// 18 Aug 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// 14 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
// 10/11/2023	jlika1	TFS 61130 61013 CUX | Cargo Priority - Cargo Maintenance
vars
	tmpTerminal : CM_Terminal;
	tmpUser		: CM_User;
begin

	tmpUser := app.getMyUser();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	self.allowMultiSelectEdit := true;	
	self.allowAdd	 		:= false;
	self.allowDelete 		:= false;
	self.showFilterOnStartup := true; 	// Show the filter frame
	self.showDataOnStartup 	:= false; 	// Do not populate the data table with data
	self.useNumRowsShown	:= true;
	self.useTblThumb 		:= false;
	self.allowHideThumbnailEmpty:=true;
	//self.useFloatingFilter  := true;	//- cnwmd1, Par #21731
	self.isSelectorCapable := true;
	self.shtEdit7.caption := null;
	self.fldEdit.useSheetBackColors := true;		
	self.fldEdit.setDefaultSheetBackColors();
	self.fldEdit.initSheetBackColors();		//set selected/unselected folders colours

	self.canAccessMoveIt	:= tmpUser.canDo(self.myTerminal, PmYardMoveView);
	self.canAccessTransactions	:= tmpUser.canDo(self.myTerminal, PmTiTransactionView);
	self.canUpdate			:= tmpUser.canDo(self.myTerminal, PmAdmCargoEnquiryMaint);
	//self.canAccessReqImage	:= (app.myRoot.client = Client_DCTGdansk); //- cnwmd1, Par 20978
	self.canAccessTodoTasksAddRemove	:= tmpUser.canAccessTodoTasksAddRemove(self.myTerminal);
	self.canAccessTodoTasksComplete := tmpUser.canAccessTodoTasksComplete(self.myTerminal);
	self.canAccessAudits	:= tmpUser.canDo(self.myTerminal, PmAdmAuditenquiryView);
	
	if self.useTxtHeader then
		// self.useFloatingFilter must be true
		self.sptDataFilter.setLeftControl(self.txtHeader);
		self.txtHeader.backColor := self.colorControlBack;
		self.txtHeader.visible := true;
		self.txtHeader.readOnly := true;
		self.sptDataFilter.showRightControl(80, true);
	endif;

	self.sptThumbEdit.splitType	:= CMUI_SplitContainer.SPLITTYPE_LOCKLEFT;
	self.initFldEdit();
	self.initTblThumb();
	self.initTableCustEntry();
	self.loadDebtorTypeCombos();
	self.loadShippingLineCombo();			//TFS 53204
	self.loadCountryOfOrigin();				// 18.08.2022 navak20 TFS 54441
	self.loadSealTypeTables();				//+cnwml2 PAR23715 SFW CCMS1131
	
	self.myAssistant.comboBoxCustomerPriority(self.cmbCustPriority, null);
	
	
	if self.useTxtThumb then
		self.sptMain.setSplitDirection(true);
		self.tblInputTop.visible := false;
		self.txtThumbnail.visible := true;
		self.txtThumbnail.backColor := self.colorControlBack;
		self.sptThumbEdit.splitType	:= CMUI_SplitContainer.SPLITTYPE_RATIO;
	endif;

	self.doLoadSpecialLifts();
	self.doLoadColours();									// PAR #32123
	// par 24342 self.doLoadStops();
	// par 24342 self.lstTblStops.setExpiryDateJadeEditMask( self );	// cnwrl1 23/12/2009 PAR 21889
//	self.doLoadHazards();	replaced &gt;&gt; CCMS 1203 JC
	self.cmbBulkEditOpt.addItem( app.getString( Regardless_Of_Original_Value ) );
//	self.cmbBulkEditOpt.addItem( app.getString( Only_If_Original_Value_Matches ) );	//10 Nov 2015	NDL	Par 36719
	self.cmbBulkEditOpt.itemData[1] := CMIF_BulkEditController.OPT_CHANGE_REGARDLESS;
//	self.cmbBulkEditOpt.itemData[2] := CMIF_BulkEditController.OPT_MATCH_ORIGINAL_VALUE;	//10 Nov 2015	NDL	Par 36719
	self.cmbBulkEditOpt.listIndex := 1;
	
	tmpTerminal := self.myTerminal;
	self.cmbDisPort.myTerminal := tmpTerminal; // so text for port is displayed in correct order from config. 
	self.cmbDisPort.myAssistant := self.myAssistant;
	self.cmbDisPort.isDisabledPortCodeSelector := true;	// 20/05/2010 cnwar2 #24261
	self.cmbTranship.myTerminal := tmpTerminal; // so text for port is displayed in correct order from config. 
	self.cmbTranship.myAssistant := self.myAssistant;
	self.cmbDestPort.myTerminal := tmpTerminal;// so text for port is displayed in correct order from config
	self.cmbDestPort.myAssistant := self.myAssistant;
	self.cmbDestPort.showAllDestinations := true;
	self.cmbLoadPort.myTerminal := tmpTerminal;// so text for port is displayed in correct order from config
	self.cmbLoadPort.myAssistant := self.myAssistant;
	self.cmbOrigPort.myTerminal := tmpTerminal;// so text for port is displayed in correct order from config
	self.cmbOrigPort.myAssistant := self.myAssistant;
	self.cmbOrigPort.showAllDestinations := true;
	self.setIncludesDepartedVoyages(self.myTerminal.getConfig(VoyCmbIncludesSailed).Boolean);
	// PAR #24516 set myTerminal and myAssistant on new Tranship combos
	self.cmbExpTshipDisch.myTerminal 	:= tmpTerminal;
	self.cmbExpTshipDisch.myAssistant 	:= self.myAssistant;
	self.cmbExpTshipDest.myTerminal 	:= tmpTerminal;
	self.cmbExpTshipDest.myAssistant 	:= self.myAssistant;
	// PAR #24516 end
	
	self.getXMLSettingsForSetup();
	
	if self.amInitialisingWithObject then
		if self.myCurrentObject.isKindOf(CM_TrackedItem) then
			self.initForTrackedItem(self.myCurrentObject.CM_TrackedItem);		// 32673
		elseif self.myCurrentObject.isKindOf(CM_SOHLocation) then
			self.initForSOHLocation(self.myCurrentObject.CM_SOHLocation);
		elseif self.myCurrentObject.isKindOf(CM_LogController) then
			self.initForLocationsController(self.myCurrentObject.CM_LogController);
		endif;
	endif;
	
	self.isBulkEditingCompleted := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableCustEntry" id="b4c91515-bb12-443d-9a68-3b101cd2fe85">
        <source>initTableCustEntry();

vars
	row : Integer;
begin
	self.tblCustEntry.inputType := Table.InputType_TextBox;
	self.tblCustEntry.userInputEnabled := true;
	self.tblCustEntry.rows := 10;
	//PAR 17299 ---to   restrict tje user to enter  only 30 characters   in each row in Custom Entry Number
	while true do
		row := row + 1; 
		if row &gt; self.tblCustEntry.rows then
			break;
		endif;
		self.tblCustEntry.accessRow(row).maxLength := 30;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="06c64659-0453-40f4-af08-25f6b1240b21">
        <updating/>
        <source>initTblThumb() updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	idx		: Integer;
//	sheet	: JadeTableSheet;
	entDef	: EntTableDef;
	ratio	: Integer;
	
begin

	if self.useTxtThumb then
		return;
	endif;

	self.fldEdit.visible 			:= true;
	self.frmDetailsBottom.visible	:= true;
	self.tblInputTop.visible		:= false; //TFS 47132 13/12/19
	self.useFrmDetailsBottomForView := true;

	entDef := app.myController.getEntTableDef(ETDef_TIEnqHeader);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ' &amp; ETDef_TIEnqHeader &amp; ' was not found.');
		return;
	endif;
	self.tblInputTop.setEntTableDef(entDef, null, 'entTableDefSetupWarning');
	self.tblInputTop.adjustHeight(1000);

	ratio := (((self.tblInputTop.height + 10) / self.sptMain.clientHeight) * 100).Integer;

	self.sptThumbEdit.showLeftControl(ratio, self.isFirstActivateComplete);
end;</source>
    </JadeMethod>
    <JadeMethod name="insertDebtorType" id="c3ba99cf-e698-4cbc-b9a5-a871b608fe23">
        <source>insertDebtorType(_tbl: CM_EntryTable io; _debtorType : CM_DebtorType; _atRow : Integer);
// ---------------------------------------------------------------------------
// Created:	9 April 2008 By Graeme Black cnwgb1 cp ccms 1047
// Injects a debtor type row into an Entry table. 
// These cannot be statically defined as they are created by the user
// ---------------------------------------------------------------------------

vars
	debtor : CM_Debtor;
	aControl : Control;
	aRow : Integer;
	jRow :JadeTableRow;
	aTrackedItem : CM_TrackedItem;
	hadException	: Boolean;
	debtorName		: String;
begin
	on Exception do app.handleDeletedObject(exception, debtor, hadException);

	aTrackedItem := self.myCurrentObject.CM_TrackedItem;
	_tbl.addAttributeAt("DtRow_" &amp; _debtorType.code, _debtorType.description, Table.InputType_TextBox, null, true, _atRow);
	//Check for value in tracked Item if exists and display or make correct selection in combobox
	// 35440 guard against the debtor having been deleted
	debtor := aTrackedItem.allDebtorsByType[_debtorType.code];
	if debtor &lt;&gt; null then
		debtorName := debtor.name;
		if hadException then
			debtor := null;
		endif;
		_tbl.setValueByName("DtRow_" &amp; _debtorType.code, debtorName);
	endif;
	aRow := _tbl.getRowByName( "DtRow_" &amp; _debtorType.code );
	jRow := _tbl.accessRow(aRow);
	jRow.backColor := self.colorValueColumn;
	aControl := self.allDebtorTypeControls["cmbDebtorType" &amp; _debtorType.code];
	if aControl &lt;&gt; null then
		_tbl.setControl( aRow, aControl );
		if debtor &lt;&gt; null and
		   aControl.CMUI_ComboBox.findObject(debtor) &gt; 0 then		// from 35440 debtor may no longer be associated with the debtor type
			aControl.CMUI_ComboBox.listObject := debtor;
		else
			aControl.CMUI_ComboBox.listIndex := -1;
		endif;
	endif;
	
	//epr 9/4/14 hiding emtpty rows
	if  self.mode = Mode_View and debtor = null and self.isHideThumbnailEmtpy then
		_tbl.hideRow(aRow);
		
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_atRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertSealType" id="043bcd1b-8ce7-4889-b423-52794bc845b3">
        <source>insertSealType(_tbl : CM_EntryTable io; _sealType : CM_SealType; _atRow : Integer);
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals

vars
	aRow : Integer;
	jRow :JadeTableRow;
	ti 	: CM_TrackedItem;
	sealTI : CM_SealTI;
	dateEntered : Boolean;
	aControl : Control;
	tranSealTi : CM_SealTI;
	sealValue : String;
begin

	ti := self.myCurrentObject.CM_TrackedItem;//06 Dec 2010	NDL	Par 26506 - moved up
	if ti = null or _sealType = null then	//06 Dec 2010	NDL	Par 26506
		return;
	endif;
	
	_tbl.addAttributeAt("StRow_" &amp; _sealType.sealType, _sealType.description, Table.InputType_TextBox, null, true, _atRow);		// cnwmc5 - 17 Sep 2014 - PAR 33694
	
	
	sealTI := ti.getSealTI(_sealType);	//06 Dec 2010	NDL	Par 26506 - moved up
	
	//06 Dec 2010	NDL	Par 26506
	if sealTI = null then
		tranSealTi := ti.getTransSealTiFromOldDataStruc(_sealType);
		sealTI := tranSealTi;
	endif;
	if sealTI &lt;&gt; null then
		sealValue := sealTI.getSealValueAsString;
	else
		sealValue := null;
	endif;
	
	
	_tbl.setValueByName("StRow_" &amp; _sealType.sealType, sealValue);	//06 Dec 2010	NDL	Par 26506
	aRow := _tbl.getRowByName( "StRow_" &amp; _sealType.sealType );
	jRow := _tbl.accessRow(aRow);
	jRow.backColor := self.colorValueColumn;
	
	if _sealType.allowMultipleSealNums then
		aControl := self.allSealTypeControls["tblSeals" &amp; _sealType.sealType];
		if aControl &lt;&gt; null then
			_tbl.setControl(aRow, aControl);
			//epr par 32630 27/1/15
			self.setCustSealTable(aControl.Table,sealValue);
		endif;
		
	endif;
	
	if sealTI &lt;&gt; null then
		if sealTI.sealedDT &lt;&gt; null then
			dateEntered := true;
			_tbl.addAttributeAt("StRow_" &amp; "DateTime_" &amp; _sealType.sealType, _sealType.description &amp; " Date/Time", Table.InputType_TextBox, null, true, _atRow + 1);
			_tbl.setValueByName("StRow_" &amp; "DateTime_" &amp; _sealType.sealType, sealTI.sealedDT);
			aRow := _tbl.getRowByName( "StRow_" &amp; "DateTime_" &amp; _sealType.sealType );
			jRow := _tbl.accessRow(aRow);
			jRow.backColor := CM_EntryTable.ReadOnlyRowColour;
			jRow.enabled := false;
		else
			dateEntered := false;
		endif;
		
		if not _sealType.allowMultipleSealNums and _sealType.savePreviousSeal then	//22 Sep 2010	NDL	Par 25608
		//if not _sealType.allowMultipleSealNums then
			if sealTI.previousSeal &lt;&gt; null then
				if dateEntered then
					_tbl.addAttributeAt("StRow_" &amp; "PreviousSeal_" &amp; _sealType.sealType, "Previous " &amp; _sealType.description, Table.InputType_TextBox, null, true, _atRow + 2);
					_tbl.setValueByName("StRow_" &amp; "PreviousSeal_" &amp; _sealType.sealType, sealTI.previousSeal);
					aRow := _tbl.getRowByName( "StRow_" &amp; "PreviousSeal_" &amp; _sealType.sealType );
					jRow := _tbl.accessRow(aRow);
					jRow.backColor := CM_EntryTable.ReadOnlyRowColour;
					jRow.enabled := false;
				else
					_tbl.addAttributeAt("StRow_" &amp; "PreviousSeal_" &amp; _sealType.sealType, "Previous " &amp; _sealType.description, Table.InputType_TextBox, null, true, _atRow + 1);
					_tbl.setValueByName("StRow_" &amp; "PreviousSeal_" &amp; _sealType.sealType, sealTI.previousSeal);
					aRow := _tbl.getRowByName( "StRow_" &amp; "PreviousSeal_" &amp; _sealType.sealType );
					jRow.backColor := CM_EntryTable.ReadOnlyRowColour;
					jRow.enabled := false;
				endif;
			endif;
		endif;
	endif;

	//epr 9/4/14 hiding emtpty rows
	if  self.mode = Mode_View and sealValue = null and self.isHideThumbnailEmtpy then
		_tbl.hideRow(aRow);
		
	endif;
epilog

	delete tranSealTi;
	
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_atRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isColumnOrganiserTable" id="6b495545-830a-4e09-a759-9da000bee6c0">
        <source>isColumnOrganiserTable(conwin: Window): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2022	jlier1	Initial creation 54700
14/04/2023	navkc1	CR 57036 Task 57590 - UI - Cargo Enquiry Create New Cargo
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
*/

vars

begin
	if conwin = self.tblView2 then
		// 14/04/2023	navkc1	CR 57036 Task 57590 Use default cargo enquiry entdef
		//if self.tblView2.myEntTableDef &lt;&gt; null and self.tblView2.myEntTableDef.name = ETDef_CargoEnqDefaultData then //10/09/2023 navmv20 CR 58250 Task 58252
		if self.tblView2.myEntTableDef &lt;&gt; null and (self.tblView2.myEntTableDef.name = ETDef_CargoEnqDefaultData or self.tblView2.myEntTableDef.name = ETDef_StorageExpDetails) then //10/09/2023 navmv20 CR 58250 Task 58252
			return true;
		endif;
	endif;

	return inheritMethod(conwin);

epilog

end;</source>
        <Parameter name="conwin" type="Window"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
