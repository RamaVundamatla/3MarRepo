    <JadeMethod name="listTableToDoTasks" id="99bae617-31e1-48fa-8608-ce61be1dfcab">
        <source>listTableToDoTasks(_lstTable 		: CMUI_ListTable input; 
					_terminal 		: CM_Terminal);
/*
----------   ----------  --------------------------------------------------
Created:	25 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
*/
vars
	task			: CM_ToDoTaskDesc;
	taskDict		: CM_ToDoTaskDescByCode;
	index			: Integer;
	assist			: CMUI_Assistant;
	
begin
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	create assist transient;
	_lstTable.clear(); 
	
	//_lstTable.displayCollection(taskDict, false, Table.DisplayCollection_Forward, null);
	foreach task in taskDict do
		index := _lstTable.addItem(assist.displayEntryToDoTaskList(task, false));	// TFS4085 MAP 12/4/17
		_lstTable.accessRow(index).itemObject := task;
	endforeach;
epilog
	delete taskDict;
	delete assist;
end;

</source>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="listTableToDoTasksForCargoType" id="126e4c8d-6595-4f1c-8b9a-3aa9765f94e8">
        <source>listTableToDoTasksForCargoType(_lstTable 		: CMUI_ListTable input; 
								_terminal 		: CM_Terminal;
								_cargoType		: CM_CargoType);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 April 2023	navmk20	Bug 56980: MTN - Additional details form not displayed

*/

vars
	task			: CM_ToDoTaskDesc;
	taskDict		: CM_ToDoTaskDescByCode;
	index			: Integer;
	assist			: CMUI_Assistant;
	toDoTaskDesc    : CM_ToDoTaskDesc;
	
begin
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	if _terminal = null then
		return;
	endif;
	
	create assist transient;
	_lstTable.clear();
	_lstTable.sortColumn[1] := 2;  
	_lstTable.sortAsc[1]    := true;
	_lstTable.sortCased[1]  := false;
	
	foreach task in taskDict do
		if _cargoType.allToDoTaskDescs.includes(task) then
			index := _lstTable.addItem(assist.displayEntryToDoTaskList(task, false));
			_lstTable.accessRow(index).itemObject := task;
		endif;
	endforeach;
epilog
	delete taskDict;
	delete assist;
end;</source>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="listTableToDoTasksSys" id="9ded7855-f6a4-4897-9cc3-9229ef99d10c">
        <source>listTableToDoTasksSys(_lstTable 		: CMUI_ListTable input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwrd1	Initial creation

*/

vars
	toDoTables : CM_ToDoTaskDescByCode; 
	
begin
	
	// DVB CCMS 1235
//	stopsTables := app.myRoot.allStopsTable;
	toDoTables := app.myRoot.allToDoTaskDescriptions;
	
