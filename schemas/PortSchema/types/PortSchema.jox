    <JadeMethod name="silentRetryLock" id="c1400584-eaff-4c6c-ac38-8b2d2adbc571">
        <source>silentRetryLock(lockExObj : LockException) : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	Max_Retries = 20;
	
vars
	obj : Object;
	retries : Integer;
	maxRetries : Integer;
begin
	if lockExObj = null then
		return false;
	endif;

	app.writeLogLockException(lockExObj);
	
	obj := lockExObj.lockTarget;

	if lockExObj = null then
		return false;
	endif;

	if app.myPassport.silentLockRetries &gt; 0 then
		maxRetries:=app.myPassport.silentLockRetries;
	else
		maxRetries:=Max_Retries;
	endif;
	retries := 0;
	
	while true do
		// Retry the lock
		retries := retries + 1;
		// tryLock attempts to lock an object but returns a boolean indicating
		// success or failure instead of raising an exception
		if tryLock(obj, lockExObj.lockType, lockExObj.lockDuration, LockTimeout_Server_Defined) then
			// We got the lock
			return true;
		endif;
		// Have we had enough...?
		if retries &gt;= maxRetries then
			// Yes, so return the fact that we didn't get the lock
			return false;
		endif;
	endwhile;

	return false; // Belts and braces - we didn't get the lock if we get here
	
end;</source>
        <Parameter name="lockExObj" type="LockException"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="siteEnumToString" id="45186f37-032c-41f8-a3fa-212cf849885c">
