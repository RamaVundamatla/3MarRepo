    <JadeMethod name="isHoldRecSplitWLE" id="e55f5344-6f16-45fa-a891-86ab262c03b5">
        <source>isHoldRecSplitWLE() : Boolean;
/*
Purpose: return true IF the TI is:
	In a discharge hold job
	Is  splittable break bulk
	Has been split
	Has been split from 'parent' on a voyage
	Is in a crane/WP transfer area
	


Date		Who		Reason
06 October 2021	navab1	TFS 51988
*/

vars
	currentLocation : CM_LocationsController;
begin
	if self.myTrackedItem = null then
		return false;
	endif;
	
	if self.job = null then
		return false;
	endif;
	
	if not self.job.isVoyageHoldJob then // IS HOLD JOB
		return false;
	endif;
	
	if not self.isReceipt then // IS DISCHARGE
		return false;
	endif;
	
	currentLocation := self.myTrackedItem.myPrimaryActualLocation;
	
	if currentLocation.isCraneLaneController() // 35091
	or currentLocation.isWorkPointLaneController() then // 35091	
		if self.myTrackedItem.myMasterTi = null then // not split
			return false;
		endif;
		
		currentLocation := self.myTrackedItem.myMasterTi.myPrimaryActualLocation;
		if not currentLocation.isVoyageController() then
			return false;
		endif;
		
		return self.myTrackedItem.isBulkByQuantity(); // IS SPLITTABLE BREAK BULK???
		
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLoadedToOperations" id="c3cff8b0-da0b-4062-9639-2b12e3553cfe">
        <source>isLoadedToOperations():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2013	cnwndl1	Initial creation	Par 31102
15 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
07 Dec 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
*/

vars

begin

	if self.job = null then
		return false;
	endif;
	
	//if self.job.isVoyageHoldJob and self.job.getMyTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 51935	// TFS 52293
	if self.job.isVoyageHoldJob and self.job.isDirectDeliveryJob then										// TFS 51935	// TFS 52293
		return true;																						// TFS 51935
	endif;																									// TFS 51935
	
	return self.job.CM_VoyageJob.isLoadedToOperations;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
