    <JadeMethod name="isStorageDetailMatch" id="c6e8ff9e-16a2-40d8-8870-3893abd51874">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose: to match trailer types			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navhl20 Bug MTN-34910: MTN - Road Gate Autocomplete is not working

*/
vars
	trailerType	: CM_TILCType;
	ti			: CM_TrackedItem;
	yaData		: CM_YAData;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then
		ti := _tiTrx.myTrackedItem;
	else
		ti := _ti;
	endif;
	
	if not ti.isTILC then
		return false;
	endif;
		
	trailerType := ti.CM_TILC.myTILCType;
	
	yaData := _criteria.myYAData;
	
	// specific value - 31221 handle wild cards as well
	if yaData.CM_YADataObjects.matchesStorage(trailerType) then
		return true;
	endif;
	
	// default value
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
