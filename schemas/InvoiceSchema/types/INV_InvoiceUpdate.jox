    <JadeMethod name="canUpdateExtRefFields" id="28e047ab-09f4-4281-a06b-fa24eb69307f">
        <source>canUpdateExtRefFields() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	invDesc		: CM_InvoiceDesc;
	inv			: CM_Invoice;
	
begin
	inv := self.myCurrentInvoice;
	
	return inv.isManUpdeExtRefAllowedForUser(); 
	
epilog

end;</source>
