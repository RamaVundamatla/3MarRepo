    <JadeMethod name="initTable" id="cd987334-9d71-4122-9f8e-1f10ec692f66">
        <source>initTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	Par 30842

*/

vars

begin

	self.tblJobs.fontName := "Tahoma";
	self.tblJobs.fixedRows := 1;

	self.tblJobs.columns := 2;
	self.tblJobs.rows := 1;
	
	self.tblJobs.setCellText(1,1, app.getErrorString(Job) &amp; Tab &amp; app.getErrorString(CM_Crane_GC));

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTable" id="bd120b76-99b2-4937-9387-ba4b5c14bfa6">
        <source>populateTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	Par 30842
10 December 2014    cnwma1 PAR #35359  Change Jobs - 1090 Error
*/

vars
	idx			: Integer;
	rows		: Integer;
	aJob		: CM_Job;
	theVoyageJob,
	aVoyageJob 			: CM_VoyageJob;
	aVoyageAllocation 	: CM_VoyageAllocation;
	theVoyageJobs		: CM_JobSet;
	aRequest 			: CM_Request;
	aWLE				: CM_WorkListEntry;
	task				: CM_RTQueueTask;
	aEntry				: CM_RTQueueEntry;
	tblStr				: String;
begin
	
	aWLE := self.myTrackedItem.getVoyageWLEUnactioned( true );
	
	if aWLE = null then 
		return;
	endif;
	
	
	/*
	aEntry := aWLE.allRTQueueEntries.last;
	
	if aEntry = null then
		return;
	endif;
	
	task := aEntry.allTasks.last;	
	
	if task = null then
		return;
	endif;
	
	if task.ti = null then // no cargo so no point moving it.
		return;
	endif;
	*/
	
	// we need to see if this task is for a voyage allocation load job	
	// then we need to see if there are other jobs for the same allocation with free slots &amp; wle's with unasigned cargo.
	// then we can build the menu!
	
	aJob := aWLE.job;
	
	if aJob = null then
		return;
	endif;
	//aJob := task.myEntry.myJob;
	
	if not aJob.isKindOf(CM_VoyageJob) then // only for voyage jobs
		return;
	else
		theVoyageJob := aJob.CM_VoyageJob;
	endif;
	
	//aRequest := task.myEntry.myWorkListEntry.myRequest;
	aRequest := aWLE.myRequest;
	
	aVoyageAllocation :=aRequest.getFirstAllocation();  //should only be one anyhow.
	
	if aVoyageAllocation = null then //has to be a voyage allocation job
		return;
	endif;
	
	// ok so we are a task with a ti and for a voyage alloc load job
	
	create theVoyageJobs transient;

	foreach aRequest in aVoyageAllocation.allSlotRequests do
		if aRequest.myJob &lt;&gt; null then							//10/12/2014 cnwma1 PAR #35359
			if aRequest.myJob = theVoyageJob then
				continue;
			endif;
			
			if aRequest.myJob.isCompleteForExit then //cnwrd1 par 34038
				continue;
			endif;		
		//	if aRequest.allWorkListEntries.first.myTrackedItem = null then // removed for #33446 cnwrd1
				aVoyageJob := aRequest.myJob.CM_VoyageJob;
				if aVoyageJob&lt;&gt; null and aVoyageJob.isLoadedToOperations then
					theVoyageJobs.addNoDuplicates(aVoyageJob,false);
				endif;
		//	endif;
		endif;
	endforeach;
	
	foreach aRequest in aVoyageAllocation.allRequests do
		if aRequest.myJob = theVoyageJob then
			continue;
		endif;
		
	//	if aRequest.allWorkListEntries.first.myTrackedItem = null then // removed for #33446 cnwrd1
			aVoyageJob := aRequest.myJob.CM_VoyageJob;
			if aVoyageJob&lt;&gt; null and aVoyageJob.isLoadedToOperations then
				theVoyageJobs.addNoDuplicates(aVoyageJob,false);
			endif;
	//	endif;
	endforeach;	
		
	idx := 1;
	foreach aJob in theVoyageJobs do	
		aVoyageJob := aJob.CM_VoyageJob;
		tblStr :=  aVoyageJob.id &amp; Tab &amp; aVoyageJob.craneId;
		rows := tblJobs.rows + 1;
		tblJobs.rows := rows;
		self.tblJobs.setCellText(rows,1, tblStr);
		self.tblJobs.accessRow(rows).itemObject := aJob;	
	endforeach;
	
	if not theVoyageJobs.isEmpty then
		self.btnOne.enabled := true;
	endif;
	
epilog
	delete theVoyageJobs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="bc74247f-cdf4-476f-aa36-9b8de65280f5">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	30842

*/

vars

begin

	self.initTable();
	
	btnOne.enabled := false;
	
	self.doResizeControls(true);
	
	self.populateTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ebc5c46d-0e43-4434-a67c-8fd24b29d33b">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	30842

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.myVoyage := self.myMobileGenericAgent.myVoyage;
	self.caption := self.caption &amp; " : " &amp; self.myVoyage.code;

	self.setupCmdButtons( 2, app.getErrorString(Select), app.getErrorString(Back), null, null, null );
	
	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;

	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8fa1beb2-ace1-4373-a8ef-91347d8476c1">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018481, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
