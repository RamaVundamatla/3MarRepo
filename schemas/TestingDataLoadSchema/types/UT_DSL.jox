    <JadeMethod name="getInvoiceType" id="c2934327-a1a7-480f-89e4-97dd1d74e75b">
        <source>getInvoiceType(_description : String) : CM_InvoiceDesc;
// return the invoice type for the given description (is unique by description)
vars
	inv : CM_InvoiceDesc;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	foreach inv in bank.invoiceTypes  discreteLock do
		if inv.description = _description then
			return inv;
		endif;
	endforeach;
	
	return null;
end;
</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="getJobLOLOControllerByID" id="9c2800f7-19c3-468d-8223-5262dc63d460">
        <source>getJobLOLOControllerByID(_voyCode : String;_bayCode : String;_location : String) : CM_SlotController;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2012		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	strs : StringArray;
	slot  : CM_LocationsController;
	idx   : Integer;
begin
	create strs transient;
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	self.assertTrueMsg((voyage &lt;&gt; null), "Voyage cannot be found - " &amp; _voyCode);
	
	strs.add(_location);
	voyage.findLocation(strs, true, slot,idx);
	self.assertTrueMsg((slot &lt;&gt; null), "Location " &amp; _location &amp; " cannot be found on " &amp; _voyCode);
	self.assertTrueMsg((slot.isKindOf(CM_SlotController)), "Location " &amp; _location &amp; " is not a SlotController");
	self.assertTrueMsg((slot.CM_SlotController.myBayVoyage.id =  _bayCode), "Location " &amp; _location &amp; " found for wrong bay - " &amp; _bayCode);
	
	return slot.CM_SlotController;
epilog

	delete strs;

end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_bayCode" type="String"/>
        <Parameter name="_location" type="String"/>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="getJobROROControllerByID" id="1e3cc45d-4e37-4bae-b242-6a4e1f0dcec3">
        <source>getJobROROControllerByID(_voyCode : String;_deckCode : String; _subDeckCode : String; _startLocation : String; _slots : CM_LCArray input; _isLoad : Boolean; _numItems : Integer);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	theDeck : CM_DeckVoyage;
	roroVoyageStructure : CM_ROROVoyageStructure;
	slotDefn : CM_ROROSlotDefn;
	slot  : CM_ROROSlotController;
	idx   : Integer;
begin
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	roroVoyageStructure:=voyage.myROROStructure;
	self.assertTrueMsg((roroVoyageStructure &lt;&gt; null), "RORO Structure cannot be found!");
	
	theDeck:=roroVoyageStructure.allDecksByCode[_deckCode];
	self.assertTrueMsg((theDeck &lt;&gt; null), "Deck " &amp; _deckCode &amp; " cannot be found!");
	
	if _subDeckCode &lt;&gt; null then
		theDeck := theDeck.getSubDeckByCode(_subDeckCode).CM_DeckVoyage;
		self.assertTrueMsg((theDeck &lt;&gt; null), "SUB Deck " &amp; _deckCode &amp; " cannot be found!");
	endif;
	
	slotDefn := theDeck.allSlotDefnByCode[_startLocation];
	self.assertTrueMsg((slotDefn &lt;&gt; null), "Location " &amp; _startLocation &amp; " cannot be found!");
	
	_slots.add( slotDefn.CM_ROROSlotDefnVoyage.mySlotController);
	

epilog



end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_deckCode" type="String"/>
        <Parameter name="_subDeckCode" type="String"/>
        <Parameter name="_startLocation" type="String"/>
        <Parameter name="_slots" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobROROGCController" id="aa0f2e2c-4087-4027-97cc-92c7a8c5c2aa">
        <source>getJobROROGCController(_voyCode : String;_deckCode : String;_slots : CM_LCArray input; _isLoad : Boolean);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	theDeck : CM_DeckVoyage;
	roroVoyageStructure : CM_ROROVoyageStructure;

	slot  : CM_ROROGCController;
	idx   : Integer;
begin
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	roroVoyageStructure:=voyage.myROROStructure;
	assertTrue(roroVoyageStructure &lt;&gt; null);
	
	theDeck:=roroVoyageStructure.allDecksByCode[_deckCode];
	assertTrue(theDeck &lt;&gt; null);
	
	foreach slot in theDeck.allROROGCControllers  discreteLock do
		if _isLoad then
			if slot.myRORORequestLoad &lt;&gt; null then
				continue;
			endif;
			_slots.add(slot);
		else
			if slot.myRORORequestDischarge = null then
				continue;
			endif;
			_slots.add(slot);

		endif;
	endforeach;
epilog



end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_deckCode" type="String"/>
        <Parameter name="_slots" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getJobROROGCControllerByID" id="fa152d37-6e4a-4c36-b3e9-b5979582c8cb">
        <source>getJobROROGCControllerByID(_voyCode : String;_deckCode : String; _subDeckCode : String; _location : String; _slots : CM_LCArray input; _isLoad : Boolean; _numItems : Integer);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	theDeck : CM_DeckVoyage;
	roroVoyageStructure : CM_ROROVoyageStructure;
	gcDefn : CM_ROROGCDefn;
	slot  : CM_ROROSlotController;
	idx   : Integer;
begin
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	roroVoyageStructure:=voyage.myROROStructure;
	self.assertTrueMsg((roroVoyageStructure &lt;&gt; null), "RORO Structure cannot be found!");
	
	theDeck:=roroVoyageStructure.allDecksByCode[_deckCode];
	self.assertTrueMsg((theDeck &lt;&gt; null), "Deck " &amp; _deckCode &amp; " cannot be found!");
	
	if _subDeckCode &lt;&gt; null then
		theDeck := theDeck.getSubDeckByCode(_subDeckCode).CM_DeckVoyage;
		self.assertTrueMsg((theDeck &lt;&gt; null), "SUB Deck " &amp; _deckCode &amp; " cannot be found!");
	endif;
	
	gcDefn := theDeck.allROROGCDefnByCode[_location];
	self.assertTrueMsg((gcDefn &lt;&gt; null), "Location " &amp; _location &amp; " cannot be found!");
	
	_slots.add( gcDefn.CM_ROROGCDefnVoyage.myGCController);
	

epilog



end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_deckCode" type="String"/>
        <Parameter name="_subDeckCode" type="String"/>
        <Parameter name="_location" type="String"/>
        <Parameter name="_slots" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobROROLaneController" id="5d64db3b-aa53-4a42-840d-363f70c0afc9">
        <source>getJobROROLaneController(_voyCode : String;_deckCode : String;_slots : CM_LCArray input; _isLoad : Boolean; _ordinal : Integer);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	theDeck : CM_DeckVoyage;
	roroVoyageStructure : CM_ROROVoyageStructure;

	slot  : CM_ROROLaneController;
	idx   : Integer;
begin
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	roroVoyageStructure:=voyage.myROROStructure;
	assertTrue(roroVoyageStructure &lt;&gt; null);
	
	theDeck:=roroVoyageStructure.allDecksByCode[_deckCode];
	assertTrue(theDeck &lt;&gt; null);
	
	if _ordinal &gt; 0 then
		slot :=  theDeck.allROROLaneControllers[0,_ordinal];
		if slot &lt;&gt; null then
			_slots.add(slot);
		endif;
		return;
	endif;
	
	foreach slot in theDeck.allROROLaneControllers  discreteLock do
		if _isLoad then
			if slot.myRORORequestLoad &lt;&gt; null then
				continue;
			endif;
			_slots.add(slot);
		else
			if slot.myRORORequestDischarge = null then
				continue;
			endif;
			_slots.add(slot);

		endif;
	endforeach;
epilog



end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_deckCode" type="String"/>
        <Parameter name="_slots" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_ordinal" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobROROSlotController" id="4616e0be-8d22-4745-a0ea-4f13bd4c74bd">
        <source>getJobROROSlotController(_voyCode : String;_deckCode : String;_slots : CM_LCArray input; _isLoad : Boolean; _numItems : Integer);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	theDeck : CM_DeckVoyage;
	roroVoyageStructure : CM_ROROVoyageStructure;

	slot  : CM_ROROSlotController;
	idx   : Integer;
begin
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	roroVoyageStructure:=voyage.myROROStructure;
	assertTrue(roroVoyageStructure &lt;&gt; null);
	
	theDeck:=roroVoyageStructure.allDecksByCode[_deckCode];
	assertTrue(theDeck &lt;&gt; null);
	
	foreach slot in theDeck.allROROSlotControllers  discreteLock do
		if _isLoad then
			if slot.myRORORequestLoad &lt;&gt; null then
				continue;
			endif;
			
			if slot.myRORORequestLoad &lt;&gt; null and slot.myRORORequestLoad.isBackEndRequest() then
				continue;
			endif;
			
			
			// ignore OOTL used for discharge
			if slot.mySlotDefn.myROROLocnDen.isOOTL and slot.myRORORequestDischarge &lt;&gt; null then
				continue;
			endif;
			
			
			idx := idx + 1;
			_slots.add(slot);
			
			if _numItems &lt;&gt; 0 and  idx &gt;= _numItems then
				break;
			endif;
		else
			if slot.myRORORequestDischarge = null then
				continue;
			endif;
			if slot.myRORORequestDischarge.isBackEndRequest() then
				continue;
			endif;			
			idx := idx + 1;
			_slots.add(slot);
			
			if _numItems &lt;&gt; 0 and  idx &gt;= _numItems then
				break;
			endif;

		endif;
	endforeach;
epilog



end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_deckCode" type="String"/>
        <Parameter name="_slots" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobSlotControllers" id="04c47aeb-56d4-4cd9-8c18-0c83bdb7dbb8">
        <source>getJobSlotControllers(_voyCode : String;
						_bayNum : String; 
						_startDeck,
						_startCell,
						_startTier,
						_numberToFind : Integer;
						_slots : CM_SlotControllerArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	voyage : CM_Voyage;
	bay : CM_BayVoyage;
	cellularVoyageStructure : CM_CellularVoyageStructure;
	iter : Iterator;
	slot  : CM_SlotController;
	idx   : Integer;
begin
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	//					  - so don't pass in cell/teir id - pass in relative position in bay, i.e. 1st cell, 2nd teir
	//create a voyage job for bay 
	
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_voyCode, null);
	cellularVoyageStructure:=voyage.myCellularVoyageStructure;
	assertTrue(cellularVoyageStructure &lt;&gt; null);
	bay:=cellularVoyageStructure.allBayVoyagesById[_bayNum];
	assertTrue(bay &lt;&gt; null);
	
	
	//we have 20 containers so create a job for 20 containers 
	//will create a job in the order of the dict so start at ordinal deck on deck and cell 1 tier 1
	// i.e. it will fill up all ondeck columns then move to the next row
	iter:=bay.allSlotControllersByOrdinal.createIterator;
	bay.allSlotControllersByOrdinal.startKeyGeq(_startDeck,_startCell,_startTier,iter);
		
	
	while iter.next(slot) do 
		if idx = _numberToFind then
			break;
		endif;
		_slots.add(slot);
		idx:=idx+1;
	endwhile;
	

epilog
	delete iter;


end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_bayNum" type="String"/>
        <Parameter name="_startDeck" type="Integer"/>
        <Parameter name="_startCell" type="Integer"/>
        <Parameter name="_startTier" type="Integer"/>
        <Parameter name="_numberToFind" type="Integer"/>
        <Parameter name="_slots" type="CM_SlotControllerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocationsController" id="49ed17c1-2d9a-4915-b388-30b16fbc59a0">
