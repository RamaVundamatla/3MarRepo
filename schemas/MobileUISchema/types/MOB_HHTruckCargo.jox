    </JadeMethod>
    <JadeMethod name="populateFromUserSelectedBRItem" id="f02fd8d0-1f7f-4b80-8b35-48a610f8524b">
        <updating/>
        <source>populateFromUserSelectedBRItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2010	cnwndl1	Initial creation	Par 25744

*/

vars

	bookingRef : String;
	bookingRefItem : CM_BookingRefItem;
	cargoTypeInteger : Integer;
	cargoType : CM_CargoType;
	row : Integer;
	isoType : CM_ISOType;
	commodity : CM_Commodity;
	operator : CM_Operator;
	product : CM_Product;
	voyage : CM_Voyage;
	portString : String;
	port : CM_Port;
	consign : CM_ConsigneeConsignor;
	
begin

	bookingRef := self.getStringValueFromTable( ETRow_BookingReference );
	bookingRefItem := self.cmbBRItem.listObject.CM_BookingRefItem;
	if bookingRefItem = null then
		return;
	endif;
	
	cargoTypeInteger := bookingRefItem.cargoType;
	if cargoTypeInteger &gt; 0 then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(cargoTypeInteger);
		if cargoType &lt;&gt; null then
			if cmbType.listObject &lt;&gt; cargoType then
				self.cmbType.listIndex := self.cmbType.findObject(cargoType);
				self.tblCargo.setValueByControlName(self.cmbType.name, self.cmbType.text);
				self.resetEntTableIfRequired( self.cmbType );
				row := tblCargo.getRow( ETRow_BookingReference );
				if row &gt; 0 then
					self.tblCargo.setCellText( row, 2, bookingRef);
					self.populateCmbBRItem();
					self.cmbBRItem.listIndex := self.cmbBRItem.findObject(bookingRefItem);
					self.tblCargo.setValueByControlName(self.cmbBRItem.name, self.cmbBRItem.text);
				endif;
			endif;
			self.cmbType.listIndex := self.cmbType.findObject(cargoType);
			self.tblCargo.setValueByControlName(self.cmbType.name, self.cmbType.text);
		endif;
	endif;
	
	if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
		isoType := bookingRefItem.myISOType;
		row := tblCargo.getRow( ETRow_IsoType );
		if row &gt; 0 and isoType &lt;&gt; null then
			self.cmbISOType.listIndex := self.cmbISOType.findObject(isoType);
		else
			self.cmbISOType.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbISOType.name, self.cmbISOType.text);
	endif;
	
	if tblCargo.getRow(ETRow_SubCargoType) &gt; 0 then
		product := bookingRefItem.myProduct;
		if product &lt;&gt; null then
			self.cmbSubCargo.listIndex := self.cmbSubCargo.findObject(product);
		else
			self.cmbSubCargo.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbSubCargo.name, self.cmbSubCargo.text);
	endif;
	
	if tblCargo.getRow(ETRow_VoyageCode) &gt; 0 and bookingRefItem.myBookingReference &lt;&gt; null then
		voyage := bookingRefItem.myBookingReference.myVoyage;
		if voyage &lt;&gt; null then
			self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);
		else
			self.cmbVoyage.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbVoyage.name, self.cmbVoyage.text);
		self.populateVoyageDependantCombos();
	endif;

	if tblCargo.getRow(ETRow_VoyageOperator) &gt; 0 then
		if bookingRefItem.getOperatorCode &lt;&gt; null then
			operator := app.myRoot.allOperators.getAtKey( bookingRefItem.getOperatorCode );
			if operator &lt;&gt; null then
				self.cmbOperator.listIndex := self.cmbOperator.findObject(operator);
			else
				self.cmbOperator.listIndex := -1;
			endif;
			self.tblCargo.setValueByControlName(self.cmbOperator.name, self.cmbOperator.text);
		endif;
	endif;
	
	if tblCargo.getRow(ETRow_DestinationPort) &gt; 0 then
		portString := bookingRefItem.getDestinationPort();
		if portString &lt;&gt; null then
			port := app.myRoot.allPorts.getAtKey(portString);
		endif;
		if port &lt;&gt; null then
			self.cmbDestination.listIndex := self.cmbDestination.findObject(port);
		else
			self.cmbDestination.listIndex  := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbDestination.name, self.cmbDestination.text);
	endif;
	
	if tblCargo.getRow(ETRow_DischargePort) &gt; 0 then
		portString := bookingRefItem.getDischargePort();
		if portString &lt;&gt; null then
			port := app.myRoot.allPorts.getAtKey(portString);
		endif;
		if port &lt;&gt; null then
			self.cmbDischarge.listIndex := self.cmbDischarge.findObject(port);
		else
			self.cmbDischarge.listIndex  := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbDischarge.name, self.cmbDischarge.text);
	endif;
	
	if tblCargo.getRow(ETRow_Commodity) &gt; 0 then
		if bookingRefItem.commodity &lt;&gt; null then
			commodity := bookingRefItem.getCommodityObj;
		endif;
		if commodity &lt;&gt; null then
			self.cmbCommodity.listIndex := self.cmbCommodity.findObject(commodity);
		else
			self.cmbCommodity.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSubCargo" id="b1c34cb2-67c7-48bb-8943-a5c8d243c65c">
        <source>populateSubCargo( _cargoType : CM_CargoType ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	beforeProd : CM_Product;
	beforeCommodity : CM_Commodity;
	beforeTrailerType : CM_TILCType;
	iter : Iterator;
	product : CM_Product;
	commodity : CM_Commodity;
	tilc : CM_TILCType;
	
	row : Integer;
	
begin

	beforeProd := cmbSubCargo.listObject.CM_Product;
	beforeCommodity := cmbCommodity.listObject.CM_Commodity;
	beforeTrailerType := cmbTrailerType.listObject.CM_TILCType;	//24 Sep 2013	NDL	Par 32556
	self.cmbSubCargo.clear();
	self.cmbCommodity.clear();
	self.cmbTrailerType.clear();	//24 Sep 2013	NDL	Par 32556
	
	if _cargoType = null then
		
		// 24 Mar 2010	NDL	Par 23316 - Put this back again.
		foreach commodity in app.myRoot.allCommodities do
			if commodity.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbCommodity.itemObject[self.cmbCommodity.addItem(commodity.getDisplayDetails(false))] := commodity;
		endforeach;
	
	else
	//	if _cargoType.allCommodities.isEmpty then
	//27 Mar 2014	NDL	Par 33748 - don't show any that are not valid for the cargo type.
		if _cargoType.allCommodities.isEmpty and _cargoType.isCommodityRequired then
			foreach commodity in app.myRoot.allCommodities do
				if commodity.isNotAvailableForEntry then
					continue;
				endif;
				self.cmbCommodity.itemObject[self.cmbCommodity.addItem(commodity.getDisplayDetails(false))] := commodity;
			endforeach;
		else
			foreach commodity in _cargoType.allCommodities do
				if commodity.isNotAvailableForEntry then
					continue;
				endif;
				self.cmbCommodity.itemObject[self.cmbCommodity.addItem(commodity.getDisplayDetails(false))] := commodity;
			endforeach;
		endif;
		
		foreach product in _cargoType.allProducts do
			if product.isNotActive then
				continue;
			endif;
			self.cmbSubCargo.itemObject[self.cmbSubCargo.addItem(product.description )] := product;
		endforeach; 
		
		//24 Sep 2013	NDL	Par 32556
		foreach tilc in app.myRoot.allTILCTypes do
			if tilc.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbTrailerType.itemObject[self.cmbTrailerType.addItem(tilc.description )] := tilc;
		endforeach;
	
	endif;
	
	if beforeProd &lt;&gt; null then
		self.cmbSubCargo.listIndex := self.cmbSubCargo.findObject(beforeProd);
		self.tblCargo.setValueByControlName(self.cmbSubCargo.name, self.cmbSubCargo.text);
	endif;
	if beforeCommodity &lt;&gt; null then
		self.cmbCommodity.listIndex := self.cmbCommodity.findObject(beforeCommodity);
		self.tblCargo.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
	endif;
	//24 Sep 2013	NDL	Par 32556
	if beforeTrailerType &lt;&gt; null then
		self.cmbTrailerType.listIndex := self.cmbTrailerType.findObject(beforeTrailerType);
		self.tblCargo.setValueByControlName(self.cmbTrailerType.name, self.cmbTrailerType.text);
	endif;
	
	row := self.tblCargo.getRow( ETRow_SubCargoType );
	if row &gt; 0 then
		if self.cmbSubCargo.listCount = 0 then
			if self.tblCargo.isRowVisible(ETRow_SubCargoType) then
				self.tblCargo.hideRowByName(ETRow_SubCargoType, false);
			endif;
		else
			if not self.tblCargo.isRowVisible(ETRow_SubCargoType) then
				self.tblCargo.showRowByName(ETRow_SubCargoType, false);
			endif;
		endif;
	endif;
	
	row := self.tblCargo.getRow( ETRow_Commodity );
	if row &gt; 0 then
		if self.cmbCommodity.listCount = 0 then
			if self.tblCargo.isRowVisible(ETRow_Commodity) then
				self.tblCargo.hideRowByName(ETRow_Commodity, false);
			endif;
		else
			if not self.tblCargo.isRowVisible(ETRow_Commodity) then
				self.tblCargo.showRowByName(ETRow_Commodity, false);
			endif;
		endif;
	endif;
	
	//24 Sep 2013	NDL	Par 32556
	row := self.tblCargo.getRow( ETRow_TrailerType );
	if row &gt; 0 then
		if self.cmbTrailerType.listCount = 0 then
			if self.tblCargo.isRowVisible(ETRow_TrailerType) then
				self.tblCargo.hideRowByName(ETRow_TrailerType, false);
			endif;
	//04 Mar 2014	NDL	Par 33596
	//	else
	//		if not self.tblCargo.isRowVisible(ETRow_TrailerType) then
	//			self.tblCargo.showRowByName(ETRow_TrailerType, false);
	//		endif;
		endif;
	endif;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="populateVoyageDependantCombos" id="48f192a7-7f62-4417-9e91-4287c0cb98e7">
        <source>populateVoyageDependantCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwndl1	Initial creation

*/

vars

	voyage : CM_Voyage;
	tmpPassport : CM_Passport;
	failedDAC  :CM_DataAccessController;
	operator : CM_Operator;
	startOperator : CM_Operator;
	port : CM_Port;
	destPort : CM_Port;
	dischgPort : CM_Port;
	
begin

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	
	tmpPassport := app.myPassport;
	startOperator := self.cmbOperator.listObject.CM_Operator;
	self.cmbOperator.clear();
	if voyage = null or voyage.isNullVoyage then	// 24 Mar 2010	NDL	Par 23282
		foreach operator in app.myRoot.allOperators do
			if operator.isNotAvailableForEntry then
				continue;
			endif;
			if tmpPassport &lt;&gt; null and (not operator.canUserAccessSelf(null, failedDAC, tmpPassport)) then
				continue;
			endif;
			self.cmbOperator.itemObject[self.cmbOperator.addItem(operator.code &amp; Tab &amp; operator.description)] := operator;
		endforeach;
	else
		foreach operator in voyage.allOperators do
			if operator.isNotAvailableForEntry then
				continue;
			endif;
			if tmpPassport &lt;&gt; null and (not operator.canUserAccessSelf(null, failedDAC, tmpPassport)) then
				continue;
			endif;
			self.cmbOperator.itemObject[self.cmbOperator.addItem(operator.code &amp; Tab &amp; operator.description)] := operator;
		endforeach;
	endif; 
	if startOperator &lt;&gt; null then
		self.cmbOperator.listIndex := self.cmbOperator.findObject(startOperator);
		self.tblCargo.setValueByControlName(self.cmbOperator.name, self.cmbOperator.text);
	endif; 
	
/*
	destPort := self.cmbDestination.listObject.CM_Port;
	self.cmbDestination.clear();
	if voyage = null then
		foreach port in app.myRoot.allActiveDestinations do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDestination.itemObject[self.cmbDestination.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	else
		foreach port in app.myRoot.allActiveDestinations do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDestination.itemObject[self.cmbDestination.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	endif;
	
	if destPort &lt;&gt; null then
		self.cmbDestination.listIndex := self.cmbDestination.findObject(destPort);
		self.tblCargo.setValueByControlName(self.cmbDestination.name, self.cmbDestination.text);
	endif;
*/	
	
	
	
	
	dischgPort := self.cmbDischarge.listObject.CM_Port;
	self.cmbDischarge.clear();
	if voyage = null then
		foreach port in app.myRoot.allActivePorts do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDischarge.itemObject[self.cmbDischarge.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	else
		foreach port in voyage.allPorts do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDischarge.itemObject[self.cmbDischarge.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	endif;
	
	if dischgPort &lt;&gt; null then
		self.cmbDischarge.listIndex := self.cmbDischarge.findObject(dischgPort);
		self.tblCargo.setValueByControlName(self.cmbDischarge.name, self.cmbDischarge.text);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetEntTableIfRequired" id="88a74beb-b0ad-4e26-a1c0-024889beeae3">
        <updating/>
        <source>resetEntTableIfRequired( combobox : ComboBox input ) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/02/2010	cnwndl1	Initial creation	CCMS MES 1005
11/03/2010	cnwdap1	PAR #22938 Correct reefer handling - any cargo can be a reefer
22 May 2013	NDL	- CCMS 2274 Break Bulk
05 May 2016 EPR 	TFS 1939 trying to improve performance not calling the table load twice and populating the combos so many times
*/
vars
	
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	isoType : CM_ISOType;
	subCargo : CM_Product;
	entTableString : String;
	imex	: CM_IMEXStatus;
	
	product : CM_Product;
	lengthRow : String;
	widthRow : String;
	heightRow : String;
	volumeRow : String;
	weightRow : String;
	id : String;
	length : Decimal [16,4];
	width : Decimal [16,4];
	height : Decimal [16,4];
	volume : Decimal [16,4]; 
	weight : Decimal [16,4]; 
	quantity : Integer;
	totalQuantity : Integer;
	colour : String;
	mark : String;
	make : String;
	model : String;
	vehicleType : String;
	year : Integer;
	measureTbl : CMUI_MeasurementTable;
	measureType : CM_MeasurementType;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		cargoType := self.myTrackedItem.myCargoType;			
		commodity := app.myRoot.allCommodities[self.myTrackedItem.commodity];
		isoType := app.myRoot.allISOTypes[self.myTrackedItem.getISOType];
		subCargo :=  self.myTrackedItem.myProduct;
		imex  :=  app.myRoot.allImexStatuses[self.myTrackedItem.getImExStatus];		
	else
		cargoType := self.cmbType.listObject.CM_CargoType;
		commodity := self.cmbCommodity.listObject.CM_Commodity;
		isoType := self.cmbISOType.listObject.CM_ISOType;
		subCargo := self.cmbSubCargo.listObject.CM_Product;
		imex  := self.cmbImexStatus.listObject.CM_IMEXStatus;					//+cnwml2 PAR25745
		
		//10 Jan 2018	NDL TFS 36411
		if self.formAction = self.UnloadingUnknownTi then
			// gather up any user entered values.
			product := self.getProductForMeasurementType();
			lengthRow := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
			widthRow := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
			heightRow := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
			if cargoType = null then
				volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
				weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
			else
				volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Volume,true).shortName;
				weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Weight,true).shortName;
			endif;
			id := getStringValueFromTable( ETRow_CargoId ).toUpper.String;
			length := self.getStringValueFromTable( lengthRow ).Decimal;
			width := self.getStringValueFromTable( widthRow ).Decimal;
			height := self.getStringValueFromTable( heightRow ).Decimal;
			volume := self.getStringValueFromTable( volumeRow ).Decimal; 
			weight := self.getStringValueFromTable( weightRow ).Decimal; 
			quantity := getStringValueFromTable( ETRow_Quantity ).Integer;
			totalQuantity := getStringValueFromTable( ETRow_NumItems ).Integer;
			colour :=  getStringValueFromTable( ETRow_Colour ).String;
			mark :=  getStringValueFromTable( ETRow_Mark ).String;
			make :=  getStringValueFromTable( ETRow_Make ).String;
			model :=  getStringValueFromTable( ETRow_Model ).String;
			vehicleType :=  getStringValueFromTable( ETRow_VehicleType ).String;
			year :=  getStringValueFromTable( ETRow_Year ).Integer;
		endif;
		
	endif;
	
	if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
		entTableString := ETDef_ContainerFull;
		if commodity &lt;&gt; null and commodity.isEmpty then
				entTableString := ETDef_ContainerEmpty;
		elseif ( isoType &lt;&gt; null and isoType.isReefer ) or ( subCargo &lt;&gt; null and subCargo.isReefer ) or ( cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer ) then
			entTableString := ETDef_ContainerFullReefer;
		endif;
	else
		entTableString := ETDef_GeneralCargo;
		// PAR #22938 allow for non-container reefers
		if ( isoType &lt;&gt; null and isoType.isReefer ) or ( subCargo &lt;&gt; null and subCargo.isReefer ) or ( cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer ) then
			entTableString := ETDef_GeneralCargoReefer;
		endif;
	endif;
	
	//if not self.lockedDown and self.myEntTableDef = null or ( self.myEntTableDef.name &lt;&gt; entTableString ) then
		//self.initTblCargo( entTableString );
	//endif;	
	
	///////////////////////cnwas3 par 23825 begin
	if cargoType = null then
		cargoType := self.cmbType.listObject.CM_CargoType;//in case we have clicked on an already defined piece of cargo...would be null otherwise because of the process above
		subCargo := self.cmbSubCargo.listObject.CM_Product;	//09 Oct 2013	NDL	Par 32764
	endif;
	
	self.initTblCargo( entTableString );
	
	//set the cargo and sub cargo before populating the combos 
	if cargoType &lt;&gt; null then
		self.tblCargo.setValueByName(ETRow_CargoType,cargoType.description);
	endif;
	if subCargo &lt;&gt; null then
		self.tblCargo.setValueByName(ETRow_SubCargoType,subCargo.description);
	endif;
		
	//hide rows  before populating the combos 
	if entTableString = ETDef_GeneralCargo or entTableString = ETDef_GeneralCargoReefer  then
		//23 Sep 2013	NDL	Par 32215
		self.tblCargo.hideRowByName(ETRow_Make, false);			
		self.tblCargo.hideRowByName(ETRow_Model, false);			
		self.tblCargo.hideRowByName(ETRow_VehicleType, false);
		self.tblCargo.hideRowByName(ETRow_Year, false);
		self.tblCargo.hideRowByName(ETRow_TrailerType, false);

		if cargoType &lt;&gt; null then
			self.hideAttributeRows(cargoType, subCargo);	//06 Sep 2013	NDL	Par 32413
			if cargoType.productType.isOneOf(ProductType_Trailer,ProductType_Vehicle) then			
				self.tblCargo.showRowByName(ETRow_Length, false);			
				self.tblCargo.showRowByName(ETRow_Width, false);			
				self.tblCargo.showRowByName(ETRow_Height, false);
			endif;
			if cargoType.productType = ProductType_Trailer then			
				self.tblCargo.showRowByName(ETRow_TrailerType,false);
			endif;
			//23 Sep 2013	NDL	Par 32215
			if cargoType.productType = ProductType_Vehicle then			
				self.tblCargo.showRowByNameAndUseShortName(ETRow_Make);	
				self.tblCargo.showRowByNameAndUseShortName(ETRow_Model);			
				self.tblCargo.showRowByNameAndUseShortName(ETRow_VehicleType);
				self.tblCargo.showRowByNameAndUseShortName(ETRow_Year);
			endif;
			
			if not cargoType.isCommodityRequired then
				self.tblCargo.hideRowByName(ETRow_Commodity, false);
			endif;		
		endif;
	endif;	
	
	self.setComboValues();
	
	//epr TFS 5406 26/7/17  if still null get them so right ent table and measurement table is set up
	if cargoType = null then
		cargoType := self.cmbType.listObject.CM_CargoType;//in case we have clicked on an already defined piece of cargo...would be null otherwise because of the process above
		subCargo := self.cmbSubCargo.listObject.CM_Product;	//09 Oct 2013	NDL	Par 32764
	endif;
	
	if ( self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canSplitTotalQuantity and self.myTrackedItem.isBulkByQuantity )
	or ( cargoType &lt;&gt; null and cargoType.allowDuplicates and cargoType.isBulkByQuantity )
	then
		self.tblCargo.showRowByName(ETRow_NumItems, false);
	else
		self.tblCargo.hideRowByName(ETRow_NumItems, false);
	endif; 
	
	if self.myEntTableView &lt;&gt; null then
		self.translateTableData(	self.tblCargo,  
									self.myEntTableView.allEntTableRows,
									self.myTrackedItem,
									cargoType,
									subCargo		//09 Oct 2013	NDL	Par 32764
									); 
	else
		self.translateTableData(	self.tblCargo,  
									self.myEntTableDef.allEntTableRows,
									self.myTrackedItem,
									cargoType,
									subCargo		//09 Oct 2013	NDL	Par 32764
									);
	endif;
	
	self.tblCargo.hideRowByName(ETRow_AlternativeId, false);	//19 Nov 2014	NDL	Par 35146
	
	self.loadTblCargo(); //04 Aug 2016	NDL	- Has to reload a second time to set the measurement tables correctly in case weight quantity or volume have been overridden...
	
	if combobox &lt;&gt; null then
		self.cmbType.listIndex := self.cmbType.findObject(cargoType);
		self.cmbCommodity.listIndex := self.cmbCommodity.findObject(commodity);
		self.cmbISOType.listIndex := self.cmbISOType.findObject(isoType);
	
		//add imex in here and always default to Export if there was no pre-existing imex selected
		if imex = null then
			imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];						//+cnwml2 PAR25745
		endif;
		self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imex);			//+cnwml2 PAR25745
		
		//self.tblCargo.setValueByControlName(self.tblCargo.name, self.tblCargo.text);
		self.tblCargo.setValueByControlName(self.cmbType.name, self.cmbType.text);
		self.tblCargo.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
		self.tblCargo.setValueByControlName(self.cmbISOType.name, self.cmbISOType.text);
		self.tblCargo.setValueByControlName(self.cmbImexStatus.name, self.cmbImexStatus.text);		//+cnwml2 PAR25745		
		//self.tblCargo.setValueByControlName(self.cmbSubCargo.name, self.cmbSubCargo.text);			
	/*	self.populateSubCargo( cargoType );
		//now need to reset the subtype if we have it as we have cleared and repopulated the combo
		self.cmbSubCargo.listIndex := self.cmbSubCargo.findObject(subCargo); //cnwrd1 par 33877
		self.tblCargo.setValueByControlName(self.cmbSubCargo.name, self.cmbSubCargo.text);	//cnwrd1 par 33877
		self.populateCmbDimType( cargoType );	//06 Sep 2013	NDL	Par 32413*/
	endif;
	

	
	self.setInitialCursorPosition();
	
	self.myMobileGenericAgent.setLocationPreChecks(null);			//cnwmc5 - 10 Jan 2014 - PAR 33233
	
	//10 Jan 2018	NDL TFS 36411
	if self.formAction = self.UnloadingUnknownTi then
		// try to put back any user entered values
		product := self.getProductForMeasurementType();
		cargoType := self.getCargoTypeForMeasurementType();
	
		lengthRow := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
		widthRow := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
		heightRow := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
		if cargoType = null then
			volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
			weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
		else
			volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Volume,true).shortName;
			weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Weight,true).shortName;
		endif;
		
		
		self.tblCargo.setValueByName(ETRow_CargoId, id );
		self.tblCargo.setValueByName(ETRow_Quantity, quantity );
		self.tblCargo.setValueByName(ETRow_NumItems, totalQuantity );
		self.tblCargo.setValueByName(ETRow_Colour, colour );
		self.tblCargo.setValueByName(ETRow_Mark, mark );
		self.tblCargo.setValueByName(ETRow_Make, make );
		self.tblCargo.setValueByName(ETRow_Model, model );
		self.tblCargo.setValueByName(ETRow_VehicleType, vehicleType );
		self.tblCargo.setValueByName(ETRow_Year, year );
		
		measureTbl := self.allMeasurementControls[lengthRow].CMUI_MeasurementTable;
	
		if measureTbl &lt;&gt; null then
			measureType := self.getDefaultMeasurementForType(product, Type_Length);
			measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, length) &amp; Space &amp; measureType.shortName);
			measureTbl.lostFocus( measureTbl );
		endif;
		measureTbl := self.allMeasurementControls[widthRow].CMUI_MeasurementTable;
		if measureTbl &lt;&gt; null then
			measureType := self.getDefaultMeasurementForType(product, Type_Width);
			measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, width) &amp; Space &amp; measureType.shortName);
			measureTbl.lostFocus( measureTbl );
		endif;
		measureTbl := self.allMeasurementControls[heightRow].CMUI_MeasurementTable;
		if measureTbl &lt;&gt; null then
			measureType := self.getDefaultMeasurementForType(product, Type_Height);
			measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, height) &amp; Space &amp; measureType.shortName);
			measureTbl.lostFocus( measureTbl );
		endif;
		measureTbl := self.allMeasurementControls[volumeRow].CMUI_MeasurementTable;
		if measureTbl &lt;&gt; null  then
			if cargoType &lt;&gt; null then 													
				measureType := cargoType.getMeasurementTypeFor(Type_Volume,true);		
			else
				measureType := app.getDefaultMeasurementForType( Type_Volume );       
			endif;
			measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, volume) &amp; Space &amp; measureType.shortName);
			measureTbl.lostFocus( measureTbl );
		endif;
		measureTbl := self.allMeasurementControls[weightRow].CMUI_MeasurementTable;
		if measureTbl &lt;&gt; null  then
			if cargoType &lt;&gt; null then 													
				measureType := cargoType.getMeasurementTypeFor(Type_Weight,true);	
			else
				measureType := app.getDefaultMeasurementForType( Type_Weight );       
			endif;
			measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, weight) &amp; Space &amp; measureType.shortName);
			measureTbl.lostFocus( measureTbl );
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
