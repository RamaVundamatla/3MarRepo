    <JadeMethod name="setConfig" id="5aa275e3-7431-4b2f-9876-596edd28a52e">
        <source>setConfig(pCode : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	logStr : String;
	oldValue : Any;
	newValue : Any;
	changeString : String;

begin

	oldValue := self.getStateData(ConfigGrp_System, pCode);	//04 Mar 2015 NDL	Par 34583

	self.setStateData(ConfigGrp_System, pCode, pValue);
	
	newValue := self.getStateData(ConfigGrp_System, pCode);	//04 Mar 2015 NDL	Par 34583
	
	//04 Mar 2015 NDL	Par 34583
	if oldValue &lt;&gt; newValue then
		changeString := "Term config " &amp; pCode &amp; ", was:'" &amp; oldValue.String &amp; "' now:'" &amp; newValue.String &amp; "'";
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									self,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									changeString,	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
			//02/06/2015 cnwdb2
/*		app.createActivityHistory(	ActivityHistoryUnitTest,	//_type : Integer;
									self,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									changeString,	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									); */
		//jlier1 TFS  61676 18/12/23							
		if pCode = AutoEvalReadyToLoad or pCode = AutoQueueReadyToLoad then
			if app.myPassport &lt;&gt; null then
				app.myPassport.setMyTerminal(app.myPassport.myTerminal);
			endif;
		endif;
	endif;
	
	if app.myLoggingForm &lt;&gt; null then
		if pCode = null then
			logStr := "null";
		else
			logStr := pCode;
		endif;
		logStr := logStr &amp; " = '" &amp; pValue.String &amp; "'";
		app.doFormLogging(method, logStr, null);
	endif;

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setDefaultCompanyBank" id="cdce805e-0a91-4a7e-8fbc-44537ec97389">
        <source>setDefaultCompanyBank( _bank : CM_Bank );

/*

