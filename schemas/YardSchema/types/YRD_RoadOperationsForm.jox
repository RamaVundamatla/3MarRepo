    <JadeMethod name="resetAllSubMenus" id="22b98ce5-2135-41cd-848e-dc583e703727">
        <source>resetAllSubMenus(_parent :MenuItem) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i 		:Integer;
	menu	:MenuItem;
begin
	while true do
		i := i + 1;
		
		menu := _parent.getMenuItem(i);			
		
		if menu = null then
			break;
		endif;
		
		menu.userObject := null;
		menu.visible	:= false;
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="MenuItem"/>
    </JadeMethod>
