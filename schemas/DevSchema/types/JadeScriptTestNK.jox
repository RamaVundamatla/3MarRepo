<Class name="JadeScriptTestNK" id="533c8708-e90a-4c54-843f-8f5063fc73c8">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="displayClassPropNames" id="7b5a5c44-e224-4a0a-9bde-e7ed5289c3f4">
        <source>displayClassPropNames();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2025	navnk30	Initial creation

*/

constants
	Separator	: String = "::";
vars
	property		: Property;
	klass			: Class;
	klassName		: String;
begin
	klass := CM_TrackedItem.class;
	klassName := klass.name;
	foreach property in klass.cnGetProperties() do
		write klassName &amp; Separator &amp; property.name;
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
