    <JadeMethod name="pw61704C3ReceivalBOL" id="9ad92c37-8f96-42c9-95f3-f23162c6bf12">
        <source>pw61704C3ReceivalBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2023	navpw1	Initial creation

*/

vars
	term,
	termMro: CM_Terminal;
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	strArray : StringArray;
	str : String;
	bolIn : CM_BOLIn;
	completedOk : Boolean;
	
begin
	app.writeLog("Running Script", LogDEBUG);
	create strArray transient;
	strArray.add("V17293547");
	strArray.add("V17293548");
	strArray.add("V17293450");
	strArray.add("V17293451");
	strArray.add("V17293469");
	strArray.add("V17293470");
	strArray.add("V17293472");
	strArray.add("V17293473");
	strArray.add("V17293474");
	strArray.add("V17293475");
	strArray.add("V17293476");
	strArray.add("V17293477");
	strArray.add("V17293481");
	strArray.add("V17293482");
	strArray.add("V17293483");
	strArray.add("V17293485");
	strArray.add("V17293497");
	strArray.add("V17293498");
	strArray.add("V17293499");
	strArray.add("V17293502");
	strArray.add("V17293504");
	strArray.add("V17293509");
	strArray.add("V17293510");
	
	create tiSet transient;
	term	:= app.myRoot.allTerminals["WEL"];
	termMro	:= app.myRoot.allTerminals["MRO"];
	bolIn	:= termMro.getBOLInByNumber("7005238", 5001);
	
	//bolIn.inspect;
	
	//return;
	
	beginTransaction;
	foreach str in strArray do
		term.lookupAllOnShipTrackedItems(str, 9, true, false, false, tiSet, null);
		
		ti := tiSet.first;
		
		if ti = null then
			app.writeLog("ti null: " &amp; str, LogDEBUG);
			
		else
			ti.setPropertyValue(CM_TrackedItem::myReceivalBOL.name, bolIn);
			app.writeLog("ti: " &amp; ti.id &amp; " | Bol Set: " &amp; bolIn.number, LogDEBUG);
		endif;
		
		tiSet.clear();
		
	endforeach;
	commitTransaction;
	
	completedOk := true;
	
epilog
	if not completedOk then
		abortTransaction;
	endif;
	
	delete tiSet;
	delete strArray;
	
end;</source>
    </JadeMethod>
