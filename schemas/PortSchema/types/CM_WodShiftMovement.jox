    <JadeMethod name="getExtraInfo" id="1955bfd8-c8c5-4081-bc73-528d7bdd7383">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	block : CM_DataContainerBlock;
	wodres : CM_WodMarineServiceDetail;
begin
	inheritMethod(_dataContainer);
	
	if self.myToBerth&lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(MOVEHEAD_BerthTo), DC_Label, 1, null);
		block.addNewItem(self.myToBerth.description , DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Occurs_datetime), DC_Label, 1, null);
		block.addNewItem(self.occursOnDT.asStringJMT(), DC_Data, 1, null);
	endif;

	// TFS 40236
	// ### BOW MARK
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(MOVEHEAD_MarkBow), DC_Label, 1, null);
	block.addNewItem(self.bowMarkTo.asStringJMT() , DC_Data, 1, null);
	
	// ### DRAFT AFT
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Draft_aft), DC_Label, 1, null);
	block.addNewItem(self.draftAft.asStringJMT() , DC_Data, 1, null);
	
	// ### DRAFT FORWARD
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Draft_fore), DC_Label, 1, null);
	block.addNewItem(self.draftFwd.asStringJMT() , DC_Data, 1, null);
	
	// ### HAS RAMP
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Vessel_external_ramp), DC_Label, 1, null);
	block.addNewItem(self.hasRamp.getYesNo() , DC_Data, 1, null);
	
	// ### STARBOARD BERTHED
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Starboard_Berthed), DC_Label, 1, null);
	block.addNewItem(self.starboardBerthed.getYesNo() , DC_Data, 1, null);

	
	foreach wodres in self.allMarineServiceDetails do
	
		wodres.getExtraInfo(_dataContainer);
	endforeach;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
