    <JadeMethod name="btnSetJobClose_click" id="5addd617-669b-47d6-b9fe-276261e32a83">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetJobClose_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	crane		: CM_Crane;				
	theJobSeed,
	theReturn	: Integer;
begin
	self.frmSeedJob.visible := false;
	
	crane := self.cmbCraneJS.listObject.CM_Crane;
	theJobSeed := self.txtSeedJob.text.Integer;
	
	if crane = null then
		return;
	endif;
	
	if theJobSeed = 0 then
		theReturn := app.msgBox("Are you sure that you want to set the seed to zero?","Set Seed Job Number",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	else
		theReturn := MsgBox_Return_Yes;
	endif;

	if crane.jobSeed &lt;&gt; theJobSeed then
		if theReturn = MsgBox_Return_Yes then
			app.myTrxUA.trxUpdateCraneSeedJobNumber(crane, theJobSeed, app.myPassport);
			global.beep;
		endif;
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
