<Class name="SysAdmin" id="d5f486b0-df6d-4e6f-b616-20f1ab9dc93e">
    <superclass name="Misc"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
	Container class for various System Administation functions.
	
	Designed to called from JadeScripts or gui forms.</text>
    <DbClassMap file="JetPlusMap"/>
    <PrimAttribute name="appSchema" id="62675a12-42d8-47e7-b9b8-fde269543a3e">
