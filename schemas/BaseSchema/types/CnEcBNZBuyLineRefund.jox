    <DbClassMap file="basemsg"/>
    <JadeMethod name="buildMessage" id="4829ecf2-e23f-4463-a790-2f29d81e920a">
        <source>buildMessage(pMessage: String io): String;

vars
	errorMessage	: String;
	
begin
	errorMessage := self.checkData();
	
	if errorMessage &lt;&gt; "" then
		return errorMessage;
	endif;
	
	pMessage := self.messType &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.oPSId.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.seqNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.password &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.amount.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.cardNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.expiry.format("yyMM") &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.currency.String;
	
	return null;
end;</source>
        <Parameter name="pMessage" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkData" id="5355d991-622c-411d-9a56-4afe4767593a">
        <source>checkData(): String;

vars
	errorMessage : String;
	
begin
	errorMessage := errorMessage &amp; checkOPSId();
	errorMessage := errorMessage &amp; checkSeqNum();
	errorMessage := errorMessage &amp; checkPassword();
	errorMessage := errorMessage &amp; checkAmount();
	errorMessage := errorMessage &amp; checkCardNum();
	errorMessage := errorMessage &amp; checkExpiry();
	errorMessage := errorMessage &amp; checkCurrency();
epilog
	return errorMessage;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="6b04fa65-9922-4a8e-9414-66466669b875">
        <updating/>
        <source>create() updating;

begin
	self.messType := "R";
	
	self.setCurrency("");
	
	self.setOPSId();
	self.setPassword();
	self.setSequenceNumber();
	self.setMyMgr();
end;</source>
    </JadeMethod>
    <JadeMethod name="getTrxString" id="8b88dc68-7aad-4698-91e9-c6a09575de33">
        <source>getTrxString(): String;

begin
	return "Refund";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setPassword" id="e67b8977-893c-4bc7-a23b-0a15c452aaac">
        <updating/>
        <source>setPassword() updating;

begin
	self.password := self.myManager.buyLineRpassword;
end;</source>
    </JadeMethod>
    <JadeMethod name="setRespApprovalNumber" id="11b5a126-a8a0-4c96-b664-147e29051c49">
        <updating/>
        <source>setRespApprovalNumber() updating;

// Only valid if respCode = "00" , "OK" or "97"

begin
	if self.respText.length &gt; 6 then // shouldn't ever be if we get a successful Refund response.
		self.respApprovalNumber := self.respText[1:6];
	else
		self.respApprovalNumber := self.respText;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="32c46a68-bd13-467b-8210-e4d95792ce8c">
        <updating/>
        <source>updateMe(	pAmount : Integer;
			pCardNum : String;
			pExpiry : Date) updating;

begin
	if self.amount &lt;&gt; pAmount then
		self.amount := pAmount;
	endif;
	
	if self.cardNum &lt;&gt; pCardNum then
		self.cardNum := pCardNum;
	endif;
	
	if self.expiry &lt;&gt; pExpiry then
		self.expiry := pExpiry;
	endif;
end;</source>
        <Parameter name="pAmount" type="Integer"/>
        <Parameter name="pCardNum" type="String"/>
        <Parameter name="pExpiry" type="Date"/>
    </JadeMethod>
</Class>
