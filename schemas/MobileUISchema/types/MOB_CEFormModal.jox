    <JadeMethod name="loadComboBoxCargoType" id="d520d2aa-3ab6-4a41-830b-b47bacfea6a9">
        <source>loadComboBoxCargoType(_cmb: MOB_ComboBox input; _cargoType : Integer);
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cargoBOLTypeArray 	: CM_CargoBOLTypeArray;
	cargoBOLType        : CM_CargoBOLType;
	index,
	selIndex			: Integer;
	
begin
	selIndex := -1;
	cargoBOLTypeArray := self.myMobileDataAgent.myTerminal.allCargoBOLTypes;	
	
	foreach cargoBOLType in cargoBOLTypeArray do	
		if (not cargoBOLType.isCargoType) then
			continue;
		endif;
		
		if not filterCargoType(cargoBOLType.CM_CargoType) then
			continue;
		endif;
		
		index :=_cmb.addItem(cargoBOLType.description);
		
		if cargoBOLType.id = _cargoType then
			selIndex := index;
		endif;
		
		_cmb.itemObject[index]	:=	cargoBOLType;
		_cmb.itemData[index]	:=	cargoBOLType.id;
	endforeach;
	
	_cmb.listIndex := selIndex;
end;</source>
        <Parameter name="_cmb" type="MOB_ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadComboBoxCommodity" id="50f18cae-bdbe-41df-840a-8f4395274d26">
        <source>loadComboBoxCommodity(_cmb: MOB_ComboBox input; _strCommodity : String);
/*
	Created on 06 June 2008
	
	by Anca Rosca
*/ 
vars
	commodity			: CM_Commodity;
	cargoBOLType		: CM_CargoBOLType;
begin
	foreach commodity in app.myRoot.allCommodities do	
		_cmb.itemObject[_cmb.addItem(commodity.description)] := commodity;
	endforeach;
	commodity := app.myRoot.allCommodities.first;
	if commodity &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(commodity);
	endif;
end;</source>
        <Parameter name="_cmb" type="MOB_ComboBox" usage="input"/>
        <Parameter name="_strCommodity" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadComboBoxOperator" id="1cfd042a-779e-4c98-b2e4-6bb0bee523e1">
        <source>loadComboBoxOperator(_cmb: MOB_ComboBox input; _strOperator : String);
/*
	Created on 17 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	operator			: CM_Operator;
	cargoBOLType		: CM_CargoBOLType;
begin
	foreach operator in app.myRoot.allOperators do	
		_cmb.itemObject[_cmb.addItem(operator.code)] := operator;
	endforeach;
	operator := app.myRoot.allOperators[_strOperator];
	if operator &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(operator);
	endif;
end;</source>
        <Parameter name="_cmb" type="MOB_ComboBox" usage="input"/>
        <Parameter name="_strOperator" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadComboBoxProduct" id="acbce2eb-5136-4595-92c8-c3a5b69669a8">
        <source>loadComboBoxProduct(_cmb: MOB_ComboBox input; _cargoTypeDesc: String; _defProduct : CM_Product);
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	productArray 	: CM_ProductByOpCodeProCodeDict;
	product         : CM_Product;
	cargoTypeID : Integer;
	cargoTypeObj : CM_CargoType;
begin
	//Get the cargo type id from the string
	cargoTypeID := app.myRoot.getCargoTypeIDFromDescription(_cargoTypeDesc);
	// find the cargo type object
	cargoTypeObj := app.myRoot.allCargoTypesById[cargoTypeID];
	
	if cargoTypeObj &lt;&gt; null then	
		foreach product in cargoTypeObj.allProducts discreteLock do	
			//epr TFS 1876 18/4/16
			if product.isNotActive then
				continue;
			endif;
			
			_cmb.itemObject[_cmb.addItem(product.code)] := product;
		endforeach;
	endif;
	if _defProduct &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_defProduct);
	endif;
end;</source>
        <Parameter name="_cmb" type="MOB_ComboBox" usage="input"/>
        <Parameter name="_cargoTypeDesc" type="String"/>
        <Parameter name="_defProduct" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f34d3f3c-3138-4177-934b-e6bbf386af6f">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018467, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
