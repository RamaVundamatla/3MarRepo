    <JadeMethod name="getExtraInfo" id="20408411-c793-405b-b54b-d461e386abe8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwml2	Initial creation

*/

vars
	block : CM_DataContainerBlock;
	
	portStr,
	hazStr	: String;
	tmpStr : String;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(BookingRef), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.bookingReference, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Operator), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.operatorCode, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Status), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.statusDesc, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Voyage), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.voyageCode, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(DischargePort), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.dischargePort, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(TranshipToPort), DC_Label, 1, null);
	if self.myBookingReference.myTranshipToPort &lt;&gt; null then
		block.addNewItem(self.myBookingReference.myTranshipToPort.code, DC_Data, 1, null);
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Destination_Port), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.destinationPort, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(OptDisPort), DC_Label, 1, null);
	foreach portStr in self.myBookingReference.allDischargePorts do
		if tmpStr = null then
			tmpStr := portStr;
		else
			tmpStr := tmpStr &amp; "; " &amp; portStr;
		endif;
	endforeach;
	block.addNewItem(tmpStr, DC_Data, 1, null);
	tmpStr := null;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(CM_Consignor), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.consignorDesc, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Consignee), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.consigneeDesc, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Hazards), DC_Label, 1, null);
	foreach hazStr in self.myBookingReference.allHazards do
		if tmpStr = null then
			tmpStr := hazStr;
		else
			tmpStr := tmpStr &amp; "; " &amp; hazStr;
		endif;
	endforeach;
	block.addNewItem(tmpStr, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(CM_Cargo_Remarks), DC_Label, 1, null);
	block.addNewItem(self.myBookingReference.remarks, DC_Data, 1, null);
	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getHSCode" id="d59ccd36-6775-40fa-ab61-27ea8283433d">
        <source>getHSCode() : String;
/*

Purpose:			

