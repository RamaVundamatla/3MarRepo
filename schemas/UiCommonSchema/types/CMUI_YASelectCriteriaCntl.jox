    <JadeMethod name="setupControl" id="31c7906e-7bf2-49f1-af83-6104488d5fd7">
        <updating/>
        <source>setupControl(pIsCriteria:Boolean; pIsNewAllocation:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Sets up the receiver ready for use.
//
// Parameters:	pIsCriteria - True if the receiver is managing Yard Allocation Criteria,
//					otherwise Yard Allocation Priorities will be assumed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCriteria	:=	pIsCriteria;
	
	if pIsCriteria then
		self.myOptEither.enabled	:=	false;
	else
		self.myOptEither.enabled	:=	true;
	endif;
	
	if pIsNewAllocation then
		self.allDeletedCPs.purge();
		self.allSelectedCPs.purge();
	endif;
end;</source>
        <Parameter name="pIsCriteria" type="Boolean"/>
        <Parameter name="pIsNewAllocation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="06a4d4db-294e-4bc8-bafa-41c9246c292c">
        <source>validateCriteria(pIsUpdate:Boolean; pIsDelete:Boolean):Boolean protected;
/* --------------------------------------------------------------------------------
// Created:		18 March 2005 by cnwdad1
//
// Purpose:		Validates the details that have been entered/selected for the Criteria.
//
// Parameters:	pIsUpdate - True if the Criteria is being updated, otherwise it will
//					be assumed that the Criteria is being created.
//				pIsDelete - True if the Criteria is bing deleted.
//
// Returns:		True if the Criteria details are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11 Mar 2010	consw1		PAR #22784 - Allow for Criteria Priority with string value

10 Sep 2012		cnwer1		PAR 29524 -Intended release mode 
// --------------------------------------------------------------------------------*/
vars
	criteriaTypeObj		: CM_YACriteriaType;
	itemObj				: CMIF_YACriteriaPriority;
	paramArrayObj		: Any;
	allObjectValuesObj	: ObjectArray;
	allIntegerValuesObj	: IntegerArray;
	allStringValuesObj	: StringArray;
	listPointer			: Integer;
	listCount			: Integer;
	errorMessage		: String;
	itemName			: String;
	
begin
	criteriaTypeObj	:=	self.getSelectedCriteriaType();
	if criteriaTypeObj = null then
		errorMessage	:=	app.getErrorString1(CMUI_YA_NO_ITEM_VALUES, "Criteria");
	endif;
	
	if self.isCriteria then
		itemName	:=	"Criteria";
	else
		itemName	:=	"Priority";
	endif;
	
	if pIsDelete then
		if self.myDisplayWindow.yaGetCriteriaPriority() = null then
			errorMessage	:=	app.getErrorString1(CMUI_YA_NO_DELETE_ITEM, itemName);
		endif;
	else
		if pIsUpdate then
			itemObj	:=	self.myDisplayWindow.yaGetCriteriaPriority();
			
			if itemObj = null then
				if errorMessage = null then
					errorMessage	:=	app.getErrorString1(CMUI_YA_NO_UPDATE_ITEM, itemName);
				else
					errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString1(CMUI_YA_NO_UPDATE_ITEM, itemName);
				endif;
			endif;
		else
			if criteriaTypeObj &lt;&gt; null then //Par 17292 AER 11/07/2008
				if not self.isCriteria then
					if criteriaTypeObj.isBooleanType() then
						create allIntegerValuesObj transient;
						
						if self.myOptEither.value then
							allIntegerValuesObj.add(CM_YADataBoolean.VALUE_EITHER);
						elseif self.myOptFalse.value then
							allIntegerValuesObj.add(CM_YADataBoolean.VALUE_FALSE);
						elseif self.myOptTrue.value then
							allIntegerValuesObj.add(CM_YADataBoolean.VALUE_TRUE);
						endif;
						
						paramArrayObj	:=	allIntegerValuesObj;
						
					elseif criteriaTypeObj.isStringType() then
						create allStringValuesObj transient;
						allStringValuesObj.add( self.myTxtItemCode.cnEcString() );
					
						paramArrayObj	:=	allStringValuesObj;
						
					elseif criteriaTypeObj.isTransportModeType() then
						create allIntegerValuesObj transient;
						listCount	:=	self.myLstTransportMode.listCount;
						
						foreach listPointer in 1 to listCount do
							if self.myLstTransportMode.itemSelected[listPointer] then
								/*epr par 29524 10/9/12
								Intended Release mode was stuffed up the Transport List uses TITransportModeConstant constants
								the intenedRelease mode uses TI_IntendedReleaseModeConstant constants which are the same except
								rail and road have different values */
								if criteriaTypeObj.isKindOf(CM_YATypeIntendedRelMode) then
									if listPointer = TI_TRANSMODE_ROAD  then
										allIntegerValuesObj.add(self.myLstTransportMode.itemData[TI_IntendedReleaseMode_ROAD]);
									elseif listPointer = TI_TRANSMODE_RAIL then
										allIntegerValuesObj.add(self.myLstTransportMode.itemData[TI_IntendedReleaseMode_RAIL]);
									else
										allIntegerValuesObj.add(self.myLstTransportMode.itemData[listPointer]);
									endif;
								else
							
									allIntegerValuesObj.add(self.myLstTransportMode.itemData[listPointer]);
								endif;											
							endif;
						endforeach;
						
						paramArrayObj	:=	allIntegerValuesObj;
						
					else
						create allObjectValuesObj transient;
						listCount	:=	self.myLstSelected.listCount;
						
						foreach listPointer in 1 to listCount do
							allObjectValuesObj.add(self.myLstSelected.itemObject[listPointer]);
						endforeach;
						
						paramArrayObj	:=	allObjectValuesObj;
					endif;
				endif;
			
				if self.isCriteriaTypeAlreadyUsed(criteriaTypeObj, paramArrayObj) then
					if errorMessage = null then
						errorMessage	:=	app.getErrorString1(CMUI_YA_CRITERIA_TYPE_USED, criteriaTypeObj.description);
					else
						errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString1(CMUI_YA_NO_UPDATE_ITEM, itemName);
					endif;
				endif;
			endif;
		endif;
		
		if self.myCmbCriteriaType.listIndex = CNEC_NULL_INDEX then
			if errorMessage = null then
				errorMessage	:=	app.getErrorString(CMUI_YA_NO_CRITERIA_TYPE);
			else
				errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString(CMUI_YA_NO_CRITERIA_TYPE);
			endif;
		endif;
		
		if (not self.isCriteriaCodeHidden)
		and self.myTxtItemCode.cnEcString() = null
		then
			if errorMessage = null then
				errorMessage	:=	app.getErrorString(CMUI_YA_NO_ATTRIBUTE_CODE);
			else
				errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString(CMUI_YA_NO_ATTRIBUTE_CODE);
			endif;
		endif;
		
		if criteriaTypeObj &lt;&gt; null
		and criteriaTypeObj.isPrimitiveValue()
		then
			if criteriaTypeObj.isBooleanType()
			and not self.myOptTrue.value
			and not self.myOptFalse.value
			and not self.myOptEither.value
			then
				if errorMessage = null then
					errorMessage	:=	app.getErrorString(CMUI_YA_NO_BOOLEAN_VALUE);
				else
					errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString(CMUI_YA_NO_BOOLEAN_VALUE);
				endif;
			endif;
			
			if criteriaTypeObj.isTransportModeType()
			and self.myLstTransportMode.listIndex = CNEC_NULL_INDEX
			then
				if errorMessage = null then
					errorMessage	:=	app.getErrorString(CMUI_YA_NO_INTEGER_VALUE);
				else
					errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString(CMUI_YA_NO_INTEGER_VALUE);
				endif;
			endif;
		else
			if self.myLstSelected.listCount() = 0
			and self.isCriteria
			then
				if errorMessage = null then
					errorMessage	:=	app.getErrorString1(CMUI_YA_NO_ITEM_VALUES, itemName);
				else
					errorMessage	:=	errorMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString1(CMUI_YA_NO_ITEM_VALUES, itemName);
				endif;
			endif;
		endif;
	endif;
	
	if errorMessage = null then
		return true;
	else
		app.msgBox(	errorMessage,
					"Error",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		return false;
	endif;
epilog
	delete allObjectValuesObj;
	delete allIntegerValuesObj;
	delete allStringValuesObj;
end;</source>
        <access>protected</access>
        <Parameter name="pIsUpdate" type="Boolean"/>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="076ea8e8-3d5f-4bea-aac1-a91f4fef59c4">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaTypes: CM_YACritetriaTypeByTypeDict;
	criteriaType: CM_YACriteriaType;
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.transparent	:=	true;
	self.setupChildControls();
	
	if not self.isInPainter() then
		// PAR 19258 - Do not use the ContainerLength criteria for priorities
		create criteriaTypes transient;
		foreach criteriaType in app.myRoot.allYACriteriaTypes do
			if criteriaType.isKindOf(CM_YATypeContainerLength) then
				continue;
			endif;
			
			criteriaTypes.add(criteriaType);
		endforeach;
		
		self.myCmbCriteriaType.listCollection(	criteriaTypes,
												false,
												Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	endif;
epilog
	delete criteriaTypes;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
