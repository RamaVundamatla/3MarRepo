<Class name="CM_QuickAccessUser" id="1626a81f-3c38-4c79-b466-ca29bee4ee96">
    <superclass name="CM_QuickAccess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="quikAccess"/>
    <ExplicitInverseRef name="myUser" id="9a3c589a-35ca-4a7b-add3-c7220979c907">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
        <Inverse name="CM_User::allUserQuickAccess"/>
    </ExplicitInverseRef>
