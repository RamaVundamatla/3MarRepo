    <JadeMethod name="getSignOffUser" id="e4088cc4-add2-438a-a885-7733dcafcb6a">
        <source>getSignOffUser():CM_InvoiceSignoffUser;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	effectiveDT : TimeStamp;
	signoff : CM_InvoiceSignoffUser;

begin

	effectiveDT := self.dateTime;
	
	signoff := self.getBank.getSignOffUser( effectiveDT );
	
	return signoff;
	
epilog

end;</source>
        <ReturnType type="CM_InvoiceSignoffUser"/>
    </JadeMethod>
