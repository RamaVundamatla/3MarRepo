    <JadeMethod name="getName" id="fc62a0d6-ae1b-4960-a564-8f574b557f94">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.vesselName &lt;&gt; null then
		return inheritMethod &amp; ' (' &amp; self.code.trimBlanks &amp; " - " &amp; self.vesselName.trimBlanks &amp; ')';
	else
		return inheritMethod &amp; ' (' &amp; self.code.trimBlanks &amp; ')';
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextEmptyLoadPosition" id="d57a9e71-6192-4206-9e6f-7a4dfcd831bc">
        <source>getNextEmptyLoadPosition(_lcsUsed : CM_LCSet input; _lolo : Boolean; _is40 : Boolean) : CM_LocationsController;
/*
Purpose:			For Dev Scripts
Date		Who		Reason
19 March 2014	cnwab1	Initial creation
*/

vars
	bay : CM_Bay;
	slotDefn : CM_SlotDefn;
	slotLC, aftSlot : CM_SlotController;
	tis : CM_TIArray;
begin
	if _lcsUsed = null then
	
		return null;
	endif;
	
	
	create tis transient;
	if _lolo then
		foreach bay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
			foreach slotDefn in bay.allSlotsByOrdinal discreteLock do
				if slotDefn.unavailable then
					continue;
				endif;
				
				slotLC := slotDefn.CM_SlotDefnVoyage.mySlotController;
				
				slotLC.getProposedTIs(tis);
				
				if not tis.isEmpty() then // there are TIs here so ignore
					continue;
				endif;
				if not _lcsUsed.includes(slotLC) then
					if _is40 then
						// put the aft in so that another 20 does not try to use it
						aftSlot := slotLC.myNextSlotInHold(); // get the AFT
						if aftSlot &lt;&gt; null then
							if not _lcsUsed.includes(aftSlot) then
								_lcsUsed.add(aftSlot);
							else
								continue; // this is not a suitable slot for the front end of a 40
							endif;
						else
							continue; // this is not a suitable slot for the front end of a 40
						endif;
					endif;
					
					_lcsUsed.add(slotLC);
					return slotLC;
				endif;
				
			endforeach;
		endforeach;
	
	endif;
epilog
	delete tis;
end;</source>
        <Parameter name="_lcsUsed" type="CM_LCSet" usage="input"/>
        <Parameter name="_lolo" type="Boolean"/>
        <Parameter name="_is40" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeSlotLCByDischargeCC" id="5653b633-60ab-4914-9973-c14e55dcc6b6">
        <source>getNextFreeSlotLCByDischargeCC(_is40 : Boolean) : CM_LocationsController;
// ---------------------------------------------------------------------------
// Created:     30 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slot, aftLC : CM_LocationsController;
begin
	foreach slot in self.allVoyageLocations discreteLock do
		if not slot.isKindOf(CM_SlotController) then // UT failure - AB
			continue;
		endif;
		if slot.allTrackedItems.isEmpty() then
			if _is40 and slot.isKindOf(CM_SlotController) then
				if slot.CM_SlotController.mySlotRequestDischarge &lt;&gt; null then
					continue;
				endif;
				if slot.CM_SlotController.myAftSlot &lt;&gt; null then
					aftLC := slot.CM_SlotController.myAftSlotInHold;
					
						if aftLC &lt;&gt; null and aftLC.allTrackedItems.isEmpty() then
							return slot;
						endif;
				endif;
			else
				if slot.CM_SlotController.mySlotRequestDischarge &lt;&gt; null then
					continue;
				endif;
				return slot;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_is40" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getNextJobNumber" id="97babbd5-0c11-43ee-82f2-da7b3fcb9414">
        <source>getNextJobNumber(_jobSheet : CM_VoyageJobSheet; _workPoint: IF_VoyageWorkPoint input) : String;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/05/13		cnwpjs		PAR # 31415 - Handle 0 increment
// ---------------------------------------------------------------------------
vars

	voyageJob	: CM_VoyageJob;
	job			: CM_Job;
	idAsNumber,
	increment	: Real;
	terminal	: CM_Terminal;
	idAsStr		: String;
	failed		: Boolean;
	shipSeed,
	jobSeed	: Real;
	workPointObject : CM_Object;
	workPointInterface : IF_VoyageWorkPoint;	
begin

	 terminal := self.myTerminal;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE();
	endif;
	workPointInterface := _workPoint;
	increment := terminal.getConfig(ShipJobNumberIncrement).Real;
	// 31415
	if increment &lt; 1 then
		increment := 1;
	endif;
	
	
	shipSeed := terminal.getConfig(ShipJobSeed).Real;
		
	// We have a crane and a job sheet.
	if _jobSheet &lt;&gt; null then
		// Whip through jobs for this crane and check out the numbers.
		foreach job in _jobSheet.allJobsByOrder discreteLock where job &lt;&gt; null do
			voyageJob:=job.CM_VoyageJob;
			if voyageJob.jobNum.isInteger() then
				idAsNumber := voyageJob.jobNum.extractNumber().max(idAsNumber);
			endif;
		endforeach;
		
		// Find the crane.
		if workPointInterface = null then
			workPointObject := _jobSheet.getMyWorkPointObject;
			if workPointObject &lt;&gt; null then
				workPointInterface:=workPointObject.IF_VoyageWorkPoint;
			endif;
		endif;	
	
		if workPointInterface = null then
			app.raiseCMException(ERR_INVALID_CRANE, null, null);
			return null;		
		endif;
		
		jobSeed:=workPointInterface.getJobSeed.Real;
		// Which is the biggest number. The crane seed or largest job num.
		idAsNumber := jobSeed.max(idAsNumber);
		
		if idAsNumber &lt;&gt; jobSeed then // PAR 13179
			// Return largest number plus increment.
			idAsNumber := idAsNumber + increment;
		endif;
	else
		// We didn't have a job sheet specified. -&gt; do we have a crane?
		if workPointInterface &lt;&gt; null then
			jobSeed:=workPointInterface.getJobSeed.Real;
			// Which is the biggest number. The crane seed or largest job num.
			idAsNumber :=  jobSeed.max(idAsNumber);
		else		
			// Whip through jobs without a job sheet and find highest value.
			foreach job in self.allVoyageJobs discreteLock where job.myJobSheet = null do
				idAsNumber := job.CM_VoyageJob.jobNum.extractNumber().max(idAsNumber);
			endforeach;
			// Is the value higher than the terminal seed value.
			idAsNumber := shipSeed.max(idAsNumber);
			// Increment value.
			if idAsNumber &gt; shipSeed then
				idAsNumber := idAsNumber + increment;
			endif;
		endif;
		
	endif;

	//padLeadingZeros(2);
	idAsStr := idAsNumber.String;

	// Long hard way of checking for dupes.
	while true do
		failed := false;
		foreach job in self.allVoyageJobs discreteLock do
			if job.CM_VoyageJob.jobNum = idAsStr then
				failed := true;
				idAsNumber := idAsNumber + 1;
				idAsStr := idAsNumber.String;
				break;
			endif;
		endforeach;
		if not failed then
			break;
		endif;
	endwhile;
	
	//return idAsNumber;
	if idAsNumber &lt; 10 and app.myRoot.client = Client_CentrePort then
		return idAsNumber.String.padLeadingZeros(1);
	endif;
	
	return idAsNumber.String;
		
end;</source>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet"/>
        <Parameter name="_workPoint" type="IF_VoyageWorkPoint" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextPortInRotation" id="d2df17b1-f857-4cd8-8ff6-16bd016afe0a">
        <source>getNextPortInRotation() : CM_Port;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 20/08/2010	cnwsh3		CCMS1063 PAR25508 - Required for reporting views when created.
//							Get the next port in the port rotation list.
// 21/11/2018	jlgdap1		TFS 42024 PEL1 Incorrect Ports in Voyage Request
/// 1/10/2021	jlier1	TFS 51963 
//----------------------------------------------------------------------
vars
	thisTerminalsPort,
	nextPort		: CM_Port;
	portRotation 	: CM_PortRotation;
	found 			: Boolean;
	wod 			: CM_WodVoyageRequest;			// TFS 42024
begin
	if not self.isDefaultVoyageProcess then
		wod := self.getWorkOrderForVoyageRequest();							// TFS 42024
		if wod &lt;&gt; null and wod.portCode4 &lt;&gt; null then						// TFS 42024
			return app.myRoot.allPorts[wod.portCode4];						// TFS 42024
		endif;																// TFS 42024
	endif;																	// TFS 42024
	
	if self.allPortRotations.isEmpty() then
		return null;
	endif;
	
	thisTerminalsPort := self.myTerminal.getDefaultPort();
	
	found := false;
	foreach portRotation in self.allPortRotations do
		//We found the matching 
		if found then
			nextPort := portRotation.myPort;
			break;
		endif;
		
		if portRotation.myPort = thisTerminalsPort then
			//found  our port so go through one more time to get the next port in the list if there is one.
			found := true;
		endif;
	endforeach;
	
	return nextPort;
		
epilog
end;</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getNextPortInRotationCode" id="569099a8-3a83-4d32-a9b2-ef9f5a5b20b3">
        <source>getNextPortInRotationCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2025	navsaa30	Initial creation
//6/6/2025      navsaa30 MTN-34919 PEN | Event Stream Voyage Information
*/

vars

begin
	if self.getNextPortInRotation &lt;&gt; null then
		return self.getNextPortInRotation.code;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextQuickCargoID" id="e0443bbd-19f4-438b-ad8b-4692812d7b95">
        <source>getNextQuickCargoID(_cargoType : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     05 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
	nextID, numId : String;
	nextNum : Integer;
	prefix : String;
	yymmdd : String;
	
begin
	yymmdd := app.actualTimeAppServer().formatAsYYYYMMDDHHmmSS()[3:6] &amp; "1";  // ### TFS 51855 14FEB2022 NAVAB1 - change to be date based
	nextNum := yymmdd.Integer ;
	
	// JLGAB1 23JUN20 trying to reduce the risk of duplicate ID errors when discharging.
	if self.vesselCode.length &gt;= 3 then
		prefix := self.vesselCode[1:3] &amp; "U";
	elseif self.vesselCode = "" then
		prefix := "SHPU";
	else
		prefix := self.vesselCode.cnEcPadTrailing(4,"U");
	endif;
	
	while true do
		nextID := prefix &amp; nextNum.String;
			if self.allOnshipTIsByIdCargoType[nextID,_cargoType] = null and
					self.allOnsiteTIsByIdCargoType[nextID, _cargoType] = null 
					and self.myTerminal.allOnsiteTIsByIdCargoType[nextID, _cargoType] = null  then						// 03/04/2014 cnwmh5
				return nextID;
			endif;
		nextNum := nextNum + 1;
	endwhile;
	
	return nextID;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextUpdateStatus" id="040bbfee-9981-4b35-a821-a0491410ec20">
        <source>getNextUpdateStatus(_status : Integer) : CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Apr 2018	jlger1	Initial creation
11 OCt 2021	jlier1 	TFS 51963 removed inapornet 
*/

vars

	nextStatus : CM_VoyageStatus;
begin

	if self.status = Voyage_Status_CargoReqPending 
		or self.status = Voyage_Status_CargoRequested or
		self.status = Voyage_Status_CargoReqRejected then		
		nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_CargoRequested];
	elseif self.status = Voyage_Status_DepServPending then		
		nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_DepServRequested];
	elseif self.status = Voyage_Status_ServicesPending then		
		nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_InitSerRequested];
	elseif self.status = Voyage_Status_VoyRequested then		
		nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_VoyReqSubmitted];		
	elseif self.status = Voyage_Status_VoyCancelled then	//02 Aug 2018	NDL	TFS 39924		
		nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_VesselArchived];		
	elseif self.status = Voyage_Status_DepServRejected then //epr TFS 41539 31/10/18
			nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_DepServRequested];
	elseif self.status = Voyage_Status_ApprovalRejected then //epr TFS 41539 31/10/18
			nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_InitSerRequested];
	endif;

	
	return nextStatus;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getNextValidStatuses" id="2b1b3446-292a-4edb-8137-154e043caa53">
        <source>getNextValidStatuses(_nextStatuses: CM_VoyageStatusByPriority input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/04/2018	jlger1	Initial creation 37931
24/04/2018	jlgdap1	TFS 38214 PEL1 Voyage Status Changes
2/11/2008  	jlger1	TFS 41523 - rewritten - just used for the webportal gets appropriate status to allow the update
06/11/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
13/12/2018  jlger1	TFS 42396 PEL now can update departure if after departure date if it is at a private berth (does not require ETMAL)
01/10/2021	jlger1	TFS 51963 - changes to voyage process -removed isPelindo1
18/08/2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
*/

vars
	voyageProcess : CM_VoyageProcess;
	currentStatus,
	nextStatus,
	voyageStatus : CM_VoyageStatus;
	workOrderDtl  : CM_WorkOrderDtl;
	failedDAC : CM_DataAccessController;			// TFS 41305
	operator : CM_Operator;							// TFS 41305
	discharge, load : Boolean;						// TFS 41305
	departedTsPassed : Boolean;
	departureMovement : HMS_VoyageMovement;
begin
	
	if self.myVoyageProcess = null then
		return;
	endif;
	currentStatus:=self.getVoyageStatusObject;
	if currentStatus = null then
		return;
	endif;
	//jlier1 TFS 51963 28/9/21
	if (self.myVoyageProcess.isDefaultProcessJMT ) then
		return;
	endif;
	departedTsPassed := (self.departedDT &lt;= app.actualTimeServer);
	//epr TFS 41539 voyage status updates 
	if currentStatus.id = Voyage_Status_VoyRequested or currentStatus.id = Voyage_Status_VoyReqRejected 
	or currentStatus.id = Voyage_Status_EUP_VoyReq  or currentStatus.id = Voyage_Status_EUP_VoyReqRej then
		if self.myOperator = null then
			return;
		endif;
		// TFS 41305 Check the user has access to the operator of the voyage					// TFS 41305
		if not self.myOperator.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then	// TFS 41305
			app.writeLog("User " &amp; app.getMyUserCode &amp; " has no access to voyage " &amp; self.code &amp; " and operator " &amp; self.myOperator.code, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;																				// TFS 41305
		endif;			
		workOrderDtl := self.getWorkOrderForVoyageRequest();		
		if workOrderDtl = null  or workOrderDtl.myParent.taskStatus =  WO_STATUS_COMPLETE  then
			return;
		endif;
		
		if self.myVoyageProcess.isMTNWOProcess then	// TFS 54298
			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_VoyRequested];	
			if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then
				_nextStatuses.add(nextStatus);
			endif;
			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_VoyReqSubmitted];	
			if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then
				_nextStatuses.add(nextStatus);
			endif;
			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_VoyCancelled];	
			if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then
				_nextStatuses.add(nextStatus);
			endif;
		
		elseif self.myVoyageProcess.isEUPDefaultProcess then								// TFS 54298
			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_EUP_VoyReq];		// TFS 54298
			if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then			// TFS 54298
				_nextStatuses.add(nextStatus);												// TFS 54298
			endif;
			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_EUP_VoyReqSubm];	// TFS 54298
			if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then			// TFS 54298
				_nextStatuses.add(nextStatus);												// TFS 54298
			endif;
			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_EUP_Cancelled];	// TFS 54298
			if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then			// TFS 54298
				_nextStatuses.add(nextStatus);												// TFS 54298
			endif;
		endif;
		
	elseif currentStatus.id = Voyage_Status_VoyReqSubmitted 	then //jlier1 TFS 52203 19/10/21
		nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_VoyCancelled];	
		if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then
			_nextStatuses.add(nextStatus);
		endif;
		
	elseif currentStatus.id = Voyage_Status_EUP_VoyReqSubm then							// TFS 54298
		nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_EUP_Cancelled];	// TFS 54298
		if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then			// TFS 54298
			_nextStatuses.add(nextStatus);												// TFS 54298
		endif;
		
	elseif currentStatus.isInitialMarineServiceStatus then
		if departedTsPassed then		
			return;
		endif;
		
		app.writeLog("Checking currentStatus.isInitialMarineServiceStatus", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if self.myHMSVoyageData  = null then
			return;
		endif;
		
		workOrderDtl :=self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);
		if workOrderDtl&lt;&gt; null and workOrderDtl.myParent.taskStatus = WO_STATUS_COMPLETE then
			//28 Nov 2018	NDL	TFS 42043 - If we have more arrivals and adeleted arrivals than IMSRs
			// then let it continue, otherwise return.
			if self.arrMoveCountGtrThanIMSR() then
				//All good we actually need another one..
			else
				return;
			endif;
		endif;
		
		//epr TFS 41310 8/10/18 must have a permit to create 
		//jlier1 TFS 52305 8/11/21
		/*if  (workOrderDtl = null)  then
			if self.myGeneralCargoVoyage = null and self.allWorkOrders.getWODPermitForDetailType(WO_TASK_MARINEINITIAL,WO_STATUS_COMPLETE)  = null then	
				return;
			endif;			
		endif;*/
		
		if self.myOperator = null then
			return;
		endif;
		// TFS 41305 Check the user has access to the operator of the voyage					// TFS 41305
		if not self.myOperator.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then	// TFS 41305
			app.writeLog("User " &amp; app.getMyUserCode &amp; " has no access to voyage " &amp; self.code &amp; " and operator " &amp; self.myOperator.code, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;																				// TFS 41305
		endif;																					// TFS 41305
		
		nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_InitSerRequested];	
		
		if  nextStatus &lt;&gt; null and nextStatus.userCanSet(self.myTerminal) then
			_nextStatuses.add(nextStatus);
		endif;
		
		return;
	elseif currentStatus.isCargoRequestStatus then
		if departedTsPassed then		
			return;
		endif;
		app.writeLog("Checking currentStatus.isCargoRequestStatus", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		// TFS 41305 Check the user has access to the discharge or load operators 				// TFS 41305
		if not self.canUserAccessForCargoRequest(app.getMyUser, app.myPassport) then			// TFS 41305
			app.writeLog("User " &amp; app.getMyUserCode &amp; " has no access to voyage " &amp; self.code &amp; " to create cargo", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;																				// TFS 41305
		endif;																					// TFS 41305
		
		
		
		//epr TFS 41539
		nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_ServicesPending];				
		
		if  nextStatus &lt;&gt; null and nextStatus.userCanSet(self.myTerminal) then
			_nextStatuses.add(nextStatus);
		endif;
		return;
	elseif currentStatus.id.isOneOf(Voyage_Status_CargoReqPending,Voyage_Status_ICargoReqPending) then
		if departedTsPassed then		
			return;
		endif;
		app.writeLog("Checking currentStatus.id.isOneOf(Voyage_Status_CargoReqPending,Voyage_Status_ICargoReqPending)", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		// TFS 41305 Check the user has access to the discharge or load operators 				// TFS 41305
		if not self.canUserAccessForCargoRequest(app.getMyUser, app.myPassport) then			// TFS 41305
			app.writeLog("User " &amp; app.getMyUserCode &amp; " has no access to voyage " &amp; self.code &amp; " to create cargo", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;																				// TFS 41305
		endif;																					// TFS 41305
		
		//epr TFS 41539
		nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_CargoRequested];		
			
		if  nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then
			_nextStatuses.add(nextStatus);
		endif;
		return;
	else
		if app.actualTimeServer &lt; self.arrivedDT then
			return;
		endif;
		app.writeLog("Checking else", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		departureMovement :=self.getMovementDeparture();
		//epr TFS 42396 12/12/18
		//if departing from private berth that can do it even if the voyage is past it departure dt and without a permit
		if departureMovement = null or  departureMovement.getMyBerth.requiresLengthOfTime then
			if departedTsPassed then		
				return;
			endif;
		endif;
		//epr TFS 41539 27/10/18
		//if app.actualTimeServer &gt;= self.arrivedDT and
		//	app.actualTimeServer &lt;= self.departedDT then
			
			
			workOrderDtl :=self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);
			if workOrderDtl = null or workOrderDtl.myParent.taskStatus &lt;&gt; WO_STATUS_COMPLETE then
				return;
			endif;
			
			workOrderDtl :=self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);
		

			nextStatus:=self.myVoyageProcess.allStatusesById[Voyage_Status_DepServRequested];	
		
						
			//create departure marine service
			if  workOrderDtl = null then					
				if nextStatus &lt;&gt; null and  nextStatus.userCanSet(self.myTerminal) then
					_nextStatuses.add(nextStatus);
				endif;

			else
				if workOrderDtl.myParent.taskStatus &lt;&gt; WO_STATUS_COMPLETE then
					if self.status = Voyage_Status_DepServRejected or self.status = Voyage_Status_DepServRequested   
						or self.status = Voyage_Status_IDepServRequest   then
						if nextStatus &lt;&gt; null and nextStatus.userCanSet(self.myTerminal) then
							_nextStatuses.add(nextStatus);
						endif;

					endif;
				endif;
			endif;
			return;
	endif;
		
	
	
epilog

end;
</source>
        <Parameter name="_nextStatuses" type="CM_VoyageStatusByPriority" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="1984227e-ad82-47c0-9eb5-2d6a69e46734">
        <source>getNiceName(): String;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return "Voyage : " &amp; self.code &amp; ". " &amp; self.vesselName &amp; " (" &amp; self.vesselCode &amp; ")";

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNonChargeTimeInMinutes" id="65bbc824-434a-4928-a5aa-e3d968cf6882">
        <source>getNonChargeTimeInMinutes():Decimal;

// non-charge time is stored as hours.minutes (decimal part is absolute minutes, NOT fractions of an hour)

vars
	hours 	: Decimal[12,0];
	minutes	: Integer;
	
begin
	hours	:=	self.nonChargeTime.rounded();
	minutes	:=	((self.nonChargeTime - hours) * 100).Integer;
	
	return hours * 60 + minutes;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNonPlannedEfectiveDTLocalTZ" id="c959dd87-accb-4062-bdb5-83472ae6e373">
        <source>getNonPlannedEfectiveDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwns1	Initial creation
// 31 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return	self.systemToLocalTime(self.nonPlannedEffectiveDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getNonWorkedROB" id="60dc46d7-87ba-45c8-8144-5cc4bbe14164">
        <source>getNonWorkedROB(_robToBeDeleted : CM_TISet input): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2020     cnwma1			Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue		
12 Dec 2024		jlier1			JIRA#19283
*/

vars
	ti  : CM_TrackedItem;
	cnt : Integer;
begin
	foreach  ti in  self.allOnshipTIsByCargoTypeId discreteLock do 
	
		if not ti.wasWorkedInSystem then
			cnt := cnt + 1 ;
			if ti.isChild then
				continue;
			endif;
			_robToBeDeleted.addNoDuplicates(ti,false);
		endif;
	endforeach;
	
	return cnt;
epilog

end;</source>
        <Parameter name="_robToBeDeleted" type="CM_TISet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumAllOnsiteTIsByIMEX" id="183b54db-6404-4403-9e4a-e3d68728418e">
        <source>getNumAllOnsiteTIsByIMEX(_imex : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		08 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	aTI : CM_TrackedItem;
	idx : Integer;
begin

	foreach aTI in self.allOnsiteTIsByCargoTypeId discreteLock do
		if aTI.getImExStatus() = _imex then
			idx := idx + 1;
			// PAR #23645 CCMS 1116 include appropriate tranships in import/export count
			if _imex = TI_IMEX_STATUS_EXPORT and aTI.isTranshipExport then
				idx := idx + 1;
			elseif _imex = TI_IMEX_STATUS_IMPORT and aTI.isTranshipOnInboundVoyage then
				idx := idx + 1;
			endif;
			// PAR #23645 CCMS 1116 end
		endif;
	endforeach;

	return idx;
end;</source>
        <Parameter name="_imex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
