    <JadeMethod name="fileSilentExceptionHandler" id="a0dcce52-345a-411e-8fab-964dea303805">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60347  Task 60349: UI - Dialog For CSV Load

*/

vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		
		_hadFileException:=true;
		
		// File is in use by another process
		if _exObj.errorCode = 5030 then
			app.raiseCMException(_exObj.errorCode, null, null);
			return returnVal;
		endif;
		
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="49b5e3e1-815c-41aa-b024-5106cedd9a69">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	theXML : String;
begin
	theXML := inheritMethod();
	theXML := theXML &amp; self.tblData.getXmlStrForColumns(false);
	theXML := theXML &amp; global.formatAsXML(self.XML_TagShowParams,chkShowParameters.value.Integer.String);
	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="44bd04c8-42c2-4fcb-85be-4583602c03e0">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	showParams : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagShowParams);
 	showParams := false;
 	if theXMLValue &lt;&gt; null then
 		showParams := theXMLValue.Integer.Boolean;
 	endif;
 	
	self.chkShowParameters.value := showParams;
	self.chkShowParameters_click(self.chkShowParameters);

end;</source>
    </JadeMethod>
