    <JadeMethod name="deleteRailArea" id="34187ccf-42bb-457a-b3fe-2c2fabe04e54">
        <source>deleteRailArea(_railAreaCode : String);
//02 November 2009	cnwjo3
//
vars
	ra : CM_Rail;
	rata : CM_YardTransferArea;
	rataCode : String;
	ta : CM_TerminalArea;
	line :CM_RailLine;
	i :Integer;
	ti					: CM_TrackedItem;
	locnController 		: CM_LocationsController;
	tiArray				: CM_TIArray;
	futureMove			: CM_FutureMove;
begin

//	train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(_trainCode,null);
	ta := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RAILWAY_TRACK,_railAreaCode];
	
	create tiArray transient;
	
	if ta &lt;&gt; null then
		if ta.isKindOf(CM_Rail) then
			ra := ta.CM_Rail;
			// for some reson we have null entries in the wagons array - cnwcs5 May 2012
			foreach line in ra.allRailLines do
				
				beginTransaction;							// 14/04/2014 cnwmh5
				while not line.allWagons.isEmpty() do
					line.allWagons.removeAt(1);
				endwhile;
				commitTransaction;
			
			endforeach;
			
			// read through all the locations controllers and get the tracked items and delete them
			foreach locnController in ra.allLocationsControllers do									// 15/04/2014 cnwmh5
				if locnController.hasTIs() then														// 22/04/2014 cnwmh5
					locnController.allTrackedItems.copy(tiArray);
					locnController.getAllPlannedTrackedItems(tiArray, false, false);
					locnController.getAllQueuedTrackedItems(tiArray, false);
				endif;
			endforeach;
			
		//	foreach ti in tiArray do	
		//		self.deleteTrackedItem(ti, false);
		//	endforeach;
			self.deleteTrackedItem(tiArray, false);
			
			self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			ra.latestEdition;																		// 22/04/204 cnwmh5
			app.myTrxDA.trxDeleteTerminalArea(ra,app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	endif;
	
	rataCode := _railAreaCode &amp; "TA";
	ta := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RAIL_TRANS,rataCode];

	if ta &lt;&gt; null then
		if ta.isKindOf(CM_YardTransferArea) then
			rata := ta.CM_YardTransferArea;
			self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteTerminalArea(rata,app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	endif;	
	
epilog

	delete tiArray;
	
end;</source>
        <Parameter name="_railAreaCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteReleaseRequest" id="8243f752-73fb-4167-baf6-f4615d41d7b7">
        <source>deleteReleaseRequest(_releaseCode: String);
//18 December 2008	cnwdw1	
//
vars
	release: CM_BulkRelease;
begin
	while true do
		release := self.getTerminal.getBulkReleaseFromCode(_releaseCode);
		if release = null then
			break;
		endif;
		self.ignoreTrxWarnings(true);
		if release.status = BR_ACTIVE then
			beginTransaction;
			release.allRequestsBeingActioned.purge();
			release.allTrackedItemsReleased.clear();
			commitTransaction;
		endif;
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteBulkRelease(release, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endwhile;
end;</source>
        <Parameter name="_releaseCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteReportTemplate" id="26db10ef-b9da-4b0b-a956-3f73cc9f028a">
        <source>deleteReportTemplate(_template : CM_ReportTemplate io);

vars
	menuEntity		: CM_MenuEntity;
	reportTemplate	: CM_ReportTemplate;
	menuSet			: CM_MenuUserItemSet;
	totalDelete		: Boolean;
	
begin
	create menuSet transient;
	
	reportTemplate := _template;
	totalDelete := true;
	foreach menuEntity in reportTemplate.allMenuUserReports do
		menuSet.add(menuEntity.CM_MenuUserReport);
	endforeach;
	
	app.myTrxDA.trxDeleteMenuUserReport(menuSet, totalDelete, app.myPassport);
