    <JadeMethod name="getWeightOutstanding" id="215139d7-016a-4bba-ad56-b240c333d7b5">
        <source>getWeightOutstanding() : Decimal;
/*

Date		Who		Reason
19 Jun 2014	cnwer1	Initial creation PAR 34406
18 Apr 2016	cnwdap1	TFS #1843 Allow for slight rounding / calculation errors in weight comparisons
22 Apr 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	diff 			: Real;		
	wTReleaseed		: Decimal[14,4];
begin
	
	wTReleaseed	:= self.getWeightReleased();						//22.04.2025 navma1 #MTN-34387
	diff 		:= self.weightRequested  - wTReleaseed;				// TFS #1843
	
	if diff.abs &lt;= Measure_AllowableDifference then					// TFS #1843
		return 0;													// TFS #1843
	endif;															// TFS #1843
	
	return self.weightRequested  - wTReleaseed;						//22.04.2025 navma1 #MTN-34387
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightPacked" id="d64d38f9-f4ed-4051-baba-d8d2134be234">
        <source>getWeightPacked() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2015	cnwndl1	Initial creation	Par 37288
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	result : Decimal[14,4];
	ti 		: CM_TrackedItem;
	allTis	: CM_TISet; 
begin
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems where ti.isChild do
	foreach ti in allTis where ti.isChild do //23/06/2023	navkc1	CR 58406 Task 58408
		if ti.isBulkByVolume or ti.isBulkByWeight then
			result := result + ti.totalWeight;
		endif;
	endforeach;
	
	return result;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightReleased" id="8e492f15-9624-45fb-aea7-96af2ac912bf">
        <source>getWeightReleased() : Decimal;
/*

Date		Who		Reason
19 Jun 2014	cnwer1	Initial creation PAR 34406
6  Dec 2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
22 Apr 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	result  : Decimal[14,4];
	ti 		: CM_TrackedItem;
begin
	
	//epr TFS 45287 16/8/19
	if self.isPackingChild then
		return self.getWeightPacked;
	endif;
	
	foreach ti in self.allTrackedItemsReleased discreteLock do						//22.04.2025 navma1 #MTN-34387
		if self.byTypeByWeight or ti.isBulkByVolume or ti.isBulkByWeight then		// 6/12/2023 navcs2 ChangeRequest 57537
			result := result + ti.totalWeight;
		endif;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightReleasedOrLoaded" id="b6a5e4dc-2952-4874-ab9a-a9e2c8ee606b">
        <source>getWeightReleasedOrLoaded(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2025	navhl20	Bug MTN-34073 : TPT - Unable to display released weight on report
*/

vars
	result 	: Decimal[14,4];
	ti 		: CM_TrackedItem;
begin
	foreach ti in self.allTrackedItemsReleased discreteLock do
		result := result + ti.totalWeight;
	endforeach;
	
	if result = null then
		foreach ti in self.allTrackedItems discreteLock do
			result := result + ti.totalWeight;
		endforeach;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
