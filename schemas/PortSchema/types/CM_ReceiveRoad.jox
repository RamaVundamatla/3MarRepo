    <JadeMethod name="getUnknownSealsAtReceiveArray" id="86d8fd98-d62c-48c5-a6f1-03ff264c26d5">
        <source>getUnknownSealsAtReceiveArray(allKnownSealTypes: String; theSealNumbers: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2021	jlgndl1	Initial creation	TFS 50749

*/

vars

	sealCheckTrx : CM_SealCheck;

begin

	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.wasPrenotified then
		sealCheckTrx := self.getTransactionByTypePriorTRX( TRANS_TYPE_SEAL_CHECK ).CM_SealCheck;	
		if sealCheckTrx &lt;&gt; null then
			sealCheckTrx.getUnknownSealTypeNumbersArray(allKnownSealTypes, theSealNumbers);
		endif;
	else
		inheritMethod(allKnownSealTypes, theSealNumbers);
	endif;

epilog

end;</source>
        <Parameter name="allKnownSealTypes" type="String"/>
        <Parameter name="theSealNumbers" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVVSubCarrierCodeDesc" id="3ca1d311-3342-46d8-9b3f-519a77271124">
