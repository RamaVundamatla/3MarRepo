    <JadeMethod name="getComboObject" id="3c230318-83c1-42f3-b40f-f00d987605fb">
        <source>getComboObject() : EntTableRow;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwrd1	Initial creation

*/

vars
	entTmp : Object;
	entRow : EntTableRow;
begin
	entTmp := cmbField.listObject;
	entRow := entTmp.EntTableRow;
	return  entRow;
epilog

end;</source>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getComboTxt" id="7abe16b6-e997-4181-8c0b-ee8358c03432">
        <source>getComboTxt() :String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwrd1	Initial creation

*/

vars

begin

