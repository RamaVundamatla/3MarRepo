Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/
// 11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
// 23 Jul 2012	cnwcs5		CCMS MES 2168 / par 29124 - new remarks parameter

vars
	
begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	
	app.setContinueCMExceptions(false);

	beginTransaction;
	return app.myUtilityCA.utlCreateROROCargoLocation(_locationID, null, _locationClass,  _locationWeight, _locationPoints, _deck, _length, _forCargo, null, _passport);	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
