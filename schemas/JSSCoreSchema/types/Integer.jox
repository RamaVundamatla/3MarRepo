<PrimType name="Integer">
    <JadeMethod name="jssAdd" id="247ab905-1aee-4d73-ba1b-d1112a388718">
        <updating/>
        <source>jssAdd(pIncrement:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Increments the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to increment a loop counter. *
//				*************************************************************
//
// Parameters:	pIncrement (Integer) - The amount by which to increment the receiver.
//
// Returns:		The result of the increment.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt;= (Max_Integer - pIncrement) then
		self := self + pIncrement;
	endif;
epilog
	return self;
end;</source>
        <Parameter name="pIncrement" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssAsKilobytes" id="a9f04754-fbe0-4333-acfe-aaad796f418d">
        <source>jssAsKilobytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent kilobytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into kilobytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_KILOBYTE	: Integer = 1024;
	
begin
	return self / BYTES_PER_KILOBYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssAsMegabytes" id="16a63533-af78-4767-ade6-66a869cf1fc9">
        <source>jssAsMegabytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent megabytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_MEGABYTE	: Integer = 1048576;
	
begin
	return self / BYTES_PER_MEGABYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssAsWords" id="52c5c728-cdeb-42a9-b100-b52ee4c00135">
        <source>jssAsWords(pTheFullLocale:LocaleFullInfo):String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver expressed in words.
//
// Parameters:	pTheNumberFormat - The locale of the number format information to
//				apply to the receiver, for example, the US "Billion" versus the UK
//				"Thousand Million".
//
// Returns:		The receiver expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.Real.jssAsWordsWhole(pTheFullLocale);
end;</source>
