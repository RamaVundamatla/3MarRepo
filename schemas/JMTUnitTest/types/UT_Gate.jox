	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	assertFalse(ya.isDisabled);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("FullRelease", true);
