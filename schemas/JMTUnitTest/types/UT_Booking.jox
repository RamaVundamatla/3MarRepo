    <JadeMethod name="tBookingDetailsEditability" id="b18a6d13-b4b2-4d06-949a-041fe114cd2b">
        <updating/>
        <source>tBookingDetailsEditability() updating;

/*

Purpose:		Check the containers booking details editability #36505

Date			Who		Reason
22/10/2015		cnwmh5	Initial creation

*/

vars

	booking							: CM_BookingRef;
	cannon							: CM_CargoType;
	vvr								: CM_VehicleVisitRecord;
	ti								: CM_TrackedItem;
	voyage							: CM_Voyage;
	bookingRefItem					: CM_BookingRefItem;
	bookingRefCont					: CM_BRefItemContainer;
	
	iter							: Iterator;
	

begin

	self.deleteBooking("UT_MDHBDEDIT");
	self.deleteVehicle("UTMHTRJ");
	self.deleteVoyage("UTMHBDVOY1");
	
	self.opts.purge();
	self.opts.addAssoc("UseVesselAllocations", true);
	voyage := self.addVoyageWithConRORO("UTMHBDVOY1", "MESDIAM", "UTOP", self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 4, false, false);
	self.assertNotNull(voyage);
	
	ti := self.getTrackedItem("UTMHBDEDIT1");
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	cannon := self.getCargoType("CANNON");
	self.assertNotNull(cannon);
	
	booking := self.addBookingForGeneralCargo("UT_MDHBDEDIT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, null, 
		cannon.id, 5);
	self.assertNotNull(booking);
	
	self.opts.purge();
	self.opts.addAssoc("Temp", 0.4.Real);
	self.opts.addAssoc("Voyage", voyage.code);
	booking := self.addBookingItemForContainer(booking, "2231", "REEF", 2);
	self.assertNotNull(booking);
	
	self.opts.purge();
	self.opts.addAssoc("Temp", 0.5.Real);
	self.opts.addAssoc("Voyage", voyage.code);
	booking := self.addBookingItemForContainer(booking, "2231", "REEF", 4);
	assertEqual(booking.allBookingRefItems.size, 3);
		
	iter := booking.allBookingRefItems.createIterator;
	iter.next(bookingRefItem);
	iter.next(bookingRefItem);
	
	self.opts.purge();
	self.opts.addAssoc("BookingItem", bookingRefItem);
	self.opts.addAssoc("Temp", 0.4.Real);
	self.opts.addAssoc("Voyage", voyage.code);
	vvr := self.gateInContainer("UTMHTRJ", "UTMHBDEDIT1", "2231", booking.operatorCode, "REEF", 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem("UTMHBDEDIT1");
	self.assertNotNull(ti);
	bookingRefCont := ti.myBookingRefItem.CM_BRefItemContainer;
	self.assertNotNull(bookingRefCont);
	
	self.opts.purge();
	self.opts.addAssoc("BookingRef", booking);
	self.opts.addAssoc("BookingRefItem", booking.allBookingRefItems.last);
	self.updateTrackedItem(ti);
	self.assertEqual(ti.myBookingRefItem, booking.allBookingRefItems.last);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_BookingItem_NotMatch);
	self.opts.purge();
	self.opts.addAssoc("Booking", booking);
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	self.updateTI(ti);
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingISOValidation" id="c3bb910b-375d-4416-afbe-e67e4739b85e">
        <updating/>
        <source>tBookingISOValidation() updating;
// jlgmd1
/*

Purpose:			Check that the EDI Booking creation validates ISO Type &amp; Group on create/update

Date		Who		Reason
06 Dec 2011	cnwkpd1	PAR #28803 - EDI Train Consist errors

*/

constants
	BadBooking		= "UT_BK_0000";
	GoodBooking1	= "UT_BK_0001";
	GoodBooking2	= "UT_BK_0002";
	
vars
	booking			: CM_BookingRef;
	operator		: String;
	
begin
	self.deleteBooking(BadBooking);
	self.deleteBooking(GoodBooking1);
	self.deleteBooking(GoodBooking2);
		
	operator := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	
	// Check that Booking for an invalid ISO Type cannot be created
	self.clearExpectedTrxErrors();
	self.expectTrxError(InvalidSettings);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, "YYYY", "MT");
	self.assertNull(booking);
	self.assertTrxError(InvalidSettings);
	self.clearExpectedTrxErrors();

	// Check that Booking for a valid ISO Type can be created
	booking := self.addBookingForContainer(GoodBooking1, self.getOperator(operator), null, null, "2200", "MT");
	self.assertNotNull(booking);

	// Check that Booking for an invalid ISO Group cannot be created
	self.opts.addAssoc("ISO Group", "XXXX");
	self.clearExpectedTrxErrors();
	self.expectTrxError(InvalidSettings);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, null, "MT");
	self.assertNull(booking);
	self.assertTrxError(InvalidSettings);
	self.clearExpectedTrxErrors();
	
	// Check that Booking for a valid ISO Group can be created
	self.opts.purge();
	self.opts.addAssoc("ISO Group", "20BX");
	booking := self.addBookingForContainer(GoodBooking2, self.getOperator(operator), null, null, null, "MT");
	self.assertNotNull(booking);
	
epilog
	self.clearExpectedTrxErrors();

end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingReeferWithoutTemp" id="2104ab83-3204-4c9b-83af-4c4403974118">
        <updating/>
        <source>tBookingReeferWithoutTemp()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2013	cnwndl1	Initial creation	Par 

*/

constants

	BadBooking = "UT_BK_TMP1";
	GoodBooking = "UT_BK_TMP2";
	
vars
	booking : CM_BookingRef;
	operator : String;
	commodity : CM_Commodity;
	tempCommodity : CM_Commodity;
	
begin

	self.deleteBooking(BadBooking);
	self.deleteBooking(GoodBooking);
		
	operator := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	
	self.setTerminalConfig(ReeferBookingReqsTemp,true);
	
	foreach commodity in CM_Commodity.instances do
		if commodity.hasTemp then
			tempCommodity := commodity;
			break;
		endif;
	endforeach;
	
	if tempCommodity = null then
		self.assertTrueMsg( false, "No commodity that requires a temperature found.");
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("ISO Group", "20BX");
	self.expectTrxError(Reefer_type_bookin_requir_temp);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, null, tempCommodity.code);
	self.assertTrueMsg( booking = null, "Test 1. With 'ReeferBookingReqsTemp' set and NO temp reading No ISO with Commodity requires temp should cause an error.");
	self.assertTrxError(Reefer_type_bookin_requir_temp);
	self.clearExpectedTrxErrors();
	
	self.opts.purge();
	self.expectTrxError(Reefer_type_bookin_requir_temp);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, "2232", tempCommodity.code);
	self.assertTrueMsg( booking = null, "Test 2. With 'ReeferBookingReqsTemp' set and NO temp reading, Reefer ISO with Commodity requires temp should cause an error.");
	self.assertTrxError(Reefer_type_bookin_requir_temp);
	self.clearExpectedTrxErrors();
	
	self.clearExpectedTrxErrors();
	self.opts.purge();
	self.opts.addAssoc("Temp", tempCommodity.minTemp - 1 );
	self.expectTrxError(VB_TEMP_VALIDATION);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, "2232", tempCommodity.code);
	self.assertTrueMsg( booking = null, "Test 3. With 'ReeferBookingReqsTemp' set and LOW temp reading, Reefer ISO with Commodity requires temp should cause an error.");
	self.assertTrxError(VB_TEMP_VALIDATION);
	self.clearExpectedTrxErrors();
	
	self.opts.purge();
	self.opts.addAssoc("Temp", tempCommodity.maxTemp + 1 );
	self.expectTrxError(VB_TEMP_VALIDATION);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, "2232", tempCommodity.code);
	self.assertTrueMsg( booking = null, "Test 4. With 'ReeferBookingReqsTemp' set and HIGH temp reading, Reefer ISO with Commodity requires temp should cause an error.");
	self.assertTrxError(VB_TEMP_VALIDATION);
	self.clearExpectedTrxErrors();
	
	self.opts.purge();
	self.expectTrxError(Reefer_type_bookin_requir_temp);
	booking := self.addBookingForContainer(BadBooking, self.getOperator(operator), null, null, "2232", null);
	self.assertTrueMsg( booking = null, "Test 5. With 'ReeferBookingReqsTemp' set and NO temp reading, for a reefer with NO Commodity should cause an error.");
	self.assertTrxError(Reefer_type_bookin_requir_temp);
	self.clearExpectedTrxErrors();

	// Check that Booking for a reefer with a valid commodity Temperature can be created
	self.opts.purge();
	self.opts.addAssoc("Temp", tempCommodity.minTemp);
	booking := self.addBookingForContainer(GoodBooking, self.getOperator(operator), null, null, "2232", tempCommodity.code);
	self.assertTrueMsg( booking &lt;&gt; null, "Test 6. With 'ReeferBookingReqsTemp' set and GOOD temp reading, Reefer ISO with Commodity requires temp should be OK.");
	self.deleteBooking(GoodBooking);
	
	// Check that Booking for an unknown container type reefer with a valid commodity Temperature can be created
	self.opts.purge();
	self.opts.addAssoc("ISO Group", "20BX");
	self.opts.addAssoc("Temp", tempCommodity.minTemp);
	booking := self.addBookingForContainer(GoodBooking, self.getOperator(operator), null, null, null, tempCommodity.code);
	self.assertTrueMsg( booking &lt;&gt; null, "Test 7. With 'ReeferBookingReqsTemp' set and Good temp reading, Unknown box with Commodity requires temp should be OK.");
	self.deleteBooking(GoodBooking);
	
	self.opts.purge();
	self.opts.addAssoc("Temp", tempCommodity.maxTemp + 1 );
	booking := self.addBookingForContainer(GoodBooking, self.getOperator(operator), null, null, "2232", null);
	self.assertTrueMsg( booking &lt;&gt; null, "Test 8. With 'ReeferBookingReqsTemp' set and Includes a temp reading, for a reefer with NO Commodity should be OK.");
	self.deleteBooking(GoodBooking);
	
epilog

	self.clearExpectedTrxErrors();
	self.deleteBooking(BadBooking);
	self.deleteBooking(GoodBooking);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingRequired" id="a128fc74-ce51-4fed-91a7-1cae8b703c06">
        <updating/>
        <source>tBookingRequired() updating;

/*

Purpose:		Check booking required Strict / Partial / None

Date			Who		Reason
26/05/2014		cnwmh5	Initial creation

*/

vars

	booking							: CM_BookingRef;
	vvr								: CM_VehicleVisitRecord;
	operator						: CM_Operator;

	origBookingReq					: Integer;
	opBookingReq					: Boolean;

begin

	origBookingReq := self.getTerminalConfig(BookingRefRequired).Integer;
	operator := self.getOperator("BOEI");
		
	self.deleteContainer("UTMHCCCCC01");					// receive first item against booking
	self.deleteContainer("UTMHCCCCC02");					// Strict
	self.deleteContainer("UTMHCCCCC03");					// Partial
	self.deleteContainer("UTMHCCCCC04");					// None
	self.deleteVehicle("UTMHJJ");
	
	self.deleteBooking("UTMDHBOOK1");
	booking := self.addBookingForContainer("UTMDHBOOK1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()), null, null, "2200", "MT");
	self.assertNotNull(booking);
		
	self.setTerminalConfig(BookingRefRequired, BookingRequired_Strict);
		
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	vvr := self.gateInContainer("UTMHJJ", "UTMHCCCCC01", "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), "MT", 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	
//	operator := self.getOperator("BOEI");
	opBookingReq := operator.requiresBookingReference;
	beginTransaction;
	operator.setPropertyValue("requiresBookingReference", true);
	commitTransaction;
	
	
	self.deleteVehicle("UTMHJJ");
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_Booking_Exceeded);
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	self.opts.addAssoc("ExpectErrors",true);
	vvr := self.gateInContainer("UTMHJJ", "UTMHCCCCC02", "2200", operator.code, "MT", 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.clearExpectedTrxErrors();
	
	self.setTerminalConfig(BookingRefRequired, BookingRequired_Partial);
	
	self.deleteVehicle("UTMHJJ");
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	vvr := self.gateInContainer("UTMHJJ", "UTMHCCCCC03", "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.setTerminalConfig(BookingRefRequired, BookingRequired_None);
	self.deleteVehicle("UTMHJJ");
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	vvr := self.gateInContainer("UTMHJJ", "UTMHCCCCC04", "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);

epilog

	beginTransaction;
	operator.setPropertyValue("requiresBookingReference", opBookingReq);
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingTranship" id="a78810fa-ec19-4fa2-ace1-62aa4da9f8e3">
        <updating/>
        <source>tBookingTranship() updating;
/*

Purpose:	Tranship booking		

Date		Who		Reason
27/05/2014	cnwmh5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	VoyageNameImport 				: String = 'UTMDHTSIMP';
	VoyageNameExport 				: String = 'UTMDHTSEXP';
	ShipName						: String = 'TRIP';
	ContainerId 					: String = "UTMDHXZ0001";
	BookingId						: String = "UTMDHTSBOOK1";
	BlockStackId					: String = "UTBSTS1";
	BlockStackId2					: String = "UTBSTS2";
	YardAllocationIdExp				: String = "UTBSTS1ALLOCEXP";
	YardAllocationIdImp				: String = "UTBSTS1ALLOCIMP";

vars

	booking							: CM_BookingRef;
	voyageImp						: CM_Voyage;
	voyageExp						: CM_Voyage;
	ti								: CM_TrackedItem;
	dischargePort					: CM_Port;
	bs								: CM_BlockStack;
	bs2								: CM_BlockStack;
	ya								: CM_YardAllocation;
	operator						: CM_Operator;
	controller						: CMIF_TranshipTIController;
	tmpLoadCC						: CMIF_LoadColorCode;
	voyageJob						: CM_VoyageJob;
	crane							: CM_Crane;
	
	slots 							: CM_SlotControllerArray;
	locations						: CM_LCArray;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.disableAllYA(true);
	
	dischargePort := app.myRoot.allPorts[self.getTerminal().getConfig(PortDestCode).String];
	self.assertNotNull(dischargePort);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);
	
	bs := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(bs);	
	bs2 := self.addBlockStack(BlockStackId2, 10, null);
	self.assertNotNull(bs2);	
	
	create locations transient;
	bs.allLocationsControllers.copy(locations);
	self.deleteYA(YardAllocationIdExp);
	ya := self.addYA(YardAllocationIdExp, YACriteriaType_OperatorItem, operator.code, YACriteriaType_ISO, "2200", 
		YACriteriaType_Commodity, "GENL", locations, null);
	self.assertNotNull(ya);
	
	locations.clear();
	bs2.allLocationsControllers.copy(locations);
	self.deleteYA(YardAllocationIdImp);
	ya := self.addYA(YardAllocationIdImp, YACriteriaType_OperatorItem, operator.code, YACriteriaType_ISO, "2200", 
		YACriteriaType_Commodity, "GENL", locations, null);
	self.assertNotNull(ya);
	
	self.deleteVoyage(VoyageNameImport);
	voyageImp := self.addVoyageWithContainerStructur(VoyageNameImport, ShipName, operator.code, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyageImp);
	
	self.deleteVoyage(VoyageNameExport);
	voyageExp := self.addVoyageWithContainerStructur(VoyageNameExport, ShipName,operator.code, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyageExp);
	
	self.deleteContainer(ContainerId);
	create slots transient;
	self.getJobSlotControllers(voyageImp.code, "01", DeckOnDeck, 2, 1, 1, slots);
	self.assertEqual(slots.size, 1);
	ti := self.addContainerAtLocnDisch(ContainerId, "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], 
		dischargePort, voyageImp);
	
	self.deleteBooking(BookingId);
	booking := self.addBookingForContainer(BookingId, voyageImp.myOperator, voyageExp, null, "2200", "GENL");
	self.assertNotNull(booking);
	
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort := app.myRoot.allPorts["NZAKA"];
	controller.myExportDisPort := app.myRoot.allPorts["NZAKL"];
	controller.myExportVoyage := voyageExp;
	controller.remarks := "Tranship Booking TEST";
	//controller.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	controller.doStoreTIBookingRef(ti.id.trimBlanks(), booking.bookingReference);
	self.makeTrackedItemTranship(controller);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship");
	self.assertEqualMsg(ti.myExportVoyage, voyageExp, "TI has wrong export voyage:1");
	self.assertEqualMsg(ti.myImportVoyage, voyageImp, "TI has wrong import voyage:1");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExp, "TI has wrong myVoyageTranshipExport:1");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImp, "TI has wrong myVoyageTranshipImport:1");
	self.assertEqualMsg(ti.myVoyage, voyageImp, "TI myVoyage reference is not the import voyage");
	
	create tmpLoadCC transient;
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(voyageImp, "CRN1", slots, true);
	self.assertNotNull(voyageJob);
	
	crane := self.getCrane("CRN1");
	self.assertNotNull(crane);
	
	self.autoplanDischargeItems(voyageImp, bs, crane);
	self.moveAllCargoOnVoyage(voyageImp, REAL_MODE);
	
	self.assertEqual(booking.allTIs.size, 1);
	self.assertEqual(booking.allTIs.first, ti);	
	
	self.assertEqual(ti.myPrimaryActualLocation.myTerminalArea, bs);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	
	self.disableAllYA(false);

	delete slots;
	delete locations;
	delete controller;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingsToReconcile" id="bbbae40f-b132-4c8c-aa27-537d602357bb">
        <updating/>
        <source>tBookingsToReconcile()updating;
// jlgmp6
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking1, booking2, booking3: CM_BookingRef;
	container1: CM_TrackedItem;
begin
	self.deleteBooking("UT_BOOKING1");
	opts.addAssoc("number", 3);
	booking1 := self.addBookingForContainer("UT_BOOKING1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage1, "NZAKL", "4400", "APPL");
	addBookingItemForContainer(booking1, "4400", "APPL", 2);
	assertEqual(booking1.myVoyage, self.voyage1);
	assertEqual(booking1.allBookingRefItems.size, 2);
	
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	updateTIBooking(container1, booking1, booking1.allBookingRefItems.first);
	assertEqual(container1.myBookingRef, booking1);
	assertEqual(container1.myBookingRefItem, booking1.allBookingRefItems.first);
	assertEqual(container1.myVoyage, self.voyage1);
	
	self.deleteContainer("TEST0000002");
	container1 := self.addContainerOpts("TEST0000002", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	updateTIBooking(container1, booking1, booking1.allBookingRefItems.first);
	assertEqual(container1.myBookingRef, booking1);
	assertEqual(container1.myBookingRefItem, booking1.allBookingRefItems.first);
	assertEqual(container1.myVoyage, self.voyage1);
	
	self.deleteContainer("TEST0000003");
	container1 := self.addContainerOpts("TEST0000003", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	app.myPassport.errorsToIgnore.add(ERR_BookingItem_NotMatch);
	updateTIBooking(container1, booking1, null);
	assertEqual(container1.myBookingRef, booking1);
	
	self.deleteBooking("UT_BOOKING2");
	opts.addAssoc("number", 3);
	booking2 := self.addBookingForContainer("UT_BOOKING2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage1, "NZAKL", "2200", "APPL");
	addBookingItemForContainer(booking2, "4400", "MT", 2);
	assertEqual(booking2.myVoyage, self.voyage1);
	assertEqual(booking2.allBookingRefItems.size, 2);
	
	self.deleteContainer("TEST0000004");
	container1 := self.addContainerOpts("TEST0000004", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	updateTIBooking(container1, booking2, null);
	assertEqual(container1.myBookingRef, booking2);

	self.deleteBooking("UT_BOOKING3");
	opts.addAssoc("number", 3);
	booking3 := self.addBookingForContainer("UT_BOOKING3", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage2, "NZAKL", "2200", "APPL");
	addBookingItemForContainer(booking3, "4400", "MT", 2);
	assertEqual(booking3.myVoyage, self.voyage2);
	assertEqual(booking3.allBookingRefItems.size, 2);
	
	self.deleteContainer("TEST0000005");
	container1 := self.addContainerOpts("TEST0000005", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	updateTIBooking(container1, booking3, null);
	assertEqual(container1.myBookingRef, booking3);
end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingsWithMultiItems" id="697ad747-1769-443c-96c1-4b9041ad6229">
        <updating/>
        <source>tBookingsWithMultiItems() updating;
// jlgmp6
/*

Purpose:			
 A booking in place with multiple items. 	#1-462
Parameters:			

Return Value:		

Date											Who							Reason
14 July 2016							cnwrh7						Initial creation
04/08/2016				cnwmh5		Change where the prenote / containers are deleted
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	NewBookingRef1				: String = "UT_Booking1";
	VoyageCode1						: String = "MESDI000001";
	VoyageCode2				    : String = "MESDI000002";
	PreNoteCode1					: String = "UTRHXZ00001";
	TruckId1								: String = "UTRHT1";
	TruckId2								: String = "UTRHT2";
	ContainerId1 						: String = "UTMHXZ00011"; 
	ContainerId2						: String = "UTMHXZ00022"; 
	CargoTypeAbberv1			: String = "UT_CAR01";
	SplitToBookingId1			: String = "UT_SPLITTOBOOK1";
vars
	booking1,booking2		:	 	CM_BookingRef;
	splitToBooking				: 		CM_BookingRef;
	voyage1							: 		CM_Voyage;
	voyage2							:		CM_Voyage;
	prenote1							: 		CM_TrackedItem;
	cargoType						: 		CM_CargoType;
	vvr1,vvr2							: 		CM_VehicleVisitRecord;
	operator							: 		CM_Operator;
	txn										:		CM_TITransaction;
	ti											:		CM_TrackedItem;
	bookingRefSet				:		CM_BookingRefSet;

	operatorCode				:		String; 
	count								: 		Integer;
	remarks							:		String;
	tis										:		CM_TISet;	
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	create tis	transient;
	create bookingRefSet transient;
	
	ti := self.getTrackedItem(PreNoteCode1);		// delete the prenote
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti,false);
	endif;

	ti := self.getTrackedItem(ContainerId1);		//make the Container1 clean
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti,false);
	endif;
	
	ti := self.getTrackedItem(ContainerId2);		//make the Container2 clean
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti,false);
	endif;

	self.deleteBooking(NewBookingRef1);		//make the Booking clean
	
	voyage1 := self.getVoyage(VoyageCode1);	//make the Voyage clean
	if voyage1 &lt;&gt; null then
		beginTransaction;
			delete voyage1;
		commitTransaction;
	endif;
	voyage2 :=	self.getVoyage(VoyageCode2);
	if voyage2 &lt;&gt; null then
		beginTransaction;
			delete voyage2;
		commitTransaction;
	endif;
	
	cargoType := self.getCargoType(CargoTypeAbberv1);
	if cargoType &lt;&gt; null then
		self.deleteCargoType(CargoTypeAbberv1);	//make the CargoType clean
	endif;
	
	//operatorCode	:= self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operatorCode	:= "HLL";
	//operator			:=	app.myRoot.allOperators.getAtKey("operatorCode");										//Get Operator for "UTOP"
	operator			:=	app.myRoot.allOperators.getAtKey("HLL");										//Get Operator for "UTOP"
	self.assertTrueMsg( operator &lt;&gt; null, "Operator of 'HLL' not found during setup.");
	
	cargoType := self.addCargoType(CargoTypeAbberv1, false);				//Create Cargo for "UT_CAR01"
	self.assertNotNull(cargoType);
	
	voyage1 := 	self.addVoyageWithContainerStructur(VoyageCode1,"MESDIAM",operatorCode,"APL");				//Create First Voyage
	self.assertNotNull(voyage1);
	
	//Step6 Enter the seocond bookings details (new voyage,booking and container)
	voyage2 := 	self.addVoyageWithContainerStructur(VoyageCode2,"MESDIAM",operatorCode,"APL");				//Create Second Voyage
	self.assertNotNull(voyage2);
	
	//Step1 #1 Create a booking 
	booking1 := self.addBookingForContainer(NewBookingRef1, self.getOperator(operatorCode),voyage1, "NZAKL", "2210", "MT");		//Create First Booking
	self.assertNotNull(booking1);
	
	//Step1 #2 Add mutilple items
	booking1 := self.addBookingItemForContainer(booking1, "4400", "APPL", 1);		
	booking1 := self.addBookingItemForContainer(booking1, "4400", "GENL", 1);
	
	//Step 2 Create a Prenote with the Booking number created
	prenote1			:= 	self.getTrackedItem(PreNoteCode1);							//make the Prenote clean
	if prenote1 &lt;&gt; null then
		self.deleteTrackedItem(prenote1, false);
	endif;
	prenote1 := self.addPrenotedContainer(booking1.allBookingRefItems.first, PreNoteCode1);
	self.assertNotNull(prenote1);
		
	//Step4	Bring prenoted item onsite through the Road Gate
	self.deleteVehicle(TruckId1);
	self.opts.purge();
	self.opts.addAssoc("ContainerID1", ContainerId1);
	self.opts.addAssoc("Voyage", voyage1.code);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("BookingItem", booking1.allBookingRefItems.first);
	vvr1 := self.gateInContainer(TruckId1, prenote1.id, "2200", operator.code, "GENL", self.getProfileSetting(UT_Profile.P_SGATE).asString());	//Bring in prenoted item //???ContainerID Or prenote1.id
	self.assertNotNull(vvr1);
	//On Site
	self.workVehicle(vvr1);
	self.assertEqual(vvr1.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr1);
	self.assertIsDeleted(vvr1.myRoadJob);
	self.assertEqual(booking1.allTIs.size, 1);
	self.assertEqual(booking1.getRecievedCount(), 1);
	
	//Step5	Edit the booking and click the Split button
	self.deleteBooking(SplitToBookingId1);			//make it is clean
		
	splitToBooking := self.addBookingForContainer(SplitToBookingId1, operator, voyage2, "NZAKL", "2200", "GENL");	//Create Split Booking
	self.assertNotNull(splitToBooking);
	
	tis.clear();
	bookingRefSet.clear();
	remarks	:=	"Split From "	&amp; NewBookingRef1 &amp; " to " &amp; SplitToBookingId1;
	
	tis.add(booking1.allTIs.first);
	
	app.myTrxUA.trxSplitBooking(tis, booking1, splitToBooking, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(booking1.allTIs.size, 0);
	self.assertEqual(booking1.getRecievedCount(), 0);
	self.assertEqual(splitToBooking.allTIs.size, 1);
	self.assertEqual(splitToBooking.getRecievedCount(), 1);	
	//self.assertEqual(splitToBooking.remarks,remarks);
	self.assertEqual(splitToBooking.voyageCode,voyage2.code);
	
	
	//Step8 
	count := 0;
	ti := tis.first;
	foreach txn in ti.allTransactions discreteLock, reversed do
		if count = 0 then
			self.assertTrue(txn.isKindOf(CM_SplitBooking));
			self.assertTrue(txn.CM_SplitBooking.oldBookingReference = NewBookingRef1);
			self.assertTrue(txn.CM_SplitBooking.oldVoyageCode = voyage1.code);
			self.assertTrue(txn.CM_SplitBooking.newBookingReference = splitToBooking.bookingReference);
			self.assertTrue(txn.CM_SplitBooking.newVoyageCode = splitToBooking.voyageCode);
			self.assertTrue(txn.CM_SplitBooking.dischargePort = splitToBooking.dischargePort);		
			self.assertTrue(txn.CM_SplitBooking.remarks = remarks);
		else
			self.assertTrue(txn.isKindOf(CM_Edit));
			self.assertTrue(txn.voyageCode = splitToBooking.voyageCode);
			self.assertTrue(txn.dischargePort = splitToBooking.dischargePort);
		endif;
		count := count + 1;
		if count &gt; 1 then 
			break;
		endif;
	endforeach;
	
	//Step10	Bring booking jobs into the gate
	self.deleteVehicle(TruckId2);
	
	self.opts.purge();
	//self.opts.addAssoc("ContainerID2", ContainerId2);
	self.opts.addAssoc("Voyage", voyage2.code);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("BookingItem", splitToBooking.allBookingRefItems.first);
	vvr2 := self.gateInContainer(TruckId2, ContainerId2, "2200", operator.code, "GENL", self.getProfileSetting(UT_Profile.P_SGATE).asString());	
	self.assertNotNull(vvr2);
	
	self.workVehicle(vvr2);
	self.assertEqual(vvr2.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr2);
	self.assertIsDeleted(vvr2.myRoadJob);
	//self.assertEqual(splitToBooking.allTIs.size, 0);
	//self.assertEqual(splitToBooking.getRecievedCount(), 1);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete tis;
	delete bookingRefSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoMatch" id="ba5d1acc-8671-4d4d-b6d9-cc4da157042c">
        <source>tCargoMatch();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2024	navra1	Initial creation for //navra1 - CR 63764/Task 64227 - 22nd May 2024

*/
constants
	ISO_TYPE : String = "2200";
vars
	isoType_20Cont : CM_ISOType;
	refItem, bookingRef : CM_BRefItemContainer;
	actualTI : CM_Container;
	isMatch : Boolean;
	containerCargoType : CM_CargoType;
	reason : String;
	commodity : CM_Commodity;
	description,remarks,purchaseOrder,serviceOrder : String;
begin
	create refItem transient;
	create actualTI transient;	
	
	//check if the cargo item has the same iso and same iso group, it matches if the matching mode is BASIC_MATCH, but does not match in STRICT_MODE since the other attributes are different
	containerCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertNotNull(containerCargoType);	
	
	isoType_20Cont := app.myRoot.allISOTypes[ISO_TYPE];
	self.assertNotNull(isoType_20Cont);	
	
	commodity := app.myRoot.allCommodities["*UTA"];
	self.assertNotNull(commodity);	
	
	description := "DESC";
	remarks:="REMARKS";
	purchaseOrder := "PURCHASE";
	serviceOrder := "SERVICE";
	
	//setup the reference item	
	refItem.setProxy(TI_CargoType_Container, commodity.code, description, remarks, null,isoType_20Cont.code, 1, 1000, 1, -1,0, 10, 1.0, Metres3perHour, 1.0, 1.0, false, true, false, null, isoType_20Cont.myISOTypeGroup.code, false,null, purchaseOrder,serviceOrder, CM_BookingRefItem.BASIC_MATCH);	
	
	//set the iso type and cargo type of the cargo item
	actualTI.setISOType(isoType_20Cont.code);
	actualTI.setCargoType(TI_CargoType_Container);	
	
	//match using BASIC_MODE, and assert that it matched
	refItem.setMatchMode(CM_BookingRefItem.BASIC_MATCH);
	isMatch := refItem.doesCargoMatch(actualTI.myCargoType, actualTI.commodity, isoType_20Cont,null, actualTI.mark, actualTI.markNumber, actualTI.getColour(), actualTI.purchaseOrder, actualTI.serviceOrder, false, reason);
	
	write "BASIC Match : " &amp; isMatch.String &amp; CrLf &amp; "Reason:" &amp; reason;
	
	self.assertTrueMsg(isMatch, "Basic mode did not match, but it should have");
	
	//match using STRICT_MODE, it would not match, assert that
	refItem.setMatchMode(CM_BookingRefItem.STRICT_MATCH);
	isMatch := refItem.doesCargoMatch(actualTI.myCargoType, actualTI.commodity, isoType_20Cont,null, actualTI.mark, actualTI.markNumber, actualTI.getColour(), actualTI.purchaseOrder, actualTI.serviceOrder, false, reason);
	
	write "STRICT Match 1st time : " &amp; isMatch.String &amp; CrLf &amp; "Reason:" &amp; reason;	
	
	self.assertFalseMsg(isMatch, "Strict mode matched, but it should not have");
	
	//add all the other attributes in the TI so that it matches the STRICT MATCH
	actualTI.setCommodity(commodity.code);
	actualTI.setPropertyValue(CM_TrackedItem::purchaseOrder.name, purchaseOrder);
	actualTI.setPropertyValue(CM_TrackedItem::serviceOrder.name, serviceOrder);	
	
	//reset the reason string returned
	reason := "";
	
	//match using STRICT_MODE, it would match now, assert that
	refItem.setMatchMode(CM_BookingRefItem.STRICT_MATCH);
	isMatch := refItem.doesCargoMatch(actualTI.myCargoType, actualTI.commodity, isoType_20Cont,null, actualTI.mark, actualTI.markNumber, actualTI.getColour(), actualTI.purchaseOrder, actualTI.serviceOrder, false, reason);	
		
	write "STRICT 2nd Match time : " &amp; isMatch.String &amp; CrLf &amp; "Reason:" &amp; reason;
	self.assertTrueMsg(isMatch, "Strict mode did not match, but it should have");	

epilog
	delete refItem;
	delete actualTI;

end;</source>
    </JadeMethod>
    <JadeMethod name="tChangeContainerBooking" id="58985de7-0d2e-4feb-8924-23e92394db56">
        <updating/>
        <source>tChangeContainerBooking()updating;
// jlgmp6
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking1, booking2: CM_BookingRef;
	container1: CM_TrackedItem;
begin
	self.deleteBooking("UT_BOOKING1");
	booking1 := self.addBookingForContainer("UT_BOOKING1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage1, "NZAKL", "4400", "APPL");
	addBookingItemForContainer(booking1, "4400", "APPL", 1);
	assertEqual(booking1.myVoyage, self.voyage1);
	assertEqual(booking1.allBookingRefItems.size, 2);
	self.deleteBooking("UT_BOOKING2");
	booking2 := self.addBookingForContainer("UT_BOOKING2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage1, "NZAKL", "4400", "APPL");
	assertEqual(booking2.myVoyage, self.voyage1);
	
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "4400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	// Set to Booking and Item
	updateTIBooking(container1, booking1, booking1.allBookingRefItems.first);
	assertEqual(container1.myBookingRef, booking1);
	assertEqual(container1.myBookingRefItem, booking1.allBookingRefItems.first);
	assertEqual(container1.myVoyage, self.voyage1);

	// Set to Booking only
	updateTIBooking(container1, booking1, null);
	assertEqual(container1.myBookingRef, booking1);
	assertEqual(container1.myBookingRefItem, booking1.allBookingRefItems.last);		// cnwmc5 - 6 June 2014
	//assertNull(container1.myBookingRefItem);											// cnwmc5 - 6 June 2014
	assertEqual(container1.myVoyage, self.voyage1);
	
	// Change to different Booking
	updateTIBooking(container1, booking2, booking2.allBookingRefItems.first);
	assertEqual(container1.myBookingRef, booking2);
	assertEqual(container1.myBookingRefItem, booking2.allBookingRefItems.first);
	assertEqual(container1.myVoyage, self.voyage1);

	// Change to no Booking 
	//updateTIBooking(container1, null, null);
	//assertEqual(container1.myBookingRef, null);
	//assertEqual(container1.myBookingRefItem, null);
	//assertEqual(container1.myVoyage, self.voyage1);

end;</source>
    </JadeMethod>
    <JadeMethod name="tExportBookingWithLinStockBook" id="d2c04f79-b3ae-463f-a950-a805b799ea69">
        <updating/>
        <source>tExportBookingWithLinStockBook() updating;
// jlgns1
// cnwrh7
// cnwmc5
//12 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars
	bookingExport, bookingStock: CM_BookingRef;
	bItem : CM_BookingRefItem;
begin
	self.deleteBooking("UT_MATTBK_EXPORT");
	self.deleteBooking("UT_MATTBK_STOCK");
	

	bookingExport := self.addBookingForContainer("UT_MATTBK_EXPORT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	
	self.opts.addAssoc("Stock", true);
	bookingStock := self.addBookingForContainer("UT_MATTBK_STOCK", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	
	self.addLinkedExportBookings(bookingStock, bookingExport);
	
	assertEqual(bookingExport.allLinkedStockBookingItems.size, 1);
	assertEqual(bookingStock.allLinkedStockBookingItems.size, 0);
	
	foreach bItem in bookingStock.allBookingRefItems do
		assertEqual(bItem.allLinkedExportBookings.size, 1);
	endforeach;

	foreach bItem in bookingExport.allBookingRefItems do
		assertEqual(bItem.allLinkedExportBookings.size, 0);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tMultipleBookingItems" id="46f3831a-983a-4a9c-a433-a82189b41b00">
        <updating/>
        <source>tMultipleBookingItems() updating;
/*

Purpose:	Check that Gating In Containers allocate to correct Bookings		

Date		Who		Reason
27/05/2014	cnwmh5	Initial creation

*/

constants

	BookingId1						: String = "UTMDHBOOKM1";
	BookingId2						: String = "UTMDHBOOKM2";
	BookingId3						: String = "UTMDHBOOKM3";
	BlockStackId					: String = "UTMHBS7";
	VoyageId						: String = "UTMDHVOY1A";
	VoyageId2						: String = "UTMDHVOY1B";
	ShipName						: String = "TRIP";
	ContainerId1					: String = "UTMHXZ00011";
	ContainerId2					: String = "UTMHXZ00012";
	ContainerId3					: String = "UTMHXZ00013";
	ContainerId4					: String = "UTMHXZ00014";
	ContainerId5					: String = "UTMHXZ00015";
	ContainerId6					: String = "UTMHXZ00016";
	PrenoteId1						: String = "UTMHXZ00301";
	PrenoteId2						: String = "UTMHXZ00302";
	PrenoteId3						: String = "UTMHXZ00401";
	TruckId							: String = "UTMHJZ";

vars

	booking1						: CM_BookingRef;
	booking2						: CM_BookingRef;
	booking3						: CM_BookingRef;
	bs								: CM_BlockStack;
	voyage							: CM_Voyage;
	voyage2							: CM_Voyage;
	vvr								: CM_VehicleVisitRecord;
	operator						: CM_Operator;
	prenote1						: CM_TrackedItem;
	prenote2						: CM_TrackedItem;
	prenote3						: CM_TrackedItem;
	ti								: CM_TrackedItem;
	releaseRequest					: CM_BulkRelease;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(BookingRefRequired, BookingRequired_None);
	self.setTerminalConfig(BookingOversubscribe, true);
	self.setTerminalConfig(AutoBookingCargoUpdates, true);

	self.deleteContainer(ContainerId1);
	self.deleteContainer(ContainerId2);
	self.deleteContainer(ContainerId3);
	self.deleteContainer(ContainerId4);
	self.deleteContainer(ContainerId5);
	self.deleteContainer(ContainerId6);
	self.deleteContainer(PrenoteId1);
	self.deleteContainer(PrenoteId2);
	self.deleteContainer(PrenoteId3);
	self.deleteVehicle(TruckId);
	self.deleteTerminalArea( BlockStackId );
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);

	bs := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(bs);	
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithContainerStructur(VoyageId, ShipName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage);
	
	self.deleteVoyage(VoyageId2);
	voyage2 := self.addVoyageWithContainerStructur(VoyageId2, ShipName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage2);
	
	self.deleteBooking(BookingId1);
	booking1 := self.addBookingForContainer(BookingId1, operator, voyage, "NZAKL", "2200", "GENL");
	self.assertNotNull(booking1);
	self.addBookingItemForContainer(booking1, "2200", "GENL", 1);
	self.addBookingItemForContainer(booking1, "2200", "GENL", 1);
	
	prenote1 := self.addPrenotedContainer(booking1.allBookingRefItems.first, PrenoteId1);
	self.assertNotNull(prenote1);
	prenote2 := self.addPrenotedContainer(booking1.allBookingRefItems.first, PrenoteId2);
	self.assertNotNull(prenote2);
	
	self.deleteBooking(BookingId2);
	self.opts.purge();
	self.opts.addAssoc('number', 3);
	booking2 := self.addBookingForContainer(BookingId2, operator, voyage, "NZAKL", "2200", "GENL");
	self.assertNotNull(booking2);
	
	self.deleteBooking(BookingId3);
	self.opts.purge();
	self.opts.addAssoc('number', 3);
	booking3 := self.addBookingForContainer(BookingId3, operator, voyage, "NZAKL", "2200", "MT");
	self.assertNotNull(booking3);
	
	
	prenote3 := self.addPrenotedContainer(booking3.allBookingRefItems.first, PrenoteId3);
	
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking1.allBookingRefItems.first);
	self.opts.addAssoc("DischargePort", "NZPOE");
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("ContainerID2", ContainerId2);
	vvr := self.gateInContainer(TruckId, ContainerId1, "2200", operator.code, "GENL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	self.assertEqual(booking1.allTIs.size, 4);
	self.roadExit(vvr);
	
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking2.allBookingRefItems.first);
	self.opts.addAssoc("DischargePort", "NZPOE");
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("ContainerID2", ContainerId3);
	vvr := self.gateInContainer(TruckId, ContainerId4, "2200", operator.code, "GENL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	self.assertEqual(booking2.allTIs.size, 2);
	self.roadExit(vvr);
	
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking1.allBookingRefItems.first);
	self.opts.addAssoc("DischargePort", "NZPOE");
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("ContainerID2", ContainerId6);
	vvr := self.gateInContainer(TruckId, ContainerId5, "2200", operator.code, "GENL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	self.assertEqual(booking1.allTIs.size, 6);
	self.assertEqual(booking2.allTIs.size, 2);
	self.roadExit(vvr);
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage2);
	self.updateBookingType(booking1, false);
	
	foreach ti in booking1.allTIs do 
		self.assertEqualMsg(ti.myVoyage, voyage2, ti.id &amp; "'s voyage (" &amp; ti.myVoyage.String &amp; ") doesn't equal " &amp; voyage2.String);
		self.assertEqualMsg(ti.allTransactions.last.isKindOf(CM_RollBooking), true, ti.id &amp; "'s last transaction isn't of type CM_RollBooking");
	endforeach;
		
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZWLG");
	self.updateBookingType(booking2, false);
	
	foreach ti in booking2.allTIs do 
		self.assertEqualMsg(ti.dischargePort, "NZWLG", ti.id &amp; "'s discharge port (" &amp; ti.dischargePort &amp; ") doesn't equal NZWLG");
		self.assertEqualMsg(ti.allTransactions.last.isKindOf(CM_RollBooking), true, ti.id &amp; "'s last transaction isn't of type CM_RollBooking");
	endforeach;
	
	// gate in prenote on booking3
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking3.allBookingRefItems.first);
	self.opts.addAssoc("DischargePort", "NZPOE");
	self.opts.addAssoc("Voyage", voyage.code);
	vvr := self.gateInContainer(TruckId, PrenoteId3, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Commodity", "MT");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	ti := self.getTrackedItem(PrenoteId3);
	self.assertNotNull(ti);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ReleasingItemOnBooking);
	
	// gate out the continer
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer(TruckId, "", "UTDRIVER1", ti.CM_Container, true, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()), null);
	self.assertNotNull(vvr);
	self.assertTrxWarning(ReleasingItemOnBooking);
	
	self.deleteTerminalArea( BlockStackId );
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPrenoteBookingWithAttachments" id="d472befc-73ec-4b1e-897f-2a5cb5db7014">
        <updating/>
        <source>tPrenoteBookingWithAttachments()updating;
// jlgns1
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	bookingOversubscribe : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	self.setTerminalConfig(PrenoteUniqBooking, false);
	
	self.setTerminalConfig(BookingOversubscribe, true);

	deleteContainer("UUT00000001");
	deleteContainer("UUT00000002");
	self.deleteBooking("UT_BOOKING");
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000001");
	assertTrue(ti.isPreNote);
	ti := self.addPrenotedAttachment(ti, booking.allBookingRefItems.first, "UUT00000002");
	assertTrue(ti.hasChildren);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPrenotedBooking" id="f1565d53-02b5-4457-89d9-34dd36d4d4a7">
        <updating/>
        <source>tPrenotedBooking()updating;
// jlgns1
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	now : TimeStamp;
begin
	deleteContainer("UUT00000001");
	deleteContainer("UUT00000002");
	self.deleteBooking("UT_BOOKING");
	self.deleteBooking("UT_BOKING2");
	
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000001");
	
	//08 Apr 2020	NDL	TFS 47958
	self.opts.purge();
	opts.addAssociation("PackDate", now.date.asStringJMT);
	opts.addAssociation("PackTime", now.time.asStringJMT);
	opts.addAssociation("AllowableTimeOffPower", "10".Decimal);
	opts.addAssociation("PackTempC", 3);
	opts.addAssociation("Temp", 3);
	opts.addAssociation("CarbonDioxide", "10.1".Decimal);
	opts.addAssociation("Humidity", "25.25".Decimal);
	opts.addAssociation("Oxygen", "73".Decimal);
	booking := self.addBookingForContainer("UT_BOKING2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "22R8", "APLD");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000002");
	self.assertTrueMsg( ti &lt;&gt; null and ti.id = "UUT00000002", "Container UUT00000002 not created");
	self.assertTrueMsg( ti.getCarbonDioxide = "10.1".Decimal, "Container UUT00000002 CarbonDioxide should be 10.1");
	self.assertTrueMsg( ti.getHumidity = "25.25".Decimal, "Container UUT00000002 Humidity should be 25.25");
	self.assertTrueMsg( ti.getOxygen = "73".Decimal, "Container UUT00000002 Oxygen should be 73");
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRetainExportBooking" id="abd82363-10ef-42d4-9752-375cfadcb699">
        <updating/>
        <source>tRetainExportBooking() updating;
/*

Purpose:			
Test that the export booking is not being overwritten by the stock booking when packing a tranship cargo item

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2016	cnwmp6	Initial creation

*/
constants
	VoyageId		= "UTMPVOY";
	BookingExportId	= "UTMPBE";
	BookingStockId	= "UTMPBS";
	CargoTransId	= "UTMPCT";
	ContainerId		= "UTMP0005340";

vars
	operator:		CM_Operator;
	voyage:			CM_Voyage;
	bookingExport:	CM_BookingRef;
	bookingStock:	CM_BookingRef;
	container:		CM_TrackedItem;
	pxyContainer:	CM_TrackedItem;
	cargo:			CM_TrackedItem;
	cargoType:		CM_CargoType;
	tiCont:			CMIF_TranshipTIController;
	bs:				CM_BlockStack;
	wh:				CM_IrregularBlockArea;
	pack:			CM_TIArray;
	unpack:			CM_TIArray;
	moveCont:		CMIF_MoveController;
	
begin
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "Operator is null");
	
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	self.assertNotNullMsg(wh, "warehouse is null");
	
	self.deleteVoyage(VoyageId);
	self.opts.purge();
	voyage := self.addVoyageWithConRORO(VoyageId, "MESDIAM", operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 0, true, false);
	self.assertNotNullMsg(voyage, "Voyage is null");	

	self.deleteBooking(BookingExportId);
	self.opts.purge();
	bookingExport := self.addBookingForContainer(BookingExportId, operator, voyage, "NZWLG", "2200", "GENL");
	self.assertNotNullMsg(bookingExport, "Export booking is null");
	
	self.deleteBooking(BookingStockId);
	self.opts.purge();
	self.opts.addAssoc("Stock", true);
	bookingStock := self.addBookingForContainer(BookingStockId, operator, voyage, "NZWLG", "2200", "GENL");
	self.assertNotNullMsg(bookingStock, "Stock booking is null");

	self.addLinkedStockBookingItems(bookingStock, bookingExport);

	self.opts.purge();
	bs := self.addBlockStack("UTMPBS1", 999, null);
	self.assertNotNullMsg(bs, "Block stack is null");
	
	self.deleteContainer(CargoTransId);
	cargoType := self.getCargoType("CAR");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	cargo := self.addCargoAtLocation(CargoTransId, cargoType, operator, bs.allLocationsControllers.first);
	self.assertNotNullMsg(cargo, "Cargo is null");
	beginTransaction;
		cargo.setTotalQuantity(1);
		cargo.setTotalWeightWithoutTrans(1800);
		cargo.setImExStatus(TI_IMEX_STATUS_IMPORT);
	commitTransaction;
	self.assertEqualMsg(cargo.totalQuantity.Integer, 1, "Cargo quantity should be 1");
	self.assertEqualMsg(cargo.totalWeight.Integer, 1800, "Cargo weight should be 1800");
	self.assertEqualMsg(cargo.getImExStatus(), TI_IMEX_STATUS_IMPORT, "Cargo IMEX status should be import");

	create tiCont transient;
	self.assertNotNullMsg(tiCont, "Tranship controller is null");
	tiCont.allTrackedItems.add(cargo);
	self.assertEqualMsg(tiCont.allTrackedItems.size, 1, "Tranship controller should have 1 cargo");
	tiCont.myExportDestPort  	:= app.myRoot.allPorts['NZAKA'];
	tiCont.myExportDisPort 		:= app.myRoot.allPorts['NZCHC'];
	tiCont.myExportVoyage 		:= voyage;
	tiCont.remarks 				:= "Trans cargo";
	//tiCont.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	
	self.makeTrackedItemTranship(tiCont);
	self.assertEqualMsg(cargo.getImExStatus(), TI_IMEX_STATUS_TRANSHIP, "Cargo IMEX status should be Tranship");

	container := self.addContainerAtLocation(ContainerId, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.allLocationsControllers.first);
	self.assertNotNullMsg(container, "Container is null");
	self.assertEqualMsg(container.getISOType(), "2200", "Container should be 2200");
	self.assertEqualMsg(container.commodity, "MT", "Container commodity should be MT");
	self.deleteStops(container);
	self.assertEqualMsg(container.getAllStops().size, 0, "Stops should be 0");
	
	self.updateTIBooking(cargo, bookingStock, bookingStock.allBookingRefItems.first);
	self.assertEqualMsg(cargo.bookingReference, BookingStockId, "Cargo booking ref should be " &amp; BookingStockId);
	self.assertNotNullMsg(cargo.myBookingRef, "Booking ref is null");
	self.assertNotNullMsg(cargo.myBookingRefItem, "Booking ref item is null");
	
	self.move(cargo, wh.allLocationsControllers.first);
	self.assertEqualMsg(cargo.allLocations.first.terminalAreaId, wh.id, "Cargo not moved to " &amp; wh.id);
	
	app.myPassport.setWarningsIgnored(true);
	
	create pack transient;
	self.assertNotNullMsg(pack, "Pack array is null");
	pack.add(cargo);
	self.assertEqualMsg(pack.size, 1, "Cargo not added to pack array");
	
	self.updateTIBooking(container, bookingExport, bookingExport.allBookingRefItems.first);
	self.assertEqualMsg(container.bookingReference, BookingExportId, "Container booking ref should be " &amp; BookingExportId);
	self.assertNotNullMsg(container.myBookingRef, "Booking ref is null");
	self.assertNotNullMsg(container.myBookingRefItem, "Booking ref item is null");
	pxyContainer := app.createUpdateProxy(container).CM_TrackedItem;
	
	create moveCont transient;
	moveCont.setMyToPrimaryLocation(null);
	moveCont.setMyOriginatingLocation(container.getPrimaryLocation(REAL_MODE));
	moveCont.setMoveMode(REAL_MODE);
	moveCont.isSystemMove := true;
	moveCont.isForcedMove := true;
	
	app.myTrxUA.trxUpdatePackUnpack(moveCont, false, pack, unpack, false, pxyContainer, app.myPassport);

	//self.packContainer(container.CM_Container, pack);
	self.assertTrueMsg(container.allChildren.size = 1 and container.allChildren.first.id = CargoTransId, "Container should contain " &amp; CargoTransId);
	self.assertEqualMsg(container.bookingReference, BookingExportId, "Continer booking ref should be " &amp; BookingExportId);
	self.assertEqualMsg(cargo.bookingReference, BookingStockId, "Cargo booking ref shoud be " &amp; BookingStockId);
	
epilog
	app.myPassport.setWarningsIgnored(false);

	delete tiCont;
	delete pack;
	delete moveCont;
	delete pxyContainer;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRollBooking" id="8589d7ba-d896-4b77-8167-7b323196e64d">
        <updating/>
        <source>tRollBooking() updating;
/*

Purpose:			

Date		Who		Reason
08 March 2016	cnwmk3	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	BookRef1				= "UT_BK_001";
	BookRef2				= "UT_BK_002";
	VoyageCode1				= "MESDI00002";
	VoyageCode2				= "MESDI00005";
	TrkNum					= "VV_1234";
	CNTR1					= "UT_CNTR001";
	CNTR2					= "UT_CNTR002";
	CNTR3					= "UT_CNTR003";
	CNTR4					= "UT_CNTR004";
vars
	booking, rollToBooking	: CM_BookingRef;
	operator				: String;
	bookRefItem				: CM_BookingRefItem;
	voy1, voy2				: CM_Voyage;
	vvr						: CM_VehicleVisitRecord;
	bs1						: CM_BlockStack;
	tis						: CM_TISet;
	bookingRefSet			: CM_BookingRefSet;
	proxyBookingRef			: CM_BookingRef;
	ti						: CM_TrackedItem;
	splitRollEvt			: CMEVT_SplitRollBooking;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteBooking(BookRef1);
	self.deleteBooking(BookRef2);
	operator := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	self.deleteVoyage(VoyageCode1);
	voy1 := self.addVoyageWithContainerStructur(VoyageCode1,"MESDIAM",operator,"APL");
	self.assertNotNull(voy1);
	self.deleteVoyage(VoyageCode2);
	voy2 := self.addVoyageWithContainerStructur(VoyageCode2,"MESDIAM", operator,"APL");
	self.assertNotNull(voy2);
	
	//create a block stack to use
	self.deleteTerminalArea("UT_BS01");
	bs1 := self.addBlockStack("UT_BS01", 10, null);
	self.assertNotNull(bs1);
	
	// Create a booking - adding ISO containers to bring onto site and multiple items- e.g. 4
	booking := self.addBookingForContainer(BookRef1, self.getOperator(operator), voy1, "NZAKL", "2210", "MT");
	booking := self.addBookingItemForContainer(booking, "4400", "MT", 1);
	booking := self.addBookingItemForContainer(booking, "2200", "GENL", 1);
	booking := self.addBookingItemForContainer(booking, "4400", "GENL", 1);
	assertNotNull(booking);
	assertEqual(booking.allBookingRefItems.size, 4);
	
	// Bring 2 containers onto site through the road gate form- using the "Reference" in the New Item text box. Move them to a known location.
	self.deleteVehicle(TrkNum);
	bookRefItem := booking.allBookingRefItems.first;
	self.assertNotNull(bookRefItem);
	self.opts.purge;
	self.opts.addAssoc("BookingItem",booking.allBookingRefItems.first);
	self.opts.addAssoc("Voyage", voy1.code);
	vvr := self.gateInContainer(TrkNum, CNTR1, "2210", booking.operatorCode, "MT", self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.workVehicle(vvr);
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	
	move(self.getTrackedItem(CNTR1), bs1);
	
	bookRefItem := booking.allBookingRefItems.first;
	self.assertNotNull(bookRefItem);
	self.opts.purge;
	self.opts.addAssoc("BookingItem",booking.allBookingRefItems.first);
	self.opts.addAssoc("Voyage", voy1.code);
	vvr := self.gateInContainer(TrkNum, CNTR2, "4400", booking.operatorCode, "MT", self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.workVehicle(vvr);
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	
	move(self.getTrackedItem(CNTR2), bs1);
	
	// Check the booking is updated to have 2 received items.
	self.assertEqual(booking.allTIs.size, 2);
	
	// Editing the booking. Roll the booking to a new voyage, New Booking, and discharge port.
	create tis transient;
	create bookingRefSet transient;
	tis.add(booking.allTIs.first);
	tis.add(booking.allTIs.last);
	bookingRefSet.add(booking);
	
	app.myTrxUA.trxRollBooking( bookingRefSet, BookRef2, voy2, "AUSYD", null, "Roll Booking", app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	rollToBooking := self.getBooking(BookRef2);
	self.assertNotNull(rollToBooking);
	
	// Check the bookings voyage and discharge port have been updated.
	self.assertEqual(rollToBooking.bookingReference, BookRef2);
	self.assertEqual(rollToBooking.voyageCode, voy2.code);
	self.assertEqual(rollToBooking.dischargePort, "AUSYD");
	
	// Check the items entered into the terminal have their Booking, voyage and discharge ports updated.
	self.assertEqual(tis.first.bookingReference, BookRef2);
	self.assertEqual(tis.first.voyageCode, voy2.code);
	self.assertEqual(tis.first.dischargePort, "AUSYD");
	
	self.assertEqual(tis.last.bookingReference, BookRef2);
	self.assertEqual(tis.last.voyageCode, voy2.code);
	self.assertEqual(tis.last.dischargePort, "AUSYD");
	
	//  Enter the remaining items onto site. First use the old booking id and check that &lt;oldbookingid&gt; has been rolled to booking &lt;newbookingid&gt;.
	booking := self.getBooking(BookRef1);
	if (not booking.isRolledOrClosed) then
		bookRefItem := booking.allBookingRefItems.first;
		self.assertNotNull(bookRefItem);
	
		ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  CNTR3);	
		self.gateInPinReceival(ti.myPinNo.pinNo, TrkNum);
	else
		//If the booking has been rolled, then gate in items using new booking.
		foreach splitRollEvt in booking.allSplitRollEventsAsOld do
			if splitRollEvt.isKindOf(CMEVT_RollBooking) then
				if booking.bookingReference &lt;&gt; splitRollEvt.myNewBookingReference.bookingReference then	
					rollToBooking := self.getBooking(BookRef2);
					bookRefItem := rollToBooking.allBookingRefItems.first;
					self.assertNotNull(bookRefItem);
					self.opts.purge;
					self.opts.addAssoc("BookingItem",rollToBooking.allBookingRefItems.first);
					self.opts.addAssoc("Voyage", voy2.code);
					self.opts.addAssoc("dischargePort", "AUSYD");
					vvr := self.gateInContainer(TrkNum, CNTR3, "2200", rollToBooking.operatorCode, "GENL", self.getProfileSetting(UT_Profile.P_DGATE).asString);
					self.workVehicle(vvr);
					assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
					self.roadExit(vvr);
		
					move(self.getTrackedItem(CNTR3), bs1);
		
					bookRefItem := rollToBooking.allBookingRefItems.first;
					self.assertNotNull(bookRefItem);
					self.opts.purge;
					self.opts.addAssoc("BookingItem",rollToBooking.allBookingRefItems.first);
					self.opts.addAssoc("Voyage", voy2.code);
					self.opts.addAssoc("dischargePort", "AUSYD");
					vvr := self.gateInContainer(TrkNum, CNTR4, "4400", rollToBooking.operatorCode, "GENL", self.getProfileSetting(UT_Profile.P_DGATE).asString);
					self.workVehicle(vvr);
					assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
					self.roadExit(vvr);
	
					move(self.getTrackedItem(CNTR4), bs1);
				endif;
			endif;
		endforeach;
	endif;
	
	// Check the items entered into the terminal have correct Booking, voyage and discharge port.
	ti := self.getTrackedItem(CNTR3);
	self.assertNotNull(ti);
	self.assertEqual(ti.bookingReference, BookRef2);
	self.assertEqual(ti.voyageCode, voy2.code);
	self.assertEqual(ti.dischargePort, "AUSYD");
	
	ti := self.getTrackedItem(CNTR4);
	self.assertEqual(ti.bookingReference, BookRef2);
	self.assertEqual(ti.voyageCode, voy2.code);
	self.assertEqual(ti.dischargePort, "AUSYD");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete tis;
	delete bookingRefSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRollSplitBooking" id="773cbf18-3646-49ee-b317-64d4d0141ca9">
        <updating/>
        <source>tRollSplitBooking() updating;

/*

Purpose:		Roll / Split booking

Date			Who		Reason
08/04/2014		cnwmh5	Initial creation

*/

constants

	RollFromBookingId				: String = "UTROLLFROMBOOK";
	RollToBookingId					: String = "UTROLLTOBOOK";
	RollToBooking2Id				: String = "UTROLLTOBOOK2";
	SplitToBookingId				: String = "UTSPLITTOBOOK";
	VoyageId						: String = "UTMHROLLBOOK";
	Voyage2Id						: String = "UTMHSPLITBOOK";
	Voyage3Id						: String = "UTMHROLLBOOK1";
	Voyage4Id						: String = "UTMHROLLBOOK2";
	VesselId						: String = "MESDIAM";
	Container1Id					: String = "UTMH0804A01";
	Container2Id					: String = "UTMH0804A02";
	
vars

	rollFromBooking					: CM_BookingRef;
	rollToBooking					: CM_BookingRef;
	splitToBooking					: CM_BookingRef;
	proxyBookingRef					: CM_BookingRef;
	voyage							: CM_Voyage;
	voyage2							: CM_Voyage;
	voyage3							: CM_Voyage;
	voyage4							: CM_Voyage;
	singleGate						: CM_Gate;
	ti								: CM_TrackedItem;
	vvr 							: CM_VehicleVisitRecord;
	auditObject						: CM_AuditObject;
	txn								: CM_TITransaction;
		
	tis								: CM_TISet;
	bookingRefSet					: CM_BookingRefSet;
	
	bookingId						: String;
	dischargePortCode				: String;
	remarks							: String;
	prevVoyageCode					: String;
	prevDischPortCode				: String;
	count							: Integer;

begin
	
	ti := self.getTrackedItem(Container1Id);
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem(Container2Id);
	self.deleteTrackedItem(ti, false);

	self.opts.purge();
	self.opts.addAssoc("CopyVoyageVAConfig", true);
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage);
	
	self.deleteVoyage(Voyage2Id);
	voyage2 := self.addVoyageWithConRORO(Voyage2Id, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage2);
	
	self.opts.purge();
	self.deleteVoyage(Voyage3Id);
	voyage3 := self.addVoyageWithConRORO(Voyage3Id, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage3);
	
	self.opts.purge();
	self.deleteVoyage(Voyage4Id);
	voyage4 := self.addVoyageWithConRORO(Voyage4Id, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage4);
	
	dischargePortCode := "NZAKL";
	bookingId := RollToBookingId;
	remarks := "Rolling From " &amp; RollFromBookingId &amp; " to " &amp; RollToBookingId;

	self.deleteBooking(RollToBookingId);
	self.deleteBooking(RollFromBookingId);
	self.opts.purge();
	self.opts.addAssoc("number", 10);
	rollFromBooking := self.addBookingForContainer(RollFromBookingId, 
		self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, dischargePortCode, "2200", "GENL");
	self.assertNotNull(rollFromBooking);
	
	create tis transient;
	create bookingRefSet transient;

	bookingRefSet.add(rollFromBooking);
	
	app.myTrxUA.trxRollBooking( bookingRefSet, bookingId, voyage, dischargePortCode, null, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	rollToBooking := self.getBooking(RollToBookingId);
	self.assertNotNull(rollToBooking);
	self.assertEqual(rollToBooking.bookingReference, RollToBookingId);
	self.assertEqual(rollToBooking.dischargePort, dischargePortCode);
	
	// 13/05/2015 cnwmh5 -  01-866:General Bookings - Start
	prevVoyageCode := rollFromBooking.voyageCode;
	prevDischPortCode := rollFromBooking.dischargePort;
	proxyBookingRef := app.createUpdateProxy(rollToBooking).CM_BookingRef;
	proxyBookingRef.setMyVoyage(voyage3);
	proxyBookingRef.setPropertyValue("dischargePort", prevDischPortCode);
	app.myTrxUA.trxUpdateBookingBulkRel(proxyBookingRef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// check that we have rolled correctly
	count := 0;
	foreach auditObject in rollToBooking.allAuditObjectsForClass discreteLock, reversed do
		if count = 0 then
			self.assertTrue(auditObject.isKindOf(CM_AuditObjectInformation));
			self.assertTrue(auditObject.CM_AuditObjectInformation.info = 
				"Rolled to booking UTROLLTOBOOK on voyage UTMHROLLBOOK1, discharge port NZAKL");			
		elseif count = 1 then
			self.assertTrue(auditObject.isKindOf(CM_AuditObjectInformation));
			self.assertTrue(auditObject.CM_AuditObjectInformation.info = 
				"Rolled from booking UTROLLTOBOOK on voyage UTMHROLLBOOK, discharge port NZAKL");	
		else
			self.assertTrue(auditObject.typeCode = "Updated");
		endif;
		count := count + 1;
		if count &gt; 2 then 
			break;
		endif;
	endforeach;
	rollToBooking := self.getBooking(RollToBookingId);
	// 13/05/2015 cnwmh5 -  01-866:General Bookings - End
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertNotNull(singleGate);
	
	self.deleteVehicle("UTMHTR1");
	self.opts.purge();
	self.opts.addAssoc("ContainerID2", Container2Id);
	self.opts.addAssoc("Voyage", voyage3.code);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", dischargePortCode);
	self.opts.addAssoc("BookingItem", rollToBooking.allBookingRefItems.first);
	vvr := self.gateInContainer("UTMHTR1", Container1Id, "2200", voyage3.myOperator.code, "GENL", singleGate);
	self.workVehicle(vvr);
	self.assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	self.assertIsDeleted(vvr.myRoadJob);
	self.assertEqual(rollToBooking.allTIs.size, 2);
	self.assertEqual(rollToBooking.getRecievedCount(), 2);
	
		self.deleteBooking(SplitToBookingId);
	splitToBooking := self.addBookingForContainer(SplitToBookingId, 
		self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage2, dischargePortCode, "2200", "GENL");
	self.assertNotNull(splitToBooking);
	
	tis.clear();
	bookingRefSet.clear();
	remarks := "Split From " &amp; rollToBooking.bookingReference &amp; " to " &amp; splitToBooking.bookingReference;
	
	tis.clear();
	tis.add(rollToBooking.allTIs.first);
	
	app.myTrxUA.trxSplitBooking(tis, rollToBooking, splitToBooking, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(rollToBooking.allTIs.size, 1);
	self.assertEqual(rollToBooking.getRecievedCount(), 1);
	self.assertEqual(splitToBooking.allTIs.size, 1);
	self.assertEqual(splitToBooking.getRecievedCount(), 1);	
	
	// 13/05/2015 cnwmh5 -  01-866:General Bookings - Start
	tis.clear();
	ti := self.getTrackedItem("UTMH0804A02");
	self.assertNotNull(ti);
	tis.add(ti);
	bookingRefSet.clear;
	bookingRefSet.add(rollToBooking);
	bookingId := RollToBooking2Id;
	
	app.myTrxUA.trxRollBooking(bookingRefSet, bookingId, voyage4, "NZWLG", null, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	rollToBooking := self.getBooking(RollToBooking2Id);
	self.assertNotNull(rollToBooking);
	self.assertEqual(rollToBooking.bookingReference, RollToBooking2Id);
	self.assertEqual(rollToBooking.dischargePort, "NZWLG");
	
	count := 0;
	foreach txn in ti.allTransactions discreteLock, reversed do
		if count = 0 then
			self.assertTrue(txn.isKindOf(CM_RollBooking));
			self.assertTrue(txn.CM_RollBooking.oldBookingReference = RollToBookingId);
			self.assertTrue(txn.CM_RollBooking.dischargePort = rollToBooking.dischargePort);
			self.assertTrue(txn.CM_RollBooking.oldVoyageCode = voyage3.code);
			self.assertTrue(txn.CM_RollBooking.newBookingReference = rollToBooking.bookingReference);
			self.assertTrue(txn.CM_RollBooking.newVoyageCode = rollToBooking.voyageCode);
			self.assertTrue(txn.CM_RollBooking.dischargePort = rollToBooking.dischargePort);		
		else
			self.assertTrue(txn.isKindOf(CM_Edit));
			self.assertTrue(txn.voyageCode = rollToBooking.voyageCode);
			self.assertTrue(txn.dischargePort = rollToBooking.dischargePort);
		endif;
		count := count + 1;
		if count &gt; 1 then 
			break;
		endif;
	endforeach;
	// 13/05/2015 cnwmh5 -  01-866:General Bookings - End
	
epilog

	delete tis;
	delete bookingRefSet;
	delete proxyBookingRef;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Failing1&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tSpecialStowBooking" id="914ffe44-2091-4ca4-b2ad-b47b045d986a">
        <updating/>
        <source>tSpecialStowBooking()updating;
// jlgns1
// cnwrh7
// cnwmc5
//14 Jan 2013	cnwdw1	
//
vars
	booking: CM_BookingRef;
	specialStow1, specialStow2: CM_SpecialStow;
	ti1, ti2 : CM_TrackedItem;
	bs1: CM_BlockStack;
	pxySpecialStow  : CM_SpecialStow;
	desc			: String;
	pxyDraw 		: CM_DrawingAttribute;	
begin
	self.deleteBooking("UT_BOOKINGST");
	
	specialStow1 := self.addSpecialStow("USTW1", "Unit Test Special Stow 1");
		assertNotNull(specialStow1);
	specialStow2 := self.addSpecialStow("USTW2", "Unit Test Special Stow 2");
		assertNotNull(specialStow2);
		
	self.opts.purge();
	self.opts.addAssoc("SpecialStow", specialStow1);
	booking := self.addBookingForContainer("UT_BOOKINGST", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.voyage1, "NZAKL", "2200", "GENL");
		assertNotNull(booking);
		assertEqual(booking.allBookingRefItems.first.mySpecialStow, specialStow1);

	bs1 := self.addBlockStack("UTBS1", 20, null);
		assertNotNull(bs1);
		
	ti1 := self.addContainerAtLocnDisch("UTST0000001", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs1.getLocationsController, voyage1.allPorts.first, voyage1);
		assertNotNull(ti1);
		
	// Attached TI to booking and check that the special stow value is copied to TI
	self.updateTIBooking(ti1, booking, booking.allBookingRefItems.first);
		assertEqual(ti1.specialStow, specialStow1.code);

	self.opts.purge();
	self.opts.addAssoc("SpecialStow", specialStow2);
	ti2 := self.addContainerAtLocnDisch("UTST0000002", "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs1.getLocationsController, voyage1.allPorts.first, voyage1);
		assertNotNull(ti2);
		assertEqual(ti2.specialStow, specialStow2.code);

	// Attached TI with a special stow to booking and check that the special stow value is not overridden by the booking value
	self.updateTIBooking(ti2, booking, booking.allBookingRefItems.first);
		assertEqual(ti2.specialStow, specialStow2.code);
	
	// 09/10/2015 cnwmh5 - Add updating for special stow
	beginLoad;
	pxySpecialStow := specialStow1.pxyCreateUpdateProxy();
	//pxyDraw := specialStow1.myDrawingAttribute.pxyCreateUpdateProxy();
	endLoad;
	
	create pxyDraw transient;
	
	desc := specialStow1.description &amp; " - Chg";
	pxySpecialStow.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateSpecialStow(pxySpecialStow, pxyDraw, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(specialStow1.description, desc);
	
epilog
	delete pxyDraw;
	delete pxySpecialStow;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStockBookingWithLinkedExpBook" id="634baa42-bf11-4093-9cf8-99dd65f56314">
        <updating/>
        <source>tStockBookingWithLinkedExpBook()updating;
// jlgns1
// cnwrh7
// cnwmc5
//12 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars
	bookingExport, bookingStock: CM_BookingRef;
	bItem : CM_BookingRefItem;
begin
	self.deleteBooking("UT_MATTBK_EXPORT");
	self.deleteBooking("UT_MATTBK_STOCK");
	

	bookingExport := self.addBookingForContainer("UT_MATTBK_EXPORT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	
	self.opts.addAssoc("Stock", true);
	bookingStock := self.addBookingForContainer("UT_MATTBK_STOCK", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2200", "MT");
	bookingStock := self.addBookingItemForContainer(bookingStock, "4400", "MT", 1);

	self.addLinkedStockBookingItems(bookingStock, bookingExport);
	
	assertEqual(bookingExport.allLinkedStockBookingItems.size, 2);
	assertEqual(bookingStock.allLinkedStockBookingItems.size, 0);
	
	foreach bItem in bookingStock.allBookingRefItems do
		assertEqual(bItem.allLinkedExportBookings.size, 1);
	endforeach;

	foreach bItem in bookingExport.allBookingRefItems do
		assertEqual(bItem.allLinkedExportBookings.size, 0);
	endforeach;
	
	// Change it to a Export Booking and check that links to export booking are removed
	self.updateBookingType(bookingStock, false);
	assertEqual(bookingExport.allLinkedStockBookingItems.size, 0);
	foreach bItem in bookingStock.allBookingRefItems do
		assertEqual(bItem.allLinkedExportBookings.size, 0);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateBookingBulkRel" id="55f1babf-bc18-42cb-b56d-567472cfe17f">
        <updating/>
        <source>tUpdateBookingBulkRel() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

19 January 2026	navbk1	Initial creation

*/

vars

	bookRefItem				: CM_BookingRefItem;
	pxyBooking,booking 		: CM_BookingRef;
	pxyBookingItem			: CM_BRefItemContainer;

begin

	self.deleteBooking("UT_BK_001");

	booking := self.addBookingForContainer("UT_BK_001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null, null, "2210", "MT");

	create pxyBookingItem transient;		

	pxyBookingItem.setProxy(TI_CargoType_Container, "MT", null, null, null, "4400", 1, 0, 0, 0, NULL_HUMIDITY, NULL_TEMPERATURE, NULL_VENTILATION, 0

							, NULL_CARBON_DIOXIDE, NULL_OXYGEN, false, false, false, null, self.opts.str("ISO Group"), false, null, null, null, CM_BookingRefItem.BASIC_MATCH);

	pxyBooking := app.createUpdateProxy(booking).CM_BookingRef;

	pxyBooking.allBookingRefItems.add(pxyBookingItem);

	app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();

epilog
 
	delete pxyBookingItem;
	delete pxyBooking;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyOnlyPrenote" id="5c6549b5-7f08-475e-a47b-119331f4e433">
        <updating/>
        <source>tVerifyOnlyPrenote()updating;
// jlgns1
// cnwrh7
// cnwmc5
//06 July 2009	cnwdw1	
//
vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	
begin
	deleteContainer("MWMU6402091");
	self.deleteBooking("UT_BOOKING");
	booking := self.addBookingForContainer("UT_BOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	opts.purge;
	opts.addAssoc("Verify", true);
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "MWMU6402091");
	assertIsDeleted(ti);
	
epilog
		
end;</source>
