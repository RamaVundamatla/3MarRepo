<Class name="CMQF_TrackedItem">
    <JadeMethod name="setFromAgent" id="a18b9445-5074-4bcb-b0df-78f4c342ff04">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 04/07/2010	cnwdap1		PAR #24519 Add Include Tranships
// 19/07/2010	cnwdap1		PAR #25021 Correct the handling of "Include Tranships"
vars
	voyageStr, string			: String;
	voy					: CM_Voyage;
	strObj				: Object;
	terminal			: CM_Terminal;
	site				: Integer;

begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_DischargePort) then
		self.setMyPort( _agent.getSelectedPort() );
	endif;

	if _agent.isRowIncluded(ETRow_LoadPort) then
		self.setMyLoadPort( _agent.getSelectedLoadPort() );
	endif;

	if _agent.isRowIncluded(ETRow_OperatorGroup) then
		self.setMyOperatorGroup( _agent.getSelectedOperatorGroup() );
	endif;

	if _agent.isRowIncluded(ETRow_IsoTypeGroup) then
		self.setMyISOTypeGroup( _agent.getSelectedISOTypeGroup() );
	endif;

	if _agent.isRowIncluded(ETRow_IMEXStatuses) then
		self.allQryIMEXStatuses.clear();
		_agent.getSelectedIMEXStatuses(self.allQryIMEXStatuses);
	endif;
	
	if _agent.isRowIncluded(ETRow_EndTime) then
		self.onTime := _agent.getValueByNameIfVisible(ETRow_EndTime).Time;
//		self.onTime := _agent.getSelectedEndTime();
	endif;
	
	
	if _agent.isRowIncluded(ETRow_OnDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_OnDate).String, 
								self.onDateTplType, self.onDateTplFactor, ETRow_OnDate);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_OnDate), 
								self.onDateTplType, self.onDateTplFactor, ETRow_OnDate);
		else
//			self.onDate := _agent.getSelectedOnDate(); Par11089
			self.onDate := _agent.getValueByNameIfVisible(ETRow_OnDate).Date;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_SiteState) then
		self.allQrySites.clear;
		_agent.getSelectedSites(self.allQrySites);
	endif;
	
	if _agent.isRowIncluded(ETRow_Stops) then
		self.allQryStopTables.clear();
		_agent.getSelectedStops(self.allQryStopTables);
		self.allQryStopTables.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	endif;
	
	if _agent.isRowIncluded(ETRow_ShipJob) then
		self.allQryVoyageJobs.clear();
		_agent.getSelectedVoyageJobs(self.allQryVoyageJobs);
		self.allQryVoyageJobs.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	endif;
	
	if _agent.isRowIncluded(ETRow_Voyage) then
		if _agent.useCurrentDefaultVoyage() then
			self.doUseAppDefaultVoyage := true;
		else
			self.doUseAppDefaultVoyage := false;
			self.setMyVoyage( _agent.getSelectedCellularVoyage() );
		endif;
		/*
		if CMUI_ReportBuilder.hasInstance(_agent.myParentForm) then
			if _agent.myCmbCellularVoy.text = _agent.OPT_DEFAULT_VOYAGE then
				self.doUseAppDefaultVoyage := true;
			else
				self.doUseAppDefaultVoyage := false;			
			endif;
		else
			self.myVoyage := _agent.myCmbCellularVoy.listObject.CM_Voyage;
		endif;
		*/
	endif;

	// PAR #24519 Include Tranships - if parameter is present, us it. If not, default to including tranships
	//if _agent.isRowIncluded(ETRow_IncludeTranships) then										// PAR #25021
	//	self.includeTranships := _agent.getIncludeTranships();									// PAR #25021
	//endif;																					// PAR #25021
	self.includeTranships := _agent.getValueByNameIfVisible(ETRow_IncludeTranships).Boolean	;	// PAR #25021
	if not _agent.isRowIncluded(ETRow_IncludeTranships) then									// PAR #25021
		self.includeTranships := true;															// PAR #25021
	endif;																						// PAR #25021

	self.id := _agent.getValueByNameIfVisible(ETRow_Id).String.toUpper()[1:30];

	self.saveToWorkList := _agent.getValueByNameIfVisible(ETRow_SaveToWorkList).Boolean;
	self.daysOnsite := _agent.getValueByNameIfVisible(ETRow_DaysOnsite).Integer;//added by cnwyl1 for ccms1504

	// ### TFS BUG 56660 23FEB2023 NAVAB1	
	if _agent.isRowIncluded(ETRow_ShippingLine) then
		if _agent.isKindOf(CMUI_ReportAgentStd) then
			self.setMyShippingLine( _agent.CMUI_ReportAgentStd.myCmbShippingLine.listObject.CM_ShippingLine );
		else
			string := _agent.getValueByName(ETRow_ShippingLine).String.trimBlanks;
			if string &lt;&gt; null then
				self.setMyShippingLine( string.asOid.CM_ShippingLine );
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
