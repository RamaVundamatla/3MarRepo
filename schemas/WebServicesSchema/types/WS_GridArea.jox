<Class name="WS_GridArea" id="fcedc289-ea3d-4e30-a4b1-eca89b35d97a">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="areaType" id="1723fcb7-897b-4f19-9a0a-8674b9f36762">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="areaTypeDesc" id="d4cdae94-a801-44c4-a42e-602a10c8343c">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="code" id="e83ad4d5-42b3-416b-bbb2-035ebec3c030">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="details1" id="bc7c5ec3-fbc7-4374-8e72-008f6baac7eb">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="details2" id="46525948-8016-4218-ab4a-39df95938b13">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxStackHeight" id="e67bec23-34a9-4c1e-be6c-d75d4d237832">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="bdbabcc0-0a0f-4cd6-809a-251ce2757a26">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theGA : CM_GridArea;
	spaceAgent : CMIF_SpaceUtilisationQryAgent;
	kpiTA : CM_KPITerminalArea;
	theGR : CM_GridRow;
	wsGR : WS_GridRow;
begin
	inheritMethod(_object);

	if not _object.isKindOf(CM_GridArea) then
		return;
	endif;
	
	theGA := _object.CM_GridArea;
	
	self.areaTypeDesc := theGA.typeString;
	self.areaType := theGA.getTypeCode();
	self.code := theGA.id;
	self.maxStackHeight := theGA.heightOfStack;
	
	// ### KPI DETAILS
	create spaceAgent transient;
	spaceAgent.allQryTerminalAreas.add(theGA);
	spaceAgent.doQuerySPACE();
	kpiTA := spaceAgent.allKPITerminalAreas.first.CM_KPITerminalArea;
	
	self.details1 := "TEU: " &amp; kpiTA.totalTEUs.String &amp; " of " &amp; kpiTA.maxTIs.String &amp; " (" &amp; kpiTA.pcCapacity.String &amp; "%)";
	self.details2 := "MT: " &amp; kpiTA.totalLocnEmpty.String &amp; " (" &amp; kpiTA.pcMT.String &amp; "%)" &amp; 
//				" OCCUPIED: " &amp; kpiTA.totalLocnOccupied.String &amp; " (" &amp; kpiTA.pcOccupied.String &amp; "%)" &amp; 
				" FULL: " &amp; kpiTA.totalLocnFull.String &amp; " (" &amp; kpiTA.pcFull.String &amp; "%)" ;

epilog
	delete spaceAgent;
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
