			return self.CM_GridController.myGridColumn.myLabourWorkArea;
		endif;
		if self.CM_GridController.myGridRow &lt;&gt; null and self.CM_GridController.myGridRow.myLabourWorkArea &lt;&gt; null then
			return self.CM_GridController.myGridRow.myLabourWorkArea;
		endif;
	endif;
	
	return null;

epilog

end;</source>
