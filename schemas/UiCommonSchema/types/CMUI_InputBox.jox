    <JadeMethod name="doOK" id="e0d940f6-7115-487a-bfa4-badda14f6f54">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.txtInput.text = null and not self.vOptional then
		app.msgBox('You must enter a ' &amp; self.fieldName &amp; ' value, or cancel', 'Nothing entered', 0);
		self.txtInput.setFocus();
		return;
	endif;
	
	inheritMethod();


end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="5a09b513-f89f-4553-8e26-0c40b890d269">
        <updating/>
        <source>init(_heading, _descr, _value : String; _maxLen, _dataType, _case : Integer; _multiLine, _optional: Boolean) updating;
// init(_heading, _descr, _value : String; _maxLen, _dataType : Integer; _multiLine: Boolean) updating;		// cnwrl1 05/06/2009 PAR 19574 - what it was
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/06/2009	cnwrl1		PAR 19574 - to add the case parameter;
// 20/01/2010	conkc1		To handle translation
// ---------------------------------------------------------------------------
vars

begin
	//
	// Can not setup actual controls here as they will be over written by translateForm method on the load
	// We store the values off and do the code in setupForm
	//
	self.vHeading     := _heading;
	self.vDescription := _descr;
	self.vValue       := _value;
	self.vMaxLen      := _maxLen;
	self.vDataType    := _dataType;
	self.vCase        := _case;
	self.vMultiLine   := _multiLine;
	self.vOptional    := _optional;		// 25/10/18 MAP TFS41191

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_maxLen" type="Integer"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_case" type="Integer"/>
        <Parameter name="_multiLine" type="Boolean"/>
        <Parameter name="_optional" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9200de68-f621-41fb-b5ec-552fdbbd23ab">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002		cnwth2	
//
// Purpose:     
//			
// Changed On 
// ----------   ----------  --------------------------------------------------
// 20/01/2010	conkc1		To ensure that the translateForm method does not clobber captions
vars
	minWidth	: Integer;

begin

	inheritMethod();
	//
	// Use the translated variables as setup in init
	//
	if vHeading = null then
		self.caption := 'Enter a value';
		lblInput.caption := "";
		lblInput.visible := false;
	else
		self.fieldName := vHeading[ 1 : self.fieldName.maxLength ];
		self.caption := 'Enter the ' &amp; vHeading &amp; ' value:';
		lblInput.visible := true;
		if vHeading.length &gt; 1 then
			lblInput.caption := vHeading[1].toUpper &amp; vHeading[2:end];
		else
			lblInput.caption := vHeading.toUpper;
		endif;
	endif;

	if vDescription = null then
		lblDescription.visible := false;
	else
		lblDescription.visible := true;
		lblDescription.caption := vDescription;
	endif;
	
	txtInput.text		:= vValue;
	txtInput.maxLength	:= vMaxLen;
	txtInput.dataType	:= vDataType;
	txtInput.case		:= vCase;				// cnwrl1 05/06/2009 PAR 19574
	
	if vMultiLine then
		txtInput.height := txtInput.height*3;
		self.btnOk.default := false;	//allows carriage returns to be used in the text box
	endif;
	
	if vMaxLen &gt; 0 then
		//pushes the textbox off the form when vmaxLen starts getting long
		//txtInput.width := self.getTextExtent('W') * vmaxLen;
	endif;


	if lblDescription.visible then
		lblDescription.top		:= WinTopMargin;
		lblDescription.left		:= WinLeftMargin;
		lblDescription.height	:= self.getTextHeightForWidth(lblDescription.caption, lblDescription.width.Integer);

		lblInput.top := WinTopMargin + lblDescription.height + (VerticalSpacing * 2);

		minWidth := (lblDescription.left + lblDescription.width + WinRightMargin).Integer;
	else
		lblInput.top 			:= WinTopMargin;
	endif;
	
	lblInput.left 	:= WinLeftMargin;
	lblInput.width	:= self.getTextExtent(lblInput.caption);
		
	txtInput.top 	:= lblInput.top;
	txtInput.left 	:= lblInput.left + lblInput.width + 20;
	
	//PAR16920 cnwsh3  Interim fix as the form is not formatting correctly during painting.  A write statement or doWindowsEvent seems to fix this.
	//JADE PAR
	self.doWindowEvents(0);
	//--------------------
	
	self.width := minWidth.max(self.getTextExtent(self.caption) + 190);

	txtInput.width	:= self.width - (txtInput.left + 15);
	
	self.height := txtInput.top + txtInput.height + (VerticalSpacing * 2) + btnOk.height + WinBottomMargin;
	//self.refreshNow();
	self.centreWindow();
	
	self.txtInput.setFocus();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2adecc78-0aef-4ffa-9165-8eca7556e49e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017375, locale);
	lblDescription.translateCaption(Xlat_0013455, locale);
	lblInput.translateCaption(Xlat_0013456, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtInput_contextMenu" id="797bf805-ea25-46de-a7ab-711138598900">
        <controlMethod name="TextBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtInput_contextMenu(textbox: TextBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/11/2019	jlgdap1		Initial creation TFS 46854 SNO Driver Identity Checking for Cargo Release
//
vars

begin
	if self.vDescription = app.getErrorString(Scan_Driver_Id) then
		return false;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="txtInput_keyDown" id="350248bb-f120-4777-b088-2544b2d85629">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtInput_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/11/2019	jlgdap1		Initial creation TFS 46854 SNO Driver Identity Checking for Release
//
vars

begin
	if self.vDescription = app.getErrorString(Scan_Driver_Id) and textbox.passwordField then
		if (keyCode = J_key_V and shift.bitAnd(2) &lt;&gt; 0)		// CTRL key pressed
		or keyCode = J_key_Ctrl then
			self.btnOk.enabled := false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtInput_keyUp" id="af80a8d9-25f9-425a-a941-7537083d8eef">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtInput_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/11/2019	jlgdap1		Initial creation TFS 46854 SNO Driver Identity Checking for Release
//
vars

begin
	if self.vDescription = app.getErrorString(Scan_Driver_Id) and textbox.passwordField then
		if (keyCode = J_key_V and shift.bitAnd(2) &lt;&gt; 0)		// CTRL key pressed
		or keyCode = J_key_Ctrl then
			textbox.text := null;
			self.btnOk.enabled := true;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
