    <JadeMethod name="updateForDelay" id="9d696aae-eb5f-486e-9dc3-fffe28f3aedc">
        <updating/>
        <source>updateForDelay(_delay :CM_Delay)updating;
// ---------------------------------------------------------------------------
// Created:     17 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Update net durations for moves and lifts
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiLift		:CM_KPIMachineLiftDtl;
	kpiLog		:CM_KPIMachineLogonOffDtl;
	tsStart, tsEnd,
	delayStart, delayEnd	:TimeStamp;
	duration				:Integer;	
begin
	tsStart 	:= self.getStartTS;
	tsEnd		:= self.getEndTS;
	delayStart	:= _delay.startDT;
	delayEnd	:= _delay.endDT;
	
	// only count that part of the delay that spans the lift/move
	if delayStart &lt; tsStart then
		delayStart := tsStart;
	endif;
	
	if delayEnd = null or delayEnd &gt; tsEnd then
		delayEnd := tsEnd;
	endif;
	
	// at this time if there are overlapping delays we will count the delay duration twice.
	// user gets a warning if they enter delays that overlap for a given machine
	duration := delayEnd.getDifferenceInSeconds (delayStart).Integer;
	
	self.delayDuration := self.delayDuration + duration;
	
	self.allDelays.add (_delay);
	
	// work out delay durations for each lift/move
	foreach kpiLift in self.allKPIMachineLifts do
		kpiLift.updateForDelay (_delay);
	endforeach;
	// work out delay durartion for logon/logoff pairs
	foreach kpiLog in self.allKPIMachineLogonOff do
		kpiLog.updateForDelay (_delay);
	endforeach;
	
 
epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="updateForLogoff" id="33de7a87-9b46-4013-8500-9fbe7b1e2be4">
        <updating/>
        <source>updateForLogoff(_history: CM_MachineLogOnOffHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Update KPI for logoff
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpi		:CM_KPIMachineLogonOffDtl;
	logon	:CM_MachineLogOnOffHistory;
begin
	logon := _history.myPriorHistory.CM_MachineLogOnOffHistory;
	// update gross running time (time logged on)
	if logon &lt;&gt; null and logon.dateTime &lt; self.getStartTS then
		// we will have already processed the logon if it is for the same date
		// if not workout gross running time from beginning of the day
		kpi := self.createKPILogonOffDtl (_history);
	
		if kpi = null then // PAR 34931 - CM_MachineLogOnOffHistory is a singleton so if the kpi has not been created do not add it to the collection.
			return;
		endif;
		
		self.grossRunningTime := self.grossRunningTime + kpi.grossDuration;
		
	endif;
	
	self.allMachineHistory.add (_history);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
    <JadeMethod name="updateForLogon" id="e3739dac-1783-4f87-a5a7-e329d9b7c4c5">
        <updating/>
        <source>updateForLogon(_history: CM_MachineLogOnOffHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Update KPI for logon
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpi	:CM_KPIMachineLogonOffDtl;
begin
	kpi := self.createKPILogonOffDtl (_history);
	
	if kpi = null then // PAR 34931 - CM_MachineLogOnOffHistory is a singleton so if the kpi has not been created do not add it to the collection.
		return;
	endif;

	self.grossRunningTime := self.grossRunningTime + kpi.grossDuration;
	
	self.allMachineHistory.add (_history);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
    <JadeMethod name="updateForLogonLogoff" id="ae67af1d-8255-480e-b7de-50e3f801b086">
        <updating/>
        <source>updateForLogonLogoff(_history :CM_MachineLogOnOffHistory)updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:Integer;
begin
	type := _history.type;
	
	if type = CM_MachineHistory.Type_LogOn then
		self.updateForLogon (_history);
	elseif type = CM_MachineHistory.Type_LogOff then
		self.updateForLogoff (_history);
	endif;
end;</source>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
    <JadeMethod name="updateForMoveHistory" id="f5bd33ac-17c8-41c0-9f37-bb68fb6ed83d">
        <updating/>
        <source>updateForMoveHistory(_history :CM_MachineMoveHistory)updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:Integer;
begin
	type := _history.type;
	
	if type = CM_MachineHistory.Type_RejectMove then
		self.updateForReject (_history);
	elseif type = CM_MachineHistory.Type_Move then
		self.updateForSetdown (_history);
	elseif type = CM_MachineHistory.Type_PickUp then
		self.updateForPickup (_history);
	elseif type = CM_MachineHistory.Type_SetDown then
		self.updateForSetdown (_history);
	endif;
epilog

end;</source>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
    </JadeMethod>
