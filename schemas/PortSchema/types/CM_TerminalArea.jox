    <JadeMethod name="getTiById" id="8bbcef1c-5631-4711-b8f9-f6aec006c3f6">
        <source>getTiById(_tiId : String) : CM_TrackedItem;
/*
Purpose:			 // 35091
Date		Who		Reason
03 Nov 2014	cnwab1	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

	lc		  : CM_LocationsController;
	ti 		  : CM_TrackedItem;
	reverseId : String;
begin

	reverseId := _tiId.reverse;
	
	foreach lc in self.allLocationsControllers discreteLock do
		foreach ti in lc.allTrackedItems discreteLock do
			if ti.id.startsWith(_tiId) or ti.idReversed.startsWith(reverseId) then	//08.01.2026 navma1 #MTN-36897
				return ti;
			endif;
		
		endforeach;
	endforeach;
	

	return null;
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getXMLForTerminalAreaLayout" id="16b1c27e-315f-443d-90d7-4c19f5d448a2">
        <source>getXMLForTerminalAreaLayout() : String;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theHeader, theDocument : String;
	theFooter : String;
	theGraphic : CM_Graphic;
	thePoints : PointArray;
	theColour : Integer;
	theXML, tmpString, theColourHex : String;
	aPoint : Point;
	anObject : Object;
begin
	theGraphic := self.myLayoutGraphic;
	if theGraphic = null then
		return null;
	endif;
	thePoints := theGraphic.pointsPolygon;
	if thePoints.isEmpty then
		return null;
	endif;
	
	theColour := theGraphic.CM_LayoutGraphic.drawLineColour;
	
	theXML := theXML &amp; "&lt;TA&gt;&lt;id&gt;" &amp; self.id.trimBlanks &amp; "&lt;/id&gt;";

	theXML := theXML &amp; "&lt;lb&gt;" &amp; theGraphic.label &amp; "&lt;/lb&gt;&lt;lc&gt;" &amp; theGraphic.lineColour.String &amp; "&lt;/lc&gt;&lt;tp&gt;" &amp;  theGraphic.CM_LayoutGraphic.type.String 
			&amp; "&lt;/tp&gt;&lt;cl&gt;" &amp; theColour.String &amp; "&lt;/cl&gt;&lt;hfo&gt;" &amp; self.hideFromOverView.Integer.String &amp; "&lt;/hfo&gt;";

	
	tmpString := null;
	foreach aPoint in thePoints do
		tmpString := tmpString &amp; aPoint.x.String &amp; ",";
		tmpString := tmpString &amp; aPoint.y.String &amp; ",";
	endforeach;
	tmpString := tmpString[1:tmpString.length - 1];
	
	theXML := theXML &amp; "&lt;Points&gt;" &amp; tmpString &amp; "&lt;/Points&gt;" ; 
/*
	foreach anObject in 	theGraphic.CM_LayoutGraphic.allLocationPointPolygons do
		if anObject = null then
			continue;
		endif;
		if not anObject.isKindOf(PointArray) then
			continue;
		endif;
		
		thePoints := anObject.PointArray;
		tmpString := null;
		foreach aPoint in thePoints do
			tmpString := tmpString &amp; aPoint.x.String &amp; ",";
			tmpString := tmpString &amp; aPoint.y.String &amp; ",";
		endforeach;
		tmpString := tmpString[1:tmpString.length - 1];
		
		theXML := theXML &amp; "&lt;LocPoints&gt;" &amp; tmpString &amp; "&lt;/LocPoints&gt;" ; 
	
	endforeach;
*/	
	theXML := theXML &amp; "&lt;/TA&gt;";
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
