epilog

end;</source>
        <Parameter name="_agent" type="CM_EDIControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeDeleted" id="2cd51e35-68f8-4777-8663-d1b5e6d9f944">
        <source>canBeDeleted(_purgeDate :Date): Boolean;
//----------------------------------------------------------------
//	Created:	03 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/08/2012	cnwcs5	par 30136 - use processDateTime (if there is one) otherwise createdTime to determine when to delete 
vars
	compareDate	:Date;
begin
	// OK to delete if we were created before the default purge date
	compareDate := self.processDateTime.date;
	
	if compareDate = null then
		compareDate := self.createdTime.date;
	endif;
	
	if compareDate &lt; _purgeDate then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_purgeDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
