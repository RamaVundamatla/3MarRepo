    <JadeMethod name="setControlsForAddEdit" id="a6da91da-db4d-4a6a-8205-4dd657b66851">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2009	cnwndl1	Initial creation
06/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	theForm.initTblInput(theForm.tblInput1, theForm.tblInput1.myEntTableDef.name);				// PAR #31155
	theForm.loadMeasurementTypes(	theForm.tblInput1,											// PAR #31155
								theForm.tblInput1.myEntTableDef.name,							// PAR #31155
								theForm.tblInput1.myEntTableDef.allEntTableRows,				// PAR #31155
								theForm.mode.isOneOf(theForm.Mode_Add, theForm.Mode_Update)	);	// PAR #31155
									
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_TrackClearance);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;

	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="5fb5057d-8817-4536-ac03-8e872bd129bc">
        <updating/>
        <source>setCtrlsForView() updating;
/*
Purpose:			

