    <JadeMethod name="getJsonForInspection" id="6a622ad5-7a7b-4ed6-a1be-61e22213bd8e">
        <source>getJsonForInspection():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2023	navsp1	Initial creation TFS ChangeRequest 57207: EUP - Refactor Inspection App API Message

*/


vars
	jsonHelper : JadeJson;	
	fullJsonString : String;	
begin
	create jsonHelper transient;	
	
	// Any exceptions generated by this will bubble up to the top CAMS handlers
	return jsonHelper.generateJson(self, JadeJson.Format_Json_Microsoft);	// Let the transform dll take care of the Microsoft Date formats. JADE2022 can generate them natively, but not 2020 :(
	
epilog
	delete jsonHelper;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
