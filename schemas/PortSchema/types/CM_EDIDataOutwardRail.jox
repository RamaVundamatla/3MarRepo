    <JadeMethod name="getTIProperties" id="21cb3a27-1ff6-4792-8284-262401f6db28">
        <source>getTIProperties(_propArray: ObjectArray io);
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
vars
	popColl: PropertyNDict;
	property: Property;
begin
	inheritMethod(_propArray);
	popColl := CM_EDIOutwardRailTI.getProperties;
	foreach property in popColl do
		_propArray.add(property);
	endforeach;

end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setData" id="816dba68-214b-4c76-8145-82d87b5aba5e">
        <updating/>
        <source>setData() updating;
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTIsArray : ObjectArray;
	ediTI		: CM_EDIOutwardRailTI;
	obj			: Object;
	dummy		: Integer;
begin

	create ediTIsArray transient;
	CM_EDIOutwardRailTI.allInstances(ediTIsArray, 0, false);
	foreach obj in ediTIsArray do
		ediTI := obj.CM_EDIOutwardRailTI;
		if (not self.allEDITrackedItems.includesKey(ediTI.id)) then
			//self.ediTrackedItems.add(ediTI);
			ediTI.setMyEDIData(self);
		endif;
	endforeach;
	
epilog
	delete ediTIsArray;
end;</source>
    </JadeMethod>
