    <JadeMethod name="create" id="e48daf82-92dd-4cda-868f-9dbacd22636f">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_Berth;
	self.permissionView	 := PmHMSBerthView;
	self.permissionMaint := PmHMSBerthMaint;
	self.myDataClass := HMS_Berth;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="638bce5e-1cf5-42d6-af38-ce1303e66e95">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	oldMinDraft	: Decimal[5,1];
	newMinDraft	: Decimal[5,1];
	pxyBerth	: HMS_Berth;
	theForm 	: SOP_HMS_TableMaintForm;
	conflictManager : CMIF_HMS_ConflictsManager;
	
begin
  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Berth transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyBerth := theForm.myProxyObject.HMS_Berth;
	theForm.tblInput1.setObjectFromTable(pxyBerth, "setObjectFromTableSpecial", false);
	pxyBerth.setProxy(theForm.myHarbour, 
			app.cargoOperationStringToEnum(theForm.tblInput1.getValueByNameIfVisible(ETRow_DefaultCargoOperationStr).String));

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateBerth(pxyBerth, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyBerth, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	if theForm.mode = theForm.Mode_Update
	and	oldMinDraft &lt;&gt; newMinDraft
	then
		create conflictManager transient; //gets deleted when the form is unloaded
		
		if conflictManager.myHarbour = null then
			conflictManager.myHarbour := theForm.myHarbour;
		endif;		
		
		conflictManager.allValidationTypes.add(ValidateBerthDepths);
		conflictManager.runConflictReport();
		
		if (not conflictManager.allCMIFConflicts.isEmpty) then
			if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then		
				theForm.myAssistant.showConflictsReport(conflictManager, null, theForm.myHarbour);
			else
				delete conflictManager;			
			endif;
		else
			delete conflictManager;
		endif;
	endif;
	
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="cfb4f4de-63f2-4236-b47e-5d9990942e10">
        <source>getCollection(): Collection;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	
	if self.myForm.SOP_HMS_TableMaintForm.myHarbour &lt;&gt; null then
		return self.myForm.SOP_HMS_TableMaintForm.myHarbour.allBerths;
	endif;
	return null;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getDefNameTblInput" id="53696b21-e984-4289-98a9-cd277b090c50">
        <source>getDefNameTblInput(): String protected;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return ETDef_HMSBerth;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="5decb0b6-2675-4ea9-a278-8fcfa8564f92">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _berth: HMS_Berth input; _tbl: CM_EntryTable input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2018	jlgndl1	Initial creation	TFS 38587
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
*/

vars

begin

	if _attrName = ETRow_ExternalRef1 then
		_berth.setExternalReference1( _strValue );
		return true;
		
	elseif _attrName = ETRow_ExternalRef2 then
		_berth.setExternalReference2( _strValue );
		return true;

	elseif _attrName = ETRow_ExternalRef3 then
		_berth.setExternalReference3( _strValue );
		return true;
	
	elseif _attrName = ETRow_ExternalRef4 then
		_berth.setExternalReference4( _strValue );
		return true;
		
	elseif _attrName = ETRow_TugBaseToBase then	//13 Nov 2018	NDL	TFS 41964
		_berth.setBaseToBaseTugDuration( _strValue.Integer );
		return true;
		
	endif;
		
	return false;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_berth" type="HMS_Berth" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="2f2b227d-ca6e-40d6-8352-85f93e250dd5">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
*/

vars

	berth : HMS_Berth;

begin

	berth := _obj.HMS_Berth;
	if _attrName = ETRow_ExternalRef1 then
		_tbl.setValue( _row, berth.externalReference1 );	
		return true;
		
	elseif _attrName = ETRow_ExternalRef2 then
		_tbl.setValue( _row, berth.externalReference2 );	
		return true;
		
	elseif _attrName = ETRow_ExternalRef3 then
		_tbl.setValue( _row, berth.externalReference3 );	
		return true;
	
	elseif _attrName = ETRow_ExternalRef4 then
		_tbl.setValue( _row, berth.externalReference4 );	
		return true;
		
	elseif _attrName = ETRow_TugBaseToBase then	//13 Nov 2018	NDL	TFS 41964
		_tbl.setValue( _row, berth.baseToBaseTugDuration );	
		return true;
		
	endif;
	
	return inheritMethod(_tbl, _attrName, _row, _obj);

epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="3f59cdfb-8cc0-4cb5-9b30-f8461939c012">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	str		: String;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.useProxyObject := true;
	inheritMethod();
	theForm.setTblDataEntRows(ETDef_HMSBerth);		//cnwdb2 - 17 April 2014 - PAR 33977
	
	theForm.myAssistant.comboBoxHMSWharf(theForm.cmbMyWharf, theForm.myHarbour, null);
	theForm.tblInput1.disableRowByName(ETRow_EndPosition);
	
	//cnwdb2 - 17 April 2014 - PAR 33977
	/*
	if app.isVoyageCommodityPlanning then
		str := Tab &amp; app.cargoOperationEnumToString(HMS_Movement.CargoOperation_Discharge, true) &amp; Tab &amp;
			app.cargoOperationEnumToString(HMS_Movement.CargoOperation_Load, true);
		
		theForm.tblInput1.setComboValuesByName(ETRow_DefaultCargoOperationStr, str);
		
	else
		theForm.tblInput1.hideRowByName(ETRow_DefaultCargoOperationStr, false);
	endif;
	*/

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="6169264c-9c89-4c1b-8356-eaf423d8cd0d">
        <updating/>
        <source>showThumbnail(pObj: HMS_Berth) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------------------
vars

	theForm : SOP_HMS_TableMaintForm;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, 'setTableFromObjectSpecial');
	theForm.myAssistant.comboBoxHMSWharf(theForm.cmbMyWharf, pObj.getHarbourReal(), pObj.myWharf);
	theForm.cmbMyWharf.lostFocus(theForm.cmbMyWharf);
	theForm.myAssistant.comboBoxHMSPaymentType(theForm.cmbPaymentType, pObj.paymentType);		// 25/6/18 MAP TFS39250
	theForm.cmbPaymentType.lostFocus(theForm.cmbPaymentType);
	
	theForm.tblInput1.setValueByName(ETRow_EndPosition, pObj.getDisplayStringForAttribute(ETRow_EndPosition, true).Integer);
end;</source>
        <Parameter name="pObj" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="9a9ca9dc-9471-4dfd-8450-eacee6451893">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	03 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpBerth : HMS_Berth;
	cell     : JadeTableCell;
begin

	tmpBerth := _obj.HMS_Berth;
	if(_idxRow &lt;&gt; 1) then
		if self.colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := tmpBerth.colour;
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
