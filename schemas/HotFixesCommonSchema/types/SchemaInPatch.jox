    <JadeMethod name="createMyClass" id="b0a14a03-5353-4827-a0ae-46684c608379">
        <source>createMyClass( _className: String; _extractWholeClass: Boolean );

vars
	clss	: ClassInSchema;

begin
	
	beginTransaction;
	create clss;
	clss.setForCreate( _className, _extractWholeClass, false, self );
	commitTransaction;

end;
</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_extractWholeClass" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractFileFromServer" id="49477814-528d-42b4-bbc4-5bbb16c49c3c">
        <source>extractFileFromServer( _fileName : String ) : Boolean;
/*--------------------------------------------------------------------
Created:	15 April 2007 By cnwvu1
Purpose:	Purpose - to get file from server
Parameters	_fileName - file name without patch
----------------------------------------------------------------------
*/
vars
	file			: File;
	fileBin			: Binary;
	
begin
	create file transient;

	file.fileName := app.getJadeInstallDir() &amp;'\'&amp; _fileName;
	
	if file.isAvailable() then
		return true;
	endif;

	// ------------------ getting file from server -----------------------

	fileBin := app.getFileBinaryFromServerBin(_fileName);
	
	if fileBin = null or fileBin.length &lt; 10 then
		app.msgBox( file.fileName &amp; ' - utility not found - contact developer.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
//		app.raiseUnexpectedProgramError(class.name, method.name, ' conversion utility not found - contact developer.');
		return false;
	endif;
	
	file.kind := File.Kind_Binary;
	file.mode := File.Mode_Output;
	file.open();
	file.writeBinary(fileBin.uncompressToBinary());
	file.close();
	
	app.writeLogMessage(class.name &amp; '&gt;&gt;' &amp; method.name &amp;' - '&amp; file.fileName &amp; ' - copied from server.');
	return true;
epilog
	if file &lt;&gt; null then
		delete file;
	endif;
end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractFilesDllFromServer" id="df7a7a84-57a6-4d4f-8fbd-34db85ea62fd">
        <source>extractFilesDllFromServer() : Boolean;
/*--------------------------------------------------------------------
Created:	15 April 2007 By cnwvu1
Purpose:	Purpose - to get all dll's from server if they don't exists
Parameters	
----------------------------------------------------------------------
*/
vars

begin

	if not self.extractFileFromServer( 'jadloadb.exe' ) then
		return false;
	endif;
	if not self.extractFileFromServer( 'jadloadb.pdb' ) then
		return false;
	endif;

	if not self.extractFileFromServer( 'jadclient.exe' ) then
		return false;
	endif;
	if not self.extractFileFromServer( 'jadclient.pdb' ) then
		return false;
	endif;

/*	we cannot replace these dll because they are in use
	if not extractFileFromServer( 'jomjdi.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomjdi.pdb' ) then
		return false;
	endif;

	if not extractFileFromServer( 'jomos.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomos.pdb' ) then
		return false;
	endif;

	if not extractFileFromServer( 'jomutil.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomutil.pdb' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomutil.tds' ) then
		return false;
	endif;
	
	if not extractFileFromServer( 'jom.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jom.pdb' ) then
		return false;
	endif;
	
	if not extractFileFromServer( 'jomobj.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomobj.pdb' ) then
		return false;
	endif;
	
	if not extractFileFromServer( 'jomsrvr.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomsrvr.pdb' ) then
		return false;
	endif;
	
	if not extractFileFromServer( 'jomnadm.dll' ) then	
		return false;
	endif;
	if not extractFileFromServer( 'jomnadm.pdb' ) then	
		return false;
	endif;
	
	if not extractFileFromServer( 'jomprx.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomprx.pdb' ) then
		return false;
	endif;
	
	if not extractFileFromServer( 'jommdb.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jommdb.pdb' ) then
		return false;
	endif;
	
	if not extractFileFromServer( 'jomnfyq.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomnfyq.pdb' ) then
		return false;
	endif;

	if not extractFileFromServer( 'jomrpc.dll' ) then
		return false;
	endif;
	if not extractFileFromServer( 'jomrpc.pdb' ) then
		return false;
	endif;
*/	
	return true;

end;
</source>
