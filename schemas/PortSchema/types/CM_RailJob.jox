    <JadeMethod name="isJobTypeMatching" id="de5a510b-79ea-49d5-a140-f05504ca8476">
        <source>isJobTypeMatching(_jobType : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023	navhl20	Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria

*/

