	self.txtScanTxt.text := self.lblScanTxt.caption.toUpper;
	
	self.setupInYard();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickInYardItem" id="d0ef2fcb-e647-4db5-834b-d8e94f4de230">
        <updating/>
        <source>clickInYardItem(obj : Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Changes

Date		Name	TFS#			Description
============================================================================
04 Feb 2010	cnwndl1	CCMS MES 1005	Initial creation	
27 Jun 2019	jlgka1	TFS 45162		STWO - CRO Management - Handheld Device.
26 Jul 2019 jlgka1 	TFS 45830		STWO - Partial Release for Break Bulk.
============================================================================*/

vars
	ti 			   	: CM_TrackedItem;
	bol	 		   	: CM_BOL;
	wle 		   	: CM_WorkListEntry;
	selectedWle    	: CM_WorkListEntry;
	checksSubCargo 	: CM_TrackedItem;
	errMsg 			: String;
	density	 		: Decimal [16,4];
	deliveryRequest : CM_DeliveryRequest;
	bulkRelease 	: CM_BulkRelease;	
	loadedTi 		: CM_TrackedItem;
	childTi 		: CM_TrackedItem; 
begin

	if obj = null then
		// searching for one
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		//app.myMobileCargoFindAgent.setSearchSite(TI_SITE_UNDEFINED);	//11 Oct 2010	NDL	Par 25836
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);	//17 Jul 2015	NDL	Par 36480
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	elseif CM_Vehicle.hasInstance( obj ) then// 04 Nov 2013	- GTL CCMS 2257 / Par 30819
		//doing a swap of cargo between trucks
		self.gotoForm( MOB_HHTruckSwapCargo, false );
		return;
		
		
	elseif CM_DeliveryRequest.hasInstance( obj ) then	//01 Jun 2010	NDL	Par 23903
		deliveryRequest:=obj.CM_DeliveryRequest;
		// searching for one
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		app.myMobileCargoFindAgent.clearHistory(true);
		app.myMobileCargoFindAgent.setMyDeliveryRequest( deliveryRequest );
		// Find an uncompleted wle and use the quantity remaining    PAR 34296  DJW 10 Jun 2014
		wle := deliveryRequest.getFirstIncompleteWLE();
		if wle &lt;&gt; null then
			self.myMobileGenericAgent.setStringField1( wle.quantity.String );	 
		else		
			self.myMobileGenericAgent.setStringField1( deliveryRequest.totalRequested.String );	 //epr par 32408 6/9/13
		endif;
		if  deliveryRequest.myCargoType &lt;&gt; null and ( deliveryRequest.myCargoType.isBulkByWeight or deliveryRequest.myCargoType.isBulkByVolume ) then
			self.myMobileGenericAgent.setDecimalField1( deliveryRequest.getRemainingWeightRequested() );
		else
			self.myMobileGenericAgent.setDecimalField1( 0.00 );
		endif;
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_UNDEFINED);	//11 Oct 2010	NDL	Par 25836
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	elseif CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
		
	elseif CM_BOL.hasInstance( obj ) then
		bol := obj.CM_BOL;
		
	endif;
	
	if ti &lt;&gt; null then
		if not self.doInterTerminalCheck(ti) then
			return;
		endif;
	endif;
	
	if ti &lt;&gt; null then
		//jlgka1 TFS 45162 --&gt;
		if not self.myMobileGenericAgent.validateReserveTI(ti.allBulkReleasesAssigned.last, ti, false, null, null) then // jlgka1 TFS 45830
			return;
		endif;
		//jlgka1 TFS 45162 &lt;--
		
		//25 Sep 2013	NDL	Par 32557
		if ti.isKindOf( CM_TILC ) then
			if self.myMobileGenericAgent.isWaitingOnRequiredChecks( CARGO_CHECK_CONTEXT_TRUKLOAD, ti, checksSubCargo ) &lt;&gt; null then
				if checksSubCargo &lt;&gt; null then
					//Unable to %1 '%2' until cargo checks for '%3' have been performed, or %4 has been unloaded from '%5'
					errMsg := app.getErrorString5(Chassis_Subcargo_checks, app.getErrorString(Load), ti.id, checksSubCargo.id, checksSubCargo.id, ti.id);
					self.msgBox(errMsg, app.getErrorString(Warning), MsgBox_OK_Only, false);
					return;
				endif;
			endif;
		endif;
	
		//Par 32337 - Attempt to pre-set the quantity based on a Wle that we might have....
		self.myMobileGenericAgent.setStringField1( null );
		self.myMobileGenericAgent.setDecimalField1(0.00);
		if ti.canSplitTotalQuantity then
			foreach wle in ti.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.job = null or not wle.job.isRoadJob then
					continue;
				endif;
				//10 Sep 2013	NDL	Par 32172
				if self.myMobileGenericAgent.myTruck &lt;&gt; wle.job.CM_RoadJob.myVehicle then
					continue;
				endif;
				selectedWle := wle;
				break;
			endforeach;
			if selectedWle &lt;&gt; null then
				if selectedWle.quantity &gt; 0 then
					self.myMobileGenericAgent.setStringField1( selectedWle.quantity.String );
				endif;
				if selectedWle.weight &gt; 0 then
					self.myMobileGenericAgent.setDecimalField1(  selectedWle.weight );
				endif;
			endif;
		endif;	
		
		// 09 Jan 2016	NDL	- TFS 3167 need to check if we are dealing with a TI only found via 'Any Id' WLE, and if so populate the wle.
		if selectedWle = null then
			self.myMobileGenericAgent.setMyWle(null);
			foreach wle in self.myMobileGenericAgent.allWlesToLoad do
				if wle.myRequest = null or not wle.myRequest.isAnyId() then
					continue;
				else
					deliveryRequest := wle.myRequest.CM_DeliveryRequest; // its always a delivery request if its an Any Id
					bulkRelease := deliveryRequest.myOriginatingBulkRelease;
					if bulkRelease = null then
						continue;
					endif;
					if bulkRelease.allTrackedItemsAssigned.includes( ti ) then
						self.myMobileGenericAgent.setMyWle(wle);
						break;
					endif;
				endif;
			endforeach;
		endif;
		
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		//self.myHandHeldCheckerAgent.setChecksState(MOB_HandHeldCheckerAgent.GateRelease);
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckLoad);//28 May 2010	NDL	Par 23698
		self.gotoForm( MOB_HHTruckLoaderCargo, false );
		return;

//	elseif bol &lt;&gt; null then

//		self.myHandHeldCheckerAgent.setMyBol(bol);
//		self.myHandHeldCheckerAgent.setState(MOB_HandHeldCheckerAgent.LoadCargo);
//		self.gotoForm( MOB_HHTruckLoaderBOLCargo, false );
//		return;
	
	endif;

epilog
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="clickOnTruckItem" id="13410ab5-d8c6-4c2b-bff5-409166ca0b6e">
        <updating/>
        <source>clickOnTruckItem(obj : Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	ti : CM_TrackedItem;
	loadedWle : CM_WorkListEntry;
	delRequest : CM_DeliveryRequest;

begin

	if CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
	endif;
	
	self.myMobileGenericAgent.setMyNextTiToAction(ti);
	//self.myHandHeldCheckerAgent.setChecksState(MOB_HandHeldCheckerAgent.GateReceipt);
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckUnload);//28 May 2010	NDL	Par 23698
	
	//15 Nov 2010	NDL	Par 26055 - This has been loaded against a delivery request and
	//								is going to be unloaded again...
	loadedWle := self.myMobileGenericAgent.getLoadedWleFor(ti);
	if loadedWle &lt;&gt; null and loadedWle.myRequest &lt;&gt; null and loadedWle.status = WLE_COMPLETED then
		if loadedWle.myRequest.isKindOf(CM_DeliveryRequest) and CM_DeliveryRequest.hasInstance(loadedWle.myRequest) then
			delRequest := loadedWle.myRequest.CM_DeliveryRequest;
		endif;
		if delRequest &lt;&gt; null then
			self.myMobileGenericAgent.setDoingReversal( true );
		endif;
	endif;
	
	self.gotoForm( MOB_HHTruckUnloaderCargo, false );

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doConfirmComplete" id="6a8c7020-a9c0-466f-93ee-9e8fd31f7f9b">
        <source>doConfirmComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2017	cnwma1	Initial creation TFS 3933:STWO - Vehicle Lander - Process Button and Truck Loader Complete Button

*/

vars
	requireConfirmComplete :Boolean;
begin

	//18/05/2017 cnwma1	 TF #3933
	requireConfirmComplete  := app.myPassport.myTerminal.getConfig(HhTruckLoadConfComplete).Boolean;
	if requireConfirmComplete then
		if self.msgBox(app.getErrorString(AreYouSureComplete),app.getErrorString(Complete)&amp;'?' , MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInterTerminalCheck" id="ad8d2256-7ff4-4315-8942-4bb1d681d5c6">
        <source>doInterTerminalCheck(ti: CM_TrackedItem): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

begin
	// re-implemented further down...
	return true;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="99fb026f-6306-4ce5-8de8-b512849a0425">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604
21 Nov 2018		jlgrh7 TFS #41535  AAT - Truck loader in Jade Desktop
*/

vars

	top : Real;
	height : Real;
	singleWidth : Integer;
	left : Real;
	width : Real;
	buttonWidth : Real;
	index : Integer;
	menuButton : MOB_Button;
	tabIndex : Integer;
	filtBtnWidth : Real;

begin
	
	self.setResizeableMarginAndFontSize();
	inheritMethod(_initialSetup);
	
	tabIndex := 4000;
	
	//26 May 2016	NDL	TFS 1593
	if self.allowDirectScan &gt; 0 then	//16 Dec 2016	NDL	TFS 3129
		if _initialSetup then
			self.btnFilter.visible := false;
			self.btnFiltClear.visible := false;
			self.txtScanTxt.visible := true;
			self.txtScanTxt.parent := self.shtInYard;
			self.txtScanTxt.setAndIncrementTabIndex( tabIndex );
			if self.allowDirectScan &gt; 1 then
				self.btnFilter.visible := true;
				self.btnFilter.parent := self.shtInYard;
				self.btnFilter.setAndIncrementTabIndex( tabIndex );
				self.btnFiltClear.visible := true;
				self.btnFiltClear.parent := self.shtInYard;
				self.btnFiltClear.setAndIncrementTabIndex( tabIndex );
			endif;
		endif;
		top := 1;
		left := 1;
		if self.allowDirectScan &gt; 1 then
			if (self.btnOne.width * 3) + (self.resizedMargin * 2) &gt; self.shtInYard.width then
				filtBtnWidth := (( self.shtInYard.width - (self.resizedMargin * 2) - 2 ) / 3 );
			else
				filtBtnWidth := self.btnOne.width;
			endif;
			width := self.shtInYard.width - (filtBtnWidth * 2 ) - ( self.resizedMargin * 2 )- 2;
		else
			width := self.shtInYard.width - 2;
		endif;
		height := self.getStdControlHeight;
		self.txtScanTxt.move(	left,
								top,
								width,
								height );
								
		if self.allowDirectScan &gt; 1 then
		
			left := self.txtScanTxt.left + self.txtScanTxt.width + self.resizedMargin;
			width := filtBtnWidth;
			self.btnFilter.move(	left,
									top,
									width,
									height );
									
			left := self.btnFilter.left + self.btnFilter.width + self.resizedMargin;
			self.btnFiltClear.move(	left,
									top,
									width,
									height );
		endif;
		
		top := height + self.resizedMargin;
		left := self.frmCargoInYard.left;
		width := self.frmCargoInYard.width;
		height := self.frmCargoInYard.height - top;
		self.frmCargoInYard.move(	left,
									top,
									width,
									height );
	else
		self.txtScanTxt.visible := false;
		self.btnFilter.visible := false;
		self.btnFiltClear.visible := false;
	endif;
	
	top := self.fldCargo.top + self.fldCargo.height + self.resizedMargin;
	height := self.getStdControlHeight;
	singleWidth := (( self.fldCargo.width - 2 ) / 3 ).Integer;
	left := self.resizedMargin;

	if _initialSetup then
		self.lblWeightValue.visible := true;
	endif;
	self.lblWeightValue.move(	left,
								top,
								singleWidth * 2,
								height );
								
	left := left + lblWeightValue.width + self.resizedMargin;
	if _initialSetup then
		self.lblCountValue.visible := true;
	endif;
	self.lblCountValue.move(	left,
								top,
								singleWidth,
								height );
								
	self.scrCargoInYard.height := self.frmCargoInYard.height -self.txtScanTxt.height+resizedMargin*4;					//+TFS41535 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReturnFromSearch" id="2612d8c2-3ff3-440f-a970-9cec85d8e6c6">
        <updating/>
        <source>doReturnFromSearch(): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	foundTi : CM_TrackedItem;
	delRequest : CM_DeliveryRequest;
	msg : String;
begin

	if app.myMobileCargoFindAgent &lt;&gt; null then
		foundTi := app.myMobileCargoFindAgent.myTrackedItemToProcess;
		delRequest := app.myMobileCargoFindAgent.myDeliveryRequest;	//01 Jun 2010	NDL	Par 23903

		app.myMobileCargoFindAgent.clearHistory(true);
		if foundTi &lt;&gt; null then
			// we have come back to this form having done a search and found an item that we want to load
			// See "clickInYardItem" method, so deal to it now.
			
			//27 Oct 2011	NDL	Par 28198
			if delRequest = null then
				// user used the "Find More Cargo..." button.
				if not foundTi.allBulkReleasesAssigned.isEmpty then
					msg := app.getErrorString3( Assigned_not_avail_via_More, foundTi.id, foundTi.allBulkReleasesAssigned.first.code, app.getErrorString( Find_more_cargo ) );
					self.msgBox(msg ,app.getErrorString(Error), MsgBox_OK_Only, true);
					return false;
				endif;
			endif;
			
			self.myMobileGenericAgent.setMyNextTiToAction(foundTi);
			self.myMobileGenericAgent.setMyDeliveryRequest(delRequest);	//01 Jun 2010	NDL	Par 23903
			//self.myHandHeldCheckerAgent.setChecksState(MOB_HandHeldCheckerAgent.GateRelease);
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckLoad);//28 May 2010	NDL	Par 23698
			self.gotoForm( MOB_HHTruckLoaderCargo, false );
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getButtonStrForTi" id="f98b8de0-ebcc-4ed7-a51f-0aefee01953d">
        <source>getButtonStrForTi( _ti : CM_TrackedItem; _wle : CM_WorkListEntry; _delReq : CM_DeliveryRequest  ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2017	jlgndl1	Initial creation	TFS 5408

*/

vars

	desc1 : String;
	desc2 : String;
	qty : Integer;
	
	density : Decimal [16,4];
	weightRequested : Decimal [16,4];
	
	bolOrCargoType : String;
	locStr : String;
	
	btnString : String;

begin

	if _ti &lt;&gt; null then

		_ti.getShortDescriptions( desc1, desc2 );
		
		if _ti.canSplitTotalQuantity and _ti.isBulkByQuantity then
			qty := _ti.totalQuantity;	
			if _wle &lt;&gt; null then
				qty := _wle.quantity;
			endif;
		endif;
		
		if self.includeBolNumber then
			bolOrCargoType := _ti.billOfLading.trimBlanks;
		endif;
		
		if bolOrCargoType = null then
			bolOrCargoType := _ti.cargoTypeDescr;
		endif;
		
		if  _ti.myPrimaryActualLocation &lt;&gt; null then
			locStr := _ti.myPrimaryActualLocation.getFullId &amp; " ";
		endif;
				
		if qty &gt; 0 then
			btnString := bolOrCargoType &amp; " - " &amp; _ti.id &amp; "(" &amp; qty.String &amp; ")" &amp; CrLf &amp; locStr &amp; desc2; 
		else
			btnString := bolOrCargoType &amp; " - " &amp; _ti.id &amp; CrLf &amp; locStr &amp; desc2;
		endif;
		
	
	elseif _delReq &lt;&gt; null then
	
		if _delReq.myCargoType = null then
			btnString := app.getErrorString(Various);
		else
			btnString := _delReq.myCargoType.description;
		endif;
		
		if _delReq.myCargoType &lt;&gt; null and ( _delReq.myCargoType.isBulkByWeight or _delReq.myCargoType.isBulkByVolume ) and _delReq.weightRequested &gt; 0 then
			if _delReq.myCargoType.isBulkByVolume then
				if _delReq.mySubCargoType &lt;&gt; null then
					density := _delReq.mySubCargoType.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
				elseif _delReq.myCargoType.mySystemProductType &lt;&gt; null then
					density := _delReq.myCargoType.mySystemProductType.getDensityValue;
				endif;
			endif;
			weightRequested := _delReq.getRemainingWeightRequested();	
			btnString := btnString  &amp; " x " &amp; _delReq.myCargoType.getBulkTrackByDisplayForWeight( weightRequested, density, true);
		elseif _delReq.totalRequested &gt; 0 then
			btnString := btnString  &amp; " (x" &amp; _delReq.totalRequested.String &amp; ")";
		elseif _delReq.totalRequested = 0 then
			btnString := btnString  &amp; " x ??";
		endif;
		btnString := btnString  &amp; " - " &amp; _delReq.operatorCode;
		if _delReq.billOfLading &lt;&gt; null then
			btnString := btnString &amp; " - " &amp; _delReq.billOfLading;
		endif;
		if _delReq.myOriginatingBulkRelease &lt;&gt; null then	
			btnString := btnString &amp; CrLf &amp; _delReq.myOriginatingBulkRelease.code;
		endif;
		
		
	endif;
	
	return btnString;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_delReq" type="CM_DeliveryRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
