	ti : CM_TrackedItem;

begin

	//02 Oct 2018	NDL	TFS 39186
	foreach ti in self.allCargoGroupsByIdDict do
		prod := ti.CM_CargoGroup.getCargoGroupCargoSubType();
		if prod = _subCargoType then
			return true;
		endif;
	endforeach;

	foreach notifiedCargoGroup in self.allNotifiedCargoGroupByIdDict do
		cg := notifiedCargoGroup.getMatchingCargoGroup();
		if cg = null then
