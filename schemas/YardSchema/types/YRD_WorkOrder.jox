    <JadeMethod name="loadTabVoyageWaterReq" id="9f4d3905-875d-4bf5-99ea-e1531c617d9c">
        <updating/>
        <source>loadTabVoyageWaterReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	harbour        : HMS_Harbour;				
	processHarbour : CM_ProcessHarbour;
	voyageProcess  : CM_VoyageProcess;
	woDtl		   : CM_WodWaterRequest;
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	woDtl := self.myPxyTask.CM_WodWaterRequest;
	
	self.shtWaterRequest.visible	:= true;
	self.fldVoyage.topSheet 		:= self.shtWaterRequest;
	self.lblWTransferType.visible 	:= false;	
	self.cmbWTransferType.visible 	:= false;	
	
	if self.cmbResourceType.visible then
		self.myAssistant.comboBoxHMSResourceType(self.cmbResourceType, null);
	endif;
	
	if woDtl.myHMSResourceType &lt;&gt; null then
		self.cmbResourceType.listIndex := self.cmbResourceType.findObject(woDtl.myHMSResourceType);
		self.cmbResourceType_click(self.cmbResourceType);
	endif;
	
	if woDtl.myHMSResource &lt;&gt; null then
		self.cmbResource.listIndex := self.cmbResource.findObject(woDtl.myHMSResource);
	endif;
	
	self.txtUnitsUsed.text := woDtl.unitsUsed.String;
	
	if woDtl.fromDateTime.isValid then
		self.txtFromDate.setDate(woDtl.fromDateTime.date);
		self.txtFromTime.setTime(woDtl.fromDateTime.time);
	endif;
	
	if woDtl.toDateTime.isValid then
		self.txtToDate.setDate(woDtl.toDateTime.date);
		self.txtToTime.setTime(woDtl.toDateTime.time);
	endif;
	
	self.cmbWTransferType.listCollection(app.myRoot.allVoyageJobTransferTypes, true, 0);
	self.cmbWTransferType.listIndex := self.cmbWTransferType.findObject(app.myRoot.allVoyageJobTransferTypes[woDtl.transferType]);
	
	if woDtl.isComplete then
		self.shtWaterRequest.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadToDoTaskDetails" id="0732ec90-df37-4c03-9487-a086f050eee6">
        <updating/>
        <source>loadToDoTaskDetails(_taskType : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars

begin
	self.clearSheets();
	self.clearMulToDoLists();

	if _taskType = WO_TASK_TODO then
		self.workOrderType := WorkOrderMode_Cargo;
		self.createPxyWorkOrder();
		self.loadTabCargoTis();
		self.loadTabToDoSpecialRate();
		return;
	endif;
	
	self.loadTabToDoDetails();
	self.loadTabToDoEntities();
	self.loadTabToDoSpecialRate();
	//self.buildTxtEntitiesList();								//08.02.2023 navma1 #56457 Task#56458
	self.updateEntitesRequestedRequired();
epilog

end;</source>
        <Parameter name="_taskType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadVoyageTaskDetails" id="203b1fe2-98b3-433d-a174-1296cb4f9989">
        <updating/>
        <source>loadVoyageTaskDetails(_taskType : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	self.fldVoyage.visible := true;
	
	self.clearSheets();
	
	self.displayVoyageCombo();
	
	if _taskType = WO_TASK_TIMECHANGE then
		self.loadTabVoyageTimeChange();
	elseif _taskType = WO_TASK_WATER then
		self.loadTabVoyageWaterReq();
	elseif _taskType = WO_TASK_EXTENSION then
		self.loadTabVoyageExtension();
	elseif _taskType = WO_TASK_HMSCANCEL then
		self.loadTabVoyageCancelReq();
	elseif _taskType = WO_TASK_BILLINGADJ then
		self.loadTabVoyageBillAdjust();
	elseif _taskType = WO_TASK_MARINEINITIAL then
		self.loadTabVoyageMarineInit();
	elseif _taskType = WO_TASK_NEWVOYAGE then 
		self.loadTabVoyageNewVoyageReq();
	elseif _taskType = WO_TASK_MARINEDEPART then 
		self.loadTabVoyageMarineDept();
	elseif _taskType = WO_TASK_PERMIT then 
		self.loadTabVoyagePermitReq();
	elseif _taskType = WO_TASK_SHIFTMOVEMENT then 
		self.loadTabVoyageShiftMovement();
	elseif _taskType = WO_TASK_CARGOREQUEST then
		self.loadTabVoyageCargoReq();
	endif;
end;</source>
        <Parameter name="_taskType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadWorkOrderDetails" id="da78b765-d0c1-41ed-9da8-03aea2a27211">
        <updating/>
        <source>loadWorkOrderDetails()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
23 Aug 2022 navma1	Bug 54297: MTN - Pack Work Order issues
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Apr 2023 navhl20 Bug 57458: EUP - Work Order Remarks
13 Oct 2023	navrv30	ChangeRequest 60458: EUP - Change Work Order Progress to be based on QTY or WT
*/

vars
	pxyWorkOrder : CM_WorkOrder;
	workOrder	 : CM_WorkOrder;
begin
	
	self.enableControlsForMode();
	
	if self.workOrderMode = self.MODE_ADD then
		self.createPxyWorkOrder();
		if self.workOrderType = WorkOrder_Type_ToDo then
			self.canMaintainTasks(WO_STATUS_PENDING);
		else
			self.canMaintainTasks(WO_STATUS_USERENTRY);
		endif;
	endif;
	
	/*
	Bulding Work Order Details 
	*/
	

	pxyWorkOrder				   := self.myPxyWorkOrder;
	workOrder					   := pxyWorkOrder.pxyGetRealObject();			//13.10.2023 navrv30 #60458
	
	if workOrder &lt;&gt; null then													//13.10.2023 navrv30 #60458
		self.lblProgress.caption 	   := app.getErrorString(WordProgress) &amp; " : " &amp; workOrder.getProgressString();       //13.10.2023 navrv30 #60458
	else 
		self.lblProgress.visible 	   := false;       																	  //13.10.2023 navrv30 #60458
	endif;
	self.txtWorkOrderId.text	   := pxyWorkOrder.id;
	
	self.txtJobRequiredByDT.text   := pxyWorkOrder.getRequiredByDateString();
	self.txtJobRequiredByTM.text   := pxyWorkOrder.getRequiredByTimeString();
	//self.txtAprovalExpDT.text      := pxyWorkOrder.getApprovalExpDateString();			//06.4.2023 navhl20	#57458
	//self.txtJobApprvalExpTM.text   := pxyWorkOrder.getApprovalExpTimeString();			//06.4.2023 navhl20	#57458

	self.txtRemarks.text 		   := pxyWorkOrder.remarks;
	self.txtReference.text		   := pxyWorkOrder.customerReference;
	self.txtTotalRequired.text	   := pxyWorkOrder.getTotalRequired.String;
	
	//self.txtTotalRequired.enabled  := not  self.isApproved;			//23.08.2022 navma1 #54297

	self.loadEmailController();
	self.buildCmbStatus();
	self.buildCmbOrganisation();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lstTasks_click" id="913be0a8-9e83-410f-89a2-a2a9ffd2fa6d">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTasks_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Apr 2022	navcs2	Initial creation
20.12.2022 	navcs2 	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
23 May 2024 navhl20 Bug 64258: MTN - Cargo work order takes significant time to click between tasks
*/

vars
	taskType	: Integer;
	wodDtl      : CM_WorkOrderDtl;
	topSheet    : Sheet;
begin
	
	if self.lstTasks.listObject = null then
		return;
	endif;
	
	wodDtl := self.lstTasks.listObject.CM_WorkOrderDtl;
	
	if wodDtl &lt;&gt; null then 
		
		self.zSetupToolbar();
		//checking if for saving the task when task count more than 1
		if self.lstTasks.listCount &gt; 1 then
			self.doSaveTask(); 
		endif; 
		
		taskType 		:= wodDtl.detailType;
		self.myPxyTask  := wodDtl;
		//topSheet 		:= self.fldCargo.topSheet;				//06.03.2023 navma1 #56457:[56458]
		
		if self.workOrderType = WorkOrderMode_Cargo then
			self.loadCargoTaskDetails(taskType);
			//self.loadTabCargoTis();							//08.02.2023 navma1  #56457:[56458]	//23.05.2024 navhl20 #64258
			self.updateCargoTabNumber();						//23.05.2024 navhl20 #64258
		elseif self.workOrderType = WorkOrderMode_Voyage then	// 20.12.2022 navcs2 #56840:[54265]
			self.loadVoyageTaskDetails(taskType);				// 20.12.2022 navcs2 #56840:[54265]
		else													// 20.12.2022 navcs2 #56840:[54265]
			self.loadToDoTaskDetails(taskType);					// 20.12.2022 navcs2 #56840:[54265]
		endif;
		//self.fldCargo.topSheet := topSheet;					//06.03.2023 navma1 #56457:[56458]
	endif;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="maintainBtnAttachCargo" id="59766549-106b-42d8-9523-0976a67485d0">
        <source>maintainBtnAttachCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Mar 2023	navcs2	ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement
12 Apr 2023 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
20 Oct 2023	navsaa30 ChangeRequest 60819: EUP | Ship Operations in DD - [54176.010] - [Release] Attach cargo items for selected voyage
30 Oct 2023 navhl20 Bug 61022: EUP - 1086 Exception when adding a booking to the Rail Receive Jobs
03 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
01 Aug 2024 navhl20	Defect 65488: Attach Cargo From Booking Release button is not visible when trying to create a release cargo work order
*/

vars
	pxyTask				: CM_WorkOrderDtl;
	btnAttachCargo		: CMUI_Button;
	transModeCombo		: CMUI_ComboBox;
	release				: CM_BulkRelease;
	bol					: CM_BOL;
	booking				: CM_BookingRef;
	bookingItem			: CM_BookingRefItem;
	voyage				: CM_Voyage;
begin
	btnAttachCargo 	:= self.btnAttachCargo;
	pxyTask 		:= self.myPxyTask;
	transModeCombo 	:= self.cmbTransMode;

	btnAttachCargo.visible := false;
	btnAttachCargo.enabled := false;	
	
	release 		:= self.cmbReleaseRequest.getCurrentItemObject.CM_BulkRelease;
	bol 			:= self.cmbBol.getCurrentItemObject.CM_BOL;
	
	if pxyTask.isKindOf(CM_WodReceive) then
		booking := self.cmbBooking.getCurrentItemObject.CM_BookingRef;
		if transModeCombo.text = TI_TRANSMODE_SHIP_STR then
			btnAttachCargo.caption := self.StringAttachCargoBOL;
			if bol &lt;&gt; null
				and bol.allTrackedItems.isEmpty = false then
					btnAttachCargo.enabled := true;
			endif;
		else
			btnAttachCargo.caption := self.StringAttachCargoBooking;
			bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;
			if bookingItem &lt;&gt; null 
			   and bookingItem.allTIs.isNotEmpty then
					btnAttachCargo.enabled := true;
			elseif booking &lt;&gt; null
				and booking.allTIs.isEmpty = false
				and self.cmbBookingItem.listObject = null then
					btnAttachCargo.enabled := true;
			endif;
		endif;
	elseif pxyTask.isKindOf(CM_WodRelease) then
		booking := self.cmbBooking.getCurrentItemObject.CM_BookingRef;						//04.07.2023 navma1 #58952
		if transModeCombo.text = TI_TRANSMODE_SHIP_STR and self.optBtnBooking.value then
			btnAttachCargo.caption := self.StringAttachCargoBooking;
			bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;				//07.7.2023 navhl20 #58952
			if bookingItem &lt;&gt; null 															//07.7.2023 navhl20 #58952
			   and bookingItem.allTIs.isNotEmpty then
					btnAttachCargo.enabled := true;
			elseif booking &lt;&gt; null
				and booking.allTIs.isEmpty = false
				and self.cmbBookingItem.listObject = null then
					btnAttachCargo.enabled := true;
			else
				voyage 		:= self.cmbTransport.listObject.CM_Voyage;						//03.05.2024 navhl20 #63971
				if voyage &lt;&gt; null																			
				and (voyage.allNotifiedTIsByCargoTypeId.isNotEmpty or voyage.allOnsiteTIsByCargoTypeId.isNotEmpty) then
					btnAttachCargo.caption := self.StringAttachCargoVoyage;
					btnAttachCargo.enabled := true;
				endif;
			endif;
		else																				//20.10.2023 navsaa30 #60819
			//if transModeCombo.text = TI_TRANSMODE_SHIP_STR then							//01.08.2024 navhl20 #65488
				btnAttachCargo.caption := self.StringAttachCargoRel;
				if release &lt;&gt; null 
					and release.releaseByType = false
					and release.allTrackedItemsAssigned.isEmpty = false then
						btnAttachCargo.enabled := true;
				endif;								
			//endif;																		//01.08.2024 navhl20 #65488
		endif;
	endif;	
	btnAttachCargo.visible := btnAttachCargo.enabled;
	btnAttachCargo.enabled := not isApproved;				//12.4.2023 navhl20	#55443:[54991]
epilog

end;</source>
    </JadeMethod>
