		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1140O,,0.0000,,OOTL0307379,Remain On Board,2063,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1141O,,0.0000,,OOTL0307380,Remain On Board,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1304OR,,0.0000,,OOTL0307393,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,4000,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1901O,,0.0000,,OOTL0307390,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,4000,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2100O,,0.0000,,OOTL0307397,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,4000,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2101O,,0.0000,,OOTL0307398,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,4000,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2101O,,0.0000,,OOTL0307399,Export,4262,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,4000,,,,0.000,VOYSHIP30738_5,,,0.0000,,,");
		idx := 0;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
			idx := idx + 1;
//			write ediText;
			self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
		endforeach;

		self.deleteVoyage(VoyageName2);
		voyage := self.getVoyage(VoyageName2);
		self.assertIsDeleted(voyage);
		voyage := self.addVoyageWithConRORO(VoyageName2, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
		self.assertNotNullMsg( voyage, 'Add voyage failed' );
		voyage := self.getVoyage(VoyageName2);
		self.assertNotNull(voyage);
		foreach ediTI in ediDataActual.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName2);
				commitTransaction;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName2);
				ediTI.setId(ediTI.id.replace('CANB', 'CANC'));
				ediTI.setId(ediTI.id.replace('OOTL0', 'OOTL2'));
				commitTransaction;
			endif;
		endforeach;
		beginTransaction;
		ediDataActual.setStatus(CM_EDIFile.EDI_STATUS_VERIFYING);
		commitTransaction;
		self.ediDBLoad(ediDataActual.ediFileArray.last);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediDataActual.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

		self.deleteVoyage(VoyageName3);
		voyage := self.getVoyage(VoyageName3);
		self.assertIsDeleted(voyage);
		voyage := self.addVoyageWithConRORO(VoyageName3, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
		self.assertNotNullMsg( voyage, 'Add voyage failed' );
		voyage := self.getVoyage(VoyageName3);
		self.assertNotNull(voyage);
		foreach ediTI in ediDataProposed.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName3);
				commitTransaction;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName3);
				ediTI.setId(ediTI.id.replace('CANB', 'CAND'));
				ediTI.setId(ediTI.id.replace('OOTL0', 'OOTL3'));
				commitTransaction;
			endif;
		endforeach;
		beginTransaction;
		ediDataProposed.setStatus(CM_EDIFile.EDI_STATUS_VERIFYING);
		commitTransaction;
		self.ediDBLoad(ediDataProposed.ediFileArray.last);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediDataProposed.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	endif;
//return;
	// setup the add stowage advice twice here
	ediText := self.uROROStowAdvice30863(VoyageName2, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
	// setup the add stowage advice here
	ediText := self.uROROStowAdvice30863(VoyageName2, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete allTIs;
	delete theLCs;
	delete unloadArray;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="uROROProposedTranshipUnLLoad" id="93376849-3354-4adb-8d67-c837858a3249">
        <updating/>
        <source>uROROProposedTranshipUnLLoad() updating;

/*

Purpose:		Check that proposed tranships in GC areas are extracted and loaded correctly	

Date			Who		Reason
08/02/2013		cnwmh5	Initial creation

*/
constants

	VesselId					: String = "JGRIG";
	VoyageIDInbound				: String = "VOY31119IN";
	VoyageIDOutbound			: String = "VOY31119OUT";
	VoyageIDProposedLoad		: String = "VOY31119PROPL";
	VoyageIDProposedLoadP		: String = "VOY31119PROPLP";
	VoyageIDProposedLoadF		: String = "VOY31119PROPLF";
	TestOperator				: String = "MSL";	
	
vars

	voyageIn					: CM_Voyage;
	voyageOut					: CM_Voyage;
	voyageActualLoad			: CM_Voyage;
	voyageProposedLoad			: CM_Voyage;
	voyage						: CM_Voyage;
	operator					: CM_Operator;
	ti							: CM_TrackedItem;
	
	transhipTIArray				: CM_TIArray;
	tisToPlan					: CM_TIArray;
	tisToMove					: CM_TIArray;
	tiSet						: CM_TISet;
	
	index						: Integer;

begin

	// defaults
	operator := app.myRoot.allOperators[TestOperator];
	self.assertNotNull(operator);
	
	// 26/08/2013 cnwmh5
	self.setTerminalConfig(NoImportStops, true);
	
	// delete the voyages
	self.deleteVoyage(VoyageIDInbound);
	self.deleteVoyage(VoyageIDOutbound);
	self.deleteVoyage(VoyageIDProposedLoad);
	self.deleteVoyage(VoyageIDProposedLoadP);
	self.deleteVoyage(VoyageIDProposedLoadF);
	
	/*********************************************************************
		Setup the Inbound Voyage 
	**********************************************************************/
	
	app.writeLog("***Setting up inbound voyage***", LogINFO);
		
	// create the inbound voyage
	self.deleteVoyage(VoyageIDInbound);
	voyageIn := self.getVoyage(VoyageIDInbound);
	self.assertIsDeleted(voyageIn);
	voyageIn := self.addVoyageWithConRORO(VoyageIDInbound, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyageIn);

	app.writeLog("***Setting up cargo for inbound voyage****", LogINFO);
	create transhipTIArray transient;
	self.xSetup31119InboundCargo(voyageIn, transhipTIArray);
	
	app.writeLog("***Setting up outbound voyage***", LogINFO);
	
	// create the outbound voyage
	self.deleteVoyage(VoyageIDOutbound);
	voyageOut := self.getVoyage(VoyageIDOutbound);
	self.assertIsDeleted(voyageOut);
	voyageOut := self.addVoyageWithConRORO(VoyageIDOutbound, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyageOut);
	
	app.writeLog("***Creating tranships details***", LogINFO);
	foreach ti in transhipTIArray do
		self.setCargoAsTranshipTo(ti, voyageOut);
	endforeach;
	
	// discharge all tranships
	self.xPlanTranshipToMove_31119(voyageIn, transhipTIArray);
	
	/*********************************************************************
		Colour code load of tranships to GC, OOTL, and standard slots
	**********************************************************************/
	self.xLoadCCPlanOutbound(voyageOut, transhipTIArray);
	
	/*********************************************************************
		Extract / Load Proposed with Planned only
	**********************************************************************/
	
	// create voyage for actual load
	self.deleteVoyage(VoyageIDProposedLoad);
	voyageProposedLoad := self.getVoyage(VoyageIDProposedLoad);
	self.assertIsDeleted(voyageProposedLoad);
	voyageProposedLoad := self.addVoyageWithConRORO(VoyageIDProposedLoad, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyageProposedLoad);
	
	// extract out the actual deck plan and load into voyage 2
	app.writeLog("***Extracting Actual from VOY31119Out, loading into VOY31119PROPL***", LogINFO);		
	self.xExtractLoadProposed1_31119(voyageOut, voyageProposedLoad);
	
	/*********************************************************************
		Load some of the items to the voyage
	**********************************************************************/
	create tisToMove transient;
	index := 1;
	while index &lt;= (transhipTIArray.size / 2).Integer do
		tisToMove.add(transhipTIArray[index]);
		index := index + 1;	
	endwhile;
	
	self.xMoveTIsToVoyage_31119(tisToMove);
	
	/*********************************************************************
		Extract / Load Proposed 
	**********************************************************************/
	
	// create voyage for actual load
	self.deleteVoyage(VoyageIDProposedLoadP);
	voyageProposedLoad := self.getVoyage(VoyageIDProposedLoadP);
	self.assertIsDeleted(voyageProposedLoad);
	voyageProposedLoad := self.addVoyageWithConRORO(VoyageIDProposedLoadP, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyageProposedLoad);
	
	// extract out the actual deck plan and load into voyage 2
	app.writeLog("***Extracting Actual from VOY31119Out, loading into VOY31119PROPLP***", LogINFO);		
	self.xExtractLoadProposed1_31119(voyageOut, voyageProposedLoad);
	
	/*********************************************************************
		Load remaining items onto the voyage
	**********************************************************************/
	tisToMove.clear();
	//index := (transhipTIArray.size / 2).Integer;
	while index &lt;= transhipTIArray.size do
		tisToMove.add(transhipTIArray[index]);
		index := index + 1;	
	endwhile;
	
	self.xMoveTIsToVoyage_31119(tisToMove);
	
	/*********************************************************************
		Extract / Load Proposed 
	**********************************************************************/
	
	// create voyage for actual load
	self.deleteVoyage(VoyageIDProposedLoadF);
	voyageProposedLoad := self.getVoyage(VoyageIDProposedLoadF);
	self.assertIsDeleted(voyageProposedLoad);
	voyageProposedLoad := self.addVoyageWithConRORO(VoyageIDProposedLoadF, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyageProposedLoad);
	
	// extract out the actual deck plan and load into voyage 2
	app.writeLog("***Extracting Actual from VOY31119Out, loading into VOY31119PROPLF***", LogINFO);		
	self.xExtractLoadProposed1_31119(voyageOut, voyageProposedLoad);
	
	// 15/09/2015 cnwmh5
	create tiSet transient;
	voyageIn.getAllTrackedItems(tiSet);
	voyageOut.getAllTrackedItems(tiSet);
	voyageProposedLoad.getAllTrackedItems(tiSet);
	beginTransaction;
	foreach ti in tiSet do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;
	
epilog

	delete transhipTIArray;
	delete tisToMove;
	delete tiSet;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;MichaelAllocChange&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;UsesExpectedErrors&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
