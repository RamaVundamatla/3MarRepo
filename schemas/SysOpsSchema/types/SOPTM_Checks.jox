    <JadeMethod name="getCollection" id="c3422358-cdb5-4034-b7da-d02929e130c1">
        <source>getCollection(): Collection;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/01/2010	cnwdap1	Initial creation
17/03/2010	cnwdap1	For 7.8.1, suppress the display of Rail Receive/Release - not in use yet
*/
vars
	cargoCheck 	: CM_CargoCheck;
	dict 		: CM_CargoCheckDict;

begin
	create dict transient;
	//return app.myPassport.myTerminal.allCargoChecks;
	foreach cargoCheck in app.myPassport.myTerminal.allCargoChecks do
	//16 Aug 2010	NDL 	Par 25215 - Make 'em visible.
	//	if cargoCheck.context.isOneOf(CARGO_CHECK_CONTEXT_RAIL_REC, CARGO_CHECK_CONTEXT_RAIL_REL) then
	//		continue;
	//	endif;
		dict.add(cargoCheck);
	endforeach;
	return dict;
epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
