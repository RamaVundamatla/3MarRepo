<Class name="CMIF_MACS3WSProxyObject" id="16d16836-65da-420d-8530-3dd5b7587214">
    <superclass name="CMIF_ExternalWSProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <JadeMethod name="display" id="61962949-8fef-4197-995e-cd5b6826e3b0">
        <source>display(): String;
/*

Purpose:			Make debugging easier, by expanding the 'Common' attributes on any MACS3 response.
					NB: This *hasn't* been designed with speed in mind ;)
					NB2: While it /should/ be ok, any errors will be handled by the inspectors exception handler

Parameters:			

Return Value:		

Date				Who		Reason
09 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	str,
	newStr	: String;
	pos,
	pos2,
	pos3	: Integer;
	
	common	: CMIF_MACS3ContCommonPxyObj;
begin
	str := inheritMethod();

	// Expand the Common attributes
	pos := str.pos("common = CMIF_MACS3ContCommonPxyObj", 1);
	if pos &gt; 0 then
		pos := pos - 1;		// Start just after the CrLf
		pos2 := 1;
		
		// Grab all the common attributes
		common := self.getPropertyValue("common").CMIF_MACS3ContCommonPxyObj;
		newStr := common.display();
		
		// Remove the Oid string
		newStr.scanUntil(CrLf, pos2);	// Jump to before the CrLf
		pos2 := pos2 + 2;				// Skip over the CrLf
		newStr := newStr[pos2:end];
		
		// Increment the tab spacing
		newStr := newStr.replace(CrLf, CrLf &amp; Tab);
		
		// Add anything pre 'common' to our new string
		newStr := str[1:pos] &amp; "common = {" &amp; CrLf &amp; newStr;
		
		// Remove the 'myTestRecordObject' and 'warningsHaveBeenAcknowledged' attributes
		while true do
			pos2 := newStr.pos("myTestRecordObject", 1);
			if pos2 = 0 then
				pos2 := newStr.pos("warningsHaveBeenAcknowledged", 1);
				if pos2 = 0 then
					break;
				endif;
			endif;
			
			// Include the preceding tab in the chunk to skip
			if newStr[pos2-1:1] = Tab then
				pos2 := pos2 - 1;
			endif;
			
			pos3 := pos2;
			newStr.scanUntil(CrLf, pos3);	// Jump to before the CrLf
			pos3 := pos3 + 2;				// Skip over the CrLf
			
			newStr := newStr[1:pos2-1] &amp; newStr[pos3:end];
		endwhile;
		
		pos := pos + 1;					// Start at 'c' (for common)
		str.scanUntil(CrLf, pos);		// Jump to before the CrLf
		pos := pos + 2;					// Skip over the CrLf
		
		// Add anything post 'common' to our new string
		newStr := newStr[1:newStr.length-1] &amp; "}" &amp; CrLf &amp; str[pos:end];
		
		return newStr;
	endif;
	
	return str;	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
