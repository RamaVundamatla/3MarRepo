    <JadeMethod name="doExportCSV" id="a0f380a2-ccff-4388-bc60-61954d9cae68">
        <source>doExportCSV();
// Created:     18/01/2007 by cnwvu1

vars
	
begin
	
	//PAR18207 cnwsh3 18/3/2009. No need to create anything if there is no data in the table.
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, 'Table Data', self.tblData);
		return;
	endif;
	
	self.tblData.outputAsCSV(null);
end;</source>
