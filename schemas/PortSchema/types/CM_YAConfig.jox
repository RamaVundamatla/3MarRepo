    <JadeMethod name="pxyCreateUpdateProxy" id="bb837dd3-56ae-414e-8809-b6605c76143d">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxy	: CM_YAConfig;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	pxy.myTerminal := self.myTerminal;

	self.allDefaultCriteriaTypes.copy(pxy.allDefaultCriteriaTypes);
	self.allDefaultSearchCriteriaTypes.copy(pxy.allDefaultSearchCriteriaTypes);

	if self.myYAOverstowHookCode &lt;&gt; null then
		pxy.myYAOverstowHookCode	:=	self.myYAOverstowHookCode.pxyCreateUpdateProxyWithCode();
	endif;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
