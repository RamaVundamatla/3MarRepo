    <JadeMethod name="setProxyForSeparations" id="bf222c9f-316f-4839-b13c-e9f90a8538e3">
        <updating/>
        <source>setProxyForSeparations( _theVoyage			: CM_Voyage; 
						_ti					: CM_TrackedItem;
						_bol				: CM_BOL;
						_booking			: CM_BookingRef;
						_cargoGroup			: CM_CargoGroup;
						_releaseRequest		: CM_BulkRelease;
						_workOrder			: CM_WorkOrderSet
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d

*/

vars
	debtorSep : CM_InvTypeDebtorSeparation;
begin
	self.raiseExceptionIfNotTransient(method);
	self.myVoyage	 	  := _theVoyage;
	
	/*if _workOrder &lt;&gt; null then		//navtnr20 31-05-2023 TFS 58089
		self.allWorkOrders.add(_workOrder);
	endif;*/
	if _workOrder &lt;&gt; null then		//navtnr20 31-05-2023 TFS 58089
		self.allWorkOrders.clear();//navtnr20 31-05-2023 TFS 58089
		_workOrder.copy(self.allWorkOrders);//navtnr20 31-05-2023 TFS 58089
	endif;
	
	if self.debtor &lt;&gt; null and self.invoiceType &lt;&gt; null then
		debtorSep := self.invoiceType.getDebtorSeparation(self.debtor);
	endif;
	
	if _theVoyage &lt;&gt; null then
		self.voyageGroupCode := _theVoyage.voyageGroupCode;
	endif;
	
	if self.invoiceType &lt;&gt; null then
		if self.myTerminal.getConfig(InvShowAllSeparation).Boolean then
			self.myTrackedItem := _ti;
			self.myBOL := _bol;
			self.myBookingRef := _booking;
			self.myCargoGroup := _cargoGroup;
			self.myReleaseRequest := _releaseRequest;
		else 
			if self.invoiceType.isCargoSpecificSeparation(debtorSep) then
				self.myTrackedItem := _ti;
			endif;
			
			if self.invoiceType.isBOLSpecificSeparation(debtorSep) then
				self.myBOL := _bol;
			endif;
			
			if self.invoiceType.isBookingSpecificSeparation(debtorSep) then
				self.myBookingRef := _booking;
			endif;
			
			if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep) then
				self.myCargoGroup := _cargoGroup;
			endif;
			
			if self.invoiceType.isReleaseSpecificSeparation(debtorSep) then
				self.myReleaseRequest := _releaseRequest;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_workOrder" type="CM_WorkOrderSet"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="82f92b6d-397a-4584-9fdf-a7696e32ba14">
        <updating/>
        <source>setProxyForUpdate(_narr 			   : String; 
				  _zeroRated 		   : Boolean; 
				  _endDT 			   : Date;
				  _purchaseOrderNumber : String; 
				  _debtorReference     : String; 
				  _debtorAddress 	   : CM_Address;
				  _alternativeAddress	: CM_Address;
				  _termOfTrade			: CM_InvoiceTermsOfTrade;
				  _currency				: CM_CurrencyType;
				  _locale				: CM_Locale
				  ) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
//09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
//14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// ---------------------------------------------------------------------------

vars
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.narration 			 := _narr[1:640];		// from 37141
	self.isZeroRatedTax		 := _zeroRated;
	self.purchaseOrderNumber := _purchaseOrderNumber;
	self.debtorReference     := _debtorReference;
	self.myBillingAddress    := _debtorAddress;		//22.07.2019 cnwma1 TFS #45577
	self.toDT.setDate(_endDT);
	self.myAlternativeAddress:= _alternativeAddress; //navtnr20 09-06-2023 Bug 58472
	//14/08/2023	navkc1	Bug 59803
	if _termOfTrade &lt;&gt; null then
		self.termsOfTradeCode	 := _termOfTrade.code;
		self.termsOfTrade		 := _termOfTrade.description;
	else
		self.termsOfTradeCode	 := null;
		self.termsOfTrade		 := null;
	endif;
	self.myCurrencyType		 := _currency;
	self.myLocale			 := _locale;
end;</source>
        <Parameter name="_narr" type="String"/>
        <Parameter name="_zeroRated" type="Boolean"/>
        <Parameter name="_endDT" type="Date"/>
        <Parameter name="_purchaseOrderNumber" type="String"/>
        <Parameter name="_debtorReference" type="String"/>
        <Parameter name="_debtorAddress" type="CM_Address"/>
        <Parameter name="_alternativeAddress" type="CM_Address"/>
        <Parameter name="_termOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_currency" type="CM_CurrencyType"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="setRunPackages" id="72775608-4067-4122-ab77-e58872788f92">
        <updating/>
        <source>setRunPackages(_runPackages : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2024	navra1	Initial creation for CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED

*/

vars

begin
	self.runPackages := _runPackages;
epilog

end;</source>
        <Parameter name="_runPackages" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="dfa94b5b-aa39-463d-8134-c44841c652b6">
        <updating/>
        <source>setStatus( _status : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197
12 July 2018    cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
22 Nov  2018    cnwma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date
08/10/2021 	jlier1		TFS 51963
*/

vars

	finIOClass : CM_ExtFinanceIO;	
	status : CM_VoyageStatus;
	invoiceStatus : CM_InvoiceStatus; // TFS 39618 PATCH 1 
begin


	if self.status &lt;&gt; _status then
		invoiceStatus := self.getInvoiceStatusObject(_status); // TFS 39618 PATCH 1 


		self.status := _status;

		if self.status = INVOICE_PENDING then
			self.pendingDT := app.actualTimeAppServer();
			// TFS 41539
			if self.myVoyage &lt;&gt; null then
				if self.myVoyage.isMTNWOVoyageProcess() then	//jlier1 TFS 51963 1/10/21
					status := app.myRoot.allVoyageStatuses[Voyage_Status_ServTaxInvGen];	// 'Marine Tax-Invoice Generated'
					if status &lt;&gt; null then
						if not status.autoApplyStatus then
							status:=null;
						endif;
					endif;
				endif;
			
			    if status &lt;&gt; null and self.invoiceType.canVoyageStatusMarineTax(self.myVoyage) then		
					self.myVoyage.setStatusFromObject(status);
				endif;
			endif;			
		elseif self.status = INVOICE_PREPEND then
			self.prependDT := app.actualTimeAppServer();
			finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
			if finIOClass &lt;&gt; null then
				if finIOClass.isKindOf(CM_Pelindo1Interface) then 						   //12.07.2018 cnwma1 TFS #39698
					self.paymentCode := finIOClass.getPaymentCode( self );
					//self.externalTaxNumber := finIOClass.getTaxNumber( self );    	   //22.11.2018 cnwma1 TFS #42118
					self.exportCurrencyCode := finIOClass.getExternalInvoiceNumber( self );
				endif;
			endif;
			
			// TFS 41539
			if self.myVoyage &lt;&gt; null then
				if self.myVoyage.isMTNWOVoyageProcess then	//jlier1 TFS 51963 1/10/21
					status := app.myRoot.allVoyageStatuses[Voyage_Status_ServPreInvGen];	// 'Marine Pre-Invoice Generated'
					if status &lt;&gt; null then
						if not status.autoApplyStatus then
							status:=null;
						endif;
					endif;
				endif;
				
				if status &lt;&gt; null and self.invoiceType.canVoyageStatusMarinePre(self.myVoyage) then
					self.myVoyage.setStatusFromObject(status);
				endif;
				
			endif;
		elseif self.status = CM_Invoice.INVOICE_POSTED_DRAFT then
			self.runPackages := true;
		endif;

		if invoiceStatus &lt;&gt; null then // TFS 39618 PATCH 1 
			invoiceStatus.processStatus(self); // TFS 39618 PATCH 1 
		endif; // TFS 39618 PATCH 1 
	
	endif;

epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTaxCodes" id="032584d6-ebee-48c4-9f40-03c6fa51150c">
