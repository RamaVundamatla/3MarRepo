    <JadeMethod name="createEmptyChild" id="0f02125a-cb9e-4d12-9be3-1fb7fc039f39">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_LogType transient;
//	_parent.inspectModal();
	myObject.CM_LogType.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	myParent := _parent;

end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="3c62bc62-fc29-4aab-85d8-69c9c42f861f">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLogType : CM_LogType;
begin
	create proxyLogType transient;
	proxyLogType.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	self.myObject := proxyLogType;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="4f4d22f7-ee88-4752-a6ed-9d8f889016e7">
        <updating/>
        <source>doDelete() : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin

 on Exception do app.handleDeletedObject(exception, self.myObject.CM_LogType, invalidObj); // cnwrd1 3.11.08 par 18090
 
	app.myTrxDA.trxDeleteLogType(self.myObject.CM_LogType, app.myPassport);
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="de262778-2465-497a-a9ef-61330b2e68bd">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyType, newType : CM_LogType;
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_LogType transient;
	endif;
	
	proxyType := self.myForm.myProxyObject.CM_LogType;
	
	proxyType.setProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
							self.myForm.tblInput1.getValueByName('description').String,
							self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
							self.myObject.CM_LogType.myCodeGroupLogSpecs);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateLogType(proxyType, newType,app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newType;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateLogType(proxyType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyType;
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPeerClass" id="90d10b78-df42-46e1-aee8-c66d50246af2">
