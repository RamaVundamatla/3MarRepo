    <JadeMethod name="sh3RenameReport" id="81fffe45-cc43-496b-89bb-8a65c6bf8109">
        <source>sh3RenameReport();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		26 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
constants
	Heading 			:  String = 'ToDo Task Resources';
vars
	repMenu				: CM_QryReportSystem;
	userMenu 			: CM_MenuUserItem;
	translationAgent 	: CM_TranslationAgent;
begin
	app.initialize();

	beginTransaction;
		foreach repMenu in CM_QryReportSystem.instances where repMenu.menuId = '_rpt153' do
			repMenu.setHeading(Heading);
			repMenu.setPropertyValue('reportName', Heading);
					
			foreach userMenu in repMenu.allMenuUserItems do
				userMenu.setHeading(Heading);
			endforeach;
		endforeach;
	commitTransaction;
	
	//Reset from the CM_QryReportSystem settings.
	create translationAgent transient;
	translationAgent.trxLoadXLATsFromGlbConstants(XLAT_ReportNames);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3RepRunReportExample" id="50c04495-0278-4122-8895-fa989d27c8ba">
