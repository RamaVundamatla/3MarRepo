    <JadeMethod name="getPlannersGroupDesc" id="f2f02753-efea-48c1-950e-d42469a8a95f">
        <source>getPlannersGroupDesc(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	cargoType : CM_CargoType;
	criteria : CM_YACriteria;
begin
	criteria := self.getAttrByType(YACriteriaType_CargoType);
	if criteria &lt;&gt; null then
		cargoType := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CargoType;
	endif;
	
	if cargoType = null then
		return "???";
	else
		return cargoType.abbreviation;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProposedVisiblity" id="2adc6ebc-ca6e-46ad-bf16-4f82d67487ef">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars
	req : CM_RORORequest;
	slotLC : CM_ROROGCController;
	theTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
	tis : CM_TIArray;
	defn : CM_DeckItem;
	slot : CM_ROROSlotDefn;
	isComp, found : Boolean;
begin
	_colour := White;

	if not  self.isLoad then
		return false;
	endif;

	// ### Load Colour Coding
	foreach aWLE in self.allWorkListEntries discreteLock do
		// If load CC has a TI it is planned
		if aWLE.myTrackedItem &lt;&gt; null then
			if not found then
				_colour := self.getAllocationColour(); 
			endif;
			return true;
		endif;
	endforeach;

	return false; // do not show 

epilog
	delete tis;
end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleAllWLEsComplete" id="08f9734e-7704-4a0f-8fff-5f256c94d7b6">
        <updating/>
        <source>handleAllWLEsComplete() updating;
/*
Purpose:	If the load request is complete and we are for a Lane then move the Lane defn layout to the Lane Cargo layer		
Purpose:	If the discharge request is complete and we are for a Lane then hide the Lane defn layout 
Date		Who		Reason
31 August 2011	cnwab1	Initial creation
*/

vars
	layer, newLayer : CM_DeckLayerLayout;
	defn : CM_DeckItem;
begin
	if self.isLoad and self.isComplete then
		if self.myLayout &lt;&gt; null then
			layer := self.myLayout.myDeckLayer; // Load CC Layer
			if layer &lt;&gt; null and layer.myDeckLayout &lt;&gt; null then
				newLayer := layer.myDeckLayout.getLaneLayer(); // The actual Lane Cargo Layer
				if newLayer &lt;&gt; null then
					defn := self.myROROController.getDefn();
					if defn &lt;&gt; null and defn.isLocnLanePosition() then // do not move the defined lane
						newLayer.addItemToBeginning(defn.myLayout);
					endif;
				endif;
			endif;
		endif;
	elseif self.isDischarge and self.isComplete then
		defn := self.myROROController.getDefn();
		defn.myLayout.hideMe(); // this will stop any moves to the LC, see CM_LC::testIsControllerAvailable
	endif;
epilog

end;</source>
    </JadeMethod>
