    <JadeMethod name="getOperatorObj" id="c7453b2e-2742-43f5-adeb-a09319054722">
        <source>getOperatorObj():CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

	oper : CM_Operator;

begin

	oper := app.myRoot.allOperators[self.operatorCode];
	
	return oper;

epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="4484f739-1ea7-409a-8169-5867e2a001b2">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

	term : CM_Terminal;
	realCg : CM_TrackedItem;
	pxyCg : CM_TrackedItem;
	invalidObj : Boolean;
	modifying : Boolean;
	updating : Boolean;
	
	_oper : CM_Operator;
	_minWeight : Decimal[14,4];
	_maxWeight : Decimal[14,4];
	_remarks : String;
	
//	notifiedCG : CM_NotifiedCargoGroup;
	_defaultLocation : String;
	cmObj : CM_Object;

begin

	term := self.getMyTerminal;
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;
	
	realCg := term.allCargoGroupsByIdCargoType.getAtKeyGeq(self.id.toUpper,null);
	if realCg &lt;&gt; null and realCg.id &lt;&gt; self.id.toUpper then
		realCg := null;
	endif;
	
	modifying := self.messageMode = self.EDI_ACTION_MODIFY;
	updating := self.messageMode = self.EDI_ACTION_UPDATE;
	on Exception do app.handleDeletedObject( exception, pxyCg, invalidObj );

	if self.messageMode = self.EDI_ACTION_ADD or realCg = null then
		pxyCg := self.createProxy();
		app.myUtilityCA.utlCreateTrackedItem(pxyCg, realCg, _passport);
		
	//13 Aug 2018	NDL	TFS 40120
	elseif self.messageMode = self.EDI_ACTION_DELETE then
		if realCg &lt;&gt; null then
			cmObj := realCg;
			app.myUtilityDA.utlDeleteCMObject( cmObj, _passport );
		else
			app.raiseCMException1( Cargo_group_not_found, self.id, null, null );
			return;
		endif;
		
	else	
		pxyCg := realCg.pxyCreateUpdateProxy();
		//Operator must remain set
		_oper := self.getOperatorObj(); // default to the new value
		if _oper = null then
			_oper := pxyCg.myOperator;
		endif;
		
		if modifying then
			//if we are modifying, only update none blank values passed in
			if minWeight = 0 then
				_minWeight := pxyCg.CM_CargoGroup.minWeight;
			else
				_minWeight := self.minWeight;
			endif;
			if maxWeight = 0 then
				_maxWeight := pxyCg.CM_CargoGroup.maxWeight;
			else
				_maxWeight := self.maxWeight;
			endif;
			if remarks = null then
				_remarks := pxyCg.remarks;
			else
				_remarks := self.remarks;
			endif;
			if defaultLocation = null then
				_defaultLocation := realCg.CM_CargoGroup.getDefaultLocation();
			else
				_defaultLocation := self.defaultLocation;
			endif;
		
		elseif updating then
			//unconditionally reset these to the values passed in
			_minWeight := self.minWeight;
			_maxWeight := self.maxWeight;
			_remarks := self.remarks;
			_defaultLocation := self.defaultLocation;
			
		else
			app.raiseCMException1( EDI_Action_Is_Invalid, self.messageMode, null, null );
			return;
		endif;
		
		pxyCg.CM_CargoGroup.setFromEDIUpdate( 	_oper,	//_oper : CM_Operator;
												_minWeight,	//_minWeight : Decimal;
												_maxWeight,	//_maxWeight : Decimal;
												_remarks,	//_remarks : String
												_defaultLocation	//_defaultLocation : String	//01 Oct 2018	NDL	TFS 39186
												);
		
		app.myUtilityUA.utlUpdateTrackedItem( pxyCg, null, TI_UPDMODE_NORMAL, null, null, null, _passport );
		
	endif;

epilog

	if pxyCg &lt;&gt; null then
		delete pxyCg;
	endif;

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f46507cb-201c-484d-ab1d-974d6520a878">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

begin

	inheritMethod(_proxyEDITI);
	
	self.remarks := _proxyEDITI.remarks;
	self.maxWeight := _proxyEDITI.maxWeight;
	self.minWeight := _proxyEDITI.minWeight;
	self.operatorCode := _proxyEDITI.operatorCode;
	self.defaultLocation := _proxyEDITI.defaultLocation;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="98c20a8b-4a0e-4aa3-864d-0492e8102a1f">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

	cType : CM_CargoType;
	oper : CM_Operator;
	tmpStr : String;
	term : CM_Terminal;
	
begin

	term := self.getMyTerminal;
	if term = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal), ETRow_Terminal, null); 
		return;
	endif;
	
	cType := self.getCargoTypeObj;
	if cType &lt;&gt; null and not cType.isCargoGroup then
		app.raiseCMException2( Cargo_type_selec_not_defin_car, cType.description, self.id, null, null );
		return;
	endif;
	
	if id = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return;
	endif;
	
	oper := self.getOperatorObj();
//	if oper = null then
	if oper = null and self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then	//13 Aug 2018	NDL	TFS 40120
		tmpStr := app.getTerminologyAlternate(null, term, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_Operator, null);
		return;
	endif;
	
	if self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD
	and self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_MODIFY
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE
	and  self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE	//13 Aug 2018	NDL	TFS 40120
	then
		app.raiseCMException1( EDI_Action_Is_Invalid, self.messageMode, null, null );
	endif;
		
epilog

end;</source>
    </JadeMethod>
</Class>
