	return self.cnEcGetProcessorSpeed();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetServerCPUInfo" id="1b345342-1ca0-43f4-95ed-ed5e19f19108">
        <executionLocation>server</executionLocation>
        <source>cnEcGetServerCPUInfo():String serverExecution;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Returns a description of the number of CPUs and their type, on
//				the server node.
//
// Parameters:	None
//
// Returns:		A string describing the server node's CPU(s).
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.cnEcGetCPUInfo();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsCapsLock" id="0ba9a3f1-931f-4dec-a9c5-275f44ec652d">
        <source>cnEcIsCapsLock():Boolean;
// -----------------------------------------------------------------------------
// Created:		05 January 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the Caps Lock is on.
//
// Parameters:	None
//
// Returns:		True if the caps lock is on, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return (call cnEcGetKeyState(CNEC_KEY_CAPS_LOCK) &gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
