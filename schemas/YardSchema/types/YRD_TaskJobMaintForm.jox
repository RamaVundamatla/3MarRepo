    <JadeMethod name="displaySelectorResults" id="b3869779-156b-41ab-b2fe-d5436c22484a">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwrd1	Initial creation
04/12/2013	cnwdap1	PAR #32719 Stop 1090 errors when displaying user-defined cargo types
*/
vars
	any : Any;
	newTi : Boolean;
	newTiStr : String;
	tiArray : StringArray;
	tiList : String;
	tiStr : String;
	
begin
	//if _mode &gt; TI_CargoType_Max then										// PAR #32719
	if _mode &gt; TI_CargoType_Max and _mode &lt; TI_CargoBOLType_Max then		// PAR #32719
		app.msgBox(app.getErrorString1(Work_order_cannotDisplayMode,_mode.String ) , app.getErrorString(Invalid_selector_mode) , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if _resultCollection.isEmpty() then
		return;
	endif;
	
	//need to set cargo type from _mode
	
	self.cmbCargoType.setObject( app.myRoot.allCargoTypesById[_mode] );
		
	foreach any in _resultCollection do
		newTiStr := any.CM_TrackedItem.id;
			if tiList &lt;&gt; null then
				tiList := tiList &amp; ", ";
			endif;
			tiList := tiList &amp; newTiStr;
	endforeach;

	self.myCurrentWorkOrder := null;
	self.mode := YRD_TaskJobMaintForm.Mode_Add;
	
	self.txtSourceList.text := tiList;
epilog

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddUserEmail" id="c3538808-610a-4971-bb88-56880cbb8962">
        <source>doAddUserEmail();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/

vars
	user : CM_User;
begin

	user := app.getMyUser();		
	
	if  user.myEmailEntity = null then
		return;
	endif;
		
	if not self.myEmailController.allToAddresses.includes( user.myEmailEntity )  then
		self.myEmailController.allToAddresses.add( user.myEmailEntity );
		self.txtEmail.text := self.myEmailController.allToAddresses.getNames();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="09d445e2-f4eb-4528-bbd9-ec009f07d2fe">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwmd1	Initial creation
26 March 2024	navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder

*/

vars
	newWorkOrder		: CM_WorkOrder;
	ls					: Boolean;
	result				: Integer;
begin
	self.createProxyChildren();
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateWorkOrder(self.myCurrentProxyWorkOrder, newWorkOrder, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateWorkOrder(self.myCurrentProxyWorkOrder,false, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.mode := self.Mode_View;
			if self.myCurrentWorkOrder = null then
				self.myCurrentWorkOrder := newWorkOrder;
			endif;
			self.setControlsForMode(true);
			delete self.myCurrentProxyWorkOrder;
			return;
		else
			result := app.showErrorWarningDialog(self.getFormCaption(), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		return;
	endwhile;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargodblClick" id="6afacc25-2e06-4af4-95f1-6ca77a0106ee">
