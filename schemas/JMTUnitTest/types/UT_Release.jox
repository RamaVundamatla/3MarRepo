										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have found all 9 containers, for Rule 3. Found - " &amp; tiArray.size.String);
	self.assertTrueMsg( tiArray.first.id = ti.id, "Agent method 'getCargoBasedOnSTW12Rules' should listed '" &amp; ti.id &amp; "' first for Rule 3.");
	
	//stage the sixth and seventh in a different area (Now fully staged but to 2 areas).  Should get rule 2
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "6", childCargoType1.id );
	self.doStwStageCargo( ti, br.allReservePackingChildren.first, ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "7", childCargoType1.id );
	self.doStwStageCargo( ti, br.allReservePackingChildren.first, ic2.allLocationsControllers.first );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
