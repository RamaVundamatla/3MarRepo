    <JadeMethod name="trxUpdateRoadJobRFIDTag" id="63e908b7-cddd-4035-9333-181e78e0a5bb">
        <updating/>
        <source>trxUpdateRoadJobRFIDTag(	_roadJob : CM_RoadJob input;
							_rfidTag : CM_RFIDTag input;
							_passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 August 2006	cnwer1	Initial creation - PAR#xxxx
18 September 2017	jlgmd1	TFS 6813 - QNS - Jade application slow

*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813

	beginTransaction;

	app.myUtilityUA.utlUpdateRoadJobRFIDTag(_roadJob,_rfidTag);
	
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
