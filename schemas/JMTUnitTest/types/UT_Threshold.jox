    <JadeMethod name="addToDoTaskDescs" id="8eef04a8-08d1-41a7-8afa-c6ab891accbc">
        <source>addToDoTaskDescs( 	_term : CM_Terminal;
					_wash : CM_ToDoTaskDesc output;
					_repair : CM_ToDoTaskDesc output;
					_pretrip : CM_ToDoTaskDesc output;
					_ptiRepair : CM_ToDoTaskDesc output;
					_survey : CM_ToDoTaskDesc output
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731
02 Nov	2022 	navds20 Task ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
11 Dec 2023		jlizm1	TFS 61654 CUX ToDo Task don't block RTL
*/

vars

	proxy : CM_ToDoTaskDesc;
	todo : CM_ToDoTaskDesc;
	
	selectedCargoTypes : ObjectArray;
	requiresWO    	   : Boolean;
	requiredExtraInfo    : String;
	selectedResourceTypes : CM_ObjectSet;
	selectedTerminals : CM_TerminalSet;

begin

	create selectedCargoTypes transient;
	selectedCargoTypes.add(app.myRoot.allCargoTypesById[ TI_CargoType_Container ]);
	create selectedResourceTypes transient;
	create selectedTerminals transient;
	selectedTerminals.add( _term );
	
	
	create proxy transient;
	proxy.setProxy(	"UT_Wash",	//pDesc:String;
					"UT_Wash",	//pShortDesc:String;
					0,	//pSortKey:Integer;
					null,	//pReportDesc:String;
					MTReportTaskColumn_Wash,	//pEmptyReportColumn: Integer;
					null,	//_trxTypeOnCompletion : CM_TransactionType;
					null,	//_trxTypeOnCreation : CM_TransactionType;
					selectedCargoTypes,	//pAllCargoTypes : Collection;
					selectedResourceTypes,	//pAllResourceTypes : Collection;
					false,	//_requiresWorkOrder : Boolean;
					null,	//_requiredExtraInfo : String;
					selectedTerminals,	//_selectedTerminals : CM_TerminalSet;
					null,	//_selectedSubTerminals : CM_SubTerminalByCodeDict
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]	
					null,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					false
					);
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, _wash, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete proxy;
	
	create proxy transient;
	proxy.setProxy(	"UT_Repair",	//pDesc:String;
					"UT_Repair",	//pShortDesc:String;
					0,	//pSortKey:Integer;
					null,	//pReportDesc:String;
					MTReportTaskColumn_Repair,	//pEmptyReportColumn: Integer;
					null,	//_trxTypeOnCompletion : CM_TransactionType;
					null,	//_trxTypeOnCreation : CM_TransactionType;
					selectedCargoTypes,	//pAllCargoTypes : Collection;
					selectedResourceTypes,	//pAllResourceTypes : Collection;
					false,	//_requiresWorkOrder : Boolean;
					null,	//_requiredExtraInfo : String;
					selectedTerminals,	//_selectedTerminals : CM_TerminalSet;
					null,	//_selectedSubTerminals : CM_SubTerminalByCodeDict
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					false
					);
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, _repair, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete proxy;
	
	create proxy transient;
	proxy.setProxy(	"UT_Pretrip",	//pDesc:String;
					"UT_Pretrip",	//pShortDesc:String;
					0,	//pSortKey:Integer;
					null,	//pReportDesc:String;
					MTReportTaskColumn_Pretrip,	//pEmptyReportColumn: Integer;
					null,	//_trxTypeOnCompletion : CM_TransactionType;
					null,	//_trxTypeOnCreation : CM_TransactionType;
					selectedCargoTypes,	//pAllCargoTypes : Collection;
					selectedResourceTypes,	//pAllResourceTypes : Collection;
					false,	//_requiresWorkOrder : Boolean;
					null,	//_requiredExtraInfo : String;
					selectedTerminals,	//_selectedTerminals : CM_TerminalSet;
					null,	//_selectedSubTerminals : CM_SubTerminalByCodeDict
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					false
					);
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, _pretrip, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete proxy;
	
	create proxy transient;
	proxy.setProxy(	"UT_PTIRepair",	//pDesc:String;
					"UT_PTIRepair",	//pShortDesc:String;
					0,	//pSortKey:Integer;
					null,	//pReportDesc:String;
					MTReportTaskColumn_PTIRepair,	//pEmptyReportColumn: Integer;
					null,	//_trxTypeOnCompletion : CM_TransactionType;
					null,	//_trxTypeOnCreation : CM_TransactionType;
					selectedCargoTypes,	//pAllCargoTypes : Collection;
					selectedResourceTypes,	//pAllResourceTypes : Collection;
					false,	//_requiresWorkOrder : Boolean;
					null,	//_requiredExtraInfo : String;
					selectedTerminals,	//_selectedTerminals : CM_TerminalSet;
					null,	//_selectedSubTerminals : CM_SubTerminalByCodeDict
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					false
					);
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, _ptiRepair, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete proxy;
	
	
	create proxy transient;
	proxy.setProxy(	"UT_Survey",	//pDesc:String;
					"UT_Survey",	//pShortDesc:String;
					0,	//pSortKey:Integer;
					null,	//pReportDesc:String;
					MTReportTaskColumn_Survey,	//pEmptyReportColumn: Integer;
					null,	//_trxTypeOnCompletion : CM_TransactionType;
					null,	//_trxTypeOnCreation : CM_TransactionType;
					selectedCargoTypes,	//pAllCargoTypes : Collection;
					selectedResourceTypes,	//pAllResourceTypes : Collection;
					false,	//_requiresWorkOrder : Boolean;
					null,	//_requiredExtraInfo : String;
					selectedTerminals,	//_selectedTerminals : CM_TerminalSet;
					null,	//_selectedSubTerminals : CM_SubTerminalByCodeDict
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					false
					);
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, _survey, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

epilog

	delete selectedCargoTypes;
	delete selectedResourceTypes;
	delete selectedTerminals;
	delete proxy;

end;</source>
