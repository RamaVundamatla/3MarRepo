    <JadeMethod name="hasUnsavedChanges" id="aeba6f0d-de26-48c6-b890-46aa92415ee2">
        <source>hasUnsavedChanges():Boolean;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return cmb_Damage.text &lt;&gt; null
	or cmb_Position.text &lt;&gt; null
	or cmb_Severity.text &lt;&gt; null
	or txt_Notes.text &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCombos" id="59be47a2-b2d0-4321-9459-e044c27663d5">
        <source>initCombos() protected;
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwdad1
//
// Purpose:		Populates the receiver's comboboxes with the relevant data.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//28 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
// --------------------------------------------------------------------------------
vars
	damageDefObj	: CM_DamageDefinitionCode;
	allCodes		: CM_DamageDefinitionByCodeDict;
	severity		: Integer;
	comboboxObj		: ComboBox;
	damagePosition	: CM_DamagePosition;
	damagePosSet	: CM_DamagePositionSet;
begin
	// Populate the Position combobox.
	
	comboboxObj	:=	self.cmb_Position;
	comboboxObj.clear();
	comboboxObj.style	:=	ComboBox.Style_DropDownComboList;
	
	comboboxObj.addItem(null);
	damagePosSet := self.myTrackedItem.myCargoType.getDamagePositions();
	
	foreach damagePosition in damagePosSet do
		comboboxObj.cnEcAddItemDataObject(damagePosition.code, 0, damageDefObj);
	endforeach;
/*		
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_Left), DamageLocation_Left, null);
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_Right), DamageLocation_Right, null);
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_Top), DamageLocation_Top, null);
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_Bottom), DamageLocation_Bottom, null);
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_Front), DamageLocation_Front, null);
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_Back), DamageLocation_Back, null);
	comboboxObj.cnEcAddItemDataObject(app.getDamageDescrForLoc(DamageLocation_All), DamageLocation_All, null);
*/
	// Populate the Damage code combobox.
	
	comboboxObj	:=	self.cmb_Damage;
	comboboxObj.clear();
	comboboxObj.style	:=	ComboBox.Style_DropDownComboList;
	comboboxObj.addItem(null);
	allCodes	:=	app.myRoot.allDamageDefinitionCodes;
	
	foreach damageDefObj in allCodes do
		comboboxObj.cnEcAddItemDataObject(damageDefObj.code, 0, damageDefObj);
	endforeach;
	
	// Populate the Severity level combobox.
	
	comboboxObj	:=	self.cmb_Severity;
	comboboxObj.clear();
	comboboxObj.style	:=	ComboBox.Style_DropDownComboList;
	comboboxObj.addItem(null);
	
	//foreach severity in 1 to DamageSeverity_MAX do	//28 June 2022 navhl20 TFS 53862
	foreach severity in 1 to 9999 do		//28 June 2022 navhl20 TFS 53862
		comboboxObj.cnEcAddItemDataObject(severity.String, severity, null);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="076e8aea-5f84-4812-96eb-535dd20012d3">
        <updating/>
        <source>setTrackedItem(_tiObj:CM_TrackedItem) updating;
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwdad1
//
// Purpose:		Sets a reference to the Tracked Item against which damaged will be recorded.
//
// Parameters:	_tiObj - A reference to the Tracked Item.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myTrackedItem	:=	_tiObj;
end;</source>
        <Parameter name="_tiObj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="24177761-d2d5-4d0d-aefc-044cc638cde4">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwdad1
//
// Purpose:		Standard form setup, invoked whenever a form is first loaded.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tiObj	: CM_TrackedItem;
	
begin
	inheritMethod();
	self.myTrackedItem := self.myMainObject.CM_TrackedItem;
	tiObj	:=	self.myTrackedItem;
	
	if tiObj = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, app.getErrorString(ERR_INVALID_TI_ID)); //Expected Tracked Item is null - message
		self.unloadForm();
	endif;
	
	// Set up the form components.
	
	self.centreWindow();
	self.initCombos();
	
	// Initialize the form's data/fields.
	
	lbl_CargoID.cnEcSet(tiObj.id);
	cmb_Position.listIndex	:=	CNEC_NULL_INDEX;
	cmb_Damage.listIndex	:=	CNEC_NULL_INDEX;
	cmb_Severity.listIndex	:=	CNEC_NULL_INDEX;
	txt_Notes.text			:=	null;
	
	self.tablePopulate();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableInitialize" id="519ed828-7565-46a0-88a2-f80887b5b36c">
        <source>tableInitialize() protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Initializes the table of previously recorded damages.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	
begin
	tableObj				:=	tbl_Packing;
	tableObj.rows			:=	1;
	tableObj.columns		:=	3;
	tableObj.fixedColumns	:=	0;
	tableObj.fixedRows		:=	1;
	tableObj.setCellText(1, 1, app.getErrorString(Position) &amp; Tab &amp; app.getErrorString(Damage) &amp; Tab &amp; app.getErrorString(Severity) );
	tableObj.parentAspect	:=	Table.ParentAspect_StretchBoth;
	tableObj.accessColumn(1).alignment	:=	Table.Alignment_Center;
	tableObj.accessColumn(2).alignment	:=	Table.Alignment_Center;
	tableObj.accessColumn(3).alignment	:=	Table.Alignment_Center;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tablePopulate" id="3ed060d1-906c-42ce-ae88-799a4eba0db4">
        <source>tablePopulate() protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Populates the table with existing recorded damages.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	tiObj		: CM_TrackedItem;
	damageObj	: CM_DamageInstance;
	rowDisplay	: String;
	
begin
	self.tableInitialize();
	tiObj		:=	self.myTrackedItem;
	
	if tiObj = null then
		return;
	elseif (not tiObj.damaged) then
		return;
	endif;
	
	tableObj	:=	tbl_Packing;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//foreach damageObj in tiObj.allDamageInstances do
	foreach damageObj in tiObj.allDamageInstancesByPos do
		rowDisplay	:=	damageObj.getTableDisplay();
		
		tableObj.cnEcAddItem(rowDisplay, damageObj);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3f2fa0e5-9e2f-4db5-8d6f-de606fd1fd99">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017619, locale);
	btn_Cancel.translateCaption(Xlat_0013223, locale);
	btn_Next.translateCaption(Xlat_0013224, locale);
	btn_OK.translateCaption(Xlat_0013225, locale);
	lbl_Damage.translateCaption(Xlat_0013226, locale);
	lbl_Notes.translateCaption(Xlat_0013227, locale);
	lbl_Notes_1.translateCaption(Xlat_0013228, locale);
	lbl_Notes_2.translateCaption(Xlat_0013229, locale);
	lbl_Position.translateCaption(Xlat_0013230, locale);
	lbl_Severity.translateCaption(Xlat_0013231, locale);
	lbl_TableCaption.translateCaption(Xlat_0013232, locale);
	lbl_Title.translateCaption(Xlat_0013233, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="601f08b9-2e99-4c52-95fb-6663cf9ff222">
        <source>validateForm():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Validates the user's inputs on the receiver.
//
// Parameters:	None
//
// Returns:		True if the user inputs are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	position		: Integer;
	positionString	: String;
	damageCode		: String;
	severity		: Integer;
	damageNotes		: String;
	message			: String;
	errorMsg		: String;
	damageDefObj	: CM_DamageDefinitionCode;
	damagePosition	: CM_DamagePosition;
begin
	//position		:=	cmb_Position.cnEcGetItemData(cmb_Position.listIndex);
	positionString	:=  cmb_Position.text.trimBlanks();
	damageCode		:=	cmb_Damage.text.trimBlanks();
	severity		:=	cmb_Severity.text.trimBlanks().Integer;
	damageNotes		:=	txt_Notes.cnEcString();
	damageDefObj	:=	app.myRoot.allDamageDefinitionCodes[damageCode];
	damagePosition  :=  app.myRoot.allDamagePositionsByCode[positionString];
	
	//if position = 0 then
	if damagePosition = null then
		message	:=	app.getErrorString(Damage_position);
		errorMsg	:=	self.concatenateErrorMsg(message, errorMsg);
	endif;
//	errorMsg	:=	self.concatenateErrorMsg(message, errorMsg);
	// no, no, no aaargh !!!!!
	if damageDefObj = null then
		message	:=	app.getErrorString(Damage_nature);
		errorMsg	:=	self.concatenateErrorMsg(message, errorMsg);
	endif;
	
//	errorMsg	:=	self.concatenateErrorMsg(message, errorMsg);
	
	if severity = 0 then
		message	:=		app.getErrorString(Damage_severity);
		errorMsg	:=	self.concatenateErrorMsg(message, errorMsg);
	endif;
	
//	errorMsg	:=	self.concatenateErrorMsg(message, errorMsg);
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
