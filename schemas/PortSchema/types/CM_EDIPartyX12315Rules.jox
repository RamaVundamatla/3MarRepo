<Class name="CM_EDIPartyX12315Rules" id="61024a6c-3e40-4d60-8ff9-3343386b223f">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="createBOLs" id="e4ab8af8-4f6e-44f1-9fda-c7485b64e039">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isImport" id="d1d54474-7623-4032-8f76-85cbbe56fd4a">
        <embedded/>
        <virtual/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="a31896de-35ec-4815-acb9-b8a3549cab8c">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2014	cnwrd1	Initial creation

*/

vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeX12_315_4010, null);
	
	if type = null or type.type &lt;&gt; EDIFileTypeX12_315_4010 then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'X12 file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isImport" id="95f57861-e1e0-46da-942a-4086a5efb46a">
        <methodInvocation>mapping</methodInvocation>
        <source>isImport(set: Boolean; _value: Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	value : String;
begin
	if set then
		global.setExtraData(self.allExtraData, self, "IsImport", _value.String);
	else
		global.getExtraData(self.allExtraData, "IsImport", value);
		if value = null then
			value := false.String;
		endif;
		_value := value.Boolean;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="86b43ce4-f8c5-46f6-91be-66743d90384c">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2014	cnwrd1	Initial creation
26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	proxy	:CM_EDIPartyX12315Rules;
begin
	proxy :=  inheritMethod();
	
	proxy.createBOLs	:= self.createBOLs;
	proxy.isImport := self.isImport;
	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6363657d-a0e1-4e5e-b112-3c5b885a3197">
        <updating/>
        <source>setForUpdate(_proxy: CM_EDIPartyX12315Rules) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2014	cnwrd1	Initial creation
26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars

begin
	inheritMethod(_proxy);
	
	self.createBOLs := _proxy.createBOLs;
	self.isImport := _proxy.isImport;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyX12315Rules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8bd0e750-7a90-4831-af54-4565e2df6c90">
        <updating/>
        <source>setProxy(_createBOLs : Boolean; _isImport : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2014	cnwrd1	Initial creation
26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars

begin
	self.createBOLs := _createBOLs;
	self.isImport := _isImport;
epilog

end;</source>
        <Parameter name="_createBOLs" type="Boolean"/>
        <Parameter name="_isImport" type="Boolean"/>
    </JadeMethod>
</Class>
