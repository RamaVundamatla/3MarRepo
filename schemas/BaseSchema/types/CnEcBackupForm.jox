    <JadeMethod name="load" id="40dfc48a-40b2-44b2-bb5a-44e825aa6357">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	
	// set Backup Form as the mdi frame
	//self.caption	:=	'Harbour management System Backup Application';
	self.caption	:=	currentSchema.getName &amp; ' Backup Application';		
	app.mdiFrame	:=	CnEcBackupForm;

	self.centreWindow();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuExit_click" id="03e450c4-35e8-4193-b4d2-6ee3a235e2dc">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuExit_click(menuItem: MenuItem input) updating;

begin
	unloadForm();
	terminate;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuReload_click" id="8db05572-8285-4d04-9730-f38d25f94a1b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuReload_click(menuItem: MenuItem input) updating;

vars
	reload		: CnEcJadeDBUnloadReload;
	ts			: TimeStamp;
	startTime	: Time;
	endTime		: Time;
 	
begin
//	ts := global.currentTimeStamp;
	startTime := ts.time;
	create reload transient;
	reload.reloadJadeDB();
	delete reload;
//	ts := global.currentTimeStamp;
	endTime := ts.time;

//	write 'Reload took ' &amp; (endTime - startTime).Time.String;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuUnload_click" id="39fbd2a1-9dbc-43c7-94ae-6295f4b43ade">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuUnload_click(menuItem: MenuItem input) updating;

vars
	unload		: CnEcJadeDBUnloadReload;
	ts			: TimeStamp;
	startTime	: Time;
	endTime		: Time;

begin
//	ts := global.currentTimeStamp;
	startTime := ts.Time;
	create unload transient;
	unload.unloadJadeDB();
	delete unload;
//	ts := global.currentTimeStamp;
	endTime := ts.time;

//	write 'Unload took ' &amp; (endTime - startTime).Time.String;			
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
