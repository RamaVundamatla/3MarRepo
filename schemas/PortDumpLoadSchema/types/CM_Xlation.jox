<Class name="CM_Xlation">
    <JadeMethod name="importPLXMLReference" id="366bc4e9-3392-4952-8bce-cab1724456fa">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;
// 02/07/2013	cnwcs5		par 31261 - remove redundant properties
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation

vars
	pos : Integer;
	operatorCode : String;
	lxlationTable : CM_XlationTable;
	xlationType : Integer;
	delimiter : String;
begin
//	if _name = CM_Xlation::myCarrier.name then
//		return app.myRoot.allCarriers[_theCode];
//	if _name = CM_Xlation::myCommodity.name then
//		return app.myRoot.allCommodities[_theCode];
//	if _name = CM_Xlation::myConsigneeConsignor.name then
//		return app.myRoot.allConsigneeConsignors[_theCode];
//	if _name = CM_Xlation::myISOType.name then
//		return app.myRoot.allISOTypes[_theCode];
//	if _name = CM_Xlation::myOperator.name then
//		return app.myRoot.allOperators[_theCode];
//	if _name = CM_Xlation::myPort.name then
//		return app.myRoot.allPorts[_theCode];
//	if _name = CM_Xlation::myVessel.name then
//		return app.myRoot.allVessels[_theCode];
	if _name = CM_Xlation::myXlationTable.name then 
		pos := 1;
		xlationType := _theCode.getDelimitedToken(pos, ':', delimiter).Integer;
		if xlationType = XLATION_TYPE_VOYAGETERMINAL then //ignore as we dont have any voyages
			return null;
		endif;
		operatorCode := _theCode.getDelimitedToken(pos, ':', delimiter);
		create lxlationTable transient;
//		lxlationTable.type := xlationType;
//		lxlationTable.myOperator := app.myRoot.allOperators[operatorCode];
		lxlationTable.setProxy(xlationType, null, app.myRoot.allOperators[operatorCode], null, null,null); 
		return lxlationTable;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
