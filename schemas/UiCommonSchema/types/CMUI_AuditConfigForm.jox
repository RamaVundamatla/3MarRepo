    <JadeMethod name="tblAuditConfigs_contextMenu" id="491bb038-a1e8-4182-8f9c-8c25308dae8b">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAuditConfigs_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

	self.mnuAudits.enabled := self.mySelectedAuditConfig &lt;&gt; null and self.mySelectedAuditConfig.hasAudits;
	self.mnuInspect.visible := self.mySelectedAuditConfig &lt;&gt; null and ( app.isDevelopmentSystem or app.getMyUser.isSuperUser );
	self.mnuInspect.enabled := self.mnuInspect.visible;
	
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="62ea7c0c-9a7f-40b6-aebb-0d462aae097b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 October 2021 14:04:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024535, locale);
	btnEnable.translateCaption(Xlat_0024536, locale);
	lblAvailable.translateCaption(Xlat_0024537, locale);
	lblSelected.translateCaption(Xlat_0024538, locale);
	mnuAudits.translateCaption(Xlat_0024539, locale);
	mnuContext.translateCaption(Xlat_0024540, locale);
	mnuInspect.translateCaption(Xlat_0024541, locale);
end;</source>
    </JadeMethod>
</GUIClass>
