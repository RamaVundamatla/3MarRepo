    <JadeMethod name="getVoyageCode" id="a05839d8-8638-43fd-9643-fbbdfdb6699e">
        <source>getVoyageCode(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol):String;
//
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
//
vars
	voyageId,xlVoyageId: String;
begin
	//get the voyage code
	//if _transaction.myTrackedItem.isExport then														// PAR #25021
	if _transaction.myTrackedItem.isExport or _transaction.myTrackedItem.isTranshipOutbound then		// PAR #25021
		voyageId := _transaction.myTrackedItem.myVoyage.code;
	//elseif _transaction.myTrackedItem.isImport then													// PAR #25021
	elseif _transaction.myTrackedItem.isImport or _transaction.myTrackedItem.isTranshipInbound then		// PAR #25021
		voyageId := _transaction.myTrackedItem.myVoyage.inwardCode;
	elseif _transaction.myTrackedItem.isStorage then
		voyageId := _transaction.myTrackedItem.myVoyage.inwardCode;
	else
		voyageId := _transaction.myTrackedItem.myVoyage.code;
	endif;

	//translate the voyage Code
	xlVoyageId := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, voyageId, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
	if xlVoyageId = NULL_VOYAGE_CODE then //cmwrs1 Mar 2007 CCMS 1050
		xlVoyageId := null;
	endif;
	return xlVoyageId;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
