    <JadeMethod name="makeMessageHeader" id="a3841e9d-77a9-4f62-91b1-bda5df18f031">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input; _unhSeqNumber : Integer io; 
					_type : String; _fileType : String; _coll :HugeStringArray input) : String updating;
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 16/05/2011	cnwcs5 	CCMS SCT 2058/par 27460 - replace literals with characters defined on protocol
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	protocol	:CM_CamProtocol;	// par 27460 cnwcs5
	strLine : String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol		:= _camTaskHistory.camProtocol;	// par 27460 cnwcs5

	// UNH Segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", null, "0", _camTaskHistory.runDateTime), _coll); 	//cnwmc5 - 15 Oct 2014 - CCMS 2380
	// BGM segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, null, 9, null), _coll);

	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="e0321613-ceaf-4f67-a6f5-672123425f35">
        <source>makeMessageRFF_BN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input;  _activity :Integer; _ti :CM_TrackedItem; _transaction :CM_TITransaction) protected;
/*	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	contentsStatus, booking, 
	release, bol			:String;
	terminal				:CM_Terminal;
begin
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _activity, _transaction.type);

	if _activity = CODECO_GATEIN then
		if _camProtocol.isUseCarrierRefForBooking then	
			booking := _ti.getCarrierReference;
		else
			booking :=  _ti.bookingReference.trimRight;
			release := _ti.deliveryRelease.trimRight;
		endif;
		
		if contentsStatus = "4" then
			//empty
			if booking &lt;&gt; null then
				self.makeRFFSegment (_camProtocol, _group, "BN",  booking );	// par 27460 17/05/2011 cnwcs5 			
			endif;			
		else	
			if booking &lt;&gt; null then
				self.makeRFFSegment (_camProtocol, _group, "BN",  booking );	// par 27460 17/05/2011 cnwcs5 			
			elseif  release &lt;&gt; null then
				self.makeRFFSegment (_camProtocol, _group, "BN",  release );	// par 27460 17/05/2011 cnwcs5 			
			else
				bol := _ti.billOfLading.trimRight ;
				
				if bol &lt;&gt; null then
					self.makeRFFSegment (_camProtocol, _group, "BM",  bol );	// par 27460 17/05/2011 cnwcs5 			
				endif;
			endif;
		endif;
	endif;
	
	if _activity = CODECO_GATEOUT then
		terminal	:= _camProtocol.terminal;
		
		if _camProtocol.isUseCarrierRefForBooking then
			release := _ti.getCarrierReference;
		else		
			release := _ti.deliveryRelease.trimRight;
			booking	:= _ti.bookingReference.trimRight;
		endif;
		
		bol 	:= _ti.billOfLading.trimRight;
		
		if contentsStatus = "4" then	//empty
			
			if release &lt;&gt; null then
				if release[1:1].isInteger then
					self.makeRFFSegment (_camProtocol, _group, "BN",  release );
				else
					self.makeRFFSegment (_camProtocol, _group, "EP",  release );
				endif;
			endif;
		else				
			if bol &lt;&gt; null then
				self.makeRFFSegment (_camProtocol, _group, "BM",  bol );	
				
			elseif release &lt;&gt; null then
				self.makeRFFSegment (_camProtocol, _group, "BN",  release);	
				
			elseif booking &lt;&gt; null then
				self.makeRFFSegment (_camProtocol, _group, "BN",  booking);	
			endif;
		endif;
	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT20Segment" id="634c4f2c-da13-4529-9bf8-3d747fc296f5">
        <updating/>
        <source>makeMessageTDT20Segment(_protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _activity :Integer ):String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			
Parameters:			
Return Value:		

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars
	vCode, msg	:String;
	voyage		:CM_Voyage;
begin
	vCode 	:= _camVoyage.getSanitisedVoyageCode().trimBlanks;
	voyage	:= _camVoyage.voyageOid;
	
	if voyage &lt;&gt; null then
		if vCode &lt;&gt; null and	//30 May 2014	cnwrs1	Par 34265
		   voyage.vesselName &lt;&gt; null then
			if _protocol.camGroup.useCallSign then
				msg := self.makeTDT20Segment (_protocol, vCode, '1', null, null, null, null, null, null, voyage.callSign.trimRight, '103', null, null);
			else
				msg := self.makeTDT20Segment (_protocol, vCode, '1', null, null, null, null, null, null, voyage.lloydsNumber, '146', null, null);
			endif;
		else
			msg := self.makeTDT20Segment (_protocol, vCode, '1', null, null, null, null, null, null, null, '103', null, null);
		endif;
	else
		//no voyage TDT+20++1+++++:103::'
		msg := self.makeTDT20Segment (_protocol, null, '1', null, null, null, null, null, null, null, '103', null, null);	
	endif;

	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_activity" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="757ff7e0-32fb-476f-9695-db03a8aae506">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 18/05/2011	cnwcs5	ccms sct 2058/par27460 - user defined special characters
// 05 Jan 2012	cnwrs1	Par 28933 - do not produce SEL message for MT containers
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	fCode 			: String;
	code 			: String;
	ti 				: CM_TrackedItem;
	contentsStatus 	: String;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
// OOCL
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);	
	// cnwrl1 19/10/2010 PAR 25867 - start of replacement coding
	if contentsStatus = "5" then
		// set up the potential group of GID, TMP, SGP and DGS records.
		if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
			// GID+ - Goods Item Details
			self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
			// TMP Segment
			self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 17/05/2011 cnwcs5 	
			// Split Goods Placement
			self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, null);		// par 27460 09/05/2011 cnwcs5 	
			// ie Dangerous Goods
			if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
				self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
			endif;																	//JIRA-20814	
		endif;
	endif;
	// EQD segment
	//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, null, null, null, null, contentsStatus); // par 27460 17/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight,fIsoCode, null, null, null, null, contentsStatus);//23/08/2017 cnwma1 TFS #5834
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN segments
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460, cnwcs5

	// RFF+CN - special18 field
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs

	// if creating extra messages for pack/unpack add 1 minute to the second message
	self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754

	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	// LOC+165
	code := _terminal.getConfig(PortDestCode).String.trimRight;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal).trimRight;
	
	if fCode &lt;&gt; "" then
		self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '139', '6', _camProtocol.camGroup.facilityCode, 'TER', 'ZZZ');	// par 27460 09/05/2011 cnwcs5 			
	else
		self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', code, '139', '6', _camProtocol.camGroup.facilityCode, 'TER', 'ZZZ');	// par 27460 09/05/2011 cnwcs5 	
	endif;
	// MEA+ segment
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16

	// DIM+ segements
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 17/05/2011 cnwcs5
	//the SEL for the seal number
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608

	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	
	// TFS #2051 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeTDT20Segment" id="4a9330e9-7ac8-4c78-b6cf-fab57d0585d9">
        <source>makeTDT20Segment(_protocol :CM_CamProtocol; _ref, _mode, _means, 
				_carrier, _carrierQual, _carrierAgency, _direction, _excess, 
				_transportMeansID, _transportQual, _transportAgency, _transportID :String):String protected;
/*
Purpose:	Make a TDT+20 segment
Parameters:	_stage	- transport stage qualifier
			_ref	- conveyance reference number
			_mode 	- mode of transport
			

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
constants
	MESSAGE	= "TDT";
	STAGE = "20";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			STAGE &amp; plus &amp; 
			_ref &amp; plus &amp;
			_mode &amp; plus &amp; 
			_means &amp; plus &amp;
			_carrier;
			
	if _carrierQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _carrierQual;
	endif;

	if _carrierAgency &lt;&gt; null then
		msg := msg &amp; colon &amp; _carrierAgency;
	endif;
	
	msg := msg &amp; plus &amp; 
			_direction &amp; plus &amp;
			_excess &amp; plus &amp;
			_transportMeansID;
	// no trailing colons for OOCL		
	if _transportQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _transportQual;
		if _transportAgency &lt;&gt; null then
			msg := msg &amp; colon &amp; _transportAgency;
			if _transportID &lt;&gt; null then
				msg := msg &amp; colon &amp; _transportID;
			endif;
		endif;
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_means" type="String"/>
        <Parameter name="_carrier" type="String"/>
        <Parameter name="_carrierQual" type="String"/>
        <Parameter name="_carrierAgency" type="String"/>
        <Parameter name="_direction" type="String"/>
        <Parameter name="_excess" type="String"/>
        <Parameter name="_transportMeansID" type="String"/>
        <Parameter name="_transportQual" type="String"/>
        <Parameter name="_transportAgency" type="String"/>
        <Parameter name="_transportID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="c4583173-caea-423f-bff4-de4901fea659">
        <updating/>
        <source>outputHeader_LOC(_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _terminal :CM_Terminal; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	
begin
	// do nothing - LOC not include in OOCL header
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
