	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="processMovementLog" id="9ae3d796-e455-4736-a43c-767c5bc44aaf">
        <updating/>
        <source>processMovementLog() : Boolean updating;
/*

Purpose:			Process CM_MovementLog - There is no collection over this
					Takes the first MaximumToProcess and optimises the Yard Allocation Blocks

Parameters:			

Return Value:		

Date		Who		Reason
20 Aug 2008	conkc1	Initial creation
22 Jul 2009	cnwkpd1	PAR #20328 - Fix problem with SDS tracking
					Also "soften" up runtime settings to add tuning ability
07 Sep 2009	cnwkpd1	PAR #20586 - Performance enhancement by reducing number of Grid Rows to 
					recalculate
					
*/

vars
	movementLog         : CM_MovementLog;
	objects,
	movementLogArray    : ObjectArray;
	object              : Object;
	sourceLocation      : CM_LocationsController;
	targetLocation      : CM_LocationsController;
	terminalArea        : CM_TerminalArea;
	error4              : Boolean;
	count               : Integer;
	now					: TimeStamp;
	difference			: TimeStampInterval;
	
begin
	on Exception do self.handleMovementLogEx(exception, error4);
	
	self.allTerminalAreasSet.clear();
	self.allGridRowsSet.clear();				// PAR #20586
	self.allGridColumnSet.clear();// PAR #26189
	self.allYABlocksSet.clear();
	self.allMovementsArray.clear();

	// PAR #20328 - Need to check age of objects against specified minimum age
	create objects transient;
	CM_MovementLog.allInstances(objects, self.maximumNumberToProcess, false);
	
	now := app.actualTimeServer();
	
	foreach object in objects do
		difference := now - object.creationTime();
		if difference.getMilliseconds &gt;= self.minimumAgeToProcess then
			self.allMovementsArray.add(object);
		endif;
	endforeach;
	
	if self.allMovementsArray.size = 0 then
		//
		// Nothing to process
		//
		return false;
	endif;
	
	foreach object in self.allMovementsArray do
		app.sendHeartbeatIfRequired();		// 4/9/17 MAP TFS5551

		movementLog := object.CM_MovementLog;
		count := count + 1;

		sourceLocation := movementLog.mySourceLocation;
		targetLocation := movementLog.myTargetLocation;
		
		if sourceLocation &lt;&gt; null then
			self.getAllTAsGridRowsAndYABlocks(sourceLocation, movementLog);
		endif;
		
		if targetLocation &lt;&gt; null then
			self.getAllTAsGridRowsAndYABlocks(targetLocation, movementLog);
		endif;
	endforeach;
	
	
	object := self.allMovementsArray[1];
	movementLogArray := self.allMovementsArray;
	
	app.myTrxUA.trxCalcLocationStatsBackground(self.allTerminalAreasSet, 
											   self.allGridRowsSet,
											   self.allGridColumnSet,
											   self.allYABlocksSet, 
											   movementLogArray, 
											   app.myPassport);
	
	//
	//  Completed all 
	//
	difference := app.actualTimeServer - now;
	app.writeLog(method.name &amp; ' instances=' &amp; count.String &amp; 
				 ' allTerminalAreasSet.size=' &amp; self.allTerminalAreasSet.size.String &amp; 
				 ' allGridRowsSet.size=' &amp; self.allGridRowsSet.size.String &amp; 
				 ' allGridColumnSet.size=' &amp; self.allGridColumnSet.size.String &amp; 
				 ' allYABlocksSet.size=' &amp; self.allYABlocksSet.size.String &amp;
				 ' elapsed=' &amp; difference.getMilliseconds.String &amp; ' ms', LogINFO);
				 
	return true;
	
	
epilog
	delete objects;			// PAR #20328
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="purgeMovementLog" id="a25df876-caec-49ed-9df0-272e3aaccf9f">
        <source>purgeMovementLog(_quiet: Boolean);
//17 February 2009	cnwdw1	
//
constants
	MaximumToProcess	: Integer = 100;

vars
	movementLogArray    : ObjectArray;
	total: Integer;
begin
	if not _quiet and app.msgBox("Purge the Movement Log?", "Purge Confirmation", MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	create movementLogArray transient;
	while true do
		movementLogArray.clear();
		CM_MovementLog.allInstances(movementLogArray, MaximumToProcess, false);
		total := total + movementLogArray.size;
		if movementLogArray.size = 0 then
			break;
		endif;
		app.myTrxDA.trxPurgeMovementLog(movementLogArray, app.myPassport);
	endwhile;
	if not _quiet then
		app.msgBox(total.String &amp; " records were deleted", "Movement Log Purged", MsgBox_OK_Only);
	endif;
	
epilog
	delete movementLogArray;
end;</source>
        <Parameter name="_quiet" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rebuildStats" id="5579d52b-c5c0-4c05-a3c6-ceef83d74c3d">
        <source>rebuildStats( _yaEntityObj : CM_YAEntity; _terminalArea : CM_TerminalArea );

// 18 February 2009	cnwdw1	
// Rebuilds the statistics for the specified Yard Allocation entity a Yard Allocation or for a Terminal Area.
// Changed by cnwrl1 21/04/2009 PAR 19463/19330 - to handle Terminal Areas.
	
vars
	blockObj			: CM_YABlock;
	arrayObj			: ObjectArray;
	blockSetObj			: CM_YABlockSet;
	termAreaSet			: CM_TerminalAreaSet;
	
begin
	if _yaEntityObj = null and _terminalArea = null then
		return;
	endif;
	
	create blockSetObj transient;
	create termAreaSet transient;
	
	if _yaEntityObj &lt;&gt; null then
		if _yaEntityObj.isKindOf( CM_YABlockGroup ) then
			foreach blockObj in _yaEntityObj.CM_YABlockGroup.allYABlocksIn do
				blockSetObj.add( blockObj );
			endforeach;
		elseif _yaEntityObj.isKindOf( CM_YABlock ) then
			blockSetObj.add( _yaEntityObj.CM_YABlock );
		else
			foreach blockObj in _yaEntityObj.CM_YardAllocation.allYABlocksIn do
				blockSetObj.add( blockObj );
			endforeach;
		endif;
	else
		termAreaSet.addNoDuplicates( _terminalArea, false );
	endif;
	
	app.myTrxUA.trxCalcLocationStats( termAreaSet, blockSetObj, arrayObj, app.myPassport );
	
epilog
	delete blockSetObj;
	delete termAreaSet;
	
end;</source>
        <Parameter name="_yaEntityObj" type="CM_YAEntity"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setupFromInitializationFile" id="9201702e-21da-43f8-855e-3969ea1bd7a6">
        <updating/>
        <source>setupFromInitializationFile() updating, protected;

/*

Purpose:			Get the relevant options from the ini file, and save them.
					Set the defaults if necessary

Parameters:			None

Return Value:		None


Date		Who		Reason
22 Jul 2009	cnwkpd1	PAR #20328 - Fix problem with SDS tracking
					Also "soften" up runtime settings to add tuning ability

*/

constants
	SectionName				= "BackgroundLocationStatistics";
	MinimumAgeToProcess		= "MinimumAgeToProcess";
	TimerIntervalCatchUp	= "TimerIntervalCatchUp";
	TimerIntervalNormal		= "TimerIntervalNormal";
	MaximumNumberToProcess	= "MaximumNumberToProcess";
	DummyValue				= "Dummy";
	
vars
	iniValue,
	iniFileName		: String;
	integerValue	: String;
	
begin
	iniFileName := app.getIniFileNameAppServer;
	
	// Get each of the required values, setting the default for any not found
	
	// Maximum number of objects to process per transaction
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, MaximumNumberToProcess, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, MaximumNumberToProcess, "20");
		self.maximumNumberToProcess:= 20;
	elseif iniValue.isInteger then
		self.maximumNumberToProcess := iniValue.Integer;
	endif;
	// Must process at least one per trx
	self.maximumNumberToProcess := self.maximumNumberToProcess.max(1);
	app.writeLog('Maximum number of logs per transaction set to ' &amp; self.maximumNumberToProcess.String, LogINFO);
	
	// Minimum object age to process (in seconds)
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, MinimumAgeToProcess, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, MinimumAgeToProcess, "30");
		self.minimumAgeToProcess := 30000;
	elseif iniValue.isInteger then
		self.minimumAgeToProcess := iniValue.Integer * 1000;
	endif;
	// Can be zero, but this could cause issues in SDS system prior to JADE 6.2.18
	app.writeLog('Minimum object age to process set to ' &amp; self.minimumAgeToProcess.String, LogINFO);

	// Normal timer interval (in seconds)
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, TimerIntervalNormal, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, TimerIntervalNormal, "30");
		self.timerIntervalNormal := 30000;
	elseif iniValue.isInteger then
		self.timerIntervalNormal := iniValue.Integer * 1000;
	endif;
	// Must be at least 1 second
	self.timerIntervalNormal := self.timerIntervalNormal.max(1000);
	app.writeLog('Normal timer interval set to ' &amp; self.timerIntervalNormal.String, LogINFO);

	// Catchup timer interval (in seconds)
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, TimerIntervalCatchUp, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, TimerIntervalCatchUp, "1");
		self.timerIntervalCatchUp := 1000;
	elseif iniValue.isInteger then
		self.timerIntervalCatchUp := iniValue.Integer * 1000;
	endif;
	// Can be zero (although not recommended)
	app.writeLog('Catch up timer interval set to ' &amp; self.timerIntervalCatchUp.String, LogINFO);

	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="9d20ae3e-abcb-4506-9bb9-570bb3e62841">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Aug 2008	conkc1	Initial creation
22 Jul 2009	cnwkpd1	PAR #20328 - Fix problem with SDS tracking
					Also "soften" up runtime settings to add tuning ability

*/

vars
	logsWereProcessed,
	startTimer		: Boolean;
	
begin
	// 33632 make SDS-aware and do nothing
	if app.isSDSSecondaryDB() then
		return;
	endif;

	if eventTag = EVENT_LOCATION_STATS_TIMER then
		startTimer := true;
		logsWereProcessed := self.processMovementLog();
	endif;
	
	
epilog
	// 33632 make SDS-aware
	if not app.isSDSSecondaryDB() then
		if startTimer then
			if logsWereProcessed then
				self.beginTimer(self.timerIntervalCatchUp, Timer_OneShot, EVENT_LOCATION_STATS_TIMER);
			else
				self.beginTimer(self.timerIntervalNormal, Timer_OneShot, EVENT_LOCATION_STATS_TIMER);
			endif;
		endif;
	endif;
		
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
