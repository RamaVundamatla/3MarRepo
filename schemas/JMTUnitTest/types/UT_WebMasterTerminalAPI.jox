vars
	
	existingCustomer_woRel				: String;
	existingCustomer_woRel_Desc			: String;
	
	existingCustomer_withRel			: String;
	existingCustomer_withRel_Desc		: String;	
	
	nonExistingCustomer					: String;
	nonExistingCustomer_Desc 			: String;
	
	existingCustomer_woSpConf			: String;
	existingCustomer_woSpConf_Desc		: String;
	
	existingCustomer_withSpConf			: String;
	existingCustomer_withSpConf_Desc	: String;
	
	params 								: String;
	response,
 	errors								: String;
begin
	params := "/"&amp;CustomerId; // navlw1
	existingCustomer_withRel := params &amp; "?MasterTerminalAPI&amp;IncludeRelatedEntities=true";
	existingCustomer_withRel_Desc :="existingCustomer_withRel";	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomer.name, existingCustomer_withRel, existingCustomer_withRel_Desc, response, errors);	
	self.assertEqualMsg(response,ResponseWithRelatedEnt,"Response should match with the customer and should include related entities");
	self.assertNullMsg(errors, "We should have no errors");
	
	existingCustomer_woRel := params &amp; "?MasterTerminalAPI&amp;IncludeRelatedEntities=false";
	existingCustomer_woRel_Desc :="existingCustomer_woRel";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomer.name, existingCustomer_woRel, existingCustomer_woRel_Desc, response, errors);	
	self.assertEqualMsg(response,ResponsewithNoRelatedEnt,"Response should match with the customer and should include related entities");
	self.assertNullMsg(errors, "We should have no errors");
		
	// customer does not exist check
	nonExistingCustomer := "/XYZ?MasterTerminalAPI&amp;IncludeRelatedEntities=true";
	nonExistingCustomer_Desc := "nonExistingCustomer ";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse","Code :96646. A customer with code XYZ was not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomer.name, nonExistingCustomer, nonExistingCustomer_Desc, response, errors);
	self.assertNullMsg(errors, "We should have no errors");

	self.opts.purge();
	existingCustomer_withSpConf := params &amp; "?MasterTerminalAPI&amp;IncludeTerminalSpecificConfig=true";		// 26.02.24		navhn30		TFS #59198
	existingCustomer_withSpConf_Desc :="existingCustomer_withSpConf";	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomer.name, existingCustomer_withSpConf, existingCustomer_withSpConf_Desc, response, errors);
	if app.isRunningInDMAST() then
		self.assertEqualMsg(response,ResponseWithSpecificConfig,"Response should match with the customer and should contain Specific config");
	elseif app.isRunningInWMAST() then
		self.assertEqualMsg(response,ResponseWirhSpecificConfigWmast,"Response should match with the customer and should contain Specific config");
	endif;
	self.assertNullMsg(errors, "We should have no errors");
	
	existingCustomer_woSpConf := params &amp; "?MasterTerminalAPI&amp;IncludeTerminalSpecificConfig=false";
	existingCustomer_woSpConf_Desc :="existingCustomer_woSpConf";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomer.name, existingCustomer_woSpConf, existingCustomer_woSpConf_Desc, response, errors);
	self.assertEqualMsg(response,ResponseWithNoSpecificConfig,"Response should match with the customer and should not contain Specific config");
	self.assertNullMsg(errors, "We should have no errors");
epilog
	
end;</source>
