    <JadeMethod name="translateForm" id="1874f746-cd9e-4da0-88c1-f829d687d3be">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 July 2018 14:27:08.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022739, locale);
	btnBulk.translateBubbleHelp(Xlat_0022740, locale);
	btnBulk.translateCaption(Xlat_0022741, locale);
	btnDelete.translateBubbleHelp(Xlat_0022742, locale);
	btnDelete.translateCaption(Xlat_0022743, locale);
	btnNew.translateBubbleHelp(Xlat_0022744, locale);
	btnNew.translateCaption(Xlat_0022745, locale);
	btnNewType.translateBubbleHelp(Xlat_0022746, locale);
	btnNewType.translateCaption(Xlat_0022747, locale);
	btnUpdate.translateBubbleHelp(Xlat_0022748, locale);
	btnUpdate.translateCaption(Xlat_0022749, locale);
	mnuFPDate.translateCaption(Xlat_0022750, locale);
	mnuFPDelete.translateCaption(Xlat_0022751, locale);
	mnuFPMain.translateCaption(Xlat_0022752, locale);
	mnuFPType.translateCaption(Xlat_0022753, locale);
	mnuFPUpdate.translateCaption(Xlat_0022754, locale);
	mnuInspect.translateCaption(Xlat_0022755, locale);
end;</source>
    </JadeMethod>
</GUIClass>
