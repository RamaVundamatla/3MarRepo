    <JadeMethod name="isCMIFDataMatch" id="acec205a-561f-4ced-8935-274defe71862">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 January 2023
TFS#		: 55588
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _cmifAutoPlan.isKindOf(CMIF_YAAutoPlanNormal) then
		return _cmifAutoPlan.CMIF_YAAutoPlanNormal.isHSCode_Match(_yaData);
	endif;
	
	return false;
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimitiveValue" id="e15dee7f-9213-40b2-a394-b3aa41c4bd4b">
        <source>isPrimitiveValue(): Boolean;
/*****************************************************
