    <JadeMethod name="getDebtorForInvoiceLine" id="76508569-eefa-4300-a8af-39b0504f1a43">
        <source>getDebtorForInvoiceLine(_invLineDesc : CM_InvoiceLineDesc) : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
01.06.2022 	navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	doLog				  : Boolean;
	debtor				  : CM_Debtor;
	tmpCode,
	lMessageText		  : String;
	tmpConsigneeOr		  : CM_ConsigneeConsignor;
	tmpVoyage			  : CM_Voyage;
	tranOperator, 
	tmpOperator			  : CM_Operator;
	tmpCarrier			  : CM_Carrier;
	myDebtorTypeCode 	  : String;
	deriveDebtorTypeFrom  : CM_DebtorType;
	debtorType 			  : CM_DebtorType;
	tmpStevedore 		  : CM_Stevedore;
	tmpShipLine			  : CM_ShippingLine; 	// 01.06.2022 navak20 TFS 53195

begin
	
	doLog 	:=  app.canLogExtraDetail(); 		//28.02.2025 navah1	#34141
	tmpCode := self.operatorCode;
	
	if tmpCode &lt;&gt; null then
		tranOperator := app.myRoot.allOperators[tmpCode];
	endif;
	
	deriveDebtorTypeFrom := _invLineDesc.myDebtorType;
	if deriveDebtorTypeFrom &lt;&gt; null then
		myDebtorTypeCode := deriveDebtorTypeFrom.code;
	
		if myDebtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
			lMessageText := "Inventory Debtor for Cargo Operator Charge";
			tmpCode := self.operatorCode;
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpOperator, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			lMessageText := "Inventory Debtor for Consignee Charge";
			tmpCode := self.consignee;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpConsigneeOr, self ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			lMessageText := "Inventory Debtor for Consignor Charge";
			tmpCode := self.consignor;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpConsigneeOr, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			lMessageText := "Inventory Debtor for Ship Operator Charge";
			tmpVoyage := self.getVoyage();
			if tmpVoyage &lt;&gt; null then // AKB October 2001 - PAR 1518.
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then // AKB October 2001 - PAR 1518.
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpOperator, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;

		elseif myDebtorTypeCode = CM_DebtorType.DT_CARRIER then
			lMessageText := "Debtor for Carrier Charge";
				tmpCode := self.carrierCode;
				if tmpCode &lt;&gt; null then
					tmpCarrier := app.myRoot.allCarriers[tmpCode];
					if tmpCarrier &lt;&gt; null then
						// ### Check for any mappings
						debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpCarrier, self );
						if debtorType = null then // no charge mappings so carry on
							debtor := tmpCarrier.myDebtor;
							if doLog and debtor &lt;&gt; null then
								app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
							endif;
						else
							debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
						endif;
					endif;
				endif;

		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then
			lMessageText := "Debtor for Stevedore for Receive Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpStevedore, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then 
			lMessageText := "Debtor for Stevedore for Release Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpStevedore, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;
		endif;
		
		// 01.06.2022 navak20 TFS 53195 Start
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE then
			lMessageText := "Debtor for Shipping Line";
			//tmpCode := self.myTrackedItem.getShippingLineCode();	//13/07/2022 navgm20 Tfs 53195
			//if tmpCode &lt;&gt; null then
			tmpShipLine := self.myTrackedItem.myShippingLine;
			if tmpShipLine &lt;&gt; null then
				// ### Check for any mappings
				debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpShipLine, self );
				if debtorType = null then // no charge mappings so carry on
					debtor := tmpShipLine.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				else
					debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
				endif;
			endif;
			//endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then
			lMessageText := "Debtor for Shipping Line Description";
			tmpCode := self.myTrackedItem.getShippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapInventory( _invLineDesc, tmpShipLine, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpShipLine.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeInventory(debtorType, self);
					endif;
				endif;
			endif;
		// TFS 53195 End
	
	endif;
	
	if debtor &lt;&gt; null then
		if debtor.isSuspended then
			if doLog and debtor &lt;&gt; null then
				app.invLog(debtor.name &amp; " is suspended, not used", LogTRACE.String);
			endif;
			debtor := null;
		endif;
	endif;
	
	if debtor = null then	
		debtor := self.getDefaultDebtorForEvent(doLog);
	endif;

	return debtor;
	

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDebtorForEvent" id="41f342ea-7c7e-46fb-a425-46eac7cee011">
        <source>getDefaultDebtorForEvent(doLog : Boolean) : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/


vars
	tmpTerminal : CM_Terminal;
	debtor : CM_Debtor;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141 
	tmpTerminal := self.myTerminal;
	debtor := tmpTerminal.getConfig(DefDebtor).CM_Debtor;
	if doLog and debtor &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Default debtor for terminal " &amp; debtor.name, LogTRACE.String);
		endif;
	endif;
	if debtor = null then
		debtor := app.myRoot.myRootCompany.debtors["RDT"];
		if doLog and debtor &lt;&gt; null then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("RDT debtor " &amp; debtor.name, LogTRACE.String);
			endif;
		endif;
	endif;

	return debtor;

end;</source>
        <Parameter name="doLog" type="Boolean"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="04bc86ba-d12a-4282-9604-168d102feacc">
        <source>getDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	returnVal : String;
	amountStr : String;

begin

	amountStr := self.getAmountString( true, null ); // ### TFS 51515 13JUL2021 NAVAB1
	
	if self.isLocationMove then
		returnVal := "Moved " &amp; amountStr &amp; " from " &amp; self.sourceLocationStr &amp; " to " &amp; self.targetLocationStr &amp; " for " &amp; self.operatorCode;
	
	elseif self.isLocationDiscrepancyDecrease then
		returnVal := "Decrease in " &amp; self.sourceLocationStr &amp; " for " &amp; self.operatorCode &amp; " of " &amp; amountStr;
	
	elseif self.isLocationDiscrepancyIncrease then
		returnVal := "Increase in " &amp; self.targetLocationStr &amp; " for " &amp; self.operatorCode &amp; " of " &amp; amountStr;
		
	elseif self.isLocationBalance then
		returnVal := "Balance in " &amp; self.targetLocationStr &amp; " for " &amp; self.operatorCode &amp; " of " &amp; amountStr;
	
	endif;
	
	return returnVal;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayColour" id="2e46e738-67d1-4d0e-83d6-0c7c4f17f7e9">
        <source>getDisplayColour( _defaultColour : Integer ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	/* // ### TFS 51515 13JUL2021 NAVAB1
	if self.isLocationBalance then
		return LightGray;
	elseif self.dateTime &lt; app.actualTimeAppServer.cnEcAddDays( ( self.myTerminal.getLocationActivityMaxDays() * -1 ) ) then
		return LightGray;
	elseif self.hasBeenEdited then
		return LightYellow;
	else
		return _defaultColour;
	endif;
	*/
	
	if self.needsRecalculation then
		return LightYellow;
	else
		return White;
	endif;
epilog

end;</source>
        <Parameter name="_defaultColour" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="b9fdc650-2ae2-472c-b39c-c715cf49498d">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	
	if self.sourceLocationStr &lt;&gt; null and self.targetLocationStr &lt;&gt; null then
		return self.myEventType.name &amp; ' ' &amp; self.sourceLocationStr &amp; "/" &amp; self.targetLocationStr;
	elseif self.sourceLocationStr &lt;&gt; null then
		return self.myEventType.name &amp; ' ' &amp; self.sourceLocationStr;
	elseif self.targetLocationStr &lt;&gt; null then
		return self.myEventType.name &amp; ' ' &amp; self.targetLocationStr;
	endif;


	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="ed13bcee-2d9e-42e0-9a1d-5192cac2c4e5">
        <source>getDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.isLocationBalance then
		return "Balance";
		
	elseif self.isLocationDiscrepancyDecrease then
		return "Discrepancy";
		
	elseif self.isLocationDiscrepancyIncrease then
		return "Discrepancy";
		
	elseif self.isLocationMove then
		if self.mySourceVoyage &lt;&gt; null then
			return self.mySourceVoyage.idForLocationActivity;
		elseif self.mySourceTrain &lt;&gt; null then
			return self.mySourceTrain.code;
		elseif self.mySourceVVR &lt;&gt; null then
			return self.mySourceVVR.idForLocationActivity;
		elseif self.mySourceLocation &lt;&gt; null then
			return self.mySourceLocation.getFullId;	
		elseif self.myTargetVoyage &lt;&gt; null then
			return self.myTargetVoyage.idForLocationActivity;
		elseif self.myTargetTrain &lt;&gt; null then
			return self.myTargetTrain.code;
		elseif self.myTargetVVR &lt;&gt; null then
			return self.myTargetVVR.idForLocationActivity;
		elseif self.myTargetLocation &lt;&gt; null then
			return self.myTargetLocation.getFullId;
		endif;
	
	else
		return inheritMethod;
		
	endif;
	
	return "Unknown";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7ae139c6-2d45-46ed-9c39-5d44487d8e16">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Apr 2021	navndl1	Initial creation	TFS	50906 
20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
*/

vars

	oper : CM_Operator;
	str, type : String;
	iCarrier : CM_Carrier;
	steveObj : CM_Stevedore;		// TFS 53362
begin

	if _attrName = ETRow_CargoTypeDescr then
		return self.getCargoTypeDescr();		
	elseif _attrName = ETRow_CarrierReference or _attrName = ETRow_CarrierCode or _attrName = ETRow_Carrier then
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean then  
			iCarrier := app.myRoot.allCarriers[self.carrierCode];
			if iCarrier&lt;&gt; null then
				return iCarrier.description;
			endif;
		endif;
		return self.carrierCode;
		
	elseif _attrName = ETRow_HasBeenEdited then
		return self.hasBeenEdited.getYesNo;
		
	elseif _attrName = ETRow_NeedsRecalculation then
		return self.needsRecalculation.getYesNo;
		
	elseif _attrName = ETRow_SourceLocation then
		return self.sourceLocationStr;
		
	elseif _attrName = ETRow_SourceTA then
		return self.getSourceTerminalAreaId();
		
	elseif _attrName = ETRow_SourceTrain then
		return self.getSourceTrain();
		
	elseif _attrName = ETRow_SourceVVR then
		return self.getSourceVvrVisitNumber();
		
	elseif _attrName = ETRow_SourceVoyage then
		return self.getSourceVoyageCode();
		
	elseif _attrName = ETRow_TargetLocation then
		return self.targetLocationStr;
		
	elseif _attrName = ETRow_TargetTA then
		return self.getTargetTerminalAreaId();
		
	elseif _attrName = ETRow_TargetTrain then
		return self.getTargetTrain();
		
	elseif _attrName = ETRow_TargetVVR then
		return self.getTargetVvrVisitNumber();
	
	elseif _attrName = ETRow_TargetVoyage then
		return self.getTargetVoyageCode();
		
	elseif _attrName = ETRow_Amount then
		return self.getAmountString(false, null);
		
	elseif _attrName = ETRow_Stevedore or  _attrName = ETRow_StevedoreCode then 
		// TFS 53362 start of this bit
		if app.myRoot.getConfig(ComboByNameStevedore).Boolean and _attrName = ETRow_Stevedore then
			steveObj := app.myRoot.allStevedores[self.stevedoreCode];
			if steveObj &lt;&gt; null then
				return steveObj.description;
			endif;
		endif;
		// TFS 53362 end of this bit
		return self.stevedoreCode;
		
	elseif _attrName = ETRow_CargoId then
		return self.getCargoId();
		
	elseif _attrName = ETRow_User or _attrName = ETRow_UserName or _attrName = ETRow_UserId then
		return self.getUserId();
		
	elseif _attrName = ETRow_LocActQuantity then
		return self.getQuantityString;
		
	elseif _attrName = ETRow_LocActVolume then
		return self.getVolumeString;
		
	elseif _attrName = ETRow_LocActWeight then
		return self.getWeightString;
		
	elseif _attrName = ETRow_Source then
		return self.getSourceDisplay;
		
	elseif _attrName = ETRow_Target then
		return self.getTargetDisplay;
		
	elseif _attrName = ETRow_Operator then
		oper := self.getOperator;
		if oper &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return oper.description;								// TFS 53362
			else														// TFS 53362
				return oper.code;
			endif;														// TFS 53362
		endif;
		return null;
	elseif _attrName.isMeasurementType then 							// ### TFS 51515 13JUL2021 NAVAB1
		_attrName.getRowNameMeasureType(str, type); 					// ### TFS 51515 13JUL2021 NAVAB1
		return self.getMeasurementStringForAttrib(str, type, _short);   // ### TFS 51515 13JUL2021 NAVAB1
	else
		return inheritMethod(_attrName, _short);
		
	endif;


epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForLineRep" id="75b491b6-e1fe-4bc2-88cd-2784deb5fb16">
        <source>getDisplayStringForLineRep( _relativeToLC : CM_LocationsController; _isThroughPutRep : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2021	navndl1	Initial creation	TFS 51616

*/

vars

begin

	if self.isLocationBalance then
		return "Balance";
		
	elseif self.isLocationDiscrepancyDecrease then
		return "Discrepancy";
		
	elseif self.isLocationDiscrepancyIncrease then
		return "Discrepancy";
		
	elseif self.isLocationMove then
	
		if ( not _isThroughPutRep and self.mySourceLocation = _relativeToLC )
		or  ( _isThroughPutRep and self.mySourceLocation.isActivityTrackingLocation )
		then
			//This one is considered to be going out
			if self.myTargetVoyage &lt;&gt; null then
				return self.myTargetVoyage.idForLocationActivity;
			elseif self.myTargetTrain &lt;&gt; null then
				return self.myTargetTrain.code;
			elseif self.myTargetVVR &lt;&gt; null then
				return self.myTargetVVR.idForLocationActivity;
			elseif self.myTargetLocation &lt;&gt; null then
				return self.myTargetLocation.getFullId;
			endif;
		
		endif;
	
		// _relativeToLC not supplied or not the same as teh source source location
		if self.mySourceVoyage &lt;&gt; null then
			return self.mySourceVoyage.idForLocationActivity;
		elseif self.mySourceTrain &lt;&gt; null then
			return self.mySourceTrain.code;
		elseif self.mySourceVVR &lt;&gt; null then
			return self.mySourceVVR.idForLocationActivity;
		elseif self.mySourceLocation &lt;&gt; null then
			return self.mySourceLocation.getFullId;	
		elseif self.myTargetVoyage &lt;&gt; null then
			return self.myTargetVoyage.idForLocationActivity;
		elseif self.myTargetTrain &lt;&gt; null then
			return self.myTargetTrain.code;
		elseif self.myTargetVVR &lt;&gt; null then
			return self.myTargetVVR.idForLocationActivity;
		elseif self.myTargetLocation &lt;&gt; null then
			return self.myTargetLocation.getFullId;
		endif;
	
	endif;
	
	return self.getDisplayString();

epilog

end;</source>
        <Parameter name="_relativeToLC" type="CM_LocationsController"/>
        <Parameter name="_isThroughPutRep" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEventTypeName" id="f3fe8909-2a77-4182-876d-c6c776941c52">
        <source>getEventTypeName(): String;

/*
Purpose:			

Date		Who		Reason
10JUN2021	NAVAB1	TFS 51219
*/


vars
	nicename : String;
begin
	nicename := self.myEventType.name;
	
	if self.isLocationBalance then
		nicename:= nicename  &amp; " (";
		if self.mySourceTA &lt;&gt; null then
			nicename:= nicename &amp; self.mySourceTA.id;
		endif;
		
		if self.myCargoType &lt;&gt; null
		and self.mySourceTA &lt;&gt; null then
			nicename:= nicename  &amp; " " &amp; self.myCargoType.abbreviation;
		else
			nicename:= nicename &amp; self.myCargoType.abbreviation;
		endif;
		
		nicename:= nicename &amp; ")";
	endif;
	
	return nicename;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportId" id="7864cb1b-957c-4283-bc99-a6f6be31f939">
        <source>getExportId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	if self.isLocationMove then
		if self.myTargetVoyage &lt;&gt; null then
			return self.myTargetVoyage.idForLocationActivity;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHasBeenEdited" id="d326f3dd-06df-48a8-bd5e-982b01d6f452">
        <source>getHasBeenEdited():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	return self.hasBeenEdited;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="1cde584e-2555-456f-9564-b6969ace8d06">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
15 July 2021	navab1	TFS 51515
*/

vars

begin

	if _attrName = ETRow_TotalWeightMT then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	elseif _attrName = ETRow_TotalVolumeMT then
		return app.convertMeasurementForDisplay(_measureType, self.volume);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="70788159-187a-4c42-a668-5a2aff7c7013">
        <source>getMyVoyage(): CM_Voyage;
/*

#### CM_Transaction has 'getMyVoyage' CM_Event uses 'getVoyage'


Purpose:		LOCATION EVENT INVOICING	

ASPA say to charge the voyage not the barge

Date		Who		Reason
14JUN2021	NAVAB1	TFS 51219
*/

vars

begin
	if self.mySourceVoyage &lt;&gt; null then
		if self.mySourceVoyage.isBarge then
			if self.myTargetVoyage &lt;&gt; null then
				if not self.myTargetVoyage.isBarge then
					return self.myTargetVoyage;
				endif;
			endif;

		else
			return self.mySourceVoyage;
		endif;
	endif;
	
	if self.myTargetVoyage &lt;&gt; null then
		return self.myTargetVoyage;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getNetAmountString" id="1171c6b6-7916-4a11-97f6-d0b84d228716">
        <source>getNetAmountString( _ta : CM_TerminalArea;  _lc : CM_LocationsController;  _includeCargoType : Boolean; _weightMeasurementType : CM_MeasurementType  ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	cargoType : CM_CargoType;
	returnVal : String;
	measureType : CM_MeasurementType;
	type : String;
	
	netQuantity : Integer;
	netVolume : Decimal[14,4];
	netWeight : Decimal[14,4];
	zero : Decimal[14,4];
	
	prevBalance : CMEVT_LocationActivity;

begin

	if self.isLocationBalance
	or ( _lc = null and _ta = null )
	then
		netQuantity := self.quantity;
		netVolume := self.volume;
		netWeight := self.weight;
	else
		if _lc &lt;&gt; null then
			prevBalance := _lc.getPreviousLocationBalance( self );
		elseif _ta &lt;&gt; null then
			prevBalance := _ta.getPreviousLocationBalance( self );
		endif;
		
		if _lc &lt;&gt; null then
			_lc.getNetBalance( prevBalance, self, netQuantity, netVolume, netWeight );
		elseif _ta &lt;&gt; null then
			_ta.getNetBalance( prevBalance, self, netQuantity, netVolume, netWeight );
		endif;
		
	endif;

	cargoType := self.getCargoType;
	
	if cargoType = null then
		if netVolume &lt;&gt; 0 then
			returnVal := netVolume.asStringWeightJMT &amp; " m3";
		elseif netWeight &lt;&gt; 0 then
			returnVal := netWeight.asStringWeightJMT &amp; " kg";
		elseif netQuantity &lt;&gt; 0 then
			returnVal := "x" &amp; netQuantity.asStringJMT;
		endif;
	
	else
		if cargoType.isTrackByVolume then
			measureType := cargoType.getDefaultMeasurementForType(Type_Volume);
			type := measureType.shortName;
			if netVolume &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, netVolume ) &amp; " " &amp; type;
			else
				returnVal := zero.asStringJMTWithPrecision(measureType.getDecimalPrecision, false) &amp; " " &amp; type;
			endif;
		elseif cargoType.isTrackByWeight then
			if _weightMeasurementType &lt;&gt; null then // ### TFS 51515 13JUL2021 NAVAB1
				measureType := _weightMeasurementType; // ### TFS 51515 13JUL2021 NAVAB1
			else
				measureType := cargoType.getDefaultMeasurementForType(Type_Weight);
			endif;
			
			type := measureType.shortName;
			if netWeight &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, netWeight ) &amp; " " &amp; type;
			else
				returnVal := zero.asStringJMTWithPrecision(measureType.getDecimalPrecision, false) &amp; " " &amp; type;
			endif;
		else
		//	if self.quantity &lt;&gt; 0 then
				returnVal := "x" &amp; netQuantity.asStringJMT;
		//	endif;
		endif;
		if _includeCargoType then
			returnVal := cargoType.description &amp; " " &amp; returnVal;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_includeCargoType" type="Boolean"/>
        <Parameter name="_weightMeasurementType" type="CM_MeasurementType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperator" id="9b1720e4-9aaf-4632-9d06-9c2631c87be4">
        <source>getOperator(): CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	operatorObj : CM_Operator;
	ti : CM_TrackedItem;
	
begin

	if self.myOperator &lt;&gt; null then
		return self.myOperator;
	endif;

	if self.operatorCode &lt;&gt; null then
		operatorObj :=  app.myRoot.allOperators[ self.operatorCode ];
		if operatorObj &lt;&gt; null then
			return operatorObj;
		endif;
	endif;
	
	ti := self.getTrackedItem;
	if ti &lt;&gt; null then
		operatorObj := ti.myOperator;
		if operatorObj &lt;&gt; null then
			return operatorObj;
		endif;
	endif;
	
	return inheritMethod;

epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getOriginalTiTrx" id="4735b319-6b02-4405-9c8c-a17c7e893f45">
        <source>getOriginalTiTrx():CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2021	navndl1	Initial creation	TFS 50906

*/

vars

	invalid : Boolean;
	edition : Integer;

begin

	if self.myOriginalTiTrx = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, self.myOriginalTiTrx, invalid );
	
	edition := self.myOriginalTiTrx.edition;
	
	if invalid then
		return null;
	endif;
	
	return self.myOriginalTiTrx;
	
	


epilog

end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getQuantityString" id="3ff15c6b-8a27-441f-8761-0fac0a19ed96">
        <source>getQuantityString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906 

*/

vars

begin

	if self.quantity = 0 then
		return null;
	else
		return self.quantity.asStringJMT;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportingCount" id="57f40957-e23c-4014-af52-6b4f701cccba">
        <source>getReportingCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2021	navndl1	Initial creation	TFS 51245
18 June 2021 - rule change, we now have 4 configs to choose from
22 June 2021 - Rule change, we now just get the associated train and use its event count or return 1.
13 Jul 2021	- Change to use eth new attributes

*/

vars

	countObject : CM_Object;
	train : CM_Train;
	voyage : CM_Voyage;
	eventType : CM_EventType;
	event : CM_EventTransaction;

begin
	
	countObject := null;
	
	//22 Jun 2021 - rule change 2.
	if self.movementDirection.isOneOf(	LocnActMoveDir_RailToYard,
						LocnActMoveDir_RailToVessel
						) then
		if self.mySourceTrain &lt;&gt; null then
			countObject := self.mySourceTrain;
		endif;
		
	elseif self.movementDirection.isOneOf(	LocnActMoveDir_VesselToRail,
							LocnActMoveDir_YardToRail
							) then
		if self.myTargetTrain &lt;&gt; null then
			countObject := self.myTargetTrain;
		endif;
	endif;
		
	
	if countObject &lt;&gt; null then
		if countObject.isKindOf( CM_Train ) then
			train := countObject.CM_Train;
			//18 June 2021  - rule change, now there are 4 different configs required.
			//eventType := self.myTerminal.getConfig( LocActRailEventCount ).CM_EventType;
			if self.movementDirection = LocnActMoveDir_RailToYard then
				eventType := self.myTerminal.getConfig( LocActRailToYard ).CM_EventType;
			elseif self.movementDirection = LocnActMoveDir_RailToVessel then
				eventType := self.myTerminal.getConfig( LocActRailToVessel ).CM_EventType;
			elseif self.movementDirection = LocnActMoveDir_VesselToRail then
				eventType := self.myTerminal.getConfig( LocActVesselToRail ).CM_EventType;
			elseif self.movementDirection = LocnActMoveDir_YardToRail then
				eventType := self.myTerminal.getConfig( LocActYardToRail ).CM_EventType;
			endif;
			
			if eventType &lt;&gt; null then
				event := train.allTransactions.getFirstOfType( eventType.type );
			endif;
			if event &lt;&gt; null then
				return event.amount.Integer;
			endif;

		endif;
		
	endif;
	
	return 1;  // They probably just haven't put in an event for the count or its the wrong type...

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReportingServiceDate" id="4a78b2d8-5b49-4d7d-809f-17be6b305c3a">
        <source>getReportingServiceDate():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	returnTS : TimeStamp;

begin

	returnTS := null;
	
	if self.directionType = self.TypeStorage then
		//we care about the input side
		if self.movementDirection = LocnActMoveDir_RailToYard then
			if self.mySourceTrain &lt;&gt; null then
				returnTS := self.mySourceTrain.getServiceDate();
			endif;
			
		elseif self.movementDirection.isOneOf(	LocnActMoveDir_BargeToYard,
										LocnActMoveDir_VesselToYard
										) then
			if self.mySourceVoyage &lt;&gt; null then
				returnTS := self.mySourceVoyage.getServiceDate();
			endif;
		endif;
						
	elseif self.directionType = self.TypeExport then
		//we care about the output side
		if self.movementDirection.isOneOf(	LocnActMoveDir_BargeToVessel,
									LocnActMoveDir_RailToVessel,
									LocnActMoveDir_YardToVessel
									) then
			if self.myTargetVoyage &lt;&gt; null then
				returnTS := self.myTargetVoyage.getServiceDate();
			endif;
		endif;
		
	elseif self.directionType =self.TypeDomestic then
		if self.movementDirection.isOneOf(	LocnActMoveDir_VesselToBarge,
									LocnActMoveDir_YardToBarge) then
			if self.myTargetVoyage &lt;&gt; null then
				returnTS := self.myTargetVoyage.getServiceDate();
			endif;
		elseif self.movementDirection.isOneOf(	LocnActMoveDir_VesselToRail,
										LocnActMoveDir_YardToRail
										) then
			if self.myTargetTrain &lt;&gt; null then
				returnTS := self.myTargetTrain.getServiceDate();
			endif;
		endif;
		
	endif;
	
	if returnTS &lt;&gt; null and returnTS.date.isValid then
		return returnTS.date;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getSourceDisplay" id="f8864bc2-dd4b-4544-b8b1-ffbe50ac6bcb">
        <source>getSourceDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	obj : Object;
	edition : Integer;
	invalid : Boolean;

begin

	if self.isLocationDiscrepancyIncrease then
		return null;
	endif;

	if self.sourceLocationStr &lt;&gt; null then
		return self.sourceLocationStr;
	endif;
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );
	
	if self.mySourceLocation &lt;&gt; null then
		obj := self.mySourceLocation;
		edition := obj.edition;
		if not invalid then
			return self.mySourceLocation.getFullId();
		endif;
		invalid := false;
	endif;
	
	if self.mySourceTA &lt;&gt; null then
		obj := self.mySourceTA;
		edition := obj.edition;
		if not invalid then
			return self.mySourceTA.id;
		endif;
		invalid := false;
	endif;
	
	if self.mySourceTrain &lt;&gt; null then
		obj := self.mySourceTrain;
		edition := obj.edition;
		if not invalid then
			return self.mySourceTrain.getCodeDate();
		endif;
		invalid := false;
	endif;
	
	if self.mySourceVVR &lt;&gt; null then
		obj := self.mySourceVVR;
		edition := obj.edition;
		if not invalid then
			return self.mySourceVVR.idForLocationActivity();
		endif;
		invalid := false;
	endif;
	
	if self.mySourceVoyage &lt;&gt; null then
		obj := self.mySourceVoyage;
		edition := obj.edition;
		if not invalid then
			return self.mySourceVoyage.idForLocationActivity();
		endif;
		invalid := false;
	endif;
	
	return app.getErrorString( Unknown );

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceParentLocation" id="dae51ee7-c64d-48c0-8827-d60b14ad746a">
        <source>getSourceParentLocation( _childObj : CM_LocationsController output ):CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS	50906 

*/

vars

	obj : CM_Object;

begin

	obj := self.mySourceTA;
	if obj = null then
		obj := self.mySourceVoyage;
		if obj = null then
			obj := self.mySourceTrain;
			if obj = null then
				obj := self.mySourceVVR;
			endif;
		endif;
	endif;
	
	_childObj := self.mySourceLocation;
	
	return obj;

epilog

end;</source>
