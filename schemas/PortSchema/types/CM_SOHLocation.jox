    <JadeMethod name="recalcSummaryData" id="195b1f6f-2dce-48e6-96ac-15a660760288">
        <updating/>
        <source>recalcSummaryData() updating;
// ---------------------------------------------------------------------------
// Created:     09 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
	sohQty,
	totQty : 	Integer;
	sohWeight,
	totWeight	: Decimal[14,4];
	sohVol,
	totVol		: Decimal[16,4];

begin

	self.currentQuantity 	:= 0;
	self.currentVolume		:= 0;
	self.currentWeightKgs	:= 0;
	
	foreach tmpTI in self.allTrackedItems discreteLock do
		tmpTI.getSOHValues(sohQty, sohWeight, sohVol);
		totQty		:= totQty + sohQty;
		totWeight	:= totWeight + sohWeight;
		totVol		:= totVol + sohVol;
	endforeach;
	
	self.currentQuantity	:= totQty;
	self.currentVolume		:= totVol;
	self.currentWeightKgs	:= totWeight;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;

	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a91927e6-ae51-4a49-869e-551691156bc8">
        <updating/>
        <source>setForCreate(_locationsController : CM_LocationsController; _product : CM_Product) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myLocationsController &lt;&gt; _locationsController then
			if self.myLocationsController &lt;&gt; null then
				self.updateObjectEdition(self.myLocationsController);
			endif;
			if _locationsController &lt;&gt; null then
				self.updateObjectEdition(_locationsController);
			endif;
		endif;
	endif;

	self.myLocationsController	:= _locationsController;
	self.myProduct				:= _product;
	
	inheritMethod(_locationsController, _product);

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
</Class>
