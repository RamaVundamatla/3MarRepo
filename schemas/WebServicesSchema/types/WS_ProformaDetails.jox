    <JadeMethod name="setValuesFromCMIF" id="65a4ec5f-22d0-4ee4-b39d-bcb360c369f5">
        <updating/>
        <source>setValuesFromCMIF(_cashPayment : CM_CashPayment; _cashCredit : CM_CashCredit) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63402  Task 63403: Jade - REST API getProformaDetailsForDebtor

*/

vars
	cashReceipt		: CM_CashReceipt;
	wsHeader		: WS_ProformaHeader;
	object 			: Object;
	cashPayment 	: CM_CashPayment;
	cashCredit 		: CM_CashCredit;
	wsDetail		: WS_ProformaDetails;
	number			: Integer;
	debtorType		: CM_DebtorType;
	id				: String;
begin
	
	if _cashPayment &lt;&gt; null then
		cashReceipt := _cashPayment.myCashReceipt;
		
		self.amountValue := _cashPayment.getActualCashValue();
		self.manual := _cashPayment.isManual();
		self.statusString := _cashPayment.getStatusDescription(_cashPayment.status);
		self.cargoDetails := _cashPayment.getCargoDetails();
		//self.cashValue := _cashPayment.cashValue.asStringJSON(); 
		self.cashValue := _cashPayment.cashValue.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
		self.chequeNumber := _cashPayment.getChequeNumber();
		self.customsEntryNumber := _cashPayment.getCustomsEntryNumber();
		self.description := _cashPayment.getDescription();
		self.service := _cashPayment.getServiceName();
		self.taxAmount := _cashPayment.getTaxAmountForPayment();
		self.taxCode := _cashPayment.getTaxCode(true);
		//self.cargoType := _cashPayment.getTrackedItemCargoType().asStringJSON();
		self.cargoType := _cashPayment.getTrackedItemCargoType().asStringJMT(); //23/08/2024	navkc1 Bug 65781
		self.cargoId := _cashPayment.getTrackedItemId();
		self.vesselName := _cashPayment.getVesselName();
		self.voyageCode := _cashPayment.getVoyageCode();
		//self.quantity := _cashPayment.getPaymentQuantity().Integer;
		self.quantity := _cashPayment.getPaymentQuantity(); // navkc1	31/03/2025 JIRA MTN-34487
		self.rate := _cashPayment.getPaymentRate();  // ### TFS CR 66288 26SEP2024 NAVAB1
	endif;
	
epilog

end;</source>
        <Parameter name="_cashPayment" type="CM_CashPayment"/>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
    </JadeMethod>
</Class>
