    <JadeMethod name="qryRailShiftKPI" id="21a993d2-4bee-40f9-ab0d-67c5e9c11a16">
        <updating/>
        <source>qryRailShiftKPI(_filter : CMQF_RailShiftKPI input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	jrwTrans : CM_JRWTrain;
	
begin
	
	jrwTrans := self.createJRWTransient(CM_JRWTrain).CM_JRWTrain;
	jrwTrans.processDate := _filter.processDate;
	//epr par 32220 12/12/13 
	if jrwTrans.processDate = null then
		jrwTrans.processDate:=_filter.baseDate;
	endif;
	app.writeLog("Rail Shift KPI process date " &amp; jrwTrans.processDate.asStringJMT,0);
	if not _filter.allTerminals.isEmpty then
		_filter.allTerminals.copy(jrwTrans.allTerminals);
	endif;
	return 1;
	
epilog

end;</source>
        <Parameter name="_filter" type="CMQF_RailShiftKPI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryReefer" id="04fda34e-04e1-4201-8ad2-36d6ca4fae36">
        <updating/>
        <source>qryReefer(_filter : CMQF_FilterReports input; _passport : CM_Passport input) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		29 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	numSelected 		: Integer;
	jrwTrans			: CM_JRWContainer;
	tiFilter			: CMQF_Reefer;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_Reefer;
	jrwTrans := self.createJRWTransient(CM_JRWContainer).CM_JRWContainer;
	jrwTrans.allTrackedItems.clear();
	_filter.filterObjects(jrwTrans.allTrackedItems, _passport);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.myOperator := tiFilter.myOperator;
	jrwTrans.qryStartDate := tiFilter.startDate;
	jrwTrans.qryEndDate := tiFilter.endDate;
	jrwTrans.myTerminalArea := tiFilter.getMyTerminalArea;
	jrwTrans.myVoyage := tiFilter.getMyVoyage;
	jrwTrans.connected := tiFilter.connected;
	jrwTrans.connectDT.setDate(tiFilter.onDate);
	jrwTrans.connectDT.setTime(tiFilter.onTime);
	
	jrwTrans.qryVoyageJobs := tiFilter.getVoyageJobIDs();
	
	if tiFilter.saveToWorkList then
		app.myTrxUA.trxUpdateReeferConnectList(jrwTrans.allTrackedItems, _passport);
	endif;
		
	numSelected := jrwTrans.allTrackedItems.size; 

epilog
	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryResourceUsage" id="a15986c0-b397-42a6-bb8a-0537b3a93dc4">
        <updating/>
        <source>qryResourceUsage(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWResourceUsage;
	resourceUsageFilter	: CMQF_ResourceUsage;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	resourceUsageFilter := _filter.CMQF_ResourceUsage;
	jrwTrans := self.createJRWTransient(CM_JRWResourceUsage).CM_JRWResourceUsage;
	
	jrwTrans.allResourceUsages.clear();
	_filter.filterObjects(jrwTrans.allResourceUsages, _passport);
	
	jrwTrans.setAllTerminals(resourceUsageFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= resourceUsageFilter.myOperator;
	
	jrwTrans.startDate 	:= resourceUsageFilter.startDate;
	jrwTrans.endDate	:= resourceUsageFilter.endDate;
	
	//19 Oct 2010	NDL	Par 23800
	jrwTrans.myVoyage 	:= resourceUsageFilter.getMyVoyage;
	jrwTrans.bookingRef 	:= resourceUsageFilter.bookingRef;
	jrwTrans.cargoId 	:= resourceUsageFilter.cargoId;
	jrwTrans.allToDoTaskDescs.clear();
	if not resourceUsageFilter.allToDoTaskDescs.isEmpty then
		resourceUsageFilter.allToDoTaskDescs.copy( jrwTrans.allToDoTaskDescs );
	endif;
	jrwTrans.setResourceTypeUsageSumSet();
	
	numSelected := jrwTrans.allResourceUsages.size; 

	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qrySAPActivity" id="0c169853-aea2-4153-9b95-95a0a638bf99">
        <updating/>
        <source>qrySAPActivity(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars
	filter : CMQF_SAPActivityHistory;
	jrwTrans : CM_JRWSAPActivity;
	numSelected : Integer;

begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	filter := _filter.CMQF_SAPActivityHistory;
	jrwTrans := self.createJRWTransient(CM_JRWSAPActivity).CM_JRWSAPActivity;
	
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allCMIFSAPActivityHistory, _passport);
	numSelected := jrwTrans.allCMIFSAPActivityHistory.size;
	
	return numSelected;
epilog

end;</source>
