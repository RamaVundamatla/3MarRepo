		elseif appSequenceId &gt;= 21 and appSequenceId &lt;= 36 then profile:='RTG'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 37 and appSequenceId &lt;= 61 then profile:='IMV'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 62 and appSequenceId &lt;= 66 then profile:='ShipLander'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId = 16 then profile:='ReachStacker';
		endif;/**/
		
		/*if      appSequenceId =  0 then profile:='RailPlanner';
		elseif appSequenceId =  1 then profile:='ShiftManager';
		elseif appSequenceId =  2 then profile:='AdminMisc';
		elseif appSequenceId =  3 then profile:='YardShipPlanner';
		elseif appSequenceId =  4 then profile:='YardShipController';
		elseif appSequenceId =  5 then profile:='EDIOperations';
		elseif appSequenceId =  6 then profile:='CorporateExec';
		elseif appSequenceId =  7 then profile:='ShipOperations';
		elseif appSequenceId &gt;= 8 and appSequenceId &lt;= 11 then profile:='ReeferReadings';
		elseif appSequenceId = 12 then profile:='RailChecker'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 13 and appSequenceId &lt;= 28 then profile:='RTG'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 29 and appSequenceId &lt;= 55 then profile:='IMV'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 56 and appSequenceId &lt;= 60 then profile:='ShipLander'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId = 61 then profile:='ReachStacker'; schemaName:='JtdMobileDriverSchema';
		endif;/**/
	endif;
	//profile:='VoyageWorker';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_mumbai" id="e57e4caa-9b84-4963-a290-f13986138ec4">
