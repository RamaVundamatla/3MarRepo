    <JadeMethod name="listBoxLimitException" id="bf8453a2-2e0a-4edd-bd18-70e7c14b40d8">
        <updating/>
        <source>listBoxLimitException( _exObj: Exception; _listbox : CMUI_ListBox; _exOccurred : Boolean output ): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2021	navndl1	Initial creation	TFS	50937 

*/

vars

begin

	if _exObj.errorCode = 14025 then
		_exOccurred := true;
		abortTransaction;
		abortTransientTransaction;
		app.msgBox(app.getErrorString1(Maxim_numbe_lines_that_displ_l, JadeTableRowLimit.String)
					,app.getErrorString(List_line_limit_reached),MsgBox_OK_Only + MsgBox_Information_Icon);
		if _exObj.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;
	endif;
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_listbox" type="CMUI_ListBox"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableRowLimitException" id="b6be28ba-ae16-49f0-b9a0-024923426673">
        <updating/>
        <source>tableRowLimitException( _exObj: Exception; _table : CM_BaseTable; _exOccurred : Boolean output ): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2010	cnwndl1	Initial creation Par 17868 ( migrated this handler from CM_BaseTable )

*/

vars

begin

	if _exObj.errorCode = 14049 then
		_exOccurred := true;
		abortTransaction;
		abortTransientTransaction;
		app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String)
					,app.getErrorString(TableRowLimitReached),MsgBox_OK_Only + MsgBox_Information_Icon);
		//return Ex_Abort_Action;							//25 Nov 2014	NDL	Par 35248
		if _exObj.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;
	endif;
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateFormCaption" id="72a54d4b-9864-44ed-ad4b-d699f69e8c21">
        <updating/>
        <source>translateFormCaption(_id : Integer; _locale : CM_Locale) updating;

vars
	translation	: XLAT_Translation;
begin
	if _locale = null then
		return;
	endif;
	// An appropriate translation is provided or nothing happens
	// and the default bubbleHelp text from Painter is displayed.
	translation	:= _locale.getTranslatedText(XLAT_Exceptions, _id);
	if translation &lt;&gt; null then
		caption := translation.text;
	endif;
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
