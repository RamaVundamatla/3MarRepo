    <JadeMethod name="convertForCCMS1205" id="f4557fec-c695-4ac2-bc9c-b015f1cfe790">
        <source>convertForCCMS1205();
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars	
	ediTrackedItem	: CM_EDITrackedItem;
begin

	foreach ediTrackedItem in self.allEDITrackedItems do
		if CM_EDICustomStopTI.hasInstance(ediTrackedItem) then
			ediTrackedItem.CM_EDICustomStopTI.convertForCCMS1205();
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="findHeadings" id="d11fce7c-9ea9-43e2-b4cc-80b3912b5e3b">
        <source>findHeadings(tiName: String; shortDesc: String io; longDesc: String io; width: Integer io; num: Integer io);
// note: num does not have to be order but the largest num must be
//	   greater than the total number of properties.
//	   ie what is return by getNumColumns.
vars

begin
	if tiName = "id" then
		num := 1;
		shortDesc := "Container";
		longDesc := "Container";
		width := 140;
	elseif tiName = "fullOrMT" then
		num := 3;
		shortDesc := "MT";
		longDesc := "MT or Full (E/F)";
		width := 30;
	elseif tiName = "voyageCode" then
		num := 4;
		shortDesc := "Voyage";
		longDesc := "Voyage Code";
		width := 100;
	elseif tiName = "vesselName" then
		num := 5;
		shortDesc := "Vessel";
		longDesc := "Vessel Name";
		width := 300;
	elseif tiName = "entryNumber" then
		num := 2;
		shortDesc := "EntryNo";
		longDesc := "Entry Number";
		width := 35;
	elseif tiName = "status" then
		num := 6;
		shortDesc := "Status";
		longDesc := "Status";
		width := 35;

	else
		num := 0;
		shortDesc := "";
		longDesc := "";
		width := 0;
	endif;
end;</source>
        <Parameter name="tiName" type="String"/>
        <Parameter name="shortDesc" type="String" usage="io"/>
        <Parameter name="longDesc" type="String" usage="io"/>
        <Parameter name="width" type="Integer" usage="io"/>
        <Parameter name="num" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getClearanceForTI" id="4718eeb9-ddb8-418f-bdc4-052d485c613e">
        <source>getClearanceForTI(_trackedItem: CM_TrackedItem): CM_EDICustomStopTI;
//----------------------------------------------------------------
//	Created:	24 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

//	This should only return a valid export clearance (or null) - do nothing if a cancel exists
//	Currently not returning any other type of clearance
vars
	ti		: CM_TrackedItem;
	ediTI	: CM_EDICustomStopTI;
begin
	
	ti := _trackedItem;
	
	if self.allUnprocCustByRespID[Customs_Export_Cancel, ti.id] = null then
		ediTI := self.allUnprocCustByRespID[Customs_Export_Cleared, ti.id];
	endif;
	
	if ediTI = null then
		if self.allUnprocCustByRespID[SEP_ContainerCancellation,ti.id] = null then
			ediTI := self.allUnprocCustByRespID[SEP_ContainerRelease,ti.id];
		endif;
	endif;
	
	return ediTI;

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="CM_EDICustomStopTI"/>
    </JadeMethod>
