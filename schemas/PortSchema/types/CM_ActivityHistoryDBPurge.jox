vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDBPurgeAttributes" id="cb2d2d5d-b1de-4be3-9420-8ae7b97ad061">
        <updating/>
        <source>setDBPurgeAttributes(_bgpDBPurgeRequest : BGP_DatabasePurgeRequest) updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//
//23/05/2012	cnwrs1	Par 29613
//24/11/2022    navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 	navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 	navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

begin

	self.user							:= _bgpDBPurgeRequest.getUserCode()[1:10];
	self.archiveDate					:= _bgpDBPurgeRequest.archiveDate;
	self.purgeArchivedLocations			:= _bgpDBPurgeRequest.purgeArchivedLocations;
	self.purgeArchivedVoyages			:= _bgpDBPurgeRequest.purgeArchivedVoyages;
	self.purgeEmptyBOLIns				:= _bgpDBPurgeRequest.purgeEmptyBOLIns;
	self.purgeMachineHistory			:= _bgpDBPurgeRequest.purgeMachineHistory;
	self.purgeNonContainerDiscrepancies	:= _bgpDBPurgeRequest.purgeNonContainerDiscrepancies;
	self.purgeOffsiteTis				:= _bgpDBPurgeRequest.purgeOffsiteTis;
	self.purgePrenotedTis				:= _bgpDBPurgeRequest.purgePrenotedTis;
	self.purgeBookingRefTis				:= _bgpDBPurgeRequest.purgeBookingRefTis;
	self.purgeNavisSmartActivity		:= _bgpDBPurgeRequest.purgeNavisSmartActivity; 			// ### TFS 50669 06AUG2021 NAVAB1
	self.purgeSundry 					:= _bgpDBPurgeRequest.purgeSundry;
	self.purgeDDExtractHistory 			:= _bgpDBPurgeRequest.purgeDDExtractHistory;
	self.purgeLockTransactions 			:= _bgpDBPurgeRequest.purgeLockTransactions;
	self.purgeEDIData 					:= _bgpDBPurgeRequest.purgeEDIData;
	self.purgeXlations 					:= _bgpDBPurgeRequest.purgeXlations;
	self.purgeYardAllocationLogTrans 	:= _bgpDBPurgeRequest.purgeYardAllocationLogTrans; 		//par16530 cnwrs1 May 2008
	self.purgeMenuUserItems 			:= _bgpDBPurgeRequest.purgeMenuUserItems; 				//par17772 cnwrs1 Aug 2008
	self.purgeLogCheckScaleHdr 			:= _bgpDBPurgeRequest.purgeLogCheckScaleHdr; 			//par17772 cnwrs1 Aug 2008
	self.purgeVehicleBookingSlots 		:= _bgpDBPurgeRequest.purgeVehicleBookings;				//15 Apr 2013	NDL	Par 31393
	self.purgeVehicleVisit 				:= _bgpDBPurgeRequest.purgeVehicleVisit; 				//par17772 cnwrs1 Aug 2008
	self.purgeCargoPhotos 				:= _bgpDBPurgeRequest.purgeCargoPhotos;
	self.purgeEventRequests 			:= _bgpDBPurgeRequest.purgeEventRequests;				//23/05/2012	cnwrs1	Par 29613
	self.purgeDutyDocs 					:= _bgpDBPurgeRequest.purgeDutyDocs; 					//21 Dec 2012	NDL	Par 30901
	if app.isCargoGroupEnabled then	 															//22 Jun 2015	NDL	Par 36338
		self.purgeReleasedCargoGroups 	:= _bgpDBPurgeRequest.purgeReleasedCargoGroups;
	endif;
	self.purgeInterTerminalRailBOLs		:=_bgpDBPurgeRequest.purgeInterTerminalRailBOLs;  		//epr TFS 4157 28/4/17
	self.truncateEDIInfoXML 			:= _bgpDBPurgeRequest.truncateEDIInfoXML;				//13 Sep 2021	NDL	TFS 51718
	self.purgeReleaseRequests 			:= _bgpDBPurgeRequest.purgeReleaseRequests;  			//24 Nov 2022 TFS 55001
	self.purgeAttachmentCargoTypes 		:= _bgpDBPurgeRequest.purgeAttachmentCargoTypes;  		//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentContract 		:= _bgpDBPurgeRequest.purgeAttachmentContract;  		//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentInvoices 		:= _bgpDBPurgeRequest.purgeAttachmentInvoices;  		//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentVoyages 		:= _bgpDBPurgeRequest.purgeAttachmentVoyages;  			//14/02/2023 navhl20 #54900[56518]
	self.purgeAttachmentWorkOrders 		:= _bgpDBPurgeRequest.purgeAttachmentWorkOrders;  		//14/02/2023 navhl20 #54900[56518]
	self.purgeWorkOrderJobSheets		:= _bgpDBPurgeRequest.purgeWorkOrderJobSheets;			//21.7.2023 navhl20 #58158
	self.purgeVisitPhotos 				:= _bgpDBPurgeRequest.purgeVisitPhotos;					//11.08.2025 navhl20 #35650
	self.purgeAgGatewayMessages 		:= _bgpDBPurgeRequest.purgeAgGatewayMessages;			//navra1 - MTN-35875- 5th Sep 2025-2
end;</source>
        <Parameter name="_bgpDBPurgeRequest" type="BGP_DatabasePurgeRequest"/>
    </JadeMethod>
    <JadeMethod name="setError" id="15a4bf23-8729-4e9a-ab65-5b57ccd05332">
        <updating/>
        <source>setError(_errors	: HugeStringArray) updating;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allErrors = null then
		create self.allErrors transient;
	endif;
	_errors.copy(self.allErrors);

end;</source>
        <Parameter name="_errors" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1c029832-b78d-42e7-b91d-3aa9b3ace069">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistoryDBPurge) updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//23/05/2012	cnwrs1	Par 29613
//24/11/2022    navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 	navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 	navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
vars

begin
	inheritMethod(_proxy);
	self.user							:= _proxy.user;
	self.archiveDate					:= _proxy.archiveDate;
	self.purgeArchivedLocations			:= _proxy.purgeArchivedLocations;
	self.purgeArchivedVoyages			:= _proxy.purgeArchivedVoyages;
	self.purgeEmptyBOLIns				:= _proxy.purgeEmptyBOLIns;
	self.purgeMachineHistory			:= _proxy.purgeMachineHistory;
	self.purgeNonContainerDiscrepancies	:= _proxy.purgeNonContainerDiscrepancies;
	self.purgeOffsiteTis				:= _proxy.purgeOffsiteTis;
	self.purgePrenotedTis				:= _proxy.purgePrenotedTis;
	self.purgeBookingRefTis				:= _proxy.purgeBookingRefTis;
	self.purgeNavisSmartActivity		:= _proxy.purgeNavisSmartActivity; 		// ### TFS 50669 06AUG2021 NAVAB1
	self.purgeSundry 					:= _proxy.purgeSundry;
	self.purgeDDExtractHistory 			:= _proxy.purgeDDExtractHistory;
	self.purgeLockTransactions 			:= _proxy.purgeLockTransactions;
	self.purgeEDIData 					:= _proxy.purgeEDIData;
	self.purgeYardAllocationLogTrans 	:= _proxy.purgeYardAllocationLogTrans; //par16530 cnwrs1 May 2008
	self.purgeMenuUserItems 			:= _proxy.purgeMenuUserItems;
	self.purgeLogCheckScaleHdr 			:= _proxy.purgeLogCheckScaleHdr; 		//par17772 cnwrs1 Aug 2008
	self.purgeDutyDocs 					:= _proxy.purgeDutyDocs;				//16 Jan 2013	NDL	Par 30901
	self.purgeInterTerminalRailBOLs 	:=_proxy.purgeInterTerminalRailBOLs; 	//epr TFS 4157 28/4/17
	
	if _proxy.allErrors &lt;&gt; null then
		create self.allErrors persistent;
		_proxy.allErrors.copy(self.allErrors);
	endif;
	
	self.purgeEventRequests 			:= _proxy.purgeEventRequests;			//23/05/2012	cnwrs1	Par 29613
