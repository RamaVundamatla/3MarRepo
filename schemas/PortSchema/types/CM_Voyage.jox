//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	if self.myGeneralCargoVoyage &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myVoyageGeneralCargo reference is already set');
		return;
	endif;
	
	self.myGeneralCargoVoyage := _pxyGCVoyage;
end;</source>
