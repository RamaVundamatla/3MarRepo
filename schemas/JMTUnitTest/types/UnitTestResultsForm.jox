    <JadeMethod name="updateJiraItem" id="759a7d9f-2e34-4737-8ce4-df498b69f339">
        <source>updateJiraItem(mth : Method input; jiraItem : String; selectedResult : UM_UnitTestResult input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2025	navbs1	Initial creation Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

begin
    beginTransaction;
	mth.cnEcSetText(jiraItem);
	selectedResult.setJiraItem(jiraItem);
	commitTransaction;
end;
</source>
        <Parameter name="mth" type="Method" usage="input"/>
        <Parameter name="jiraItem" type="String"/>
        <Parameter name="selectedResult" type="UM_UnitTestResult" usage="input"/>
