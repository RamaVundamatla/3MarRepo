    <JadeMethod name="createDragSelectFrame" id="b0649d68-ac4a-4a1e-bab5-1e2f446daed6">
        <updating/>
        <source>createDragSelectFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpDragFrame	: YRD_ContainerDragSelectFrame;
	
begin

	if self.myScrollingFrame = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myScrollingFrame is null');
		return;
	endif;

	create tmpDragFrame transient;
//	tmpDragFrame.height := 500;
	self.myDrawingFrame.myDragSelectFrame := tmpDragFrame;

	tmpDragFrame.parent := self.myScrollingFrame;
	tmpDragFrame.setForCreate();
	self.form.addControl(tmpDragFrame);
//process.weidebug;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createDrawingController" id="312ce457-bbaa-46ee-8a82-6be54816b62b">
        <updating/>
        <source>createDrawingController() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myDrawingFrame = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myDrawingFrame is null');
		return;
	endif;

	delete self.myDrawingController;
	delete self.myRoRoLaneDrawingController;	// cnwjk3 ccms 1018 4/12/09
	
	if self.isForRows then
		create self.myDrawingController as YRD_CargoRowDrawingController transient;
		self.myDrawingController.setForCreate(self);
	elseif self.isForGCRacks then
		create self.myDrawingController as YRD_GCRackDrawingController transient;
		self.myDrawingController.setForCreate(self);
	elseif self.isForEndView then
		create self.myDrawingController as YRD_CargoBayDrawingController transient;
		self.myDrawingController.setForCreate(self);
	elseif self.isForOverview then
		create self.myDrawingController as YRD_GridOViewDrawingController transient;
		self.myDrawingController.setForCreate(self);
	elseif self.isForRoRoLanes then								// cnwjk3 ccms 1018 4/12/09
		create self.myRoRoLaneDrawingController;				// cnwjk3 ccms 1018 4/12/09
		self.myRoRoLaneDrawingController.setForCreate(self);	// cnwjk3 ccms 1018 4/12/09
	else
		create self.myDrawingController transient;
		self.myDrawingController.setForCreate(self);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createDrawingFrame" id="0a301ea4-fbf2-4f2b-9590-acccde02885e">
        <updating/>
        <source>createDrawingFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDrawingFrame	: YRD_ContainerDrawingFrame;
	
begin

	if self.myScrollingFrame = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myScrollingFrame is null');
		return;
	endif;

	create tmpDrawingFrame transient;
	self.myDrawingFrame := tmpDrawingFrame;
	tmpDrawingFrame.name := "Drawing Frame";
	tmpDrawingFrame.bevelInner := Frame.Bevel_None;
	tmpDrawingFrame.bevelOuter := Frame.Bevel_None;
	tmpDrawingFrame.borderStyle := Frame.BorderStyle_None;
	tmpDrawingFrame.boundaryWidth := 0;
	tmpDrawingFrame.parent := self.myScrollingFrame;
	tmpDrawingFrame.alignContainer := Frame.AlignContainer_All;
	tmpDrawingFrame.caption := null;
	
	self.form.addControl(tmpDrawingFrame);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createOverlayFrame" id="ccbb2c8e-3538-4337-9be9-fe694cdc61bc">
        <updating/>
        <source>createOverlayFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpDrawingFrame	: YRD_ContainerOverDrawingFrame;
	
begin

	if self.myScrollingFrame = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myScrollingFrame is null');
		return;
	endif;

	// ### THIS ONE IS FOR EDIT DRAWING
	create tmpDrawingFrame transient;
	self.myDrawingFrame.myOverlayDrawingFrame := tmpDrawingFrame;
	tmpDrawingFrame.parent := self.myScrollingFrame;
	tmpDrawingFrame.setForCreate(true);
	self.form.addControl(tmpDrawingFrame);

	// ### THIS ONE ONLY DRAWS  and will have no interaction
	create tmpDrawingFrame transient;
	self.myDrawingFrame.myOverlayViewingFrame := tmpDrawingFrame;
	tmpDrawingFrame.parent := self.myScrollingFrame;
	tmpDrawingFrame.setForCreate(false);
	self.form.addControl(tmpDrawingFrame);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createScrollingFrame" id="3ebeed5c-c99b-4814-9952-a37e666c7ccb">
        <updating/>
        <source>createScrollingFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpScrollingFrame	: YRD_ContainerScrollingFrame;
	
begin

	create tmpScrollingFrame transient;
	self.myScrollingFrame := tmpScrollingFrame;
	
	tmpScrollingFrame.bevelInner := Frame.Bevel_None;
	tmpScrollingFrame.name := "Scrolling Frame";
	
	tmpScrollingFrame.bevelOuter := Frame.Bevel_None;
	tmpScrollingFrame.borderStyle := Frame.BorderStyle_None;
	tmpScrollingFrame.boundaryWidth := 0;
	
	tmpScrollingFrame.parent := self;
//	tmpScrollingFrame.alignContainer := Frame.AlignContainer_All;
	
	self.form.addControl(tmpScrollingFrame);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="d8c13460-4ecd-441c-8988-a44e4b1fc675">
        <updating/>
        <source>drawSelf() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myDrawingController = null then
		return;
	endif;
	self.myDrawingController.drawSelf(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrentScrollableFrmValues" id="d998a722-de17-4f35-acf2-33518079ba85">
        <source>getCurrentScrollableFrmValues(_hScrollValue: Integer output; _vScrollValue: Integer output; _width: Real output; _height: Real output);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpScrollFrame	: CMUI_ScrollableFrame;
begin
	tmpScrollFrame := self.myScrollableFrame;
	if tmpScrollFrame = null then
		return;
	endif;
	
	_hScrollValue := tmpScrollFrame.getHScrollValue();
	_vScrollValue := tmpScrollFrame.getVScrollValue();
	_width := tmpScrollFrame.width;
	_height := tmpScrollFrame.height;

end;</source>
        <Parameter name="_hScrollValue" type="Integer" usage="output"/>
        <Parameter name="_vScrollValue" type="Integer" usage="output"/>
        <Parameter name="_width" type="Real" usage="output"/>
        <Parameter name="_height" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCurrentScrollableFrmWH" id="340c75f5-541d-4271-99f5-63d71d5bc893">
        <source>getCurrentScrollableFrmWH( _width: Real output; _height: Real output);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpScrollFrame	: CMUI_ScrollableFrame;
begin
	tmpScrollFrame := self.myScrollableFrame;
	if tmpScrollFrame = null then
		return;
	endif;
	
	_width := tmpScrollFrame.getHScrollWidth();
	_height := tmpScrollFrame.getVScrollHeight();

end;</source>
        <Parameter name="_width" type="Real" usage="output"/>
        <Parameter name="_height" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCurrentScrollingFrmValues" id="9a7d27bf-b999-4bd8-938e-454bbfc2e1f6">
        <source>getCurrentScrollingFrmValues(_hScrollValue: Integer output; _vScrollValue: Integer output; _width: Real output; _height: Real output);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpScrollFrame	: CMUI_ScrollingFrame;
begin
	tmpScrollFrame := self.myScrollingFrame;

	if tmpScrollFrame = null then
		return;
	endif;
	
	_width := tmpScrollFrame.width;
	_height := tmpScrollFrame.height;


end;</source>
        <Parameter name="_hScrollValue" type="Integer" usage="output"/>
        <Parameter name="_vScrollValue" type="Integer" usage="output"/>
        <Parameter name="_width" type="Real" usage="output"/>
        <Parameter name="_height" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleScrollableMouseDown" id="4a29e56f-307a-45ea-aba4-f54001a70abc">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>handleScrollableMouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		14 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rdc	: YRD_RoRoLaneDrawingController;
	ydc : YRD_ContainerDrawingController;
	tmpTA : CM_TerminalArea;
begin
	inheritMethod(frame, button, shift, x, y);

	if self.isForGCRacks then
		return;
	endif;

	if self.isForRoRoLanes then									// cnwjk3 CCMS 1018 02/02/10
		rdc := self.myRoRoLaneDrawingController;				// cnwjk3 CCMS 1018 02/02/10
		if rdc &lt;&gt; null then										// jlgmd1	TFS#36913 08/02/2018
			rdc.doDFMouseDown(self.myDrawingFrame,button,shift,x,y);// cnwjk3 CCMS 1018 02/02/10
		endif;													// jlgmd1	TFS#36913 08/02/2018
		return;													// cnwjk3 CCMS 1018 02/02/10
	endif;														// cnwjk3 CCMS 1018 02/02/10
	
	ydc := self.myDrawingController;
	ydc.doDFMouseDown(self.myDrawingFrame,button,shift,x,y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="init" id="6da57a69-2c9d-4334-a78c-81086e32122c">
        <updating/>
        <source>init(_terminalArea : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myTerminalArea := _terminalArea;
	if _terminalArea = null then
		self.caption := null;
		return;
	endif;

	self.caption := _terminalArea.id;
	self.myDrawingController.init(_terminalArea, null);

end;</source>
        <Parameter name="_terminalArea" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="postCreate" id="778d4d65-df64-4506-90ac-695d785eaf24">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>postCreate() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpScrollableFrame	: CMUI_ScrollableFrame;
	
begin

	// These MUST be called in the following order
	self.createScrollingFrame();
	self.createDrawingFrame();
	self.createOverlayFrame();
	self.createDragSelectFrame();
	self.createDrawingController();
	
//	self.myScrollableFrame.backColor := Red;
//	self.myScrollingFrame.backColor := Blue;
//	self.myDrawingFrame.backColor := Yellow;
	
	tmpScrollableFrame := self.myScrollableFrame;
	if tmpScrollableFrame &lt;&gt; null then
		tmpScrollableFrame.setHLabelDetails(30, false);
		tmpScrollableFrame.setVLabelDetails(30, false);
	endif;

	self.setScrollingFrame(self.myScrollingFrame);
	



end;</source>
    </JadeMethod>
    <JadeMethod name="resetScrollValues" id="aea81252-42f3-4456-9a0c-efa75dcb1412">
        <source>resetScrollValues();
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myScrollableFrame.scrollResetScrollValues();
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeScrollingFrame" id="cf82d873-c83d-4383-8939-68fb4a07ddd8">
        <source>resizeScrollingFrame(pWidth: Real; pHeight: Real);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myScrollableFrame.height := self.height; // TFS 4436
	self.myScrollableFrame.width := self.width; // TFS 4436

	inheritMethod(pWidth, pHeight);
	
	self.myDrawingFrame.resizeOverlayFrames(pWidth, pHeight);
end;</source>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="userResize" id="57b0a73c-f9b1-4ce5-b8aa-10227aef3e01">
        <controlMethod name="CMUI_GridAreaDockBar::userResize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userResize(dockBar: JadeDockBar input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpScrollingFrame	: CMUI_ScrollingFrame;
	
begin
	inheritMethod(dockBar);
	
	if (self.isInPainter) then
		return;
	endif;
	
	tmpScrollingFrame := self.myScrollingFrame;
	if tmpScrollingFrame = null then
		tmpScrollingFrame.move(0, 0, self.clientWidth, self.clientHeight);
		tmpScrollingFrame.cnEcResizeContents();
	endif;

end;</source>
        <Parameter name="dockBar" type="JadeDockBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="77a21c7a-4628-49b2-a085-98f965fff7ba">
        <controlMethod name="CMUI_GridAreaDockBar::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: YRD_ContainerGridAreaDockBar input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	
begin
	inheritMethod(cntrl, persistCntrl);

	if (self.isInPainter) then
		return;
	endif;

	// These MUST be called in the following order
	cntrl.createScrollingFrame();
	cntrl.createDrawingFrame();
	cntrl.createOverlayFrame();
	cntrl.createDragSelectFrame();
	cntrl.createDrawingController();
	
//	self.myScrollableFrame.backColor := Red;
//	self.myScrollingFrame.backColor := Blue;
//	self.myDrawingFrame.backColor := Yellow;
	
	self.setScrollingFrame(self.myScrollingFrame);
	
	tmpScrollableFrame := self.myScrollableFrame;
	if tmpScrollableFrame &lt;&gt; null then
		tmpScrollableFrame.setHLabelDetails(30, false);
		tmpScrollableFrame.setVLabelDetails(30, false);
	endif;

end;</source>
        <Parameter name="cntrl" type="YRD_ContainerGridAreaDockBar" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="YRD_ContainerGridAreaDockBar">
        <bitmap></bitmap>
        <DevControlProperties name="alignChildren">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - none</value>
                <value>1 - all horizontal</value>
                <value>2 - all vertical</value>
                <value>3 - automatic</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignContainer">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - none</value>
                <value>1 - top</value>
                <value>2 - bottom</value>
                <value>3 - left</value>
                <value>4 - right</value>
                <value>5 - all horizontal</value>
                <value>6 - all vertical</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="autoSpacingX">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="autoSpacingY">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
