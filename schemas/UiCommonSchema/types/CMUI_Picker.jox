        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateMultiSelection" id="7fec54db-148f-4419-9ff3-8b813c4f888e">
        <updating/>
        <source>validateMultiSelection(_oa : ObjectArray; _msg : String output) : Boolean protected, updating;
// 29287 allow multi-select of pre-notes of a single booking ref, or a single booking ref
vars
	obj			: Object;
	hasBooking	: Boolean;
	ti			: CM_TrackedItem;
	bookingRefItem	: CM_BookingRefItem;
	firstTi : CM_TrackedItem;
	theEntDef : String;
	theError : String;
	diff : Decimal [16,4];
begin
	if _oa = null then
		return true;
	endif;
	
	
	//cnwrd1 par 33096 - no longer care if we are on different booking items! Test if we are the 'same' for gate form receival
	theEntDef := app.getEntTableForCompRoadGate(_oa.first);

	if theEntDef &lt;&gt; null then
		hideEntTableException := true;
		if not app.testSameAsByEntTable( _oa.first, _oa,null, theEntDef, false,theError) then
			if theError &lt;&gt; null then
				_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, theError);
			endif;
			return false;
		endif;
	endif;

	//14 Nov 2013	NDL	Par 32995
	if _oa.size &gt; 1 then
		// If we are going to allow multi-select of existing pre-notes they better match exactly.
		foreach obj in _oa do
			if obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
				if ti.canMergeBreakBulk() and not allowCreateJobsBtn then
					//Not allowed to be multi select break bulk
					_msg := app.getErrorString1(Not_multi_selec_break_b_cargo, ti.id );
					return false;
				endif;
				if ti.damaged then
					//Not allowed to be damaged
					_msg := app.getErrorString2(Cargo_item_not_multi, ti.id, app.getErrorString(Damage) );
					return false;
				endif;
				if not ti.allAttachments.isEmpty then
					//Not allowed to have attachments ( includes photos )
					_msg := app.getErrorString2(Cargo_item_not_multi, ti.id, app.getErrorString(Attachments) );
					return false;
				endif;
				if not ti.allChildren.isEmpty then
					//Not allowed to have children
					_msg := app.getErrorString2(Cargo_item_not_multi, ti.id, app.getErrorString( Child_cargo ) );
					return false;
				endif;
				if not ti.allSeals.isEmpty then
					//Not allowed to have seals
					_msg := app.getErrorString2(Cargo_item_not_multi, ti.id, app.getErrorString(Seal_number) );
					return false;
				endif;
				if firstTi = null then
					firstTi := ti;
					continue;
				else
					if firstTi.cargoType &lt;&gt; ti.cargoType then
						_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(CargoType));
						return false;
					elseif firstTi.myProduct &lt;&gt; ti.myProduct then
						_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(SubCargoType));
						return false;
					elseif firstTi.getImExStatus &lt;&gt; ti.getImExStatus then
						_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(IMEX));
						return false;
					elseif firstTi.totalWeight &lt;&gt; ti.totalWeight then
						if firstTi.totalWeight &gt; ti.totalWeight then	//22 Dec 2016	NDL	TFS 3134 / 2683
							diff := firstTi.totalWeight - ti.totalWeight;
						else
							diff := ti.totalWeight - firstTi.totalWeight;
						endif;
						if diff &gt; Measure_AllowableDifference then
							_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(Weight));
							return false;
						endif;
					elseif firstTi.totalVolume &lt;&gt; ti.totalVolume then
						_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(Volume));
						return false;
					elseif firstTi.commodity &lt;&gt; ti.commodity then
						_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(Commodity));
						return false;
					elseif firstTi.isoTypeDesc &lt;&gt; ti.isoTypeDesc then
						_msg := app.getErrorString1(Selec_cargo_items_not_have_dif, app.getErrorString(ISO_Type));
						return false;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	return true;
epilog
	hideEntTableException := false;
end;
</source>
        <access>protected</access>
        <Parameter name="_oa" type="ObjectArray"/>
        <Parameter name="_msg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
