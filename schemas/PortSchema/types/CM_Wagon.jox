    <JadeMethod name="setMyWagonMaster" id="cd9f2aec-bd9d-457c-8212-99eb4b487b6b">
        <updating/>
        <source>setMyWagonMaster( _wagonMaster : CM_WagonMaster; _oldId : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2009	cnwndl1	Initial creation

*/

vars

	wagonMaster : CM_WagonMaster;
	wagonMasterProxy : CM_WagonMaster;
	oldWagonMaster : CM_WagonMaster;
	
begin

	if _wagonMaster &lt;&gt; null then
		self.myWagonMaster := _wagonMaster;
	else
		// no wagon master supplied, see if we can find one.
		wagonMaster := app.myRoot.allWagonMasters.getAtKey(self.id);
		
		if wagonMaster = null then
			//create a wagon master if none exists
			create wagonMasterProxy transient;
			wagonMasterProxy.autoCreateFromWagon(self);
			
			create wagonMaster persistent;
			wagonMaster.setForCreate(wagonMasterProxy);
			
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(wagonMaster);
			
		endif;
		
		if wagonMaster &lt;&gt; null then
		
			self.myWagonMaster := wagonMaster;
			
		endif;
	endif;

	// The wagonMaster was reset because the wagon id has changed and teh wagon master was auto created.
	// If this was the only wagon on the wagonmaster, we should delete the old wagonmaster. 
	if _oldId.trimBlanks &lt;&gt; null and _oldId &lt;&gt; self.id then
		oldWagonMaster := app.myRoot.allWagonMasters.getAtKey(_oldId);
		if oldWagonMaster &lt;&gt; null then
			if oldWagonMaster.autoCreated and oldWagonMaster.allWagons.isEmpty then
				// The old wagon master was auto created and has no associated wagons, delete it.
				oldWagonMaster.erase(0);
			endif;
		endif;
	endif;
	
epilog

	delete wagonMasterProxy;

end;</source>
        <Parameter name="_wagonMaster" type="CM_WagonMaster"/>
        <Parameter name="_oldId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3ca4a1c4-d4f6-45d7-85d7-9999108bbed7">
        <updating/>
        <source>setProxy(_term			  : CM_Terminal; 
		_id 			  : String; 
		_class 			  : CM_WagonClass;
		_train			  : CM_Train;
		_outTrain		  : CM_Train;
		_remark 		  : String;
		_maxCargoHeight	  : Decimal; 
		_maxCargoWeight	  : Decimal;
		_tareWeight		  : Decimal;
		_carrier		  : CM_Carrier;
		_receiveStevedore : CM_Stevedore;
		_releaseStevedore : CM_Stevedore) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 jul 2002 		to accept a null _class parameter. We figure it out. This MAY have to be re-impliimented for off shore sites
			cnwmd1  CCMS 1067, Par 19913 - New fields - cargo weights, heights and carrier.
04 Nov 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
25 Jul 2022	jlika1	TFS 54050 - EUP- Max Wagon Payload
/*

*/
vars
	wagonClassId 		: String;	
	lWagonClass  		: CM_WagonClass;
	nullTrain    		: CM_Train;
	allowWagonWeights	: Boolean;
begin
	
	self.raiseExceptionIfNotTransient(method);
	
	if _term &lt;&gt; null then	
		allowWagonWeights := _term.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	self.id := _id.toUpper;
	
	if _class &lt;&gt; null then
		lWagonClass := _class;
		if self.id.length &gt; 20 then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_INVALID_WAGONNO, _id, null, null);
		endif;
	else
		wagonClassId := app.myRoot.getWagonClassViaHookCode(_term,_id,_carrier); //20 Jul 2009 NDL CCMS 1067
		if wagonClassId = null then
			app.raiseCMException1(ERR_INVALID_WAGONNO, _id, null, null);
			return;
		endif;
		lWagonClass := app.myRoot.allWagonClasses[wagonClassId];
		if lWagonClass = null then
			app.raiseCMException2(ERR_KEY_NOT_FOUND, wagonClassId, app.getErrorString(Wagon_classes), null, null); //+ cnwmd1, CCMS 1067, Par 19710
			return;
		endif;
	endif;	

	self.myWagonClass    := lWagonClass;
	self.myTerminal      := _term;
	self.myTrainInwards  := _train;
	self.myTrainOutwards := _outTrain;
	
	// Default to NULL TRAIN - says DQ August2009
	if _term &lt;&gt; null and _train = null then
		nullTrain 			 := _term.getNullTrain();
		self.myTrainInwards  := nullTrain;
		self.myTrainOutwards := nullTrain;
	
	endif;
	self.myCarrier			 := _carrier;
	self.remarks  			 := _remark.trimBlanks;
	self.myStevedoreReceive  := _receiveStevedore;     //02.10.2020 cnwma1 TFS #50112
	self.myStevedoreRelease  := _releaseStevedore;     //02.10.2020 cnwma1 TFS #50112
	
	if allowWagonWeights then	
		self.maxCargoWeight		 := _maxCargoWeight;
		self.tareWeight		 	 := _tareWeight;
	endif;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_class" type="CM_WagonClass"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_outTrain" type="CM_Train"/>
        <Parameter name="_remark" type="String"/>
        <Parameter name="_maxCargoHeight" type="Decimal"/>
        <Parameter name="_maxCargoWeight" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_receiveStevedore" type="CM_Stevedore"/>
        <Parameter name="_releaseStevedore" type="CM_Stevedore"/>
    </JadeMethod>
