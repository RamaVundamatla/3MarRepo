    <JadeMethod name="am028_GRRF_picture_click" id="c7bdbdaf-8e11-4880-b060-149e68986520">
        <updating/>
        <source>am028_GRRF_picture_click():Integer updating;

vars
	keyCode:Integer;
	picture:Picture;
begin
	myGTE_ReleaseRequestForm_1:=app.getForm('GTE_ReleaseRequestForm').GTE_ReleaseRequestForm;
	myGTE_ReleaseRequestForm_1.cmbType.gotFocus(myGTE_ReleaseRequestForm_1.cmbType);
	myGTE_ReleaseRequestForm_1.cmbType.lostFocus(myGTE_ReleaseRequestForm_1.cmbType);
	myCMUI_Navigator_1.lstTest.listIndex:=app.atcgGetListHierarchicalIndex(myCMUI_Navigator_1.lstTest, 'Port Otago|Gate Functions|Release Requests|Active|', 22);
	myCMUI_Navigator_1.lstTest.itemSelected[myCMUI_Navigator_1.lstTest.listIndex]:=true;
	myCMUI_Navigator_1.lstTest.mouseUp(myCMUI_Navigator_1.lstTest, 1, 0, 124, 172);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myGTE_ReleaseRequestForm_1.tblSearch.keyDown(myGTE_ReleaseRequestForm_1.tblSearch, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=9;
	myGTE_ReleaseRequestForm_1.tblSearch.keyUp(myGTE_ReleaseRequestForm_1.tblSearch, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myGTE_ReleaseRequestForm_1.tblSearch.keyUp(myGTE_ReleaseRequestForm_1.tblSearch, keyCode, 0);
	app.doWindowEvents(shortPause);
	keyCode:=9;
	myGTE_ReleaseRequestForm_1.tblSearch.keyUp(myGTE_ReleaseRequestForm_1.tblSearch, keyCode, 0);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myGTE_ReleaseRequestForm_1, 'Search;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;2;-282;0;1;|;frmSearchToolbar;CMUI_Toolbar;0;-286;0;0;|').Picture;
	picture.mouseDown(picture, 1, 0, 8, 15);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myGTE_ReleaseRequestForm_1, 'Search;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;2;-282;0;1;|;frmSearchToolbar;CMUI_Toolbar;0;-286;0;0;|').Picture;
	picture.mouseUp(picture, 1, 0, 8, 15);
	app.doWindowEvents(shortPause);
	myGTE_ReleaseRequestForm_1.tblSearch.accessCell(2, 2).text:='';
	picture:=app.atcgGetAddedControl(myGTE_ReleaseRequestForm_1, 'Search;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;2;-282;0;1;|;frmSearchToolbar;CMUI_Toolbar;0;-286;0;0;|').Picture;
	app.doWindowEvents(shortPause);
	picture.click(picture);  // Search  // 13:02:35
	return 0;
end;</source>
