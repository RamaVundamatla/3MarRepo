    <JadeMethod name="canMultiEdit" id="25546c18-7973-4774-b01d-1cd7057a2bd4">
        <source>canMultiEdit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation	Par 27441
28/03/2018 	JLGNS1	Bug 37813: STWO - Transaction enquiry, selecting multiple lines and clicking right mouse click is giving error 1086
*/

vars

	obj : Object;
	thisTxnType : String;
	lastTxnType : String;
	txn : CM_TITransaction;

begin

	foreach obj in self.tblTransactions.allSelectedObjects do
		// If any of the selected items are not TI Transactions (i.e. Events), then
		// bulk edit is not allowed
		if not obj.isKindOf(CM_TITransaction) then
			return false;
		endif;
		txn := obj.CM_TITransaction;
		thisTxnType := txn.typeString;
		if lastTxnType &lt;&gt; null and thisTxnType &lt;&gt; lastTxnType then
			return false;
		endif;
		lastTxnType := thisTxnType;
	endforeach;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTransactionSearch" id="239bfbe6-903b-4547-9757-6557f1a8b263">
        <updating/>
        <source>cargoTransactionSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
   Jan 2012	cnwjre1	CCMS 1262  transaction enquiry and selector queries, cargo transactions
12 Dec 2019 cnwma1	Bug 47966: STWO - Transaction Enquiry ignores midnight 'Time To'
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	type			: Integer;
	iter			: Iterator;
	transObj		: CM_TITransaction;
	dateTypeDict	: CM_TITransactionByDateTypeDict;
	typeDateDict	: CM_TITransactionByTypeDateDict;
	keyTimeStamp	: TimeStamp;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
	keyType			: Integer;
	atLimit			: Boolean;
	breakOut		: Boolean;
	passport		: CM_Passport;
	user			: CM_User;
begin
	passport := app.myPassport;
	user 	 := app.getMyUser();

	startTimeStamp.setDate(self.filterDateFrom);
	startTimeStamp.setTime(self.filterTimeFrom);

	endTimeStamp.setDate(self.filterDateTo);
	endTimeStamp.setTime(self.filterTimeTo);
	
	if self.filterTransactionType = null then
		// date search
		dateTypeDict := self.myTerminal.allTITransactions;
		iter 		 :=	dateTypeDict.createIterator();
		dateTypeDict.startKeyGeq(startTimeStamp, 0, iter);
	
		while iter.next(transObj) do
			iter.getCurrentKeys(keyTimeStamp, keyType); //MTN-35226
		
			if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
				break;
			endif;
			
			if self.includesTransObject(transObj, breakOut, passport) then
				atLimit := self.addObjectToCollection(transObj, user);
			endif;
			
			if atLimit or  breakOut then
				break;
			endif;
		endwhile;
	else
		// transaction type search
		type 		 := self.filterTransactionType.trxType;
		typeDateDict := self.myTerminal.allTITransactionsByTypeDate;
		iter 		 :=	typeDateDict.createIterator();
		typeDateDict.startKeyGeq(type, startTimeStamp, iter);
	
		while iter.next(transObj) do
			iter.getCurrentKeys(keyType, keyTimeStamp); //MTN-35226
			
			if type &lt;&gt; keyType then
				break;
			endif;
			
			if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
				break;
			endif;
			
			if self.includesTransObject(transObj, breakOut, passport) then
				atLimit := self.addObjectToCollection(transObj, user);
			endif;
			
			if atLimit or  breakOut then
				break;
			endif;
		endwhile;
	endif;
	self.searchCancelled := breakOut;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkSearchReturnOption" id="8152c75e-7e3b-4094-9a04-f723829d2383">
        <updating/>
