<Class name="WS_CargoFilterSite" id="10c5284b-be5b-40e8-a9b4-c5daa6a10b54">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Site/State of the cargo</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="34017ea4-0571-4004-8bc8-f00331fb5c0f">
        <type name="String"/>
        <text>Site/State Description ex[0=**Anywhere**,1=Onsite,3=Notified,4=Offsite,5=Onship,12=Inter Terminal Transfer In Coming,13=Inter Terminal Transfer Out Going]</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="68cac844-dcf4-48c6-bb85-f1dcdb6f29b3">
        <type name="String"/>
        <text>Site/State ID</text>
    </PrimAttribute>
    <JadeMethod name="setFromSiteDesc" id="c4f1faca-8796-4c78-b5ef-ae56f1f19809">
        <updating/>
        <source>setFromSiteDesc(_desc:String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2009	#cnwdz2	 
12/09/2019	jlgdap1	TFS 45769 JMT Web Portal selector query parameters - rewrite to align with site
*/

vars
	site : Integer;
	
begin
	if _desc = CM_ContainerEnqForm.ANYSITE_STRING then
		site := TI_SITE_UNDEFINED;
	elseif _desc = CM_ContainerEnqForm.ONSITE_STRING then
		site := TI_SITE_ONSITE;
	elseif _desc = CM_ContainerEnqForm.OFFSITE_STRING then
		site := TI_SITE_OFFSITE;
	elseif _desc = CM_ContainerEnqForm.ONSHIP_STRING then
		site := TI_SITE_ONSHIP;
	elseif _desc = CM_ContainerEnqForm.NOTIFIED_STRING then
		site := SEL_QUERYSITE_NOTIFIED;
	elseif _desc = CM_ContainerEnqForm.TRANSFER_STRING_TO then
		site := TI_STATE_TRANSFER_TO;
	elseif _desc = CM_ContainerEnqForm.TRANSFER_STRING_FROM then
		site := TI_STATE_TRANSFER_FROM;
	endif;
	
	//self.id := CM_ContainerEnqForm.getSiteStateFromString(_desc).String;	// old way
	self.id := site.String;
	self.cmObjectId := self.id;
epilog
	
end;</source>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
</Class>
