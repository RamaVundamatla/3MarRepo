    <JadeMethod name="cmbBR_dropDown" id="02d1dee6-ca1d-4b37-98b4-c9cf93e80c4f">
        <controlMethod name="CMUI_ComboBox::dropDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBR_dropDown(combobox: ComboBox input):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	ti 				: CM_TrackedItem;
	cargoType		: CM_CargoType;
	id				: String;
	tbl				: CM_EntryTable;
	entView			: EntTableView;
	entTableRow		: EntTableRow;
	aBR : CM_BulkRelease;

begin

	cargoType := self.cmbTypeToPack.listObject.CM_CargoType;
	id := self.cmbPackInto.text;
	if cargoType = null then
		ti := self.myTerminal.allOnsiteTIsByIdCargoType[id, null];
	else
		ti := self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType.id, id];		
	endif;
	
	if ti = null then
		self.doCmbBRBuild(null);
		return true;
	endif;

	// ### CCMS 1288 AKB2005APR
	// cnwdad1 28/05/2007 - PAR #14118.
	//aBR := ti.allBulkReleasesAssigned[BR_TYPE_PACKING, BR_ACTIVE, null, null];
	aBR := ti.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING, BR_ACTIVE, null, null);
	if aBR &lt;&gt; null then
		self.doCmbBRBuild(aBR);
	else
		self.doCmbBRBuild(null);
	endif;		
	self.cmbBR.lostFocus(self.cmbBR);
	return true;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbBR_lostFocus" id="a5ee3f04-eea0-4516-a347-49526f8c9382">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBR_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblMasterEnt.setValueByControlName(combobox.name, combobox.text);
	if self.tblMasterEnt.getValueByName(ETRow_BookingRef) = null then
		self.tblMasterEnt.setValueByName(ETRow_BookingRef, combobox.text);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoDetail_click" id="68239ab6-f1cb-436e-9860-d3d06b786a5a">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoDetail_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpCmbProd		: CMUI_ComboProduct;
	tmpCmbItem 		: CMUI_ComboBox;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	beforeTxt		: String;
	tmpCargoType	: CM_CargoType;
begin

	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;
	
	//find out what table text is to see if combo has changed.  
	beforeTxt := self.tblDataDetailSaveText;
	
	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 
		tmpCargoType := combobox.listObject.CM_CargoType;
		
		if tmpCargoType &lt;&gt; null then 
			// populate product combo
			tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Product));
			tmpCmbProd := tmpCell.cellControl.CMUI_ComboProduct;
			tmpCmbProd.clear(); // cargo type has changes so what if anything in hear it is bunk.
			tmpCmbProd.setCargoType(tmpCargoType);
			
			tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Id));
			tmpCmbItem := tmpCell.cellControl.CMUI_ComboBox;
			tmpCmbItem.clear(); // cargo type has changes so what if anything in hear it is bunk.
			if tmpCargoType &lt;&gt; null and tmpCargoType.id &lt; TI_CargoBOLType_Max then
				self.myAssistant.comboBoxTrackedItemToPack(tmpCmbItem, tmpCargoType.id, TI_STATE_NORMAL, null ); 				
			endif;

			// also populate Items combo with all avail items of this cargo
		endif;

		//update proxy object in table	
		self.myCurrentDetailObject.CMIF_BOLOutLine.myCargoType := tmpCargoType;

		self.tblDataDetailSaveText := combobox.text;
	endif;
	// of text hasnt changed then dont need to do anything. 
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_click" id="c990c7eb-ab97-4264-90ea-5db38887aeb0">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_click(combobox: CMUI_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	beforeTxt		: String;
begin

	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;
	
	//find out what table text is to see if combo has changed. 
	beforeTxt := self.tblDataDetailSaveText;
	
	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 
		
		//	 update table text here. if in lost focus can stuff up. 
		self.zDoTblDetailDataRowColChg(self.tblDataDetail);
		// update and populate product combo
		self.doCmbCargoTypeChange(combobox);
		self.tblDataDetailSaveText := combobox.text;
	endif;
	// of text hasnt changed then dont need to do anything. 
end;</source>
        <Parameter name="combobox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_lostFocus" id="ac43029c-63a9-430a-a9ae-bdbd2d346022">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_lostFocus(combobox: CMUI_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
