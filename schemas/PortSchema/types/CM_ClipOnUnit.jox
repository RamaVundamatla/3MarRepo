    <JadeMethod name="connectToPower" id="51487c28-858d-4fa0-9453-dc0b42b36317">
        <updating/>
        <source>connectToPower(params : CMIF_ConnectParams; _passport : CM_Passport input) updating;
//NFS 3814 AA 25/9/01: Contains all the rules for connecting a COU to power
vars
	txn : CM_TITransaction;
	txnParams : CMIF_ConnectParams;
begin
	self.onPower := true;
	
	txnParams := params;
	txnParams.type := TRANS_TYPE_CONNECT_POWER;
	txnParams.myOtherTrackedItem := self.myReefer;
	txnParams.myTrackedItem := self;
	txn := self.createTransaction(txnParams, _passport);	
	txn.CM_ConnectPower.secondary := true;
end;</source>
        <Parameter name="params" type="CMIF_ConnectParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="35706960-6bc5-4e10-9d32-504829e1aabd">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
