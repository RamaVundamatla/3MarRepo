    <JadeMethod name="tblSelectedItems_dragDrop" id="3d0672ca-744f-4d28-9091-0874a74d45a4">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectedItems_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2012	cnwrd1	Initial creation

*/

vars

	moveController : CMIF_MoveController;
	tmpTi			: CM_TrackedItem;
begin

	moveController := app.myMoveController;
	
	tmpTi := moveController.myTrackedItem;
	if tmpTi = null then
		return;
	endif;
	
	if not self.allSelectedCargo.includes( tmpTi ) then
		self.allSelectedCargo.add( tmpTi );
	endif;
	
	foreach tmpTi in moveController.allOtherTrackedItems do		
		if not self.allSelectedCargo.includes( tmpTi ) then
			self.allSelectedCargo.add( tmpTi );
		endif;
	endforeach;
	
	self.displaySelectedTIs();

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
