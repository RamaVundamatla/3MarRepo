    <JadeMethod name="getRemainingQuantity" id="1dad40c1-9d4e-45f1-ad64-aa6289dc535f">
        <source>getRemainingQuantity(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2024	navlc30	Initial creation
11 Nov 2024 navlc30 JIRA 33404 EUP - To Do Task Job for which a WO Transaction is set on Complete - Total Qty and Operator are not shown correctly
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	quantity : Integer;
	wle		 : CM_WorkListEntry;
	ti		 : CM_TrackedItem;
begin
	wle := self.workListEntries.first;	

	if wle &lt;&gt; null and wle.isForToDoWOTransaction() then
		foreach ti in self.allTrackedItems discreteLock do		//06.03.2025 navma1 #MTN-34179
			quantity := quantity + ti.totalQuantity;
		endforeach;
		return quantity.asStringJMT;
	endif;

	return inheritMethod();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingVolume" id="40e26a98-76eb-48b6-aa45-1ac70b344ced">
        <source>getRemainingVolume(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2024	navlc30	Initial creation
11 Nov 2024 navlc30 JIRA 33404 EUP - To Do Task Job for which a WO Transaction is set on Complete - Total Qty and Operator are not shown correctly
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	density,
	volume : Decimal[14,4];
	ti     : CM_TrackedItem;
	wle    : CM_WorkListEntry;
begin

	wle := self.workListEntries.first;	

	if wle &lt;&gt; null and wle.isForToDoWOTransaction() then
		foreach ti in self.allTrackedItems discreteLock do		//06.03.2025 navma1 #MTN-34179
			density := ti.getDensity().max(1);
			volume  := volume + (ti.totalWeight/density);
		endforeach;
		return volume.asStringJMT;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
