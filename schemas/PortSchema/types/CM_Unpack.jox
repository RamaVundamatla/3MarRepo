    <JadeMethod name="updateTI" id="8b2c838f-6a0f-45a4-a765-e69655d0aedd">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
begin
	inheritMethod(_passport);			//cnwmc5 - 17 April 2015 - PAR 35925
	
	if self.myTrackedItem = null then
		return;
	else
		tmpTI := self.myTrackedItem;  //cnwjo3, lets start using local variable
	endif;
	
	//tmpTI.setUnpackedDT(self.dateTime);  //cnwjo3, not doing this for parent here, only for child

	// release date is set if item is packed so
	// ensure unset when unpacked.
	//if tmpTI.releasedDT.isValid then
	if tmpTI.isOnSite and tmpTI.releasedDT.isValid then	//07 Dec 2017	NDL	TFS 8116
		tmpTI.setReleasedDT(null);
	endif;

	//cnwjo3 par 20271, its a child, set pack/unpack datetime
	if self.action = ACTION_UNPACK_FROM then
		tmpTI.setUnpackedDT(self.dateTime);
		tmpTI.setPackedDT(null);
	endif;	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2a261f3d-a65d-4d34-b1fb-5a62cf6c28b5">
        <source>validateForUpdate(pProxyTransaction: CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// You cannot edit any fields for this transaction type
	app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);

	inheritMethod(pProxyTransaction);

end;</source>
        <Parameter name="pProxyTransaction" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
