    <JadeMethod name="selectTableRowForVehicle" id="f5c70c94-7df5-4107-902c-0970fd214f15">
        <source>selectTableRowForVehicle(_vehicle: CM_Vehicle input) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	wleArray 	: CM_WLEArray;
	wle		  	: CM_WorkListEntry;
	row 		: Integer;
	isFirst		: Boolean; //cnwmc5 - par 29716
begin
	if not inheritMethod(_vehicle) then
		return false;
	endif;
	
	if self.myDataTable = null then
		return false;	// should not happen
	endif;

	self.myDataTable.clearAllSelected;

	create wleArray transient;
	
	_vehicle.getAllWLEs(wleArray);
	
	isFirst := true; //cnwmc5 par 29716
	
	foreach wle in wleArray do
		//cnwmc5 - par 29716 - changed this if statement to work correctly
		if self.myDataTable.findObjectInRowReversed(wle, row) then 	//self.myDataTable.findObjectInRow(wle, row) then
			self.myDataTable.selectRow(row, false);
			
			//cnwmc5 - par 29716
			if isFirst = true then
				self.myDataTable.topRow:= row;
			endif;
			
			isFirst := false;
		endif;
	endforeach;
epilog
	if wleArray &lt;&gt; null then
		delete wleArray;
	endif;
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
