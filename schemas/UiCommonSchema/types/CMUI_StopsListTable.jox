        <access>readonly</access>
        <text>This is a collection of all stops that existed on the TrackedItem prior to any changes.
</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allSelectedStops" id="dd76d317-c363-4ef9-b864-68d91e3c65c6">
