    <JadeMethod name="ianExtWebservice" id="38298950-b709-483d-8c28-e64b5c00d57a">
        <source>ianExtWebservice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2025	navra1	Initial creation

*/

vars
	extDef			: CM_ExternalWebServiceDef;
	objArray : ObjectArray;
	now : TimeStamp;
	date : Date;
	time : Time;
	
begin
	now.setDateTime(2025,1,1,0,0,0,0);
	
	foreach extDef in app.myRoot.allExternalWebServices discreteLock do		
		if extDef.name = 'PANSWWS' and extDef.isKindOf(CM_APIEndpointServiceDef) then
			beginTransaction;
				extDef.CM_APIEndpointServiceDef.setLastSuccessfulTS(now);
