    <JadeMethod name="onOperatorChanged" id="2737709f-9534-452b-973f-6e3746e601bb">
        <source>onOperatorChanged() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2009	cnwjk3	Initial creation

*/

vars
	opTerm  	: CM_OperatorTerminal;
	operator : CM_Operator;
	ctrl			: Control;
begin
	self.doSetTemperatureLabels();
	
	//epr TFS 3581 15/3/17
	operator :=  self.cmbOperatorCode.listObject.CM_Operator;
	if operator &lt;&gt; null then
		opTerm:=operator.allOperatorTerminals[self.myTerminal];
		if opTerm &lt;&gt; null then
			self.getControlForEntDefRow(self.chkExternallyMonitor.name,ctrl);
			if ctrl &lt;&gt; null then
				ctrl.CMUI_FieldCheckBox.setValue(opTerm.isExternallyMonitored);
			endif;
		endif;
	endif;
epilog

end;</source>
