    <JadeMethod name="doDelete" id="4f95e436-726c-4cd3-b6f2-c95b96908b3a">
        <updating/>
        <source>doDelete(): Boolean updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteHookCode(self.myCurrentObject.CM_HookCode, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.clearDetailFrame();
			return true;
		else
			theResult := app.showErrorWarningDialog('Hook Code Maintenance', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="ad6946af-a56a-4810-8db7-ec00e92a474d">
        <updating/>
        <source>doSave(): Boolean updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------

// 25/09/2008	concms1	par 16762 - higlight any syntax errors
vars

	realHookCode,
	proxyHookCode	: CM_HookCode;
	cmif			: CMIF_HookCode;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	if self.myProxyObject = null then
		if self.mode = Mode_Add then
			create self.myProxyObject as CM_HookCode transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	create cmif transient;
	proxyHookCode := self.myProxyObject.CM_HookCode;
	cmif.myProxyHookCode := proxyHookCode;

	self.setHookCodeProxy(cmif);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateHookCode(cmif, realHookCode, app.myPassport);
		else
			app.myTrxUA.trxUpdateHookCode(cmif, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			if self.mode = Mode_Add then
				self.myCurrentObject := realHookCode;
			endif;
			return true;
		else
			// call method to highlight syntax errors before we display error dialog so the user can see both
			// the error text and the highlighted source.  The error dialog is modal so need to do it here.
			self.highlightSyntaxErrors (app.myPassport);
		
			theResult := app.showErrorWarningDialog('Hook Code Maintenance', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

epilog
	delete cmif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedLinks" id="866fe06f-74f8-4d93-9520-63b9ecfdcf12">
        <source>getSelectedLinks(_code : CM_HookCode) protected;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	link	: CM_HookLink;

begin

	self.allSelectedLinkObjects.clear();
	foreach link in _code.allHookLinks do
		if link.myLinkObject &lt;&gt; null then	//05 Jul 2016	NDL	TFS 2275
			self.allSelectedLinkObjects.add(link.myLinkObject);
		endif;
	endforeach;
	
	//05 Jul 2016	NDL	TFS 2275
	if _code.myHookType.hookType = HookType_CargoIdConversion then
		if self.allSelectedLinkObjects.isEmpty then
			self.allSelectedLinkObjects.add(app.myRoot);
		endif;
	endif;
	
	self.lstTblLinks.setSelected(self.allSelectedLinkObjects);

end;</source>
        <access>protected</access>
        <Parameter name="_code" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="highlightSyntaxErrors" id="87b692c4-b00c-43ef-8fc6-e4bac57e9c89">
        <source>highlightSyntaxErrors(_passport :CM_Passport)protected;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by concms1
// Purpose:     PAR 16762 - highlight any syntax errors
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error		:CM_Error;
	sa			:StringArray;
	pos, length	:Integer;
begin
	foreach error in _passport.allErrorWarnings do
		if error.errorCode = ERR_SYNTAX_ERROR_LONG then
			self.txtJadeCode.selLength := null;

			if error.fieldName &lt;&gt; null then
				delete sa;
				sa := error.fieldName.getTokens;
				
				if sa.size = 2 then
					pos		:= sa[1].Integer;
					length	:= sa[2].Integer;
					
					if length &gt; 0 then
						self.txtJadeCode.selStart	:= pos;
						self.txtJadeCode.selLength	:= length;
					endif;
				endif;
				return;
			endif;
		endif;
	endforeach;
epilog
	delete sa;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="58c8d11d-4edc-428b-91f1-3ff97e3f1c26">
        <updating/>
        <source>includeObject(_obj: CM_HookCode; _passport: CM_Passport): Boolean updating;
// -------------------------------------------
// Created 07 March 2005 by cnwdvb1
// -------------------------------------------
begin
	if _obj.myHookType.hookType = HookType_HMS_CheckPoint
	or _obj.myHookType.hookType = HookType_IsStopRelevant
	or _obj.myHookType.hookType = HookType_ContainerAttributes
	or _obj.myHookType.hookType = HookType_ContainerUnique	//29 Mar 2011	NDL	Par 27290
	or _obj.myHookType.hookType = HookType_LocationTranslation
	or _obj.myHookType.hookType = HookType_EDIFileFieldHook  //cnwrd1  25.11.08 par 18528
	or _obj.myHookType.hookType = HookType_EDIFileIncludeLine //cnwrd1  25.11.08 par 18528
	or _obj.myHookType.hookType = HookType_CashProForma		// cnwjre1 7/04/2015 Ghana cash
	or _obj.myHookType.hookType = HookType_VesselProforma		// jlgab1 MARCH18 TFS 37453
//+	or _obj.myHookType.hookType = HookType_InvoiceQuantity	// Aug 2010 24024
//+	or _obj.myHookType.hookType = HookType_InvoiceRate		// Aug 2010 24024
	then
		// These types not maintained from this form
		return false;
	endif;

	return not _obj.isNotAvailableForEntry;
end;</source>
        <Parameter name="_obj" type="CM_HookCode"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
