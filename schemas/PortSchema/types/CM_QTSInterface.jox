    <JadeMethod name="createCashReceiptRecordType8" id="082e1a5a-96eb-4d79-8808-247dbb3af1bf">
        <source>createCashReceiptRecordType8(_file : File input; _cashPayment : CM_CashPayment);
/*

Purpose:			
		Mapping Record Type 8 , Col 27
		Mandatory Col: 11
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	str 	: String;
	cashRec : CM_CashReceipt;
begin
	
	cashRec  	:= _cashPayment.myCashReceipt;
	
	str := 
	"8"                    &amp; Comma &amp;                   //01 - Record Type                                
	Space                  &amp; Comma &amp;                   //02 - Currency
	Space                  &amp; Comma &amp;                   //03 - Receipt Method  
	Space                  &amp; Comma &amp;                   //04 - Lockbox Number
	mapper(cashRec,"DepositDate")       &amp; Comma &amp;      //05 - Deposit Date                              
	Space                  &amp; Comma &amp;                   //06 - Deposit Time
	Space                  &amp; Comma &amp;                   //07 - Lockbox Batch Count
	Space                  &amp; Comma &amp;                   //08 - Lockbox Record Count
	Space                  &amp; Comma &amp;                   //09 - Lockbox Amount
	Space                  &amp; Comma &amp;                   //10 - Destination Bank Account
	Space                  &amp; Comma &amp;                   //11 - Bank Origination Number
	mapper(cashRec,"CustomerName")      &amp; Comma &amp;      //12 - Payment Interface Flexfield Segment 1
	mapper(cashRec,"ChequeNumber")      &amp; Comma &amp;      //13 - Payment Interface Flexfield Segment 2
	mapper(cashRec,"ChequeBank")        &amp; Comma &amp;      //14 - Payment Interface Flexfield Segment 3
	mapper(cashRec,"CashInv")           &amp; Comma &amp;      //15 - Payment Interface Flexfield Segment 4
	mapper(cashRec,"Voyage")            &amp; Comma &amp;      //16 - Payment Interface Flexfield Segment 5
	Space                  &amp; Comma &amp;                   //17 - Payment Interface Flexfield Segment 6
	Space                  &amp; Comma &amp;                   //18 - Payment Interface Flexfield Segment 7
	Space                  &amp; Comma &amp;                   //19 - Payment Interface Flexfield Segment 8
	mapper(cashRec,"PosRef")            &amp; Comma &amp;      //20 - Payment Interface Flexfield Segment 9
	mapper(cashRec,"CreatedBy")         &amp; Comma &amp;      //21 - Payment Interface Flexfield Segment 10
	mapper(cashRec,"MopCode")           &amp; Comma &amp;      //22 - Payment Interface Flexfield Segment 11
	mapper(cashRec,"MopDesc")           &amp; Comma &amp;      //23 - Payment Interface Flexfield Segment 12
	Space                  &amp; Comma &amp;                   //24 - Payment Interface Flexfield Segment 13
	Space                  &amp; Comma &amp;                   //25 - Payment Interface Flexfield Segment 14
	Space                  &amp; Comma &amp;                   //26 - Payment Interface Flexfield Segment 15
	Space                  ;                 		   //27 - END
	
	_file.writeLine(str);
epilog

end;</source>
