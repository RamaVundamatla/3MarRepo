        <source>comboBoxHMSWharf(pCmb : ComboBox input; _harbour : HMS_Harbour; _wharf : HMS_Wharf);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	pCmb.clear();
	
	if (not HMS_Harbour.hasInstance(_harbour)) then
		return;
	endif;
	
	pCmb.listCollection(_harbour.allWharves, true, 0);
	
	if _wharf &lt;&gt; null then
		pCmb.text := self.displayEntryHMSWharf(_wharf);
