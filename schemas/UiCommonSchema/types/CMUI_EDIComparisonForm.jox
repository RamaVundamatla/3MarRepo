    <JadeMethod name="doSaveEDITrackedItem" id="447e01a4-e35c-4801-9629-00f2548dd131">
        <source>doSaveEDITrackedItem()  : Boolean protected;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS

*/

vars
	ediUIAgent  : CMUI_EDIAgent;
	allPxyEDITIs : CM_EDITIById;
	theReturn : Integer;
begin
	create ediUIAgent transient;
	create allPxyEDITIs transient;
	
	ediUIAgent.saveEDITIChangesToPxy(self.tblData,allPxyEDITIs,app.myPassport);
	
	while true do
		app.myTrxUA.trxUpdateEDITIs(allPxyEDITIs, app.myPassport);
		if not app.myPassport.trxCompletedOK then

			theReturn := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return true;
epilog
	if allPxyEDITIs &lt;&gt; null then
		allPxyEDITIs.purge;
	endif;
	delete allPxyEDITIs;
	delete ediUIAgent;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveVerify" id="f80357b8-f9b0-4b8e-84cf-15d5eecd287c">
        <updating/>
        <source>doSaveVerify() updating;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS

*/

vars
	row : Integer;
begin
	row:= self.tblData.accessedRow.row;
	
	if not self.doSaveEDITrackedItem() then
		return;
	endif;
	
	//do verify
	if not self.doVerify() then
		return;
	endif;
		
	self.doEdit(false);
epilog

	self.tblData.accessRow(row);
	if self.tblData.allSelectedObjects.isEmpty then
		self.tblData.selectRow (row, false);
	endif;
end;</source>
    </JadeMethod>
