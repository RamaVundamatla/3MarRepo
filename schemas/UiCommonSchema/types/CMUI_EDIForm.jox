    <JadeMethod name="getEDITIClass" id="13d8202f-4ced-4cef-b73b-392182a34834">
        <source>getEDITIClass(): Class;
//----------------------------------------------------------------
//	Created:	01 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_EDIData) then
			return self.myCurrentObject.CM_EDIData.getEDITIType(null);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'expected an EDIData class');
			return null;
		endif;
	
	else
		return CM_EDITrackedItem;	
	endif;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getEdiFileForCustomsStop" id="4362c8bf-1a15-43c0-9a2e-2eccffc9ce23">
        <updating/>
        <source>getEdiFileForCustomsStop() : CM_EDIFile updating, protected;
// ---------------------------------------------------------------------------
// Created:		17 October 2007  by cnwvu1
// ---------------------------------------------------------------------------

vars
	ediCustomsStopTI: CM_EDICustomStopTI;

begin
	
	if self.tblEDITI.getControl(0).row &gt; 0 then
		ediCustomsStopTI:= self.tblEDITI.getControl(0).accessRow(tblEDITI.getControl(0).row).itemObject.CM_EDICustomStopTI;
		if ediCustomsStopTI &lt;&gt; null then
			return ediCustomsStopTI.myEDIFile;
		else
			return null;
		endif;
	else
		return null;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="getExistingXmlFor" id="7cf05f0a-a277-4b1f-843e-23345d0b8cf2">
        <source>getExistingXmlFor( _table : CM_DataTable; entTableDef : EntTableDef ):String;
/*
Purpose:	Extract the xml definition for a given ETDEF we want to use for tblEDITI

Date		Who		Reason
16 Mar 2012	cnwndl1	Initial creation	Par 29104
04 Mar 2013	cnwcs5	par 31087 - remove redundant code

*/

vars
	tagPrefix, tagSuffix, 
	defName, tmpDefStr 		: String;
	startPos				: Integer;
begin
	if entTableDef = null then
		return null;
	endif;
	
	defName 	:= entTableDef.name;	
	startPos 	:= 1;
	tmpDefStr 	:= self.xmlStrTblEDITI.cnEcGetNextTagValueOfName(_table.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then		
		tagPrefix 	:= J_key_LessThan.Character &amp; _table.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
		tagSuffix 	:= global.formatAsXMLSuffix(_table.XMLTag_EntTblDef &amp; defName).trimBlanks;

		return tagPrefix &amp; tmpDefStr &amp; tagSuffix;
	endif;
	
	return null;

epilog
	
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="entTableDef" type="EntTableDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileType" id="ad799eb9-c8df-4545-bbe8-60a84112a37c">
        <source>getFileType(_class: Class): Integer;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 7.6.3 PAR17931 - cnwsh3 Removed CM_EDIDataCBPCAMIR and CM_EDIDataASCX12309 as no data type of this was implemented.
// 14 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 29 Mar 2023 	jlika1 	TFS 57276  POB | QShips - Manual Load of XML EDI file
// 27 Jun 2023	jlizm1	TFS 53901 EUP VBS EDI
vars
	type	: Class;
begin
	type := _class;
	
	if type = CM_EDIDataBayPlan then
		return EDI_Index_BayPlan;
	elseif type = CM_EDIDataBookingRef then
		return EDI_Index_BookingRef;
	elseif type = CM_EDIDataPrenote then
		return EDI_Index_Prenote;
	elseif type = CM_EDIDataStowAdvice then
		return EDI_Index_StowAdvice;
	elseif type = CM_EDIDataLoadList then
		return EDI_Index_LoadList;
	elseif type = CM_EDIDataCustomStop then
		return EDI_Index_CustomStop;
	elseif type = CM_EDIDataOperatorStop then
		return EDI_Index_OperatorStop;
	elseif type = CM_EDIDataOutwardRail then
		return EDI_Index_OutwardRail;
	elseif type = CM_EDIDataGateDoc then
		return EDI_Index_GateDoc;
	elseif type = CM_EDIDataGenCSV then
		return EDI_Index_Generic;
	elseif type = CM_EDIDataGenXML then
		return EDI_Index_Generic;
	elseif type = CM_EDIDataTranship then
		return EDI_Index_Tranship;
	elseif type = CM_EDIDataFleet then //cnwrd1 ccms 1034 Fleet file
		return EDI_Index_Fleet;
	elseif type = CM_EDIDataFleetWagon then //MES 1010 InterfaceLoad jmn
		return EDI_Index_FleetWagon;		
	// 7.6.3 PAR17931 - cnwsh3 
	//elseif type = CM_EDIDataCBPCAMIR then
	//	return self.CAMIR;
	//elseif type = CM_EDIDataASCX12309 then
	//	return self.X12;
	//Anca Nelson 1618 11/04/08
	elseif type = CM_EDIDataProduct then
		return EDI_Index_CargoSubtype;
	elseif type = CM_EDIDataUSCustomsMessage then
		return EDI_Index_USCustomMessage; 
	elseif type = CM_EDIDataBillOfLading then
		return EDI_Index_USBOLManifest;
	elseif type = CM_EDIDataReleaseRequest then // cnwgb1 MES 1011 7.9.09
		return EDI_Index_ReleaseProduct;
	// cnwrs1 Messina CCMS 1008 Par 20320 Sept 2009
	elseif type = CM_EDIDataBOL then
		return EDI_Index_BOL;
	elseif type = CM_EDIDataStop then
		return EDI_Index_Stop;
	elseif type = CM_EDIDataTrain then
		return EDI_Index_Train;
	elseif type = CM_EDIDataVBSSlot then	// TFS 53901
		return EDI_Index_VBSSlot;
	elseif type = CM_EDIDataVoyage then
		return EDI_Index_Voyage;
	elseif type = CM_EDIDataVoyageQships then
		return EDI_Index_Voyage;
	elseif type = CM_EDIDataWagon then
		return EDI_Index_Wagon;
	elseif type = CM_EDIDataShipManifest then
		return EDI_Index_ShipManifest;
	elseif type = CM_EDIDataDeckPlan then
		return EDI_Index_ROROShipManifest;
	elseif type = CM_EDIDataTransManifest then	//06.Jun.2023 navsp1 TFS 58054
		return EDI_Index_TransportManifest;
	elseif type = CM_EDIDataCallOff then
		return EDI_Index_CallOff;
	else
		return null ;
	endif;	
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIndexForEDIDataSheet" id="b1bf6cba-5f65-46a5-af97-308e0c1b57d4">
        <source>getIndexForEDIDataSheet():Integer protected;
/*
Date		Who		Reason
18 Oct 2012	cnwcs5	Initial creation - par 30501
*/
vars
	index, result	:Integer;
	folder			:CMUI_Folder;
	sheet, clone	:CMUI_Sheet;
begin
	folder	:= self.fldDetail;
	sheet	:= self.shtEDIData;
	result	:= -1;	
	
	while true do
		clone := sheet.getControl(index);
		
		if clone = null or not clone.visible then
			break;
		endif;
		
		if folder.topSheet = clone then
			result := index;
			break;
		endif;
		
		index := index + 1;
	endwhile;
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNewEDIFile" id="4b289e05-7d5f-4ceb-b581-9170bcda9fa6">
        <source>getNewEDIFile();
// ---------------------------------------------------------------------------
// Created:     20 June 2003  by Jason Chapman  (cnwjc2)
// ----------   ----------  --------------------------------------------------
vars
	fileGet		 		: CMDFileOpen;
//	fileName			: String;
begin
	create fileGet;
	fileGet.cnEcSetFilters( true, 2, CNEC_FILE_FILTER_DATA );
//	fileGet.filter := '*.*';
	fileGet.fileName := '';
//	fileGet.initDir := self.myTerminal.getConfig(EDIFileDirectory).String;	// cnwrl1 27/05/2009 PAR 19732 - what it was
	fileGet.initDir := self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	if fileGet.open = CMDialog.Return_OK then	//user clicked OK
		self.txtFileName.text := fileGet.fileName;
		// navmd1 16/02/2023 TFS 59811 Enable transform of .json messages
		if fileGet.fileName.endsWith__(".json") then
			self.lblTransformAs.visible := true;
			self.cmbTransformAs.visible := true;
		else
			self.lblTransformAs.visible := false;
			self.cmbTransformAs.visible := false;
		endif;
	else
		self.txtFileName.text := null;
	endif;
epilog
	delete fileGet;	
end;</source>
    </JadeMethod>
    <JadeMethod name="getTblDataDef" id="878acea4-5a5e-4e56-b4d5-7387027b2f99">
        <source>getTblDataDef():EntTableDef;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	entDef	: EntTableDef;
begin
	if self.filterFileType &lt;&gt; null then 
		if self.filterFileType = EDI_Index_BayPlan then
			entDef := app.myController.getEntTableDef(ETDef_EDIFileBayPlanData);
		elseif self.filterFileType = EDI_Index_USCustomMessage then
			entDef := app.myController.getEntTableDef(ETDef_EDIFileUSCustomsMessage);
		elseif self.filterFileType = EDI_Index_USBOLManifest then
			entDef := app.myController.getEntTableDef(ETDef_EDIFileUSCustomsManifest);
		elseif self.filterFileType = EDI_Index_TransportManifest					//06.06.2023 navsp1 TFS 58054
		or self.filterFileType = EDI_Index_CallOff then
			entDef := app.myController.getEntTableDef(ETDef_EDIFileTransportManifest);
		else
			entDef := app.myController.getEntTableDef(ETDef_EDIFileDefaultData);
		endif;
	else
		entDef := app.myController.getEntTableDef(ETDef_EDIFileDefaultData);
	endif;
	return entDef;
	
end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getTblDetailDef" id="da15b7cc-bc0d-4f1e-b132-8dff88ff65c4">
        <updating/>
        <source>getTblDetailDef():EntTableDef updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 18 Jul 2023	navdap1	TFS 58923 EUP Calloff EDI Data Type / EDI Load
// 09 Aug 2023	navra1	TFS 59666 - EUP - CallOff fields not available in the column organiser
//
vars
	entDef	: EntTableDef;
begin
	
	if not global.isValidObject(self.myCurrentObject) then
		self.myCurrentObject := null;
	endif;
	
	if self.myCurrentObject = null then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataEdit);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataBayPlan) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataBayPlanEdit);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataStowAdvice) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataStowageEdit);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataLoadList) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataLoadList);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataCustomStop) or
		self.myCurrentObject.isKindOf(CM_EDIDataOperatorStop) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataCusResEdit);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataTranship) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataTranship);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataFleet) then //cnwrd1 ccms 1034 Fleet file
		entDef := app.myController.getEntTableDef(ETDef_EDIDataFleet);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataBillOfLading) then //US Customs &amp; Border Protection messaging changes.
		entDef := app.myController.getEntTableDef(ETDef_EDIDataUSBillOfLading);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataUSCustomsMessage) then //US Customs &amp; Border Protection messaging changes.
		entDef := app.myController.getEntTableDef(ETDef_EDIDataUSCustomsMessage);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataCargo) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataUser);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataCargoGroupAssign) then	//14 Aug 2015	NDL	Par 36608
		entDef := app.myController.getEntTableDef(ETDef_EDIDataCargoGrpAssEdit);
	elseif self.myCurrentObject.isKindOf(CM_EDIDataMultiMoveGroup) then	//17 Sep 2015	NDL	Par 36906
		entDef := app.myController.getEntTableDef(ETDef_EDIDataCargoGrpAssEdit);  // yep its the same etdef as the group assign... (Just teh EDI Details sheet)
	elseif self.myCurrentObject.isKindOf(CM_EDIDataOpCarrierAcessByCT) then
		entDef := app.myController.getEntTableDef(ETDef_EDIDataOpCarrierAccess);
	elseif self.getMyCurrentObject.isKindOf(CM_EDIDataTransManifest) then	//06.Jun.2023 navsp1 TFS 58054
		entDef := app.myController.getEntTableDef(ETDef_EDIDataTransportManifest);	//navra1 - TFS 59666 - 8th Aug 2023
	elseif self.getMyCurrentObject.isKindOf(CM_EDIDataCallOff) then			// TFS 58923
		entDef := app.myController.getEntTableDef(ETDef_EDIDataCallOff);			//navra1 - TFS 59666 - 8th Aug 2023
	else
		entDef := app.myController.getEntTableDef(ETDef_EDIDataEdit);
	endif;
	
	return entDef;
	
end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getTblEDITIXML" id="94858c5e-cc82-48c4-8a13-54e10be1500b">
        <updating/>
        <source>getTblEDITIXML(_userWindow: CM_UserWindow) updating;
/*
Purpose:	Get the saved XML for tblEDITI from the user window and store it
			in a property on the form for easy access.  Note this may include xml for multiple ETDEFs
			
/* Changes

Date		Name	TFS#		Description
============================================================================
19/03/2012	cnwndl1	Par 29104	Initial creation
04/03/2013	cnwcs5	par 31087 	Fix problem where we kept inserting CrLf
18/02/2019	jlgka1	42120		Fix problem where the User custom column
								is not being retained when the form closed and
								re-opened.
============================================================================*/

vars
	table		  : CM_DataTable;
	tagStr 	      : String;
	tmpStr		  : String;
	tmpStr2		  : String;
	startingPoint : Integer;
begin
	table	:= self.tblEDITI;
	tagStr 	:= table.XMLTag_Table &amp; table.name;
	//tmpStr 	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(tagStr);
	//jlgka1 TFS 42120 --&gt;
	startingPoint := 1;
	tmpStr 	:= _userWindow.xmlInfo.cnEcGetNextTagValueOfName(tagStr, startingPoint);
	tmpStr2 := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(tagStr, startingPoint);
	
	if tmpStr2 &lt;&gt; null and tmpStr2 &lt;&gt; tmpStr then
		tmpStr := tmpStr2;
	endif;
	//jlgka1 TFS 42120 &lt;--
	if not tmpStr.startsWith (CrLf) then		
		self.xmlStrTblEDITI := global.formatAsXMLPrefix(tagStr) &amp; tmpStr &amp; global.formatAsXMLSuffix(tagStr);
	else
		// so we don't keep adding CrLf
		self.xmlStrTblEDITI := J_key_LessThan.Character &amp; tagStr &amp; J_key_GreaterThan.Character &amp; 
								tmpStr &amp; 
								global.formatAsXMLSuffix(tagStr);
	endif;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ba38b1e7-c8a8-4f35-8f65-ba777bde2e83">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Changed On  Changed By  Reason	
----------  ----------  --------------------------------------------------
04/03/2013	cnwcs5		par 31087 - no need to get XML string for currenttblEDITI as we would have
								  - updated it when we resized a column or changes settings using column organisor
*/
vars
	xml : String;
begin
	xml := inheritMethod();

	xml := xml &amp; global.formatAsXML(self.XML_SPLITMAINT, self.sptMain.leftToRightRatio.String);
	xml := xml &amp; self.xmlStrTblEDITI;	// 16 Mar 2012	NDL	Par 29104
	
	return xml;
end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handle14051Error" id="32cceab0-7725-4d65-b292-4e3e98b00785">
        <updating/>
        <source>handle14051Error(_exObj: Exception; _table : CM_BaseTable; _exOccurred : Boolean output ): Integer updating;
//
//10 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar - dont add CrLf when doing writline
//
vars

begin
	if _exObj.errorCode = 14051 then
		_exOccurred := true;
		abortTransaction;
		abortTransientTransaction;
		if _exObj.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handle89095" id="4389ac4c-0d83-4122-86fd-56f593b57d74">
        <updating/>
        <source>handle89095(_exObj: Exception; _exOccurred : Boolean output ): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2020	jlgndl1	Initial creation	TFS 49485

*/

vars

begin
	if _exObj.errorCode = Input_required_field_ediFleCls then
		_exOccurred := true;
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="333b1264-71a4-4d80-9ea9-a51d9db6046d">
        <updating/>
        <source>handleNotification(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
28/08/2012	cnwcs5	par 30134 	minor rework 
18/02/2013	cnwcs5	par 30970 	actually 31086 but patch goiing out with 30970
05 Feb 2016	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
18/07/2018 	jlgns1	Bug 39370: 	POL - [Fwd: ##RE-8177## : EDI Operations Fault]
20 Jul 2018	jlgrs1	TFS 39370 	PON reflect changes in 2 copies
07 Jul 2019	jlgka1 	TFS 45459	PNL - Error 4 in EDI notification.
09 Jul 2019 jlgka1 	TFS 45529	EDI Operation - 1090 Error when loading first file after opening form.
27 Jul 2019 jlgmd1	TFS 45814	PNL - Error 4 in EDI Form
15 Nov 2022 navhl20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
30 Nov 2022 navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
27 May 2024 navsp1  Bug 60229: EUP | FR 53824 - Verify Error display UI changes
============================================================================*/
vars
	event				: Integer;
	table				: CM_DataTable;
	numItems			: Integer;	//	Bug 39370
	breakOut			: Boolean;	//	Bug 39370
	invalid 			: Boolean;
	currObjInvalid		: Boolean;  // jlgka1 TFS 45459
	
begin
	event := self.myTerminal.getEventFromTerminalEvent(_eventType);

	if _eventType = Object_Delete_Event then
		// expect this to be an EDIData delete
		table := self.tblData;
		
		if self.mode = CM_TableViewForm.Mode_Update and table.allSelectedObjects.includes(_object) then
			app.msgBox(app.getErrorString1(UserDeletedACurrentItem, app.getErrorString(EDI_Data)), app.getErrorString(EDI_Data), MsgBox_Information_Icon);
			
			table.removeItemObject(_object);
			table.clearAllSelected();
			table.colourRows(self.colorRow1, self.colorRow2);
			
			self.mode := Mode_View;
			
			self.setControls();
			self.clearErrorWarnings();
			self.setControls();
			
			if self.myCurrentObject = _object then
				self.myCurrentObject := null;
			endif;
			
		elseif self.mode = CM_TableViewForm.Mode_View then
			table.removeItemObject(_object);
		endif;

		// so the user can cause the rowColumnChg event
		table.row		:= table.fixedRows;
		table.column 	:= table.columns;
		
	elseif event = EVENT_EDI_EDITI_UPDATE or event = EVENT_EDI_EDITI_VERIFY then			//30.11.2022 navma1 #52499
		// update editi in table
		if _userInfo.isKindOf(CM_EDITrackedItem) then
			self.doUpdateEDITI(_userInfo.CM_EDITrackedItem,event);							//30.11.2022 navma1 #52499
		endif;
		
	elseif event = Event_CusResEDITI_Create then
		//add object if suitable
		self.doAddCreatedEDITI(_object.CM_EDIFile);
		
	elseif event = Event_EDITI_Delete then
		// Delete of EDI Tracked Item(s) in table 
		self.doRemoveDeletedEDITIs(_object.CM_EDIData, _userInfo);

	elseif event = EDIData_Create_Event then 
		if not self.amInitialisingWithObject then	// par 30970
			if self.tblData.rows &lt; 32000 then
				on Exception do app.handleDeletedObject(exception, _userInfo.Object, invalid);				
				
				//jlgka1 TFS 45459 --&gt;
				if self.myCurrentObject &lt;&gt; null then
					on Exception do app.handleDeletedObject(exception, self.myCurrentObject, currObjInvalid);	//jlgka1 TFS 45459
					//need to access the object for the exception handle to get trigger
					self.myCurrentObject.edition;
					if currObjInvalid then
						// If our current object is no longer valid then clear it. (we should have a queued delete note behind us)
						self.myCurrentObject := null;		// 24/07/2019 jlgmd1 TFS 45816
					endif;
				endif;
				//jlgka1 TFS 45459 &lt;--
				
				if _userInfo &lt;&gt; null and
				   self.myCurrentObject &lt;&gt; null and
				   self.myCurrentObject.class = _userInfo.Object.class then
				   //	self.updateTblData(_userInfo.CM_EDIData);					//	Bug 39370
					self.addObjectToTable(_userInfo.CM_EDIData,numItems,breakOut);	//	Bug 39370
				endif;
			endif;
		endif;	
	
	elseif event = Progress_Update_Event then
		self.updateProgressAuto(_userInfo.CMIF_Monitor);
	else 
		if _object.isKindOf(CM_EDIData) then
			if self.tblData.rows &lt; 32000 then
//				self.updateTblData(_object.CM_EDIData); 

				// 24/07/2019 jlgmd1 TFS 45816
				if self.myCurrentObject &lt;&gt; null then
					on Exception do app.handleDeletedObject(exception, self.myCurrentObject, currObjInvalid);
					self.myCurrentObject.edition;
					if currObjInvalid then
						// If our current object is no longer valid then clear it. (we should have a queued delete note behind us)
						self.myCurrentObject := null;
					endif;
				endif;

				if _object &lt;&gt; null and
				   self.myCurrentObject &lt;&gt; null and
				   self.myCurrentObject.class = _object.class then
					self.myChangedObject := _object.CM_EDIData;
					self.doRefreshWithTimer();
					//self.tblData.removeItemObject(_object);			// 15 Nov 2022 navhl20 TFS 55084				//TFS 60229
					//self.addObjectToTable(_object.CM_EDIData,numItems,breakOut);	// 15 Nov 2022 navhl20 TFS 55084	//TFS 60229 - This was calling infinite syatem event (infinite loop)
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
